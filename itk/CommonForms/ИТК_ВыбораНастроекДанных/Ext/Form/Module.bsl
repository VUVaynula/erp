#Область ОписаниеПеременных

&НаКлиенте
Перем ИдентификаторПоследнейВыделеннойСтроки Экспорт; // Идентификатор последней выделенной строки

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Режим = Параметры.Режим;
	ТекущееИмя = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "ТекущееИмя");
	КлючНастроек = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "Ключ");
	
	ИнициализацияЭлементовФормы();
	
	ЗаполнениеДереваНастроек();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НастройкиПриАктивизацииСтроки(Элемент)
	
	ИдентификаторТекущейСтроки = Элемент.ТекущаяСтрока;
	
	Если ИдентификаторТекущейСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Имя = Элемент.ТекущиеДанные.Имя;
	
	Если ИдентификаторПоследнейВыделеннойСтроки <> ИдентификаторТекущейСтроки Тогда 
		
		ИдентификаторПоследнейВыделеннойСтроки = ИдентификаторТекущейСтроки;
		ОбновитьЭлементыФормы();
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ИмяНастройкиОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, СтандартнаяОбработка)
	
	НайденнаяСтрока = НайтиСтроку(Текст);
	Если НайденнаяСтрока = Неопределено Тогда
		Возврат
	КонецЕсли;
	
	Элементы.Настройки.ТекущаяСтрока = НайденнаяСтрока.ПолучитьИдентификатор();
	ТекущийЭлемент = Элементы.Настройки;
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ОсновноеДействие();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Удалить(Команда)
	
	ТекущиеДанные = Элементы.Настройки.ТекущиеДанные;
	ИмяНастройка = ТекущиеДанные.Имя;
	
	СтрокиВопроса = Новый Массив;
	Если ТекущееИмя = ИмяНастройка Тогда
		СтрокиВопроса.Добавить(НСтр("ru = 'Внимание! Удаляется настройка с которой производится работа';
									|en = 'Attention! The setting with which the work is performed is deleted'"));
	КонецЕсли;
	СтрокиВопроса.Добавить(СтрШаблон(НСтр("ru = 'Будет удалена настройка: %1. Продолжить?';
											|en = 'This will remove the setting: %1. Continue?'"), ИмяНастройка));
	
	ТекстВопроса = СтрСоединить(СтрокиВопроса, Символы.ПС);
	ЗаголовокВопроса = ИТК_КонсольРазработчикаКлиентСервер.Представление();
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ВопросПодтвержденияУдаленияЗавершение", ЭтотОбъект);
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет, ,	КодВозвратаДиалога.Да, ЗаголовокВопроса);

КонецПроцедуры

&НаКлиенте
Процедура Действие(Команда)
	
	ОсновноеДействие();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ИнициализацияЭлементовФормы()
	
	УстановитьУсловноеОформление();
	
	РежимСохранение = (Режим = ИТК_Перечисления.РежимДиалогаУправлениеДаннымиВНастройкахСохранение());
	РежимЗагрузка = (Режим = ИТК_Перечисления.РежимДиалогаУправлениеДаннымиВНастройкахЗагрузка());
	РежимВыбор = (Режим = ИТК_Перечисления.РежимДиалогаУправлениеДаннымиВНастройкахВыбор());
	
	Если РежимСохранение Тогда
		ЗаголовокФормы = НСтр("ru = 'Сохранение данных (в настройки)';
								|en = 'Saving data (in settings)'");
		Элементы.Сохранить.КнопкаПоУмолчанию = Истина;
	ИначеЕсли РежимЗагрузка Тогда
		ЗаголовокФормы = НСтр("ru = 'Загрузка данных (из настроек)';
								|en = 'Download data (from settings)'");
		Элементы.Загрузить.КнопкаПоУмолчанию = Истина;
	ИначеЕсли РежимВыбор Тогда
		ЗаголовокФормы = НСтр("ru = 'Выбор данных (из настроек)';
								|en = 'Select data (from settings)'");
		Элементы.Выбрать.КнопкаПоУмолчанию = Истина;
	КонецЕсли;
	
	ИТК_ФормаКлиентСервер.Заголовок(ЭтотОбъект, ЗаголовокФормы);
	
	Элементы.Сохранить.Видимость = РежимСохранение;
	Элементы.Загрузить.Видимость = РежимЗагрузка;
	Элементы.Выбрать.Видимость = РежимВыбор;
	
	НедоступноЧтениеНастроекДругихПользователей = Не ПравоДоступа("АдминистрированиеДанных", Метаданные);
	Элементы.НедоступноЧтениеНастроекДругихПользователей.Видимость = РежимЗагрузка И НедоступноЧтениеНастроекДругихПользователей;
	
	Элементы.Имя.Видимость = РежимСохранение;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "Настройки", Новый Структура("Текст", НСтр("ru = '<Не авторизован>';
																										|en = '<Not authorized>'")), "Настройки.Имя", "");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	ТекущиеДанные = Элементы.Настройки.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ТекущиеДанныеРодитель = Неопределено;
	Иначе
		ТекущиеДанныеРодитель = ТекущиеДанные.ПолучитьРодителя();
	КонецЕсли;
	
	ЭтоНастройка = СтрокаНастройка(ТекущиеДанные);
	ЭтоСвояНастройка = ЭтоНастройка И ТекущиеДанныеРодитель = Неопределено;
	
	ДоступностьУдаления = ЭтоСвояНастройка И ЗначениеЗаполнено(ТекущиеДанные.Имя);
	Элементы.Удалить.Доступность = ДоступностьУдаления;
	Элементы.КонтекстноеМенюУдалить.Доступность = ДоступностьУдаления;
	
	Элементы.Загрузить.Доступность = ЭтоНастройка;
	Элементы.Выбрать.Доступность = ЭтоНастройка;
	
КонецПроцедуры

&НаКлиенте
Функция НайтиСтроку(Имя)
	
	Результат = Неопределено;
	
	Для Каждого Строка Из Настройки.ПолучитьЭлементы() Цикл
		
		Если Строка.Имя = Имя
				И СтрокаНастройка(Строка) Тогда
				
			Результат = Строка;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;

КонецФункции

&НаКлиенте
Функция СтрокаНастройка(Строка)
	
	Возврат (Строка <> Неопределено 
				И Строка.Картинка = БиблиотекаКартинок.ИТК_ТипХраненияДанныхНастройка);
	
КонецФункции

&НаСервере
Процедура ЗаполнениеДереваНастроек()
	
	ДоступноЧтениеНастроекДругихПользователей = НЕ ПравоДоступа("АдминистрированиеДанных", Метаданные);
	ВключатьЧужие = (ДоступноЧтениеНастроекДругихПользователей 
					И Режим <> ИТК_Перечисления.РежимДиалогаУправлениеДаннымиВНастройкахСохранение());
	СохраненныеНастройки = ИТК_ДанныеВНастройках.Получить(КлючНастроек, ВключатьЧужие);
	
	Для Каждого ОписаниеНастройки Из СохраненныеНастройки.Пользователь Цикл 
		ДобавитьСтроку(Настройки, ОписаниеНастройки.Значение, БиблиотекаКартинок.ИТК_ТипХраненияДанныхНастройка);
	КонецЦикла;
	
	Если НЕ ВключатьЧужие Тогда 
		Возврат;
	КонецЕсли;
	
	ГруппаНастройкиДругихПользователей = Неопределено;
	ГруппыПользователи = Новый Соответствие;
	
	Для Каждого ОписаниеНастройки Из СохраненныеНастройки.Чужие Цикл
		
		Если ГруппаНастройкиДругихПользователей = Неопределено Тогда
			
			ГруппаНастройкиДругихПользователей = ДобавитьСтроку(Настройки, НСтр("ru = 'Другие пользователи';
																						|en = 'Other users'"), БиблиотекаКартинок.ИТК_Папка);
			
		КонецЕсли;
		
		ГруппаПользователь = ГруппыПользователи.Получить(ОписаниеНастройки.Значение);
		Если ГруппаПользователь = Неопределено Тогда
			
			ГруппаПользователь = ДобавитьСтроку(ГруппаНастройкиДругихПользователей, ОписаниеНастройки.Значение, БиблиотекаКартинок.ИТК_Пользователь);
			ГруппыПользователи.Вставить(ОписаниеНастройки.Значение, ГруппаПользователь); 
			
		КонецЕсли;
		
		ДобавитьСтроку(ГруппаПользователь, ОписаниеНастройки.Представление, БиблиотекаКартинок.ИТК_ТипХраненияДанныхНастройка);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ДобавитьСтроку(Родитель, Имя, Картинка)

	НоваяСтрока = Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.Имя = Имя;
	НоваяСтрока.Картинка = Картинка;
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаКлиенте
Процедура ВопросПодтвержденияУдаленияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		ТекущиеДанные = Элементы.Настройки.ТекущиеДанные;
		
		ИТК_КонсольРазработчика.УдалитьДанныеВНастройках(ТекущиеДанные.Имя);
		Оповестить("ИзмененыПоследниеОткрытыеДанные");

		Настройки.ПолучитьЭлементы().Удалить(НайтиСтроку(ТекущиеДанные.Имя));
		
		Если Имя = ТекущиеДанные.Имя Тогда
			Имя = Неопределено;
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОсновноеДействие()
	
	ТекущиеДанные = Элементы.Настройки.ТекущиеДанные;
	РежимСохранение = (Режим = ИТК_Перечисления.РежимДиалогаУправлениеДаннымиВНастройкахСохранение());
	
	Если НЕ (СтрокаНастройка(ТекущиеДанные)
				ИЛИ РежимСохранение) Тогда
		Возврат;
	КонецЕсли;
	
	// Определение имени настройки
	Если РежимСохранение Тогда
		ИмяНастройки = Имя;
	Иначе
		ИмяНастройки = ТекущиеДанные.Имя;
	КонецЕсли;
	
	Если Режим = ИТК_Перечисления.РежимДиалогаУправлениеДаннымиВНастройкахЗагрузка() Тогда
		
		ТекущиеДанныеРодитель = ТекущиеДанные.ПолучитьРодителя();
		
		Если ТекущиеДанныеРодитель = Неопределено Тогда
			
			Результат = ИмяНастройки;
			
		Иначе
			
			Результат = Новый Структура;
			Результат.Вставить("Имя", ИмяНастройки);
			Результат.Вставить("Пользователь", ТекущиеДанныеРодитель.Имя);
			
		КонецЕсли;
		
		Закрыть(Результат);
		
	ИначеЕсли РежимСохранение Тогда
		
		// Проверим не пустое ли имя
		Если НЕ ЗначениеЗаполнено(ИмяНастройки) Тогда
			
			ПоказатьПредупреждение( , НСтр("ru = 'Не заполнено имя настройки';
											|en = 'Setting name not filled'"), , ИТК_КонсольРазработчикаКлиентСервер.Представление());
			ТекущийЭлемент = Элементы.Имя;
			
			Возврат;
			
		КонецЕсли;
		
		НайденнаяСтрока = НайтиСтроку(ИмяНастройки);

		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Имя", ИмяНастройки);
		
		ОписаниеОповещенияЗавершения = Новый ОписаниеОповещения("ВопросСохраненияЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		Если НайденнаяСтрока = Неопределено Тогда

			ВыполнитьОбработкуОповещения(ОписаниеОповещенияЗавершения, КодВозвратаДиалога.Да);
			
		Иначе
			
			ТекстВопроса = СтрШаблон(НСтр("ru = 'Настройка: %1 уже существует. Заменить?';
											|en = 'Customization: %1 already exists. Replace?'"), ИмяНастройки);
			ПоказатьВопрос(ОписаниеОповещенияЗавершения, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да, ИТК_КонсольРазработчикаКлиентСервер.Представление());
			
		КонецЕсли; 
		
	Иначе
		
		Закрыть(ИмяНастройки);

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросСохраненияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Закрыть(ДополнительныеПараметры.Имя);

КонецПроцедуры

#КонецОбласти
