#Область ОписаниеПеременных

&НаКлиенте
Перем ТаймерЗакрытия;

&НаКлиенте
Перем ДанныеАвторизации;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИмяПользователя = Параметры.ИмяПользователя;
	УникальныйИдентификаторПользователя = Параметры.УникальныйИдентификаторПользователя;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(ДанныеАвторизации) Тогда
		
		Отказ = Истина;
		ВернутьДанныеАвторизации();

	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Запуск(Команда)
	
	ТаймерЗакрытия = 30;
	ОбновитьЭлементыФормы();
	ПодключитьОбработчикОжидания("ПодключаемыйВернутьДанныеАвторизации", 1);
	
	ДанныеАвторизации = ПодменитьДанныеАвторизации(УникальныйИдентификаторПользователя);
	
	// BSLLS:UsingHardcodeSecretInformation-off
	Пароль = "Qwerty123456789!";
	// BSLLS:UsingHardcodeSecretInformation-on
	
	Команда = СтрШаблон("/N""%1"" /P""%2""", ИмяПользователя, Пароль);
	
	#Если НЕ ВебКлиент Тогда
		ЗапуститьСистему(Команда);
	#КонецЕсли
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПодключаемыйВернутьДанныеАвторизации()
	
	ТаймерЗакрытия = ТаймерЗакрытия - 1;
	ОбновитьЭлементыФормы();
	
	Если ЗначениеЗаполнено(ТаймерЗакрытия) Тогда
		Возврат;
	КонецЕсли;
	
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура ВернутьДанныеАвторизации()
	
	Если ЗначениеЗаполнено(ДанныеАвторизации) Тогда
		
		ВернутьДанныеАвторизацииПользователя(ДанныеАвторизации);
		ДанныеАвторизации = Неопределено;
		
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("ПодключаемыйЗакрытьПослеОжидания", 0.1, Истина);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ВернутьДанныеАвторизацииПользователя(ДанныеАвторизации)
	
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(ДанныеАвторизации.УникальныйИдентификатор);
	ЗаполнитьЗначенияСвойств(ПользовательИБ, ДанныеАвторизации, , "УникальныйИдентификатор");
	
	ПользовательИБ.Записать();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйЗакрытьПослеОжидания()
	
	Закрыть();

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПодменитьДанныеАвторизации(УникальныйИдентификаторПользователя)
	
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(УникальныйИдентификаторПользователя);
	
	Результат = Новый Структура;
	Результат.Вставить("УникальныйИдентификатор", ПользовательИБ.УникальныйИдентификатор);
	Результат.Вставить("АутентификацияСтандартная", ПользовательИБ.АутентификацияСтандартная);
	Результат.Вставить("ЗапрещеноИзменятьПароль", ПользовательИБ.ЗапрещеноИзменятьПароль);
	Результат.Вставить("СохраняемоеЗначениеПароля", ПользовательИБ.СохраняемоеЗначениеПароля);
	
	ПользовательИБ.АутентификацияСтандартная = Истина;
	ПользовательИБ.ЗапрещеноИзменятьПароль = Истина;
	
	СохраняемоеЗначениеПароля = "UFsxOq/KlPH4n3Txbhh6F6hgG+A=,aQp2yfJ4uMWBrAqjri9wVyXy/M4="; //Это хэш-функция строки "Qwerty123456789!"
	ПользовательИБ.СохраняемоеЗначениеПароля = СохраняемоеЗначениеПароля;
	
	ПользовательИБ.Записать();
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	Элементы.ФормаЗакрыть.Заголовок = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(НСтр("ru = 'Закрыть';
																						|en = 'Close'"), ТаймерЗакрытия);
	
КонецПроцедуры

#КонецОбласти
