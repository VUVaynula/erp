#Область ОписаниеПеременных

&НаКлиенте
Перем ПользователиПоследнееВыделение;

&НаКлиенте
Перем ИдетПолучениеПользователей;

&НаКлиенте
Перем АктивныеПользователиПоследнееВыделение;

&НаКлиенте
Перем ИдетПолучениеАктивныхПользователей;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ОтображатьОтключенных = Истина;
	
	НачальнаяСтраница = ИТК_ОбщийКлиентСервер.Свойство(Параметры, "НачальнаяСтраница");
	Если ЗначениеЗаполнено(НачальнаяСтраница) Тогда
		Элементы.Страницы.ТекущаяСтраница = Элементы["Страница" + НачальнаяСтраница];
	КонецЕсли;
	
	ОбновитьЭлементыФормыПриСозданииНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИТК_ОбщийКлиент.ОбработчикПриОткрытии(Отказ);
	
	ИдетПолучениеПользователей = Ложь;
	ИдетПолучениеАктивныхПользователей = Ложь;
	
	ОбновитьПользователей();
	
	Если Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаАктивныеПользователи Тогда
		ОбновитьАктивныхПользователейИБ();
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("ПодключаемыйОбновлениеПользователей", 60);
	ПодключитьОбработчикОжидания("ПодключаемыйОбновлениеАктивныхПользователей", 60);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИТК_ПользовательИБ_Записан" Тогда
		
		ОбновитьПользователей();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	Если Не ЗначениеЗаполнено(КоличествоАктивныхПользователей) Тогда
		ОбновитьАктивныхПользователейИБ();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПользователиИБ

&НаКлиенте
Процедура ПользователиИБПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.ПользователиИБ.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		
		ПользователиПоследнееВыделение = Неопределено;
		Возврат;
		
	КонецЕсли;
	
	ПользователиПоследнееВыделение = Новый Структура("Пользователь", ТекущиеДанные.Пользователь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПользователиИБВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ВыбранныеДанные = ПользователиИБ.НайтиПоИдентификатору(ВыбраннаяСтрока);
	
	ИТК_ТуллкитКлиент.ОткрытьИнструмент(ИТК_Перечисления.ИнструментРедактированиеПользователяИБ(),
											ВыбранныеДанные.УникальныйИдентификатор, ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыАктивныеПользователи

&НаКлиенте
Процедура АктивныеПользователиПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.АктивныеПользователи.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		
		АктивныеПользователиПоследнееВыделение = Неопределено;
		Возврат;
		
	КонецЕсли;
	
	АктивныеПользователиПоследнееВыделение = Новый Структура("Пользователь", ТекущиеДанные.Пользователь);
	
КонецПроцедуры

&НаКлиенте
Процедура АктивныеПользователиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ВыбранныеДанные = АктивныеПользователи.НайтиПоИдентификатору(ВыбраннаяСтрока);
	ИТК_ТуллкитКлиент.ОткрытьИнструмент(ИТК_Перечисления.ИнструментРедактированиеПользователяИБ(),
											ВыбранныеДанные.УникальныйИдентификатор, ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Обновить(Команда)
	
	ОбновитьПользователей();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтображатьОтключенных(Команда)
	
	ОтображатьОтключенных = Не ОтображатьОтключенных;
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьАктивныхПользователей(Команда)
	
	ОбновитьАктивныхПользователейИБ();
	
КонецПроцедуры

&НаКлиенте
Процедура ЖурналРегистрацииПоПользователю(Команда)
	
	ТекущиеДанные = Элементы.ПользователиИБ.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Пользователь", ТекущиеДанные.Пользователь);
	
	ИТК_ФормаКлиент.ОткрытьЖурналРегистрации(ПараметрыФормы);
	
КонецПроцедуры

&НаКлиенте
Процедура ЖурналРегистрацииПоАктивномуПользователю(Команда)
	
	ТекущиеДанные = Элементы.АктивныеПользователи.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Пользователь", ТекущиеДанные.Пользователь);
	
	ИТК_ФормаКлиент.ОткрытьЖурналРегистрации(ПараметрыФормы);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьПодПользователем(Команда)
	
	ТекущиеДанные = Элементы.ПользователиИБ.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьЗапускПодПользователем(ТекущиеДанные.Пользователь, ТекущиеДанные.УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьПодАктивнымПользователем(Команда)
	
	ТекущиеДанные = Элементы.АктивныеПользователи.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ОткрытьЗапускПодПользователем(ТекущиеДанные.Пользователь, ТекущиеДанные.УникальныйИдентификатор);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьПользователей()
	
	ИдетПолучениеПользователей = Истина;
	
	ДлительнаяОперация = ОбновитьПользователейНаСервере(УникальныйИдентификатор);
	
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершеноОбновлениеПользователей", ЭтотОбъект);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОбновитьПользователейНаСервере(УникальныйИдентификатор)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыПроцедуры = Новый Структура;
	
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_Пользователи.ДанныеПользователей", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершеноОбновлениеПользователей(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		ОбновитьПользователейНаФорме(Результат.АдресРезультата);
		ИТК_ФормаКлиент.ВосстановитьВыделениеТаблицы(ЭтотОбъект, "ПользователиИБ", ПользователиПоследнееВыделение);
		
	КонецЕсли;
	
	ИдетПолучениеПользователей = Ложь;
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервере
Процедура ОбновитьПользователейНаФорме(АдресРезультата)
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	ЗначениеВРеквизитФормы(Результат, "ПользователиИБ");
	КоличествоПользователей = ПользователиИБ.Количество();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьАктивныхПользователейИБ()
	
	ИдетПолучениеАктивныхПользователей = Истина;
	
	ДлительнаяОперацияАктивныеПользователи = ОбновитьАктивныхПользователейНаСервере(УникальныйИдентификатор);
	
	ПараметрыОжидания = ИТК_ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершеноОбновлениеАктивныхПользователей", ЭтотОбъект);
	ИТК_ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперацияАктивныеПользователи, ОповещениеОЗавершении, ПараметрыОжидания);
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОбновитьАктивныхПользователейНаСервере(УникальныйИдентификатор)
	
	ПараметрыВыполнения = ИТК_ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыПроцедуры = Новый Структура;
	
	Возврат ИТК_ДлительныеОперации.ВыполнитьВФоне("ИТК_Пользователи.ДанныеАктивныхПользователей", ПараметрыПроцедуры, ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ЗавершеноОбновлениеАктивныхПользователей(Результат, ДополнительныеПараметры) Экспорт
	
	ИТК_ДлительныеОперацииКлиент.ПодготовитьРезультатВыполнения(Результат);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		
		ОбновитьАктивныхПользователейНаФорме(Результат.АдресРезультата);
		ИТК_ФормаКлиент.ВосстановитьВыделениеТаблицы(ЭтотОбъект, "АктивныеПользователи", АктивныеПользователиПоследнееВыделение);
		
	КонецЕсли;
	
	ИдетПолучениеАктивныхПользователей = Ложь;
	ОбновитьЭлементыФормы();

КонецПроцедуры

&НаСервере
Процедура ОбновитьАктивныхПользователейНаФорме(АдресРезультата)
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	ЗначениеВРеквизитФормы(Результат, "АктивныеПользователи");
	КоличествоАктивныхПользователей = АктивныеПользователи.Количество();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Оформление = Новый Структура("ЦветТекста", ИТК_ОбщийКлиентСервер.ЦветТекстаНедоступно());
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "ПользователиИБ", Оформление, "ПользователиИБ.Отключен", Истина);
	
	Оформление = Новый Структура("Шрифт", ИТК_ОбщийКлиентСервер.ШрифтЖирный());
	ИТК_Форма.ДобавитьУсловноеОформление(УсловноеОформление, "АктивныеПользователи", Оформление, "АктивныеПользователи.Конфигуратор", Истина);

КонецПроцедуры

&НаСервере
Процедура ОбновитьЭлементыФормыПриСозданииНаСервере()
	
	УстановитьУсловноеОформление();
	
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.ПользователиИБ);
	ИТК_ФормаКлиентСервер.ОтображатьСтрокуПоискаТаблицыФормы(Элементы.АктивныеПользователи);
	
	Состояние = НСтр("ru = 'Получение списка пользователей...';
					|en = 'Getting a list of users...'");
	ИТК_ФормаКлиентСервер.ОтображениеСостоянияТабличногоДокумента(Элементы.ИдетПолучениеПользователейТабличныйДокумент, Состояние);
			
	Состояние = НСтр("ru = 'Получение списка активных пользователей...';
					|en = 'Getting a list of active users...'");
	ИТК_ФормаКлиентСервер.ОтображениеСостоянияТабличногоДокумента(Элементы.ИдетПолучениеАктивныхПользователейТабличныйДокумент, Состояние);
	
	Элементы.ПользователиИБАдресЭлектроннойПочты.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.15");
	Элементы.ПользователиИБЗапрещеноВосстанавливатьПароль.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.15");
	
	Элементы.ПользователиИБАутентификацияOpenIDConnect.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.19");
	Элементы.ПользователиИБАутентификацияТокеномДоступа.Видимость = ИТК_ОбщийКлиентСервер.ПоддерживаетсяПлатформой("8.3.21");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	Элементы.ИдетПолучениеПользователейТабличныйДокумент.Видимость = ИдетПолучениеПользователей;
	Элементы.ПользователиИБ.Видимость = Не ИдетПолучениеПользователей;
	Элементы.ПользователиИБОтображатьОтключенных.Пометка = ОтображатьОтключенных;
	
	Если ОтображатьОтключенных Тогда
		ОтборСтрок = Неопределено;
	Иначе
		ОтборСтрок = Новый ФиксированнаяСтруктура("Отключен", Ложь);
	КонецЕсли;
	Элементы.ПользователиИБ.ОтборСтрок = ОтборСтрок;
	
	#Если ВебКлиент Тогда
		ДоступенЗапускПодПользователем = Ложь;
	#Иначе
		ДоступенЗапускПодПользователем = Истина;
	#КонецЕсли
	Элементы.ПользователиИБЗапуститьПодПользователем.Видимость = ДоступенЗапускПодПользователем;

	Элементы.ИдетПолучениеАктивныхПользователейТабличныйДокумент.Видимость = ИдетПолучениеАктивныхПользователей;
	Элементы.АктивныеПользователи.Видимость = Не ИдетПолучениеАктивныхПользователей;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьЗапускПодПользователем(ИмяПользователя, УникальныйИдентификаторПользователя)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ИмяПользователя", ИмяПользователя);
	ПараметрыФормы.Вставить("УникальныйИдентификаторПользователя", УникальныйИдентификаторПользователя);
	
	ОткрытьФорму("Обработка.ИТК_Пользователи.Форма.ЗапускПодПользователем", ПараметрыФормы, ЭтотОбъект, , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбновлениеПользователей()
	
	ОбновитьПользователей();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйОбновлениеАктивныхПользователей()
	
	ОбновитьАктивныхПользователейИБ();
	
КонецПроцедуры

#КонецОбласти
