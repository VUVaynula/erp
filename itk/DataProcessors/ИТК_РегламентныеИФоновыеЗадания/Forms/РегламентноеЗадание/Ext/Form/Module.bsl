
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Новое = Параметры.Новое;
	Копирование = Параметры.Копирование;
	
	Идентификатор = Параметры.Идентификатор;
	
	ИТК_Форма.ЗаполнитьСписокПользователей(Элементы.ИмяПользователя.СписокВыбора);
	
	// Заполним список регламентных заданий
	СписокВыбора = Элементы.ИмяРегламентногоЗадания.СписокВыбора;
	Для Каждого РегламентноеЗадание Из Метаданные.РегламентныеЗадания Цикл
		
		СписокВыбора.Добавить(РегламентноеЗадание.Имя, РегламентноеЗадание.Представление());
		
	КонецЦикла;
	
	Если НЕ (Новое
				ИЛИ Копирование) Тогда
		
		РегламентноеЗадание = ИТК_РегламентныеЗадания.Получить(Идентификатор);
		ИмяРегламентногоЗадания = РегламентноеЗадание.Метаданные.Имя;
		
		ЗаполнитьФорму(РегламентноеЗадание);
		
	Иначе 
		
		Идентификатор = НСтр("ru = '<Авто>';
							|en = '<Auto>'");
		
		Расписание = Новый РасписаниеРегламентногоЗадания;
		Расписание.ПериодПовтораДней = 1;
		
	КонецЕсли;
	
	ОбновитьЭлементыФормыПриСозданииНаСервере();
	
КонецПроцедуры 

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НаименованиеПриИзменении(Элемент)
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура РегламентноеЗаданиеОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяРегламентногоЗаданияПриИзменении(Элемент)
	
	ЗаполнитьФорму(ИмяРегламентногоЗадания);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключаемыйПолноеИмяМетодаНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ЧастиИмениМетода = СтрРазделить(ПолноеИмяМетода, ".");
	
	ИмяМодуля = ЧастиИмениМетода[0];
	ИмяМетода = ЧастиИмениМетода[1];
	
	ИТК_РедакторКодаКлиент.ОткрытьКодМодуля(ИмяМодуля, ИмяМетода);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НастроитьРасписание(Команда)

	ДиалогРасписанияРегламентногоЗадания = Новый ДиалогРасписанияРегламентногоЗадания(Расписание);
	
	Оповещение = Новый ОписаниеОповещения("НастройкаРасписанияЗавершена", ЭтотОбъект);
	ДиалогРасписанияРегламентногоЗадания.Показать(Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИЗакрытьВыполнить(Команда)
	
	Свойства = Новый Структура;
	Свойства.Вставить("Ключ");
	Свойства.Вставить("Наименование");
	Свойства.Вставить("Использование");
	Свойства.Вставить("ИмяПользователя");
	Свойства.Вставить("ИнтервалПовтораПриАварийномЗавершении");
	Свойства.Вставить("КоличествоПовторовПриАварийномЗавершении");
	Свойства.Вставить("Расписание");
	Свойства.Вставить("Избранное");
	Свойства.Вставить("ИзбранноеКартинка");
	
	ЗаполнитьЗначенияСвойств(Свойства, ЭтотОбъект);
	
	ИдентификаторЗадания = Неопределено;
	Если Не Новое Тогда
		ИдентификаторЗадания = Новый УникальныйИдентификатор(Идентификатор);
	КонецЕсли;
	Свойства.Вставить("Идентификатор", ИдентификаторЗадания);
	
	Свойства.Вставить("Метаданные", ИмяРегламентногоЗадания);
	
	Если Избранное Тогда
		ИзбранноеКартинка = БиблиотекаКартинок.ИТК_Избранное;
	Иначе
		ИзбранноеКартинка = Новый Картинка;
	КонецЕсли;
	Свойства.ИзбранноеКартинка = ИзбранноеКартинка;
	
	Закрыть(Свойства);
	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиКОшибке(Команда)

	ОписаниеОшибкиВМодуле = ИТК_КодКлиентСервер.ОписаниеОшибкиВМодуле(Ошибка);
	ИТК_РедакторКодаКлиент.ОткрытьКодМодуля(ОписаниеОшибкиВМодуле.ИмяМодуля, ОписаниеОшибкиВМодуле.НомерСтроки);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьЭлементыФормы()
	
	СозданиеНового = Новое И Не Копирование;
	
	// Заголовок
	Если НЕ ПустаяСтрока(Наименование) Тогда
		
		Представление = Наименование;
		
	ИначеЕсли НЕ ПустаяСтрока(СинонимМетаданных) Тогда
		
		Представление = СинонимМетаданных;
		
	Иначе
		
		Представление = ИмяМетаданных;
		
	КонецЕсли;
	
	Если Новое Тогда
		Заголовок = НСтр("ru = 'Регламентное задание (создание)';
						|en = 'Scheduled job (creation)'");
	Иначе
		Заголовок = СтрШаблон(НСтр("ru = '%1 (Регламентное задание)';
									|en = '%1 (Scheduled job)'"), Представление);
	КонецЕсли;
	
	Элементы.НастроитьРасписание.Заголовок = Расписание;
	Элементы.ИмяРегламентногоЗадания.Доступность = СозданиеНового;
	
	Элементы.СообщенияПользователюИОписаниеИнформацииОбОшибке.Видимость = Не Новое;
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаРасписанияЗавершена(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Расписание = Результат;
	Модифицированность = Истина;
	
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьФорму(Знач Источник)
	
	Если ТипЗнч(Источник) = Тип("Строка") Тогда
		
		ОбъектМетаданных = Метаданные.РегламентныеЗадания[Источник];
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ОбъектМетаданных);
		Наименование = ОбъектМетаданных.Представление();
		
	ИначеЕсли ТипЗнч(Источник) = Тип("РегламентноеЗадание") Тогда
		
		ОбъектМетаданных = Источник.Метаданные;
		
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Источник);
		Идентификатор = Источник.УникальныйИдентификатор;
		
		СообщенияИОписаниеИнформацииОбОшибке = ИТК_РегламентныеЗадания.СообщенияИОписанияОшибок(Источник);
		Ошибка = СообщенияИОписаниеИнформацииОбОшибке.Ошибка;
		Сообщения = СтрСоединить(СообщенияИОписаниеИнформацииОбОшибке.Сообщения, Символы.ПС);
		
	КонецЕсли;
	
	Избранное = ИТК_РегламентныеЗадания.Избранное(Источник);
	
	ИмяМетаданных        = ОбъектМетаданных.Имя;
	СинонимМетаданных    = ОбъектМетаданных.Синоним;
	ПолноеИмяМетода  = ОбъектМетаданных.ИмяМетода;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЭлементыФормыПриСозданииНаСервере()
	
	ВыгруженныеФайлы = ИТК_ФайлыКонфигурации.ПутьКФайлам();
	Элементы.ПерейтиКОшибке.Видимость = ЗначениеЗаполнено(ВыгруженныеФайлы) И ЗначениеЗаполнено(Ошибка);
	
	Если ЗначениеЗаполнено(ВыгруженныеФайлы) Тогда
		
		ЭлементПолноеИмяМетода = Элементы.ПолноеИмяМетода;
		
		ЭлементПолноеИмяМетода.Вид = ВидПоляФормы.ПолеНадписи;
		ЭлементПолноеИмяМетода.Гиперссылка = Истина;
		ЭлементПолноеИмяМетода.УстановитьДействие("Нажатие", "ПодключаемыйПолноеИмяМетодаНажатие");
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
