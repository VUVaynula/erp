#Область ПрограммныйИнтерфейс

Функция СоответствиеОписаниеИнструментов() Экспорт
	
	Результат = Новый Соответствие;
	
	// Все инструменты
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Доступ"] = Истина;
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Все инструменты';
												|en = 'All instruments'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_Подсистема;
	
	Результат.Вставить(ИТК_Перечисления.Инструменты(), ОписаниеИнструмента);
	
	// Открыть объект
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Доступ"] = Истина;
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Открыть объект';
												|en = 'Open object'");
	ОписаниеИнструмента["ПредставленияДействия"] = НСтр("ru = 'Открыть объект';
														|en = 'Open object'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ПоказатьДанные;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментОткрытьОбъект(), ОписаниеИнструмента);
	
	// Универсальная форма выбора
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_ДинамическийСписок";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Форма выбора (универсальная)';
												|en = 'Selection form (universal)'");
	
	Результат.Вставить(ИТК_Перечисления.ИнструментУниверсальнаяФормаВыбора(), ОписаниеИнструмента);
	
	// Поиск и замена ссылок
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_ПоискИЗаменаСсылок";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Поиск и замена ссылок';
												|en = 'Search and replace links'");
	ОписаниеИнструмента["ПредставленияДействия"] = НСтр("ru = 'Замена ссылки на объект';
														|en = 'Replacing an object reference'");
	ОписаниеИнструмента["ПредставленияДействияСписок"] = НСтр("ru = 'Замена ссылок на объекты';
															|en = 'Replacing object references'");
	ОписаниеИнструмента["ОбработчикБСПИнтеграции"] = "ИТК_ИнтеграцияВКонфигурациюКлиент.ПоискИЗаменаСсылок";
	ОписаниеИнструмента["Множественный"] = Истина;
	ОписаниеИнструмента["ДоступенДляПеречислений"] = Истина;
	ОписаниеИнструмента["Порядок"] = 60;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментПоискИЗаменаСсылок(), ОписаниеИнструмента);
	
	// Подписки на события
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_ПодпискиНаСобытия";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Подписки на события';
												|en = 'Event subscriptions'");
	ОписаниеИнструмента["ПредставленияДействия"] = НСтр("ru = 'Подписки на события по объекту';
												|en = 'Event subscriptions by object'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_МетаданныеПодпискаНаСобытие;
	ОписаниеИнструмента["ОбработчикБСПИнтеграции"] = "ИТК_ИнтеграцияВКонфигурациюКлиент.ПодпискиНаСобытия";
	ОписаниеИнструмента["Множественный"] = Истина;
	ОписаниеИнструмента["Порядок"] = 70;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментПодпискиНаСобытия(), ОписаниеИнструмента);
	
	// Журнал регистрации
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_ЖурналРегистрации";
	
	Доступ = ПравоДоступа("Использование", Метаданные.Обработки.ИТК_ЖурналРегистрации)
				И ПравоДоступа("ЖурналРегистрации", Метаданные);
	ОписаниеИнструмента["Доступ"] = Доступ;
	
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Журнал регистрации';
												|en = 'Registration log'");
	ОписаниеИнструмента["ПредставленияДействия"] = НСтр("ru = 'Журнал регистрации по объекту';
														|en = 'Object registration log'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ЖурналРегистрации;
	ОписаниеИнструмента["ОбработчикБСПИнтеграции"] = "ИТК_ИнтеграцияВКонфигурациюКлиент.ЖурналРегистрации";
	ОписаниеИнструмента["Порядок"] = 50;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментЖурналРегистрации(), ОписаниеИнструмента);
	
	// Регламентные и фоновые задания
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_РегламентныеИФоновыеЗадания";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Регламентные и фоновые задания';
												|en = 'Scheduled and background jobs'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.РегламентныеЗадания;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментРегламентныеИФоновыеЗадания(), ОписаниеИнструмента);
	
	// Обработка в консоли кода
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_КонсольКода";
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_КонсольКода;
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Обработка в консоли кода';
												|en = 'Code console processing'");
	ОписаниеИнструмента["ПредставленияДействия"] = ОписаниеИнструмента["Представление"];
	ОписаниеИнструмента["ПредставленияДействияСписок"] = ОписаниеИнструмента["Представление"];
	ОписаниеИнструмента["ОбработчикБСПИнтеграции"] = "ИТК_ИнтеграцияВКонфигурациюКлиент.ОбработкаВКонсолиКода";
	ОписаниеИнструмента["Множественный"] = Истина;
	ОписаниеИнструмента["Порядок"] = 65;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментОбработкаВКонсолиКода(), ОписаниеИнструмента);

	// Пользователи
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_Пользователи";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Пользователи';
												|en = 'Users'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.Пользователь;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментПользователи(), ОписаниеИнструмента);
	
	// Редактор объекта
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_РедакторОбъекта";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Редактор объекта';
												|en = 'Object editor'");
