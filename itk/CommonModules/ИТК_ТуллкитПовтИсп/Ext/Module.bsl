	ОписаниеИнструмента["Метаданные"] = "Отчет.ИТК_АнализПравДоступа";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Анализ прав доступа';
												|en = 'Access rights analysis'");
	ОписаниеИнструмента["ПредставленияДействия"] = НСтр("ru = 'Анализ прав доступа к объекту';
														|en = 'Analysis of access rights to an object'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_АнализПравДоступа;
	ОписаниеИнструмента["ОбработчикБСПИнтеграции"] = "ИТК_ИнтеграцияВКонфигурациюКлиент.АнализПравДоступа";
	ОписаниеИнструмента["Множественный"] = Истина;
	ОписаниеИнструмента["Порядок"] = 20;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментАнализПравДоступа(), ОписаниеИнструмента);
	
	// Редактирование пользователя ИБ
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_Пользователи";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Редактирование пользователя ИБ';
												|en = 'Editing an DB user'");
