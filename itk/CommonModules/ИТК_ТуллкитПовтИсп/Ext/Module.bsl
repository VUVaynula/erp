	ОписаниеИнструмента["Порядок"] = 80;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментРедактированиеПользователяИБ(), ОписаниеИнструмента);
	
	// Монитор лицензий
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Отчет.ИТК_МониторЛицензий";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Монитор лицензий';
