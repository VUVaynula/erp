														|en = 'Edit object'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_РедакторОбъекта;
	ОписаниеИнструмента["ОбработчикБСПИнтеграции"] = "ИТК_ИнтеграцияВКонфигурациюКлиент.РедакторОбъекта";
	ОписаниеИнструмента["Порядок"] = 10;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментРедакторОбъекта(), ОписаниеИнструмента);
	
	// Редактор констант
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_РедакторКонстант";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Редактор констант';
												|en = 'Constant editor'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_РедакторКонстант;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментРедакторКонстант(), ОписаниеИнструмента);
	
	// Редактор параметров сеанса
