	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_МониторЛицензий;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментМониторЛицензий(), ОписаниеИнструмента);
	
	// Поиск ссылок на объект
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_ПоискСсылокНаОбъект";
