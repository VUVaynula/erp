	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_РедакторПараметровСеанса";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Редактор параметров сеанса';
												|en = 'Session parameter editor'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_РедакторПараметровСеанса;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментРедакторПараметровСеанса(), ОписаниеИнструмента);
	
	// Сравнение объектов
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Отчет.ИТК_СравнениеОбъектов";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Сравнение объектов';
												|en = 'Object comparison'");
	ОписаниеИнструмента["ПредставленияДействия"] = НСтр("ru = 'Сравнить с другим объектом';
														|en = 'Compare with another object'");
	ОписаниеИнструмента["ПредставленияДействияСписок"] = НСтр("ru = 'Сравнить объекты';
															|en = 'Compare objects'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_СравнениеОбъектов;
	ОписаниеИнструмента["ОбработчикБСПИнтеграции"] = "ИТК_ИнтеграцияВКонфигурациюКлиент.СравнениеОбъектов";
	ОписаниеИнструмента["Множественный"] = Истина;
	ОписаниеИнструмента["Порядок"] = 40;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментСравнениеОбъектов(), ОписаниеИнструмента);
	
	// Метаданные
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_Метаданные";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Метаданные';
												|en = 'Metadata'");
	ОписаниеИнструмента["ПредставленияДействия"] = НСтр("ru = 'Метаданные объекта';
														|en = 'Object metadata'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_ИнструментМетаданные;
	ОписаниеИнструмента["ДоступенДляПеречислений"] = Истина;
	ОписаниеИнструмента["Порядок"] = 20;
	ОписаниеИнструмента["ОбработчикБСПИнтеграции"] = "ИТК_ИнтеграцияВКонфигурациюКлиент.СвойстваМетаданныхОбъекта";
	
	Результат.Вставить(ИТК_Перечисления.ИнструментМетаданные(), ОписаниеИнструмента);

	// Структура хранения
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_Метаданные";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Структура хранения';
												|en = 'Storage structure'");
	ОписаниеИнструмента["ПредставленияДействия"] = НСтр("ru = 'Структура хранения объекта';
														|en = 'Object storage structure'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_ИнструментСтруктураХранения;
	ОписаниеИнструмента["ДоступенДляПеречислений"] = Истина;
	ОписаниеИнструмента["Порядок"] = 90;
	ОписаниеИнструмента["ОбработчикБСПИнтеграции"] = "ИТК_ИнтеграцияВКонфигурациюКлиент.СтруктураХраненияОбъекта";
	
	Результат.Вставить(ИТК_Перечисления.ИнструментСтруктураХранения(), ОписаниеИнструмента);
	
	// Поиск по структуре хранения
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_ПоискПоСтруктуреХранения";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Поиск по структуре хранения';
												|en = 'Search by storage structure'");
