	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_КонсольЗапросов;
	ОписаниеИнструмента["Порядок"] = 10;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментКонсольЗапросов(), ОписаниеИнструмента);
	
	// Консоль схем компоновки данных
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_КонсольРазработчика";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Консоль схем компоновки данных';
												|en = 'Data composition schema console'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_КонсольСхемКомпоновкиДанных;
	ОписаниеИнструмента["Порядок"] = 20;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментКонсольСхемКомпоновкиДанных(), ОписаниеИнструмента);
	
	// Консоль кода
	ОписаниеИнструмента = ОписаниеИнструментаКонструктор();
	ОписаниеИнструмента["Метаданные"] = "Обработка.ИТК_КонсольКода";
	ОписаниеИнструмента["Представление"] = НСтр("ru = 'Консоль кода';
												|en = 'Code console'");
	ОписаниеИнструмента["Картинка"] = БиблиотекаКартинок.ИТК_КонсольКода;
	ОписаниеИнструмента["Порядок"] = 30;
	
	Результат.Вставить(ИТК_Перечисления.ИнструментКонсольКода(), ОписаниеИнструмента);
	
	// Заполнение данных (автоматически)
	Для Каждого КлючЗначение Из Результат Цикл 
		
		ОписаниеИнструмента = КлючЗначение.Значение;
		ПолноеИмяОбъектМетаданных = ОписаниеИнструмента["Метаданные"];
		Если ПолноеИмяОбъектМетаданных = Неопределено Тогда 
			Продолжить;
		КонецЕсли;
		
		ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(ПолноеИмяОбъектМетаданных);
		ОписаниеИнструмента["ПолноеИмяФормы"] = ПолноеИмяОбъектМетаданных + ".Форма";
		
		Если ЗначениеЗаполнено(ОписаниеИнструмента["Доступ"]) Тогда
			Продолжить;
		КонецЕсли;
		ОписаниеИнструмента["Доступ"] = ПравоДоступа("Использование", ОбъектМетаданных);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОписаниеИнструментаКонструктор()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Метаданные", Неопределено);
	Результат.Вставить("Представление", "");
	Результат.Вставить("Доступ", Неопределено);
	Результат.Вставить("Множественный", Ложь);
	Результат.Вставить("ОбработчикБСПИнтеграции", "");
	Результат.Вставить("ПредставленияДействия", "");
	Результат.Вставить("ПредставленияДействияСписок", "");
	Результат.Вставить("ПолноеИмяФормы", "");
	Результат.Вставить("Порядок", 100);
	Результат.Вставить("ДоступенДляПеречислений", Ложь);
	
	КартинкаПоУмолчанию = ИТК_ОбщийКлиентСерверПовтИсп.БиблиотекаКартинок("Форма");
	Результат.Вставить("Картинка", КартинкаПоУмолчанию);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
