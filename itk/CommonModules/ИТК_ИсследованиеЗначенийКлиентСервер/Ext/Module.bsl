#Область ПрограммныйИнтерфейс

Процедура РазвернутьСтрокуВФорме(ОсновноеЗначение, Строка, Значение) Экспорт
	
	Строка.ПолучитьЭлементы().Очистить();
	
	РасшифровкаЗначения = РасшифровкаЗначения(ОсновноеЗначение, Строка, Значение);
	Для Каждого ОписаниеРасшифровки Из РасшифровкаЗначения Цикл 
		
		НоваяСтрока = Строка.ПолучитьЭлементы().Добавить();
		ЗаполнениеСтрокиНаФорме(НоваяСтрока, ОписаниеРасшифровки.Имя, ОписаниеРасшифровки.Значение, ОписаниеРасшифровки.Индекс);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнениеСтрокиНаФорме(Строка, Имя, Значение, Индекс = Неопределено) Экспорт
	
	Строка.Имя = Имя;
	Строка.Индекс = Индекс;
	Строка.ПредставлениеТипа = ТипЗнч(Значение);
	
	ОписаниеЗначения = ОписаниеЗначения(Значение);
	
	Если ОписаниеЗначения.Расшифровывается Тогда
		ПустаяСтрока = Строка.ПолучитьЭлементы().Добавить();
	КонецЕсли;

	ПолеПредставления = "Представление";
	Если ОписаниеЗначения.Открывается Тогда
		ПолеПредставления = "ПредставлениеГиперссылки";
	КонецЕсли;
	Строка[ПолеПредставления] = ОписаниеЗначения.Представление;
	
КонецПроцедуры

Функция ИсследуемоеЗначениеСтрокиФормы(ОсновноеЗначение, Строка) Экспорт
	
	Результат = ОсновноеЗначение;
	Если Строка = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	СтрокиЗначения = СтрокиЗначенияОбратно(Строка);
	Для Каждого Строка Из СтрокиЗначения Цикл 
		
		// Получение значение через индекс
		Если ТипЗнч(Результат) = Тип("Соответствие")
				ИЛИ ТипЗнч(Результат) = Тип("ФиксированноеСоответствие") Тогда
				
			Индекс = 0;	
			Для Каждого ЭлементСоответствия Из Результат Цикл 
				
				Если Индекс = Строка.Индекс Тогда
					
					Результат = ЭлементСоответствия.Значение;
					Прервать;
					
				КонецЕсли;
				
				Индекс = Индекс + 1;
				
			КонецЦикла;
				
		ИначеЕсли ТипЗнч(Результат) = Тип("ДеревоЗначений") Тогда
			
			Результат = Результат.Строки[Строка.Индекс];
			
		Иначе
			Результат = Результат[Строка.Индекс];
		КонецЕсли;

	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОписаниеЗначения(Значение, МаксимальнаяДлина = 300)
	
	Открывается = Ложь;
	Расшифровывается = Ложь;
	Представление = Значение;
	ТипЗначения = ТипЗнч(Значение);
	
	Если ТипЗначения = Тип("СистемнаяИнформация") Тогда
		
		Открывается = Истина;
		Расшифровывается = Истина;
		Представление = СтрШаблон(НСтр("ru = '%1 ...'; en = '%1 ...'"), Значение.ВерсияОС);
		
	ИначеЕсли Значение = Неопределено Тогда
		
		Представление = НСтр("ru = 'Неопределено'; en = 'Undefined'");
		
	ИначеЕсли ТипЗначения = Тип("Строка") Тогда
		
		//Открывается = СтрДлина(Значение) > 100
		//					ИЛИ СтрЧислоСтрок(Значение) > 1;
		Представление = СтрШаблон("""%1""", Значение);
		
	ИначеЕсли ТипЗначения = Тип("Массив")
				ИЛИ ТипЗначения = Тип("ФиксированныйМассив") Тогда
				
		Открывается = ЗначениеЗаполнено(Значение);
		Расшифровывается = ЗначениеЗаполнено(Значение);
		
		Представление = "";
		Для Каждого ЭлементМассива Из Значение Цикл 
			
			ПредставлениеЭлемента = ПредставлениеЭлементаЗначения(ЭлементМассива);
			ДополнитьПредставлениеЭлементом(Представление, ПредставлениеЭлемента, МаксимальнаяДлина);
			
		КонецЦикла;
		
		ДополнитьПредставлениеКоличеством(Представление, Значение);
		
	ИначеЕсли ТипЗначения = Тип("Структура")
				ИЛИ ТипЗначения = Тип("ФиксированнаяСтруктура") Тогда
		
		Открывается = ЗначениеЗаполнено(Значение);
		Расшифровывается = ЗначениеЗаполнено(Значение);
		
		СписокЗначений = Новый СписокЗначений;
		Для Каждого ЭлементСтруктуры Из Значение Цикл 
			СписокЗначений.Добавить(ЭлементСтруктуры.Значение, ЭлементСтруктуры.Ключ);
		КонецЦикла;
		СписокЗначений.СортироватьПоПредставлению();
		
		Представление = "";
		Для Каждого ЭлементСписка Из СписокЗначений Цикл 
			
			ПредставлениеЗначения = ПредставлениеЭлементаЗначения(ЭлементСписка.Значение);
			ПредставлениеЭлемента = СтрШаблон("%1 = %2", ЭлементСписка.Представление, ПредставлениеЗначения);
			
			ДополнитьПредставлениеЭлементом(Представление, ПредставлениеЭлемента, МаксимальнаяДлина);
			
		КонецЦикла;
		
		Представление = ИТК_ФормаКлиентСервер.ЗаголовокСКоличествомВНачале(Представление, Значение.Количество());
		
	ИначеЕсли ТипЗначения = Тип("Структура")
				ИЛИ ТипЗначения = Тип("ФиксированнаяСтруктура") Тогда
		
		Открывается = ЗначениеЗаполнено(Значение);
		Расшифровывается = ЗначениеЗаполнено(Значение);
		
		СписокЗначений = Новый СписокЗначений;
		Для Каждого ЭлементСтруктуры Из Значение Цикл 
			СписокЗначений.Добавить(ЭлементСтруктуры.Значение, ЭлементСтруктуры.Ключ);
		КонецЦикла;
		СписокЗначений.СортироватьПоПредставлению();
		
		Представление = "";
		Для Каждого ЭлементСписка Из СписокЗначений Цикл 
			
			ПредставлениеЗначения = ПредставлениеЭлементаЗначения(ЭлементСписка.Значение);
			ПредставлениеЭлемента = СтрШаблон("%1 = %2", ЭлементСписка.Представление, ПредставлениеЗначения);
			
			ДополнитьПредставлениеЭлементом(Представление, ПредставлениеЭлемента, МаксимальнаяДлина);
			
		КонецЦикла;

		Представление = ИТК_ФормаКлиентСервер.ЗаголовокСКоличествомВНачале(Представление, Значение.Количество());

		
	ИначеЕсли ТипЗначения = Тип("Соответствие")
				ИЛИ ТипЗначения = Тип("ФиксированноеСоответствие") Тогда
		
		Открывается = ЗначениеЗаполнено(Значение);
		Расшифровывается = ЗначениеЗаполнено(Значение);
		
		Представление = "";
		Для Каждого ЭлементСоответствия Из Значение Цикл 
			
			ПредставлениеЗначения = ПредставлениеЭлементаЗначения(ЭлементСоответствия.Значение);
			ПредставлениеЭлемента = СтрШаблон("[%1] = %2", ЭлементСоответствия.Ключ, ПредставлениеЗначения);
			
			ДополнитьПредставлениеЭлементом(Представление, ПредставлениеЭлемента, МаксимальнаяДлина);
			
		КонецЦикла;
		
		Представление = ИТК_ФормаКлиентСервер.ЗаголовокСКоличествомВНачале(Представление, Значение.Количество());
		
	ИначеЕсли ТипЗначения = Тип("СписокЗначений") Тогда
		
		Открывается = ЗначениеЗаполнено(Значение);
		Расшифровывается = ЗначениеЗаполнено(Значение);
		
		Представление = "";
		Для Каждого ЭлементСписка Из Значение Цикл 
			
			ПредставлениеЭлемента = ЭлементСписка.Представление;
			Если НЕ ЗначениеЗаполнено(ПредставлениеЭлемента) Тогда
				ПредставлениеЭлемента = ПредставлениеЭлементаЗначения(ЭлементСписка.Значение);
			КонецЕсли;
			
			ДополнитьПредставлениеЭлементом(Представление, ПредставлениеЭлемента, МаксимальнаяДлина);
			
		КонецЦикла;
		
		Представление = ИТК_ФормаКлиентСервер.ЗаголовокСКоличествомВНачале(Представление, Значение.Количество());
		
	КонецЕсли;
	
	//ИТК_ОбщийКлиент.ПредставлениеТипаКлиента()
	#Если Сервер Тогда
		
	Если ТипЗначения = Тип("ТаблицаЗначений") Тогда
		
		Открывается = Истина;
		Расшифровывается = ЗначениеЗаполнено(Значение);
		Представление = ИТК_ФормаКлиентСервер.ЗаголовокСКоличествомВНачале(ТипЗнч(Значение), Значение.Количество());
		
	ИначеЕсли ТипЗначения = Тип("СтрокаТаблицыЗначений") Тогда
		
		Расшифровывается = Истина;
		
	ИначеЕсли ТипЗначения = Тип("ДеревоЗначений") Тогда
		
		Открывается = Истина;
		Расшифровывается = ЗначениеЗаполнено(Значение);
		
	ИначеЕсли ТипЗначения = Тип("СтрокаДереваЗначений") Тогда
		
		Расшифровывается = Истина;
		
	ИначеЕсли ТипЗначения = Тип("КоллекцияСтрокДереваЗначений") Тогда
		
		Расшифровывается = Истина;
		
	КонецЕсли;
	
	#КонецЕсли
	
	Результат = Новый Структура;
	Результат.Вставить("Представление", Представление);
	Результат.Вставить("Открывается", Открывается);
	Результат.Вставить("Расшифровывается", Расшифровывается);
	
	Возврат Результат;
	
КонецФункции

Функция РасшифровкаЗначения(ОсновноеЗначение, Строка, Значение, КодЯзыкаПрограммирования = Неопределено)
	
	Если КодЯзыкаПрограммирования = Неопределено Тогда
		КодЯзыкаПрограммирования = ИТК_ОбщийВызовСервера.КодЯзыкаПрограммирования();
	КонецЕсли;
	
	ТипЗначения = ТипЗнч(Значение);
	Результат = Новый Массив;
	
	ДобавитьПоляПеречисляемыхТипов(Результат, Значение, ТипЗначения, КодЯзыкаПрограммирования);
	
	Если ТипЗначения = Тип("Массив")
				ИЛИ ТипЗначения = Тип("ФиксированныйМассив") Тогда
		
		Для Индекс = 0 По Значение.ВГраница() Цикл 
			
			Имя = СтрШаблон("[%1]", ИТК_Строки.ЧислоВСтроку(Индекс));
			ДобавитьЭлементРасшифровки(Результат, Имя, Значение[Индекс], Индекс);
					
		КонецЦикла;
		
	ИначеЕсли ТипЗначения = Тип("Структура")
				ИЛИ ТипЗначения = Тип("ФиксированнаяСтруктура") Тогда
				
		СписокЗначений = Новый СписокЗначений;
		Для Каждого ЭлементСтруктуры Из Значение Цикл 
			СписокЗначений.Добавить(ЭлементСтруктуры.Значение, ЭлементСтруктуры.Ключ);
		КонецЦикла;
		СписокЗначений.СортироватьПоПредставлению();
		
		Представление = "";
		Для Каждого ЭлементСписка Из СписокЗначений Цикл 
			ДобавитьЭлементРасшифровки(Результат, ЭлементСписка.Представление, ЭлементСписка.Значение, ЭлементСписка.Представление);
		КонецЦикла;	
		
	ИначеЕсли ТипЗначения = Тип("СписокЗначений") Тогда
		
		Для Индекс = 0 По Значение.Количество() - 1 Цикл 
			
			Имя = СтрШаблон("[%1]", ИТК_Строки.ЧислоВСтроку(Индекс));
			ДобавитьЭлементРасшифровки(Результат, Имя, Значение[Индекс].Значение, Индекс);
					
		КонецЦикла;
		
	ИначеЕсли ТипЗначения = Тип("Соответствие")
				ИЛИ ТипЗначения = Тип("ФиксированноеСоответствие") Тогда
				
		Индекс = 0;
		Для Каждого ЭлементСоответствия Из Значение Цикл 
			
			Имя = СтрШаблон("[%1] - %2", Индекс, ПредставлениеРасшифровываемогоЗначения(ЭлементСоответствия.Ключ));
			ДобавитьЭлементРасшифровки(Результат, Имя, ЭлементСоответствия.Значение, Индекс);

			Индекс = Индекс + 1;
			
		КонецЦикла;
		
	ИначеЕсли ТипЗначения = Тип("ТаблицаЗначений") Тогда
		
		Для НомерСтроки = 1 По Значение.Количество() Цикл 
			
			Индекс = НомерСтроки - 1;
			
			Имя = СтрШаблон(НСтр("ru = 'Строка [%1]'; en = 'Row [%1]'"), ИТК_Строки.ЧислоВСтроку(НомерСтроки));
			ДобавитьЭлементРасшифровки(Результат, Имя, Значение[Индекс], Индекс);
					
		КонецЦикла;
		
	ИначеЕсли ТипЗначения = Тип("СтрокаТаблицыЗначений") Тогда
		
		СтрокаТаблицаЗначений = Строка.ПолучитьРодителя();
		ТаблицаЗначений = ИсследуемоеЗначениеСтрокиФормы(ОсновноеЗначение, СтрокаТаблицаЗначений);
		
		Для Каждого Колонка Из ТаблицаЗначений.Колонки Цикл 
			ДобавитьЭлементРасшифровки(Результат, Колонка.Имя, Значение[Колонка.Имя], Колонка.Имя);
		КонецЦикла;
		
	ИначеЕсли ТипЗначения = Тип("ДеревоЗначений") Тогда
		
		Для НомерСтроки = 1 По Значение.Строки.Количество() Цикл 
			
			Индекс = НомерСтроки - 1;
			
			Имя = СтрШаблон(НСтр("ru = 'Строка [%1]'; en = 'Row [%1]'"), ИТК_Строки.ЧислоВСтроку(НомерСтроки));
			ДобавитьЭлементРасшифровки(Результат, Имя, Значение.Строки[Индекс], Индекс);
					
		КонецЦикла;
		
	ИначеЕсли ТипЗначения = Тип("КоллекцияСтрокДереваЗначений") Тогда
		
		Для НомерСтроки = 1 По Значение.Количество() Цикл 
			
			Индекс = НомерСтроки - 1;
			
			Имя = СтрШаблон(НСтр("ru = 'Строка [%1]'; en = 'Row [%1]'"), ИТК_Строки.ЧислоВСтроку(НомерСтроки));
			ДобавитьЭлементРасшифровки(Результат, Имя, Значение[Индекс], Индекс);
					
		КонецЦикла;
		
	ИначеЕсли ТипЗначения = Тип("СтрокаДереваЗначений") Тогда
		
		ДеревоЗначений = ДеревоЗначенийВладелец(ОсновноеЗначение, Строка);
		
		Для Каждого Колонка Из ДеревоЗначений.Колонки Цикл 
			ДобавитьЭлементРасшифровки(Результат, Колонка.Имя, Значение[Колонка.Имя], Колонка.Имя);
		КонецЦикла;
		
		ПодчиненныеСтроки = Значение.Строки;
		Если ЗначениеЗаполнено(ПодчиненныеСтроки) Тогда
			
			Представление = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(НСтр("ru = 'Строки'; en = 'Rows'"), ПодчиненныеСтроки.Количество());
			ДобавитьЭлементРасшифровки(Результат, Представление, ПодчиненныеСтроки, "Строки");
			
		КонецЕсли;
		
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьЭлементРасшифровки(Результат, Имя, Значение, Индекс = Неопределено)
	
	ОписаниеЭлемента = Новый Структура;
	ОписаниеЭлемента.Вставить("Имя", Имя);
	ОписаниеЭлемента.Вставить("Значение", Значение);
	ОписаниеЭлемента.Вставить("Индекс", Индекс);
	
	Результат.Добавить(ОписаниеЭлемента);	
	
КонецПроцедуры

Функция ПредставлениеЭлементаЗначения(Значение)
	
	ОписаниеЗначения = ОписаниеЗначения(Значение);
	
	Если ОписаниеЗначения.Расшифровывается Тогда
		Результат = ПредставлениеРасшифровываемогоЗначения(Значение);
	Иначе
		Результат = ОписаниеЗначения.Представление
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеРасшифровываемогоЗначения(Значение)
	
	Результат = ТипЗнч(Значение);
	
	ТипЗначения = ТипЗнч(Значение);
	Если ТипЗначения = Тип("Массив")
			ИЛИ ТипЗначения = Тип("ФиксированныйМассив")
			ИЛИ ТипЗначения = Тип("Структура")
			ИЛИ ТипЗначения = Тип("ФиксированнаяСтруктура")
			ИЛИ ТипЗначения = Тип("Соответствие")
			ИЛИ ТипЗначения = Тип("ФиксированноеСоответствие")
			ИЛИ ТипЗначения = Тип("СписокЗначений")
			Тогда
		
		Результат = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(Результат, Значение.Количество());
		
	ИначеЕсли ТипЗнч(Значение) = Тип("Строка") Тогда
		
		Результат = СтрШаблон("""%1""", Значение);
		
	ИначеЕсли ТипЗнч(Значение) = Тип("Дата") Тогда
		
		Результат = СтрШаблон("'%1'", Значение);
		
	ИначеЕсли ТипЗнч(Значение) = Тип("Число") Тогда
		
		Результат = Значение;
		
	КонецЕсли;
	
	#Если Сервер Тогда
		
	Если ТипЗначения = Тип("ТаблицаЗначений") Тогда
		Результат = ИТК_ФормаКлиентСервер.ЗаголовокСКоличеством(Результат, Значение.Количество());
	КонецЕсли;
	
	#КонецЕсли
	
	Возврат Результат;
	
КонецФункции

Процедура ДополнитьПредставлениеЭлементом(Представление, ПредставлениеЭлемента, МаксимальнаяДлина)
	
	Если ЗначениеЗаполнено(Представление) Тогда
		Представление = Представление + ", ";
	КонецЕсли;
	
	Представление = Представление + ПредставлениеЭлемента;
	
	Если СтрДлина(Представление) > МаксимальнаяДлина Тогда
		Представление = ИТК_Строки.Сократить(Представление, МаксимальнаяДлина, Истина);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДополнитьПредставлениеКоличеством(Представление, Значение)
	
	Количество = Значение.Количество();
	Если ЗначениеЗаполнено(Количество) Тогда
		Представление = "(" + Количество + ") "+ Представление;
	КонецЕсли;
	
КонецПроцедуры

Функция СтрокиЗначенияОбратно(Строка)
	
	Результат = Новый Массив;
	
	Если Строка.Индекс <> Неопределено Тогда
		Результат.Добавить(Строка);
	КонецЕсли;
	
	Родитель = Строка.ПолучитьРодителя();
	Пока Родитель <> Неопределено Цикл 
		
		Если Родитель.Индекс <> Неопределено Тогда
			Результат.Вставить(0, Родитель);
		КонецЕсли;
		Родитель = Родитель.ПолучитьРодителя();
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьПоляПеречисляемыхТипов(Результат, Значение, ТипЗначения, КодЯзыкаПрограммирования);
	
	Соответствие = ИТК_ИсследованиеЗначенийКлиентСерверПовтИсп.СоответствиеПоляПеречисляемыхТипов();
	ОписаниеПолей = Соответствие.Получить(ТипЗначения);
	Если ОписаниеПолей = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ОписаниеПоля Из ОписаниеПолей Цикл 
		
		Если КодЯзыкаПрограммирования = ИТК_ОбщийКлиентСервер.КодЯзыкаРусский() Тогда
			ИмяПоля = ОписаниеПоля.Имя;
		Иначе
			ИмяПоля = ОписаниеПоля.ИмяНаАнглийском;
		КонецЕсли;
		
		ОписаниеТипов = ИТК_ТипыКлиентСервер.ОписаниеТиповПоТипу(ОписаниеПоля.Тип);
		ЗначениеПоля = ОписаниеТипов.ПривестиЗначение(Значение[ИмяПоля]);
		
		ДобавитьЭлементРасшифровки(Результат, ИмяПоля, Значение[ИмяПоля], ИмяПоля);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ДеревоЗначенийВладелец(ОсновноеЗначение, Строка)
	
	СтрокаВладелец = Строка.ПолучитьРодителя();
	Пока СтрокаВладелец <> Неопределено
			И СтрокаВладелец.Индекс = "Строки" Цикл 
		
		СтрокаСтроки = СтрокаВладелец.ПолучитьРодителя();
		СтрокаВладелец = СтрокаСтроки.ПолучитьРодителя();
			
	КонецЦикла;
	
	Возврат ИсследуемоеЗначениеСтрокиФормы(ОсновноеЗначение, СтрокаВладелец);
	
КонецФункции

#КонецОбласти
