#Область ПрограммныйИнтерфейс

// Возвращает строку имени элемента данных для запроса из отладки
//
// Параметры:
//	Объект - СхемаКомпоновкиДанных, Запрос, ПостроительЗапроса, ПостроительОтчета, ДинамическийСписок, МакетКомпоновкиДанных - Объект отладки
//	ТипЭлементов - Перечисление.ИТК_ЭлементыДанных - Тип элементов
//	ТипХранения - Перечисление.ИТК_ТипыХраненияДанных - Тип хранения данных
//	ДополнительныеПараметры - Структура - Дополнительные параметры
//
// Возвращаемое значение:
//   Строку - Имя данных используемое при загрузке данных из отладки
//
Функция СохранитьДанные(Объект, ТипЭлементов, ТипХранения, ДополнительныеПараметры) Экспорт
	
	// Считывание данных
	ТекстОшибки = "";
	Если ТипЭлементов = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
		ДанныеОбъекта = ДанныеЗапросаИзОбъекта(Объект, ДополнительныеПараметры, ТекстОшибки);
	Иначе
		ДанныеОбъекта = ДанныеСКДИзОбъекта(Объект, ДополнительныеПараметры, ТекстОшибки);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат ТекстОшибки;
	КонецЕсли;
	
	Если ДополнительныеПараметры.Объединение Тогда
		// Объединение, не доделано
		СохраняемыеДанные = ДанныеОбъекта;
	Иначе
		СохраняемыеДанные = ДанныеОбъекта;
	КонецЕсли;
	
	ИмяДанных = ДополнительныеПараметры.Имя;
	Если ИмяДанных = Неопределено Тогда
		ИмяДанных = ИТК_ОтладкаКлиентСервер.ИмяДанныхПоУмолчанию(ТипЭлементов);
	КонецЕсли;
	
	Результат = НСтр("ru = 'Сохранено успешно'; en = 'Saved successfully'");
	Если ТипХранения = ИТК_Перечисления.ТипХраненияДанныхНастройка() Тогда 
		
		ПолноеИмя = ИмяДанных;
		
		Если ТранзакцияАктивна() Тогда
			
			СохраненоВФоне = ИТК_КонсольРазработчика.СохранитьДанныеВФоне(ПолноеИмя, СохраняемыеДанные);	
			Если СохраненоВФоне Тогда
				Результат = НСтр("ru = 'Сохранено, сохраняется в фоне'; en = 'Saved, saved in the background'");
			КонецЕсли;
			
			Результат = Результат + НСтр("ru = ' (В ТРАНЗАКЦИИ)'; en = ' (IN TRANSACTION)'");
			
		Иначе
			
			ИТК_КонсольРазработчика.СохранитьДанные(ПолноеИмя, СохраняемыеДанные);
			
		КонецЕсли;
		
	Иначе
		
		ПолноеИмя = ИТК_ФайлыКлиентСервер.ПолноеИмя(ДополнительныеПараметры.Путь, ИмяДанных, ИТК_ОбщийКлиентСервер.ОсновноеРасширениеФайловДанных());
		ИТК_MCRФормат.ЗаписатьДанныеВФайл(СохраняемыеДанные, ПолноеИмя);
		
	КонецЕсли;
	
	ИТК_КонсольРазработчика.ДобавитьВПоследниеРабочиеДанные(ПолноеИмя, ТипХранения);
	
	Возврат Результат;

КонецФункции

Функция ПредставлениеМенеджераВременныхТаблиц(Объект, ВключатьПустые = Истина) Экспорт
	
	ИспользуетсяРешетка = Ложь;
	Для Каждого ВременнаяТаблица Из Объект.Таблицы Цикл 
		
		Если СтрНайти(ВременнаяТаблица.ПолноеИмя, "#") Тогда
			
			ИспользуетсяРешетка = Истина;
			Прервать;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ИспользуетсяРешетка Тогда
		Результат = Новый Соответствие;
	Иначе
		Результат = Новый Структура;
	КонецЕсли;
	
	Для Каждого ВременнаяТаблица Из Объект.Таблицы Цикл 
		
		ТаблицаЗначений = ВременнаяТаблица.ПолучитьДанные().Выгрузить();
		КоличествоСтрок = ТаблицаЗначений.Количество();
		
		Если ВключатьПустые
				ИЛИ КоличествоСтрок > 0 Тогда
			
			Если ИспользуетсяРешетка Тогда
				ШаблонКлюча = "%1(%2)";
			Иначе
				ШаблонКлюча = "%1_%2";
			КонецЕсли;
				
			Результат.Вставить(СтрШаблон(ШаблонКлюча, ВременнаяТаблица.ПолноеИмя, ИТК_Строки.ЧислоВСтроку(КоличествоСтрок)), ТаблицаЗначений);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДанныеЗапросаИзОбъекта(Объект, ДополнительныеПараметры, ТекстОшибки)
	
	Результат = Новый Массив;
	Ошибки = Новый Массив;
	
	Если НЕ ДопустимыйТипОбъектаПолученияЗапроса(Объект) Тогда
		
		ТекстОшибки = НСтр("ru = 'Неверный тип параметра, ожидаются типы Запрос, МакетКомпоновкиДанных, ДинамическийСписок, ПостроительЗапроса, ПостроительОтчета';
							|en = 'Invalid parameter type, Query, DataCompositionTemplate, DynamicListQueryBuilder, ReportBuilder'");
		Ошибки.Добавить(ТекстОшибки);
		
	ИначеЕсли ТипЗнч(Объект) = Тип("ДинамическийСписок")
			И НЕ Объект.ПроизвольныйЗапрос Тогда
			
		ТекстОшибки = НСтр("ru = 'Не удалось загрузить данные динамического списка (флаг ПроизвольныйЗапрос не установлен)';
							|en = 'Dynamic list data could not be loaded (CustomQuery flag is not set)'");
		Ошибки.Добавить(ТекстОшибки);
		
	Иначе
		
		Если ТипЗнч(Объект) = Тип("МакетКомпоновкиДанных") Тогда
			
			Параметры = Новый Структура;
			Для Каждого ЗначениеПараметра Из Объект.ЗначенияПараметров Цикл 
				Параметры.Вставить(ЗначениеПараметра.Имя, ЗначениеПараметра.Значение);
			КонецЦикла;
			
			Для Каждого НаборДанных Из Объект.НаборыДанных Цикл 
				
				Если ТипЗнч(НаборДанных) = Тип("НаборДанныхЗапросМакетаКомпоновкиДанных") Тогда
					
					ТекстЗапроса = НаборДанных.Запрос;
					ВременныеТаблицы = Новый Соответствие;
					
					ДополнительныеСвойства = Новый Структура;
					ДополнительныеСвойства.Вставить("Параметры", ПодготовитьПараметрыЗапроса(Объект, ТекстЗапроса, Параметры));
					ДополнительныеСвойства.Вставить("ВременныеТаблицы", ВременныеТаблицы);
					ЭлементДанныхЗапрос = НовыйЭлементДанных(ИТК_Перечисления.ЭлементДанныхЗапрос(), НаборДанных.Имя, ТекстЗапроса, ДополнительныеСвойства);
					
					Результат.Добавить(ЭлементДанныхЗапрос);
					
				КонецЕсли;
				
			КонецЦикла;
			
		Иначе
			
			// Получаем текст запроса
			Если ТипЗнч(Объект) = Тип("ДинамическийСписок") Тогда
				ТекстЗапроса = Объект.ТекстЗапроса;
			Иначе 
				ТекстЗапроса = Объект.Текст;
			КонецЕсли;
			
			// Загрузка временных таблиц
			ВременныеТаблицы = Новый Соответствие;
			Если ТипЗнч(Объект) = Тип("Запрос") Тогда
				
				Если Объект.МенеджерВременныхТаблиц <> Неопределено Тогда
					
					ЛимитЯчеек = ЛимитЯчеекВнешнихИсточников();
					Для Каждого ВременнаяТаблица Из Объект.МенеджерВременныхТаблиц.Таблицы Цикл
						
						ТаблицаЗначений = ВременнаяТаблица.ПолучитьДанные().Выгрузить();
						КоличествоЯчеек = ВременнаяТаблица.Колонки.Количество() * ТаблицаЗначений.Количество();
						
						Если КоличествоЯчеек > ЛимитЯчеек Тогда // Проверим лимит ячеек
							
							Ошибки.Добавить(СтрШаблон(НСтр("ru = 'Слишком большой объем данных таблица: %1, ячеек %2 (лимит: %3)';
															|en = 'Too much data to table: %1, cells %2 (limit: %3)'"),
												ВременнаяТаблица.ПолноеИмя, ИТК_Строки.ЧислоВСтроку(КоличествоЯчеек), ИТК_Строки.ЧислоВСтроку(ЛимитЯчеек)));

						КонецЕсли;
						
						ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйВнешнийИсточник(ВременнаяТаблица.ПолноеИмя, 
															ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение(), ТаблицаЗначений);
															ВременныеТаблицы.Вставить(Новый УникальныйИдентификатор, ОписаниеВнешнегоИсточника);
						
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЕсли;
			
			// Загрузка параметров
			
			Если ТипЗнч(Объект) = Тип("ДинамическийСписок") Тогда
				
				Параметры = Новый Структура;
				Для Каждого ПараметрЗапроса Из Объект.Параметры.Элементы Цикл
					Параметры.Вставить(Строка(ПараметрЗапроса.Параметр), ПараметрЗапроса.Значение);
				КонецЦикла;
				
			Иначе
				
				Параметры = Объект.Параметры;
				
			КонецЕсли;
			
			ДополнительныеСвойства = Новый Структура;
			ДополнительныеСвойства.Вставить("Параметры", ПодготовитьПараметрыЗапроса(Объект, ТекстЗапроса, Параметры));
			ДополнительныеСвойства.Вставить("ВременныеТаблицы", ВременныеТаблицы);
			
			ТипЭлементаЗапрос = ИТК_Перечисления.ЭлементДанныхЗапрос();
			ЭлементДанныхЗапрос = НовыйЭлементДанных(
										ТипЭлементаЗапрос,
										ИТК_ОтладкаКлиентСервер.ИмяЭлементаДанных(ТипЭлементаЗапрос, ДополнительныеПараметры.Имя),
										ТекстЗапроса,
										ДополнительныеСвойства);
			
			Результат.Добавить(ЭлементДанныхЗапрос);
			
		КонецЕсли;
		
	КонецЕсли;
	
	ТекстОшибки = СтрСоединить(Ошибки, "; ");
	
	Возврат Результат;
	
КонецФункции

Функция ПодготовитьПараметрыЗапроса(Объект, Текст, Параметры)
	
	ТекстОшибки = Неопределено;
	НайденныеПараметры = ИТК_Запрос.НайтиПараметры(Текст, ТекстОшибки);
	
	Если ЗначениеЗаполнено(ТекстОшибки)
			И ТипЗнч(Объект) = Тип("Запрос") Тогда
			
		// Запрос не проходит синтаксический контроль, получим параметры из объекта запрос
		НайденныеПараметры = ИТК_Запрос.ПодготовитьПараметры(Объект);
		
	КонецЕсли;
	
	Результат = Новый Соответствие;
	Для Каждого ПараметрЗапроса Из НайденныеПараметры Цикл 
		
		ИмяПараметра = ПараметрЗапроса.Ключ;
		ЗначениеПараметра = ИТК_ОбщийКлиентСервер.Свойство(Параметры, ИмяПараметра); 
		
		
		Если ЗначениеПараметра = Неопределено Тогда
			
			ЯзыкПрограммирования = ИТК_Общий.КодЯзыкаПрограммирования();
			Если ЯзыкПрограммирования = ИТК_ОбщийКлиентСервер.КодЯзыкаРусский() Тогда
				ВыражениеПараметра = "Результат = Неопределено;";
			Иначе
				ВыражениеПараметра = "Result = Undefined;";
			КонецЕсли;
			
			ЗначениеПараметра = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(ИТК_Перечисления.СложныйПараметрЗапросаВыражение(), ВыражениеПараметра);
			
		ИначеЕсли ТипЗнч(ЗначениеПараметра) = Тип("Граница") Тогда
			
			ОписаниеГраницы = ИТК_Запрос.ОписаниеИзГраницы(ЗначениеПараметра);
			ЗначениеПараметра = ИТК_ЗапросКлиентСервер.ЗначениеСложногоПараметра(ИТК_Перечисления.СложныйПараметрЗапросаГраница(), ОписаниеГраницы);
			
		ИначеЕсли ИТК_Метаданные.ЭтоТабличнаяЧастьОбъекта(ЗначениеПараметра) Тогда
			
			ЗначениеПараметра = ЗначениеПараметра.Выгрузить();
			
		КонецЕсли;
		
		Результат.Вставить(ИмяПараметра, ЗначениеПараметра);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ДанныеСКДИзОбъекта(Схема, ДополнительныеПараметры, ТекстОшибки)

	Настройки = ДополнительныеПараметры.Настройки;
	ВнешниеНаборыДанных = ДополнительныеПараметры.ВнешниеНаборыДанных;
	
	Результат = Новый Массив;
	
	Ошибки = Новый Массив;
	Если ТипЗнч(Схема) <> Тип("СхемаКомпоновкиДанных") Тогда
		
		ТекстОшибки = НСтр("ru = 'Неверный тип параметра Схема ожидается (СхемаКомпоновкиДанных)';
							|en = 'Invalid parameter type Scheme is expected (DataCompositionSchema)'");
		Ошибки.Добавить(ТекстОшибки);
		
	КонецЕсли;
	
	Если Настройки <> Неопределено И ТипЗнч(Настройки) <> Тип("НастройкиКомпоновкиДанных") Тогда
		
		ТекстОшибки = НСтр("ru = 'Неверный тип параметра Настройки ожидается (НастройкиКомпоновкиДанных)';
							|en = 'Invalid parameter type Settings is expected (DataCompositionSettings)'");
		Ошибки.Добавить(ТекстОшибки);
		
	КонецЕсли;
	
	Если ВнешниеНаборыДанных <> Неопределено И ТипЗнч(ВнешниеНаборыДанных) <> Тип("Структура") Тогда
		
		ТекстОшибки = НСтр("ru = 'Неверный тип параметра ВнешниеНаборыДанных ожидается (Структура)';
							|en = 'Invalid parameter type ExternalSource is expected (Structure)'");
		Ошибки.Добавить(ТекстОшибки);
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Ошибки) Тогда
		
		ВнешниеИсточники = Новый Соответствие;
		
		Если ВнешниеНаборыДанных <> Неопределено Тогда
			
			ЛимитЯчеек = ЛимитЯчеекВнешнихИсточников();
			Для Каждого ВнешнийИсточник Из ВнешниеНаборыДанных Цикл
				
				ТаблицаЗначений = ВнешнийИсточник.Значение;
				КоличествоЯчеек = ТаблицаЗначений.Колонки.Количество() * ТаблицаЗначений.Количество();
				
				Если КоличествоЯчеек > ЛимитЯчеек Тогда // Проверим лимит ячеек
					
					ШаблонОшибки = НСтр("ru = 'Слишком большой объем данных таблица: %1, ячеек %2 (лимит: %3)';
										|en = 'Too much data to table: %1, cells %2 (limit: %3)'");
					ПредставлениеКоличестваОшибок = ИТК_Строки.ЧислоВСтроку(КоличествоЯчеек);
					ПредставлениеЛимитаЯчеек = ИТК_Строки.ЧислоВСтроку(ЛимитЯчеек);
					Ошибки.Добавить(СтрШаблон(ШаблонОшибки,	ВнешниеНаборыДанных.Ключ, ПредставлениеКоличестваОшибок, ПредставлениеЛимитаЯчеек));
					
				КонецЕсли;
				
				ОписаниеВнешнегоИсточника = ИТК_КонсольРазработчикаДанныеКлиентСервер.НовыйВнешнийИсточник(ВнешнийИсточник.Ключ, 
																								ИТК_Перечисления.ТипЗначенияВнешнегоИсточникаЗначение(), ТаблицаЗначений);
				ВнешниеИсточники.Вставить(Новый УникальныйИдентификатор, ОписаниеВнешнегоИсточника);
				
			КонецЦикла;
			
		КонецЕсли;
		
		ДополнительныеСвойства = Новый Структура;
		ДополнительныеСвойства.Вставить("ВнешниеИсточники", ВнешниеИсточники);
		
		ТипЭлементаСхема = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных();
		ЭлементДанныхСхемаКомпоновкиДанных = НовыйЭлементДанных(
												ТипЭлементаСхема,
												ИТК_ОтладкаКлиентСервер.ИмяЭлементаДанных(ТипЭлементаСхема, ДополнительныеПараметры.Имя),
												ИТК_СКД.XMLТекст(Схема),
												ДополнительныеСвойства);
		
		Если Настройки <> Неопределено Тогда
			
			ЭлементДанныхВариантНастроек = НовыйЭлементДанных(
												ИТК_Перечисления.ЭлементДанныхВариантОтчетаСКД(),
												НСтр("ru = 'Вариант'; en = 'Variant'"),
												ИТК_СКД.XMLТекст(Настройки));
			
			ЭлементыСхемыКомпоновкиДанных = Новый Массив;
			ЭлементыСхемыКомпоновкиДанных.Добавить(ЭлементДанныхВариантНастроек);
			ЭлементДанныхСхемаКомпоновкиДанных.Вставить("Elements", ЭлементыСхемыКомпоновкиДанных);
			
		КонецЕсли;
		
		Результат.Добавить(ЭлементДанныхСхемаКомпоновкиДанных);
		
	КонецЕсли;
	
	ТекстОшибки = СтрСоединить(Ошибки, "; ");
	
	Возврат Результат;
	
КонецФункции

Функция НовыйЭлементДанных(Тип, Имя, Текст, ДополнительныеСвойства = Неопределено)
	
	Результат = Новый Структура;
	Результат.Вставить("Name", Имя);
	Результат.Вставить("Type", Тип);
	Результат.Вставить("Text", Текст);
	
	Если Тип = ИТК_Перечисления.ЭлементДанныхЗапрос() Тогда
		
		Результат.Вставить("ExternalSources", ДополнительныеСвойства.ВременныеТаблицы);
		Результат.Вставить("Parameters", ДополнительныеСвойства.Параметры);
		
	ИначеЕсли Тип = ИТК_Перечисления.ЭлементДанныхСхемаКомпоновкиДанных() Тогда
		Результат.Вставить("ExternalSources", ДополнительныеСвойства.ВнешниеИсточники);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДопустимыйТипОбъектаПолученияЗапроса(Объект)
	
	Возврат ТипЗнч(Объект) = Тип("ДинамическийСписок")
				ИЛИ ТипЗнч(Объект) = Тип("Запрос")
