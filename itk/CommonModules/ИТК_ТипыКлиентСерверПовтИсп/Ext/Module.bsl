#Область ПрограммныйИнтерфейс

Функция СоответствиеПростыеТипы() Экспорт
	
	Результат = Новый Соответствие;
	Результат.Вставить(Тип("Null"), Истина);
	Результат.Вставить(Тип("Неопределено"), Истина);
	Результат.Вставить(Тип("Число"), Истина);
	Результат.Вставить(Тип("Строка"), Истина);
	Результат.Вставить(Тип("Дата"), Истина);
	Результат.Вставить(Тип("Булево"), Истина);
	Результат.Вставить(Тип("УникальныйИдентификатор"), Истина);
	Результат.Вставить(Тип("ХранилищеЗначения"), Истина);
	Результат.Вставить(Тип("Тип"), Истина);
	Результат.Вставить(Тип("МоментВремени"), Истина);
	Результат.Вставить(Тип("ОписаниеТипов"), Истина);
	Результат.Вставить(Тип("ВидДвиженияБухгалтерии"), Истина);
	Результат.Вставить(Тип("ВидДвиженияНакопления"), Истина);
	Результат.Вставить(Тип("ВидСчета"), Истина);
	Результат.Вставить(Тип("Структура"), Истина);
	Результат.Вставить(Тип("ФиксированнаяСтруктура"), Истина);
	Результат.Вставить(Тип("Массив"), Истина);
	Результат.Вставить(Тип("ФиксированныйМассив"), Истина);
	Результат.Вставить(Тип("Соответствие"), Истина);
	Результат.Вставить(Тип("ФиксированноеСоответствие"), Истина);
				
	#Если Сервер Тогда
					
		Результат.Вставить(Тип("РезультатЗапроса"), Истина);
		Результат.Вставить(Тип("ОбъектМетаданных"), Истина);
		
	#КонецЕсли
	
	Возврат Результат;
	
КонецФункции

