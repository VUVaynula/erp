#Область ПрограммныйИнтерфейс

Процедура ОбработкаГиперссылкиСвойства(Форма, ДанныеГиперссылки, ЗначениеСвойства, ПолноеИмяОбъектаМетаданных, СтандартнаяОбработка) Экспорт 
	
	СтандартнаяОбработка = Ложь;
	
	Если ДанныеГиперссылки.Свойство("Модуль") Тогда
		
		ПолноеИмяМодуля = ИТК_ИнструментМетаданныеКлиентСервер.ИмяМодуляИзДанныхГиперссылки(ДанныеГиперссылки.Модуль, ПолноеИмяОбъектаМетаданных, ЗначениеСвойства);
		ИТК_РедакторКодаКлиент.ОткрытьКодМодуля(ПолноеИмяМодуля);
		
	ИначеЕсли ДанныеГиперссылки.Свойство("ОбъектМетаданных") Тогда	
		
		ИТК_ТуллкитКлиент.ОткрытьИнструмент(ИТК_Перечисления.ИнструментМетаданные(), ЗначениеСвойства);
		
	ИначеЕсли ДанныеГиперссылки.Свойство("ОписаниеТипов") Тогда	
		
		ЭтоОписаниеТипов = (ТипЗнч(ЗначениеСвойства) = Тип("ОписаниеТипов"));
		Если ЭтоОписаниеТипов Тогда
			
			Если ИТК_ТипыКлиентСервер.КоличествоСсылочных(ЗначениеСвойства) = 1 Тогда

				Тип = ИТК_ТипыКлиентСервер.ПервыйСсылочный(ЗначениеСвойства);
				ПолноеИмя = ИТК_Метаданные.ПолноеИмя(Тип);
				Если ПолноеИмя = Неопределено Тогда
					Возврат;
				КонецЕсли;
				
				ИТК_ТуллкитКлиент.ОткрытьИнструмент(ИТК_Перечисления.ИнструментМетаданные(), ПолноеИмя);

			Иначе
				
				ДополнительныеПараметрыОповещения = Новый Структура;
				ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВыборТипаЗавершен", ЭтотОбъект, ДополнительныеПараметрыОповещения);
				ТолькоСсылочные = ИТК_ТипыКлиентСервер.СсылочныеТипы(ЗначениеСвойства);
				
				ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(Форма, Неопределено, ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборТипа(),
																			ТолькоСсылочные, ОписаниеОповещенияЗавершение);

			КонецЕсли;
			
		Иначе
			
			Если ЗначениеСвойства.Количество() = 1 Тогда
				
				ИмяТипа = ЗначениеСвойства[0];
				ПолноеИмя = ИТК_Метаданные.ПолноеИмя(Тип(ИмяТипа));
				ИТК_ТуллкитКлиент.ОткрытьИнструмент(ИТК_Перечисления.ИнструментМетаданные(), ПолноеИмя);
				
			Иначе
				
				ДополнительныеПараметрыОповещения = Новый Структура;
				ОписаниеОповещенияЗавершение = Новый ОписаниеОповещения("ВыборОбъектаМетаданныхЗавершен", ЭтотОбъект, ДополнительныеПараметрыОповещения);
				
				ДополнительныеПараметры = Новый Структура;
				ДополнительныеПараметры.Вставить("ДоступныеОбъекты", ЗначениеСвойства);
				
				ИТК_ФормаКлиент.ОткрытьРедактированиеТипаЗначения(Форма, Неопределено, ИТК_Перечисления.РежимРедактированияТипаЗначенияВыборОбъектаМетаданных(), ,
																	ОписаниеОповещенияЗавершение, , ДополнительныеПараметры);
				
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ДанныеГиперссылки.Свойство("Ссылка") Тогда
		
		ПоказатьЗначение( , ЗначениеСвойства);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборОбъектаМетаданныхЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_ТуллкитКлиент.ОткрытьИнструмент(ИТК_Перечисления.ИнструментМетаданные(), Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборТипаЗавершен(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Тип = ИТК_ТипыКлиентСервер.ПервыйСсылочный(Результат);
	ПолноеИмя = ИТК_Метаданные.ПолноеИмя(Тип);
	ИТК_ТуллкитКлиент.ОткрытьИнструмент(ИТК_Перечисления.ИнструментМетаданные(), ПолноеИмя);
	
КонецПроцедуры

#КонецОбласти

