Функция СтруктураЗначенияСвойства() Экспорт
	
	ПолеЗаголовок = "Заголовок";
	ПолеТипЗначения = "ТипЗначения";
	ПолеЭтоДополнительноеСведение = "ЭтоДополнительноеСведение";
	
	ПолеОбъект = "Объект";
	ПолеСвойство = "Свойство";
	ПолеЗначение = "Значение";
	Если ИТК_БСППовтИсп.АнглийскаяБСП() Тогда
		
		ПолеЗаголовок = "Title";
		ПолеТипЗначения = "ValueType";
		ПолеЭтоДополнительноеСведение = "IsAdditionalInfo";
		
		ПолеОбъект = "Object";
		ПолеСвойство = "Property";
		ПолеЗначение = "Value";
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ПолеОбъект", ПолеОбъект);
	Результат.Вставить("ПолеСвойство", ПолеСвойство);
	Результат.Вставить("ПолеЗначение", ПолеЗначение);
	
	Результат.Вставить("ПолеЗаголовок", ПолеЗаголовок);
	Результат.Вставить("ПолеТипЗначения", ПолеТипЗначения);
	Результат.Вставить("ПолеЭтоДополнительноеСведение", ПолеЭтоДополнительноеСведение);
	
	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить(ПолеЗаголовок);
	СписокСвойств.Добавить(ПолеТипЗначения);
	СписокСвойств.Добавить(ПолеЭтоДополнительноеСведение);
	Результат.Вставить("Список", СтрСоединить(СписокСвойств, ","));
	
	Возврат Результат;
	
КонецФункции

Процедура УстановитьЗначениеДополнительногоСвойстваОбъекта(Объект, Свойство, Значение) Экспорт
	
	СтруктураЗначенияСвойства = СтруктураЗначенияСвойства();
	
	ЭтоДополнительноеСведение = ИТК_Общий.ЗначениеРеквизитаОбъекта(Свойство, СтруктураЗначенияСвойства.ПолеЭтоДополнительноеСведение);
	Если ЭтоДополнительноеСведение Тогда
		
		ИмяРегистраДополнительныеСведения = "ДополнительныеСведения";
		Если ИТК_БСППовтИсп.АнглийскаяБСП() Тогда
			ИмяРегистраДополнительныеСведения = "AdditionalInfo";
		КонецЕсли;
		
		МенеджерЗаписи = РегистрыСведений[ИмяРегистраДополнительныеСведения].СоздатьМенеджерЗаписи(); 
		
		МенеджерЗаписи[СтруктураЗначенияСвойства.ПолеОбъект] = Объект.Ссылка;
		МенеджерЗаписи[СтруктураЗначенияСвойства.ПолеСвойство] = Свойство;
		МенеджерЗаписи[СтруктураЗначенияСвойства.ПолеЗначение] = Значение;
		
		МенеджерЗаписи.Записать();
		
	Иначе
		
		ТабличнаяЧастьСвойства = Объект[ИмяТЧДополнительныеРеквизиты()];
		
		Строка = ТабличнаяЧастьСвойства.Найти(Свойство, "Свойство");
		Если Строка = Неопределено Тогда
			
			Строка = ТабличнаяЧастьСвойства.Добавить();
			Строка[СтруктураЗначенияСвойства.ПолеСвойство] = Свойство;
			
		КонецЕсли;
		
		Строка.Значение = Значение;
		
	КонецЕсли;
	
КонецПроцедуры

Функция РаботаСВнешнимиРесурсамиЗаблокирована() Экспорт
	
	Если НЕ ИТК_БСППовтИсп.СуществуетПодсистема("СтандартныеПодсистемы.РегламентныеЗадания") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ИТК_МетаданныеПовтИсп.ИмяКонфигурации() = "Drive" Тогда
		ИмяМодуля = "РегламентныеЗаданияСлужебный";
	Иначе
		
		Если Поддерживается("3.0") Тогда
			ИмяМодуля = "РегламентныеЗаданияСервер";
		Иначе
			ИмяМодуля = "РегламентныеЗаданияСлужебный";
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ИТК_БСПКлиентСервер.ВыполнитьФункцию(ИмяМодуля + ".РаботаСВнешнимиРесурсамиЗаблокирована");
	
КонецФункции

Процедура РазблокироватьРаботуСВнешнимиРесурсами() Экспорт
	
	Если НЕ ИТК_БСППовтИсп.СуществуетПодсистема("СтандартныеПодсистемы.РегламентныеЗадания") Тогда
		Возврат;
	КонецЕсли;
	
	ИТК_БСПКлиентСервер.ВыполнитьПроцедуру("РегламентныеЗаданияСервер.РазблокироватьРаботуСВнешнимиРесурсами");
	
КонецПроцедуры

Функция РегламентноеЗаданиеДоступноПоФункциональнымОпциям(Задание, ЗависимостиЗаданий = Неопределено) Экспорт
	
	Если НЕ ИТК_БСППовтИсп.СуществуетПодсистема("СтандартныеПодсистемы.РегламентныеЗадания") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыФункции = Новый Массив;
	ПараметрыФункции.Добавить(Задание);
	ПараметрыФункции.Добавить(ЗависимостиЗаданий);
	
	Возврат ИТК_БСПКлиентСервер.ВыполнитьФункцию("РегламентныеЗаданияСлужебный.РегламентноеЗаданиеДоступноПоФункциональнымОпциям", ПараметрыФункции);
	
КонецФункции

Функция ДополнительнаяИнформацияПоРегламентномуЗаданию(ОбъектМетаданных) Экспорт
	
	ЗависимыеРегламентныеЗадания = ИТК_БСППовтИсп.РегламентныеЗаданияЗависимыеОтФункциональныхОпций();
	
	РаботаетСВнешнимиРесурсами = Ложь;
	ФункциональнаяОпция = "";
	ДоступноПоФункциональнымОпциям = Истина;
	ЗаданиеВМоделиСервиса = Ложь;
	

	Если ИТК_БСППовтИсп.АнглийскаяБСП() Тогда
		
		ПолеОписанияРегламентноеЗадание = "ScheduledJob";
		ПолеОписанияФункциональнаяОпция = "FunctionalOption";
		ПолеОписанияРаботаетСВнешнимиРесурсами = "UseExternalResources";
		
	Иначе
		
		ПолеОписанияРегламентноеЗадание = "РегламентноеЗадание";
		ПолеОписанияФункциональнаяОпция = "ФункциональнаяОпция";
		ПолеОписанияРаботаетСВнешнимиРесурсами = "РаботаетСВнешнимиРесурсами";
		
	КонецЕсли;
	
	ОписаниеРегламентногоЗадания = Неопределено;
	Если ЗависимыеРегламентныеЗадания <> Неопределено Тогда
		
		ОписаниеРегламентногоЗадания = ЗависимыеРегламентныеЗадания.Найти(ОбъектМетаданных, ПолеОписанияРегламентноеЗадание);
		
	КонецЕсли;
	
	Если ОписаниеРегламентногоЗадания <> Неопределено Тогда
		
		ФункциональнаяОпция = ОписаниеРегламентногоЗадания[ПолеОписанияФункциональнаяОпция];
		Если ТипЗнч(ФункциональнаяОпция) = Тип("ОбъектМетаданных") Тогда
			ФункциональнаяОпция = ФункциональнаяОпция.Имя;
		КонецЕсли;
		РаботаетСВнешнимиРесурсами = ОписаниеРегламентногоЗадания[ПолеОписанияРаботаетСВнешнимиРесурсами];
		
		ДоступноПоФункциональнымОпциям = РегламентноеЗаданиеДоступноПоФункциональнымОпциям(ОбъектМетаданных, ЗависимыеРегламентныеЗадания);
		
		РегламентныеЗаданияВМоделиСервиса = ИТК_БСППовтИсп.РегламентныеЗаданияВМоделиСервиса();
		ЗаданиеВМоделиСервиса = (РегламентныеЗаданияВМоделиСервиса.Получить(ОбъектМетаданных) <> Неопределено);
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("РаботаетСВнешнимиРесурсами", РаботаетСВнешнимиРесурсами);
	Результат.Вставить("ФункциональнаяОпция", ФункциональнаяОпция);
	Результат.Вставить("ДоступноПоФункциональнымОпциям", ДоступноПоФункциональнымОпциям);
	Результат.Вставить("ЗаданиеВМоделиСервиса", ЗаданиеВМоделиСервиса);
	
	Возврат Результат;
	
КонецФункции

Функция Поддерживается(ТребуемаяВерсия = Неопределено) Экспорт 
	
	ВерсияБСП = ИТК_БСППовтИсп.Версия();
	Если ВерсияБСП = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ТребуемаяВерсия = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат (ИТК_ОбщийКлиентСервер.СравнитьВерсии(ВерсияБСП, ТребуемаяВерсия) >= 0);
	
КонецФункции

Функция ТекстЗапросаГруппыПользователей() Экспорт
	
	ИмяИсточника = "ГруппыПользователей";
	
	ШаблонЗапроса = "ВЫБРАТЬ
	|	ГруппыПользователей.Ссылка КАК Группа
	|ИЗ
	|	Справочник.%1 КАК ГруппыПользователей
	|{ГДЕ
	|	ГруппыПользователей.Ссылка.* КАК Группа}";

	Возврат СтрШаблон(ШаблонЗапроса, ИмяИсточника);
	
КонецФункции

Функция ПолноеИмяФормыСтандартнойОбработки(Идентификатор) Экспорт
	
	ОбъектМетаданных = Метаданные.Обработки.Найти(Идентификатор);
	
	Если ОбъектМетаданных <> Неопределено Тогда
		Возврат СтрШаблон("Обработка.%1.Форма", Идентификатор);
	КонецЕсли;
	
	АнглийскийИдентификатор = ИТК_БСПКлиентСерверПовтИсп.АнглийскийИдентификаторСтандартнойОбработки(Идентификатор);
	ОбъектМетаданных = Метаданные.Обработки.Найти(АнглийскийИдентификатор);
	
	Если ОбъектМетаданных = Неопределено Тогда
		Результат = Неопределено;
	Иначе	
		Результат = СтрШаблон("Обработка.%1.Форма", АнглийскийИдентификатор);
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Функция ДанныеФормыШаблонаОтчетаНаСКД(НавигационнаяСсылка) Экспорт
	
	ВариантОтчета = ИТК_Общий.СсылкаПоНавигационнойСсылке(НавигационнаяСсылка);
	
	Результат = Новый Структура;
	Результат.Вставить("ВариантОтчета", ВариантОтчета);
	
	ИмяПоля = "Отчет.Имя";
	Если ИТК_БСППовтИсп.АнглийскаяБСП() Тогда
		ИмяПоля = "Report.Name";
	КонецЕсли;
	ИмяОтчета = ИТК_Общий.ЗначениеРеквизитаОбъекта(ВариантОтчета, ИмяПоля);
	Результат.Вставить("НавигационнаяСсылка", "e1cib/app/Отчет." + ИмяОтчета);
	
	Возврат Результат;
	
КонецФункции

Функция ИдентификаторПользователяИБИзСсылкиСправочникаПользователи(Пользователь) Экспорт

	ИмяПоляИдентификаторПользователяИБ = "ИдентификаторПользователяИБ";
	Если ИТК_БСППовтИсп.АнглийскаяБСП() Тогда
		ИмяПоляИдентификаторПользователяИБ = "IBUserID";
	КонецЕсли;
	
	Возврат ИТК_Общий.ЗначениеРеквизитаОбъекта(Пользователь, ИмяПоляИдентификаторПользователяИБ);

КонецФункции

Функция СлужебнаяТЧ(ОбъектМетаданных, Коллекция, ИмяТЧ) Экспорт
	
	Если ИТК_Метаданные.ЭтоСправочник(Коллекция)
			И ОбъектМетаданных.Имя = ИмяСправочникаНаборыДополнительныхРеквизитовИСведений() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат (ИмяТЧ = ИмяТЧДополнительныеРеквизиты());
	
КонецФункции
	
