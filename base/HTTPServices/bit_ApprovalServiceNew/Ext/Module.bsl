Функция RefreshToken(Запрос)
		
	ИмяСобытия = НСтр("ru = 'approval/v1/refresh_token'; en = 'approval/v1/refresh_token'",
		ОбщегоНазначения.КодОсновногоЯзыка());
	Попытка
		ЗапросJSON    = Запрос.ПолучитьТелоКакСтроку();
		ДанныеЗапроса = ЗначениеИзСтрокиJSON(ЗапросJSON);
		Результат     = ЗарегистрироватьУстройство(ДанныеЗапроса.Token, ДанныеЗапроса.DeviceId,
														ДанныеЗапроса.OS, ДанныеЗапроса.UserName);
		Ответ = СформироватьОтветJSON(Результат);
		Если Константы.бит_РежимОтладкиВебСервисов.Получить() Тогда
			ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Вызов метода RefreshToken.
                                   |Параметры: %1
                                   |Результат: %2';
								   |en = 'HTTP service bit_ApprovalServiceNew. Call the RefreshToken method.
                                   |Parameters: %1
                                   |Result: %2'");	
			ТекстСообщения = СтрШаблон(ТекстСообщения, ЗапросJSON, Ответ); 
			ЗарегистрироватьИнформацию(ИмяСобытия, ТекстСообщения);				
		КонецЕсли; 		
	Исключение
		Ответ = Новый Структура("code, message, error");
		Ответ.code     = "500";
		Ответ.message  = "Server error.";
		Ответ.error    = "500";
		ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Ошибка метода RefreshToken.
                               |Параметры: %1
                               |Описание ошибки: %2';
