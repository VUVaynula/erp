Функция ПолучитьСсылку(ТипОбъекта, ИдентификаторОбъекта)
	
	ПозицияРазделителя = Найти(ТипОбъекта, ".");
	
	Если НЕ ПозицияРазделителя = 0 Тогда
		ТипОбъекта = Сред(ТипОбъекта, ПозицияРазделителя+1, СтрДлина(ТипОбъекта));
	КонецЕсли;
	
	Если бит_МобильноеПриложениеПереопределяемый.ЭтоСправочник(ТипОбъекта) Тогда
		МенеджерОбъекта = Справочники[ТипОбъекта];
	Иначе
		МенеджерОбъекта = Документы[ТипОбъекта];
	КонецЕсли;
	
	Попытка
		УИД            = Новый УникальныйИдентификатор(ИдентификаторОбъекта);
		ОбъектСсылка   = МенеджерОбъекта.ПолучитьСсылку(УИД);
		ДокументОбъект = ОбъектСсылка.ПолучитьОбъект();
	Исключение
		ДокументОбъект = Неопределено;
	КонецПопытки;
	
	Если ДокументОбъект = Неопределено Тогда
		ОбъектСсылка = Неопределено;
	КонецЕсли;
	
	Возврат ОбъектСсылка;
	
КонецФункции

// Функция реализует проверку настройки "Необходим комментарий или задача" по всем вариантам
Функция НеобходимКомментарийЗадачаПолнаяПроверка(Организация, ПолноеИмяОбъекта, ВидРешения)
	
	ОбъектСистемы = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(ПолноеИмяОбъекта);
	
	// 1. Организация, ОбъектСистемы, ВидРешения - все реквизиты заполнены	
	Результат = бит_МобильноеПриложениеПереопределяемый.НеобходимКомментарийЗадача(Организация,
	    ОбъектСистемы, ВидРешения);

	Если Результат.ЗаписьСуществует Тогда
		Возврат Результат.НеобходимКомментарийЗадача; 
	КонецЕсли;
	
	// 2. ОбъектСистемы, ВидРешения - реквизиты заполнены, Организация - не заполнена.
	Результат = бит_МобильноеПриложениеПереопределяемый.НеобходимКомментарийЗадача(
							Справочники.Организации.ПустаяСсылка(), ОбъектСистемы, ВидРешения);	

	Если Результат.ЗаписьСуществует Тогда
		Возврат Результат.НеобходимКомментарийЗадача; 
	КонецЕсли;
	
	// 3. Организация, ВидРешения - реквизиты заполнены, ОбъектСистемы - не заполнен.
	Результат = бит_МобильноеПриложениеПереопределяемый.НеобходимКомментарийЗадача(
							Организация, Справочники.бит_ОбъектыСистемы.ПустаяСсылка(), ВидРешения);	

	Если Результат.ЗаписьСуществует Тогда
		Возврат Результат.НеобходимКомментарийЗадача; 
	КонецЕсли;
	
	// 4. ВидРешения - реквизит заполнены, Организация, ОбъектСистемы - не заполнены.
	Результат = бит_МобильноеПриложениеПереопределяемый.НеобходимКомментарийЗадача(
		Справочники.Организации.ПустаяСсылка(), Справочники.бит_ОбъектыСистемы.ПустаяСсылка(), ВидРешения);	

	Если Результат.ЗаписьСуществует Тогда
		Возврат Результат.НеобходимКомментарийЗадача; 
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ПолучитьОбъектыСистемы(ИменаОбъектов)

	Результат = Новый Массив;
	Результат.Добавить(Справочники.бит_ОбъектыСистемы.ПустаяСсылка());
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИменаОбъектов", ИменаОбъектов);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОбъектыСистемы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.бит_ОбъектыСистемы КАК ОбъектыСистемы
	|ГДЕ
	|	ОбъектыСистемы.ИмяОбъекта В(&ИменаОбъектов)";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ДанныеТабличнойЧасти(ДанныеЗапроса)
	
	Результат = Новый Структура;
	Результат.Вставить("Version",      "");
	Результат.Вставить("ErrorMessage", "");
	Результат.Вставить("Lines",         Новый Массив);
	
	Если НЕ ТипЗнч(ДанныеЗапроса) = Тип("Структура") Тогда
		Результат.ErrorMessage = НСтр("ru = 'Неверные данные для обработки.'; en = 'Incorrect data for processing.'",
		    ОбщегоНазначения.КодОсновногоЯзыка());
		Возврат Результат;
	КонецЕсли;
	
	ТипОбъекта = ДанныеЗапроса.ObjectType;
	ИдентификаторОбъекта = ДанныеЗапроса.ID;
	
	УстановитьПривилегированныйРежим(Истина);
	
	ОбъектСсылка = ПолучитьСсылку(ТипОбъекта, ИдентификаторОбъекта);
	Если ОбъектСсылка = Неопределено Тогда
		Результат.ErrorMessage = НСтр("ru = 'Объект не найден.'; en = 'Object not found.'",
		    ОбщегоНазначения.КодОсновногоЯзыка());
		Возврат Результат;
	КонецЕсли;
	
	бит_МобильноеПриложениеПереопределяемый.ДанныеТабличнойЧасти(ОбъектСсылка, Результат);
	
	Возврат Результат;
	
КонецФункции

Функция УстановитьДанныеТабличнойЧасти(ДанныеЗапроса = Неопределено)
	
	Результат = Новый Структура;
	Результат.Вставить("ErrorMessage", "");
	
	Если НЕ ТипЗнч(ДанныеЗапроса) = Тип("Структура") Тогда
		Результат.ErrorMessage = НСтр("ru = 'Неверные данные для обработки.'; en = 'Incorrect data for processing.'",
		    ОбщегоНазначения.КодОсновногоЯзыка());
		Возврат Результат;
	КонецЕсли;
	
	ТипОбъекта = ДанныеЗапроса.ObjectType;
	ИдентификаторОбъекта = ДанныеЗапроса.ID;
	
	УстановитьПривилегированныйРежим(Истина);
	
	ОбъектСсылка = ПолучитьСсылку(ТипОбъекта, ИдентификаторОбъекта);
	Если ОбъектСсылка = Неопределено Тогда
		Результат.ErrorMessage = НСтр("ru = 'Объект не найден.'; en = 'Object not found.'",
		    ОбщегоНазначения.КодОсновногоЯзыка());
		Возврат Результат;
	КонецЕсли;
	
	Если ДанныеЗапроса.Lines.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	бит_МобильноеПриложениеПереопределяемый.УстановитьДанныеТабличнойЧасти(ОбъектСсылка, ДанныеЗапроса, Результат);
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьОбъектПоИдентификатору(ПараметрыОбъекта)
	
	Ид              = ПараметрыОбъекта.ID;
	Имя             = ПараметрыОбъекта.ObjectName;
	ИмяПользователя = ПараметрыОбъекта.User;
	
	УстановитьПривилегированныйРежим(Истина);
	ТекПользователь = НайтиПользователя(ИмяПользователя);
	Если НЕ ЗначениеЗаполнено(ТекПользователь) Тогда
		ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Ошибка метода GetObject.
                               |Не удалось найти пользователя по имени: %1';
							   |en = 'HTTP service bit_ApprovalServiceNew. GetObject method error.
                               |Could not find user by name: %1'");		
		ТекстСообщения = СтрШаблон(ТекстСообщения, ИмяПользователя);
		ИмяСобытия = НСтр("ru = 'approval/v1/object'; en = 'approval/v1/object'", ОбщегоНазначения.КодОсновногоЯзыка());
		ЗарегистрироватьОшибку(ИмяСобытия, ТекстСообщения);			
	КонецЕсли; 
	
	Результат = Неопределено;
	
	// Получаем ссылку.
	Если НЕ ЗначениеЗаполнено(Имя) Тогда
		ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Ошибка метода GetObject.
                               |Пустое значение обязательного параметра ObjectName';
							   |en = 'HTTP service bit_ApprovalServiceNew. GetObject method error.
                               |Empty value of the required parameter ObjectName'");		
		ТекстСообщения = СтрШаблон(ТекстСообщения, ИмяПользователя);
		ИмяСобытия = НСтр("ru = 'approval/v1/object'; en = 'approval/v1/object'", ОбщегоНазначения.КодОсновногоЯзыка());
		ЗарегистрироватьОшибку(ИмяСобытия, ТекстСообщения);			
		Возврат Результат;
	КонецЕсли;
	
	Если бит_МобильноеПриложениеПереопределяемый.ЭтоСправочник(Имя) Тогда
		МенеджерОбъекта = Справочники[Имя];
	Иначе
		МенеджерОбъекта = Документы[Имя];
	КонецЕсли;
	
	УИД = Новый УникальныйИдентификатор(Ид);
	СсылкаОбъекта = МенеджерОбъекта.ПолучитьСсылку(УИД);
	
	Если ОбщегоНазначения.СсылкаСуществует(СсылкаОбъекта) Тогда
		Объекты = Новый Массив();
		Объекты.Добавить(СсылкаОбъекта);
		РеквизитыОбъектов = РеквизитыОбъектов(Объекты);	
		// Получение сведений о прикрепленных файлах.
		ПрикрепленныеФайлы = ПолучитьИнформациюФайлов(Объекты);
		
		ЗаявкаНаРС = РеквизитыОбъектов.Найти(СсылкаОбъекта, "ОбъектВизирования");
		Если ЗаявкаНаРС <> Неопределено Тогда
			ЗапросПлатежнойПозиции = бит_МобильноеПриложениеПереопределяемый.ЗапросПлатежнойПозиции();
			Результат = ЗаполнитьОбъектВизирования(ЗаявкаНаРС, ПрикрепленныеФайлы, ЗапросПлатежнойПозиции);
		КонецЕсли;

	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
 
Функция СтрокаВДату(Знач Значение)
	
	Если НЕ ПустаяСтрока(Значение) Тогда
		Значение = Лев(Значение, 8);
		Значение = СтроковыеФункцииКлиентСервер.СтрокаВДату(Значение);
	Иначе
		Значение = Дата('0001.01.01');
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции 

