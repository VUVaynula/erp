Функция GetServiceInfo(Запрос)
	
	ИмяСобытия = НСтр("ru = 'approval/v1/service_info/'; en = 'approval/v1/service_info/'",
		ОбщегоНазначения.КодОсновногоЯзыка());
	Попытка
		Данные = ИнформацияОСервисе();
		Ответ  = СформироватьОтветJSON(Данные);
		Если Константы.бит_РежимОтладкиВебСервисов.Получить() Тогда
			ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Вызов метода ServiceInfo.
                                   |Результат: %1';
								   |en = 'HTTP service bit_ApprovalServiceNew. Call the ServiceInfo method.
                                   |Result: %1'"); 
			ТекстСообщения = СтрШаблон(ТекстСообщения, Ответ); 
			ЗарегистрироватьИнформацию(ИмяСобытия, ТекстСообщения);				
		КонецЕсли;
	Исключение
		ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Ошибка метода ServiceInfo.
                               |Описание ошибки: %1';
							   |en = 'HTTP service bit_ApprovalServiceNew. ServiceInfo method error.
                               |Error description: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 
		ЗарегистрироватьОшибку(ИмяСобытия, ТекстСообщения);			
		Ответ = Неопределено;		
	КонецПопытки;
	
	Возврат Ответ;
	
КонецФункции

// Диагностический метод проверки доступности сервера и API.
//
// Параметры:
//  Запрос	 - HTTPСервисЗапрос	 - Запрос от мобильного приложения,
//  	см. общий макет бит_ОписаниеСервисаМобильногоВизирования.
// 
// Возвращаемое значение:
//  HTTPСервисОтвет - Ответ с информацией в теле, см. общий макет бит_ОписаниеСервисаМобильногоВизирования.
//
Функция Ping(Запрос)
	
	Если Константы.бит_РежимОтладкиВебСервисов.Получить() Тогда
		ИмяСобытия = НСтр("ru = 'approval/v1/ping/'; en = 'approval/v1/ping/'", ОбщегоНазначения.КодОсновногоЯзыка());
		ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Вызов метода Ping.';
								|en = 'HTTP service bit_ApprovalServiceNew. Call the Ping method.'");
		ЗарегистрироватьИнформацию(ИмяСобытия, ТекстСообщения);
	КонецЕсли; 
	
	Возврат СформироватьОтветJSON("pong");
	
КонецФункции

