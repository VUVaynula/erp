		ТекстСообщения = СтрШаблон(ТекстСообщения, ЗапросJSON,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 
		ЗарегистрироватьОшибку(ИмяСобытия, ТекстСообщения);					
	КонецПопытки;
		
	Возврат Ответ;
	
КонецФункции

