Функция ПринятьЗадачуЗапрос(Запрос)
	
	ИмяСобытия = НСтр("ru = 'approval/v1/task/accept'; en = 'approval/v1/task/accept'",
		ОбщегоНазначения.КодОсновногоЯзыка());
	Попытка
		ЗапросJSON    = Запрос.ПолучитьТелоКакСтроку();
		ДанныеЗапроса = ЗначениеИзСтрокиJSON(ЗапросJSON);
		Результат     = ПринятьЗадачу(ДанныеЗапроса.ID, ДанныеЗапроса.Result);
		Ответ         = СформироватьОтветJSON(Результат);
		Если Константы.бит_РежимОтладкиВебСервисов.Получить() Тогда
			ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Вызов метода AcceptTask.
                                   |Параметры: %1
                                   |Результат: %2';
								   |en = 'HTTP service bit_ApprovalServiceNew. Call the AcceptTask method.
                                   |Parameters: %1
                                   |Result: %2'");	
			ТекстСообщения = СтрШаблон(ТекстСообщения, ЗапросJSON, Ответ); 
			ЗарегистрироватьИнформацию(ИмяСобытия, ТекстСообщения);				
		КонецЕсли; 
	Исключение
		ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Вызов метода AcceptTask.
                               |Параметры: %1
                               |Описание ошибки: %2';
							   |en = 'HTTP service bit_ApprovalServiceNew. Call the AcceptTask method.
                               |Parameters: %1
                               |Error description: %2'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ЗапросJSON,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 
		ЗарегистрироватьОшибку(ИмяСобытия, ТекстСообщения);				
		Ответ = Ложь;
	КонецПопытки;
	
	Возврат Ответ;
	
