Функция ЕстьЗадачиПоДокументу(Ссылка, Виза)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Задача.Ссылка КАК Ссылка,
	|	Задача.Предмет КАК Предмет
	|ИЗ
	|	Задача.бит_Задача КАК Задача
	|ГДЕ
	|	Задача.Виза = &Виза
	|	И Задача.Предмет = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Виза",   Виза);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат НЕ РезультатЗапроса.Пустой();
	
КонецФункции

Функция ПолучитьЗадачи(User)
	
	УстановитьПривилегированныйРежим(Истина);	
	Результат = Новый Массив;
	ТекПользователь = НайтиПользователя(User);
	Если НЕ ЗначениеЗаполнено(ТекПользователь) Тогда
		ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Ошибка метода Tasks.
                               |Не удалось найти пользователя по имени: %1';
							   |en = 'HTTP service bit_ApprovalServiceNew. Tasks method error.
                               |Could not find user by name: %1'");		
		ТекстСообщения = СтрШаблон(ТекстСообщения, User);
		ИмяСобытия = НСтр("ru = 'approval/v1/tasks'; en = 'approval/v1/tasks'", ОбщегоНазначения.КодОсновногоЯзыка());
		ЗарегистрироватьОшибку(ИмяСобытия, ТекстСообщения);			
	КонецЕсли; 
	
	ТипыОбъектовВизирования = бит_МобильноеПриложениеПереопределяемый.ТипыОбъектов();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекПользователь",         ТекПользователь);
	Запрос.УстановитьПараметр("ТипыОбъектовВизирования", ТипыОбъектовВизирования);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	""MyTasks"" КАК Direction,
	|	ЗадачаПоИсполнителю.Ссылка КАК Ref,
	|	ЗадачаПоИсполнителю.Выполнена КАК IsCompleted,
	|	ЗадачаПоИсполнителю.Номер КАК Number,
	|	ЗадачаПоИсполнителю.Состояние КАК State,
	|	ЕСТЬNULL(ЗадачаПоИсполнителю.Состояние.Наименование, """") КАК StateName,
	|	ЗадачаПоИсполнителю.Дата КАК Date,
	|	ЗадачаПоИсполнителю.СрокИсполнения КАК Deadline,
	|	ЗадачаПоИсполнителю.Наименование КАК Name,
	|	ЗадачаПоИсполнителю.Автор КАК Author,
	|	ЕСТЬNULL(ЗадачаПоИсполнителю.Автор.Наименование, """") КАК AuthorName,
	|	ЗадачаПоИсполнителю.Исполнитель КАК Responsible,
	|	ЕСТЬNULL(ЗадачаПоИсполнителю.Исполнитель.Наименование, """") КАК ResponsibleName,
	|	ЗадачаПоИсполнителю.Важность КАК Importance,
	|	ЗадачаПоИсполнителю.Описание КАК Description,
	|	ЗадачаПоИсполнителю.РезультатВыполнения КАК Result,
	|	ЗадачаПоИсполнителю.Предмет КАК Object
	|ПОМЕСТИТЬ ВсеЗадачи
	|ИЗ
	|	Задача.бит_Задача.ЗадачиПоИсполнителю(
	|			&ТекПользователь,
	|			Выполнена = ЛОЖЬ
	|				И АлгоритмПодчиненный = ЗНАЧЕНИЕ(Справочник.бит_АлгоритмыПроцессов.ПустаяСсылка)
	|				И Состояние <> ЗНАЧЕНИЕ(Справочник.бит_СтатусыОбъектов.Задача_Остановлена)) КАК ЗадачаПоИсполнителю
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	""TasksFromMe"",
	|	Задача.Ссылка,
	|	Задача.Выполнена,
	|	Задача.Номер,
	|	Задача.Состояние,
	|	ЕСТЬNULL(Задача.Состояние.Наименование, """"),
	|	Задача.Дата,
	|	Задача.СрокИсполнения,
	|	Задача.Наименование,
	|	Задача.Автор,
	|	ЕСТЬNULL(Задача.Автор.Наименование, """"),
	|	Задача.Исполнитель,
	|	ЕСТЬNULL(Задача.Исполнитель.Наименование, """"),
	|	Задача.Важность,
	|	Задача.Описание,
	|	Задача.РезультатВыполнения,
	|	Задача.Предмет
	|ИЗ
	|	Задача.бит_Задача КАК Задача
	|ГДЕ
	|	Задача.Автор = &ТекПользователь
	|	И Задача.БизнесПроцесс = ЗНАЧЕНИЕ(БизнесПроцесс.бит_Процесс.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВсеЗадачи.Object КАК Object
	|ИЗ
	|	ВсеЗадачи КАК ВсеЗадачи
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(ВсеЗадачи.Object) В (&ТипыОбъектовВизирования)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеЗадачи.Direction КАК Direction,
	|	ВсеЗадачи.Ref КАК Ref,
	|	ВсеЗадачи.IsCompleted КАК IsCompleted,
	|	ВсеЗадачи.Number КАК Number,
	|	ВсеЗадачи.State КАК State,
	|	ВсеЗадачи.StateName КАК StateName,
	|	ВсеЗадачи.Date КАК Date,
	|	ВсеЗадачи.Deadline КАК Deadline,
	|	ВсеЗадачи.Name КАК Name,
	|	ВсеЗадачи.Author КАК Author,
	|	ВсеЗадачи.AuthorName КАК AuthorName,
	|	ВсеЗадачи.Responsible КАК Responsible,
	|	ВсеЗадачи.ResponsibleName КАК ResponsibleName,
	|	ВсеЗадачи.Importance КАК Importance,
	|	ВсеЗадачи.Description КАК Description,
	|	ВсеЗадачи.Result КАК Result,
	|	ВсеЗадачи.Object КАК Object
	|ИЗ
	|	ВсеЗадачи КАК ВсеЗадачи";
				   
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ОбъектыЗадач = РезультатЗапроса[1].Выгрузить().ВыгрузитьКолонку("Object");
	РеквизитыОбъектовЗадач = Новый ТаблицаЗначений;
	Если ОбъектыЗадач.Количество() > 0 Тогда
		РеквизитыОбъектовЗадач = РеквизитыОбъектов(ОбъектыЗадач);	
		// Получение сведений о прикрепленных файлах.
		ПрикрепленныеФайлы = ПолучитьИнформациюФайлов(ОбъектыЗадач);
	КонецЕсли;
	
	ЗапросПлатежнойПозиции = бит_МобильноеПриложениеПереопределяемый.ЗапросПлатежнойПозиции();
	Выборка = РезультатЗапроса[2].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		МетаОбъект = Выборка.Ref.Метаданные();
		Имена = бит_ОбщегоНазначенияКлиентСервер.РазобратьПолноеИмяОбъекта(МетаОбъект.ПолноеИмя());
		
		МодельОбъекта = Новый Структура("ID, ObjectName, CollectionName");
		МодельОбъекта.ID             = XMLСтрока(Выборка.Ref);
		МодельОбъекта.ObjectName     = Имена.ИмяОбъекта;
		МодельОбъекта.CollectionName = Имена.ИмяКоллекции;
		
		Задача = Новый Структура;
		Задача.Вставить("ObjectModel",     МодельОбъекта);
		Задача.Вставить("Direction",       Выборка.Direction);
		Задача.Вставить("IsCompleted",     Выборка.IsCompleted);
		Задача.Вставить("Number",          Выборка.Number);
		Задача.Вставить("State",           Выборка.StateName);
		Задача.Вставить("Date",            Выборка.Date);
		Задача.Вставить("Deadline",        Выборка.Deadline);
		Задача.Вставить("Name",            Выборка.Name);
		Задача.Вставить("Author",          Выборка.AuthorName);
		Задача.Вставить("Responsible",     Выборка.ResponsibleName);
		Задача.Вставить("Importance",      Строка(Выборка.Importance));
		Задача.Вставить("Description",     Выборка.Description);
		Задача.Вставить("Result",          Выборка.Result);
		Задача.Вставить("Object",          Строка(Выборка.Object));
		Задача.Вставить("RelatedDocument", Неопределено);
		
		Если ЗначениеЗаполнено(Выборка.Object)
			И РеквизитыОбъектовЗадач.Количество() > 0 Тогда
			
			ОбъектЗадачи = РеквизитыОбъектовЗадач.Найти(Выборка.Object ,"ОбъектВизирования");
			Если ОбъектЗадачи <> Неопределено Тогда
				Задача.RelatedDocument = ЗаполнитьОбъектВизирования(ОбъектЗадачи, ПрикрепленныеФайлы, ЗапросПлатежнойПозиции, Истина);
			КонецЕсли;
		КонецЕсли;
		
		Результат.Добавить(Задача);		
		
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);	
	
	Возврат Результат;
	
КонецФункции

Функция РеквизитыОбъектов(ОбъектыЗадач, РежимАрхива = Ложь, РежимПолученияРеквизитов = Ложь)
	
	СписокОбъектовВизирования = Новый СписокЗначений;
	СписокОбъектовВизирования.ЗагрузитьЗначения(ОбъектыЗадач);
	
	АдресВХранилище = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор); 
	МатрицаДоступа = Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа();
	
	ПараметрыПолучения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
	ПараметрыПолучения.МатрицаДоступа           = МатрицаДоступа;
	ПараметрыПолучения.ВыводитьВТаблицуЗначений = Истина;
	ПараметрыПолучения.ЭтоМобильноеПриложение   = Истина;
	ПараметрыПолучения.РежимАрхива              = РежимАрхива;
	ПараметрыПолучения.РежимПолученияРеквизитов = РежимПолученияРеквизитов;
	ПараметрыПолучения.Отбор.ОбъектВизирования  = СписокОбъектовВизирования;
 	Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
	
	Результат = ПолучитьИзВременногоХранилища(АдресВХранилище);
	Возврат Результат.РезультатТаблицаЗначений;
	
КонецФункции

Функция ПринятьЗадачу(ID, Result)
	
	Результат    = Ложь;
	ЗадачаСсылка = Задачи.бит_Задача.ПолучитьСсылку(Новый УникальныйИдентификатор(ID));
	Если ЗначениеЗаполнено(ЗадачаСсылка) Тогда
		Структура = Новый Структура;
		Если ЗначениеЗаполнено(Result) Тогда		
			Структура.Вставить("РезультатВыполнения", Result);		
		КонецЕсли; 		
		Результат = Задачи.бит_Задача.ПринятьЗадачу(ЗадачаСсылка,,Структура);		
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции

Функция ВыполнитьЗадачу(ID, Result)
	
	Результат    = Ложь;
	ЗадачаСсылка = Задачи.бит_Задача.ПолучитьСсылку(Новый УникальныйИдентификатор(ID));
	Если ЗначениеЗаполнено(ЗадачаСсылка) Тогда
		СтрПар = Новый Структура;
		Если ЗначениеЗаполнено(Result) Тогда		
			СтрПар.Вставить("РезультатВыполнения", Result);		
		КонецЕсли; 
		Результат = Задачи.бит_Задача.ОтметитьВыполнение(ЗадачаСсылка,,,СтрПар);
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции

Функция ЗаписатьЗадачу(ID, Result)
	
	Результат    = Ложь;
	ЗадачаСсылка = Задачи.бит_Задача.ПолучитьСсылку(Новый УникальныйИдентификатор(ID));
	Если ЗначениеЗаполнено(ЗадачаСсылка) И ЗначениеЗаполнено(Result) Тогда
		ЗадачаОб = ЗадачаСсылка.ПолучитьОбъект();
		ЗадачаОб.РезультатВыполнения = Result;
		Результат = бит_ОбщегоНазначения.ЗаписатьЗадачу(ЗадачаОб);
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции

Функция СоздатьЗадачу(ПараметрыЗадачи)
	
	Name        = ПараметрыЗадачи.Name;
	Description = ПараметрыЗадачи.Description;
	Importance  = ПараметрыЗадачи.Importance;
	Deadline    = ПараметрыЗадачи.Deadline;
	Responsible = ПараметрыЗадачи.Responsible;
	ObjectName  = ПараметрыЗадачи.ObjectName;
	ObjectID    = ПараметрыЗадачи.ObjectID;
	VisaID      = ПараметрыЗадачи.VisaID;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Результат = Ложь;
	
	// Попытаемся найти ответственного по строке.
	ОтветственныйСсылка = НайтиПользователя(Responsible);	
	Если НЕ ЗначениеЗаполнено(ОтветственныйСсылка) Тогда
		// Ответственный был указан неверно - ставим ответственным самого пользователя.
		ОтветственныйСсылка = Пользователи.ТекущийПользователь();
	КонецЕсли; 
	
	Попытка
		Важность = Перечисления.бит_ВидыВажностиЗадач[Importance];
	Исключение
		// Не удалось определить - по умолчанию.
		Важность = Перечисления.бит_Важность.Средняя;
	КонецПопытки;
	
	Попытка
		Срок = Дата(Deadline);
	Исключение
		// Не удалось определить - по умолчанию
		Срок = НачалоДня(КонецДня(ТекущаяДатаСеанса())+1);
	КонецПопытки;
	
	Предмет = Неопределено;
	Если ЗначениеЗаполнено(ObjectName) И ЗначениеЗаполнено(ObjectID) Тогда
		Если бит_РаботаСМетаданными.ОбъектПринадлежитКоллекцииМетаданных("Документы",ObjectName) Тогда
			Предмет = Документы[ObjectName].ПолучитьСсылку(Новый УникальныйИдентификатор(ObjectID));
		ИначеЕсли бит_РаботаСМетаданными.ОбъектПринадлежитКоллекцииМетаданных("Справочники",ObjectName) Тогда	
			Предмет = Справочники[ObjectName].ПолучитьСсылку(Новый УникальныйИдентификатор(ObjectID));
		КонецЕсли;	
	КонецЕсли; 
	
	Виза = Справочники.бит_Визы.ПустаяСсылка();
	Если ЗначениеЗаполнено(VisaID) Тогда
		Виза = Справочники.бит_Визы.ПолучитьСсылку(Новый УникальныйИдентификатор(VisaID));
	КонецЕсли; 
	
	СтрЗадача = Задачи.бит_Задача.СтруктураЗадачи();
	СтрЗадача.Наименование    = Name;
	СтрЗадача.Описание        = Description;
	СтрЗадача.Важность        = Важность;
	СтрЗадача.Исполнитель     = ОтветственныйСсылка;
	СтрЗадача.СрокИсполнения  = Срок;
	СтрЗадача.СпособАдресации = 0;
	СтрЗадача.Предмет         = Предмет;
	СтрЗадача.Виза            = Виза;
	
	МаксКоличествоОбъектов = бит_УправлениеПроцессами.МаксимальноеКоличествоОбъектовАдресации();	
	ЗадачаСсылка = Задачи.бит_Задача.СоздатьНовуюЗадачу(СтрЗадача, МаксКоличествоОбъектов);
	Результат = ?(ЗначениеЗаполнено(ЗадачаСсылка), Истина, Ложь);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область Файлы

// Функция получает информацию о файлах, прикрепленных к документам.
Функция ПолучитьИнформациюФайлов(Объекты)
	
	ПрикрепленныеФайлы = Новый Соответствие;
	
	ШаблонЗапроса =
	"ВЫБРАТЬ
	|	ТаблицаХранения.ВладелецФайла КАК ВладелецФайла,
	|	ТаблицаХранения.Ссылка КАК Файл,
	|	ТаблицаХранения.Наименование КАК Наименование,
	|	ТаблицаХранения.ДатаМодификацииУниверсальная КАК ДатаМодификацииФайла,
	|	ТаблицаХранения.Расширение КАК Расширение,
	|	ТаблицаХранения.Размер КАК Размер
	|ИЗ
	|	&ИмяТаблицыХранения КАК ТаблицаХранения
	|ГДЕ
	|	НЕ ТаблицаХранения.ПометкаУдаления
	|	И ТаблицаХранения.ВладелецФайла В(&ИмяПараметраВладельцев)";
	
	Разделитель =
	"
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|";
	
	ШаблонЗапросаИтоги = 
	"
	|
	|ИТОГИ ПО
	|	ВладелецФайла";
	
	ТекстыЗапросов = Новый Массив;
	Ном = 1;
	// Группируем ссылки по именам объектов.
	СсылкиПоТипам = СгруппироватьОбъектыПоТипам(Объекты);
	Запрос = Новый Запрос;
	Для каждого КиЗ Из СсылкиПоТипам Цикл
		ИмяСправочника = КиЗ.Ключ + "ПрисоединенныеФайлы";
		Если Метаданные.Справочники.Найти(ИмяСправочника) = Неопределено Тогда
			Продолжить;
		КонецЕсли;	
		ИмяПараметраВладельцев = "МассивСсылок_" + Формат(Ном, "ЧГ=");
		Запрос.УстановитьПараметр(ИмяПараметраВладельцев, КиЗ.Значение);
		ТекстЗапроса = ШаблонЗапроса;
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ИмяПараметраВладельцев", ИмяПараметраВладельцев);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ИмяТаблицыХранения", "Справочник." + ИмяСправочника);
		ТекстыЗапросов.Добавить(ТекстЗапроса);
		Ном = Ном + 1;
	КонецЦикла;
	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, Разделитель);
	
	Если НЕ ПустаяСтрока(ТекстЗапроса) Тогда
		ТекстЗапроса = ТекстЗапроса + ШаблонЗапросаИтоги;
		Запрос.Текст = ТекстЗапроса;
		Результат = Запрос.Выполнить();
		ВыборкаВладелец = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаВладелец.Следующий() Цикл
			Выборка = ВыборкаВладелец.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Файлы = Новый Массив;
			Пока Выборка.Следующий() Цикл
				ДанныеФайла = Новый Структура;
				ДанныеФайла.Вставить("Размер"              , Выборка.Размер);
				ДанныеФайла.Вставить("Расширение"          , Выборка.Расширение);
				ДанныеФайла.Вставить("Наименование"        , Выборка.Наименование);
				ДанныеФайла.Вставить("ДатаМодификацииФайла", Выборка.ДатаМодификацииФайла);
				ДанныеФайла.Вставить("ИдФайла"             , XMLСтрока(Выборка.Файл));
				ДанныеФайла.Вставить("ИдВерсии"            , XMLСтрока(Выборка.Файл));
				Файлы.Добавить(ДанныеФайла);
			КонецЦикла;
			ПрикрепленныеФайлы.Вставить(ВыборкаВладелец.ВладелецФайла, Файлы);
		КонецЦикла;
	КонецЕсли;
	
	// Дополним прикрепленные файлы файлами проектов договоров.
	бит_МобильноеПриложениеПереопределяемый.ПрикрепленныеФайлыПроектовДоговоров(ПрикрепленныеФайлы, СсылкиПоТипам);
	
	Возврат ПрикрепленныеФайлы;
	
КонецФункции

// Группирует массив объектов по типам объектов.
Функция СгруппироватьОбъектыПоТипам(Объекты)
	
	СсылкиПоТипам = Новый Структура;
	Для каждого ТекДок Из Объекты Цикл
		ИмяДок = ТекДок.Метаданные().Имя;
		Если СсылкиПоТипам.Свойство(ИмяДок) Тогда
			СсылкиПоТипам[ИмяДок].Добавить(ТекДок);
		Иначе
			СсылкиПоТипам.Вставить(ИмяДок, Новый Массив);
			СсылкиПоТипам[ИмяДок].Добавить(ТекДок);
		КонецЕсли;	  
	КонецЦикла;	  
	
	Возврат СсылкиПоТипам;
	
КонецФункции

#КонецОбласти

#Область ДопИзмерения

Функция ПолучитьНазначенияДополнительныхИзмерений()
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДопИзмерения.ИмяИзмерения КАК ИмяИзмерения,
	|	ДопИзмерения.Синоним КАК Синоним
	|ИЗ
	|	РегистрСведений.бит_НазначениеДополнительныхИзмерений КАК ДопИзмерения";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Измерения = Новый Массив;
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ДопИзмерение = Новый Структура("Name, Description", Выборка.ИмяИзмерения, Выборка.Синоним);
		Измерения.Добавить(ДопИзмерение);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Измерения;
	
КонецФункции

Функция ПолучитьОбъектыСДопИзмерениями(ДанныеЗапроса)
	
	Если НЕ ТипЗнч(ДанныеЗапроса) = Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	
	Результат = Новый Массив;
	ОбъектыКонфигурации = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеЗапроса, "ObjectTypes", Неопределено);
	Если ТипЗнч(ОбъектыКонфигурации) = Тип("Массив") Тогда
		Для каждого ОбъектКонфигурации Из ОбъектыКонфигурации Цикл
			ТипОбъекта = ОбъектКонфигурации.ObjectType;
			Если СтрНачинаетсяС(ТипОбъекта, "ДокументСсылка.") Тогда
				ОбъектыВизирования = ОбъектКонфигурации.DocsArray;
				Аналитики    = ОбъектКонфигурации.AnalyticsArray;
				ИмяДокумента = СтрЗаменить(ТипОбъекта, "ДокументСсылка.", "");
				ДокументыСДопИзмерениями = Новый Массив;
				Для каждого ОбъектаУИД Из ОбъектыВизирования Цикл
					ДокументУИД    = Новый УникальныйИдентификатор(ОбъектаУИД);
					ДокументСсылка = Документы[ИмяДокумента].ПолучитьСсылку(ДокументУИД);
					ДокументыСДопИзмерениями.Добавить(ДокументСсылка);
				КонецЦикла;
				СуществующиеАналитики = ПолучитьСуществующиеАналитики(ИмяДокумента, Аналитики);
				СформироватьДанныеПоДопИзмерениям(ТипОбъекта, ИмяДокумента, ДокументыСДопИзмерениями, СуществующиеАналитики, Результат);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьСуществующиеАналитики(ИмяДокумента, Аналитики)

	Результат     = Новый Массив;
	МетаДокумента = Метаданные.Документы[ИмяДокумента];
	Для каждого ИмяАналитики Из Аналитики Цикл
		Если МетаДокумента.Реквизиты.Найти(ИмяАналитики) <> Неопределено Тогда					
			Результат.Добавить(ИмяАналитики);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура СформироватьДанныеПоДопИзмерениям(ТипОбъекта, ИмяДокумента, Документы, Аналитики, Результат)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Документы", Документы);
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	Документ.Ссылка КАК Ссылка
	|	&СписокАналитик
	|ИЗ
	|	Документ.&ИмяДокумента КАК Документ
	|ГДЕ
	|	Документ.Ссылка В(&Документы)
	|ИТОГИ ПО
	|	Ссылка";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ИмяДокумента", ИмяДокумента);
	Если Аналитики.Количество() = 0 Тогда
	    ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&СписокАналитик", "");	
	Иначе		
		СписокАналитик = " , ";
		Для каждого ИмяАналитики Из Аналитики Цикл
			СписокАналитик = СписокАналитик + "Документ." + ИмяАналитики + ", ";
		КонецЦикла;
		СписокАналитик = Сред(СписокАналитик, 0, СтрДлина(СписокАналитик) - 2);
		ТекстЗапроса   = СтрЗаменить(ТекстЗапроса, "&СписокАналитик", СписокАналитик);
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСсылка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаСсылка.Следующий() Цикл
		АналитикиОтвет = Новый Массив;
		ВыборкаДЗ = ВыборкаСсылка.Выбрать();
		Пока ВыборкаДЗ.Следующий() Цикл
			Для каждого ИмяАналитики Из Аналитики Цикл
				ЗначениеАналитики = ВыборкаДЗ[ИмяАналитики];
				Если НЕ ЗначениеЗаполнено(ЗначениеАналитики) Тогда
					Продолжить;
				КонецЕсли;
				СтруктураАналитика = Новый Структура("Name, Value", ИмяАналитики, ЗначениеАналитики.Description);				
				АналитикиОтвет.Добавить(СтруктураАналитика);
			КонецЦикла;
		КонецЦикла;
		СтруктураОтвет = Новый Структура;
		СтруктураОтвет.Вставить("ObjectType", ТипОбъекта);
		СтруктураОтвет.Вставить("Id",         XMLСтрока(ВыборкаСсылка.Ссылка));
		СтруктураОтвет.Вставить("Analytics",  АналитикиОтвет);
		Результат.Добавить(СтруктураОтвет);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область Пользователи

// Функция выполняет поиск пользователя по имени.
//
// Параметры:
//  ИмяПользователя - Строка
//
// Возвращаемое значение:
//  СправочникСсылка.Пользователи -  ссылка на пользователя.
//
Функция НайтиПользователя(ИмяПользователя)
	
	УстановитьПривилегированныйРежим(Истина);
	НайденныйПользователь = Справочники.Пользователи.ПустаяСсылка();
	
	НайденныйПользователь = Пользователи.НайтиПоИмени(ИмяПользователя);
	
	Если НЕ ЗначениеЗаполнено(НайденныйПользователь) Тогда
		НайденныйПользователь = Справочники.Пользователи.НайтиПоНаименованию(ИмяПользователя);
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(НайденныйПользователь) Тогда
		ПользовательИБ =  ПользователиИнформационнойБазы.НайтиПоИмени(ИмяПользователя);
		Если НЕ ПользовательИБ = Неопределено Тогда			
			НайденныйПользователь = Справочники.Пользователи.НайтиПоРеквизиту("ИдентификаторПользователяИБ",ПользовательИБ.УникальныйИдентификатор);	
		КонецЕсли; 
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(НайденныйПользователь) Тогда
		НайденныйПользователь = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	Возврат НайденныйПользователь;
	
КонецФункции

Функция ПолучитьПользователей()
	
	УстановитьПривилегированныйРежим(Истина);
	ПользователиСистемы = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Пользователи.Ссылка КАК Ссылка,
	|	Пользователи.Подразделение КАК Подразделение,
	|	ЕСТЬNULL(Пользователи.Подразделение.Наименование, """") КАК ПодразделениеНаименование,
	|	Пользователи.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	НЕ Пользователи.ПометкаУдаления
	|	И НЕ Пользователи.Недействителен";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ПользовательСсылка = Выборка.Ссылка;
		ПользовательИБ     = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Выборка.ИдентификаторПользователяИБ);
		// Если у пользователя нет доступа в базу,
		// тогда пропускаем его.
		Если ПользовательИБ = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ПользовательСистемы             = Новый Структура("Id, Name, Department");
		ПользовательСистемы.Name        = ПользовательИБ.Имя;
		ПользовательСистемы.Id          = XMLСтрока(ПользовательСсылка);
		ПользовательСистемы.Department  = Выборка.ПодразделениеНаименование;
		ПользователиСистемы.Добавить(ПользовательСистемы);
	КонецЦикла;
		
	УстановитьПривилегированныйРежим(Ложь);	
	
	Возврат ПользователиСистемы;
	
КонецФункции

#КонецОбласти

#Область ФормированиеТабличныхЧастейHTML

Функция СформироватьТабличнуюЧастьHTML(ДанныеЗапроса)

	Если НЕ ТипЗнч(ДанныеЗапроса) = Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	
	ТипОбъекта = ДанныеЗапроса.ObjectType;
	ИдентификаторОбъекта = ДанныеЗапроса.ID;
	
	УстановитьПривилегированныйРежим(Истина);
	
	ОбъектСсылка = ПолучитьСсылку(ТипОбъекта, ИдентификаторОбъекта);
	Если ОбъектСсылка = Неопределено Тогда
		ТекстСообщения = НСтр("ru = 'Объект в системе не найден.'; en = 'An object was not found in the system.'");
		Возврат ТекстСообщения;
	КонецЕсли;	
	
	ДопАналитики = ПолучитьСоставДопАналитик();
	Если бит_МобильноеПриложениеПереопределяемый.ЕстьУникальнаяТабличнаяЧасть(ОбъектСсылка) Тогда
		Результат = бит_МобильноеПриложениеПереопределяемый.УникальнаяТабличнаяЧасть(ОбъектСсылка, ДопАналитики);
	Иначе	
		ШапкаHTMLДокумента = СформироватьШапкуHTML(Строка(ОбъектСсылка));
		BodyHTMLДокумента  = ПолучитьBodyHTMLДокумента(ОбъектСсылка, ДопАналитики);
		Результат          = ШапкаHTMLДокумента + Символы.ПС +  BodyHTMLДокумента;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Результат;

КонецФункции 

Функция СформироватьШапкуHTML(Заголовок)

	Шапка =
	"<!DOCTYPE html>
	|<html>
	|<head>
	|<meta charset=""utf-8"">
	|<title>%1</title>
	|%2
	|<!--[if lt IE 9]>      
	|<script src=""http://html5shiv.googlecode.com/svn/trunk/html5.js""></script
	|<![endif]-->
	|</head>";
	
	Стили = СформироватьСтили();
	Шапка = СтрШаблон(Шапка, Заголовок, Стили);

	Возврат Шапка;
	
КонецФункции 

Функция СформироватьСтили()

	ОписаниеСтилей =
	"<style>
	|table {
	|  border-collapse: collapse; 
	|  line-height: 1.1;
	|  font-family: ""Lucida Sans Unicode"", ""Lucida Grande"", sans-serif;
	|  color: #0C213B;
	|}
	|th {
	|  padding: 10px; 
	|  border: 1px solid grey;
	|  background: lightgrey;
	|}
	|td {
	|  font-size: 0.8em;
	|  padding: 5px 7px;
	|  border: 1px solid grey;
	|}
	|</style>";	

	Возврат ОписаниеСтилей;						
						
КонецФункции 

Функция ПолучитьBodyHTMLДокумента(ОбъектСсылка, ДопАналитики)

	МетаОбъект = ОбъектСсылка.Метаданные();
	
	ТелоHTMLДокумента = "<body>" + Символы.ПС;
	
	ИсключитьСтолбцы = Новый Массив;
	ИсключитьСтолбцы.Добавить("ИД");
	ИсключитьСтолбцы.Добавить("ИД_Прогноз");
	ИсключитьСтолбцы.Добавить("ИДВладельца");
	ИсключитьСтолбцы.Добавить("КоэффициентРаспределения");
	ИсключитьСтолбцы.Добавить("УдалитьНазначениеПлатежа");
	ИсключитьСтолбцы.Добавить("Расчетная");
	ИсключитьСтолбцы.Добавить("Удалить_Сценарий");
	ИсключитьСтолбцы.Добавить("Служебный");
	
	ИменаТабличныхЧастей = Новый Массив;
	
	Если ТипЗнч(ОбъектСсылка) = Тип("ДокументСсылка.бит_АктуализацияБюджета")
		ИЛИ ТипЗнч(ОбъектСсылка) = Тип("ДокументСсылка.бит_ФормаВводаБюджета") 
		ИЛИ ТипЗнч(ОбъектСсылка) = Тип("ДокументСсылка.бит_КорректировкаБюджета") Тогда
		
		ИменаТабличныхЧастей.Добавить("БДДС");		
	ИначеЕсли ТипЗнч(ОбъектСсылка) = Тип("ДокументСсылка.бит_ВерсияОтчета") Тогда
		
		ИменаТабличныхЧастей.Добавить("ПараметрыХранение");		
	ИначеЕсли ТипЗнч(ОбъектСсылка) = Тип("ДокументСсылка.бит_ДополнительныеУсловияПоДоговору") Тогда
		
		ИменаТабличныхЧастей.Добавить("ГрафикПлатежей");		
		ИменаТабличныхЧастей.Добавить("ГрафикНачислений");		
		ИменаТабличныхЧастей.Добавить("ГрафикВыдачиТраншей");		
	ИначеЕсли ТипЗнч(ОбъектСсылка) = Тип("ДокументСсылка.бит_КорректировкаКонтрольныхЗначений") Тогда
		
		ИменаТабличныхЧастей.Добавить("УвеличениеЛимита");
		ИменаТабличныхЧастей.Добавить("УменьшениеЛимита");
	Иначе
		бит_МобильноеПриложениеПереопределяемый.ИменаТабличныхЧастей(ОбъектСсылка, ИменаТабличныхЧастей);
	КонецЕсли;	
	СформироватьBodyHTMLДокумента(ОбъектСсылка, МетаОбъект, ИменаТабличныхЧастей, ТелоHTMLДокумента, ИсключитьСтолбцы, ДопАналитики);		
	ТелоHTMLДокумента = ТелоHTMLДокумента + "</body>" + Символы.ПС + "</html>";
	
	Возврат ТелоHTMLДокумента;
	
КонецФункции 

Процедура СформироватьBodyHTMLДокумента(ОбъектСсылка, МетаОбъект, ИменТабличныхЧастей, ТелоHTMLДокумента, ИсключитьСтолбцы, ДопАналитики)
	
	// Формируем заголовки.
	ТелоHTMLДокумента = ТелоHTMLДокумента + "<h2>" + Строка(ОбъектСсылка) + "</h2>" + Символы.ПС;
	
	Для каждого ИмяТабличнойЧасти Из ИменТабличныхЧастей Цикл
		
		Попытка
			МетаТабличнаяЧасть = МетаОбъект.ТабличныеЧасти[ИмяТабличнойЧасти];
		Исключение
			Инфо = НСтр("ru = 'Табличной части с именем ""%1"" не существует.'; en = 'The table part named ""%1"" does not exist.'");
			Инфо = СтрШаблон(Инфо, МетаТабличнаяЧасть.Синоним);
			ТелоHTMLДокумента = ТелоHTMLДокумента + "<h3>" + Инфо + "</h3>" + Символы.ПС;
			Возврат;
		КонецПопытки;
		
		ТелоHTMLДокумента = ТелоHTMLДокумента + "<h3>" + МетаТабличнаяЧасть.Синоним + "</h3>" + Символы.ПС;
		ТелоHTMLДокумента = ТелоHTMLДокумента + "<table>" + Символы.ПС;
		
		// Формируем заголовок табличной части
		
		ЗаголовокТаблицы = "<tr>" + Символы.ПС;
		
		Для каждого метаРеквизит Из МетаТабличнаяЧасть.Реквизиты Цикл			
			
			ИмяКолонки = метаРеквизит.Синоним;
			
			Если НЕ ИсключитьСтолбцы.Найти(метаРеквизит.Имя) = Неопределено Тогда
				Продолжить;				
			КонецЕсли;
			
			// Игнорируем столбцы, оканчивающиеся на "_Старый".
			Если НЕ СтрНайти(метаРеквизит.Имя, "_Старый") = 0 Тогда
				Продолжить;	
			КонецЕсли;
			
			НайденнаяАналитика = Неопределено;
			ДопАналитики.Свойство(метаРеквизит.Имя, НайденнаяАналитика);
			
			Если НЕ НайденнаяАналитика = Неопределено Тогда
				
				Если НайденнаяАналитика.Используется Тогда
					ИмяКолонки = НайденнаяАналитика.Синоним;
				Иначе
					Продолжить;	
				КонецЕсли;
				
			КонецЕсли;
			
			ЗаголовокТаблицы = ЗаголовокТаблицы + "<th>" + ИмяКолонки + "</th>" + Символы.ПС;			
			
		КонецЦикла;
		
		ЗаголовокТаблицы = ЗаголовокТаблицы + "</tr>" + Символы.ПС;
		
		ТелоHTMLДокумента = ТелоHTMLДокумента + ЗаголовокТаблицы;
		
		// Формируем данные табличной части
		
		ДанныеТаблицы = "";
		
		Для каждого строка Из ОбъектСсылка[ИмяТабличнойЧасти] Цикл
			
			ДанныеТаблицы = ДанныеТаблицы + "<tr>" + Символы.ПС;
			
			Для каждого метаРеквизит Из МетаТабличнаяЧасть.Реквизиты Цикл
				
				Если НЕ ИсключитьСтолбцы.Найти(метаРеквизит.Имя) = Неопределено Тогда
					Продолжить;				
				КонецЕсли;
				
				// Игнорируем столбцы, оканчивающиеся на "_Старый".
				Если НЕ СтрНайти(метаРеквизит.Имя, "_Старый") = 0 Тогда
					Продолжить;	
				КонецЕсли;
				
				НайденнаяАналитика = Неопределено;
				ДопАналитики.Свойство(метаРеквизит.Имя, НайденнаяАналитика);
				
				Если НЕ НайденнаяАналитика = Неопределено И НЕ НайденнаяАналитика.Используется Тогда
					Продолжить;	
				КонецЕсли;
				
				ДанныеКолонки = строка[метаРеквизит.Имя];				
				
				ДанныеТаблицы = ДанныеТаблицы + "<td>" + ДанныеКолонки + "</td>" + Символы.ПС;			
				
			КонецЦикла;
			
			ДанныеТаблицы = ДанныеТаблицы + "</tr>" + Символы.ПС;
			
		КонецЦикла;
		
		ТелоHTMLДокумента = ТелоHTMLДокумента + ДанныеТаблицы;		
		ТелоHTMLДокумента = ТелоHTMLДокумента + "</table>" + Символы.ПС;
		ТелоHTMLДокумента = ТелоHTMLДокумента + "</br>" + Символы.ПС;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОстаткиПоБюджету

Функция ПолучитьОстаткиПоБюджету(ДанныеЗапроса)

	Если НЕ ТипЗнч(ДанныеЗапроса) = Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если бит_МобильноеПриложениеПереопределяемый.ЭтоСправочник(ДанныеЗапроса.ObjectType) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ТипДокумента            = ДанныеЗапроса.ObjectType;
	УникальныйИдентификатор = Новый УникальныйИдентификатор(ДанныеЗапроса.Id);
	ОбъектСсылка            = Документы[ТипДокумента].ПолучитьСсылку(УникальныйИдентификатор);
	
	Если НЕ ЗначениеЗаполнено(ОбъектСсылка) Тогда
		Возврат Неопределено;	
	КонецЕсли;		
	
	ДеревоИнформация = бит_МобильноеПриложениеПереопределяемый.ДанныеОбъекта(ОбъектСсылка);
	
	Если НЕ ЗначениеЗаполнено(ДеревоИнформация) Тогда
		ТекстСообщения = НСтр("ru = 'По данному объекту нет дополнительной информации.';
								|en = 'There is no additional information on this property.'");
		Возврат ТекстСообщения;
	КонецЕсли;
	
	Результат = Новый Массив;
	Для каждого Строка Из ДеревоИнформация.Строки Цикл	
		
		Если СтрСравнить(Строка.Имя, "СуммаДокумента") = 0 Тогда
			Имя      = "DocumentSums";
			Описание = Строка.ИмяПараметра;
		ИначеЕсли СтрСравнить(Строка.Имя, "СведенияОбОплате") = 0 Тогда
			Имя      = "PaymentDetails";
			Описание = Строка.ИмяПараметра;
		ИначеЕсли СтрСравнить(Строка.Имя, "ОстаткиПобюджету") = 0 Тогда
			Имя      = "Balances";
			Описание = Строка.ИмяПараметра;
		Иначе
			Продолжить;			
		КонецЕсли;
		
		Раздел = Новый Структура("Name, Description, Details", Имя, Описание);
		Детали = Новый Массив;
		
		Для каждого строка2 Из Строка.Строки Цикл
			Если строка2.ЭтоГруппа Тогда
				СтатьиОборотов = Новый Массив;
				Для каждого строка3 Из строка2.Строки Цикл
					Entry = Новый Структура("Name, Value", строка3.ИмяПараметра, Строка(строка3.ЗначениеПараметра));						
					СтатьиОборотов.Добавить(Entry);
				КонецЦикла;
				Detail = Новый Структура("Name, Entries", строка2.ИмяПараметра, СтатьиОборотов);
			Иначе
				Detail = Новый Структура("Name, Value", строка2.ИмяПараметра, Строка(строка2.ЗначениеПараметра));
			КонецЕсли;
			Детали.Добавить(Detail);
		КонецЦикла;
		
		Раздел.Details = Детали;
		Результат.Добавить(Раздел);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

