Функция ПолучитьТипыОбъектовВизирования()
	
	Результат = Новый Массив;
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОбъектыВизирования.ОбъектСистемы КАК ОбъектСистемы,
	|	ОбъектыВизирования.ОбъектСистемы.Наименование КАК Наименование,
	|	ОбъектыВизирования.ОбъектСистемы.ИмяОбъектаПолное КАК ИмяОбъектаПолное,
	|	ОбъектыВизирования.Синоним КАК Синоним,
	|	ДопАналитики.Аналитика КАК Аналитика
	|ИЗ
	|	РегистрСведений.бит_ОбъектыМобильногоВизирования КАК ОбъектыВизирования
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_НазначениеДополнительныхАналитик КАК ДопАналитики
	|		ПО ОбъектыВизирования.ОбъектСистемы = ДопАналитики.Объект
	|ИТОГИ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Аналитика)
	|ПО
	|	ОбъектСистемы";
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаОбъектСистемы = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ФильтрПоОтображениюОстатков = бит_МобильноеПриложениеПереопределяемый.ТипыОбъектовДляОтображенияОстатков();
	ФильтрПоОтображениюТабЧастей = бит_МобильноеПриложениеПереопределяемый.ТипыОбъектовДляОтображенияТабличныхЧастей();
	
	Пока ВыборкаОбъектСистемы.Следующий() Цикл
		
		ОбъектСистемы = Новый Структура;
		ОбъектСистемы.Вставить("Name");
		ОбъектСистемы.Вставить("Title");
		ОбъектСистемы.Вставить("Synonim");
		ОбъектСистемы.Вставить("ShowBudgetBalances");
		ОбъектСистемы.Вставить("ShowTabularSection");
		ОбъектСистемы.Вставить("Properties");
		ОбъектСистемы.Вставить("ObjectFilter");
		ОбъектСистемы.Вставить("AdditionalPropsFilter");
		
		ИмяОбъекта = ВыборкаОбъектСистемы.ИмяОбъектаПолное;
		ИмяОбъекта = СтрЗаменить(ИмяОбъекта, "Документ.", "ДокументСсылка.");
		ИмяОбъекта = СтрЗаменить(ИмяОбъекта, "Справочник.", "СправочникСсылка.");
		
		ОбъектСистемы.Name = ИмяОбъекта;
		ОбъектСистемы.Title = ВыборкаОбъектСистемы.Наименование;
		// N.B. Отказаться от строкового варианта для проверки, перейти на метаданные.
		ОбъектСистемы.ShowBudgetBalances = ФильтрПоОтображениюОстатков.Найти(ИмяОбъекта) <> Неопределено;
		ОбъектСистемы.ShowTabularSection = ФильтрПоОтображениюТабЧастей.Найти(ИмяОбъекта) <> Неопределено;
		
		ДопАналитики = Новый Массив;
		ВыборкаДЗ    = ВыборкаОбъектСистемы.Выбрать();
		Пока ВыборкаДЗ.Следующий() Цикл
			Синоним = ВыборкаДЗ.Синоним;
			Если ЗначениеЗаполнено(ВыборкаДЗ.Аналитика) Тогда
				АналитикаСсылка = ВыборкаДЗ.Аналитика;
				УИДСтрока       = XMLСтрока(АналитикаСсылка);
				// N.B. Разименовать в запросе.
				АналитикаСтруктура = Новый Структура("Id, Description", УИДСтрока, СокрЛП(АналитикаСсылка.Наименование));
				ДопАналитики.Добавить(АналитикаСтруктура);
			КонецЕсли;
		КонецЦикла;
		ОбъектСистемы.Synonim    = Синоним;
		ОбъектСистемы.Properties = ДопАналитики;

		ОбъектСистемы.ObjectFilter = бит_МобильноеПриложениеПереопределяемый.ФильтрРеквизитовОбъекта(
		                              ВыборкаОбъектСистемы.ОбъектСистемы);
									  
		ОбъектСистемы.AdditionalPropsFilter = ФильтрыДопРеквизитовОбъекта(ВыборкаОбъектСистемы.ИмяОбъектаПолное);
		
		Результат.Добавить(ОбъектСистемы);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Результат;
	
КонецФункции

Функция ФильтрыДопРеквизитовОбъекта(ИмяОбъектаПолное)
	
	Результат = Новый Массив;
	
	Если ЗначениеЗаполнено(ИмяОбъектаПолное) Тогда
		УстановитьПривилегированныйРежим(Истина);
		
		ВидСвойств  = "ДополнительныеРеквизиты";
		ВладелецСвойств = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ИмяОбъектаПолное).ПустаяСсылка();
		ОбъектМетаданных = ВладелецСвойств.Метаданные();
		ТабличнаяЧасть = ОбъектМетаданных.ТабличныеЧасти.Найти(ВидСвойств);
		Если НЕ ТабличнаяЧасть = Неопределено Тогда
			СвойстваОбъекта = УправлениеСвойствами.СвойстваОбъекта(ВладелецСвойств, Истина, Ложь);
			Для каждого Свойство Из СвойстваОбъекта Цикл
				УИДСтрока = XMLСтрока(Свойство.Ссылка);
				Описание = СокрЛП(Свойство.Наименование);
				ДопРеквизит = Новый Структура("Id, Description", УИДСтрока, Описание);
				Результат.Добавить(ДопРеквизит);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьОбъекты(ДанныеЗапроса)
	
	Если НЕ ТипЗнч(ДанныеЗапроса) = Тип("Массив") Тогда
		Возврат "";
	КонецЕсли;
	
	ВсеСсылки = Новый Массив;
	ОбъектыПоТипам = Новый Массив;
	УстановитьПривилегированныйРежим(Истина);
	// Получение ссылок запрашиваемых объектов.
	Для каждого Строка Из ДанныеЗапроса Цикл
		ТипОбъекта     = Строка.ObjectType;
		Идентификаторы = Строка.IDsArray;
		ТекущиеСсылки  = Новый Массив;
		Для каждого Строка Из Идентификаторы Цикл
			Ссылка = ПолучитьСсылку(ТипОбъекта, Строка);
			Если ЗначениеЗаполнено(Ссылка) Тогда
				ВсеСсылки.Добавить(Ссылка);
				ТекущиеСсылки.Добавить(Ссылка)
			Иначе
				Продолжить;
			КонецЕсли;
		КонецЦикла;
		// Группировка объектов по типам.
		ТекущиеОбъекты = Новый Структура("ТипОбъекта, Ссылки", ТипОбъекта, ТекущиеСсылки);
		ОбъектыПоТипам.Добавить(ТекущиеОбъекты);
	КонецЦикла;
	
	// Получение сведений о прикрепленных файлах.
	ПрикрепленныеФайлы = ПолучитьИнформациюФайлов(ВсеСсылки);
	
	// Заполнение результата.
	ЗапросПлатежнойПозиции = бит_МобильноеПриложениеПереопределяемый.ЗапросПлатежнойПозиции();
	Результат = Новый Массив;
	Для каждого ТекущиеОбъекты Из ОбъектыПоТипам Цикл
		ДанныеОбъектов = Новый Массив;
		
		РеквизитыОбъектов = РеквизитыОбъектов(ТекущиеОбъекты.Ссылки, Истина, Истина);
		ДоступныеВизы = ПолучитьДоступныеВизыОбъектов(ТекущиеОбъекты.Ссылки);
		Для каждого СтрокаТаблицы Из РеквизитыОбъектов Цикл
		
			ДанныеОбъекта = Новый Структура;
			ДанныеОбъекта.Вставить("ID",                XMLСтрока(СтрокаТаблицы.ОбъектВизирования));
			ДанныеОбъекта.Вставить("Date",              Формат(СтрокаТаблицы.Дата, "ДЛФ=D"));
			ДанныеОбъекта.Вставить("Number",            СтрокаТаблицы.Номер);
			ДанныеОбъекта.Вставить("Company",           Строка(СтрокаТаблицы.Организация));
			ДанныеОбъекта.Вставить("Department",        СтрСоединить(СтрокаТаблицы.ЦФОСмешанная, ", "));
			ДанныеОбъекта.Вставить("TurnoverItem",      СтрСоединить(СтрокаТаблицы.СтатьяОборотовСмешанная, ", "));
			ДанныеОбъекта.Вставить("Partner",           Строка(СтрокаТаблицы.Контрагент));
			ДанныеОбъекта.Вставить("Amount",            Строка(СтрокаТаблицы.СуммаДокумента));
			ДанныеОбъекта.Вставить("Currency",          Строка(СтрокаТаблицы.ВалютаДокумента));
			ДанныеОбъекта.Вставить("ManagerialPurpose", Строка(СтрокаТаблицы.НазначениеПлатежаУпр));
			ДанныеОбъекта.Вставить("Status",            Строка(СтрокаТаблицы.Статус));
			ДанныеОбъекта.Вставить("ResponsiblePerson", Строка(СтрокаТаблицы.Ответственный));
			ДанныеОбъекта.Вставить("Scenario",          Строка(СтрокаТаблицы.Сценарий));
			ДанныеОбъекта.Вставить("Comment",           СтрокаТаблицы.Комментарий);
			ДанныеОбъекта.Вставить("OverBudget",        ?(ЗначениеЗаполнено(СтрокаТаблицы.СверхБюджета),СтрокаТаблицы.СверхБюджета,Ложь));
			ДанныеОбъекта.Вставить("BasisForecast",     Неопределено);
			ДанныеОбъекта.Вставить("Executor",          "");
			ДанныеОбъекта.Вставить("PaymentDate",       "");
			ДанныеОбъекта.Вставить("AdditionalProps",   ДополнительныеРеквизитыОбъекта(СтрокаТаблицы.ОбъектВизирования));
			
			ДоступныеВизыОбъекта = ДоступныеВизы[СтрокаТаблицы.ОбъектВизирования];
			Если ДоступныеВизыОбъекта = Неопределено Тогда
				ДоступныеВизыОбъекта = Новый Массив;
			КонецЕсли;
			ДанныеОбъекта.Вставить("AvailableVisas", ДоступныеВизыОбъекта);
			
			бит_МобильноеПриложениеПереопределяемый.ДополнитьДанныеОбъекта(ДанныеОбъекта, СтрокаТаблицы, ЗапросПлатежнойПозиции);
			
			// Данные о файлах.
			Файлы = ПрикрепленныеФайлы[СтрокаТаблицы.ОбъектВизирования];
			ДанныеОбъекта.Вставить("Files", Новый Массив);
			Если ЗначениеЗаполнено(Файлы) Тогда
				Для каждого ДанныеФайла Из Файлы Цикл
					ИнформацияОФайле = Новый Структура;
					ИнформацияОФайле.Вставить("Name",        ДанныеФайла.Наименование);
					ИнформацияОФайле.Вставить("DateChanged", ДанныеФайла.ДатаМодификацииФайла);
					ИнформацияОФайле.Вставить("ID",          ДанныеФайла.ИдФайла);
					ИнформацияОФайле.Вставить("VersionID",   ДанныеФайла.ИдВерсии);
					ИнформацияОФайле.Вставить("Ext",         ДанныеФайла.Расширение);
					ИнформацияОФайле.Вставить("Size",        ДанныеФайла.Размер);
					ДанныеОбъекта.Files.Добавить(ИнформацияОФайле);
				КонецЦикла;
			КонецЕсли;
			
			ДанныеОбъектов.Добавить(ДанныеОбъекта);
		
		КонецЦикла; 
		
		ДанныеПоТипам = Новый Структура("ObjectType, ObjectsArray", ТекущиеОбъекты.ТипОбъекта, ДанныеОбъектов);
		Результат.Добавить(ДанныеПоТипам);
	КонецЦикла;
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Результат;

КонецФункции

// Функция устанавливает решения по указанным объектам.
//
// Параметры:
//   Objects - Массив из Структура- объекты визирования.
//   Decision - Строка.
//
// Возвращаемое значение:
//  Строка - список Id документов с пустыми комментариями, если установлена необходимость заполнения Комментария.
//
Функция УстановитьРешения(Objects, Decision)
	
	УстановитьПривилегированныйРежим(Истина);	
	
	// N.B. Решение = Справочники.бит_ВидыРешенийСогласования.ПолучитьСсылку(Новый УникальныйИдентификатор(Decision));
	Если ЗначениеЗаполнено(Decision) Тогда		
		Решение = Справочники.бит_ВидыРешенийСогласования.НайтиПоНаименованию(Decision);		
	Иначе			
		Решение = Справочники.бит_ВидыРешенийСогласования.ПустаяСсылка();		
	КонецЕсли; 
	
	// Инициализация таблицы документов.
	ТаблицаДокументы = Новый ТаблицаЗначений;
	ТаблицаДокументы.Колонки.Добавить("Выполнять",           Новый ОписаниеТипов("Булево"));
	ТаблицаДокументы.Колонки.Добавить("ЕстьНеустановленные", Новый ОписаниеТипов("Булево"));
	ТаблицаДокументы.Колонки.Добавить("Ссылка");
	ТаблицаДокументы.Колонки.Добавить("ТипДокумента");
	ТаблицаДокументы.Колонки.Добавить("Организация",         Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ТаблицаДокументы.Колонки.Добавить("Комментарий",         Новый ОписаниеТипов("Строка"));
	ТаблицаДокументы.Колонки.Добавить("Id",                  Новый ОписаниеТипов("Строка"));
	ТаблицаДокументы.Колонки.Добавить("ПолноеИмяОбъекта",    Новый ОписаниеТипов("Строка"));
	
	// Разбор полученных данных и заполнение таблицы документов.
	Если Решение.Пустая() Тогда
		ТекстСообщения = НСтр("ru = 'Решение ""%1"" не найдено.'; en = 'Solution ""%1"" not found.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, Decision); 
		Возврат ТекстСообщения;
	КонецЕсли;
	
	Для каждого Модель Из Objects Цикл
		МенеджерКоллекции = бит_ОбщегоНазначения.ПолучитьМенеджер(Модель.CollectionName);
		МенеджерОбъекта   = МенеджерКоллекции[Модель.ObjectName];
		Ссылка            = МенеджерОбъекта.ПолучитьСсылку(Новый УникальныйИдентификатор(Модель.ID));
		
		Если ЗначениеЗаполнено(Ссылка) Тогда
			МетаОбъект                      = Ссылка.Метаданные();
			НоваяСтрока                     = ТаблицаДокументы.Добавить();
			НоваяСтрока.Выполнять           = Истина;
			НоваяСтрока.ЕстьНеустановленные = Истина;
			НоваяСтрока.Ссылка              = Ссылка;
			НоваяСтрока.ТипДокумента        = ТипЗнч(Ссылка);
			НоваяСтрока.Комментарий         = Модель.Comment;
			НоваяСтрока.Id                  = Модель.Id;
			НоваяСтрока.ПолноеИмяОбъекта    = Ссылка.Метаданные().ПолноеИмя();
			
			Если бит_РаботаСМетаданными.ЕстьРеквизит("Организация", МетаОбъект) Тогда
				НоваяСтрока.Организация = Ссылка.Организация;
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла; // Массив для обработки.
	
	// Проверяем установлен ли комментарий, либо создана ли задача.
	СПустымиКомментариями = Новый Массив;
	Для каждого Строка Из ТаблицаДокументы Цикл
		Если НеобходимКомментарийЗадачаПолнаяПроверка(Строка.Организация, Строка.ПолноеИмяОбъекта, Решение) Тогда
			Если НЕ ЗначениеЗаполнено(Строка.Комментарий) Тогда
				Виза = ПолучитьТекущуюВизу(Строка.Ссылка);
				Если НЕ ЕстьЗадачиПоДокументу(Строка.Ссылка, Виза) Тогда
					СПустымиКомментариями.Добавить(Новый Структура("Id", Строка.Id));
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если СПустымиКомментариями.Количество() > 0 Тогда
		Возврат СПустымиКомментариями;
	КонецЕсли;
	
	ОбъектыВизирования = ТаблицаДокументы.ВыгрузитьКолонку("Ссылка");
	ДоступныеВизы = ИдентификаторыДоступныхВизОбъектов(ОбъектыВизирования);
	// Выполнение установки решений.
	Для каждого СтрокаДанных Из ТаблицаДокументы Цикл
		ДоступныеВизыОбъекта = ДоступныеВизы[СтрокаДанных.Ссылка];
		Если ДоступныеВизыОбъекта = Неопределено Тогда
			ДоступныеВизыОбъекта = Новый Массив;
		КонецЕсли;
		
		ПараметрыПринятияРешения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыПринятияРешения();
		Для каждого ВизаОбъекта Из ДоступныеВизыОбъекта Цикл
			ПараметрыПринятияРешения.ОбъектВизирования         = СтрокаДанных.Ссылка;
			ПараметрыПринятияРешения.ИДВизы                    = ВизаОбъекта;
			ПараметрыПринятияРешения.Решение                   = Решение;
			ПараметрыПринятияРешения.Комментарий               = СтрокаДанных.Комментарий;
			ПараметрыПринятияРешения.ДатаУстановкиРешения      = ТекущаяДатаСеанса();
			ПараметрыПринятияРешения.ПроводитьПослеУтверждения = бит_ВизированиеСервер.ПриниматьКУчетуПослеУтверждения(СтрокаДанных.Ссылка);
			
			Обработки.бит_КонсольОперативногоВизирования.УстановитьРешениеПоВизе(ПараметрыПринятияРешения);
		КонецЦикла;
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);	

	РезСтрока = "Ок";
	Возврат РезСтрока;
	
КонецФункции
 
Функция ПолучитьТекущуюВизу(ДокументСсылка)
	
	ДоступныеПустые = ПолучитьДоступныеВизыОбъекта(ДокументСсылка);
	
	ТекущаяВиза = Неопределено;
	Если ДоступныеПустые.Количество() > 0 Тогда
		ТекущаяВиза = ДоступныеПустые[0];
	КонецЕсли;
	
	Возврат ТекущаяВиза;
	
КонецФункции

Функция ЗарегистрироватьУстройство(Token, DeviceId, OS, UserName)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТекПользователь = НайтиПользователя(UserName);
	МобУстройство   = Справочники.бит_МобильныеУстройства.НайтиПоРеквизиту("ИД", DeviceId);
	
	Если НЕ ЗначениеЗаполнено(МобУстройство) Тогда
		// Создаем новое мобильное устройство.
		МобУстройствоОб       = Справочники.бит_МобильныеУстройства.СоздатьЭлемент();
		МобУстройствоОб.ИД    = DeviceId;
		МобУстройствоОб.Токен = Token;
		
		Если НЕ Метаданные.Перечисления.бит_МобильныеОперационныеСистемы.ЗначенияПеречисления.Найти(OS)= Неопределено Тогда			
			ОС = Перечисления.бит_МобильныеОперационныеСистемы[OS];			
		Иначе			
			ОС = Перечисления.бит_МобильныеОперационныеСистемы.android;			
		КонецЕсли;
		
		МобУстройствоОб.ОперационнаяСистема =  ОС;
		МобУстройствоОб.Наименование = Строка(ОС) + " " + Строка(DeviceId);			
		МобУстройствоОб.ДатаРегистрации = ТекущаяДатаСеанса();
		МобУстройствоОб.УстановитьНовыйКод();
		
		УстройствоСоздано = бит_ОбщегоНазначения.ЗаписатьСправочник(МобУстройствоОб,"","Ошибки",Истина);
		
		Если УстройствоСоздано Тогда
			МобУстройство = МобУстройствоОб.Ссылка;			
		КонецЕсли; 
	Иначе	
		// Устройство было создано ранее.
		МобУстройствоОб                 = МобУстройство.ПолучитьОбъект();
		МобУстройствоОб.Токен           = Token;
		МобУстройствоОб.ПометкаУдаления = Ложь;
		бит_ОбщегоНазначения.ЗаписатьСправочник(МобУстройствоОб, "", "Ошибки", Истина);
		УстройствоСоздано = Истина;
	КонецЕсли; 

	УстройствоНазначено = Ложь;
	Если ЗначениеЗаполнено(ТекПользователь) Тогда
		Если УстройствоСоздано Тогда
			
			// Назначим устройство пользователю.
			МенеджерЗаписи = РегистрыСведений.бит_УстройстваПользователей.СоздатьМенеджерЗаписи();
			МенеджерЗаписи.Пользователь    = ТекПользователь;
			МенеджерЗаписи.Устройство      = МобУстройство;
			МенеджерЗаписи.ДатаПодключения = ТекущаяДатаСеанса();
			
			Попытка
				МенеджерЗаписи.Записать();
				УстройствоНазначено = Истина;
			Исключение
				
				ИмяСобытия = НСтр("ru = 'Регистрация устройства пользователя из мобильного приложения';
									|en = 'Registering a user''s device from a mobile application'",
									ОбщегоНазначения.КодОсновногоЯзыка());
				ТекстСообщения = НСтр("ru = 'Ошибка назначения устройства пользователю.
                                       |Описание ошибки: %1';
									   |en = 'Error assigning device to user.
                                       |Error description: %1'");
				ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				ЗарегистрироватьОшибку(ИмяСобытия, ТекстСообщения);					
			КонецПопытки;
		КонецЕсли; 
	КонецЕсли; 
	
	РезультатСтруктура = Новый Структура("code, message, error");
	
	Если УстройствоСоздано И УстройствоНазначено Тогда
		РезультатСтруктура.code    = "200";
		РезультатСтруктура.error   = "0";
		РезультатСтруктура.message = НСтр("ru = 'New device created and assigned to user.';
											|en = 'New device created and assigned to user.'");
	ИначеЕсли НЕ УстройствоСоздано Тогда
		РезультатСтруктура.code    = "500";
		РезультатСтруктура.error   = "1";
		РезультатСтруктура.message = НСтр("ru = 'Cannot create device.'; en = 'Cannot create device.'");
	ИначеЕсли НЕ УстройствоНазначено Тогда
		РезультатСтруктура.code = "500";
		Если НЕ ЗначениеЗаполнено(ТекПользователь) Тогда
			РезультатСтруктура.error   = "2";
			РезультатСтруктура.message = НСтр("ru = 'Cannot find the user.'; en = 'Cannot find the user.'");
		Иначе	
			РезультатСтруктура.error   = "3";
			РезультатСтруктура.message = НСтр("ru = 'Cannot assign device to user.'; en = 'Cannot assign device to user.'");
		КонецЕсли; 
	КонецЕсли; 
	
	УстановитьПривилегированныйРежим(Ложь);	
	
	Возврат РезультатСтруктура;
	
КонецФункции

// Функция получает объекты визирования.
//
// Параметры:
//  Пользователь	 - Строка	 - Пользователь для которого получаем список объектов визирования.
//  ИменаОбъектов	 - Строка	 - Имена типов объектов визирования, которые анализируем.
// 
// Возвращаемое значение:
//  Массив - массив структур.
//
Функция ПолучитьОбъектыВизирования(ДанныеЗапроса)
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("User",       "");
	ПараметрыЗапроса.Вставить("Objects",    "");
	ПараметрыЗапроса.Вставить("DateStart",  Дата('00010101'));
	ПараметрыЗапроса.Вставить("DateFinish", Дата('00010101'));
	
	ЗаполнитьЗначенияСвойств(ПараметрыЗапроса, ДанныеЗапроса);
	
	Пользователь     = ПараметрыЗапроса.User;
	ИменаОбъектов    = ПараметрыЗапроса.Objects;
	НачалоПериода    = ПараметрыЗапроса.DateStart;
	ОкончаниеПериода = ПараметрыЗапроса.DateFinish;
  
	ТекПользователь  = НайтиПользователя(Пользователь);
	Если НЕ ЗначениеЗаполнено(ТекПользователь) Тогда
		ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Ошибка метода GetObjectsForApproval.
                               |Не удалось найти пользователя по имени: %1';
							   |en = 'HTTP service bit_ApprovalServiceNew. GetObjectsForApproval method error.
                               |Could not find user by name: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, Пользователь);
		ИмяСобытия = НСтр("ru = 'approval/v1/objects_for_approval'; en = 'approval/v1/objects_for_approval'",
			ОбщегоНазначения.КодОсновногоЯзыка());
		ЗарегистрироватьОшибку(ИмяСобытия, ТекстСообщения);	
	КонецЕсли; 
    
    ПараметрыСеанса.бит_ИдентификаторСеанса = Новый УникальныйИдентификатор;						 			
	
	ТипыОбъектов = Новый СписокЗначений();
	Если ТипЗнч(ИменаОбъектов) = Тип("Строка") И НЕ ПустаяСтрока(ИменаОбъектов) Тогда
		ПолученныеТипы = бит_ОбщегоНазначенияКлиентСервер.ПолучитьТипыИзСтроки(ИменаОбъектов);
		Если ПолученныеТипы.Количество()=0 Тогда
			Возврат Неопределено;
		КонецЕсли;
		ТипыОбъектов.ЗагрузитьЗначения(ПолученныеТипы);
	КонецЕсли; 
	
	АдресВХранилище = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор); 
	МатрицаДоступа = Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа();
	
	ПараметрыПолучения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
	ПараметрыПолучения.МатрицаДоступа           = МатрицаДоступа;
	ПараметрыПолучения.ВыводитьВТаблицуЗначений = Истина;
	ПараметрыПолучения.ЭтоМобильноеПриложение   = Истина;
	ПараметрыПолучения.Отбор.ТипОбъекта         = ТипыОбъектов;

	// Отборы по дате.
	НастраиваемыеОтборы = Новый Структура;
	Если ЗначениеЗаполнено(НачалоПериода) Тогда
		НачалоПериода = СтрокаВДату(НачалоПериода);
		ЭлементОтбора                = Обработки.бит_КонсольОперативногоВизирования.НовыйЭлементВнешнегоОтбора();
		ЭлементОтбора.ЛевоеЗначение  = "Дата";
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.БольшеИлиРавно;
		ЭлементОтбора.ПравоеЗначение = НачалоПериода;
		// АПК:1297-выкл Строковый параметр.
		ЭлементОтбора.Представление  = "НачалоПериода";
		// АПК:1297-вкл
		НастраиваемыеОтборы.Вставить("НачалоПериода", ЭлементОтбора);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОкончаниеПериода) Тогда
		ОкончаниеПериода = КонецДня(СтрокаВДату(ОкончаниеПериода));
		ЭлементОтбора                = Обработки.бит_КонсольОперативногоВизирования.НовыйЭлементВнешнегоОтбора();
		ЭлементОтбора.ЛевоеЗначение  = "Дата";
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.МеньшеИлиРавно;
		ЭлементОтбора.ПравоеЗначение = ОкончаниеПериода;
		// АПК:1297-выкл Строковый параметр.
		ЭлементОтбора.Представление  = "ОкончаниеПериода";
		// АПК:1297-вкл
		НастраиваемыеОтборы.Вставить("ОкончаниеПериода", ЭлементОтбора);
	КонецЕсли;
	Если ЗначениеЗаполнено(НастраиваемыеОтборы) Тогда
		ПараметрыПолучения.Отбор.ВнешниеОтборы = НастраиваемыеОтборы;
	КонецЕсли;
	
	// РМВ.
	Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
	
	Результат = ПолучитьИзВременногоХранилища(АдресВХранилище);
	ТаблицаОбъектовВизирования = Результат.РезультатТаблицаЗначений;
	ОбъектыВизирования = Новый Массив;
	Если ТаблицаОбъектовВизирования.Количество() > 0 Тогда
		УстановитьПривилегированныйРежим(Истина);
		// Получение сведений о прикрепленных файлах.
		ВсеСсылки = ТаблицаОбъектовВизирования.ВыгрузитьКолонку("ОбъектВизирования");
		ВсеСсылки = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ВсеСсылки);
		ПрикрепленныеФайлы = ПолучитьИнформациюФайлов(ВсеСсылки);		
		ЗапросПлатежнойПозиции = бит_МобильноеПриложениеПереопределяемый.ЗапросПлатежнойПозиции();
		Для каждого СтрокаТаблицы Из ТаблицаОбъектовВизирования Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ОбъектВизирования) Тогда	
				Продолжить;
			КонецЕсли;
			ДанныеОбъекта = ЗаполнитьОбъектВизирования(СтрокаТаблицы, ПрикрепленныеФайлы, ЗапросПлатежнойПозиции);
			ОбъектыВизирования.Добавить(ДанныеОбъекта);		
		КонецЦикла; 
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
  
  	Возврат ОбъектыВизирования;
  	
КонецФункции
 
Функция ЗаполнитьОбъектВизирования(СтрокаТаблицы, ПрикрепленныеФайлы, ЗапросПлатежнойПозиции, ЭтоЗадача = Ложь)
	
	СтрВизы = "";
	ВизаИД = "";
	Для каждого Виза Из СтрокаТаблицы.ВизаСмешанная Цикл
		СтрВизы = СтрВизы +?(ПустаяСтрока(СтрВизы),"",", ")+ Строка(Виза);
		Если ЗначениеЗаполнено(Виза) И ПустаяСтрока(ВизаИД) Тогда			
			ВизаИД = XMLСтрока(Виза);			
		КонецЕсли; 
	КонецЦикла; 

	МетаОбъект = СтрокаТаблицы.ОбъектВизирования.Метаданные();
	Имена      = бит_ОбщегоНазначенияКлиентСервер.РазобратьПолноеИмяОбъекта(МетаОбъект.ПолноеИмя());
	
	МодельОбъекта = Новый Структура("ID, ObjectName, CollectionName");
	МодельОбъекта.ID             = XMLСтрока(СтрокаТаблицы.ОбъектВизирования);
	МодельОбъекта.ObjectName     = Имена.ИмяОбъекта;
	МодельОбъекта.CollectionName = Имена.ИмяКоллекции;
	
	ДанныеОбъекта = Новый Структура;
	ДанныеОбъекта.Вставить("Company",           Строка(СтрокаТаблицы.Организация));
	ДанныеОбъекта.Вставить("Department",        СтрСоединить(СтрокаТаблицы.ЦФОСмешанная, ", "));
	ДанныеОбъекта.Вставить("TurnoverItem",      СтрСоединить(СтрокаТаблицы.СтатьяОборотовСмешанная, ", "));
	ДанныеОбъекта.Вставить("Partner",           Строка(СтрокаТаблицы.Контрагент));
	ДанныеОбъекта.Вставить("Amount",            Формат(СтрокаТаблицы.СуммаДокумента, "ЧГ="));
	ДанныеОбъекта.Вставить("Currency",          Строка(СтрокаТаблицы.ВалютаДокумента));
	ДанныеОбъекта.Вставить("ManagerialPurpose", Строка(СтрокаТаблицы.НазначениеПлатежаУпр));
	ДанныеОбъекта.Вставить("OverBudget",        ?(ЗначениеЗаполнено(СтрокаТаблицы.СверхБюджета),СтрокаТаблицы.СверхБюджета,Ложь));
	ДанныеОбъекта.Вставить("Status",            Строка(СтрокаТаблицы.Статус));
	ДанныеОбъекта.Вставить("ResponsiblePerson", Строка(СтрокаТаблицы.Ответственный));
	ДанныеОбъекта.Вставить("Scenario",          Строка(СтрокаТаблицы.Сценарий));
	ДанныеОбъекта.Вставить("Comment",           СтрокаТаблицы.Комментарий);
	ДанныеОбъекта.Вставить("Date",              ?(ЭтоЗадача, СтрокаТаблицы.Дата, Формат(СтрокаТаблицы.Дата, "ДЛФ=D")));
	ДанныеОбъекта.Вставить("Number",            СтрокаТаблицы.Номер);
	ДанныеОбъекта.Вставить("AdditionalProps",   ДополнительныеРеквизитыОбъекта(СтрокаТаблицы.ОбъектВизирования));
	ДанныеОбъекта.Вставить("UseInternalTables", ИспользоватьВнутреннююТаблицу(СтрокаТаблицы.ОбъектВизирования));
	ДанныеОбъекта.Вставить("BasisForecast",     Неопределено);
	ДанныеОбъекта.Вставить("Executor",          "");
	ДанныеОбъекта.Вставить("PaymentDate",       "");
	
	бит_МобильноеПриложениеПереопределяемый.ДополнитьДанныеОбъекта(ДанныеОбъекта, СтрокаТаблицы, ЗапросПлатежнойПозиции, ЭтоЗадача);
	
	ОбъектВизирования = Новый Структура;		
	ОбъектВизирования.Вставить("Visas",             СтрВизы);
	ОбъектВизирования.Вставить("VisasID",           ВизаИД);
	ОбъектВизирования.Вставить("ObjectModel",       МодельОбъекта);
	ОбъектВизирования.Вставить("ObjectInfo",        ДанныеОбъекта);
	ОбъектВизирования.Вставить("ApplicationReestr", Неопределено);
	ОбъектВизирования.Вставить("Files",             Новый Массив);
	
	Если бит_МобильноеПриложениеПереопределяемый.ЭтоРеестр(СтрокаТаблицы.ОбъектВизирования) Тогда
		бит_МобильноеПриложениеПереопределяемый.ДополнитьДаннымиРеестраПлатежей(ОбъектВизирования, СтрокаТаблицы);
	КонецЕсли;
	
	// Данные о файлах.
	ПрикрепленныеФайлыОбъекта = ПрикрепленныеФайлы[СтрокаТаблицы.ОбъектВизирования];
	Если ТипЗнч(ПрикрепленныеФайлыОбъекта) = Тип("Массив") Тогда
		Для каждого ДанныеФайла Из ПрикрепленныеФайлыОбъекта Цикл
			ИнформацияОФайле = Новый Структура;
			ИнформацияОФайле.Вставить("Name",        ДанныеФайла.Наименование);
			ИнформацияОФайле.Вставить("DateChanged", ДанныеФайла.ДатаМодификацииФайла);
			ИнформацияОФайле.Вставить("ID",          ДанныеФайла.ИдФайла);
			ИнформацияОФайле.Вставить("VersionID",   ДанныеФайла.ИдВерсии);
			ИнформацияОФайле.Вставить("Ext",         ДанныеФайла.Расширение);
			ИнформацияОФайле.Вставить("Size",        ДанныеФайла.Размер);
			ОбъектВизирования.Files.Добавить(ИнформацияОФайле);
		КонецЦикла;
	КонецЕсли;
	
	Возврат ОбъектВизирования;
	
КонецФункции

// Функция получает историю визирования.
//
// Параметры:
//  ПараметрыОбъекта - Структура - структура параметров объекта.
// 
// Возвращаемое значение:
//  Массив - массив структур.
//
Функция ПолучитьИсториюВизированияОбъектов(ДанныеЗапроса)
	
	Пользователь     = ДанныеЗапроса.User;
	ИменаОбъектов    = ДанныеЗапроса.Objects;
	НачалоПериода    = ДанныеЗапроса.DateStart;
	ОкончаниеПериода = ДанныеЗапроса.DateFinish;
	Статусы          = ДанныеЗапроса.Status;
  
	ТекПользователь  = НайтиПользователя(Пользователь);
	НачалоПериода    = СтрокаВДату(НачалоПериода);
	ОкончаниеПериода = КонецДня(СтрокаВДату(ОкончаниеПериода));
	Если НЕ ЗначениеЗаполнено(ТекПользователь) Тогда
		ТекстСообщения = НСтр("ru = 'HTTP-сервис bit_ApprovalServiceNew. Ошибка метода HistoryApproval.
                               |Не удалось найти пользователя по имени: %1';
							   |en = 'HTTP service bit_ApprovalServiceNew. HistoryApproval method error.
                               |Could not find user by name: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, Пользователь);
		ИмяСобытия = НСтр("ru = 'approval/v1/HistoryApproval'; en = 'approval/v1/HistoryApproval'",
			ОбщегоНазначения.КодОсновногоЯзыка());
		ЗарегистрироватьОшибку(ИмяСобытия, ТекстСообщения);	
	КонецЕсли; 
    
    ПараметрыСеанса.бит_ИдентификаторСеанса = Новый УникальныйИдентификатор;						 			
	
	СписокТипов = Новый СписокЗначений;	
	Если ТипЗнч(ИменаОбъектов) = Тип("Строка") И НЕ ПустаяСтрока(ИменаОбъектов) Тогда
		
		ПолученныеТипы = бит_ОбщегоНазначенияКлиентСервер.ПолучитьТипыИзСтроки(ИменаОбъектов);
		Если ПолученныеТипы.Количество()=0 Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Для каждого ТекТип Из ПолученныеТипы Цикл
			СписокТипов.Добавить(ТекТип);		
		КонецЦикла; 
	
	КонецЕсли;
	
	СписокСтатусов = Новый СписокЗначений;
	Если ТипЗнч(Статусы) = Тип("Строка") И НЕ ПустаяСтрока(Статусы) Тогда
		
		ПолученныеТипы =СтрРазделить(Статусы, ",", Ложь);
		Если ПолученныеТипы.Количество() = 0 Тогда
			СписокСтатусов.Добавить(Статусы);
		КонецЕсли;
		
		Для каждого ТекТип Из ПолученныеТипы Цикл
			СписокСтатусов.Добавить(ТекТип);		
		КонецЦикла; 
	
	КонецЕсли;
	
	ОбъектыВизирования = Новый Массив;
	АдресВХранилище    = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор); 
	МатрицаДоступа     = Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа();
	ПараметрыПолучения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
	ПараметрыПолучения.МатрицаДоступа           = МатрицаДоступа;
	ПараметрыПолучения.ВыводитьВТаблицуЗначений = Истина;
	ПараметрыПолучения.ЭтоМобильноеПриложение   = Истина;
	ПараметрыПолучения.РежимАрхива              = Истина;
	
	Если СписокТипов.Количество() > 0 Тогда
		ПараметрыПолучения.Отбор.ТипОбъекта = СписокТипов;
	КонецЕсли;
	
	НастраиваемыеОтборы = Новый Структура;
	Если СписокСтатусов.Количество() > 0 Тогда
		ЭлементОтбора                = Обработки.бит_КонсольОперативногоВизирования.НовыйЭлементВнешнегоОтбора();
		ЭлементОтбора.ЛевоеЗначение  = "Статус.Наименование";
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.ВСписке;
		ЭлементОтбора.ПравоеЗначение = СписокСтатусов;
		// АПК:1297-выкл Строковый параметр.
		ЭлементОтбора.Представление  = "ОтборПоСтатусам";
		// АПК:1297-вкл
		НастраиваемыеОтборы.Вставить("СтатусНаименование", ЭлементОтбора);
	КонецЕсли;
	
	// Отборы по дате последнего решения.
	ЭлементОтбора                = Обработки.бит_КонсольОперативногоВизирования.НовыйЭлементВнешнегоОтбора();
	ЭлементОтбора.ЛевоеЗначение  = "ДатаКрайняя";
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.БольшеИлиРавно;
	ЭлементОтбора.ПравоеЗначение = НачалоПериода;
	// АПК:1297-выкл Строковый параметр.
	ЭлементОтбора.Представление  = "НачалоПериода";
	// АПК:1297-вкл
	НастраиваемыеОтборы.Вставить("НачалоПериода", ЭлементОтбора);
	
	ЭлементОтбора                = Обработки.бит_КонсольОперативногоВизирования.НовыйЭлементВнешнегоОтбора();
	ЭлементОтбора.ЛевоеЗначение  = "ДатаКрайняя";
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.МеньшеИлиРавно;
	ЭлементОтбора.ПравоеЗначение = ОкончаниеПериода;
	// АПК:1297-выкл Строковый параметр.
	ЭлементОтбора.Представление  = "ОкончаниеПериода";
	// АПК:1297-вкл
	НастраиваемыеОтборы.Вставить("ОкончаниеПериода", ЭлементОтбора);
	
	ПараметрыПолучения.Отбор.ВнешниеОтборы = НастраиваемыеОтборы;
	
	// РМВ.
	Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	

	РезультатОбработки = ПолучитьИзВременногоХранилища(АдресВХранилище);
	ТаблицаДокументов  = РезультатОбработки.РезультатТаблицаЗначений;
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Получение сведений о прикрепленных файлах.
	ВсеСсылки = ТаблицаДокументов.ВыгрузитьКолонку("ОбъектВизирования");
	ВсеСсылки = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ВсеСсылки);
	ПрикрепленныеФайлы = ПолучитьИнформациюФайлов(ВсеСсылки);
	
	ОбъектыВизирования = Новый Массив;
	Для каждого СтрокаТаблицы Из ТаблицаДокументов Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ОбъектВизирования) Тогда	
			Продолжить;		
		КонецЕсли;
		// Извлекаем историю визирования.
		
		СтрВизы = "";
		ВизаИД = "";
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Объект", СтрокаТаблицы.ОбъектВизирования);
		Запрос.УстановитьПараметр("Пользователь", ТекПользователь);
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИсторияВиз.Период КАК Период,
		|	ИсторияВиз.Виза КАК Виза,
		|	ИсторияВиз.Пользователь КАК Пользователь,
		|	ИсторияВиз.Комментарий КАК Комментарий,
		|	ИсторияВиз.Решение КАК Решение
		|ИЗ
		|	РегистрСведений.бит_ИсторияИзмененияВиз КАК ИсторияВиз
		|ГДЕ
		|	ИсторияВиз.Объект = &Объект
		|	И ИсторияВиз.Пользователь = &Пользователь
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период УБЫВ";
		
		Результат = Запрос.Выполнить();
		Выборка   = Результат.Выбрать();
		
		Если Выборка.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		VisaHistory = Новый Структура("Row");
		Визы = Новый Массив();
		StatusDate = '00010101';
		Пока Выборка.Следующий() Цикл
			Если StatusDate = '00010101' Тогда
				StatusDate = Формат(Выборка.Период,"ДЛФ=D");
			КонецЕсли;
			
			Visa = Новый Структура;
			Visa.Вставить("Period",     Выборка.Период);
			Visa.Вставить("Visa",       Строка(Выборка.Виза));
			Visa.Вставить("User",       Строка(Выборка.Пользователь));
			Visa.Вставить("Comment",    Выборка.Комментарий);
			Visa.Вставить("Decision",   Строка(Выборка.Решение));
			Визы.Добавить(Visa);
			СтрВизы = СтрВизы +?(ПустаяСтрока(СтрВизы),"",", ")+ Строка(Выборка.Виза);
			
			Если ЗначениеЗаполнено(Выборка.Виза) Тогда			
				 ВизаИД = XMLСтрока(Выборка.Виза);			
			КонецЕсли;
		КонецЦикла;	
		VisaHistory.Row = Визы;

		МетаОбъект = СтрокаТаблицы.ОбъектВизирования.Метаданные();
		Имена      = бит_ОбщегоНазначенияКлиентСервер.РазобратьПолноеИмяОбъекта(МетаОбъект.ПолноеИмя());
		
		МодельОбъекта                = Новый Структура("ID, ObjectName, CollectionName");
		МодельОбъекта.ID             = XMLСтрока(СтрокаТаблицы.ОбъектВизирования);
		МодельОбъекта.ObjectName     = Имена.ИмяОбъекта;
		МодельОбъекта.CollectionName = Имена.ИмяКоллекции;
		
		ДанныеОбъекта = Новый Структура;
		ДанныеОбъекта.Вставить("Company",           Строка(СтрокаТаблицы.Организация));
		ДанныеОбъекта.Вставить("Department",        СтрСоединить(СтрокаТаблицы.ЦФОСмешанная, ", "));
		ДанныеОбъекта.Вставить("TurnoverItem",      СтрСоединить(СтрокаТаблицы.СтатьяОборотовСмешанная, ", "));
		ДанныеОбъекта.Вставить("Partner",           Строка(СтрокаТаблицы.Контрагент));
		ДанныеОбъекта.Вставить("Amount",            Формат(СтрокаТаблицы.СуммаДокумента, "ЧГ="));
		ДанныеОбъекта.Вставить("Currency",          Строка(СтрокаТаблицы.ВалютаДокумента));
		ДанныеОбъекта.Вставить("ManagerialPurpose", Строка(СтрокаТаблицы.НазначениеПлатежаУпр));
		ДанныеОбъекта.Вставить("OverBudget",        ?(ТипЗнч(СтрокаТаблицы.СверхБюджета) = Тип("Булево"), СтрокаТаблицы.СверхБюджета, Ложь));
		ДанныеОбъекта.Вставить("Status",            Строка(СтрокаТаблицы.Статус));
		ДанныеОбъекта.Вставить("StatusDate",        Формат(StatusDate,"ДЛФ=D"));
		ДанныеОбъекта.Вставить("ResponsiblePerson", Строка(СтрокаТаблицы.Ответственный));
		ДанныеОбъекта.Вставить("Scenario",          Строка(СтрокаТаблицы.Сценарий));
		ДанныеОбъекта.Вставить("Comment",           СтрокаТаблицы.Комментарий);
		ДанныеОбъекта.Вставить("Date",              Формат(СтрокаТаблицы.Дата, "ДЛФ=D"));
		ДанныеОбъекта.Вставить("Number",            СтрокаТаблицы.Номер);
		ДанныеОбъекта.Вставить("AdditionalProps",   ДополнительныеРеквизитыОбъекта(СтрокаТаблицы.ОбъектВизирования));
		ДанныеОбъекта.Вставить("UseInternalTables", ИспользоватьВнутреннююТаблицу(СтрокаТаблицы.ОбъектВизирования));
		ДанныеОбъекта.Вставить("BasisForecast",     Неопределено);
		ДанныеОбъекта.Вставить("Executor",          "");
		ДанныеОбъекта.Вставить("PaymentDate",       "");
		// N.B.
		Если СтрокаТаблицы.Статус.Наименование = "Проверен"
			ИЛИ СтрокаТаблицы.Статус.Наименование = "Утвержден"
			ИЛИ СтрокаТаблицы.Статус.Наименование = "Закрыта"
			ИЛИ СтрокаТаблицы.Статус.Наименование = "Исполнена"
			ИЛИ СтрокаТаблицы.Статус.Наименование = "Утверждена"
			ИЛИ СтрокаТаблицы.Статус.Наименование = "Оплачена"
			ИЛИ СтрокаТаблицы.Статус.Наименование = "Выполнена" Тогда
			
			ДанныеОбъекта.Вставить("Agreed", Истина);
		Иначе 
			ДанныеОбъекта.Вставить("Agreed", Ложь);
		КонецЕсли;
		бит_МобильноеПриложениеПереопределяемый.ДополнитьДанныеОбъекта(ДанныеОбъекта, СтрокаТаблицы); 
		
		ОбъектВизирования = Новый Структура;
		ОбъектВизирования.Вставить("Visas",             СтрВизы);
		ОбъектВизирования.Вставить("VisasID",           ВизаИД);
		ОбъектВизирования.Вставить("ObjectModel",       МодельОбъекта);
		ОбъектВизирования.Вставить("ObjectInfo",        ДанныеОбъекта);
		ОбъектВизирования.Вставить("VisaHistory",       VisaHistory);
		ОбъектВизирования.Вставить("ApplicationReestr", Неопределено);
		ОбъектВизирования.Вставить("Files",             Новый Массив);
		
		Если бит_МобильноеПриложениеПереопределяемый.ЭтоРеестр(СтрокаТаблицы.ОбъектВизирования) Тогда
			бит_МобильноеПриложениеПереопределяемый.ДополнитьДаннымиРеестраПлатежей(ОбъектВизирования, СтрокаТаблицы);
		КонецЕсли;
		
		// Данные о файлах.
		ПрикрепленныеФайлыОбъекта = ПрикрепленныеФайлы[СтрокаТаблицы.ОбъектВизирования];
		Если ТипЗнч(ПрикрепленныеФайлыОбъекта) = Тип("Массив") Тогда
			Для каждого ДанныеФайла Из ПрикрепленныеФайлыОбъекта Цикл
				ИнформацияОФайле = Новый Структура;
				ИнформацияОФайле.Вставить("Name",        ДанныеФайла.Наименование);
				ИнформацияОФайле.Вставить("DateChanged", ДанныеФайла.ДатаМодификацииФайла);
				ИнформацияОФайле.Вставить("ID",          ДанныеФайла.ИдФайла);
				ИнформацияОФайле.Вставить("VersionID",   ДанныеФайла.ИдВерсии);
				ИнформацияОФайле.Вставить("Ext",         ДанныеФайла.Расширение);
				ИнформацияОФайле.Вставить("Size",        ДанныеФайла.Размер);
				ОбъектВизирования.Files.Добавить(ИнформацияОФайле);
			КонецЦикла;
		КонецЕсли;
		
		ОбъектыВизирования.Добавить(ОбъектВизирования);		
		
	КонецЦикла; 
	
	УстановитьПривилегированныйРежим(Ложь);
  
  	Возврат ОбъектыВизирования;
  	
КонецФункции

Функция ПолучитьСтатусы()
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Статусы.Наименование КАК Наименование
	|ИЗ
	|	РегистрСведений.бит_ОбъектыМобильногоВизирования КАК ОбъектыВизирования
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_СтатусыОбъектов КАК Статусы
	|		ПО ОбъектыВизирования.ОбъектСистемы = Статусы.Объект";
	
	Выборка = Запрос.Выполнить().Выбрать();
	ПереченьСтатусов = Новый Массив();
	Пока Выборка.Следующий() Цикл
		ПереченьСтатусов.Добавить(Выборка.Наименование);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ПереченьСтатусов;
	
КонецФункции

Функция ВидыРешенийСогласования(ДанныеЗапроса)

	Если НЕ ТипЗнч(ДанныеЗапроса) = Тип("Массив") Тогда
		Возврат Неопределено;
	КонецЕсли;		

	Результат = Новый Массив;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ВидыРешенийСогласования.ОбъектСистемы КАК ОбъектСистемы,
	|	ВидыРешенийСогласования.Организация КАК Организация,
	|	ВидыРешенийСогласования.ВидРешения КАК ВидРешения,
	|	ВидыРешенийСогласования.НеобходимКомментарийЗадача КАК НеобходимКомментарийЗадача,
	|	ВидыРешенийСогласования.КодСортировки КАК КодСортировки,
	|	ВЫБОР
	|		КОГДА Решения.ТипРешения = ЗНАЧЕНИЕ(Перечисление.бит_ТипыРешений.Согласующее)
	|			ТОГДА ИСТИНА
	|		КОГДА Решения.ТипРешения = ЗНАЧЕНИЕ(Перечисление.бит_ТипыРешений.Отклоняющее)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК СогласующееРешение
	|ИЗ
	|	РегистрСведений.бит_НазначениеВидовРешенийСогласования КАК ВидыРешенийСогласования
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_ВидыРешенийСогласования КАК Решения
	|		ПО ВидыРешенийСогласования.ВидРешения = Решения.Ссылка
	|ГДЕ
	|	НЕ ВидыРешенийСогласования.ВидРешения.Отключено
	|	И &ДопУсловие
	|ИТОГИ ПО
	|	ОбъектСистемы,
	|	Организация";
	
	Запрос = Новый Запрос;
	Если ДанныеЗапроса.Количество() > 0 Тогда
		ОбъектыСистемы = ПолучитьОбъектыСистемы(ДанныеЗапроса);
		Запрос.УстановитьПараметр("ОбъектыСистемы", ОбъектыСистемы);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ДопУсловие","ВидыРешенийСогласования.ОбъектСистемы В(&ОбъектыСистемы)");
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И &ДопУсловие","");
	КонецЕсли;
	Запрос.Текст = ТекстЗапроса;
	
	ВыборкаОбъектСистемы = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОбъектСистемы.Следующий() Цикл
		
		ОбъектСистемы             = Новый Структура("Id, Description, Organizations");
		ОбъектСистемы.Id          = XMLСтрока(ВыборкаОбъектСистемы.ОбъектСистемы);
		ОбъектСистемы.Description = Строка(ВыборкаОбъектСистемы.ОбъектСистемы);
		
		Организации = Новый Массив;
		ВыборкаОрганизация = ВыборкаОбъектСистемы.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаОрганизация.Следующий() Цикл
						
			Решения = Новый Массив;
			Выборка = ВыборкаОрганизация.Выбрать();
			Пока Выборка.Следующий() Цикл
				
				Решение                   = Новый Структура("Id, Description, NeedCommentOrTask, Priority, Approval");
				Решение.Id                = XMLСтрока(Выборка.ВидРешения);
				Решение.Description       = Строка(Выборка.ВидРешения);
				Решение.NeedCommentOrTask = Выборка.НеобходимКомментарийЗадача;
				Решение.Priority          = Выборка.КодСортировки;
				Решение.Approval          = Выборка.СогласующееРешение;
				
				Решения.Добавить(Решение);
			КонецЦикла;
			
			ТекущаяОрганизация             = Новый Структура("Id, Description, Decisions");
			ТекущаяОрганизация.Id          = XMLСтрока(ВыборкаОрганизация.Организация);
			ТекущаяОрганизация.Description = Строка(ВыборкаОрганизация.Организация);
			ТекущаяОрганизация.Decisions   = Решения;
			
			Организации.Добавить(ТекущаяОрганизация);
			
		КонецЦикла;
		
		ОбъектСистемы.Organizations = Организации;
		
		Результат.Добавить(ОбъектСистемы);
		
	КонецЦикла;
		
	Возврат Результат;
	
КонецФункции 

Функция ИсторияВизирования(Ид, Имя)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если бит_МобильноеПриложениеПереопределяемый.ЭтоСправочник(Имя) Тогда
		МенеджерОбъекта = Справочники[Имя];
	Иначе
		МенеджерОбъекта = Документы[Имя];
	КонецЕсли;
	УИД    = Новый УникальныйИдентификатор(Ид);
	Ссылка = МенеджерОбъекта.ПолучитьСсылку(УИД);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Объект", Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИсторияВизирования.Период КАК Период,
	|	ИсторияВизирования.Виза КАК Виза,
	|	ИсторияВизирования.Пользователь КАК Пользователь,
	|	ИсторияВизирования.Комментарий КАК Комментарий,
	|	ИсторияВизирования.Решение КАК Решение
	|ИЗ
	|	РегистрСведений.бит_ИсторияИзмененияВиз КАК ИсторияВизирования
	|ГДЕ
	|	ИсторияВизирования.Объект = &Объект";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Результат = Новый Массив;
	Пока Выборка.Следующий() Цикл
		Запись = Новый Структура();
		Запись.Вставить("Period",   Выборка.Период);
		Запись.Вставить("Visa",     Строка(Выборка.Виза));
		Запись.Вставить("User",     Строка(Выборка.Пользователь));
		Запись.Вставить("Comment",  Строка(Выборка.Комментарий));
		Запись.Вставить("Decision", Строка(Выборка.Решение));
		Результат.Добавить(Запись);
	КонецЦикла;	
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьДоступныеВизыОбъекта(ОбъектВизирования)
	
	Результат          = Новый Массив;
	АдресВХранилище    = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор);
	МатрицаДоступа     = Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа();
	ПараметрыПолучения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
	ПараметрыПолучения.МатрицаДоступа           = МатрицаДоступа;
	ПараметрыПолучения.ВыводитьВТаблицуЗначений = Истина;
	ПараметрыПолучения.ЭтоМобильноеПриложение   = Истина;
	ПараметрыПолучения.Отбор.ОбъектВизирования  = ОбъектВизирования;
	Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
	РезультатОбработки = ПолучитьИзВременногоХранилища(АдресВХранилище);
	ТаблицаОбъектов    = РезультатОбработки.РезультатТаблицаЗначений;
	
	Если ТаблицаОбъектов.Количество() > 0 Тогда
		СтрокаТаблицы = ТаблицаОбъектов[0];
		Для каждого Виза Из СтрокаТаблицы.ВизаСмешанная Цикл
			Результат.Добавить(Виза);
		КонецЦикла;
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Функция ПолучитьДоступныеВизыОбъектов(ОбъектыВизирования, ВозвращатьИДРегистраВиз = Ложь)
	
	Результат = Новый Соответствие;
	
	Если ОбъектыВизирования.Количество() > 0 Тогда
		ОтборОбъектыВизирования = Новый СписокЗначений;
		ОтборОбъектыВизирования.ЗагрузитьЗначения(ОбъектыВизирования);
		
		АдресВХранилище     = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор);
		МатрицаДоступа      = Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа();
		ПараметрыПолучения  = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
		ПараметрыПолучения.МатрицаДоступа           = МатрицаДоступа;
		ПараметрыПолучения.ВыводитьВТаблицуЗначений = Истина;
		ПараметрыПолучения.ЭтоМобильноеПриложение   = Истина;
		ПараметрыПолучения.Отбор.ОбъектВизирования  = ОтборОбъектыВизирования;
		Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
		РезультатОбработки = ПолучитьИзВременногоХранилища(АдресВХранилище);
		ТаблицаОбъектов    = РезультатОбработки.РезультатТаблицаЗначений;
		
		Для каждого СтрокаТаблицы Из ТаблицаОбъектов Цикл
			Визы = Новый Массив;
			Для каждого Виза Из СтрокаТаблицы.ВизаСмешанная Цикл
				ПараметрыВизы = Новый Структура;
				ПараметрыВизы.Вставить("Id",          XMLСтрока(Виза));
				ПараметрыВизы.Вставить("Description", Виза.Наименование);
				Если ВозвращатьИДРегистраВиз Тогда
					ПараметрыВизы.Вставить("МассивИД", СтрокаТаблицы.ИД);
				КонецЕсли;
				Визы.Добавить(ПараметрыВизы);
			КонецЦикла;
			Результат.Вставить(СтрокаТаблицы.ОбъектВизирования, Визы)
		КонецЦикла; 
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

Функция ИдентификаторыДоступныхВизОбъектов(ОбъектыВизирования)
	
	Результат = Новый Соответствие;
	
	Если ОбъектыВизирования.Количество() > 0 Тогда
		ОтборОбъектыВизирования = Новый СписокЗначений;
		ОтборОбъектыВизирования.ЗагрузитьЗначения(ОбъектыВизирования);
		
		АдресВХранилище                             = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор);
		МатрицаДоступа                              = Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа();
		ПараметрыПолучения                          = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
		ПараметрыПолучения.МатрицаДоступа           = МатрицаДоступа;
		ПараметрыПолучения.ВыводитьВТаблицуЗначений = Истина;
		ПараметрыПолучения.ЭтоМобильноеПриложение   = Истина;
		ПараметрыПолучения.Отбор.ОбъектВизирования  = ОтборОбъектыВизирования;
		Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
		
		РезультатОбработки = ПолучитьИзВременногоХранилища(АдресВХранилище);
		ТаблицаОбъектов    = РезультатОбработки.РезультатТаблицаЗначений;
		
		Для каждого СтрокаТаблицы Из ТаблицаОбъектов Цикл
			Результат.Вставить(СтрокаТаблицы.ОбъектВизирования, СтрокаТаблицы.ИД)
		КонецЦикла; 
	КонецЕсли;
		
	Возврат Результат;
	
