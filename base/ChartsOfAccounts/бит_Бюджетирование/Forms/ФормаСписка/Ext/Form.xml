			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ТекПланСчетов.Ссылка,
	ТекПланСчетов.Код,
	ТекПланСчетов.КодБыстрогоВыбора,
	ТекПланСчетов.Наименование,
	ТекПланСчетов.НаименованиеПолное,
	ТекПланСчетов.ВерсияДанных,
	ТекПланСчетов.ПометкаУдаления,
	ТекПланСчетов.Предопределенный,
	ТекПланСчетов.Родитель,
	ТекПланСчетов.Забалансовый,
	ВЫБОР
		КОГДА ТекПланСчетов.Вид = ЗНАЧЕНИЕ(ВидСчета.Активный)
			ТОГДА &amp;А
		ИНАЧЕ ВЫБОР
				КОГДА ТекПланСчетов.Вид = ЗНАЧЕНИЕ(ВидСчета.Пассивный)
					ТОГДА &amp;П
				ИНАЧЕ &amp;АП
			КОНЕЦ
	КОНЕЦ КАК Вид,
	ТекПланСчетов.Валютный,
	ТекПланСчетов.Количественный,
	ТекПланСчетов.Порядок,
	Субконто1.Субконто КАК Субконто1,
	Субконто2.Субконто КАК Субконто2,
	Субконто3.Субконто КАК Субконто3,
	Субконто4.Субконто КАК Субконто4,
	ТекПланСчетов.ЗапретитьИспользоватьВПроводках
ИЗ
	ПланСчетов.бит_Бюджетирование КАК ТекПланСчетов
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ТекПланСчетовВидыСубконто.ВидСубконто.Наименование + ВЫБОР
				КОГДА ТекПланСчетовВидыСубконто.ТолькоОбороты
					ТОГДА &amp;Оборот
				ИНАЧЕ &amp;Пусто
			КОНЕЦ КАК Субконто,
			ТекПланСчетовВидыСубконто.Ссылка КАК Ссылка
		ИЗ
			ПланСчетов.бит_Бюджетирование.ВидыСубконто КАК ТекПланСчетовВидыСубконто
		ГДЕ
			ТекПланСчетовВидыСубконто.НомерСтроки = 1) КАК Субконто1
		ПО ТекПланСчетов.Ссылка = Субконто1.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ТекПланСчетовВидыСубконто.ВидСубконто.Наименование + ВЫБОР
				КОГДА ТекПланСчетовВидыСубконто.ТолькоОбороты
					ТОГДА &amp;Оборот
				ИНАЧЕ &amp;Пусто
			КОНЕЦ КАК Субконто,
			ТекПланСчетовВидыСубконто.Ссылка КАК Ссылка
		ИЗ
			ПланСчетов.бит_Бюджетирование.ВидыСубконто КАК ТекПланСчетовВидыСубконто
		ГДЕ
			ТекПланСчетовВидыСубконто.НомерСтроки = 2) КАК Субконто2
		ПО ТекПланСчетов.Ссылка = Субконто2.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ТекПланСчетовВидыСубконто.ВидСубконто.Наименование + ВЫБОР
				КОГДА ТекПланСчетовВидыСубконто.ТолькоОбороты
					ТОГДА &amp;Оборот
				ИНАЧЕ &amp;Пусто
			КОНЕЦ КАК Субконто,
			ТекПланСчетовВидыСубконто.Ссылка КАК Ссылка
		ИЗ
			ПланСчетов.бит_Бюджетирование.ВидыСубконто КАК ТекПланСчетовВидыСубконто
		ГДЕ
			ТекПланСчетовВидыСубконто.НомерСтроки = 3) КАК Субконто3
		ПО ТекПланСчетов.Ссылка = Субконто3.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ТекПланСчетовВидыСубконто.ВидСубконто.Наименование + ВЫБОР
				КОГДА ТекПланСчетовВидыСубконто.ТолькоОбороты
					ТОГДА &amp;Оборот
				ИНАЧЕ &amp;Пусто
			КОНЕЦ КАК Субконто,
			ТекПланСчетовВидыСубконто.Ссылка КАК Ссылка
		ИЗ
			ПланСчетов.бит_Бюджетирование.ВидыСубконто КАК ТекПланСчетовВидыСубконто
		ГДЕ
			ТекПланСчетовВидыСубконто.НомерСтроки = 4) КАК Субконто4
		ПО ТекПланСчетов.Ссылка = Субконто4.Ссылка</QueryText>
				<MainTable>ChartOfAccounts.бит_Бюджетирование</MainTable>
