					<v8:content>List</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.Ref</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	Таблица.Ссылка,
	Таблица.ПометкаУдаления,
	Таблица.Номер,
	Таблица.Дата,
	Таблица.БизнесПроцесс,
	Таблица.ТочкаМаршрута,
	Таблица.Наименование,
	Таблица.Выполнена,
	Таблица.Автор,
	Таблица.Важность,
	Таблица.СрокИсполнения,
	Таблица.ДатаПринятияКИсполнению,
	Таблица.ДатаНачалаИсполнения,
	Таблица.ДатаОкончанияИсполнения,
	Таблица.Описание,
	Таблица.РезультатВыполнения,
	Таблица.Предмет,
	Таблица.Состояние,
	Таблица.СостояниеПредыдущее,
	Таблица.ЗадачаОснование,
	Таблица.Алгоритм,
	Таблица.АлгоритмПодчиненный,
	Таблица.ТочкаАлгоритма,
	Таблица.ЭтоПроверочнаяЗадача,
	Таблица.Исполнитель,
	Таблица.РольИсполнителя,
	Таблица.ОбъектАдресации_1,
	Таблица.ОбъектАдресации_2,
	Таблица.ОбъектАдресации_3,
	ВЫБОР
		КОГДА НЕ Таблица.Выполнена
				И Таблица.СрокИсполнения &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				И Таблица.СрокИсполнения &lt; &amp;ТекущаяДата
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК Просрочена,
	ВЫБОР
		КОГДА НаличиеПрисоединенныхФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА 0
		КОГДА НаличиеПрисоединенныхФайлов.ЕстьФайлы
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЕстьФайлы
ИЗ
	Задача.бит_Задача КАК Таблица
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеПрисоединенныхФайлов
		ПО Таблица.Ссылка = НаличиеПрисоединенныхФайлов.ОбъектСФайлами</QueryText>
				<MainTable>Task.бит_Задача</MainTable>
