#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ПрограммныйИнтерфейс

#Область ДляВызоваИзДругихПодсистем

// Процедура устанавливает значения регистра по умолчанию
//
// Параметры:
//   Запись           - РегистрСведенийЗапись - запись регистра
//   ДанныеЗаполнения - Структура - где ключ - имя ресурса
//
Процедура УстановкаНастроекПоУмолчанию(Запись, ДанныеЗаполнения) Экспорт
	
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"Период",
		ТекущаяДатаСеанса());
	
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"СтруктурноеПодразделение",
		Неопределено);
				
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"ФормироватьДвиженияПоФактуБюджетаЗакупок",
		Ложь);
		
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"ФормироватьЗависимыеОборотыПоФактуБюджетаЗакупок",
		Ложь);

	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"НастройкиЗакупокУстановлены",
		Истина);
		
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"КонтролироватьЗаявкуНаЗатратыПоБюджету",
		Ложь);
		
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету",
		Истина);
		
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

&НаСервере
Процедура ЗаполнитьНастройкуКонтроляПоБюджетуПриПереходеНаНовуюВерсию() Экспорт
 	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Таблица.Период КАК Период,
	|	Таблица.СтруктурноеПодразделение КАК СтруктурноеПодразделение,
	|	Таблица.УстанавливатьВДоговорахВысокийПриоритетЗаполненияАналитик КАК УстанавливатьВДоговорахВысокийПриоритетЗаполненияАналитик,
	|	Таблица.КонтролироватьГрафикиДоговоровПоБюджету КАК КонтролироватьГрафикиДоговоровПоБюджету,
	|	Таблица.КонтролироватьПревышенияСуммыПоДоговору КАК КонтролироватьПревышенияСуммыПоДоговору,
	|	Таблица.НастройкиДоговоровИЗатратУстановлены КАК НастройкиДоговоровИЗатратУстановлены,
	|	Таблица.УдалитьКонтролироватьЗаявкуНаЗатратыПоБюджету КАК УдалитьКонтролироватьЗаявкуНаЗатратыПоБюджету,
	|	Таблица.УдалитьНеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету КАК УдалитьНеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету,
	|	Таблица.ВерсияУдалитьКонтролироватьЗаявкуНаЗатратыПоБюджету КАК ВерсияУдалитьКонтролироватьЗаявкуНаЗатратыПоБюджету,
	|	Таблица.ВерсияУдалитьНеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету КАК ВерсияУдалитьНеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету
	|ИЗ
	|	РегистрСведений.бит_НастройкиДоговоровИЗатрат КАК Таблица
	|ГДЕ
	|	Таблица.ВерсияУдалитьКонтролироватьЗаявкуНаЗатратыПоБюджету = """"
	|	И Таблица.ВерсияУдалитьНеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету = """"";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ВерсияБФ = ОбновлениеИнформационнойБазы.ВерсияИБ("БитФинанс");
	НаборЗаписейНастройкиДоговоровИЗатрат = РегистрыСведений.бит_НастройкиДоговоровИЗатрат.СоздатьНаборЗаписей(); 
	ВыборкаНастройкиДоговоровИЗатрат = РезультатЗапроса.Выбрать();
    Пока ВыборкаНастройкиДоговоровИЗатрат.Следующий() Цикл
		НоваяНастройка = НаборЗаписейНастройкиДоговоровИЗатрат.Добавить();	
		ЗаполнитьЗначенияСвойств(НоваяНастройка, ВыборкаНастройкиДоговоровИЗатрат);
	    НоваяНастройка.ВерсияУдалитьКонтролироватьЗаявкуНаЗатратыПоБюджету = ВерсияБФ;
		НоваяНастройка.ВерсияУдалитьНеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету = ВерсияБФ;
	КонецЦикла;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НастройкиДоговоров.Период КАК Период,
	|	НастройкиДоговоров.СтруктурноеПодразделение КАК СтруктурноеПодразделение,
	|	НастройкиДоговоров.УдалитьКонтролироватьЗаявкуНаЗатратыПоБюджету КАК КонтролироватьЗаявкуНаЗатратыПоБюджету,
	|	НастройкиДоговоров.УдалитьНеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету КАК НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету
	|ПОМЕСТИТЬ ВТНастройкиДоговоров
	|ИЗ
	|	РегистрСведений.бит_НастройкиДоговоровИЗатрат КАК НастройкиДоговоров
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	СтруктурноеПодразделение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НастройкиЗакупок.Период КАК Период,
	|	НастройкиЗакупок.СтруктурноеПодразделение КАК СтруктурноеПодразделение,
	|	НастройкиЗакупок.ФормироватьДвиженияПоФактуБюджетаЗакупок КАК ФормироватьДвиженияПоФактуБюджетаЗакупок,
	|	НастройкиЗакупок.НастройкиЗакупокУстановлены КАК НастройкиЗакупокУстановлены,
	|	НастройкиЗакупок.ФормироватьЗависимыеОборотыПоФактуБюджетаЗакупок КАК ФормироватьЗависимыеОборотыПоФактуБюджетаЗакупок
	|ПОМЕСТИТЬ ВТНастройкиЗакупок
	|ИЗ
	|	РегистрСведений.бит_НастройкиЗакупок КАК НастройкиЗакупок
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	СтруктурноеПодразделение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТНастройкиДоговоров.Период КАК ПериодДоговор,
	|	ВТНастройкиДоговоров.СтруктурноеПодразделение КАК СтруктурноеПодразделение,
	|	МАКСИМУМ(ВТЗакупки.Период) КАК ПериодЗакупки
	|ПОМЕСТИТЬ ВТСовпашиеНастройки
	|ИЗ
	|	ВТНастройкиДоговоров КАК ВТНастройкиДоговоров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНастройкиЗакупок КАК ВТЗакупки
	|		ПО ВТНастройкиДоговоров.СтруктурноеПодразделение = ВТЗакупки.СтруктурноеПодразделение
	|			И ВТНастройкиДоговоров.Период >= ВТЗакупки.Период
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТНастройкиДоговоров.Период,
	|	ВТНастройкиДоговоров.СтруктурноеПодразделение
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ПериодДоговор,
	|	СтруктурноеПодразделение,
	|	ПериодЗакупки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТСовпашиеНастройки.ПериодДоговор КАК Период,
	|	ВТСовпашиеНастройки.СтруктурноеПодразделение КАК СтруктурноеПодразделение,
	|	ВТНастройкиДоговоров.КонтролироватьЗаявкуНаЗатратыПоБюджету КАК КонтролироватьЗаявкуНаЗатратыПоБюджету,
	|	ВТНастройкиДоговоров.НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету КАК НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету,
	|	ВТНастройкиЗакупок.ФормироватьДвиженияПоФактуБюджетаЗакупок КАК ФормироватьДвиженияПоФактуБюджетаЗакупок,
	|	ВТНастройкиЗакупок.НастройкиЗакупокУстановлены КАК НастройкиЗакупокУстановлены,
	|	ВТНастройкиЗакупок.ФормироватьЗависимыеОборотыПоФактуБюджетаЗакупок КАК ФормироватьЗависимыеОборотыПоФактуБюджетаЗакупок
	|ПОМЕСТИТЬ ВТИтогНастройкиДоговоровИЗакупок
	|ИЗ
	|	ВТСовпашиеНастройки КАК ВТСовпашиеНастройки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНастройкиДоговоров КАК ВТНастройкиДоговоров
	|		ПО ВТСовпашиеНастройки.ПериодДоговор = ВТНастройкиДоговоров.Период
	|			И ВТСовпашиеНастройки.СтруктурноеПодразделение = ВТНастройкиДоговоров.СтруктурноеПодразделение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНастройкиЗакупок КАК ВТНастройкиЗакупок
	|		ПО ВТСовпашиеНастройки.ПериодЗакупки = ВТНастройкиЗакупок.Период
	|			И ВТСовпашиеНастройки.СтруктурноеПодразделение = ВТНастройкиЗакупок.СтруктурноеПодразделение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТНастройкиДоговоров.Период КАК Период,
	|	ВТНастройкиДоговоров.СтруктурноеПодразделение КАК СтруктурноеПодразделение,
	|	ВТНастройкиДоговоров.КонтролироватьЗаявкуНаЗатратыПоБюджету КАК КонтролироватьЗаявкуНаЗатратыПоБюджету,
	|	ВТНастройкиДоговоров.НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету КАК НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету,
	|	ЛОЖЬ КАК ФормироватьДвиженияПоФактуБюджетаЗакупок,
	|	ИСТИНА КАК НастройкиЗакупокУстановлены,
	|	ЛОЖЬ КАК ФормироватьЗависимыеОборотыПоФактуБюджетаЗакупок
	|ПОМЕСТИТЬ ВТИтогНастройкиТолькоДоговоров
	|ИЗ
	|	ВТНастройкиДоговоров КАК ВТНастройкиДоговоров
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНастройкиЗакупок КАК ВТНастройкиЗакупок
	|		ПО ВТНастройкиДоговоров.СтруктурноеПодразделение = ВТНастройкиЗакупок.СтруктурноеПодразделение
	|			И ВТНастройкиДоговоров.Период >= ВТНастройкиЗакупок.Период
	|ГДЕ
	|	ВТНастройкиЗакупок.Период ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВТНастройкиДоговоров.Период) КАК ПериодДоговор,
	|	ВТНастройкиЗакупок.СтруктурноеПодразделение КАК СтруктурноеПодразделение,
	|	ВТНастройкиЗакупок.Период КАК ПериодЗакупки
	|ПОМЕСТИТЬ ВТНастройкиЗакупокПослеДоговоров
	|ИЗ
	|	ВТНастройкиЗакупок КАК ВТНастройкиЗакупок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНастройкиДоговоров КАК ВТНастройкиДоговоров
	|		ПО ВТНастройкиЗакупок.СтруктурноеПодразделение = ВТНастройкиДоговоров.СтруктурноеПодразделение
	|			И ВТНастройкиЗакупок.Период > ВТНастройкиДоговоров.Период
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНастройкиДоговоров КАК ВТНастройкиДоговоровПериод
	|		ПО ВТНастройкиЗакупок.СтруктурноеПодразделение = ВТНастройкиДоговоровПериод.СтруктурноеПодразделение
	|			И ВТНастройкиЗакупок.Период = ВТНастройкиДоговоровПериод.Период
	|ГДЕ
	|	ВТНастройкиДоговоровПериод.Период ЕСТЬ NULL
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТНастройкиЗакупок.Период,
	|	ВТНастройкиЗакупок.СтруктурноеПодразделение
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ПериодДоговор,
	|	ПериодЗакупки,
	|	СтруктурноеПодразделение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТНастройкиЗакупокПослеДоговоров.ПериодЗакупки КАК Период,
	|	ВТНастройкиЗакупокПослеДоговоров.СтруктурноеПодразделение КАК СтруктурноеПодразделение,
	|	ВТНастройкиДоговоров.КонтролироватьЗаявкуНаЗатратыПоБюджету КАК КонтролироватьЗаявкуНаЗатратыПоБюджету,
	|	ВТНастройкиДоговоров.НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету КАК НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету,
	|	ВТНастройкиЗакупок.ФормироватьДвиженияПоФактуБюджетаЗакупок КАК ФормироватьДвиженияПоФактуБюджетаЗакупок,
	|	ВТНастройкиЗакупок.НастройкиЗакупокУстановлены КАК НастройкиЗакупокУстановлены,
	|	ВТНастройкиЗакупок.ФормироватьЗависимыеОборотыПоФактуБюджетаЗакупок КАК ФормироватьЗависимыеОборотыПоФактуБюджетаЗакупок
	|ПОМЕСТИТЬ ВТИтогНастройкиЗакупок
	|ИЗ
	|	ВТНастройкиЗакупокПослеДоговоров КАК ВТНастройкиЗакупокПослеДоговоров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНастройкиДоговоров КАК ВТНастройкиДоговоров
	|		ПО ВТНастройкиЗакупокПослеДоговоров.ПериодДоговор = ВТНастройкиДоговоров.Период
	|			И ВТНастройкиЗакупокПослеДоговоров.СтруктурноеПодразделение = ВТНастройкиДоговоров.СтруктурноеПодразделение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНастройкиЗакупок КАК ВТНастройкиЗакупок
	|		ПО ВТНастройкиЗакупокПослеДоговоров.ПериодЗакупки = ВТНастройкиЗакупок.Период
	|			И ВТНастройкиЗакупокПослеДоговоров.СтруктурноеПодразделение = ВТНастройкиЗакупок.СтруктурноеПодразделение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТНастройкиЗакупок.Период КАК Период,
	|	ВТНастройкиЗакупок.СтруктурноеПодразделение КАК СтруктурноеПодразделение,
	|	ЛОЖЬ КАК КонтролироватьЗаявкуНаЗатратыПоБюджету,
	|	ЛОЖЬ КАК НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету,
	|	ВТНастройкиЗакупок.ФормироватьДвиженияПоФактуБюджетаЗакупок КАК ФормироватьДвиженияПоФактуБюджетаЗакупок,
	|	ВТНастройкиЗакупок.НастройкиЗакупокУстановлены КАК НастройкиЗакупокУстановлены,
	|	ВТНастройкиЗакупок.ФормироватьЗависимыеОборотыПоФактуБюджетаЗакупок КАК ФормироватьЗависимыеОборотыПоФактуБюджетаЗакупок
	|ПОМЕСТИТЬ ВТИтогНастройкиТолькоЗакупок
	|ИЗ
	|	ВТНастройкиЗакупок КАК ВТНастройкиЗакупок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНастройкиДоговоров КАК ВТНастройкиДоговоров
	|		ПО ВТНастройкиЗакупок.СтруктурноеПодразделение = ВТНастройкиДоговоров.СтруктурноеПодразделение
	|			И ВТНастройкиЗакупок.Период >= ВТНастройкиДоговоров.Период
	|ГДЕ
	|	ВТНастройкиДоговоров.Период ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТИтогНастройкиДоговоровИЗакупок.Период КАК Период,
	|	ВТИтогНастройкиДоговоровИЗакупок.СтруктурноеПодразделение КАК СтруктурноеПодразделение,
	|	ВТИтогНастройкиДоговоровИЗакупок.КонтролироватьЗаявкуНаЗатратыПоБюджету КАК КонтролироватьЗаявкуНаЗатратыПоБюджету,
	|	ВТИтогНастройкиДоговоровИЗакупок.НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету КАК НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету,
