#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ОбработчикиСобытий

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Для каждого Запись Из ЭтотОбъект Цикл
		Если НЕ ЗначениеЗаполнено(Запись.Алгоритм) Тогда
			Возврат;		
		КонецЕсли; 
		
		Результат = Справочники.бит_АлгоритмыПроцессов.АлгоритмГотовКРаботе(Запись.Алгоритм);
		Если НЕ Результат Тогда
			Отказ = Истина; 
		КонецЕсли;
	КонецЦикла; 
	
	ДополнительныеСвойства.Вставить("ПроверкаВыполнена", Истина);
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если Количество() > 0 Тогда
		ОбъектСистемы = Отбор.ОбъектСистемы.Значение;
		ВидАлгоритма  = Отбор.ВидАлгоритма.Значение;
		Если ВидАлгоритма = Перечисления.бит_ВидыАлгоритмов.Визирование
			И ЗначениеЗаполнено(ОбъектСистемы)
			И бит_ОбщегоНазначенияПовтИсп.МеханизмВизированияОтключен(ОбъектСистемы) Тогда
			ТекстСообщения = НСтр("ru = 'Механизм визирования для ""%1"" отключен.';
				|en = 'The sight functions for ""%1"" are disabled.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ОбъектСистемы);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,,Отказ);
		КонецЕсли;
	КонецЕсли;
	
	// Конроль при программной записи набора.
	ПроверкаВыполнена = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства, 
							"ПроверкаВыполнена", Ложь);
	
	Если НЕ ПроверкаВыполнена Тогда
		Если НЕ ПроверитьЗаполнение() Тогда
			Отказ = Истина;		
		КонецЕсли;
	КонецЕсли; 
	
	ДополнительныеСвойства.Вставить("ПроверкаВыполнена", Ложь);
	
	Если Отказ Тогда
		Возврат;	
	КонецЕсли; 
		
КонецПроцедуры

#КонецОбласти

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли