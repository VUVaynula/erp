#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ТекущаяЗапись Из ЭтотОбъект Цикл
		
		Если НЕ ЗначениеЗаполнено(ТекущаяЗапись.ЗначениеПараметра) Тогда			
			ТекущаяЗапись.ЗначениеПараметра = Неопределено;			
		ИначеЕсли НЕ ТекущаяЗапись.Параметр.ТипЗначения = Неопределено Тогда			
			Если НЕ ТекущаяЗапись.Параметр.ТипЗначения.СодержитТип(ТипЗнч(ТекущаяЗапись.ЗначениеПараметра)) Тогда
				ТекущаяЗапись.ЗначениеПараметра = Неопределено;
			КонецЕсли;			
		Иначе
			ТекущаяЗапись.ЗначениеПараметра = Неопределено;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли