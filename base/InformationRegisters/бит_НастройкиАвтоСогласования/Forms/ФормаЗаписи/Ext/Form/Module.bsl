
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТолькоПросроченные = (Запись.Просрочка > 0);
	УправлениеЭлементамиФормы(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если ТолькоПросроченные Тогда
		Если ТекущийОбъект.Просрочка = 0 Тогда
			ТекстСообщения = НСтр("ru='Не указано время просрочки (минимум 1 минута).';
							 	|en='The delay time is not specified (at least 1 minute).'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "Просрочка", "Запись.Просрочка", Отказ);
		КонецЕсли;
	Иначе
		ТекущийОбъект.Просрочка = 0;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТолькоПросроченныеПриИзменении(Элемент)
	
	УправлениеЭлементамиФормы(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеЭлементамиФормы(Форма)
	
	ТолькоПросроченные = Форма.ТолькоПросроченные;
	ЭлементПросрочка   = Форма.Элементы.Просрочка;
	
	ЭлементПросрочка.АвтоОтметкаНезаполненного = ТолькоПросроченные;
	ЭлементПросрочка.Доступность               = ТолькоПросроченные;
	
КонецПроцедуры

#КонецОбласти