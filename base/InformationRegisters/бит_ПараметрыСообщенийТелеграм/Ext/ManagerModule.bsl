#Область ПрограммныйИнтерфейс

// Процедура сохраняет значения параметров сообщения в систему.
//
// Параметры:
//	ПараметрыКлюча - Структура - см. функцию НовыеПараметрыКлюча().
//	ПараметрыСообщения - Структура - структура сохраняемых параметров:
//		* Ключ     - Имя параметра.
//		* Значение - Значение сохраняемого параметра.
//
Процедура СохранитьПараметрыСообщения(ПараметрыКлюча, ПараметрыСообщения) Экспорт
	
	Если ПараметрыСообщения.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	НаборПараметров = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.СоздатьНаборЗаписей();
	НаборПараметров.Отбор.Чат.Установить(ПараметрыКлюча.Чат);
	НаборПараметров.Отбор.СообщениеИД.Установить(ПараметрыКлюча.СообщениеИД);
	Для каждого ПараметрСообщения Из ПараметрыСообщения Цикл
		ЗаписьПараметра                   = НаборПараметров.Добавить();
		ЗаписьПараметра.Чат               = ПараметрыКлюча.Чат;
		ЗаписьПараметра.СообщениеИД       = ПараметрыКлюча.СообщениеИД;
		ЗаписьПараметра.Параметр          = ПараметрСообщения.Ключ;
		ЗаписьПараметра.ЗначениеПараметра = ПараметрСообщения.Значение;
		ЗаписьПараметра.ДатаОтправки      = ТекущаяДатаСеанса();
	КонецЦикла;
	НаборПараметров.Записать();
	
КонецПроцедуры

// Функция возвращает значения параметров сообщения.
//
// Параметры:
//	ПараметрыКлюча - Структура - см. функцию НовыеПараметрыКлюча().
//
// Возвращаемое значение:
//	Структура - Структура параметров сообщения:
//		* Ключ     - Строка - Имя параметра.
//		* Значение - Произвольный - Значение сохраняемого параметра.
//
Функция ПараметрыСообщения(ПараметрыКлюча) Экспорт
	
	ПараметрыСообщения = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	бит_ПараметрыСообщенийТелеграм.Параметр КАК Параметр,
	|	бит_ПараметрыСообщенийТелеграм.ЗначениеПараметра КАК ЗначениеПараметра
	|ИЗ
	|	РегистрСведений.бит_ПараметрыСообщенийТелеграм КАК бит_ПараметрыСообщенийТелеграм
	|ГДЕ
	|	бит_ПараметрыСообщенийТелеграм.Чат = &Чат
	|	И бит_ПараметрыСообщенийТелеграм.СообщениеИД = &СообщениеИД";
	Запрос.УстановитьПараметр("Чат",         ПараметрыКлюча.Чат);
	Запрос.УстановитьПараметр("СообщениеИД", ПараметрыКлюча.СообщениеИД);
	ВыборкаПараметров = Запрос.Выполнить().Выбрать();
	Пока ВыборкаПараметров.Следующий() Цикл
		ПараметрыСообщения.Вставить(ВыборкаПараметров.Параметр, ВыборкаПараметров.ЗначениеПараметра);
	КонецЦикла;
	
	Возврат ПараметрыСообщения;
	
КонецФункции

// Процедура удаляет историю записей регистра бит_ПараметрыСообщенийТелеграм.
// 
// Параметры:
//  РежимСообщений    - Строка.
// 
Процедура УдалитьИсториюЗаписей(РежимСообщений = "Нет") Экспорт
	
	РежимыВывода = бит_ОбщегоНазначения.ОпределитьРежимыВывода(РежимСообщений);		
	
	РезультатЗапроса = УстаревшиеЗаписи();
	
	Если РезультатЗапроса.Пустой() Тогда		
		ТекстСообщения = НСтр("ru='Нет данных для обработки.';en='No data was provided.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли; 
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Ном = 1;
	КоличествоЗаписей = Выборка.Количество();	
	Пока Выборка.Следующий() Цикл
		МенеджерЗаписи = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
		Попытка			
			МенеджерЗаписи.Удалить();			
		Исключение			
			Если РежимыВывода.ВыводитьОшибки Тогда			
				ТекстСообщения = НСтр("ru='Не удалось удалить историю записей регистра ""%1"".';
						  	  		  |en='Failed to delete the history records for ""%1"".'");
				ТекстСообщения = СтрШаблон(ТекстСообщения, Метаданные.РегистрыСведений.бит_ПараметрыСообщенийТелеграм.Представление());
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения + Символы.ПС + ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			КонецЕсли;			
		КонецПопытки; 
		
		Ном = Ном + 1;
	КонецЦикла; 
	
	Если РежимыВывода.ВыводитьИнформацию Тогда		
		ТекстСообщения = НСтр("ru='Удаление истории записей завершено.';
							  |en='Removing history records completed'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		
	КонецЕсли; 	
	
КонецПроцедуры

// Функция формирует структуру параметров обработки записей регистра.
//
// Возвращаемое значение:
//	Структура - параметры обработки записей:
//		* Чат         - СправочникСсылка.бит_ЧатыTelegram;
//		* СообщениеИД - Число.
//
Функция НовыеПараметрыКлюча() Экспорт
	
	ПараметрыКлюча = Новый Структура;
	ПараметрыКлюча.Вставить("Чат", Справочники.бит_ЧатыTelegram.ПустаяСсылка());
	ПараметрыКлюча.Вставить("СообщениеИД", 0);
	
	Возврат ПараметрыКлюча;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция УстаревшиеЗаписи()
	
	АктуальнаяДата = бит_ТелеграмСервер.ГраницаАктуальнойИсторииТелеграм();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПараметрыСообщенийТелеграм.Чат КАК Чат,
	|	ПараметрыСообщенийТелеграм.СообщениеИД КАК СообщениеИД,
	|	ПараметрыСообщенийТелеграм.Параметр КАК Параметр
	|ИЗ
	|	РегистрСведений.бит_ПараметрыСообщенийТелеграм КАК ПараметрыСообщенийТелеграм
	|ГДЕ
	|	ПараметрыСообщенийТелеграм.ДатаОтправки < &ДатаОтправки";
	Запрос.УстановитьПараметр("ДатаОтправки", АктуальнаяДата);
	Возврат Запрос.Выполнить();
	
КонецФункции

#КонецОбласти

#КонецЕсли