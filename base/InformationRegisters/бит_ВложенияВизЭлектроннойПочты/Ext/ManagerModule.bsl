// Функция возвращает вложения печатных форм,
//	которые необходимо вложить к объекту при отправке по почте.
// 
// Параметры:
// 	СсылкаНаОбъект - ДокументСсылка, СправочникСсылка - ссылка на объект для которого определяется состав печатных форм.
// 
// Возвращаемое значение:
// 	Массив.
//
Функция ВложенияЭлектроннойПочты(СсылкаНаОбъект) Экспорт
	
	Вложения = Новый Массив;
	
	ПолноеИмяМетаданных = СсылкаНаОбъект.Метаданные().ПолноеИмя();
	ПараметрыВложений   = бит_ОповещенияПовтИсп.ПараметрыВложенийЭлектроннойПочты(ПолноеИмяМетаданных);
	
	ПараметрыПечати = Новый Структура;
	ПараметрыПечати.Вставить("ДополнитьКомплектВнешнимиПечатнымиФормами", Ложь);	
	
	МассивОбъектов  = Новый Массив;
	МассивОбъектов.Добавить(СсылкаНаОбъект);
	
	Для каждого ПараметрыВложения Из ПараметрыВложений Цикл
		Если НЕ ВыполняютсяУсловияВидимостиПечатнойФормы(СсылкаНаОбъект, ПараметрыВложения) Тогда
			Продолжить;
		КонецЕсли;
		
		Идентификатор = ПараметрыВложения.Идентификатор;
		ПечатныеФормы = КоллекцияПечатныхФорм(МассивОбъектов, ПараметрыВложения);
		Для каждого ПечатнаяФорма Из ПечатныеФормы Цикл
			Поток = Новый ПотокВПамяти;
			ПечатнаяФорма.ТабличныйДокумент.Записать(Поток, ТипФайлаТабличногоДокумента.PDF);
			ДвоичныеДанныеФайла            = Поток.ЗакрытьИПолучитьДвоичныеДанные();
			АдресФайлаВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла, Новый УникальныйИдентификатор);
			
			НовоеОписание = Обработки.бит_ВизированиеСИспользованиемЭлектроннойПочты.ОписаниеВложения();
			НовоеОписание.Представление             = ПараметрыВложения.Представление + ".pdf";
			НовоеОписание.АдресВоВременномХранилище = АдресФайлаВоВременномХранилище;
			
			Вложения.Добавить(НовоеОписание);
		КонецЦикла;
	КонецЦикла;
	
	Возврат Вложения;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция КоллекцияПечатныхФорм(МассивОбъектов, Параметры)
	
	КоллекцияПечатныхФорм = Новый Массив;
	
	Если ЗначениеЗаполнено(Параметры.ВнешняяОбработка) Тогда
		ОбъектыПечати      = Новый СписокЗначений;
		ПараметрыИсточника = Новый Структура;
		ПараметрыИсточника.Вставить("ИдентификаторКоманды", Параметры.Идентификатор);
		ПараметрыИсточника.Вставить("ОбъектыНазначения",    МассивОбъектов);
		
		УправлениеПечатью.ПечатьПоВнешнемуИсточнику(Параметры.ВнешняяОбработка,
														ПараметрыИсточника,
														КоллекцияПечатныхФорм,
														ОбъектыПечати,
														Неопределено);
	Иначе
		ПараметрыПечати = Новый Структура;
		ПараметрыПечати.Вставить("ДополнитьКомплектВнешнимиПечатнымиФормами", Ложь);
		
		ИмяМенеджераПечати = Параметры.МенеджерПечати;
		Если ПустаяСтрока(ИмяМенеджераПечати) Тогда
			ИмяМенеджераПечати = Параметры.ИмяОбъекта;
		КонецЕсли;
		
		ПечатныеФормы = УправлениеПечатью.СформироватьПечатныеФормы(ИмяМенеджераПечати,
																	Параметры.Идентификатор,
																	МассивОбъектов,
																	ПараметрыПечати);
		КоллекцияПечатныхФорм = ПечатныеФормы.КоллекцияПечатныхФорм;
	КонецЕсли;
							
	Возврат КоллекцияПечатныхФорм;
	
КонецФункции

Функция ВыполняютсяУсловияВидимостиПечатнойФормы(СсылкаНаОбъект, ПараметрыПечатнойФормы)
	
	Если НЕ ПараметрыПечатнойФормы.ЕстьУсловияВидимости Тогда
		Возврат Истина;
	КонецЕсли;
	
	ПроверяемыеРекзивиты = Новый Массив;
	Для каждого Условие Из ПараметрыПечатнойФормы.УсловияВидимости Цикл
		ПроверяемыеРекзивиты.Добавить(Условие.Реквизит);
	КонецЦикла;
	бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(ПроверяемыеРекзивиты);
	ИменаРеквизитов    = СтрСоединить(ПроверяемыеРекзивиты, ", ");
	ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаОбъект, ИменаРеквизитов);
	
	Для каждого Условие Из ПараметрыПечатнойФормы.УсловияВидимости Цикл
		ИмяРеквизита = Условие.Реквизит;
		Если НЕ ЗначенияРеквизитов.Свойство(ИмяРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		УсловиеВыполняется = Истина;
		Если Условие.ВидСравнения = ВидСравнения.Равно
			ИЛИ Условие.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно Тогда
			УсловиеВыполняется = ЗначенияРеквизитов[ИмяРеквизита] = Условие.Значение;
		ИначеЕсли Условие.ВидСравнения = ВидСравнения.Больше
			ИЛИ Условие.ВидСравнения = ВидСравненияКомпоновкиДанных.Больше Тогда
			УсловиеВыполняется = ЗначенияРеквизитов[ИмяРеквизита] > Условие.Значение;
		ИначеЕсли Условие.ВидСравнения = ВидСравнения.БольшеИлиРавно
			ИЛИ Условие.ВидСравнения = ВидСравненияКомпоновкиДанных.БольшеИлиРавно Тогда
			УсловиеВыполняется = ЗначенияРеквизитов[ИмяРеквизита] >= Условие.Значение;
		ИначеЕсли Условие.ВидСравнения = ВидСравнения.Меньше
			ИЛИ Условие.ВидСравнения = ВидСравненияКомпоновкиДанных.Меньше Тогда
			УсловиеВыполняется = ЗначенияРеквизитов[ИмяРеквизита] < Условие.Значение;
		ИначеЕсли Условие.ВидСравнения = ВидСравнения.МеньшеИлиРавно
			ИЛИ Условие.ВидСравнения = ВидСравненияКомпоновкиДанных.МеньшеИлиРавно Тогда
			УсловиеВыполняется = ЗначенияРеквизитов[ИмяРеквизита] <= Условие.Значение;
		ИначеЕсли Условие.ВидСравнения = ВидСравнения.НеРавно
			ИЛИ Условие.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно Тогда
			УсловиеВыполняется = ЗначенияРеквизитов[ИмяРеквизита] <> Условие.Значение;
		ИначеЕсли Условие.ВидСравнения = ВидСравнения.ВСписке
			ИЛИ Условие.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке Тогда
			Если ТипЗнч(Условие.Значение) = Тип("СписокЗначений") Тогда
				УсловиеВыполняется = Условие.Значение.НайтиПоЗначению(ЗначенияРеквизитов[ИмяРеквизита]) <> Неопределено;
			Иначе // Массив
				УсловиеВыполняется = Условие.Значение.Найти(ЗначенияРеквизитов[ИмяРеквизита]) <> Неопределено;
			КонецЕсли;
		ИначеЕсли Условие.ВидСравнения = ВидСравнения.НеВСписке
			ИЛИ Условие.ВидСравнения = ВидСравненияКомпоновкиДанных.НеВСписке Тогда
			Если ТипЗнч(Условие.Значение) = Тип("СписокЗначений") Тогда
				УсловиеВыполняется = Условие.Значение.НайтиПоЗначению(ЗначенияРеквизитов[ИмяРеквизита]) = Неопределено;
			Иначе // Массив
				УсловиеВыполняется = Условие.Значение.Найти(ЗначенияРеквизитов[ИмяРеквизита]) = Неопределено;
			КонецЕсли;
		ИначеЕсли Условие.ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено Тогда
			УсловиеВыполняется = ЗначениеЗаполнено(ЗначенияРеквизитов[ИмяРеквизита]);
		ИначеЕсли Условие.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено Тогда
			УсловиеВыполняется = НЕ ЗначениеЗаполнено(ЗначенияРеквизитов[ИмяРеквизита]);
		КонецЕсли;
		Если НЕ УсловиеВыполняется Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#КонецЕсли