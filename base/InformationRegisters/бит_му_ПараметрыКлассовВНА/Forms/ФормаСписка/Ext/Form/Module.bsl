
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	бит_РаботаСДиалогамиСервер.ФормаСпискаРегистраПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект);	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок
 
&НаКлиенте
Процедура СписокПередУдалением(Элемент, Отказ)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;	
	Если ЕстьОбъектыКласса(ТекущиеДанные.Класс, ТекущиеДанные.Организация) Тогда
		
		Если ЗначениеЗаполнено(ТекущиеДанные.Организация) Тогда
			ТекстСообщения = НСтр("ru='Для организации ""%1"" в системе зарегистрированы объекты класса ""%2"". Удаление запрещено.';
								  |en='For the entity ""%1"" in system-class facilities account ""%2"". Removing prohibited.'");
		Иначе
			ТекстСообщения = НСтр("ru='В системе зарегистрированы объекты класса ""%2"". Удаление запрещено.';
							 	  |en='In system-class facilities account ""%2"". Removing prohibited.'");
		КонецЕсли;
		ТекстСообщения = СтрШаблон(ТекстСообщения, ТекущиеДанные.Организация, ТекущиеДанные.Класс);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,,,, Отказ);
		
	 КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Функция определяет есть ли объекты данного класса класса.
// 
// Параметры:
//  ТекущийКласс  	   - СправочникСсылка.бит_КлассыОсновныхСредств.
//  ТекущаяОрганизация - СправочникСсылка.Организации.
// 
// Возвращаемое значение:
//   Булево.
//
&НаСервереБезКонтекста
Функция ЕстьОбъектыКласса(ТекущийКласс, ТекущаяОрганизация)

	Возврат бит_му_ВНА.ЕстьОбъектыКласса(ТекущийКласс, ТекущаяОрганизация);

КонецФункции

#КонецОбласти
