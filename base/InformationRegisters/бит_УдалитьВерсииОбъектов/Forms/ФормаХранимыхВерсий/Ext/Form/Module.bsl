
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Ссылка = Параметры.Ссылка;
	РазрешеноПереходитьНаВерсию = Не Параметры.ЗапрещеноРедактировать;
	
КонецПроцедуры // ПриСозданииНаСервере()

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

//Код процедур и функций

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписокВерсий

&НаКлиенте
Процедура СписокВерсийВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ОткрытьОтчетПоВерсиямОбъекта();
	
КонецПроцедуры // СписокВерсийВыбор()

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОткрытьВерсиюОбъекта(Команда)
	
	ОткрытьОтчетПоВерсиямОбъекта();
	
КонецПроцедуры // ОткрытьВерсиюОбъекта()

&НаКлиенте
Процедура ПерейтиНаВерсию(Команда)
	
	ТекущиеДанные = Элементы.СписокВерсий.ТекущиеДанные;
	Если Элементы.СписокВерсий.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
КонецПроцедуры // ПерейтиНаВерсию()

&НаКлиенте
Процедура СформироватьОтчетПоИзменениям(Команда)
	
	ВыделенныеСтроки = Элементы.СписокВерсий.ВыделенныеСтроки;
	
	СравниваемыеВерсии = СформироватьМассивВыбранныхВерсий(ВыделенныеСтроки);
	
	Если СравниваемыеВерсии.Количество() < 2 Тогда
		Предупреждение(НСтр("ru='Для формирования отчета по изменениям, необходимо выбрать, как минимум, две версии.';
						    |en='To generate a report on changes at least two versions must be selected'"));
	Иначе
		ОткрытьФормуОтчета(СравниваемыеВерсии);
	КонецЕсли;
	
КонецПроцедуры // СформироватьОтчетПоИзменениям()

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура - открывает форму отчета по изменениям, с требуемыми параметрами.
//
// Параметры:
//  СравниваемыеВерсии - Массив.
//
&НаКлиенте
Процедура ОткрытьФормуОтчета(СравниваемыеВерсии)
	
	ПараметрыОтчета = Новый Структура;
	ПараметрыОтчета.Вставить("Ссылка"			 , Ссылка);
	ПараметрыОтчета.Вставить("СравниваемыеВерсии", СравниваемыеВерсии);
	
	ОткрытьФорму("РегистрСведений.бит_УдалитьВерсииОбъектов.Форма.ОтчетПоВерсиямОбъекта",
					ПараметрыОтчета,
					ЭтотОбъект,
					УникальныйИдентификатор);
					
КонецПроцедуры // ОткрытьФормуОтчета()
				
// Процедура - проверяет, что в списке версий выбрана версия и вызывает форму
// отчета с переданным параметром - номером выбранной версии.
//
&НаКлиенте
Процедура ОткрытьОтчетПоВерсиямОбъекта()
	
	ТекущиеДанные = Элементы.СписокВерсий.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	СравниваемыеВерсии = Новый Массив;
	СравниваемыеВерсии.Добавить(ТекущиеДанные.НомерВерсии);
	
	ОткрытьФормуОтчета(СравниваемыеВерсии);
	
КонецПроцедуры // ОткрытьОтчетПоВерсиямОбъекта()

// Функция - возвращает массив номеров выбранных версий.
//
// Параметры:
//  ВыделенныеСтроки.
//
// Возвращаемое значение:
//  Массив.
//
&НаКлиенте
Функция СформироватьМассивВыбранныхВерсий(ВыделенныеСтроки)
	
	СравниваемыеВерсии = Новый Массив;
	
	Если ВыделенныеСтроки.Количество() > 0 Тогда
		
		Для Каждого НомерВыделеннойСтроки Из ВыделенныеСтроки Цикл
			СтрокаВерсии = Элементы.СписокВерсий.ДанныеСтроки(НомерВыделеннойСтроки);
			СравниваемыеВерсии.Добавить(СтрокаВерсии.НомерВерсии);
		КонецЦикла;
				
	КонецЕсли;

	Возврат СравниваемыеВерсии;
	
КонецФункции // СформироватьМассивВыбранныхВерсий()

// Функция - возвращает список номеров версий объекта переданного по ссылке.
//
// Параметры:
// Ссылка - СправочникСсылка, ДокументСсылка - ссылка на объект.
//
&НаСервереБезКонтекста
Функция СформироватьТаблицуВерсий(Ссылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	НомерВерсии КАК НомерВерсии,
	|	АвторВерсии КАК АвторВерсии,
	|	ДатаВерсии  КАК ДатаВерсии,
	|	Комментарий КАК Комментарий,
	|	Ложь 		КАК ЭтоТекущаяВерсия
	| ИЗ
	|	РегистрСведений.бит_УдалитьВерсииОбъектов
	|ГДЕ
	|	Объект = &Ссылка
	|УПОРЯДОЧИТЬ ПО 
	| 	НомерВерсии Убыв
	|";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	
	ТаблицаВерсий = РезультатЗапроса.Выгрузить();
	Если ТаблицаВерсий.Количество() > 0 Тогда
		ТаблицаВерсий[0].ЭтоТекущаяВерсия = Истина;
	КонецЕсли;
	
	Возврат ТаблицаВерсий;
	
КонецФункции // СформироватьТаблицуВерсий()

&НаСервере
Функция ПолучитьИнформациюПоВерсии(Знач Ссылка, Знач НомерВерсии)
	
	СтруктураВерсии = Новый Структура("ВерсияОбъекта, АвторВерсии, ДатаВерсии");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("НомерВерсии", Число(НомерВерсии));
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ВерсияОбъекта КАК ВерсияОбъекта,
	|	АвторВерсии   КАК АвторВерсии,
	|	ДатаВерсии    КАК ДатаВерсии
	|ИЗ
	|	РегистрСведений.бит_УдалитьВерсииОбъектов
	|ГДЕ
	|	Объект = &Ссылка
	|	И НомерВерсии = &НомерВерсии
	|";
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
	
		Выборка = РезультатЗапроса.Выбрать();	
	    Выборка.Следующий();
		СтруктураВерсии.Вставить("ВерсияОбъекта", Выборка.ВерсияОбъекта.Получить());
		СтруктураВерсии.Вставить("АвторВерсии"  , Выборка.АвторВерсии);
		СтруктураВерсии.Вставить("ДатаВерсии"   , Выборка.ДатаВерсии);
		
	КонецЕсли;	

	Возврат СтруктураВерсии;
		
КонецФункции

&НаСервере
Функция ВосстановитьВерсиюОбъекта(знач АдресВоВременномХранилище = "", ТекстСообщенияОбОшибке = "")
	
	Объект = Неопределено;
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеОбъекта = ПолучитьИзВременногоХранилища(АдресВоВременномХранилище);
	
	Если ТипЗнч(ДанныеОбъекта) = Тип("ДвоичныеДанные") Тогда
		
		ЧтениеFastInfoSet = Новый ЧтениеFastInfoSet;
		ЧтениеFastInfoSet.УстановитьДвоичныеДанные(ДанныеОбъекта);
		
		Попытка
			Объект = ПрочитатьXML(ЧтениеFastInfoSet);
			// Объект.Проведен = Ложь;
		Исключение
			ТекстСообщенияОбОшибке = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки;
		
	ИначеЕсли ТипЗнч(ДанныеОбъекта) = Тип("Структура") Тогда
		
		Попытка
			СсылкаНаДокумент = ДанныеОбъекта.Ссылка;
			Если ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.бит_Проформы") Тогда
				Объект = Документы.бит_Проформы.ПолучитьОбъектПоСтруктуреДанных(ДанныеОбъекта);
			КонецЕсли;
		Исключение
			ТекстСообщенияОбОшибке = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки;
		
	КонецЕсли;
	
	Возврат Объект;
	
КонецФункции

#КонецОбласти
