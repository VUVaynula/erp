// Функция регистрирует состояние мдм.
// 
// Параметры:
//  Объект 				 - СправочникСсылка.бит_мдм_ОбъектОбмена, СправочникСсылка.бит_мдм_ОбъектОбменаИерархияДанных
//  ВходящееСостояние    - Строка, ПеречислениеСсылка.бит_мдм_СостоянияОбъектов
//  ВходящийПользователь - СправочникСсылка.Пользователи
//  Комментарий 		 - Строка.
// 
// Возвращаемое значение:
//  Булево.
// 
Функция Зарегистрировать(Объект, ВходящееСостояние, ВходящийПользователь = Неопределено) Экспорт

	РезультатВыполнено = Ложь;
	
	Если НЕ ЗначениеЗаполнено(ВходящийПользователь) Тогда		
		ТекПользователь = Пользователи.ТекущийПользователь();		
	Иначе		
		ТекПользователь = ВходящийПользователь;		
	КонецЕсли; 
	
	Если ТипЗнч(ВходящееСостояние) = Тип("Строка") Тогда		
		ТекСостояние = Перечисления.бит_мдм_СостоянияОбъектов[ВходящееСостояние];		
	Иначе		
		ТекСостояние = ВходящееСостояние;		
	КонецЕсли; 
	
	Менеджер = РегистрыСведений.бит_мдм_СостоянияОбъектов.СоздатьМенеджерЗаписи();
	Менеджер.ПериодИзменения = ТекущаяДата();
	Менеджер.Объект          = Объект;
	Менеджер.Пользователь    = ТекПользователь;
	Менеджер.Состояние       = ТекСостояние;
	
	Попытка
		
		Менеджер.Записать();
		РезультатВыполнено = Истина;
		
	Исключение
		
		ТекстСообщения = НСтр("ru='Не удалось зарегистрировать состояние %1 для объекта %2. Описание ошибки: %3'; 
							  |en='Failed to register state %1 for the object %2. Error description: %3'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ТекСостояние, Объект, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации("МДМ.РегистрацияСостояния",
								 УровеньЖурналаРегистрации.Ошибка, 
								 Метаданные.РегистрыСведений.бит_мдм_СобытияОбъектов, 
								 ТекстСообщения);
		
	КонецПопытки;

	Возврат РезультатВыполнено;
	
КонецФункции // Зарегистрировать()

// Функция получает состояние объекта обмена.
// 
// Параметры:
//  ОбъектОбмена - СправочникСсылка.бит_мдм_ОбъектыОбмена, СправочникСсылка.бит_мдм_ОбъектыОбменаИерархияЭлементов.
// 
// Возвращаемое значение:
//  РегистрСведений.бит_мдм_СостоянияОбъектов.
// 
Функция СостояниеОбъекта(ОбъектОбмена) Экспорт

	Состояние = Перечисления.бит_мдм_СостоянияОбъектов.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Объект", ОбъектОбмена);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бит_мдм_СостоянияОбъектов.Состояние
	|ИЗ
	|	РегистрСведений.бит_мдм_СостоянияОбъектов КАК бит_мдм_СостоянияОбъектов
	|ГДЕ
	|	бит_мдм_СостоянияОбъектов.Объект = &Объект";	
				   
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда	
		Состояние = Выборка.Состояние;	
	КонецЕсли; 

	Возврат Состояние;
	
КонецФункции // СостояниеОбъекта()

#КонецОбласти

#КонецЕсли
