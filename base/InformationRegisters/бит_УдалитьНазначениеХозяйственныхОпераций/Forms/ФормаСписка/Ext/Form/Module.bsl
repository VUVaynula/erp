
#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаЗаполнитьПоУмолчанию(Команда)
	
	ТекстСообщения =  НСтр("ru='Назначить хозяйственные операции по-умолчанию?';en='Assign chores default operations?'");
	Ответ = Неопределено;

	ПоказатьВопрос(Новый ОписаниеОповещения("КомандаЗаполнитьПоУмолчаниюЗавершение", ЭтотОбъект), 
		ТекстСообщения, РежимДиалогаВопрос.ДаНет, 15, КодВозвратаДиалога.Нет); 
	
КонецПроцедуры
	
// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура КомандаЗаполнитьПоУмолчаниюЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
		
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда	
		ЗаполнитьПоУмолчанию();
		Элементы.Список.Обновить();	
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура назначает хозяйственые операции по-умолчанию. 
