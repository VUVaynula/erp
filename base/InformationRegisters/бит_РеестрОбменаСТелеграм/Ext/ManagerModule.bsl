
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Процедура удаляет историю записей регистра бит_РеестрОбменаСТелеграм.
// 
// Параметры:
//  РежимСообщений    - Строка.
// 
Процедура УдалитьИсториюЗаписей(РежимСообщений = "Нет") Экспорт
	
	РежимыВывода = бит_ОбщегоНазначения.ОпределитьРежимыВывода(РежимСообщений);		
	
	РезультатЗапроса = УстаревшиеЗаписи();
	
	Если РезультатЗапроса.Пустой() Тогда		
		ТекстСообщения = НСтр("ru='Нет данных для обработки.';en='No data was provided.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли; 
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Ном = 1;
	КоличествоЗаписей = Выборка.Количество();	
	Пока Выборка.Следующий() Цикл
		МенеджерЗаписи = РегистрыСведений.бит_РеестрОбменаСТелеграм.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
		Попытка			
			МенеджерЗаписи.Удалить();			
		Исключение			
			Если РежимыВывода.ВыводитьОшибки Тогда
				ТекстСообщения = НСтр("ru = 'Не удалось удалить историю записей регистра %1.';
									  |en = 'Failed to delete the history records for %1.'");
				ТекстСообщения = СтрШаблон(ТекстСообщения, Метаданные.РегистрыСведений.бит_РеестрОбменаСТелеграм.Представление());
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения + Символы.ПС + ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			КонецЕсли;			
		КонецПопытки; 
		
		Ном = Ном + 1;
	КонецЦикла; 
	
	Если РежимыВывода.ВыводитьИнформацию Тогда		
		ТекстСообщения = НСтр("ru='Удаление истории записей завершено.';
							  |en='Removing history records completed'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		
	КонецЕсли; 	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция УстаревшиеЗаписи()
	
	АктуальнаяДата = бит_ТелеграмСервер.ГраницаАктуальнойИсторииТелеграм();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РеестрОбменаСТелеграм.Чат КАК Чат,
	|	РеестрОбменаСТелеграм.СообщениеИД КАК СообщениеИД,
	|	РеестрОбменаСТелеграм.ВидЗапросаТелеграм КАК ВидЗапросаТелеграм
	|ИЗ
	|	РегистрСведений.бит_РеестрОбменаСТелеграм КАК РеестрОбменаСТелеграм
	|ГДЕ
	|	РеестрОбменаСТелеграм.ДатаОтправки < &ДатаОтправки";
	Запрос.УстановитьПараметр("ДатаОтправки", АктуальнаяДата);
	Возврат Запрос.Выполнить();
	
КонецФункции

#КонецОбласти

#КонецЕсли