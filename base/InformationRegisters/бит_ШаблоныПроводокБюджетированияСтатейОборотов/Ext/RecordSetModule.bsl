
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ОбработчикиСобытий

Процедура ПриЗаписи(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;	
	КонецЕсли;
	
	ОбъектСШаблонами = Неопределено;
	Для каждого ЭлементОтбора Из Отбор Цикл
		Если ЭлементОтбора.Имя = "ОбъектСШаблонами" Тогда
			ОбъектСШаблонами = ЭлементОтбора.Значение;
		КонецЕсли;
	КонецЦикла;
	
	ОтметитьКоличество(ОбъектСШаблонами);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОтметитьКоличество(ОбъектСШаблонами)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ОбъектСШаблонами", ОбъектСШаблонами);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтатьиОборотов.Ссылка КАК ОбъектСШаблонами,
	|	ЕСТЬNULL(НаборЗаписей.Назначено, ЛОЖЬ) КАК Назначено,
	|	СУММА(ВЫБОР
	|			КОГДА НаборЗаписей.ОбъектСШаблонами ЕСТЬ NULL
	|				ТОГДА 0
	|			ИНАЧЕ 1
	|		КОНЕЦ) КАК Количество
	|ИЗ
	|	Справочник.бит_СтатьиОборотов КАК СтатьиОборотов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_ШаблоныПроводокБюджетированияСтатейОборотов КАК НаборЗаписей
	|		ПО СтатьиОборотов.Ссылка = НаборЗаписей.ОбъектСШаблонами
	|ГДЕ
	|	СтатьиОборотов.Ссылка = &ОбъектСШаблонами
	|
	|СГРУППИРОВАТЬ ПО
	|	СтатьиОборотов.Ссылка,
	|	ЕСТЬNULL(НаборЗаписей.Назначено, ЛОЖЬ)";		
	
	
	НаличиеШаблонов = РегистрыСведений.бит_НаличиеШаблоновПроводокБюджетирования.СоздатьНаборЗаписей();
	РезультатЗапроса   = Запрос.Выполнить();	
	Выборка			   = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НаличиеШаблонов.Отбор.ОбъектСШаблонами.Установить(Выборка.ОбъектСШаблонами);
		Если Выборка.Количество > 0 Тогда
			ЗаполнитьЗначенияСвойств(НаличиеШаблонов.Добавить(), Выборка);
		КонецЕсли;
	КонецЦикла;
	
	НаличиеШаблонов.Записать();
	
КонецПроцедуры

#КонецОбласти

#Иначе
	ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'; en = 'Invalid call of the object on the client.'");
#КонецЕсли