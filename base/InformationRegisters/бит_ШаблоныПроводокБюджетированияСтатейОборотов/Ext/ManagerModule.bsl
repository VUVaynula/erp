#Область СлужебныйПрограммныйИнтерфейс

Процедура ЗаполнитьПоДаннымСтатейОборотовПриПереходеНаНовуюВерсию() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЕстьНазначенныеШаблоны.ОбъектСШаблонами КАК ОбъектСШаблонами,
	|	ЕстьНазначенныеШаблоны.Количество КАК Количество,
	|	ЕстьНазначенныеШаблоны.Назначено КАК Назначено
	|ИЗ
	|	РегистрСведений.бит_НаличиеШаблоновПроводокБюджетирования КАК ЕстьНазначенныеШаблоны";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	УдалитьШаблоныПроводок.Ссылка.Родитель КАК Родитель,
	|	УдалитьШаблоныПроводок.Ссылка КАК Ссылка,
	|	ШаблоныПроводок.Ссылка КАК ШаблонПроводки
	|ИЗ
	|	Справочник.бит_СтатьиОборотов.УдалитьШаблоныПроводок КАК УдалитьШаблоныПроводок
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_ШаблоныПроводокБюджетирования КАК ШаблоныПроводок
	|		ПО УдалитьШаблоныПроводок.СчетДТ = ШаблоныПроводок.СчетДТ
	|			И УдалитьШаблоныПроводок.СчетКТ = ШаблоныПроводок.СчетКТ
	|			И УдалитьШаблоныПроводок.Содержание = ШаблоныПроводок.Содержание
	|			И УдалитьШаблоныПроводок.КоэффициентСумма = ШаблоныПроводок.КоэффициентСумма
	|			И УдалитьШаблоныПроводок.КоэффициентКоличество = ШаблоныПроводок.КоэффициентКоличество
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка";
	
	РезультатЗапроса = Запрос.Выполнить();
	СтатьиОборотов = РезультатЗапроса.Выгрузить();
	СтатьиОборотов.Колонки.Добавить("КонтрольнаяСумма", ОбщегоНазначения.ОписаниеТипаСтрока("32"));
		
	Ссылка 			 = Неопределено;
	Состав 			 = Новый Массив;
	КонтрольныеСуммы = Новый Массив;
	
	Для каждого СтрокаТаблицы Из СтатьиОборотов Цикл
		Если СтрокаТаблицы.Ссылка <> Ссылка Тогда
			Если ЗначениеЗаполнено(Состав) Тогда
				КонтрольнаяСумма = ОбщегоНазначения.КонтрольнаяСуммаСтрокой(Состав);	
				Для каждого Элемент Из КонтрольныеСуммы Цикл
					Элемент.КонтрольнаяСумма = КонтрольнаяСумма;
				КонецЦикла;
			КонецЕсли;	
			Ссылка = СтрокаТаблицы.Ссылка;
			Состав = Новый Массив;
			КонтрольныеСуммы = Новый Массив;
		КонецЕсли;
		КонтрольныеСуммы.Добавить(СтрокаТаблицы);
		Состав.Добавить(СтрокаТаблицы.ШаблонПроводки);
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Состав) Тогда
		КонтрольнаяСумма = ОбщегоНазначения.КонтрольнаяСуммаСтрокой(Состав);	
		Для каждого Элемент Из КонтрольныеСуммы Цикл
			Элемент.КонтрольнаяСумма = КонтрольнаяСумма;
		КонецЦикла;
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СтатьиОборотов", СтатьиОборотов);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтатьиОборотов.Родитель КАК Группа,
	|	СтатьиОборотов.Ссылка КАК Ссылка,
	|	СтатьиОборотов.ШаблонПроводки КАК ШаблонПроводки,
	|	СтатьиОборотов.КонтрольнаяСумма КАК КонтрольнаяСумма
	|ПОМЕСТИТЬ КонтрольныеСуммы
	|ИЗ
	|	&СтатьиОборотов КАК СтатьиОборотов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонтрольныеСуммы.Группа КАК Группа,
	|	КонтрольныеСуммы.КонтрольнаяСумма КАК КонтрольнаяСумма,
	|	КонтрольныеСуммы.Ссылка КАК Ссылка,
	|	КонтрольныеСуммы.ШаблонПроводки КАК ШаблонПроводки,
	|	1 КАК Количество
	|ИЗ
	|	КонтрольныеСуммы КАК КонтрольныеСуммы
	|
	|УПОРЯДОЧИТЬ ПО
	|	Группа,
	|	Количество
	|ИТОГИ
	|	СУММА(Количество)
	|ПО
	|	Группа,
	|	КонтрольнаяСумма,
	|	Ссылка";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
	РезультатЗапроса.Строки.Сортировать("Группа возр, Количество убыв", Истина);
	
	Для каждого ВыборкаРодитель Из РезультатЗапроса.Строки Цикл
		ГруппыУжеНазначены = Ложь;
		Для каждого ВыборкаКонтрольнаяСумма Из ВыборкаРодитель.Строки Цикл
			Если ВыборкаКонтрольнаяСумма.Количество > 1 И НЕ ГруппыУжеНазначены Тогда
				НазначитьШаблоныПроводок(ВыборкаКонтрольнаяСумма.Группа, ВыборкаКонтрольнаяСумма.Строки[0].Строки, Истина);
				ГруппыУжеНазначены = Истина;
				Для каждого ВыборкаСсылка Из ВыборкаКонтрольнаяСумма.Строки Цикл
					НазначитьШаблоныПроводок(ВыборкаСсылка.Ссылка, ВыборкаСсылка.Строки, Ложь);
				КонецЦикла;
			Иначе	
				Для каждого ВыборкаСсылка Из ВыборкаКонтрольнаяСумма.Строки Цикл
					НазначитьШаблоныПроводок(ВыборкаСсылка.Ссылка, ВыборкаСсылка.Строки, Истина);
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура НазначитьШаблоныПроводок(СтатьяОборотов, ШаблоныПроводок, Назначено)

	НачатьТранзакцию();
	Попытка
		НаборЗаписей = РегистрыСведений.бит_ШаблоныПроводокБюджетированияСтатейОборотов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ОбъектСШаблонами.Установить(СтатьяОборотов);
		
		Для каждого СтрокаТаблицы Из ШаблоныПроводок Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ШаблонПроводки) Тогда
				Продолжить;	
			КонецЕсли;
			Запись = НаборЗаписей.Добавить();
			Запись.ОбъектСШаблонами = СтатьяОборотов;
			Запись.ШаблонПроводки	= СтрокаТаблицы.ШаблонПроводки;
			Запись.Назначено 	  	= Назначено;
		КонецЦикла;
		КоличествоСтрок = НаборЗаписей.Количество();
		ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей,, Истина);
		
		НаборЗаписей = РегистрыСведений.бит_НаличиеШаблоновПроводокБюджетирования.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ОбъектСШаблонами.Установить(СтатьяОборотов);
		Запись = НаборЗаписей.Добавить();
		Запись.ОбъектСШаблонами = СтатьяОборотов;
		Запись.Количество 	  	= КоличествоСтрок;
		Запись.Назначено 	  	= Назначено;
		ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей,, Истина);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		бит_ОбновлениеИнформационнойБазыБФ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), 
			СтатьяОборотов, "ЗаполнитьПоДаннымСтатейОборотовПриПереходеНаНовуюВерсию");
	КонецПопытки;
			
КонецПроцедуры

#КонецОбласти

#КонецЕсли