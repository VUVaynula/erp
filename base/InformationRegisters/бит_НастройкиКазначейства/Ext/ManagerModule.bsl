// Процедура устанавливает значения регистра по умолчанию
//
// Параметры:
//   Запись           - РегистрСведенийЗапись - запись регистра
//   ДанныеЗаполнения - Структура - где ключ - имя ресурса
//
Процедура УстановкаНастроекПоУмолчанию(Запись, ДанныеЗаполнения) Экспорт
	
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"Период",
		ТекущаяДатаСеанса());
	
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"СтруктурноеПодразделение",
		Неопределено);
	
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"СценарийКонтроляПоБюджету",
		Справочники.СценарииПланирования.ПустаяСсылка());
		
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"КонтролироватьОстаткиПоПрогнозуПлатежа",
		Перечисления.бит_ВидыКонтроля.НеКонтролировать);
	
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"ДопустимыйПроцентПревышенияСуммыПрогнозаПлатежа",
		0);

	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"КонтролироватьОстаткиПоПрогнозуПоступления",
		Перечисления.бит_ВидыКонтроля.НеКонтролировать);
			
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"ДопустимыйПроцентПревышенияСуммыПрогнозаПоступления",
		0);
	
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"КонтролироватьЗаявкуПоБюджету",
		Ложь);
		
	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"НеУчитыватьСверхБюджетныеЗаявкиПриКонтролеПоБюджету",
		Ложь);

	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"КонтролироватьКрайнююДатуПлатежа",
		Перечисления.бит_ВидыКонтроляДатыПлатежа.Предупреждать);

	бит_НастройкиПрограммы.УстановитьЗначениеПоУмолчанию(
		Запись,
		ДанныеЗаполнения,
		"ЗапретитьПлатежиБезЗаявки",
		Ложь);
			
КонецПроцедуры

#КонецОбласти
#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область ОбновлениеИБ

Процедура ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию(Параметры)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Настройки.Период КАК Период,
	|	Настройки.СтруктурноеПодразделение КАК СтруктурноеПодразделение
	|ИЗ
	|	РегистрСведений.бит_НастройкиКазначейства КАК Настройки
	|ГДЕ
	|	(Настройки.КонтролироватьОстаткиПоПрогнозуПлатежа = ЗНАЧЕНИЕ(Перечисление.бит_ВидыКонтроля.ПустаяСсылка)
	|			ИЛИ Настройки.КонтролироватьОстаткиПоПрогнозуПоступления = ЗНАЧЕНИЕ(Перечисление.бит_ВидыКонтроля.ПустаяСсылка))";
	
	ТаблицаИзмерений = Запрос.Выполнить().Выгрузить();
	
	ДополнительныеПараметры = ОбновлениеИнформационнойБазы.ДополнительныеПараметрыОтметкиОбработки();
	ДополнительныеПараметры.ПолноеИмяРегистра = "РегистрСведений.бит_НастройкиКазначейства";
	ДополнительныеПараметры.ЭтоНезависимыйРегистрСведений = Истина;
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, ТаблицаИзмерений, ДополнительныеПараметры);
		
КонецПроцедуры

Процедура ОбработатьДанныеДляПереходаНаНовуюВерсию(Параметры)  Экспорт
		
	ПолноеИмяРегистра  = "РегистрСведений.бит_НастройкиКазначейства"; 
	МетаданныеРегистра = Метаданные.РегистрыСведений.бит_НастройкиКазначейства;
	
	ДополнительныеПараметры = ОбновлениеИнформационнойБазы.ДополнительныеПараметрыОтметкиОбработки();
	ДополнительныеПараметры.ПолноеИмяРегистра             = ПолноеИмяРегистра;
	ДополнительныеПараметры.ЭтоНезависимыйРегистрСведений = Истина;
	
	Выборка		 = ОбновлениеИнформационнойБазы.ВыбратьИзмеренияНезависимогоРегистраСведенийДляОбработки(Параметры.Очередь, ПолноеИмяРегистра);
	ИмяПроцедуры = "РегистрыСведений.бит_НастройкиКазначейства.ОбработатьДанныеДляПереходаНаНовуюВерсию";
	
	Пока Выборка.Следующий() Цикл
		
		ПредставлениеОрганизации = Строка(Выборка.СтруктурноеПодразделение);
		
		НачатьТранзакцию();
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.бит_НастройкиКазначейства");
			ЭлементБлокировки.УстановитьЗначение("СтруктурноеПодразделение", Выборка.СтруктурноеПодразделение);
			ЭлементБлокировки.УстановитьЗначение("Период", 					 Выборка.Период);
			Блокировка.Заблокировать();

			НаборЗаписей = РегистрыСведений.бит_НастройкиКазначейства.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.СтруктурноеПодразделение.Установить(Выборка.СтруктурноеПодразделение);
			НаборЗаписей.Отбор.Период.Установить(Выборка.Период); 
			НаборЗаписей.Прочитать();
						
			Если НаборЗаписей.Количество() = 0 Тогда
				НоваяСтрока = НаборЗаписей.Добавить();
				НоваяСтрока.СтруктурноеПодразделение = Выборка.СтруктурноеПодразделение;
				НоваяСтрока.Период        			 = Выборка.Период;
				
				ДанныеЗаполнения = Новый Структура("СтруктурноеПодразделение, Период",
									Выборка.СтруктурноеПодразделение, Выборка.Период);
									
				УстановкаНастроекПоУмолчанию(НоваяСтрока, ДанныеЗаполнения);
			Иначе
				Для каждого Запись Из НаборЗаписей Цикл
					Если НЕ ЗначениеЗаполнено(Запись.КонтролироватьОстаткиПоПрогнозуПлатежа) Тогда
						Если Запись.УдалитьКонтролироватьОстаткиПоПрогнозуПлатежа Тогда
							Запись.КонтролироватьОстаткиПоПрогнозуПлатежа = Перечисления.бит_ВидыКонтроля.Контролировать;
						Иначе	
							Запись.КонтролироватьОстаткиПоПрогнозуПлатежа = Перечисления.бит_ВидыКонтроля.НеКонтролировать;
						КонецЕсли;
					КонецЕсли; 
					Если НЕ ЗначениеЗаполнено(Запись.КонтролироватьОстаткиПоПрогнозуПоступления) Тогда
						Если Запись.УдалитьКонтролироватьОстаткиПоПрогнозуПоступления Тогда
							Запись.КонтролироватьОстаткиПоПрогнозуПоступления = Перечисления.бит_ВидыКонтроля.Контролировать;
						Иначе	
							Запись.КонтролироватьОстаткиПоПрогнозуПоступления = Перечисления.бит_ВидыКонтроля.НеКонтролировать;
						КонецЕсли;
					КонецЕсли; 
				КонецЦикла;
			КонецЕсли;
			
			Если НаборЗаписей.Модифицированность() Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
			Иначе
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(НаборЗаписей, ДополнительныеПараметры);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();    
			
		Исключение
			
			ОтменитьТранзакцию();                         
			ТекстСообщения = НСтр("ru = 'В процедуре %1 не удалось обработать объект настройки ""%2"" по причине:
								|%3'"); 			
				
			Если НЕ ЗначениеЗаполнено(ПредставлениеОрганизации) Тогда
				ПредставлениеОрганизации = НСтр("ru = 'Для всего предприятия'; en = 'For the whole enterprise'");  
				
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, ИмяПроцедуры, 
					ПредставлениеОрганизации, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));   
				ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(), 
					УровеньЖурналаРегистрации.Предупреждение, , , ТекстСообщения);  
			Иначе
				
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, ИмяПроцедуры, 
					ПредставлениеОрганизации, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));   
				ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(), 
					УровеньЖурналаРегистрации.Предупреждение, Выборка.СтруктурноеПодразделение.Метаданные(), 
					Выборка.СтруктурноеПодразделение, ТекстСообщения);  

			КонецЕсли;
		КонецПопытки;
	КонецЦикла;
	
	Параметры.ОбработкаЗавершена = НЕ ОбновлениеИнформационнойБазы.ЕстьДанныеДляОбработки(Параметры.Очередь, ПолноеИмяРегистра);
	
КонецПроцедуры

#КонецОбласти 

#КонецОбласти 

#КонецЕсли