#Область СлужебныйПрограммныйИнтерфейс

Функция ПараметрыПолученияДанныхНастройки() Экспорт
	
	ПараметрыПолучения = Новый Структура();
	
	РегистрМетаданные = СоздатьНаборЗаписей().Метаданные();
	
	Для Каждого Измерение Из РегистрМетаданные.Измерения Цикл
		Если НЕ Измерение.Имя = "ПорядокПрименения" Тогда
			ПараметрыПолучения.Вставить(Измерение.Имя);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПараметрыПолучения;
	
КонецФункции

Функция КоличествоНастроекКорренспонденции(ПараметрыПолученияДанных) Экспорт
	
	КоличествоНастроек = 0;
	
	Если Не ЗначениеЗаполнено(ПараметрыПолученияДанных.ПланСчетов) 
		Или Не ЗначениеЗаполнено(ПараметрыПолученияДанных.НастройкаФормированияПроводок)
		Или Не ЗначениеЗаполнено(ПараметрыПолученияДанных.ОбъектУчетаДт) 
		Или Не ЗначениеЗаполнено(ПараметрыПолученияДанных.ОбъектУчетаКт) Тогда
		Возврат КоличествоНастроек;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(1) КАК Количество
	|ИЗ
	|	РегистрСведений.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете КАК НастройкиОтражения
	|ГДЕ
	|	НастройкиОтражения.ПланСчетов = &ПланСчетов
	|	И НастройкиОтражения.НастройкаФормированияПроводок = &НастройкаФормированияПроводок
	|	И НастройкиОтражения.ОбъектУчетаДт = &ОбъектУчетаДт
	|	И НастройкиОтражения.ОбъектУчетаКт = &ОбъектУчетаКт
	|	И НастройкиОтражения.ДолгосрочныйДт = &ДолгосрочныйДт
	|	И НастройкиОтражения.ДолгосрочныйКт = &ДолгосрочныйКт
	|";
	Запрос.УстановитьПараметр("ПланСчетов", ПараметрыПолученияДанных.ПланСчетов);
	Запрос.УстановитьПараметр("НастройкаФормированияПроводок", ПараметрыПолученияДанных.НастройкаФормированияПроводок);
	Запрос.УстановитьПараметр("ОбъектУчетаДт", ПараметрыПолученияДанных.ОбъектУчетаДт);
	Запрос.УстановитьПараметр("ОбъектУчетаКт", ПараметрыПолученияДанных.ОбъектУчетаКт);
	Запрос.УстановитьПараметр("ДолгосрочныйДт", ПараметрыПолученияДанных.ДолгосрочныйДт);
	Запрос.УстановитьПараметр("ДолгосрочныйКт", ПараметрыПолученияДанных.ДолгосрочныйКт);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		КоличествоНастроек = Выборка.Количество;
	КонецЕсли;
	
	Возврат КоличествоНастроек;
	
КонецФункции

Функция ПорядокПримененияНастройки(ПараметрыПолученияДанных) Экспорт
	
	ПорядокПрименения = 0;
	
	Если Не ЗначениеЗаполнено(ПараметрыПолученияДанных.ПланСчетов) 
		Или Не ЗначениеЗаполнено(ПараметрыПолученияДанных.НастройкаФормированияПроводок)
		Или Не ЗначениеЗаполнено(ПараметрыПолученияДанных.ОбъектУчетаДт) 
		Или Не ЗначениеЗаполнено(ПараметрыПолученияДанных.ОбъектУчетаКт) Тогда
		Возврат ПорядокПрименения;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НастройкиОтражения.ПорядокПрименения КАК ПорядокПрименения
	|ИЗ
	|	РегистрСведений.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете КАК НастройкиОтражения
	|ГДЕ
	|	НастройкиОтражения.ПланСчетов = &ПланСчетов
	|	И НастройкиОтражения.НастройкаФормированияПроводок = &НастройкаФормированияПроводок
	|	И НастройкиОтражения.ОбъектУчетаДт = &ОбъектУчетаДт
	|	И НастройкиОтражения.ОбъектУчетаКт = &ОбъектУчетаКт
	|	И НастройкиОтражения.ДолгосрочныйДт = &ДолгосрочныйДт
	|	И НастройкиОтражения.ДолгосрочныйКт = &ДолгосрочныйКт
	|	
	|УПОРЯДОЧИТЬ ПО
	|	НастройкиОтражения.ПорядокПрименения УБЫВ";
	Запрос.УстановитьПараметр("ПланСчетов", ПараметрыПолученияДанных.ПланСчетов);
	Запрос.УстановитьПараметр("НастройкаФормированияПроводок", ПараметрыПолученияДанных.НастройкаФормированияПроводок);
	Запрос.УстановитьПараметр("ОбъектУчетаДт", ПараметрыПолученияДанных.ОбъектУчетаДт);
	Запрос.УстановитьПараметр("ОбъектУчетаКт", ПараметрыПолученияДанных.ОбъектУчетаКт);
	Запрос.УстановитьПараметр("ДолгосрочныйДт", ПараметрыПолученияДанных.ДолгосрочныйДт);
	Запрос.УстановитьПараметр("ДолгосрочныйКт", ПараметрыПолученияДанных.ДолгосрочныйКт);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПорядокПрименения = Выборка.ПорядокПрименения;
	КонецЕсли;
	
	ПорядокПрименения = ПорядокПрименения + 1;
	
	Возврат ПорядокПрименения;
	
КонецФункции

// Изменяет порядок применения настройки на некоторое число позиций
// 
// Параметры:
// 	КлючЗаписи - РегистрСведенийКлючЗаписи.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете - Исходный ключ записи настройки
// 	Сдвиг - Число - Число позиций, на которые необходимо изменить порядок применения настройки
//
// Возвращаемое значение:
// 	РегистрСведенийКлючЗаписи.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете - Ключ записи настроки после изменения порядка применения.
Функция ИзменитьПорядокПримененияНастройки(КлючЗаписи, Сдвиг) Экспорт
	
	НачатьТранзакцию();
	
	Попытка
		БлокировкаДанных = Новый БлокировкаДанных();
		ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("РегистрСведений.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете");
		ЭлементБлокировкиДанных.УстановитьЗначение("ПланСчетов", КлючЗаписи.ПланСчетов);
		ЭлементБлокировкиДанных.УстановитьЗначение("НастройкаФормированияПроводок", КлючЗаписи.НастройкаФормированияПроводок);
		ЭлементБлокировкиДанных.УстановитьЗначение("ОбъектУчетаДт", КлючЗаписи.ОбъектУчетаДт);
		ЭлементБлокировкиДанных.УстановитьЗначение("ОбъектУчетаКт", КлючЗаписи.ОбъектУчетаКт);
		ЭлементБлокировкиДанных.УстановитьЗначение("ДолгосрочныйДт", КлючЗаписи.ДолгосрочныйДт);
		ЭлементБлокировкиДанных.УстановитьЗначение("ДолгосрочныйКт", КлючЗаписи.ДолгосрочныйКт);
		ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
		БлокировкаДанных.Заблокировать();
		
		ТекущийПорядокПрименения = КлючЗаписи.ПорядокПрименения;
		
		НаборЗаписей = РегистрыСведений.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ПланСчетов.Установить(КлючЗаписи.ПланСчетов);
		НаборЗаписей.Отбор.НастройкаФормированияПроводок.Установить(КлючЗаписи.НастройкаФормированияПроводок);
		НаборЗаписей.Отбор.ОбъектУчетаДт.Установить(КлючЗаписи.ОбъектУчетаДт);
		НаборЗаписей.Отбор.ОбъектУчетаКт.Установить(КлючЗаписи.ОбъектУчетаКт);
		НаборЗаписей.Отбор.ДолгосрочныйДт.Установить(КлючЗаписи.ДолгосрочныйДт);
		НаборЗаписей.Отбор.ДолгосрочныйКт.Установить(КлючЗаписи.ДолгосрочныйКт);
		
		НаборЗаписей.Прочитать();
		
		НовыйПорядокПрименения = ТекущийПорядокПрименения + Сдвиг;
		
		Если НовыйПорядокПрименения < 1 Или НовыйПорядокПрименения > НаборЗаписей.Количество() Тогда
			ОтменитьТранзакцию();
			Возврат КлючЗаписи;
		КонецЕсли;
		
		ТаблицаЗаписей = НаборЗаписей.Выгрузить();
		
		Запись = ТаблицаЗаписей[ТекущийПорядокПрименения - 1];
		ТаблицаЗаписей.Сдвинуть(Запись, Сдвиг);
		
		ПорядокПрименения = 1;
		Для каждого СтрокаТаблицы Из ТаблицаЗаписей Цикл
			СтрокаТаблицы.ПорядокПрименения = ПорядокПрименения;
			ПорядокПрименения = ПорядокПрименения + 1;
		КонецЦикла;
	
		ЗначенияКлюча = Новый Структура;
		Для каждого Измерение Из Метаданные.РегистрыСведений.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете.Измерения Цикл
			ЗначенияКлюча.Вставить(Измерение.Имя);
		КонецЦикла;
		ЗаполнитьЗначенияСвойств(ЗначенияКлюча, Запись);
		НовыйКлючЗаписи = СоздатьКлючЗаписи(ЗначенияКлюча);
		
		НаборЗаписей.Загрузить(ТаблицаЗаписей);
		НаборЗаписей.Записать();
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение СтрШаблон(НСтр("ru = 'Не удалось изменить порядок применения записи по причине: %1';
										|en = 'Cannot change the record application procedure due to: %1'"),  ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
	Возврат НовыйКлючЗаписи;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбновлениеИнформационнойБазы

// Добавляет в список процедуры-обработчики обновления данных ИБ
// для всех поддерживаемых версий библиотеки или конфигурации.
// Вызывается перед началом обновления данных ИБ для построения плана обновления.
//
//  Обработчики - См. ОбновлениеИнформационнойБазы.НоваяТаблицаОбработчиковОбновления
//
// Пример добавления процедуры-обработчика в список:
//  Обработчик = Обработчики.Добавить();
//  Обработчик.Версия              = "1.1.0.0";
//  Обработчик.Процедура           = "ОбновлениеИБ.ПерейтиНаВерсию_1_1_0_0";
//  Обработчик.МонопольныйРежим    = Ложь;
//
// Параметры:
// 	Обработчики - см. ОбновлениеИнформационнойБазы.НоваяТаблицаОбработчиковОбновления
//
Процедура ПриДобавленииОбработчиковОбновления(Обработчики) Экспорт

	Обработчик = Обработчики.Добавить();
	Обработчик.Процедура = "РегистрыСведений.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете.ОбработатьДанныеДляПереходаНаНовуюВерсию";
	Обработчик.Версия = "2.5.21.38";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("80745678-fd87-4aef-ba93-be35cb287f94");
	Обработчик.Многопоточный = Истина;
	Обработчик.Порядок = Перечисления.ПорядокОбработчиковОбновления.Некритичный;
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "РегистрыСведений.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете.ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.Комментарий = НСтр("ru = 'Переносит настройки счетов международного учета с объектов учета типа
		|перечисление ""Объекты финансового учета"" на объекты учета типа план видов характеристик ""Статьи активов и пассивов"".';
		|en = 'Transfers settings of financial accounting accounts from accounting objects of the ""Financial accounting objects""
		|enumeration type to accounting objects of the ""Asset and liability items"" chart of characteristic types type.'");
	
	Обработчик.ПриоритетыВыполнения = ОбновлениеИнформационнойБазы.ПриоритетыВыполненияОбработчика();
	
	Приоритет = Обработчик.ПриоритетыВыполнения.Добавить();
	Приоритет.Процедура = "ПланыВидовХарактеристик.СтатьиАктивовПассивов.ЗаполнитьЭлементыНачальнымиДанными";
	Приоритет.Порядок = "После";
	
	Читаемые = Новый Массив;
	Читаемые.Добавить(Метаданные.ПланыВидовХарактеристик.СтатьиАктивовПассивов.ПолноеИмя());
	Читаемые.Добавить(Метаданные.РегистрыСведений.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете.ПолноеИмя());
	Обработчик.ЧитаемыеОбъекты = СтрСоединить(Читаемые, ",");
	
	Изменяемые = Новый Массив;
	Изменяемые.Добавить(Метаданные.РегистрыСведений.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете.ПолноеИмя());
	Изменяемые.Добавить(Метаданные.РегистрыСведений.НастройкиОтраженияКорреспонденцийВМеждународномУчете.ПолноеИмя());
	Обработчик.ИзменяемыеОбъекты = СтрСоединить(Изменяемые, ",");
	
	Блокируемые = Новый Массив;
	Блокируемые.Добавить(Метаданные.РегистрыСведений.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете.ПолноеИмя());
	Блокируемые.Добавить(Метаданные.РегистрыСведений.НастройкиОтраженияКорреспонденцийВМеждународномУчете.ПолноеИмя());
	Обработчик.БлокируемыеОбъекты = СтрСоединить(Блокируемые, ",");

КонецПроцедуры

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	МетаданныеРегистра = СоздатьНаборЗаписей().Метаданные();
	ПолноеИмяРегистра = МетаданныеРегистра.ПолноеИмя();
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаРегистров = ПолноеИмяРегистра;
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиИзмеренияНезависимогоРегистраСведений();
	
	ДополнительныеПараметры = ОбновлениеИнформационнойБазы.ДополнительныеПараметрыОтметкиОбработки();
	ДополнительныеПараметры.Вставить("ЭтоНезависимыйРегистрСведений", Истина);
	ДополнительныеПараметры.Вставить("ПолноеИмяРегистра", ПолноеИмяРегистра);
	
	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НастройкиОтраженияКорреспонденций.ПланСчетов КАК ПланСчетов,
	|	НастройкиОтраженияКорреспонденций.НастройкаФормированияПроводок КАК НастройкаФормированияПроводок,
	|	НастройкиОтраженияКорреспонденций.ДолгосрочныйДт КАК ДолгосрочныйДт,
	|	НастройкиОтраженияКорреспонденций.ДолгосрочныйКт КАК ДолгосрочныйКт
	|ИЗ
	|	РегистрСведений.УдалитьНастройкиОтраженияКорреспонденцийВМеждународномУчете КАК НастройкиОтраженияКорреспонденций
	|ГДЕ
	|	(НастройкиОтраженияКорреспонденций.СтатьяАктивовПассивовДт = ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка)
	|	ИЛИ НастройкиОтраженияКорреспонденций.СтатьяАктивовПассивовКт = ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка))
	|	И НЕ НастройкиОтраженияКорреспонденций.НеОбработанаАвтоматически
	|";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Результат = Запрос.Выполнить();
	
	НастройкиСчетов = Результат.Выгрузить();
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, НастройкиСчетов, ДополнительныеПараметры);
	
КонецПроцедуры

// Обработчик обновления
// 
// Параметры:
// 	Параметры - См. ОбновлениеИнформационнойБазы.ДополнительныеПараметрыВыборкиДанныхДляМногопоточнойОбработки 
//
Процедура ОбработатьДанныеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	МетаданныеРегистра = СоздатьНаборЗаписей().Метаданные();
	ПолноеИмяРегистра = МетаданныеРегистра.ПолноеИмя();
	
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если ОбновляемыеДанные.Количество() = 0 Тогда
		Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяРегистра);
		Возврат;
	КонецЕсли;
	
	СоответствиеОбъектовСтатьям = Перечисления.УдалитьОбъектыФинансовогоУчета.СоответствиеОбъектовФинансовогоУчетаСтатьямАктивовПассивов();
	ЗаменяемыеОбъектыУчета = Перечисления.УдалитьОбъектыФинансовогоУчета.ЗаменяемыеОбъектыФинансовогоУчета();
	ЗаменяющиеСтатьиАктивовПассивов = Новый Массив();
	
	Для Каждого КлючИЗначение Из ЗаменяемыеОбъектыУчета Цикл
		СтатьяАктивовПассивов = СоответствиеОбъектовСтатьям[КлючИЗначение.Ключ];
		Если ЗаменяющиеСтатьиАктивовПассивов.Найти(СтатьяАктивовПассивов) = Неопределено Тогда
			ЗаменяющиеСтатьиАктивовПассивов.Добавить(СтатьяАктивовПассивов);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Выборка Из ОбновляемыеДанные Цикл
		НастройкиПроводок = Справочники.НастройкиФормированияПроводокМеждународногоУчета.НастройкиФормированияПроводок(Выборка.НастройкаФормированияПроводок);
		НастройкиУчета = МеждународныйУчетПоДаннымФинансовыхРегистров.НастройкиУчетаПоНастройкамФормированияПроводок(НастройкиПроводок);
		ОписаниеОбъектовУчета = ПланыВидовХарактеристик.СтатьиАктивовПассивов.ОписаниеОбъектовФинансовогоУчета(НастройкиУчета,, ЗаменяющиеСтатьиАктивовПассивов);
		
		НачатьТранзакцию();
		
		Попытка
			
			БлокировкаДанных = Новый БлокировкаДанных();
			БлокировкаДанных.Добавить(ПолноеИмяРегистра);
			БлокировкаДанных.Добавить(Метаданные.РегистрыСведений.НастройкиОтраженияКорреспонденцийВМеждународномУчете.ПолноеИмя());
			
			Для Каждого ЭлементБлокировки Из БлокировкаДанных Цикл
				ЭлементБлокировки.УстановитьЗначение("ПланСчетов", Выборка.ПланСчетов);
				ЭлементБлокировки.УстановитьЗначение("НастройкаФормированияПроводок", Выборка.НастройкаФормированияПроводок);
				ЭлементБлокировки.УстановитьЗначение("ДолгосрочныйДт", Выборка.ДолгосрочныйДт);
				ЭлементБлокировки.УстановитьЗначение("ДолгосрочныйКт", Выборка.ДолгосрочныйКт);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			КонецЦикла;
			
			БлокировкаДанных.Заблокировать();
			
			НаборЗаписейЭтогоРегистра = СоздатьНаборЗаписей();
			НаборЗаписейЭтогоРегистра.Отбор.ПланСчетов.Установить(Выборка.ПланСчетов);
			НаборЗаписейЭтогоРегистра.Отбор.НастройкаФормированияПроводок.Установить(Выборка.НастройкаФормированияПроводок);
			НаборЗаписейЭтогоРегистра.Отбор.ДолгосрочныйДт.Установить(Выборка.ДолгосрочныйДт);
			НаборЗаписейЭтогоРегистра.Отбор.ДолгосрочныйКт.Установить(Выборка.ДолгосрочныйКт);
			НаборЗаписейЭтогоРегистра.Прочитать();
			
			НаборЗаписейНовогоРегистра = РегистрыСведений.НастройкиОтраженияКорреспонденцийВМеждународномУчете.СоздатьНаборЗаписей();
			НаборЗаписейНовогоРегистра.Отбор.ПланСчетов.Установить(Выборка.ПланСчетов);
			НаборЗаписейНовогоРегистра.Отбор.НастройкаФормированияПроводок.Установить(Выборка.НастройкаФормированияПроводок);
			НаборЗаписейНовогоРегистра.Отбор.ДолгосрочныйДт.Установить(Выборка.ДолгосрочныйДт);
			НаборЗаписейНовогоРегистра.Отбор.ДолгосрочныйКт.Установить(Выборка.ДолгосрочныйКт);
			
			Для Каждого ЗаписьЭтогоРегистра Из НаборЗаписейЭтогоРегистра Цикл
				Если (ЗаписьЭтогоРегистра.СтатьяАктивовПассивовДт = ПланыВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка()
					ИЛИ ЗаписьЭтогоРегистра.СтатьяАктивовПассивовКт = ПланыВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка())
					И НЕ ЗаписьЭтогоРегистра.НеОбработанаАвтоматически Тогда
					ОбработатьЗаписьРегистраДляПереходаНаНовуюВерсию(ЗаписьЭтогоРегистра, СоответствиеОбъектовСтатьям, "Дт");
					ОбработатьЗаписьРегистраДляПереходаНаНовуюВерсию(ЗаписьЭтогоРегистра, СоответствиеОбъектовСтатьям, "Кт");
					
					Если ЗаписьЭтогоРегистра.НеОбработанаАвтоматически Тогда
						Продолжить;
					КонецЕсли;
					
					ЗаписьНовогоРегистра = НаборЗаписейНовогоРегистра.Добавить();
					ЗаполнитьЗначенияСвойств(ЗаписьНовогоРегистра, ЗаписьЭтогоРегистра,,
						"ОбъектУчетаДт,ОбъектУчетаКт,ДополнительныйОтборДт,ДополнительныйОтборКт");
					
					ЗаписьНовогоРегистра.ОбъектУчетаДт = ЗаписьЭтогоРегистра.СтатьяАктивовПассивовДт;
					ЗаписьНовогоРегистра.ОбъектУчетаКт = ЗаписьЭтогоРегистра.СтатьяАктивовПассивовКт;
					
					ОбработатьДополнительныйОтборДляПереходаНаНовуюВерсию(ЗаписьЭтогоРегистра, ЗаписьНовогоРегистра,
						ЗаменяющиеСтатьиАктивовПассивов, ОписаниеОбъектовУчета, "Дт");
					
					ОбработатьДополнительныйОтборДляПереходаНаНовуюВерсию(ЗаписьЭтогоРегистра, ЗаписьНовогоРегистра,
						ЗаменяющиеСтатьиАктивовПассивов, ОписаниеОбъектовУчета, "Кт");
					КонецЕсли;
			КонецЦикла;
			
			Если НаборЗаписейЭтогоРегистра.Модифицированность() Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписейЭтогоРегистра);
			Иначе
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(НаборЗаписейЭтогоРегистра);
			КонецЕсли;
			
			Если НаборЗаписейНовогоРегистра.Количество() > 0 Тогда
				ТаблицаЗаписей = НаборЗаписейНовогоРегистра.Выгрузить();
				ТаблицаЗаписей.Сортировать("ПланСчетов,НастройкаФормированияПроводок,ОбъектУчетаДт,ОбъектУчетаКт,ДолгосрочныйДт,ДолгосрочныйКт,ПорядокПрименения");
				
				ИндексЗаписи = 1;
				
				Пока ИндексЗаписи < ТаблицаЗаписей.Количество() Цикл
					ПредыдущаяЗапись = ТаблицаЗаписей[ИндексЗаписи - 1];
					ТекущаяЗапись = ТаблицаЗаписей[ИндексЗаписи];
					
					Если ПредыдущаяЗапись.ПланСчетов = ТекущаяЗапись.ПланСчетов
						И ПредыдущаяЗапись.НастройкаФормированияПроводок = ТекущаяЗапись.НастройкаФормированияПроводок
						И ПредыдущаяЗапись.ОбъектУчетаДт = ТекущаяЗапись.ОбъектУчетаДт
						И ПредыдущаяЗапись.ОбъектУчетаКт = ТекущаяЗапись.ОбъектУчетаКт
						И ПредыдущаяЗапись.ДолгосрочныйДт = ТекущаяЗапись.ДолгосрочныйДт
						И ПредыдущаяЗапись.ДолгосрочныйКт = ТекущаяЗапись.ДолгосрочныйКт
						И ПредыдущаяЗапись.ПорядокПрименения >= ТекущаяЗапись.ПорядокПрименения Тогда
						ТекущаяЗапись.ПорядокПрименения = ПредыдущаяЗапись.ПорядокПрименения + 1;
					КонецЕсли;
					
					ИндексЗаписи = ИндексЗаписи + 1;
				КонецЦикла;
				
				НаборЗаписейНовогоРегистра.Загрузить(ТаблицаЗаписей);
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписейНовогоРегистра);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			Шаблон = НСтр("ru = 'Не удалось записать данные в регистр %1 по причине: %2';
							|en = 'Cannot save the data to the %1 register. Reason: %2'");
			
			ТекстСообщения = 	СтрШаблон(
				Шаблон,
				ПолноеИмяРегистра,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			ЗаписьЖурналаРегистрации(
				ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
				УровеньЖурналаРегистрации.Ошибка,
				МетаданныеРегистра,,
				ТекстСообщения);
			
		КонецПопытки;
		
	КонецЦикла;
	
	Параметры.ОбработкаЗавершена = Не ОбновлениеИнформационнойБазы.ЕстьДанныеДляОбработки(Параметры.Очередь, ПолноеИмяРегистра);
	
КонецПроцедуры

Процедура ОбработатьЗаписьРегистраДляПереходаНаНовуюВерсию(ЗаписьЭтогоРегистра, СоответствиеОбъектовСтатьям, ДтКт)
	
	Если ЗначениеЗаполнено(ЗаписьЭтогоРегистра["СтатьяАктивовПассивов" + ДтКт]) Тогда
		СтатьяАктивовПассивов = ЗаписьЭтогоРегистра["СтатьяАктивовПассивов" + ДтКт];
	ИначеЕсли ЗаписьЭтогоРегистра["ОбъектУчета" + ДтКт] = Перечисления.УдалитьОбъектыФинансовогоУчета.ПрочиеАктивыПассивы Тогда
		СтатьяАктивовПассивов = ПолучитьСтатьюАктивовПассивовИзДополнительногоОтбора(ЗаписьЭтогоРегистра, ДтКт);
	Иначе
		СтатьяАктивовПассивов = СоответствиеОбъектовСтатьям[ЗаписьЭтогоРегистра["ОбъектУчета" + ДтКт]];
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтатьяАктивовПассивов) Тогда
		ЗаписьЭтогоРегистра["СтатьяАктивовПассивов" + ДтКт] = СтатьяАктивовПассивов;
	Иначе
		ЗаписьЭтогоРегистра.НеОбработанаАвтоматически = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьДополнительныйОтборДляПереходаНаНовуюВерсию(ЗаписьЭтогоРегистра, ЗаписьНовогоРегистра,
	ЗаменяющиеСтатьиАктивовПассивов, ОписаниеОбъектовУчета, ДтКт)
	
	Если ЗаписьЭтогоРегистра["ЕстьДополнительныйОтбор" + ДтКт] Тогда
		ДополнительныйОтбор = ЗаписьЭтогоРегистра["ДополнительныйОтбор" + ДтКт].Получить(); // НастройкиКомпоновкиДанных
	Иначе
		ДополнительныйОтбор = Неопределено;
	КонецЕсли;
	
	Если ЗаменяющиеСтатьиАктивовПассивов.Найти(ЗаписьЭтогоРегистра["СтатьяАктивовПассивов" + ДтКт]) <> Неопределено Тогда
		ДополнитьОтборЗаменяющихСтатейАктивовПассивов(ДополнительныйОтбор, ЗаписьЭтогоРегистра, ОписаниеОбъектовУчета, ДтКт);
	ИначеЕсли ЗаписьЭтогоРегистра["ОбъектУчета" + ДтКт] = Перечисления.УдалитьОбъектыФинансовогоУчета.ПрочиеАктивыПассивы Тогда
		УдалитьОтборПоСтатьеАктивовПассивов(ДополнительныйОтбор, ЗаписьЭтогоРегистра, ДтКт);
	КонецЕсли;
	
	Если ТипЗнч(ДополнительныйОтбор) <> Тип("НастройкиКомпоновкиДанных") Тогда
		ЗаписьНовогоРегистра["ЕстьДополнительныйОтбор" + ДтКт] = Ложь;
		ЗаписьНовогоРегистра["ДополнительныйОтбор" + ДтКт] = Неопределено;
	ИначеЕсли ДополнительныйОтбор.Отбор.Элементы.Количество() > 0 Тогда
		ЗаписьНовогоРегистра["ЕстьДополнительныйОтбор" + ДтКт] = Истина;
		ЗаписьНовогоРегистра["ДополнительныйОтбор" + ДтКт] = Новый ХранилищеЗначения(ДополнительныйОтбор);
	Иначе
		ЗаписьНовогоРегистра["ЕстьДополнительныйОтбор" + ДтКт] = Ложь;
		ЗаписьНовогоРегистра["ДополнительныйОтбор" + ДтКт] = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьСтатьюАктивовПассивовИзДополнительногоОтбора(ЗаписьЭтогоРегистра, ДтКт)
	
	СтатьяАктивовПассивов = ПланыВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка();
	
	Если ЗаписьЭтогоРегистра["ЕстьДополнительныйОтбор" + ДтКт] Тогда
		КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных();
		ДополнительныйОтбор = ЗаписьЭтогоРегистра["ДополнительныйОтбор" + ДтКт].Получить();
		
		ПланыВидовХарактеристик.СтатьиАктивовПассивов.ИнициализироватьКомпоновщикНастроекИсточникомДанных(
			КомпоновщикНастроек, Метаданные.РегистрыНакопления.ДвиженияПоПрочимАктивамПассивам.Имя);
		
		Если ТипЗнч(ДополнительныйОтбор) = Тип("НастройкиКомпоновкиДанных") Тогда
			КомпоновщикНастроек.ЗагрузитьНастройки(ДополнительныйОтбор);
		КонецЕсли;
		
		НастройкиОтбора = КомпоновщикНастроек.Настройки.Отбор;
		ОтборНаРавенствоСтатье = Неопределено;
		
		Для Каждого ЭлементОтбора Из НастройкиОтбора.Элементы Цикл
			Если ЭлементОтбора.Использование = Истина
				И ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных")
				И ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Статья")
				И ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно Тогда
				ОтборНаРавенствоСтатье = ЭлементОтбора;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ОтборНаРавенствоСтатье <> Неопределено Тогда
			СтатьяАктивовПассивов = ОтборНаРавенствоСтатье.ПравоеЗначение;
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтатьяАктивовПассивов;
	
КонецФункции

Процедура ДополнитьОтборЗаменяющихСтатейАктивовПассивов(ДополнительныйОтбор, ЗаписьЭтогоРегистра, ОписаниеОбъектовУчета, ДтКт)
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных();
	ОписаниеОбъектаУчета = ОписаниеОбъектовУчета.Найти(ЗаписьЭтогоРегистра["СтатьяАктивовПассивов" + ДтКт], "ОбъектУчета");
	
	Если ОписаниеОбъектаУчета = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПланыВидовХарактеристик.СтатьиАктивовПассивов.ИнициализироватьКомпоновщикНастроекИсточникомДанных(
		КомпоновщикНастроек, ОписаниеОбъектаУчета.ИсточникДанных);
	
	Если ТипЗнч(ДополнительныйОтбор) = Тип("НастройкиКомпоновкиДанных") Тогда
		КомпоновщикНастроек.ЗагрузитьНастройки(ДополнительныйОтбор);
	КонецЕсли;
	
	НастройкиОтбора = КомпоновщикНастроек.Настройки.Отбор;
	
	Если ЗаписьЭтогоРегистра["ОбъектУчета" + ДтКт] = Перечисления.УдалитьОбъектыФинансовогоУчета.НоменклатураПринятаяВПереработкуНаСкладе Тогда
		НовыйОтбор = НастройкиОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйОтбор.Использование = Истина;
		НовыйОтбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("РазделУчета");
		НовыйОтбор.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйОтбор.ПравоеЗначение = Перечисления.РазделыУчетаСебестоимостиТоваров.МатериалыПринятыеВПереработку;
	КонецЕсли;
	
	Если ЗаписьЭтогоРегистра["ОбъектУчета" + ДтКт] = Перечисления.УдалитьОбъектыФинансовогоУчета.НоменклатураПринятаяВПереработкуКСписанию Тогда
		НовыйОтбор = НастройкиОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйОтбор.Использование = Истина;
		НовыйОтбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("РазделУчета");
		НовыйОтбор.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйОтбор.ПравоеЗначение = Перечисления.РазделыУчетаСебестоимостиТоваров.МатериалыПринятыеВПереработкуКОформлениюСписания;
	КонецЕсли;
	
	Если ЗаписьЭтогоРегистра["ОбъектУчета" + ДтКт] = Перечисления.УдалитьОбъектыФинансовогоУчета.НоменклатураПринятаяНаХранениеНаСкладе Тогда
		РазделыУчетаНаСкладах = Новый СписокЗначений();
		РазделыУчетаНаСкладах.Добавить(Перечисления.РазделыУчетаСебестоимостиТоваров.ТоварыПринятыеНаОтветхранение);
		РазделыУчетаНаСкладах.Добавить(Перечисления.РазделыУчетаСебестоимостиТоваров.ТоварыНаХраненииСПравомПродажи);
		
		НовыйОтбор = НастройкиОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйОтбор.Использование = Истина;
		НовыйОтбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("РазделУчета");
		НовыйОтбор.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
		НовыйОтбор.ПравоеЗначение = РазделыУчетаНаСкладах;
	КонецЕсли;
	
	Если ЗаписьЭтогоРегистра["ОбъектУчета" + ДтКт] = Перечисления.УдалитьОбъектыФинансовогоУчета.НоменклатураПринятаяНаХранениеКСписанию Тогда
		РазделыУчетаСписания = Новый СписокЗначений();
		РазделыУчетаСписания.Добавить(Перечисления.РазделыУчетаСебестоимостиТоваров.ТоварыПринятыеНаОтветхранениеКОформлениюСписания);
		РазделыУчетаСписания.Добавить(Перечисления.РазделыУчетаСебестоимостиТоваров.ТоварыНаХраненииСПравомПродажиКОформлениюСписания);
		
		НовыйОтбор = НастройкиОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйОтбор.Использование = Истина;
		НовыйОтбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("РазделУчета");
		НовыйОтбор.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
		НовыйОтбор.ПравоеЗначение = РазделыУчетаСписания;
	КонецЕсли;
	
	ДополнительныйОтбор = КомпоновщикНастроек.ПолучитьНастройки();
	
КонецПроцедуры

Процедура УдалитьОтборПоСтатьеАктивовПассивов(ДополнительныйОтбор, ЗаписьЭтогоРегистра, ДтКт)
	
	Если ТипЗнч(ДополнительныйОтбор) <> Тип("НастройкиКомпоновкиДанных") Тогда
		Возврат;
	КонецЕсли;
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных();
	ПланыВидовХарактеристик.СтатьиАктивовПассивов.ИнициализироватьКомпоновщикНастроекИсточникомДанных(
		КомпоновщикНастроек, Метаданные.РегистрыНакопления.ДвиженияПоПрочимАктивамПассивам.Имя);
	КомпоновщикНастроек.ЗагрузитьНастройки(ДополнительныйОтбор);
	
	НастройкиОтбора = КомпоновщикНастроек.Настройки.Отбор;
	ОтборНаРавенствоСтатье = Неопределено;
	
	Для Каждого ЭлементОтбора Из НастройкиОтбора.Элементы Цикл
		Если ЭлементОтбора.Использование = Истина
			И ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных")
			И ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Статья")
			И ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно
			И ЭлементОтбора.ПравоеЗначение = ЗаписьЭтогоРегистра["СтатьяАктивовПассивов" + ДтКт] Тогда
			ОтборНаРавенствоСтатье = ЭлементОтбора;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ОтборНаРавенствоСтатье <> Неопределено Тогда
		НастройкиОтбора.Элементы.Удалить(ОтборНаРавенствоСтатье);
	КонецЕсли;
	
	ДополнительныйОтбор = КомпоновщикНастроек.ПолучитьНастройки();
	
КонецПроцедуры

