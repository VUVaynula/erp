#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий
	
Процедура ПередЗаписью(Отказ, Замещение)

	Если ОбменДанными.Загрузка Тогда	
		Возврат;	
	КонецЕсли; 
	
	Для каждого Строка Из ЭтотОбъект Цикл
		Если НЕ ЗначениеЗаполнено(Строка.Пользователь) Тогда
			ТекстСообщения = НСтр("ru = 'Значение поля ""Пользователь"" не может быть пустым.';
								  |en = 'Значение поля ""Пользователь"" не может быть пустым.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,,Отказ);
    	КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Строка.ИмяЭлементаУправления) Тогда
			ТекстСообщения 	= НСтр("ru = 'Значение поля ""Имя элемента управления"" не может быть пустым.';
								   |en = 'Значение поля ""Имя элемента управления"" не может быть пустым.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,,Отказ);
 		КонецЕсли;
	КонецЦикла;
	
	Если НЕ Отказ Тогда
		ОбновитьПовторноИспользуемыеЗначения();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли