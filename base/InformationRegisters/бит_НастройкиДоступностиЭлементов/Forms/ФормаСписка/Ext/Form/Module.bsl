
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбъектыНастройки = бит_НастройкиДоступностиЭлементовФорм.ОбъектыНастройкиДоступностиЭлементов();
	ОбъектыСистемы.Параметры.УстановитьЗначениеПараметра("ДоступныеОбъектыСистемы", ОбъектыНастройки);
			
	ОтобразитьНастройкиОбъектаСистемы();
	
	УстановитьОтборПользователь();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "Запись_бит_НастройкиДоступностиЭлементов" Тогда
		Элементы.ОбъектыСистемы.Обновить();
		Элементы.Список.Обновить();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОтборПользовательПриИзменении(Элемент)
	
	УстановитьОтборПользователь();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыОбъектыСистемы

&НаСервереБезКонтекста
Процедура ОбъектыСистемыПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	Для каждого СтрокаДинамическогоСписка Из Строки Цикл
		Данные = СтрокаДинамическогоСписка.Значение.Данные;
		
		Представление = Данные.Наименование;
		Если Данные.КоличествоНастроек > 0 Тогда
			Представление = Представление + " (" + Данные.КоличествоНастроек + ")";
		КонецЕсли;
		
		Данные.Представление = Представление;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыСистемыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектыСистемыПриАктивизацииСтроки(Элемент)
	
	ПодключитьОбработчикОжидания("ПриИзмененииТекущегоОбъектаСистемы", 0.1, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаКлиенте
Процедура СписокПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Если Не Копирование Тогда
		Отказ = Истина;
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ОбъектСистемы", ТекущийОбъектСистемы);
		ПараметрыФормы.Вставить("Пользователь",  Пользователь);
		
		ОткрытьФорму("РегистрСведений.бит_НастройкиДоступностиЭлементов.ФормаЗаписи",
			ПараметрыФормы, ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ГрупповаяНастройкаПолей(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ОбъектСистемы", ТекущийОбъектСистемы);
	ПараметрыФормы.Вставить("Пользователь",  Пользователь);
	
	ОткрытьФорму("РегистрСведений.бит_НастройкиДоступностиЭлементов.Форма.ГрупповаяНастройкаДоступности", ПараметрыФормы);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОтобразитьНастройкиОбъектаСистемы()
	
	Список.Параметры.УстановитьЗначениеПараметра("ОбъектСистемы", ТекущийОбъектСистемы);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборПользователь()
	
	ЗначениеОтбора = Пользователь;
	Если НЕ ЗначениеЗаполнено(ЗначениеОтбора) Тогда
		ЗначениеОтбора = Неопределено; // На случай пустых ссылок.
	КонецЕсли;
	ОбъектыСистемы.Параметры.УстановитьЗначениеПараметра("ОтборПоПользователю", ЗначениеОтбора);
	Список.Параметры.УстановитьЗначениеПараметра("ОтборПоПользователю", ЗначениеОтбора);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииТекущегоОбъектаСистемы()
	
	Если Элементы.ОбъектыСистемы.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Элементы.ОбъектыСистемы.ТекущиеДанные.Ссылка <> ТекущийОбъектСистемы Тогда
		ТекущийОбъектСистемы = Элементы.ОбъектыСистемы.ТекущиеДанные.Ссылка;
		ОтобразитьНастройкиОбъектаСистемы();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти