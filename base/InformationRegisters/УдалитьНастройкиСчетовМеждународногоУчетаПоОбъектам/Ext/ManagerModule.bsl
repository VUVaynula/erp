#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции

#Область ОбновлениеИнформационнойБазы

// Добавляет в список процедуры-обработчики обновления данных ИБ
// для всех поддерживаемых версий библиотеки или конфигурации.
// Вызывается перед началом обновления данных ИБ для построения плана обновления.
//
//  Обработчики - См. ОбновлениеИнформационнойБазы.НоваяТаблицаОбработчиковОбновления
//
// Пример добавления процедуры-обработчика в список:
//  Обработчик = Обработчики.Добавить();
//  Обработчик.Версия              = "1.1.0.0";
//  Обработчик.Процедура           = "ОбновлениеИБ.ПерейтиНаВерсию_1_1_0_0";
//  Обработчик.МонопольныйРежим    = Ложь;
//
// Параметры:
// 	Обработчики - см. ОбновлениеИнформационнойБазы.НоваяТаблицаОбработчиковОбновления
//
Процедура ПриДобавленииОбработчиковОбновления(Обработчики) Экспорт
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Процедура = "РегистрыСведений.УдалитьНастройкиСчетовМеждународногоУчетаПоОбъектам.ОбработатьДанныеДляПереходаНаНовуюВерсию";
	Обработчик.Версия = "2.5.21.38";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("dc287a94-cb93-4bfa-ae87-cf3580744665");
	Обработчик.Многопоточный = Истина;
	Обработчик.Порядок = Перечисления.ПорядокОбработчиковОбновления.Некритичный;
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "РегистрыСведений.УдалитьНастройкиСчетовМеждународногоУчетаПоОбъектам.ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.Комментарий = НСтр("ru = 'Заменяет значение ""Объект настройки"" с типом перечисление ""Типы налогов"" на значение с типом справочник ""Виды налогов и взносов"".
		|Переносит настройки счетов международного учета с объектов учета типа перечисление ""Объекты финансового учета""
		|на объекты учета типа план видов характеристик ""Статьи активов и пассивов"".';
		|en = 'Replaces the ""Setting object"" value of the ""Tax types"" enumeration type with the value of the ""Tax and contribution kinds"" catalog type.
		|Transfers settings of financial accounting accounts from accounting objects of the ""Financial accounting objects""
		|enumeration type to accounting objects of the ""Asset and liability items"" chart of characteristic type.'");
	
	Читаемые = Новый Массив;
	Читаемые.Добавить(Метаданные.РегистрыСведений.УдалитьНастройкиСчетовМеждународногоУчетаПоОбъектам.ПолноеИмя());
	Обработчик.ЧитаемыеОбъекты = СтрСоединить(Читаемые, ",");
	
	Изменяемые = Новый Массив;
	Изменяемые.Добавить(Метаданные.РегистрыСведений.УдалитьНастройкиСчетовМеждународногоУчетаПоОбъектам.ПолноеИмя());
	Изменяемые.Добавить(Метаданные.РегистрыСведений.НастройкиСчетовМеждународногоУчетаПоОбъектам.ПолноеИмя());
	Обработчик.ИзменяемыеОбъекты = СтрСоединить(Изменяемые, ",");
	
	Блокируемые = Новый Массив;
	Блокируемые.Добавить(Метаданные.РегистрыСведений.УдалитьНастройкиСчетовМеждународногоУчетаПоОбъектам.ПолноеИмя());
	Блокируемые.Добавить(Метаданные.РегистрыСведений.НастройкиСчетовМеждународногоУчетаПоОбъектам.ПолноеИмя());
	Обработчик.БлокируемыеОбъекты = СтрСоединить(Блокируемые, ",");

КонецПроцедуры

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	МетаданныеРегистра = СоздатьНаборЗаписей().Метаданные();
	ПолноеИмяРегистра = МетаданныеРегистра.ПолноеИмя();
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаРегистров = ПолноеИмяРегистра;
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиИзмеренияНезависимогоРегистраСведений();
	
	ДополнительныеПараметры = ОбновлениеИнформационнойБазы.ДополнительныеПараметрыОтметкиОбработки();
	ДополнительныеПараметры.Вставить("ЭтоНезависимыйРегистрСведений", Истина);
	ДополнительныеПараметры.Вставить("ПолноеИмяРегистра", ПолноеИмяРегистра);
	
	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НастройкиСчетовПоОбъектам.ПланСчетов КАК ПланСчетов,
	|	НастройкиСчетовПоОбъектам.НастройкаФормированияПроводок КАК НастройкаФормированияПроводок,
	|	НастройкиСчетовПоОбъектам.ОбъектНастройки КАК ОбъектНастройки,
	|	НастройкиСчетовПоОбъектам.Организация КАК Организация
	|ИЗ
	|	РегистрСведений.УдалитьНастройкиСчетовМеждународногоУчетаПоОбъектам КАК НастройкиСчетовПоОбъектам
	|ГДЕ
	|	НастройкиСчетовПоОбъектам.СтатьяАктивовПассивов = ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка)
	|	И НЕ НастройкиСчетовПоОбъектам.НеОбработанаАвтоматически
	|";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Результат = Запрос.Выполнить();
	
	НастройкиСчетов = Результат.Выгрузить();
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, НастройкиСчетов, ДополнительныеПараметры);
	
КонецПроцедуры

// Обработчик обновления
// 
// Параметры:
// 	Параметры - См. ОбновлениеИнформационнойБазы.ДополнительныеПараметрыВыборкиДанныхДляМногопоточнойОбработки 
//
Процедура ОбработатьДанныеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	МетаданныеРегистра = СоздатьНаборЗаписей().Метаданные();
	ПолноеИмяРегистра = МетаданныеРегистра.ПолноеИмя();
	
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если ОбновляемыеДанные.Количество() = 0 Тогда
		Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяРегистра);
		Возврат;
	КонецЕсли;
	
	СоответствиеОбъектовСтатьям = Перечисления.УдалитьОбъектыФинансовогоУчета.СоответствиеОбъектовФинансовогоУчетаСтатьямАктивовПассивов();
	ЗаменяемыеОбъектыУчета = Перечисления.УдалитьОбъектыФинансовогоУчета.ЗаменяемыеОбъектыФинансовогоУчета();
	
	Для Каждого Выборка Из ОбновляемыеДанные Цикл
		НачатьТранзакцию();
		
		Попытка
			
			Если ТипЗнч(Выборка.ОбъектНастройки) = Тип("ПеречислениеСсылка.УдалитьТипыНалогов") Тогда
				НовыйОбъектНастройки = Перечисления.УдалитьТипыНалогов.СсылкаВидыНалоговВзносовПоТипуНалогов(Выборка.ОбъектНастройки);
			Иначе
				НовыйОбъектНастройки = Выборка.ОбъектНастройки;
			КонецЕсли;
			
			БлокировкаДанных = Новый БлокировкаДанных();
			
			ЭлементБлокировки = БлокировкаДанных.Добавить(ПолноеИмяРегистра);
			ЭлементБлокировки.УстановитьЗначение("ОбъектНастройки", Выборка.ОбъектНастройки);
			
			ЭлементБлокировки = БлокировкаДанных.Добавить(Метаданные.РегистрыСведений.НастройкиСчетовМеждународногоУчетаПоОбъектам.ПолноеИмя());
			ЭлементБлокировки.УстановитьЗначение("ОбъектНастройки", НовыйОбъектНастройки);
			
			Для Каждого ЭлементБлокировки Из БлокировкаДанных Цикл
				ЭлементБлокировки.УстановитьЗначение("ПланСчетов", Выборка.ПланСчетов);
				ЭлементБлокировки.УстановитьЗначение("НастройкаФормированияПроводок", Выборка.НастройкаФормированияПроводок);
				ЭлементБлокировки.УстановитьЗначение("Организация", Выборка.Организация);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			КонецЦикла;
			
			БлокировкаДанных.Заблокировать();
			
			НаборЗаписейЭтогоРегистра = СоздатьНаборЗаписей();
			НаборЗаписейЭтогоРегистра.Отбор.ПланСчетов.Установить(Выборка.ПланСчетов);
			НаборЗаписейЭтогоРегистра.Отбор.НастройкаФормированияПроводок.Установить(Выборка.НастройкаФормированияПроводок);
			НаборЗаписейЭтогоРегистра.Отбор.ОбъектНастройки.Установить(Выборка.ОбъектНастройки);
			НаборЗаписейЭтогоРегистра.Отбор.Организация.Установить(Выборка.Организация);
			НаборЗаписейЭтогоРегистра.Прочитать();
			
			НаборЗаписейНовогоРегистра = РегистрыСведений.НастройкиСчетовМеждународногоУчетаПоОбъектам.СоздатьНаборЗаписей();
			НаборЗаписейНовогоРегистра.Отбор.ПланСчетов.Установить(Выборка.ПланСчетов);
			НаборЗаписейНовогоРегистра.Отбор.НастройкаФормированияПроводок.Установить(Выборка.НастройкаФормированияПроводок);
			НаборЗаписейНовогоРегистра.Отбор.ОбъектНастройки.Установить(НовыйОбъектНастройки);
			НаборЗаписейНовогоРегистра.Отбор.Организация.Установить(Выборка.Организация);
			
			ТаблицаЗаписей = НаборЗаписейЭтогоРегистра.Выгрузить();
			
			Для Каждого ЗаписьЭтогоРегистра Из НаборЗаписейЭтогоРегистра Цикл
				Если ЗаписьЭтогоРегистра.СтатьяАктивовПассивов = ПланыВидовХарактеристик.СтатьиАктивовПассивов.ПустаяСсылка()
					И НЕ ЗаписьЭтогоРегистра.НеОбработанаАвтоматически Тогда
					СтатьяАктивовПассивов = СоответствиеОбъектовСтатьям[ЗаписьЭтогоРегистра.ОбъектУчета];
					
					Если ЗначениеЗаполнено(СтатьяАктивовПассивов) Тогда
						ЗаписьЭтогоРегистра.СтатьяАктивовПассивов = СтатьяАктивовПассивов;
					Иначе
						ЗаписьЭтогоРегистра.НеОбработанаАвтоматически = Истина;
						Продолжить;
					КонецЕсли;
					
					ЗаписатьВНовыйРегистр = Истина;
					ЗаменяющийОбъектУчета = ЗаменяемыеОбъектыУчета[ЗаписьЭтогоРегистра.ОбъектУчета];
					
					Если ЗаменяющийОбъектУчета <> Неопределено Тогда
						Для Каждого ЗаписьТаблицы Из ТаблицаЗаписей Цикл
							Если ЗаписьТаблицы.ОбъектУчета = ЗаменяющийОбъектУчета
								И ЗаписьТаблицы.ТипНастройки = ЗаписьЭтогоРегистра.ТипНастройки
								И ЗаписьТаблицы.МестоУчета = ЗаписьЭтогоРегистра.МестоУчета Тогда
								ЗаписатьВНовыйРегистр = Ложь;
								Если ЗаписьТаблицы.СчетУчета <> ЗаписьЭтогоРегистра.СчетУчета
								 ИЛИ ЗаписьТаблицы.СчетУчетаДолгосрочный <> ЗаписьЭтогоРегистра.СчетУчетаДолгосрочный Тогда
									ЗаписьЭтогоРегистра.НеОбработанаАвтоматически = Истина;
								КонецЕсли;
								Прервать;
							КонецЕсли;
						КонецЦикла;
					КонецЕсли;
					
					Если ЗаписатьВНовыйРегистр Тогда
						ЗаписьНовогоРегистра = НаборЗаписейНовогоРегистра.Добавить();
						ЗаполнитьЗначенияСвойств(ЗаписьНовогоРегистра, ЗаписьЭтогоРегистра,, "ОбъектУчета,ОбъектНастройки");
						ЗаписьНовогоРегистра.ОбъектУчета = СтатьяАктивовПассивов;
						ЗаписьНовогоРегистра.ОбъектНастройки = НовыйОбъектНастройки;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			
			Если НаборЗаписейЭтогоРегистра.Модифицированность() Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписейЭтогоРегистра);
			Иначе
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(НаборЗаписейЭтогоРегистра);
			КонецЕсли;
			
			Если НаборЗаписейНовогоРегистра.Количество() > 0 Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписейНовогоРегистра);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			Шаблон = НСтр("ru = 'Не удалось записать данные в регистр %1 по причине: %2';
							|en = 'Cannot save the data to the %1 register. Reason: %2'");
			
			ТекстСообщения = 	СтрШаблон(
				Шаблон,
				ПолноеИмяРегистра,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			ЗаписьЖурналаРегистрации(
				ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
				УровеньЖурналаРегистрации.Ошибка,
				МетаданныеРегистра,,
				ТекстСообщения);
			
		КонецПопытки;
		
	КонецЦикла;
	
	Параметры.ОбработкаЗавершена = Не ОбновлениеИнформационнойБазы.ЕстьДанныеДляОбработки(Параметры.Очередь, ПолноеИмяРегистра);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецЕсли