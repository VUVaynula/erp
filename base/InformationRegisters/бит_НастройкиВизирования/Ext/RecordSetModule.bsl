#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, Замещение)

	Если ОбменДанными.Загрузка Тогда
		Возврат;	
	КонецЕсли;	

	Для каждого СтрокаТаблицы Из ЭтотОбъект Цикл
		СтрокаТаблицы.НастройкиВизированияУстановлены = Истина;
		
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.СтруктурноеПодразделение) 
		   И СтрокаТаблицы.СтруктурноеПодразделение <> Неопределено Тогда
			ТекстСообщения = НСтр("ru = 'Структурное подразделение не может быть пустой ссылкой.'"); 
			ВызватьИсключение ТекстСообщения;
		КонецЕсли;
	КонецЦикла; 
	
КонецПроцедуры

#КонецОбласти

#Иначе
	ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'; en = 'Invalid call of the object on the client.'");
#КонецЕсли