#Область ОбновлениеИнформационнойБазы

// см. ОбновлениеИнформационнойБазыБСП.ПриДобавленииОбработчиковОбновления
Процедура ПриДобавленииОбработчиковОбновления(Обработчики) Экспорт

	Обработчик = Обработчики.Добавить();
	Обработчик.Процедура = "Справочники.ЭтапыПодготовкиБюджетов.ОбработатьДанныеДляПереходаНаНовуюВерсию";
	Обработчик.Версия = "2.5.21.62";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("a2cd2d9c-ee2f-44b2-a5a4-69db33bc857e");
	Обработчик.Многопоточный = Истина;
	Обработчик.ПроцедураЗаполненияДанныхОбновления = "Справочники.ЭтапыПодготовкиБюджетов.ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию";
	Обработчик.ПроцедураПроверки = "ОбновлениеИнформационнойБазы.ДанныеОбновленыНаНовуюВерсиюПрограммы";
	Обработчик.Комментарий = НСтр("ru = 'Добавляет колонку ""Действие"" в таблицу ""Виды бюджетов"", хранящуюся в реквизите ""Настройка действия"".';
									|en = 'Adds the ""Action"" column to the ""Budget profiles"" table stored in the ""Action setting"" attribute.'");
	
	Читаемые = Новый Массив;
	Читаемые.Добавить(Метаданные.Справочники.ЭтапыПодготовкиБюджетов.ПолноеИмя());
	Обработчик.ЧитаемыеОбъекты = СтрСоединить(Читаемые, ",");
	
	Изменяемые = Новый Массив;
	Изменяемые.Добавить(Метаданные.Справочники.ЭтапыПодготовкиБюджетов.ПолноеИмя());
	Обработчик.ИзменяемыеОбъекты = СтрСоединить(Изменяемые, ",");
	
	Блокируемые = Новый Массив;
	Блокируемые.Добавить(Метаданные.Справочники.ЭтапыПодготовкиБюджетов.ПолноеИмя());
	Обработчик.БлокируемыеОбъекты = СтрСоединить(Блокируемые, ",");

КонецПроцедуры

// Описание
// 
// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
Процедура ЗарегистрироватьДанныеКОбработкеДляПереходаНаНовуюВерсию(Параметры = Неопределено) Экспорт
	
	ИмяОбъектаМетаданных = Метаданные.Справочники.ЭтапыПодготовкиБюджетов.ПолноеИмя();
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ИмяОбъектаМетаданных;
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ЭтапыПодготовкиБюджетов.Ссылка КАК Ссылка,
	|	ЭтапыПодготовкиБюджетов.НастройкаДействия КАК НастройкаДействия
	|ИЗ
	|	Справочник.ЭтапыПодготовкиБюджетов КАК ЭтапыПодготовкиБюджетов
	|ГДЕ
	|	ЭтапыПодготовкиБюджетов.Действие = ЗНАЧЕНИЕ(Перечисление.ТипыДействийЭтаповПодготовкиБюджетов.ВводБюджетов)";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Результат = Запрос.Выполнить();
	
	ТаблицаРезультат = Результат.Выгрузить();
	СсылкиКОбработке = Новый Массив;
	Для Каждого СтрокаТаблицы Из ТаблицаРезультат Цикл
		НастройкаДействия = СтрокаТаблицы.НастройкаДействия.Получить();
		Если ТипЗнч(НастройкаДействия) = Тип("ТаблицаЗначений") Тогда
			СтрокаВидыБюджетов = НастройкаДействия.Найти("ВидыБюджетов", "Имя");
			Если СтрокаВидыБюджетов = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ТаблицаВидыБюджетов = СтрокаВидыБюджетов.Значение; // -ТаблицаЗначений-
			Если ТаблицаВидыБюджетов.Колонки.Найти("Действие") = Неопределено Тогда
				СсылкиКОбработке.Добавить(СтрокаТаблицы.Ссылка);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, СсылкиКОбработке);
	
КонецПроцедуры

Процедура ОбработатьДанныеДляПереходаНаНовуюВерсию(Параметры) Экспорт
	
	ОбъектМетаданных = Метаданные.Справочники.ЭтапыПодготовкиБюджетов;
	ИмяОбъектаМетаданных = ОбъектМетаданных.ПолноеИмя();
	
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если ОбновляемыеДанные.Количество() = 0 Тогда
		Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ИмяОбъектаМетаданных);
		Возврат;
	КонецЕсли;
	
	Для Каждого Выборка Из ОбновляемыеДанные Цикл
		НачатьТранзакцию();
		
		Попытка
			
			Этап = Выборка.Ссылка; // СправочникСсылка.ЭтапыПодготовкиБюджетов - 
			
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить(ИмяОбъектаМетаданных);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Этап);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			Блокировка.Заблокировать();
			
			ЭтапОбъект = Этап.ПолучитьОбъект();
			НастройкаДействия = ЭтапОбъект.НастройкаДействия.Получить();
			СтрокаВидыБюджетов = НастройкаДействия.Найти("ВидыБюджетов", "Имя");
			Если СтрокаВидыБюджетов = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ТаблицаВидыБюджетов = СтрокаВидыБюджетов.Значение; // - ТаблицаЗначений -
			Если ТаблицаВидыБюджетов.Колонки.Найти("Действие") = Неопределено Тогда
				ТаблицаВидыБюджетов.Колонки.Добавить("Действие",
					Новый ОписаниеТипов("ПеречислениеСсылка.ТипыДействийЭкземпляровБюджетов"));
				ЭтапОбъект.НастройкаДействия = Новый ХранилищеЗначения(НастройкаДействия);
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ЭтапОбъект);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			Шаблон = НСтр("ru = 'Не удалось записать этап подготовки бюджетов %1 по причине: %2';
							|en = 'Cannot save the ""%1"" due to ""%2""'");
			
			ТекстСообщения = 	СтрШаблон(
				Шаблон,
				Этап,
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
			ЗаписьЖурналаРегистрации(
				ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
				УровеньЖурналаРегистрации.Ошибка,
				ОбъектМетаданных,,
				ТекстСообщения);
			
		КонецПопытки;
		
	КонецЦикла;
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ИмяОбъектаМетаданных);
	
КонецПроцедуры

#КонецОбласти

