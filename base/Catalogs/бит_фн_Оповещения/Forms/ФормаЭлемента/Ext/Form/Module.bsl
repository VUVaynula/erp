
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаОбъектаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);	
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
	
	Если Параметры.Ключ.Пустая() Тогда
		ПодготовитьФормуНаСервере();
	КонецЕсли;
	
	УстановитьВидимость();
	УстановитьОтборыДинамическихСписков();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ПодготовитьФормуНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	СтруктураНастройки = Новый Структура;
	СтруктураНастройки.Вставить("НастройкиКомпоновщика", Компоновщик.ПолучитьНастройки());
	ТекущийОбъект.СохранитьНастройкиКомпоновщика(СтруктураНастройки);

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ДоработатьТаблицуПолучатели(ТекущийОбъект);
	УстановитьОтборыДинамическихСписков();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВидСобытияПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.ОбъектСистемы) Тогда
		
		// Проверим соответствует ли объект системы виду события.
		Если Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ЗаписанСправочник") 
			И НЕ ВидОбъектаСистемы = ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.Справочник") Тогда
			
			Объект.ОбъектСистемы = Неопределено;
		ИначеЕсли Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ИзмененоСостояниеЗадачи") 
			И НЕ ВидОбъектаСистемы = ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.Задача") Тогда
			
			Объект.ОбъектСистемы = Неопределено;
		ИначеЕсли Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ИзмененоСостояниеПроцесса") 
			И НЕ ВидОбъектаСистемы = ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.БизнесПроцесс") Тогда
			
			Объект.ОбъектСистемы = Неопределено;
		ИначеЕсли Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ДокументыДляВизирования") Тогда
			
			Объект.ОбъектСистемы = Неопределено;
		ИначеЕсли Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ИзмененаДатаПлатежа")
			И НЕ Объект.ОбъектСистемы = ПлатежнаяПозиция Тогда
			
			Объект.ОбъектСистемы = Неопределено;
		Иначе	
			Если НЕ ВидОбъектаСистемы = ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.Документ") Тогда
				Объект.ОбъектСистемы = Неопределено;
			КонецЕсли; 
			
			Если ОграничитьСписокОбъектов() Тогда
				Если КэшЗначений.СписокВизируемыхОбъектов.НайтиПоЗначению(Объект.ОбъектСистемы) = Неопределено Тогда
					Объект.ОбъектСистемы = Неопределено;
				КонецЕсли; 
			КонецЕсли; // Проверка на вхождение в список визируемых.
		КонецЕсли; // По виду события.
		
	КонецЕсли;
	
	ВидСобытияИзменение();
	
КонецПроцедуры

// Процедура - обработчик события "ПриИзменении" поля ввода "ВидСобытия".
// 
&НаСервере
Процедура ВидСобытияИзменение()
	
	УстановитьОбъектПоВидуСобытия();
	ИзменениеОбъектаСистемы();
	ИнициализироватьКомпоновщик();
	УстановитьВидимость();
	
КонецПроцедуры

// Функция определяет необходимость инициализации компоновщика.
//
// Возвращаемое значение:
//  Результат - Булево.
//
&НаСервере
Функция НеобходимоИнициализироватьКомпоновщик()

	Результат = Ложь;
	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		Если Объект.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.НапоминанияПоГрафикуНачислений
			ИЛИ Объект.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.НапоминанияПоГрафикуПлатежей
			ИЛИ Объект.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ОкончаниеСрокаДействияДоговора
			ИЛИ Объект.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.НапоминанияОбОплате Тогда
			
			Результат = Истина;
		КонецЕсли;	
	ИначеЕсли бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
		Если Объект.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ОкончаниеСрокаДействияДоговора
			ИЛИ Объект.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.НапоминанияОбОплате Тогда
			Результат = Истина;
		КонецЕсли;
	КонецЕсли; 

	Возврат Результат;
	
КонецФункции // НеобходимоИнициализироватьКомпоновщик()

// Процедура инциализирует компоновщик.
// 
// Параметры:
// 
&НаСервере
Процедура ИнициализироватьКомпоновщик()

	Если НеобходимоИнициализироватьКомпоновщик() Тогда

		ТекОбъект = ДанныеФормыВЗначение(Объект, Тип("СправочникОбъект.бит_фн_Оповещения"));
			
		ТекОбъект.ИнициализироватьКомпоновщик(Объект.ВидСобытия, Компоновщик);
		
	КонецЕсли;
	
КонецПроцедуры // ИнициализироватьКомпоновщик()

// Процедура - обработчик события "НачалоВыбора" поля ввода "ОбъектСистемы".
// 
&НаКлиенте
Процедура ОбъектСистемыНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	СписокВидовОбъектов = Новый СписокЗначений;
	Если Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ЗаписанСправочник") Тогда
		СписокВидовОбъектов.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.Справочник"));
	ИначеЕсли Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ИзмененоСостояниеПроцесса") Тогда
		СписокВидовОбъектов.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.БизнесПроцесс"));
	ИначеЕсли Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ИзмененоСостояниеЗадачи") Тогда
		СписокВидовОбъектов.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.Задача"));
	// ++ ЕРП
	ИначеЕсли Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ПринятоРешение") 
		ИЛИ Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.УстановленСтатус") 
		ИЛИ Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ДоступнаВиза") Тогда
		
		СписокВидовОбъектов.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.Документ"));
		СписокВидовОбъектов.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.Справочник"));
	// -- ЕРП
	ИначеЕсли Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ДокументыДляВизирования") Тогда
		СписокВидовОбъектов.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.Обработка"));
	Иначе	
		СписокВидовОбъектов.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.Документ"));
	КонецЕсли; 
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТекущийОбъектСистемы"   ,Объект.ОбъектСистемы);
	ПараметрыФормы.Вставить("ВидыОбъектов"           ,СписокВидовОбъектов);
	Если Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ИзмененаДатаПлатежа") Тогда 
		ДоступныеОбъектыСистемы = Новый СписокЗначений;
		Если ЗначениеЗаполнено(ПлатежнаяПозиция) Тогда			
			ДоступныеОбъектыСистемы.Добавить(ПлатежнаяПозиция);			
		КонецЕсли; 
		ПараметрыФормы.Вставить("ДоступныеОбъектыСистемы", ДоступныеОбъектыСистемы);
	ИначеЕсли Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ДокументыДляВизирования") Тогда	
		ДоступныеОбъектыСистемы = ОбработкиВизирования();
		ПараметрыФормы.Вставить("ДоступныеОбъектыСистемы", ДоступныеОбъектыСистемы);
	ИначеЕсли ОграничитьСписокОбъектов() Тогда
		ПараметрыФормы.Вставить("ДоступныеОбъектыСистемы", КэшЗначений.СписокВизируемыхОбъектов);	
	КонецЕсли; 	
	
	ОткрытьФорму("ОбщаяФорма.бит_ФормаВыбораОбъектовСистемы", ПараметрыФормы, Элемент);
	
КонецПроцедуры

// Процедура - обработчик события "ПриИзменении" поля ввода "ПользовательскоеУсловие".
// 
&НаКлиенте
Процедура ПользовательскоеУсловиеПриИзменении(Элемент)
	
	ОбновитьДеревоУсловия();
	РазвернутьДерево();	
	
КонецПроцедуры

&НаКлиенте
Процедура НаименованиеНачалоВыбораИзСписка(Элемент, СтандартнаяОбработка)
	
	Элемент.СписокВыбора.Очистить();
	
	Если Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.УстановленСтатус") Тогда
		СтрокаВыбора = НСтр("ru = '%1 ""%2""'; en = '%1 ""%2""'");
		СтрокаВыбора = СтрШаблон(СтрокаВыбора, 
		                         Объект.ВидСобытия,
								 Объект.Статус);
	ИначеЕсли Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ПринятоРешение") Тогда
		СтрокаВыбора = НСтр("ru = '%1 ""%2"" по визе ""%3""'; en = '%1 ""%2"" on visa ""%3""'");
		СтрокаВыбора = СтрШаблон(СтрокаВыбора, 
		                         Объект.ВидСобытия,
								 Объект.Решение,
								 Объект.Виза);
	Иначе	
		СтрокаВыбора = НСтр("ru = '%1'; en = '%1'");
		СтрокаВыбора = СтрШаблон(СтрокаВыбора, Объект.ВидСобытия);
	КонецЕсли;
	
	Элемент.СписокВыбора.Добавить(СтрокаВыбора);
	
КонецПроцедуры // НаименованиеНачалоВыбораИзСписка

&НаКлиенте
Процедура НаименованиеАвтоПодбор(Элемент, Текст, ДанныеВыбора, Параметры, Ожидание, СтандартнаяОбработка)
	
	Элемент.СписокВыбора.Очистить();
	
	Если Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.УстановленСтатус") Тогда
		СтрВыбора = НСтр("ru = '%1 ""%2""'; en = '%1 ""%2""'");
		СтрВыбора = СтрШаблон(СтрВыбора, Объект.ВидСобытия, Объект.Статус);
	ИначеЕсли Объект.ВидСобытия = ПредопределенноеЗначение("Перечисление.бит_фн_ВидыСобытийОповещений.ПринятоРешение") Тогда	
		СтрВыбора = НСтр("ru = '%1 ""%2"" по визе ""%3""'; en = '%1 ""%2"" on visa ""%3""'");
		СтрВыбора = СтрШаблон(СтрВыбора, Объект.ВидСобытия, Объект.Решение, Объект.Виза);
	Иначе	
		СтрВыбора = НСтр("ru = '%1'; en = '%1'");
		СтрВыбора = СтрШаблон(СтрВыбора, Объект.ВидСобытия);
	КонецЕсли; 
	
	Элемент.СписокВыбора.Добавить(СтрВыбора);
	
КонецПроцедуры // НаименованиеАвтоПодбор()

