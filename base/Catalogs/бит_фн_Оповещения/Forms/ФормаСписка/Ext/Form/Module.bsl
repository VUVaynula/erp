
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.СписокПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НазначитьОповещение(Команда)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено И НЕ ТекущиеДанные.ЭтоГруппа Тогда
		ЗначенияЗаполнения = Новый Структура;
		ЗначенияЗаполнения.Вставить("ВидСобытия",	ТекущиеДанные.ВидСобытия);
		ЗначенияЗаполнения.Вставить("ОбъектСистемы",ТекущиеДанные.ОбъектСистемы);
		ЗначенияЗаполнения.Вставить("Оповещение",	ТекущиеДанные.Ссылка);
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
		ОписаниеОповещения = Новый ОписаниеОповещения("НазначитьОповещениеЗавершение", ЭтотОбъект);
		ОткрытьФорму("РегистрСведений.бит_фн_НазначениеОповещений.ФормаЗаписи", СтруктураПараметров, ЭтотОбъект,,,,ОписаниеОповещения);
	КонецЕсли;
	
КонецПроцедуры

// Процедура обработчик оповещения "ЕдиницаИзмеренияВопросЗавершение".
// 
// Параметры:
// Результат - Значение, переданное при вызове метода Закрыть открываемой формы.
// ДополнительныеПараметры - Структура.
// 
&НаКлиенте
Процедура НазначитьОповещениеЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Элементы.Список.Обновить();
	
КонецПроцедуры

#КонецОбласти
