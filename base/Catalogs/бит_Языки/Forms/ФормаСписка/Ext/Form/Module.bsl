	РежимОкна  = РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс;	
	ОткрытьФорму("Справочник.бит_Языки.Форма.ФормаПодбора",, ЭтотОбъект,,,,, РежимОкна);
	
КонецПроцедуры

#КонецОбласти

