#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	ПарамРБ = бит_РегламентныеЗакрытия.ПараметрыРегистраБухгалтерии(РегистрБухгалтерии);
	МаксКоличествоРесурсовНастройки = Справочники.бит_НастройкиЗакрытия.МаксимальноеКоличествоРесурсовНастройки();
	
	// Если это регистр бюджетирования, тогда
	// Проверим заполненность имени показателя ЦФО.	
	Если ПарамРБ.ЭтоРегистрБюдж Тогда
		ПроверяемыеРеквизиты.Добавить("ИмяПоказателяЦФО");
	КонецЕсли;
	
	// Проверка табличной части закрытие
	Для каждого СтрокаИмена Из ИменаРесурсов Цикл
		ПроверяемыеРеквизиты.Добавить("Закрытие.ИмяПоказателя"+СтрокаИмена.ИмяРеквизита);
	КонецЦикла; 
	
	ПроверитьЗаполнениеТЧЗакрытие(Отказ);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПроверитьЗаполнениеТЧЗакрытие(Отказ)

	// Проверка на идентичность имен в строке.
	РеквизитыТЧ = Метаданные.Справочники.бит_НастройкиЗакрытия.ТабличныеЧасти.Закрытие.Реквизиты;
	ПоляТаблицы = Новый СписокЗначений;
	ПоляТаблицы.Добавить("ИмяПоказателяВалютнаяСумма");
	ПоляТаблицы.Добавить("ИмяПоказателяСумма1");
	ПоляТаблицы.Добавить("ИмяПоказателяСумма2");
	ПоляТаблицы.Добавить("ИмяПоказателяСумма3");
	ПоляТаблицы.Добавить("ИмяПоказателяКоличество");
	Для каждого Поле Из ПоляТаблицы Цикл
		Поле.Представление = РеквизитыТЧ[Поле.Значение].Представление();	
	КонецЦикла; 
	
	Ресурсы = Новый Массив;
	Ресурсы.Добавить("Сумма");
	Ресурсы.Добавить("СуммаРегл");
	Ресурсы.Добавить("СуммаУпр");
	
	Префикс = "Закрытие[%1].%2";
	Для каждого СтрокаТаблицы Из Закрытие Цикл
		Для каждого Ресурс Из Ресурсы Цикл
			Количество	  = 0;
			ПоляСОшибками = Новый Массив; 
			Для каждого Поле Из ПоляТаблицы Цикл
				Если СтрокаТаблицы[Поле.Значение] = Ресурс Тогда
					Количество = Количество + 1;
					Если Количество > 1 Тогда
						ПоляСОшибками.Добавить(Поле);
					КонецЕсли;
				КонецЕсли; 
			КонецЦикла; 
			ТекстПримечания = НСтр("ru = 'Повторяется ресурс ""%1"".'"); 
			Если ЗначениеЗаполнено(ПоляСОшибками) Тогда
				Для каждого Поле Из ПоляСОшибками Цикл
					ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка" , "КОРРЕКТНОСТЬ", 
										Поле.Представление, СтрокаТаблицы.НомерСтроки, НСтр("ru = 'Закрытие'"), 
										СтрШаблон(ТекстПримечания, Ресурс));
					Колонка = СтрШаблон(Префикс, СтрокаТаблицы.НомерСтроки - 1, Поле.Значение);
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Колонка, ,Отказ); 
				КонецЦикла; 
			КонецЕсли; 
		КонецЦикла;
		
		Если СтрокаТаблицы.ВидЗакрытия = Перечисления.бит_ВидыЗакрытия.Распределение Тогда
			Количество = 0;
			Для каждого Поле Из ПоляТаблицы Цикл
				Если СтрокаТаблицы[Поле.Значение] = "Сумма" Тогда
					Прервать;
				Иначе	
					Количество = Количество + 1;
				КонецЕсли;	
			КонецЦикла; 
			
			Если Количество = ПоляТаблицы.Количество() Тогда
				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка" , "КОРРЕКТНОСТЬ", 
									Поле.Представление, СтрокаТаблицы.НомерСтроки, НСтр("ru = 'Закрытие'"), 
									СтрШаблон(ТекстПримечания, Ресурс));
				Колонка = СтрШаблон(Префикс, СтрокаТаблицы.НомерСтроки - 1, Поле.Значение);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Колонка, ,Отказ); 

				ТекстСообщения = СтрШаблон(НСтр("ru='В строке %1 нет ни одного значения с именем ""Сумма"".';
									|en='The line number %1 no value to the ""Amount"" name.'"),
										СтрокаТаблицы.НомерСтроки);
										
				Колонка = СтрШаблон(Префикс, СтрокаТаблицы.НомерСтроки - 1, "НомерСтроки");						
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, , ,Отказ); 
			КонецЕсли; 
		КонецЕсли; 

		СтрИндекс = Формат(СтрокаТаблицы.НомерСтроки-1,"ЧН=0; ЧГ="); 
		Если СтрокаТаблицы.ВидЗакрытия = Перечисления.бит_ВидыЗакрытия.Простое И НЕ ЗначениеЗаполнено(СтрокаТаблицы.СчетЗакрытия) Тогда
			
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка" , "ЗАПОЛНЕНИЕ", 
									НСтр("ru = 'Счет закрытия'") , СтрокаТаблицы.НомерСтроки, НСтр("ru = 'Закрытие'"), 
									СтрШаблон(ТекстПримечания, Ресурс));
									
			Колонка	= СтрШаблон(Префикс, СтрокаТаблицы.НомерСтроки - 1, "СчетЗакрытия");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Колонка, , Отказ);
			
		ИначеЕсли СтрокаТаблицы.ВидЗакрытия = Перечисления.бит_ВидыЗакрытия.Распределение И НЕ ЗначениеЗаполнено(СтрокаТаблицы.База) Тогда	
			
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка" , "ЗАПОЛНЕНИЕ", 
									НСтр("ru = 'База'") , СтрокаТаблицы.НомерСтроки, НСтр("ru = 'Закрытие'"), 
									СтрШаблон(ТекстПримечания, Ресурс));
			
			Колонка = СтрШаблон(Префикс, СтрокаТаблицы.НомерСтроки - 1, "База");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Колонка,, Отказ);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли