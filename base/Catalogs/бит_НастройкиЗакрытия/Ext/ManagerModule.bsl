// Функция формирует список субконто.
// 
// Параметры:
//  КоличествоСубконто - Число
//  ЕстьПодразделение - Булево
// 
// Возвращаемое значение:
//  СписокСубконто - СписокЗначений.
// 
Функция СформироватьСписокСубконто(КоличествоСубконто, ЕстьПодразделение) Экспорт
	
	СписокСубконто = Новый СписокЗначений;
	
	Для Сч = 1 По КоличествоСубконто Цикл		
		СписокСубконто.Добавить("Субконто"+Сч, НСтр("ru='Субконто';en='Subconto'")+Сч);		
	КонецЦикла; 
	
	Если ЕстьПодразделение Тогда		
		СписокСубконто.Добавить("Подразделение", НСтр("ru='Подразделение';en='Department'"));		
	КонецЕсли; 
	
	Возврат СписокСубконто;
	
КонецФункции // СформироватьСписокСубконто()

Процедура СформироватьСписокСпособовЗаполненияСубконто(Форма) Экспорт
	
	СпособыЗаполнения 		 = Форма.СпособыЗаполнения;
	СпособыЗаполненияПростой = Форма.СпособыЗаполненияПростой;
	КоличествоСубконто 		 = Форма.ПараметрыРБ.МинКоличествоСубконто;
	ЕстьПодразделение 		 = Форма.ПараметрыРБ.ЕстьПодразделение;
	
	СпособыЗаполнения.Очистить();
	СпособыЗаполненияПростой.Очистить();
	
	Для Ном = 1 По КоличествоСубконто Цикл
		СпособыЗаполнения.Добавить("ДанныеСубконто"    + Ном);
		СпособыЗаполненияПростой.Добавить("Субконто"   + Ном);
	КонецЦикла;
	
	Если ЕстьПодразделение  Тогда
		СпособыЗаполнения.Добавить("ДанныеПодразделение");
		СпособыЗаполненияПростой.Добавить("Подразделение");
	КонецЕсли;	
	
	Для Ном = 1 По КоличествоСубконто Цикл
		СпособыЗаполнения.Добавить("ДанныеКорСубконто" + Ном);
		СпособыЗаполненияПростой.Добавить("КорСубконто" + Ном);
	КонецЦикла;
	
	Если ЕстьПодразделение  Тогда
		СпособыЗаполнения.Добавить("ДанныеКорПодразделение");
		СпособыЗаполненияПростой.Добавить("КорПодразделение");
	КонецЕсли;	
	
	Для Ном = 1 По КоличествоСубконто Цикл
		СпособыЗаполнения.Добавить("БазаСубконто" + Ном);
	КонецЦикла;
	
	Если ЕстьПодразделение Тогда
		СпособыЗаполнения.Добавить("БазаПодразделение");
	КонецЕсли;
	
	Для Ном = 1 По КоличествоСубконто Цикл
		СпособыЗаполнения.Добавить("БазаКорСубконто" + Ном);
	КонецЦикла;
	
	Если ЕстьПодразделение Тогда
		СпособыЗаполнения.Добавить("БазаКорПодразделение");
	КонецЕсли;

	СпособыЗаполнения.Добавить("Явно",  НСтр("ru='Указано явно';en='Clearly stated'"));
	СпособыЗаполненияПростой.Добавить("Явно", НСтр("ru='Указано явно';en='Clearly stated'"));
	
КонецПроцедуры // СформироватьСписокСпособовЗаполненияСубконто()

#КонецОбласти 	

