
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИменаРесурсов = Параметры.ИменаРесурсов;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПоКнопкеГотово(Команда)
	
	Сформировать();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура Сформировать()

	Успех = Ложь;
	Для каждого Элемент Из ИменаРесурсов Цикл
		Если Элемент.Пометка Тогда
			Успех = Истина;		
			Прервать;
		КонецЕсли;	
	КонецЦикла; 
	
	Если НЕ Успех Тогда
		ТекстСообщения = НСтр("ru = 'В списке ресурсров не выбранно ни одного ресурса.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "ИменаРесурсов"); 
		Возврат;
	КонецЕсли;

	Закрыть(ИменаРесурсов);

КонецПроцедуры

#КонецОбласти