
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаОбъектаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
		
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если Параметры.Ключ.Пустая() Тогда
		ПодготовитьФормуНаСервере();
	КонецЕсли;
			
	// Условное оформление субконто
	бит_БухгалтерскийУчет.УстановитьОформлениеСубконтоТаблицы(УсловноеОформление,
		"Закрытие", "СубконтоЗакрытия", "КоличествоДоступныхСубконтоЗакрытия",
		МаксКоличествоСубконтоНастройки);														   
															   
	УстановитьУсловноеОформление();
	УстановитьПараметрыВыбораДляСчетов();
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ПодготовитьФормуНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ПодготовитьФормуНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура РегистрБухгалтерииПриИзменении(Элемент)
	
	Если Объект.РегистрБухгалтерии = ТекущийРегистрБухгалтерии Тогда
		Возврат;	
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("РегистрБухгалтерииПриИзмененииЗавершение", ЭтотОбъект);
	
	Если Объект.Закрытие.Количество() > 0 Тогда
		ТекстСообщения = НСтр("ru='Табличная часть будет очищена. Продолжить?';
							  |en='Tabular section will be cleaned. Continue?'");
		
		ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет,, КодВозвратаДиалога.Нет);
	Иначе
		ВыполнитьОбработкуОповещения(Оповещение, КодВозвратаДиалога.Да);
	КонецЕсли; 
	
КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
// 
&НаКлиенте
Процедура РегистрБухгалтерииПриИзмененииЗавершение(Ответ, ДопПараметры) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда
		РегистрБухгалтерииПриИзмененииНаСервере();	
	Иначе
		Объект.РегистрБухгалтерии = ТекущийРегистрБухгалтерии;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗакрытие

&НаКлиенте
Процедура ЗакрытиеПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТекущаяСтрока = Элементы.Закрытие.ТекущиеДанные;
	
	Если НоваяСтрока Тогда
		ТекущаяСтрока.ИД = Строка( Новый УникальныйИдентификатор);
		Если НЕ Копирование Тогда
			ТекущаяСтрока.СчетЗакрытия = ПараметрыРБ.ПустойСчет;
			ТекущаяСтрока.ВидЗакрытия = ПредопределенноеЗначение("Перечисление.бит_ВидыЗакрытия.Простое");
		КонецЕсли; 
	КонецЕсли; 
	
	УстановитьСпискиВыбораСпособаЗаполнения();
	УстановитьСпискиВыбораПолейИРесурсовИсточника();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытиеВидЗакрытияПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Закрытие.ТекущиеДанные;
	
	УстановитьСпискиВыбораСпособаЗаполнения();
	
	// Очистим недоступные способы заполнения субконто
	// для выбранного вида закрытия.
	ЭтоРаспределение = ТекущаяСтрока.ВидЗакрытия = ПредопределенноеЗначение("Перечисление.бит_ВидыЗакрытия.Распределение");
	Если ЭтоРаспределение Тогда
		Список = СпособыЗаполнения;
	Иначе	
		Список = СпособыЗаполненияПростой;
	КонецЕсли;

	Для Ном = 1 По ПараметрыРБ.МинКоличествоСубконто Цикл
		Если Список.НайтиПоЗначению(ТекущаяСтрока["СпособЗаполненияСубконто" + Ном]) = Неопределено Тогда
			ТекущаяСтрока["СпособЗаполненияСубконто" + Ном] = "";			 
		КонецЕсли; 
	КонецЦикла; 
	
	Если НЕ ЭтоРаспределение Тогда
	    // Очистим поля заполняющиеся для распределения.		
		Для Ном = 1 По ПараметрыРБ.МинКоличествоСубконто Цикл
			ТекущаяСтрока["ПолеБазы"   + Ном] = "";
			ТекущаяСтрока["ПолеДанных" + Ном] = "";
		КонецЦикла;
	КонецЕсли; 
	
	Если ИспользуетсяРаспределение <> ИспользуетсяРаспределение(ЭтотОбъект) Тогда
		ИспользуетсяРаспределение = НЕ ИспользуетсяРаспределение;
	    УправлениеФормой(ЭтотОбъект);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытиеДанныеПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Закрытие.ТекущиеДанные;
	ПриИзмененииИсточникаДанныхНаСервере(ТекущаяСтрока.ПолучитьИдентификатор());
	УстановитьСпискиВыбораПолейИРесурсовИсточника();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытиеСчетЗакрытияПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Закрытие.ТекущиеДанные;
	ЗакрытиеСчетЗакрытияПриИзмененииНаСервере(ТекущаяСтрока.ПолучитьИдентификатор());
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытиеСубконтоЗакрытияПриИзменении(Элемент)
	
	ТекущаяСтрока     = Элементы.Закрытие.ТекущиеДанные;
	
	ЗначениеСубконто  = ПолучитьЗначениеСубконтоТабПоле(ТекущаяСтрока,"Закрытие",Элемент.Имя);		
	ИзменениеСубконтоЗакрытия(Элементы.Закрытие.ТекущиеДанные,ЗначениеСубконто);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытиеСубконтоЗакрытияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные     = Элементы.Закрытие.ТекущиеДанные;
	ЗначениеСубконто  = ПолучитьЗначениеСубконтоТабПоле(ТекущиеДанные, "Закрытие", Элемент.Имя);
	
	Если НЕ ЗначениеЗаполнено(ЗначениеСубконто) Тогда
	   Элемент.ВыбиратьТип = Истина;
	Иначе	
	   Элемент.ВыбиратьТип = Ложь;
	КонецЕсли; 
	
	ОграничениеСубконто = ПолучитьОграничениеТипаДляСубконто(Элемент.Имя, ТекущиеДанные);
	
	Элемент.ОграничениеТипа = ОграничениеСубконто;
	
	НачалоВыбораСубконтоЗакрытия(Элемент,СтандартнаяОбработка,ТекущиеДанные,ЗначениеСубконто);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытиеСпособЗаполненияСубконто1ПриИзменении(Элемент)

	ТекущиеДанные = Элементы.Закрытие.ТекущиеДанные;
