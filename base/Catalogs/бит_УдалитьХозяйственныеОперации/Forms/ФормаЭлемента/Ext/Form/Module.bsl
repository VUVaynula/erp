
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗаполнитьКэшированныеЗначения(мКэшЗначений);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	
	Объект.Наименование = Элемент.ТекстРедактирования;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектСистемыНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СписокВидовОбъектов = Новый СписокЗначений;
	СписокВидовОбъектов.Добавить(мКэшЗначений.ВидОбъектаДокумент);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВидыОбъектов",				СписокВидовОбъектов);
	ПараметрыФормы.Вставить("ТекущийОбъектСистемы",		мКэшЗначений.ОбъектСистемы);
	ПараметрыФормы.Вставить("ДоступныеОбъектыСистемы",	мКэшЗначений.ДоступныеОбъектыСистемы);
	ОткрытьФорму("ОбщаяФорма.бит_ФормаВыбораОбъектовСистемы", ПараметрыФормы, Элемент);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

//  Процедура заполняет кэш значений, необходимый при работе на клиенте.
//
&НаСервере
Процедура ЗаполнитьКэшированныеЗначения(КэшированныеЗначения)
	
	КэшированныеЗначения = Новый Структура;
	КэшированныеЗначения.Вставить("ВидОбъектаДокумент" ,Перечисления.бит_ВидыОбъектовСистемы.Документ);

	ДоступныеОбъектыСистемы = Новый СписокЗначений;

	Если Метаданные.Документы.Найти("бит_кзн_ПлатежнаяПозиция") <> Неопределено Тогда 	
		// + Документ бит_кзн_ПлатежнаяПозиция
		ОбъектСистемы = бит_ПраваДоступа.ПолучитьОбъектДоступаПоМетаданным(Метаданные.Документы.бит_кзн_ПлатежнаяПозиция);
		ДоступныеОбъектыСистемы.Добавить(ОбъектСистемы);
	КонецЕсли;
	
	Если Метаданные.Документы.Найти("бит_кзн_ПозицияПоступления") <> Неопределено Тогда 	
		// + Документ бит_кзн_ПозицияПоступления
		ОбъектСистемы = бит_ПраваДоступа.ПолучитьОбъектДоступаПоМетаданным(Метаданные.Документы.бит_кзн_ПозицияПоступления);
		ДоступныеОбъектыСистемы.Добавить(ОбъектСистемы);
	КонецЕсли;
	
	Если Метаданные.Документы.Найти("бит_кзн_ЗаявкаНаРасходованиеСредств") <> Неопределено Тогда 	
		// + Документ бит_кзн_ПозицияПоступления
		ОбъектСистемы = бит_ПраваДоступа.ПолучитьОбъектДоступаПоМетаданным(Метаданные.Документы.бит_кзн_ЗаявкаНаРасходованиеСредств);
		ДоступныеОбъектыСистемы.Добавить(ОбъектСистемы);
	КонецЕсли;
	
	Если Метаданные.Документы.Найти("бит_кзн_ПланируемоеПоступлениеДенежныхСредств") <> Неопределено Тогда 	
		// + Документ бит_кзн_ПозицияПоступления
		ОбъектСистемы = бит_ПраваДоступа.ПолучитьОбъектДоступаПоМетаданным(Метаданные.Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств);
		ДоступныеОбъектыСистемы.Добавить(ОбъектСистемы);
	КонецЕсли;
	
	Если Метаданные.Документы.Найти("бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") <> Неопределено Тогда 	
		// + Документ бит_кзн_ПозицияПоступления
		ОбъектСистемы = бит_ПраваДоступа.ПолучитьОбъектДоступаПоМетаданным(Метаданные.Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств);
		ДоступныеОбъектыСистемы.Добавить(ОбъектСистемы);
	КонецЕсли;
	
	КэшированныеЗначения.Вставить("ДоступныеОбъектыСистемы", ДоступныеОбъектыСистемы);	
	
	ОбъектСистемы = бит_ПраваДоступа.ПолучитьОбъектДоступаПоМетаданным(Метаданные.Документы.бит_кзн_ЗаявкаНаРасходованиеСредств);
	КэшированныеЗначения.Вставить("ОбъектСистемы", ОбъектСистемы);	
 
КонецПроцедуры

#КонецОбласти

