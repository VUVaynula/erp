
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// АПК:1297-выкл Строковый параметр.
	ИмяДополнительногоПоля = "ДополнительноеПоле1";
	ИмяПоляПриемника       = "СтатьяОборотов";
	// АПК:1297-вкл
	
	ШаблонВыражения = 
	"// Добавление нового движения в приемник
	|Если ЗначениеЗаполнено(ДополнительныеДанные[""%ИмяДополнительногоПоля%""]) И НЕ Отказ  Тогда
	|	
	|	НоваяЗапись = НаборПриемник.Добавить();
	|	ЗаполнитьЗначенияСвойств(НоваяЗапись, ЗаписьПриемник, , ""ВидДвижения"");
	|	НоваяЗапись[""%ИмяПоляПриемника%""] = ДополнительныеДанные[""%ИмяДополнительногоПоля%""];
	|
	|	Если НЕ НоваяЗапись = Неопределено Тогда
	|		ПараметрыЗаписи = НовыеПараметрыЗаписиСоответствияДвижений();
	|		ПараметрыЗаписи.Реквизиты 			 = СтруктураШапкиДокумента;
	|		ПараметрыЗаписи.СтороныТрансляции 	 = СтруктураПараметров; 
	|		ПараметрыЗаписи.НомерСтрокиИсточника = Ном;
	|		ПараметрыЗаписи.НомерСтрокиПриемника = НаборПриемник.Количество() - 1;
	|		ПараметрыЗаписи.Активность 			 = НоваяЗапись.Активность;
	|		// Можно добавить комментарий:
	|		ПараметрыЗаписи.СлужебнаяОтметкаДт   = """"; // В контексте доступна заполненная переменная СлужебнаяОтметкаДт;
	|		ПараметрыЗаписи.СлужебнаяОтметкаКт	 = """"; // В контексте доступна заполненная переменная СлужебнаяОтметкаКт;
	|
	|		Подключаемый_ДобавитьЗаписьСоответствияДвижений(НаборСоответствие, ПараметрыЗаписи);
	|	КонецЕсли;   
	|КонецЕсли;
	|";
	
	ОбновитьВыражениеРезультат(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ИмяДополнительногоПоляПриИзменении(Элемент)
	
	ОбновитьВыражениеРезультат(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяПоляПриемникаПриИзменении(Элемент)
	
	ОбновитьВыражениеРезультат(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)
	
	ОбновитьВыражениеРезультат(ЭтотОбъект);
	Закрыть(ВыражениеРезультат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста 
Процедура ОбновитьВыражениеРезультат(Форма)

	ВыражениеРезультат = Форма.ШаблонВыражения;
	ВыражениеРезультат = СтрЗаменить(ВыражениеРезультат, "%ИмяДополнительногоПоля%", Форма.ИмяДополнительногоПоля);
	ВыражениеРезультат = СтрЗаменить(ВыражениеРезультат, "%ИмяПоляПриемника%"      , Форма.ИмяПоляПриемника);
	
	Форма.ВыражениеРезультат = ВыражениеРезультат;
	
КонецПроцедуры // ОбновитьВыражениеРезультат()

#КонецОбласти


