
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОписаниеТипов = Неопределено;
	Массив = Новый Массив;
		
	Если Объект.Ссылка = Справочники.бит_ЗначенияПоУмолчанию.ГФУНоменклатурыГП Тогда
			
		Массив.Добавить(Тип("СправочникСсылка.ГруппыФинансовогоУчетаНоменклатуры"));
		
	ИначеЕсли Объект.Ссылка = Справочники.бит_ЗначенияПоУмолчанию.ПриоритетЗаказаНаПеремещение Тогда
			
		Массив.Добавить(Тип("СправочникСсылка.Приоритеты"));
		
	ИначеЕсли Объект.Ссылка = Справочники.бит_ЗначенияПоУмолчанию.ПриоритетЗаказаНаПеремещение Тогда
		
		Массив.Добавить(Тип("СправочникСсылка.ВидыЦен"));
		
	ИначеЕсли Объект.Ссылка = Справочники.бит_ЗначенияПоУмолчанию.ВидыНоменклатурыДляРасчетаПлановыхКалькуляций Тогда
		
		Массив.Добавить(Тип("СправочникСсылка.ВидыНоменклатуры"));
		
	ИначеЕсли Объект.Ссылка = Справочники.бит_ЗначенияПоУмолчанию.Организация Тогда
		
		Массив.Добавить(Тип("СправочникСсылка.Организации"));
		
	ИначеЕсли Объект.Ссылка = Справочники.бит_ЗначенияПоУмолчанию.ПодразделениеДиспетчер Тогда
		
		Массив.Добавить(Тип("СправочникСсылка.СтруктураПредприятия"));
		
	ИначеЕсли Объект.Ссылка = Справочники.бит_ЗначенияПоУмолчанию.ПериодичностьРасчетаДни Тогда
		
		Массив.Добавить(Тип("Число"));              
		ОписаниеТипов = Новый ОписаниеТипов(Массив, , , Новый КвалификаторыЧисла(3, 0, ДопустимыйЗнак.Неотрицательный));
		
	ИначеЕсли Объект.Ссылка = Справочники.бит_ЗначенияПоУмолчанию.ВидСоответствияЦФО_Касса Тогда
		
		Массив.Добавить(Тип("СправочникСсылка.бит_ВидыСоответствийАналитик"));
		
	ИначеЕсли Объект.Ссылка = Справочники.бит_ЗначенияПоУмолчанию.РеквизитХарактеристикиПризнакЗаказногоИзделия
		ИЛИ Объект.Ссылка = Справочники.бит_ЗначенияПоУмолчанию.ЗначениеСтандартногоПризнакаИзделия Тогда
		
		Массив.Добавить(Тип("ПланВидовХарактеристикСсылка.ДополнительныеРеквизитыИСведения"));
		
	ИначеЕсли Объект.Ссылка = Справочники.бит_ЗначенияПоУмолчанию.СверхнормативныеМатериалыЗаказНаПроизводство Тогда
		
		Массив.Добавить(Тип("СправочникСсылка.СтатьиКалькуляции"));
		
	КонецЕсли;
	
	Если ОписаниеТипов = Неопределено Тогда
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
	КонецЕсли;
	
	Элементы.ЗначенияЗначение.ОграничениеТипа = ОписаниеТипов;
	Элементы.ЗначенияЗначение.Доступность = Истина;
	
КонецПроцедуры
