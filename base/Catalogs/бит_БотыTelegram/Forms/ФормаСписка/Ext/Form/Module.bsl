
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьУсловноеОформление();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()

	УсловноеОформление.Элементы.Очистить();
	
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	
	ПолеУО    = ЭлементУО.Поля.Элементы.Добавить();
	ПолеУО.Поле 		 = Новый ПолеКомпоновкиДанных("Список");
	ПолеУО.Использование = Истина;
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Список.ОбслуживатьЧаты", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.НеЗаполненноеСубконто);
	
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	
	ПолеУО    = ЭлементУО.Поля.Элементы.Добавить();
	ПолеУО.Поле 		 = Новый ПолеКомпоновкиДанных("Список");
	ПолеУО.Использование = Истина;
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Список.Ссылка", ВидСравненияКомпоновкиДанных.Равно, бит_ТелеграмПовтИсп.ГлавныйБот());
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Шрифт", ШрифтыСтиля.ОсновнойЭлементСписка);
	
КонецПроцедуры

#КонецОбласти