
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	КопироватьПравилаЗаполнения = Параметры.КопироватьПравилаЗаполнения;
	КопироватьСпособКомпоновки  = Параметры.КопироватьСпособКомпоновки;
	
	Элементы.КопироватьСпособКомпоновки.Видимость = КопироватьСпособКомпоновки;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	
	Результат = НовыеСохраненныеНастройки();
	ЗаполнитьЗначенияСвойств(Результат, ЭтотОбъект);
	
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Функция НовыеСохраненныеНастройки()

	Настройки = Новый Структура; 
	Настройки.Вставить("КопироватьПравилаЗаполнения", Ложь);
	Настройки.Вставить("КопироватьСпособКомпоновки",  Ложь);
	
	Возврат Настройки;

КонецФункции
 
#КонецОбласти

