Процедура ЗаменитьДублиКлючейАналитики() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДанныеСправочника.Ссылка КАК Ссылка,
	|	ДанныеСправочника.ПометкаУдаления КАК ПометкаУдаления,
	|	Аналитика.КлючАналитики КАК КлючАналитики
	|ИЗ
	|	Справочник.бит_КлючиСценарийЦФО КАК ДанныеСправочника
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_АналитикаСценарийЦФО КАК ДанныеРегистра
	|		ПО ДанныеСправочника.Ссылка = ДанныеРегистра.КлючАналитики
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_АналитикаСценарийЦФО КАК Аналитика
	|		ПО ДанныеСправочника.Сценарий = Аналитика.Сценарий
	|			И ДанныеСправочника.ЦФО = Аналитика.ЦФО
	|ГДЕ
	|	ДанныеРегистра.КлючАналитики ЕСТЬ NULL";

	// Сформируем соответствие ключей аналитики.
	СоответствиеАналитик = Новый Соответствие;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
	
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			
			СоответствиеАналитик.Вставить(Выборка.Ссылка, Выборка.КлючАналитики);
			
			Если Не Выборка.ПометкаУдаления Тогда
				СправочникОбъект = Выборка.Ссылка.ПолучитьОбъект();
				// АПК:280-выкл - Допустимо пропустить обработку исключения, так как
				// это не останавливающая операция.
				Попытка
					СправочникОбъект.УстановитьПометкуУдаления(Истина, Ложь);
				Исключение
					// Обработка не требуется.
				КонецПопытки;
				// АПК:280-вкл.
			КонецЕсли;

		КонецЦикла;
		
		Для каждого КлючЗначение Из СоответствиеАналитик Цикл
			ПарыЗамен = Новый Соответствие;
			ПарыЗамен.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
			
			ПараметрыЗамены = ОбщегоНазначения.ПараметрыЗаменыСсылок();
			ПараметрыЗамены.ВключатьБизнесЛогику 	= Ложь;
			ПараметрыЗамены.ЗаменаПарыВТранзакции 	= Ложь;
			ПараметрыЗамены.ПривилегированнаяЗапись = Истина;
			
			ОбщегоНазначения.ЗаменитьСсылки(ПарыЗамен, ПараметрыЗамены);
		КонецЦикла; 
	КонецЕсли;
		
КонецПроцедуры

// Находит неиспользуемые ключи аналитики связанные с помеченными на удаление объектами и устанавливает
// у таких ключей пометку на удаление.
// Ключи считаются свободными если они ссылаются на Сценарий и ЦФО, помеченные на удаление, и не участвуют в движениях
// регистра накопления бит_ОборотыПоБюджетам.
//
Процедура ПометитьНаУдалениеНеиспользуемыеКлючиАналитики() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КлючиАналитики.Ссылка
	|ИЗ
	|	Справочник.бит_КлючиСценарийЦФО КАК КлючиАналитики";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ОбластьПоиска = Новый Массив;
	ОбластьПоиска.Добавить(Метаданные.Справочники.СценарииПланирования.ПолноеИмя());
	ОбластьПоиска.Добавить(Метаданные.Справочники.Подразделения.ПолноеИмя());
	
	СценарийЦФО = НайтиПомеченныеНаУдаление(Новый Массив, ОбластьПоиска);
	
	Если СценарийЦФО.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СценарийЦФО", СценарийЦФО);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КлючиАналитики.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ КлючиАналитики
	|ИЗ
	|	Справочник.бит_КлючиСценарийЦФО КАК КлючиАналитики
	|ГДЕ
	|	КлючиАналитики.Сценарий В(&СценарийЦФО)
	|	И КлючиАналитики.ЦФО В(&СценарийЦФО)
	|	И НЕ КлючиАналитики.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КлючиАналитики.Ссылка КАК Ссылка,
	|	ОборотыПоБюджетам.Сценарий КАК Сценарий
	|ПОМЕСТИТЬ НеиспользуемыеКлючи
	|ИЗ
	|	КлючиАналитики КАК КлючиАналитики
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.бит_ОборотыПоБюджетам КАК ОборотыПоБюджетам
	|		ПО КлючиАналитики.Ссылка = ОборотыПоБюджетам.КлючСценарийЦФО
	|ГДЕ
	|	ОборотыПоБюджетам.Сценарий ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НеиспользуемыеКлючи.Ссылка КАК Ссылка
	|ИЗ
	|	НеиспользуемыеКлючи КАК НеиспользуемыеКлючи";
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока РезультатЗапроса.Следующий() Цикл
		КлючАналитики = РезультатЗапроса.Ссылка.ПолучитьОбъект();
		КлючАналитики.УстановитьПометкуУдаления(Истина);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

