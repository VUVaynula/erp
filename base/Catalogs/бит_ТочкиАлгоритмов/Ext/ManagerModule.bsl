#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Функция НовыеПараметрыПроверкиЗаполнения() Экспорт
	
	ПараметрыПроверки = Новый Структура;
	ПараметрыПроверки.Вставить("ПроверятьЗацикливаниеПоВложеннойТаблице", Ложь);
	ПараметрыПроверки.Вставить("Ссылка", Справочники.бит_ТочкиАлгоритмов.ПустаяСсылка());
	ПараметрыПроверки.Вставить("ИсходящиеТочкиДляПроверкиЗацикливания",   Неопределено);
	Возврат ПараметрыПроверки;
	
КонецФункции

Процедура ПроверитьЗаполнение(РеквизитыТочки, Отказ, ПараметрыПроверки = Неопределено) Экспорт

	// 1 - несколько входящих,
	// 2 - несколько исходящих,
	// 3 - нет входящих,
	// 4 - нет исходящих,
	// 5 - неожиданные входящие точки,
	// 6 - неожиданные входящие точки,
	// 7 - точки обработки не поддерживаются алгоритмом.
	
	Если ПараметрыПроверки = Неопределено Тогда
		ПараметрыПроверки = НовыеПараметрыПроверкиЗаполнения();
	КонецЕсли;
	
	Ссылка 			  = РеквизитыТочки.Ссылка;
	Наименование 	  = РеквизитыТочки.Наименование;
	Владелец 		  = РеквизитыТочки.Владелец;
	ВидТочки 		  = РеквизитыТочки.ВидТочки;
	ВходящиеТочки 	  = РеквизитыТочки.ВходящиеТочки;
	ИсходящиеТочки 	  = РеквизитыТочки.ИсходящиеТочки;
	ПараметрыПроцесса = РеквизитыТочки.ПараметрыПроцесса;
	ВидАлгоритма      = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Владелец, "ВидАлгоритма");
	
	ЭтоПоэтапныйАлгоритм = (РеквизитыТочки.Владелец.СпособВыполнения = Перечисления.бит_СпособыВыполненияАлгоритма.Поэтапно);
	
	// Несколько входящих.
	Если ВидТочки <> Перечисления.бит_ВидыТочекАлгоритмов.Слияние
		И ВходящиеТочки.Количество() > 1
		И ВидАлгоритма <> Перечисления.бит_ВидыАлгоритмов.Прочее Тогда
		
		РазрешеныНесколькоВходищих = Ложь;
		Если ЭтоПоэтапныйАлгоритм Тогда
			Для каждого СтрокаИсходящейТочки Из ИсходящиеТочки Цикл
				Если ПараметрыПроверки.ПроверятьЗацикливаниеПоВложеннойТаблице Тогда
					Если ТочкиЗациклены(ПараметрыПроверки.Ссылка, СтрокаИсходящейТочки.Точка,
											ПараметрыПроверки.ИсходящиеТочкиДляПроверкиЗацикливания) Тогда
						РазрешеныНесколькоВходищих = Истина;
						Прервать;
					КонецЕсли;
				Иначе
					Если бит_УправлениеПроцессами.ТочкиЗациклены(Ссылка, СтрокаИсходящейТочки.Точка) Тогда
						РазрешеныНесколькоВходищих = Истина;
						Прервать;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Если НЕ РазрешеныНесколькоВходищих Тогда
			ТекстСообщения = ТекстОшибкиЗаполнения(Наименование, 1);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Владелец,,,Отказ); 
		КонецЕсли;
	КонецЕсли; 
	
	// Несколько исходящих.
	Если ВидТочки <> Перечисления.бит_ВидыТочекАлгоритмов.Разделение
		И ВидТочки <> Перечисления.бит_ВидыТочекАлгоритмов.ВыборВарианта
		И ИсходящиеТочки.Количество() > 1 Тогда
		Если ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Условие Тогда
			Если ИсходящиеТочки.Количество() > 2 Тогда
				ТекстСообщения = ТекстОшибкиЗаполнения(Наименование, 0, 
									НСтр("ru='Поддерживает только 2 связи.';en='Only supports 2 communication.'"));
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Владелец,,,Отказ);
			КонецЕсли; 
		Иначе
			ТекстСообщения = ТекстОшибкиЗаполнения(Наименование, 2);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Владелец,,,Отказ);
		КонецЕсли;
	КонецЕсли; 
	
	// Нет входящих.
	Если ВидТочки <> Перечисления.бит_ВидыТочекАлгоритмов.Старт И ВходящиеТочки.Количество() = 0 Тогда
		ТекстСообщения = ТекстОшибкиЗаполнения(Наименование, 3);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Владелец,,,Отказ); 
	КонецЕсли; 
	
	// Нет исходящих.
	Если ВидТочки <> Перечисления.бит_ВидыТочекАлгоритмов.Завершение И ИсходящиеТочки.Количество() = 0 Тогда
		ТекстСообщения = ТекстОшибкиЗаполнения(Наименование, 4);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Владелец,,,Отказ); 
	КонецЕсли;
	
	// Неожиданные входящие точки.
	Если ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Старт И ВходящиеТочки.Количество() > 0 Тогда
		ТекстСообщения = ТекстОшибкиЗаполнения(Наименование, 5);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Владелец,,,Отказ); 
	КонецЕсли; 
	
	// Неожиданные входящие точки.
	Если ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Завершение И ИсходящиеТочки.Количество() > 0 Тогда
		ТекстСообщения = ТекстОшибкиЗаполнения(Наименование, 6);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Владелец,,,Отказ); 
	КонецЕсли;
	
	// Точки обработок в необрабатываемых алгоритмах.
	Если ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Обработка
		И ВидАлгоритма <> Перечисления.бит_ВидыАлгоритмов.Визирование Тогда
		ТекстСообщения = ТекстОшибкиЗаполнения(Наименование, 7);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Владелец,,,Отказ); 
	КонецЕсли;
	
	// Связи точки Условие.
	Если ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Условие Тогда
		Отбор = Новый Структура("Направление",Перечисления.бит_Направление.Вертикаль);
		Результат = ИсходящиеТочки.НайтиСтроки(Отбор);
		Если Результат.Количество() > 1 Тогда
			Пояснение = НСтр("ru='Несколько связей ""Да"".';en='Several links ""Yes.""'"); 
			ТекстСообщения = ТекстОшибкиЗаполнения(Наименование, 0, Пояснение);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Владелец,,,Отказ);
		КонецЕсли; 
		
		Отбор = Новый Структура("Направление",Перечисления.бит_Направление.Горизонталь);
		Результат = ИсходящиеТочки.НайтиСтроки(Отбор);
		Если Результат.Количество() > 1 Тогда
			Пояснение = НСтр("ru='Несколько связей ""Нет"".';en='Several links ""No"".'"); 
			ТекстСообщения = ТекстОшибкиЗаполнения(Наименование, 0, Пояснение);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Владелец,,,Отказ);
		КонецЕсли;
	КонецЕсли;
	
	НовыйКэш = Новый Соответствие;
	Если ТипЗнч(РеквизитыТочки) = Тип("СправочникОбъект.бит_ТочкиАлгоритмов") Тогда
		КэшПройденныхТочек = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(РеквизитыТочки.ДополнительныеСвойства,
													"КэшПройденныхТочек",
													НовыйКэш);
	Иначе
		КэшПройденныхТочек = НовыйКэш;
	КонецЕсли;
	
	Если НЕ ЭтоПоэтапныйАлгоритм Тогда
		// Проверка на зацикливание
		Для каждого СтрокаТаблицы Из ИсходящиеТочки Цикл
			Если СтрокаТаблицы.Точка.ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Слияние Тогда
				ПроверитьЗацикливаниеТочкиСлияния(СтрокаТаблицы.Точка, СтрокаТаблицы.Точка, Отказ, КэшПройденныхТочек);
				Если Отказ Тогда
					Прервать;
				КонецЕсли;
			КонецЕсли; 
		КонецЦикла;
	КонецЕсли;
		
	Если Справочники.бит_АлгоритмыПроцессов.ЕстьДинамическиеПараметры(Владелец) 
		 И ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Действие Тогда
		бит_УправлениеПроцессами.ПроверитьЗаполнениеПараметровПроцесса(ПараметрыПроцесса, Отказ);
	КонецЕсли;
	
КонецПроцедуры
 
#КонецОбласти

#Область СлужебныеПроцедурыИФункции 

Процедура ЗаполнитьЗначенияУсловийПриПереходеНаНовуюВерсию() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВходящиеТочкиТочекАлгоритмов.Ссылка КАК ТочкаАлгоритма,
	|	""ВходящиеТочки"" КАК ТабличнаяЧасть,
	|	ВходящиеТочкиТочекАлгоритмов.НомерСтроки КАК НомерСтроки,
	|	ВЫБОР
	|		КОГДА ВходящиеТочкиТочекАлгоритмов.Направление = ЗНАЧЕНИЕ(Перечисление.бит_Направление.Горизонталь)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЗначениеУсловия,
	|	ВходящиеТочкиТочекАлгоритмов.Направление КАК Направление
	|ИЗ
	|	Справочник.бит_ТочкиАлгоритмов.ВходящиеТочки КАК ВходящиеТочкиТочекАлгоритмов
	|ГДЕ
	|	ВходящиеТочкиТочекАлгоритмов.Точка.ВидТочки = ЗНАЧЕНИЕ(Перечисление.бит_ВидыТочекАлгоритмов.Условие)
	|	И ВходящиеТочкиТочекАлгоритмов.ЗначениеУсловия = НЕОПРЕДЕЛЕНО
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ИсходящиеТочкиТочекАлгоритмов.Ссылка,
	|	""ИсходящиеТочки"",
	|	ИсходящиеТочкиТочекАлгоритмов.НомерСтроки,
	|	ВЫБОР
	|		КОГДА ИсходящиеТочкиТочекАлгоритмов.Направление = ЗНАЧЕНИЕ(Перечисление.бит_Направление.Горизонталь)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ,
	|	ИсходящиеТочкиТочекАлгоритмов.Направление
	|ИЗ
	|	Справочник.бит_ТочкиАлгоритмов.ИсходящиеТочки КАК ИсходящиеТочкиТочекАлгоритмов
	|ГДЕ
	|	ИсходящиеТочкиТочекАлгоритмов.Ссылка.ВидТочки = ЗНАЧЕНИЕ(Перечисление.бит_ВидыТочекАлгоритмов.Условие)
	|	И ИсходящиеТочкиТочекАлгоритмов.ЗначениеУсловия = НЕОПРЕДЕЛЕНО
	|ИТОГИ ПО
	|	ТочкаАлгоритма";
	
	ВыборкаТочекАлгоритма = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаТочекАлгоритма.Следующий() Цикл
		ТочкаАлгоритма = ВыборкаТочекАлгоритма.ТочкаАлгоритма.ПолучитьОбъект();
		ВыборкаЗначенийУсловий = ВыборкаТочекАлгоритма.Выбрать();
		Пока ВыборкаЗначенийУсловий.Следующий() Цикл
			ИмяТабличнойЧасти = ВыборкаЗначенийУсловий.ТабличнаяЧасть;
			ИндексСтроки      = ВыборкаЗначенийУсловий.НомерСтроки - 1;
			ТочкаАлгоритма[ИмяТабличнойЧасти][ИндексСтроки].ЗначениеУсловия = ВыборкаЗначенийУсловий.ЗначениеУсловия;
		КонецЦикла;
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(ТочкаАлгоритма);
	КонецЦикла;	

КонецПроцедуры

Процедура ПроверитьЗацикливаниеТочкиСлияния(ТочкаСлияния, ТекущаяТочка, Отказ, КэшПройденныхТочек = Неопределено, ЗафиксированныеТочки = Неопределено)

	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если КэшПройденныхТочек = Неопределено Тогда
		КэшПройденныхТочек = Новый Соответствие;
	ИначеЕсли КэшПройденныхТочек.Получить(ТекущаяТочка) = Истина Тогда
		// Проверка уже выполнялась
		Возврат;
	КонецЕсли;
	
	Для каждого СтрокаТаблицы Из ТекущаяТочка.ИсходящиеТочки Цикл
		Если ЗафиксированныеТочки = Неопределено Тогда
			ВышестоящиеТочки = Новый Соответствие;
		Иначе
			ВышестоящиеТочки = Новый Соответствие(ЗафиксированныеТочки);
		КонецЕсли;
		
		ИсходящаяТочка = СтрокаТаблицы.Точка;
		
		Если ИсходящаяТочка = ТочкаСлияния Тогда
			ТекстСообщения = СтрШаблон(НСтр("ru='Обнаружено зацикливание на точке ""%1"".';
											|en='Loop detected on point ""%1"".'"),
									   Строка(ТекущаяТочка));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ); 
			Прервать;
		КонецЕсли;
		
		Если ВышестоящиеТочки.Получить(ИсходящаяТочка) = Неопределено Тогда
			ВышестоящиеТочки.Вставить(ИсходящаяТочка, Истина);
		Иначе
			// Цикл за пределами проверяемой точки слияния. 
			Прервать;
		КонецЕсли;
		
		СтекПроверки = Новый ФиксированноеСоответствие(ВышестоящиеТочки);
		ПроверитьЗацикливаниеТочкиСлияния(ТочкаСлияния, ИсходящаяТочка, Отказ, КэшПройденныхТочек, СтекПроверки);
		Если Отказ Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла; 
	
	КэшПройденныхТочек.Вставить(ТекущаяТочка, Истина);

КонецПроцедуры

Функция ТекстОшибкиЗаполнения(Представление, КодОшибки = 0, Пояснение = "")
	
	// 0 - недокументированная ошибка. Ожидается "пояснение".
	// 1 - несколько входящих,
	// 2 - несколько исходящих,
	// 3 - нет входящих,
	// 4 - нет исходящих,
	// 5 - неожиданные входящие точки,
	// 6 - неожиданные входящие точки,
	// 7 - точки обработки не поддерживаются алгоритмом.
	
	ТекстСообщения = "";
	ТекстОшибки    = НСтр("ru='Точка ""%1"" размещена некорректно. %2';
						  |en='Point ""%1"" placed incorrectly. %2'");
	
	Если КодОшибки = 1 Тогда
		ТекстСообщения = НСтр("ru='Несколько входящих связей доступны только в циклах поэтапных алгоритмов. Используйте точку слияния.';
							  |en='Several incoming links is not supported. Use the point of merger.'"); 
	ИначеЕсли КодОшибки = 2 Тогда	
		ТекстСообщения = НСтр("ru='Несколько исходящих связей не поддерживается. Используйте точку разделения.';
							  |en='Several outgoing links is not supported. Use the split point.'"); 
	ИначеЕсли КодОшибки = 3 Тогда	
		ТекстСообщения = НСтр("ru='Нет входящих связей.';en='No incoming connections.'");
	ИначеЕсли КодОшибки = 4 Тогда	
		ТекстСообщения = НСтр("ru='Нет исходящих связей.';en='No outbound connections.'");
	ИначеЕсли КодОшибки = 5 Тогда	
		ТекстСообщения = НСтр("ru='Входящие связи не поддерживаются.';en='Incoming communications are not supported.'");
	ИначеЕсли КодОшибки = 6 Тогда	
		ТекстСообщения = НСтр("ru='Исходящие связи не поддерживаются.';en='Outgoing communications are not supported.'");
	ИначеЕсли КодОшибки = 7 Тогда
		ТекстСообщения = НСтр("ru='Точки обработки не поддерживаются данным видом алгоритмов.';
							|en='Processing points are not supported by this type of algorithms.'");
	ИначеЕсли КодОшибки = 0 Тогда	
		ТекстСообщения = Пояснение;	
	КонецЕсли; 
	
	Возврат СтрШаблон(ТекстОшибки, Представление, ТекстСообщения);
	
КонецФункции

Функция ТочкиЗациклены(Точка1, Точка2, ИсходящиеТочки, СтекПроверки = Неопределено)
	
	Если СтекПроверки = Неопределено Тогда
		СтекПроверки = Новый Соответствие;
	КонецЕсли;
	Если СтекПроверки.Получить(Точка2) = Неопределено Тогда
		СтекПроверки.Вставить(Точка2, Ложь);
	Иначе
		// Внешний цикл не относящийся к проверяемым точкам.
		Возврат Ложь;
	КонецЕсли;
	
	Если Точка1 = Точка2 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Отбор = Новый Структура("ТочкаМаршрута", Точка2);
	СтрокиИсходищихТочек = ИсходящиеТочки.НайтиСтроки(Отбор);
	Для каждого СтрокаИсходящейТочки Из СтрокиИсходищихТочек Цикл
		ИсходящаяТочка = СтрокаИсходящейТочки.ИсходящаяТочка;
		Если ТочкиЗациклены(Точка1, ИсходящаяТочка, ИсходящиеТочки, СтекПроверки) Тогда
			Возврат Истина;
