#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоГруппа Тогда
		Возврат;	
	КонецЕсли;
	
	Если НЕ ЭтоРасчет Тогда
		ФормулаРасчета = "";
		ПараметрыРасчета.Очистить();
	КонецЕсли;
	
КонецПроцедуры
	
Процедура ПриЗаписи(Отказ)
		
	Если ОбменДанными.Загрузка Тогда
		Возврат;			
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(СтатьяОборотов) Тогда
		Справочники.бит_СтатьиБюджета.СтатьяБюджетаУникальна(Ссылка, Отказ);
		Если НЕ Отказ И НЕ ДополнительныеСвойства.Свойство("ЭтоКопирование") Тогда
			Справочники.бит_Бюджеты.ОбработатьБюджетЗапрещенКПланированию(Владелец);
		КонецЕсли;
	КонецЕсли;	
	
	Если НЕ ПометкаУдаления И НЕ ЭтоГруппа И ЭтоРасчет Тогда
		Справочники.бит_СтатьиБюджета.ПроверитьСтатьюНаЦикличность(Ссылка, Отказ);
	КонецЕсли;

КонецПроцедуры

Процедура ПередУдалением(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;			
	КонецЕсли; 
	
	Справочники.бит_Бюджеты.ОбработатьБюджетЗапрещенКПланированию(Владелец, Ссылка);
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	НепроверяемыеРеквизиты = Новый Массив();
	
	Если ЭтоГруппа Тогда
		НепроверяемыеРеквизиты.Добавить("СтатьяОборотов");
	Иначе
		Если ЭтоРасчет Тогда
			НепроверяемыеРеквизиты.Добавить("СтатьяОборотов");
		Иначе
			НепроверяемыеРеквизиты.Добавить("ФормулаРасчета");
		КонецЕсли;	
	КонецЕсли;
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	
КонецПроцедуры

#КонецОбласти

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли