КонецПроцедуры

&НаСервере
Функция СохраненныеПараметрыРасчета()
		
	АдресПараметров = ПоместитьВоВременноеХранилище(Объект.ПараметрыРасчета.Выгрузить());
	Возврат АдресПараметров;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()

	УсловноеОформление.Элементы.Очистить();
	
	// Цвет текста расчетов.
	ЦветТекстаРасчетов = Новый Структура("ЦветТекста", ЦветаСтиля.ГиперссылкаЦвет);
			
	// Расчет. Выделение текста цветом.
	СтруктураУсловия 	= бит_РаботаСДиалогамиСервер.ПростоеУсловие("СтатьиБюджета.ЭтоРасчет", Истина);
	МассивОформляемых   = Новый Массив;
	МассивОформляемых.Добавить("СтатьиБюджета");
	ЭлементОформления = Новый Структура("СтруктураОформления, СтруктураУсловия, МассивОформляемыхПолей", 
									ЦветТекстаРасчетов, СтруктураУсловия, МассивОформляемых);
	бит_РаботаСДиалогамиСервер.ДобавитьЭлементУсловногоОформления(УсловноеОформление, "ЦветТекстаРасчетов", ЭлементОформления);				
			
	// Расчет. Выделение текста цветом.
	СтруктураУсловия 	= бит_РаботаСДиалогамиСервер.ПростоеУсловие("Объект.ПараметрыРасчета.ЭтоРасчет", Истина);
	МассивОформляемых   = Новый Массив;
	МассивОформляемых.Добавить("ПараметрыРасчета");
	ЭлементОформления = Новый Структура("СтруктураОформления, СтруктураУсловия, МассивОформляемыхПолей", 
									ЦветТекстаРасчетов, СтруктураУсловия, МассивОформляемых);
	бит_РаботаСДиалогамиСервер.ДобавитьЭлементУсловногоОформления(УсловноеОформление, "ЦветТекстаПараметраРасчета", ЭлементОформления);				
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура СформироватьИмяПараметра(ПараметрРасчета, НомерПараметра)

	ПараметрРасчета.ИмяПараметра = СтрШаблон(НСтр("ru='[П%1]';en='[P%1]'"), Строка(НомерПараметра));

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура СформироватьТекстКоличествоОтдельно(ПараметрРасчета, НомерПараметра)

	ПараметрРасчета.КоличествоОтдельно = СтрШаблон(НСтр("ru='[П%1.Количество]';en='[P%1.Quantity]'"), НомерПараметра);

КонецПроцедуры

// Процедура извлекает параметр расчета.
//
// Параметры:
//  АдресПараметровРасчета - УникальныйИндетификатор.
//
&НаСервере
Процедура ИзвлечьПараметрыРасчета(АдресПараметровРасчета)
	
	ПараметрыВременно = ПолучитьИзВременногоХранилища(АдресПараметровРасчета);
	Объект.ПараметрыРасчета.Загрузить(ПараметрыВременно);
	Сч = 1;
	Для каждого ПараметрРасчета Из Объект.ПараметрыРасчета Цикл
		ПараметрРасчета.ЭтоРасчет = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрРасчета.ЗначениеПараметра, "ЭтоРасчет");
		СформироватьТекстКоличествоОтдельно(ПараметрРасчета, Сч);
		Сч = Сч + 1;
	КонецЦикла;
	
КонецПроцедуры// ИзвлечьПараметрыРасчета

// Процедура обработчик оповещения "ФормыВводаФункцииЗавершение".
//
// Параметры:
// Ответ - Структура
// ДополнительныеДанные - Произвольный.
//
&НаКлиенте
Процедура ФормыВводаФункцииЗавершение(Результат, ДополнительныеДанные) Экспорт
	
	Если Результат <> Неопределено Тогда		
		ТекстФормулы.УстановитьТекст(Результат);
	КонецЕсли;
	
КонецПроцедуры

// Процедура устанавливает текст формулы.
// 
// Параметры:
//  Значение - Строка.
//
&НаКлиенте
Процедура ДобавитьЭлементВТекстФормулы(Значение)
	
	Элементы.ТекстФормулы.ВыделенныйТекст = Значение;
	
КонецПроцедуры

// Процедура добавляет параметр расчета.
// 
// Параметры:
//  ЗначениеПараметра - СправочникСсылка.бит_СтатьиБюджета.
//
&НаКлиенте
Функция МожноДобавитьПараметр(ЗначениеПараметра)
	
	МожноДобавитьПараметр = Истина;
	
	Если ЗначениеЗаполнено(ТекущаяСтатья) И ЗначениеПараметра = ТекущаяСтатья Тогда
		
		МожноДобавитьПараметр = Ложь;
		
	Иначе
	
		ОтборПоЗначению    = Новый Структура("ЗначениеПараметра", ЗначениеПараметра);
		НайденныеПараметры = Объект.ПараметрыРасчета.НайтиСтроки(ОтборПоЗначению);
		Если НайденныеПараметры.Количество() > 0 Тогда
			МожноДобавитьПараметр = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат МожноДобавитьПараметр;
		
КонецФункции

// Функция возвращает значение реквизита статьи "это расчет".
//
// Возвращаемое значение:
//  Булево - это расчет.
//
&НаСервере
Функция ЭтоРасчет(Знач ЗначениеПараметра)

	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗначениеПараметра, "ЭтоРасчет");;	

КонецФункции

// Процедура добавляет параметр расчета.
// 
// Параметры:
//  ЗначениеПараметра - СправочникСсылка.бит_СтатьиБюджета.
//
&НаКлиенте
Процедура ДобавитьПараметрРасчета(ЗначениеПараметра = Неопределено)
	
	// Поиск параметров по значению.
	Если МожноДобавитьПараметр(ЗначениеПараметра) Тогда
			
		// Добавление нового параметра.
		НовыйПараметр = Объект.ПараметрыРасчета.Добавить();
		НомерПараметра = Объект.ПараметрыРасчета.Количество();		
		Если ЗначениеЗаполнено(ЗначениеПараметра) Тогда
			НовыйПараметр.ЗначениеПараметра = ЗначениеПараметра;
			НовыйПараметр.ЭтоРасчет = ЭтоРасчет(ЗначениеПараметра);
		КонецЕсли;
		СформироватьИмяПараметра(НовыйПараметр, НомерПараметра);
		СформироватьТекстКоличествоОтдельно(НовыйПараметр, НомерПараметра);
		Модифицированность = Истина;
			
	КонецЕсли;
		
КонецПроцедуры

// Процедура добавляет открывает форму ввода функции.
// 
// Параметры:
//  ИмяФункции - Строка.
//
&НаКлиенте
Процедура ВводФункции(ИмяФункции)
		
	ВыбранныеОбласти = Новый СписокЗначений;
	Для каждого ТекущийПараметр Из Объект.ПараметрыРасчета Цикл
		ВыбранныеОбласти.Добавить(ТекущийПараметр.ИмяПараметра, 
			ТекущийПараметр.ИмяПараметра+":"+Строка(ТекущийПараметр.ЗначениеПараметра));
		Если Объект.ПоказатьТекстКоличество Тогда
			ВыбранныеОбласти.Добавить(ТекущийПараметр.КоличествоОтдельно, 
				ТекущийПараметр.КоличествоОтдельно+":"+Строка(ТекущийПараметр.ЗначениеПараметра));
		КонецЕсли;
	КонецЦикла;
	 	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВыбранныеОбласти" , ВыбранныеОбласти);
	ПараметрыФормы.Вставить("ВладелецИмяФормы" , ИмяФормы);
	ПараметрыФормы.Вставить("ФункцииДляЗапроса", Истина);
	ПараметрыФормы.Вставить("ИмяФункции"	   , ИмяФункции);
	
	ОповещениеЗакрытияФормы = Новый ОписаниеОповещения("ФормыВводаФункцииЗавершение", ЭтотОбъект);
	ОткрытьФорму("ОбщаяФорма.бит_ФормаВводаФункции", ПараметрыФормы, ЭтотОбъект,,,, ОповещениеЗакрытияФормы, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры // ВводФункции()

// Функция удаляет скобки параметра.
//
// Возвращаемое значение:
//  Строка - имя параметра без скобок.
//
&НаСервере
Функция УдалитьСкобкиПараметра(Знач ИмяПараметра, ЗаменаПервойСкобки = "")

	ИмяПараметра = СтрЗаменить(ИмяПараметра, "[", ЗаменаПервойСкобки);
	ИмяПараметра = СтрЗаменить(ИмяПараметра, "]", "");
	
	Возврат ИмяПараметра;

КонецФункции // УдалитьСкобкиПараметра()

// Функция проверяет формулу.
// 
// Возвращаемое значение:
//  Булево.
//
&НаСервере
Функция ФормулаВерна()
	
	ВсеВерно = Истина;
	
	// Исправление. Числа не могут быть записанны с использованием запятой.
	ТекстПроверки = ТекстФормулы.ПолучитьТекст();
	ТекстПроверки = СтрЗаменить(ТекстПроверки, ",", ".");
	ТекстФормулы.УстановитьТекст(ТекстПроверки);
	
	// Проверка выполнения формулы в запросе.
	ТекстВыбора = "";
	Для каждого ТекущийПараметр Из Объект.ПараметрыРасчета Цикл
		ИмяПараметра = УдалитьСкобкиПараметра(ТекущийПараметр.ИмяПараметра);
		// Формирование текста выбора для запроса.
		СтрокаВыбора = СтрШаблон("0 КАК %1", ИмяПараметра);
		ТекстВыбора = ?(ПустаяСтрока(ТекстВыбора), СтрокаВыбора, ТекстВыбора + СтрШаблон(",
																		   |%1", СтрокаВыбора));
	КонецЦикла;
				
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	0 КАК П1
	|ПОМЕСТИТЬ ВременнаяТаблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&Формула КАК Формула
	|ИЗ
	|	ВременнаяТаблица КАК ТаблицаПараметров";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "0 КАК П1", ТекстВыбора);	
	ФормулаЗапроса = УдалитьСкобкиПараметра(ТекстПроверки, "ТаблицаПараметров.");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Формула", ФормулаЗапроса);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, ".Количество", "");
	
	Попытка
		РезультатЗапроса = Запрос.Выполнить();	
	Исключение
		ТекстСообщения = НСтр("ru='В формуле допущена ошибка.';en='There is a mistake in the formula.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,, "ТекстФормулы");
		ВсеВерно = Ложь;
	КонецПопытки;
	
	Возврат ВсеВерно;
	
КонецФункции

#КонецОбласти
