#Область ЭлементыФормулыДополнительно

&НаКлиенте
Процедура Очистить(Команда)
	
	ТекстФормулы = "";
	
КонецПроцедуры

&НаКлиенте
Процедура РедакторФормул(Команда)
		
	ВыбранныеОбласти = Новый СписокЗначений;
	Для каждого ТекущийПараметр Из Объект.ПараметрыРасчета Цикл
		ВыбранныеОбласти.Добавить(ТекущийПараметр.ИмяПараметра, 
			ТекущийПараметр.ИмяПараметра + ":" + Строка(ТекущийПараметр.ЗначениеПараметра));
		Если Объект.ПоказатьТекстКоличество Тогда
			ВыбранныеОбласти.Добавить(ТекущийПараметр.КоличествоОтдельно, 
				ТекущийПараметр.КоличествоОтдельно+":"+Строка(ТекущийПараметр.ЗначениеПараметра));
		КонецЕсли;
	КонецЦикла;
	 	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВыбранныеОбласти" , ВыбранныеОбласти);
	ПараметрыФормы.Вставить("ВладелецИмяФормы" , ИмяФормы);
	ПараметрыФормы.Вставить("ФункцииДляЗапроса", Истина);
	
	ОповещениеЗакрытияФормы = Новый ОписаниеОповещения("ФормыВводаФункцииЗавершение", ЭтотОбъект);
	ОткрытьФорму("ОбщаяФорма.бит_ФормаВводаФункции", ПараметрыФормы, ЭтотОбъект,,,, 
		ОповещениеЗакрытияФормы, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры // РедакторФормул()

#КонецОбласти

&НаКлиенте
Процедура ОК(Команда)
	
	Модифицированность = Ложь;
		
	ВсеВерно = ФормулаВерна();
	Если НЕ ВсеВерно Тогда
		Возврат;		   
	КонецЕсли;
	
	РезСтруктура = Новый Структура;
	РезСтруктура.Вставить("ФормулаРасчета", 		 ТекстФормулы.ПолучитьТекст());
	РезСтруктура.Вставить("АдресПараметровРасчета",  СохраненныеПараметрыРасчета());
	РезСтруктура.Вставить("ПоказатьТекстКоличество", Объект.ПоказатьТекстКоличество);
	
	Закрыть(РезСтруктура);
	
КонецПроцедуры

