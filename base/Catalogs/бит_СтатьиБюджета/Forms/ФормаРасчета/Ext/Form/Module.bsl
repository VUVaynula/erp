
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаОбъектаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	
	Объект.Владелец = Параметры.Владелец;
	ТекущаяСтатья   = Параметры.Статья;
		
	Объект.ФормулаРасчета = Параметры.ФормулаРасчета;	
	ТекстФормулы.УстановитьТекст(Объект.ФормулаРасчета);
	
	Объект.ПоказатьТекстКоличество = Параметры.ПоказатьТекстКоличество;
	Элементы.ПараметрыРасчетаКоличествоОтдельно.Видимость = Объект.ПоказатьТекстКоличество;
	
	ИзвлечьПараметрыРасчета(Параметры.АдресПараметровРасчета);
		
	УстановитьУсловноеОформление();	
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
    СтатьиБюджета, "Владелец", Объект.Владелец, ВидСравненияКомпоновкиДанных.Равно, , Истина, 
    РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный);
		
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Отказ = Истина;
	Модифицированность = Ложь;
	РезСтруктура = Новый Структура;
	РезСтруктура.Вставить("ФормулаРасчета"		  , ТекстФормулы.ПолучитьТекст());
	РезСтруктура.Вставить("АдресПараметровРасчета", СохраненныеПараметрыРасчета());
	
	Закрыть(РезСтруктура);
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПараметрыРасчета

&НаКлиенте
Процедура ПараметрыРасчетаВыборЗначения(Элемент, Значение, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПараметрыРасчета.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		Если Элемент.ТекущийЭлемент.Имя = "ПараметрыРасчетаКоличествоОтдельно" Тогда
			ДобавитьЭлементВТекстФормулы(ТекущиеДанные.КоличествоОтдельно);
		Иначе	
			ДобавитьЭлементВТекстФормулы(ТекущиеДанные.ИмяПараметра);
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыРасчетаПослеУдаления(Элемент)
	
	Сч = 1;
	Для каждого СтрокаПараметров Из Объект.ПараметрыРасчета Цикл
		СформироватьИмяПараметра(СтрокаПараметров, Сч);
		Сч = Сч + 1;	
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьТекстКоличествоПриИзменении(Элемент)
	
	Элементы.ПараметрыРасчетаКоличествоОтдельно.Видимость = Объект.ПоказатьТекстКоличество;
	
КонецПроцедуры

#КонецОбласти

