	// АПК:277-выкл
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ТекущаяТочкаВариантыЗначение");
	// АПК:277-вкл 
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"ТекущаяТочкаВарианты.Значение", ВидСравненияКомпоновкиДанных.Равно, Неопределено);
