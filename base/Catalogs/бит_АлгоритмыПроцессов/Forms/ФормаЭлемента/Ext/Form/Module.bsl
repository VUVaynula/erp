&НаКлиенте
Процедура ПредложитьЗаписатьСправочник()

	Если Объект.Ссылка.Пустая() И ЗначениеЗаполнено(Объект.ВидАлгоритма) Тогда
		ТекстСообщения = "";
		Если Объект.ВидАлгоритма = ПредопределенноеЗначение("Перечисление.бит_ВидыАлгоритмов.Прочее") Тогда
			ТекстСообщения = НСтр("ru = 'Для заполнения действий в точках вида ""Действие"" требуется записать алгоритм. Продолжить?';
								  |en = 'To fill in actions in points of the ""Action""type, you need to write an algorithm. Continue?'"); 
			ОписаниеОповещения = Новый ОписаниеОповещения("ПредложитьЗаписатьСправочникЗавершение", ЭтотОбъект);
			ПоказатьВопрос(ОписаниеОповещения, ТекстСообщения, РежимДиалогаВопрос.ДаНет);
		КонецЕсли;
