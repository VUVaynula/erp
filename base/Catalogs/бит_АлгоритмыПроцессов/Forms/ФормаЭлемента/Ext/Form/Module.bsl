// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура ПредложитьЗаписатьСправочникЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Если ПроверитьЗаполнение() Тогда
			Записать();
		КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ПриАктивизацииГрафическойСхемы()

	ТекущийЭлементСхемы = Элементы.ГрафическаяСхема.ТекущийЭлемент;
	ТочкаМаршрута = Неопределено;
	Если ТекущийЭлементСхемы <> Неопределено Тогда
		ТочкаМаршрута = НайтиТочкуМаршрута(ТекущийЭлементСхемы.Имя, "КодТочки");
		Если ТочкаМаршрута <> Неопределено Тогда
			Если ТекущаяТочкаИдентификатор <> ТочкаМаршрута.ИдентификаторТочки Тогда
			    УстановитьСвойстваТекущейСтрокиТочекМаршрута(ЭтотОбъект);
				УстановитьСвойстваТекущейТочки(ТочкаМаршрута);
				УстановитьПараметрыВыбораТекущаяТочкаДействие(ЭтотОбъект);
			КонецЕсли;
		КонецЕсли; 
	КонецЕсли; 
	
	УправлениеПанельюТекущаяТочка(ЭтотОбъект, ТекущаяТочкаИдентификатор <> 0);
	
КонецПроцедуры
 
&НаКлиенте    
Функция НайтиТочкуМаршрута(Значение, Колонка)
	
	// Используется сканирование таблицы, для того, что бы избежать вызова сервера при обработке на клиенте.
	СтрокаТочекМаршрута = Неопределено;
	Для каждого СтрокаТаблицы Из ТочкиМаршрута Цикл
	    Если СтрокаТаблицы[Колонка] = Значение Тогда
		      Возврат СтрокаТаблицы
		КонецЕсли; 
	КонецЦикла; 
	
	Возврат СтрокаТочекМаршрута
	
КонецФункции
 
&НаСервереБезКонтекста
Процедура ПриИзмененииГрафическойСхемы(Форма)
	
	ВидыЭлементов = бит_УправлениеПроцессами.ВидыЭлементовГрафическойСхемы();
	
	ИдентификаторыТочек = Новый Массив;
	
	ДокументDOM = бит_УправлениеПроцессами.ГрафическаяСхемаВDOM(Форма.ГрафическаяСхема);
	
	// Каждый элемент схемы "item" представлен свойством "itemType"
	СписокЭлементовDOM = ДокументDOM.ПолучитьЭлементыПоИмени("itemType");
	
	Для Каждого Элемент Из СписокЭлементовDOM Цикл
		
		ТипЭлемента = Число(Элемент.ТекстовоеСодержимое);
		
		Если ТипЭлемента = 0 ИЛИ ТипЭлемента = 1 Тогда
			// Типы элементов см. бит_УправлениеПроцессами.ТипыЭлементовГрафическойСхемы().
			Продолжить;
		КонецЕсли;
		
		УзелТочкиМаршрута = Элемент.РодительскийУзел;
		
		// Каждый элемент схемы имеет itemId
		ИдентификаторТочки = Число(бит_УправлениеПроцессами.ЗначениеСвойстваЭлемента(УзелТочкиМаршрута, "itemId"));
		КодТочки		   = бит_УправлениеПроцессами.ЗначениеСвойстваЭлемента(УзелТочкиМаршрута, "itemCode");
		НаименованиеТочки  = бит_УправлениеПроцессами.ЗначениеСвойстваЭлемента(УзелТочкиМаршрута, "content");
		УзлыВариантов      = УзелТочкиМаршрута.ПолучитьЭлементыПоИмени("transition");
		
		ВидТочки           = ВидыЭлементов[ТипЭлемента];
		
		// Заполняеем перечень текущих идентификаторов
		ИдентификаторыТочек.Добавить(ИдентификаторТочки);
		
		// Находим, есть ли данный узел в точках маршрута
		ПараметрыОтбора = Новый Структура("ИдентификаторТочки", ИдентификаторТочки);
		
		РезультатПоиска = Форма.ТочкиМаршрута.НайтиСтроки(ПараметрыОтбора);
		
		Если РезультатПоиска.Количество() = 0 Тогда
			СтрокаТаблицы = Форма.ТочкиМаршрута.Добавить();
			СтрокаТаблицы.НоваяТочка         = Истина;
			СтрокаТаблицы.Модифицированность = Истина;
			СтрокаТаблицы.ИдентификаторТочки = ИдентификаторТочки;
			СтрокаТаблицы.ВидТочки           = ВидТочки;
			СтрокаТаблицы.Наименование       = НаименованиеТочки;
			СтрокаТаблицы.КодТочки           = КодТочки;
			ТаблицаВариантов = СтрокаТаблицы.Варианты;
			Для каждого УзелВарианта Из УзлыВариантов Цикл
				СтрокаВарианта = ТаблицаВариантов.Добавить();
				ИмяВарианта    = бит_УправлениеПроцессами.ЗначениеСвойстваЭлемента(УзелВарианта, "name");
				СтрокаВарианта.Имя = ИмяВарианта;
			КонецЦикла;
			Если ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.ПодчиненныйПроцесс 
				И Форма.ТекущийВидАлгоритма = Перечисления.бит_ВидыАлгоритмов.Визирование Тогда
				ТекстСообщения = НСтр("ru = 'Вложенные процессы в алгоритме визирования не поддерживаются.';
									  |en = 'Nested processes are not supported in the sighting algorithm.'"); 
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			КонецЕсли;
		Иначе            
			СтрокаТаблицы = РезультатПоиска[0];
			Если СтрокаТаблицы.Наименование <> НаименованиеТочки Тогда
			     СтрокаТаблицы.Наименование = НаименованиеТочки;
				 СтрокаТаблицы.Модифицированность = Истина;
			КонецЕсли; 
			Если СтрокаТаблицы.КодТочки <> КодТочки Тогда
			     СтрокаТаблицы.КодТочки = КодТочки;
				 СтрокаТаблицы.Модифицированность = Истина;
			КонецЕсли;
			СопоставитьВарианты(УзлыВариантов, СтрокаТаблицы.Варианты);
		КонецЕсли;
		
	КонецЦикла;

	// Удалим из таблицы точек маршрута те элементы, которые удалили на схеме.
	СтрокиКУдалению = Новый Массив;
	Для Каждого СтрокаТаблицы Из Форма.ТочкиМаршрута Цикл
		Если ИдентификаторыТочек.Найти(СтрокаТаблицы.ИдентификаторТочки) = Неопределено Тогда
			СтрокиКУдалению.Добавить(СтрокаТаблицы);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого СтрокаТаблицы Из СтрокиКУдалению Цикл
		ЗаполнитьЗначенияСвойств(Форма.ТочкиМаршрутаКУдалению.Добавить(), СтрокаТаблицы);
		Если СтрокаТаблицы.ИдентификаторТочки = Форма.ТекущаяТочкаИдентификатор Тогда
		    Форма.ТекущаяТочкаИдентификатор = 0; 
			УправлениеПанельюТекущаяТочка(Форма, Ложь);
		КонецЕсли;
		Форма.ТочкиМаршрута.Удалить(СтрокаТаблицы);
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура СопоставитьВарианты(УзлыВариантов, ВариантыТочки)
	
	КоличествоВариантовЭлемента = УзлыВариантов.Количество();
	Если УзлыВариантов.Количество() = ВариантыТочки.Количество() Тогда
		Возврат;
	КонецЕсли;
	
	КопияВариантыТочки = ВариантыТочки.Выгрузить();
	ВариантыТочки.Очистить();
	
	Для каждого УзелВарианта Из УзлыВариантов Цикл
		СтрокаВарианта = ВариантыТочки.Добавить();
		ИмяВарианта    = бит_УправлениеПроцессами.ЗначениеСвойстваЭлемента(УзелВарианта, "name");
		СтрокаВарианта.Имя = ИмяВарианта;
		
		СтрокаДоИзменения = КопияВариантыТочки.Найти(ИмяВарианта, "Имя");
		Если СтрокаДоИзменения <> Неопределено Тогда
			ЗаполнитьЗначенияСвойств(СтрокаВарианта, СтрокаДоИзменения);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ВидЭлемента(ЭлементDOM)
	
	ВидЭлемента = Неопределено;
	
	ТипЭлемента = бит_УправлениеПроцессами.ЗначениеСвойстваЭлемента(ЭлементDOM, "itemType");
	Если ЗначениеЗаполнено(ТипЭлемента) Тогда
		ВидыЭлементов = бит_УправлениеПроцессами.ВидыЭлементовГрафическойСхемы();
		ВидЭлемента   = ВидыЭлементов[Число(ТипЭлемента)];
	КонецЕсли;
	
	Возврат ВидЭлемента;
	
КонецФункции

&НаКлиенте 
Процедура ВыделитьЭлементыСхемы()
		
	ВыделитьЭлементыСхемыНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ВыделитьЭлементыСхемыНаСервере()
	
	ДокументDOM 	   = бит_УправлениеПроцессами.ГрафическаяСхемаВDOM(ГрафическаяСхема);
	СписокЭлементовDOM = ДокументDOM.ПолучитьЭлементыПоИмени("itemType");
	
	ТаблицаМаршрута = РеквизитФормыВЗначение("ТочкиМаршрута");
	ТаблицаМаршрута.Индексы.Добавить("ИдентификаторТочки");
	
	Для Каждого Элемент Из СписокЭлементовDOM Цикл
		
		ТипЭлемента = Число(Элемент.ТекстовоеСодержимое);
		Если НЕ (ТипЭлемента = 4 ИЛИ ТипЭлемента = 5 ИЛИ ТипЭлемента = 10) Тогда
			Продолжить;
		КонецЕсли;
		
		УзелТочкиМаршрута  = Элемент.РодительскийУзел;
		ИдентификаторТочки = Число(бит_УправлениеПроцессами.ЗначениеСвойстваЭлемента(УзелТочкиМаршрута, "itemId"));
		СтрокаТаблицы      = ТаблицаМаршрута.Найти(ИдентификаторТочки, "ИдентификаторТочки");
		
		СвойствоДляПроверки = Неопределено;
		Если СтрокаТаблицы.ВидТочки = ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.ПодчиненныйПроцесс") Тогда
			Если Объект.ВидАлгоритма = ПредопределенноеЗначение("Перечисление.бит_ВидыАлгоритмов.Визирование") Тогда
				СвойствоДляПроверки = Неопределено;
				// Затемнить элемент.
				бит_УправлениеПроцессами.УстановитьЗначениеСвойстваЭлемента(УзелТочкиМаршрута, "passageState", "1");
			Иначе	
				СвойствоДляПроверки = СтрокаТаблицы.Действие;
			КонецЕсли; 
		ИначеЕсли СтрокаТаблицы.ВидТочки = ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.Действие") Тогда
			СвойствоДляПроверки = СтрокаТаблицы.Действие;	
		ИначеЕсли СтрокаТаблицы.ВидТочки = ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.Условие") Тогда
			СвойствоДляПроверки = СтрокаТаблицы.Условие;
		КонецЕсли; 
		
		Если СвойствоДляПроверки <> Неопределено Тогда
			Если ЗначениеЗаполнено(СвойствоДляПроверки) Тогда
				passageState = "0";
			Иначе	
				passageState = "2";
			КонецЕсли; 
			бит_УправлениеПроцессами.УстановитьЗначениеСвойстваЭлемента(УзелТочкиМаршрута, "passageState", passageState);
		КонецЕсли; 
	КонецЦикла;
	
	ГрафическаяСхема = бит_УправлениеПроцессами.ГрафическаяСхемаИзDOM(ДокументDOM);
	
КонецПроцедуры

&НаСервере 
Процедура ЗаполнитьТочкиМаршрута(Ссылка, Копирование)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТочкиАлгоритмов.Ссылка КАК ТочкаМаршрута,
	|	ТочкиАлгоритмов.ВидТочки КАК ВидТочки,
	|	ТочкиАлгоритмов.Наименование КАК Наименование,
	|	ТочкиАлгоритмов.ИдентификаторТочки КАК ИдентификаторТочки,
	|	ТочкиАлгоритмов.КодТочки КАК КодТочки,
	|	ТочкиАлгоритмов.ПользовательскоеУсловие КАК Условие,
	|	ТочкиАлгоритмов.ПользовательскоеДействие КАК Действие,
	|	ТочкиАлгоритмов.ПользовательскийВыборВарианта КАК ВыборВарианта
	|ПОМЕСТИТЬ ТочкиМаршрута
	|ИЗ
	|	Справочник.бит_ТочкиАлгоритмов КАК ТочкиАлгоритмов
	|ГДЕ
	|	ТочкиАлгоритмов.Владелец = &Владелец
	|	И ТочкиАлгоритмов.ИдентификаторТочки <> 0
	|	И ТочкиАлгоритмов.АктивнаяТочкаМаршрута
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА &Копирование
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.бит_ТочкиАлгоритмов.ПустаяСсылка)
	|		ИНАЧЕ ТочкиМаршрута.ТочкаМаршрута
	|	КОНЕЦ КАК ТочкаМаршрута,
	|	ТочкиМаршрута.ВидТочки КАК ВидТочки,
	|	ТочкиМаршрута.Наименование КАК Наименование,
	|	ТочкиМаршрута.ИдентификаторТочки КАК ИдентификаторТочки,
	|	ТочкиМаршрута.КодТочки КАК КодТочки,
	|	ВЫБОР
	|		КОГДА &Копирование
	|				И ТочкиМаршрута.Условие.КонтекстВыполнения = ЗНАЧЕНИЕ(Перечисление.бит_КонтекстыВыполненияПользовательскихУсловий.Процесс)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеУсловия.ПустаяСсылка)
	|		ИНАЧЕ ТочкиМаршрута.Условие
	|	КОНЕЦ КАК Условие,
	|	ТочкиМаршрута.Действие КАК Действие,
	|	ТочкиМаршрута.ВыборВарианта КАК ВыборВарианта,
	|	&Копирование КАК НоваяТочка,
	|	&Копирование КАК Модифицированность,
	|	ТочкиМаршрута.ТочкаМаршрута.ПараметрыПроцесса.(
	|		Ссылка КАК Ссылка,
	|		НомерСтроки КАК НомерСтроки,
	|		Имя КАК Имя,
	|		СтрТип КАК СтрТип,
	|		Значение КАК Значение,
	|		Обязательный КАК Обязательный
	|	) КАК ПараметрыПроцесса,
	|	ТочкиМаршрута.ТочкаМаршрута.ВариантыВыбора.(
	|		Ссылка КАК Ссылка,
	|		НомерСтроки КАК НомерСтроки,
	|		ИмяВарианта КАК Имя,
	|		ЗначениеВыбора КАК Значение
	|	) КАК ВариантыВыбораТочки
	|ИЗ
	|	ТочкиМаршрута КАК ТочкиМаршрута
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИдентификаторТочки";
	
	Запрос.УстановитьПараметр("Владелец", Ссылка);
	Запрос.УстановитьПараметр("Копирование", Копирование);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ТочкиМаршрута.Очистить();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоваяСтрока = ТочкиМаршрута.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДетальныеЗаписи);
		НоваяСтрока.ПараметрыТочки.Загрузить(ВыборкаДетальныеЗаписи.ПараметрыПроцесса.Выгрузить());
		НоваяСтрока.Варианты.Загрузить(ВыборкаДетальныеЗаписи.ВариантыВыбораТочки.Выгрузить());
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииНаименованияТекущейТочки()
	
	ДокументDOM = бит_УправлениеПроцессами.ГрафическаяСхемаВDOM(ГрафическаяСхема);
	
	ИдентификаторТочки = Строка(ТекущаяТочкаИдентификатор);
	УзелТочкиМаршрута  = бит_УправлениеПроцессами.ЭлементПоЗначениюСвойства(ДокументDOM, "itemId", ИдентификаторТочки);
	
	Если УзелТочкиМаршрута = Неопределено Тогда
		Возврат;	
	КонецЕсли; 

	ТипЭлемента = ВидЭлемента(УзелТочкиМаршрута);
	
	УзелДляУстановкиЗаголовка = УзелТочкиМаршрута;
	Если ТипЭлемента = Перечисления.бит_ВидыТочекАлгоритмов.ВыборВарианта Тогда
		ЗаголовкиВыбораВарианта = УзелТочкиМаршрута.ПолучитьЭлементыПоИмени("itemTitle");
		Если ЗаголовкиВыбораВарианта.Количество() = 1 Тогда
			УзелДляУстановкиЗаголовка = ЗаголовкиВыбораВарианта[0];
		КонецЕсли;
	Иначе
		УзелДляУстановкиЗаголовка = УзелТочкиМаршрута;
	КонецЕсли;
	бит_УправлениеПроцессами.УстановитьЗначениеСвойстваЭлемента(УзелДляУстановкиЗаголовка, "content", ТекущаяТочкаНаименование);
	
	ГрафическаяСхема = бит_УправлениеПроцессами.ГрафическаяСхемаИзDOM(ДокументDOM);
	
	ДобавитьНовуюСхемуВИсторию();
	
КонецПроцедуры

&НаСервереБезКонтекста 
Процедура ВыделитьЭлементСхемы(СвойствоДляПроверки, Затемнить, ИдентификаторТочки, Форма)
	
	Если Затемнить Тогда
		passageState = "1";
	Иначе	
		Если НЕ ЗначениеЗаполнено(СвойствоДляПроверки)  Тогда  
			passageState = "2";
		Иначе
			passageState = "0";
		КонецЕсли;
	КонецЕсли; 

	бит_УправлениеПроцессами.ВыделитьЭлемент(Форма.ГрафическаяСхема, 
		ИдентификаторТочки, passageState);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста 
Процедура УправлениеПанельюТекущаяТочка(Форма, ПоказатьСвойства)

	Элементы = Форма.Элементы;
	Объект   = Форма.Объект;

	Элементы.ДекорацияСвойстваТочки.Видимость 	  = НЕ ПоказатьСвойства; 
	Элементы.ДекорацияКот.Видимость 	  		  = НЕ ПоказатьСвойства;
	Элементы.ГруппаСвойстваТекущейТочки.Видимость = ПоказатьСвойства;

	ЭтоТочкаДействия  = Форма.ТекущаяТочкаВидТочки = ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.Действие");			
	ЭтоТочкаУсловия   = Форма.ТекущаяТочкаВидТочки = ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.Условие");
	ЭтоТочкаПроцесса  = Форма.ТекущаяТочкаВидТочки = ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.ПодчиненныйПроцесс");
	ЭтоТочкаОбработки = Форма.ТекущаяТочкаВидТочки = ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.Обработка");
	ЭтоТочкаВарианта  = Форма.ТекущаяТочкаВидТочки = ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.ВыборВарианта");
		
	Элементы.ТекущаяТочкаДействие.Видимость = ЭтоТочкаДействия ИЛИ ЭтоТочкаПроцесса ИЛИ ЭтоТочкаОбработки;
	Элементы.ТекущаяТочкаУсловие.Видимость  = ЭтоТочкаУсловия;
	Элементы.ТекущаяТочкаВыборВарианта.Видимость = ЭтоТочкаВарианта;
	Элементы.ТекущаяТочкаВарианты.Видимость      = ЭтоТочкаВарианта;
	
	Если Объект.ВидАлгоритма = ПредопределенноеЗначение("Перечисление.бит_ВидыАлгоритмов.Прочее") Тогда
		Элементы.ТекущаяТочкаПараметрыПроцесса.Видимость = (ЭтоТочкаДействия ИЛИ ЭтоТочкаПроцесса) 
			И Форма.ИспользуютсяПараметрыТочки;
	Иначе	
		Элементы.ТекущаяТочкаПараметрыПроцесса.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.ГруппаСвойстваТочки.Видимость = НЕ Форма.ЭтоВебКлиент;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьСвойстваТекущейСтрокиТочекМаршрута(Форма)

	Если НЕ Форма.ТекущаяТочкаМодифицированность Тогда
	     Возврат;	
	КонецЕсли;
	
	НайденныеСтроки = Форма.ТочкиМаршрута.НайтиСтроки(
		Новый Структура("ИдентификаторТочки", Форма.ТекущаяТочкаИдентификатор));
	Если НайденныеСтроки.Количество() > 0 Тогда
		СвойстваТочки = НайденныеСтроки[0];
		СвойстваТочки.Наименование = Форма.ТекущаяТочкаНаименование; 
		СвойстваТочки.ИдентификаторТочки = Форма.ТекущаяТочкаИдентификатор;
		СвойстваТочки.Действие = Форма.ТекущаяТочкаДействие;
		СвойстваТочки.Условие = Форма.ТекущаяТочкаУсловие;
		СвойстваТочки.Модифицированность = Форма.ТекущаяТочкаМодифицированность;
		СвойстваТочки.ВидТочки           = Форма.ТекущаяТочкаВидТочки;
		СвойстваТочки.КодТочки           = Форма.ТекущаяТочкаКодТочки;
		
		СвойстваТочки.ВыборВарианта      = Форма.ТекущаяТочкаВыборВарианта;
		СвойстваТочки.Варианты.Очистить();
		Для каждого ТекущийВариант Из Форма.ТекущаяТочкаВарианты Цикл
			НовыйВариант = СвойстваТочки.Варианты.Добавить();
			ЗаполнитьЗначенияСвойств(НовыйВариант, ТекущийВариант);
		КонецЦикла;
		
		ПараметрыТочки = СвойстваТочки.ПараметрыТочки;
		КопироватьЗначенияПараметров(Форма.Объект.ПараметрыАлгоритма, 
			Форма.ТекущаяТочкаПараметрыПроцесса, ПараметрыТочки);
		Форма.ТекущаяТочкаМодифицированность = Ложь;	
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСвойстваТекущейТочки(СвойстваТочки)

	ТекущаяТочкаНаименование       = СвойстваТочки.Наименование; 
	ТекущаяТочкаИдентификатор      = СвойстваТочки.ИдентификаторТочки;
	ТекущаяТочкаДействие           = СвойстваТочки.Действие;
	ТекущаяТочкаУсловие            = СвойстваТочки.Условие;
	ТекущаяТочкаМодифицированность = СвойстваТочки.Модифицированность;
	ТекущаяТочкаВидТочки           = СвойстваТочки.ВидТочки;
	ТекущаяТочкаКодТочки           = СвойстваТочки.КодТочки;
	ТекущаяТочкаВыборВарианта      = СвойстваТочки.ВыборВарианта;

	КопироватьЗначенияПараметров(Объект.ПараметрыАлгоритма, 
		СвойстваТочки.ПараметрыТочки, ТекущаяТочкаПараметрыПроцесса);
		
	ТекущаяТочкаВарианты.Очистить();
	Для каждого Вариант Из СвойстваТочки.Варианты Цикл
		НоваяСтрокаВарианта = ТекущаяТочкаВарианты.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаВарианта, Вариант);
	КонецЦикла;
	Элементы.ТекущаяТочкаВариантыЗначение.ОграничениеТипа = ОграничениеТипаЗначенийВарианта(СвойстваТочки.ВыборВарианта);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура КопироватьЗначенияПараметров(Шаблон, Источник, Приемник)

	Приемник.Очистить();
	Для каждого ТекущийПараметр Из Шаблон Цикл
		Если НЕ ТекущийПараметр.Динамический Тогда
		     Продолжить;
		КонецЕсли;
	    НоваяСтрока = Приемник.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекущийПараметр);
	    // Используется сканирование таблицы, для того, что бы избежать вызова сервера при обработке на клиенте.
		Для каждого ПараметрТочки Из Источник Цикл
		   Если ПараметрТочки.Имя = ТекущийПараметр.Имя Тогда
		   	    НоваяСтрока.Значение = ТекущийПараметр.Тип.ПривестиЗначение(ПараметрТочки.Значение);
		   КонецЕсли; 
		КонецЦикла; 
	КонецЦикла; 

КонецПроцедуры

&НаСервереБезКонтекста
Функция ОграничениеТипаЗначенийВарианта(Знач ВыборВарианта)
	
	Если НЕ ЗначениеЗаполнено(ВыборВарианта) Тогда
		Возврат Новый ОписаниеТипов;
	КонецЕсли;
	
	ОграничениеВыбораВариантов = ВыборВарианта.ОграничениеТипаЗначенийВариантов.Получить();
	Если ОграничениеВыбораВариантов = Неопределено Тогда
		Возврат Новый ОписаниеТипов;
	КонецЕсли;
	
	Возврат ОграничениеВыбораВариантов;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьПараметрыВыбораТекущаяТочкаДействие(Форма)

	Объект = Форма.Объект;
	Элементы = Форма.Элементы;
	
	ПараметрыВыбора = Новый Структура; 	
	Если Форма.ТекущаяТочкаВидТочки = ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.Обработка") Тогда
		НазначениеДействия = ПредопределенноеЗначение("Перечисление.бит_НазначенияПользовательскихДействий.Обработка");
	ИначеЕсли Объект.ВидАлгоритма = ПредопределенноеЗначение("Перечисление.бит_ВидыАлгоритмов.Визирование") Тогда
		НазначениеДействия = ПредопределенноеЗначение("Перечисление.бит_НазначенияПользовательскихДействий.Визирование");
	ИначеЕсли Объект.ВидАлгоритма = ПредопределенноеЗначение("Перечисление.бит_ВидыАлгоритмов.ИзменениеСтатусовОбъектов") Тогда
		НазначениеДействия = ПредопределенноеЗначение("Перечисление.бит_НазначенияПользовательскихДействий.ИзменениеСтатусовОбъектов");
	ИначеЕсли Объект.ВидАлгоритма = ПредопределенноеЗначение("Перечисление.бит_ВидыАлгоритмов.Прочее") Тогда
		Если Форма.ТекущаяТочкаВидТочки = ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.ПодчиненныйПроцесс") Тогда
			НазначениеДействия = ПредопределенноеЗначение("Перечисление.бит_НазначенияПользовательскихДействий.ПодчиненныйПроцесс");
		Иначе	
			НазначениеДействия = ПредопределенноеЗначение("Перечисление.бит_НазначенияПользовательскихДействий.СозданиеЗадачи");
		КонецЕсли; 
		ПараметрыВыбора.Вставить("Алгоритм", Объект.Ссылка);
	КонецЕсли; 
	
	ПараметрыВыбора.Вставить("Назначение",НазначениеДействия);
	
	бит_ОбщегоНазначенияКлиентСервер.УстановитьПараметрыВыбораЭлемента(Элементы.ТекущаяТочкаДействие, ПараметрыВыбора);
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьФормуНаСервере(КартаМаршрута, Алгоритм, Копирование)

	ИнициацияПараметровИстории();
	
	ОпределитьИспользуютсяПараметрыТочки(ЭтотОбъект);

	Если ТипЗнч(КартаМаршрута) = Тип("ГрафическаяСхема") Тогда
		ГрафическаяСхема = КартаМаршрута;
		ЗаполнитьТочкиМаршрута(Алгоритм, Копирование);
		// Что бы синхронизироваь данные справочника "Точки" и схемы.
		ПриИзмененииГрафическойСхемы(ЭтотОбъект);
		ДобавитьНовуюСхемуВИсторию();
	КонецЕсли;

КонецПроцедуры

// Открывает форму помощника создания точек алгоритма.
// 
&НаКлиенте
Процедура ОткрытьФормуПомощника(ПараметрыФормы)
	
	Если Модифицированность Тогда
		Оповещение = Новый ОписаниеОповещения("ВопросОЗаписиЭлементаЗавершение", ЭтотОбъект, ПараметрыФормы);
		Вопрос = РежимДиалогаВопрос.ДаНет;
		Текст = Нстр("ru = 'Для открытия формы помощника необходимо записать документ. Записать?'");
		ПоказатьВопрос(Оповещение, Текст, Вопрос, 0);
	Иначе
		РежимОкна = РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс;
		ОткрытьФорму("Справочник.бит_АлгоритмыПроцессов.Форма.ФормаПомощникаВводаАлгоритма",ПараметрыФормы,ЭтотОбъект,,,,,РежимОкна);
	КонецЕсли;
	
КонецПроцедуры

// Процедура - обработчик оповещения "ВопросОЗаписиЭлементаЗавершение".
// 
&НаКлиенте
Процедура ВопросОЗаписиЭлементаЗавершение(Ответ, ПараметрыФормы) Экспорт

	Если Ответ = КодВозвратаДиалога.Да
		И Записать() Тогда
		РежимОкна = РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс;		
		ОткрытьФорму("Справочник.бит_АлгоритмыПроцессов.Форма.ФормаПомощникаВводаАлгоритма",ПараметрыФормы,ЭтотОбъект,,,,,РежимОкна);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ИсходящиеТочкиДляПроверкиЗацикливания(ТочкиМаршрута, ТаблицаСвязей, ИдентификаторыТочек)
	
	ИсходящиеТочкиДляПроверкиЗацикливания = Новый ТаблицаЗначений;
	
	ТипТочка = Новый ОписаниеТипов("СправочникСсылка.бит_ТочкиАлгоритмов");
	ИсходящиеТочкиДляПроверкиЗацикливания.Колонки.Добавить("ТочкаМаршрута",  ТипТочка);
	ИсходящиеТочкиДляПроверкиЗацикливания.Колонки.Добавить("ИсходящаяТочка", ТипТочка);
	
	Для каждого СтрокаТаблицы Из ТочкиМаршрута Цикл
		ОтборПоИсточнику = Новый Структура("ЭлементИсточник", СтрокаТаблицы.ИдентификаторТочки);
		НайденныеСвязи   = ТаблицаСвязей.НайтиСтроки(ОтборПоИсточнику);
		Для каждого ЭлементСвязи Из НайденныеСвязи Цикл
			СвойствоИсходящейТочки  = ИдентификаторыТочек.Получить(ЭлементСвязи.ЭлементПриемник);
			Если СвойствоИсходящейТочки = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			НоваяСтрока = ИсходящиеТочкиДляПроверкиЗацикливания.Добавить();
			НоваяСтрока.ТочкаМаршрута  = СтрокаТаблицы.ТочкаМаршрута;
			НоваяСтрока.ИсходящаяТочка = СвойствоИсходящейТочки.ТочкаМаршрута;
		КонецЦикла;
	КонецЦикла;
	
	Возврат ИсходящиеТочкиДляПроверкиЗацикливания;
	
КонецФункции

#Область РаботаСИсториейИзменений

&НаСервере
Процедура ИнициацияПараметровИстории()
	
	ГлубинаХранения = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_ГлубинаХраненияИсторииАлгоритмов");
	
	ПараметрыИстории = Новый Структура;
	ПараметрыИстории.Вставить("ИсторияИзмененийСхемы", Новый Массив);
	ПараметрыИстории.Вставить("УказательТекущейСхемы", 0);
	ПараметрыИстории.Вставить("ГлубинаХранения",       ГлубинаХранения + 1);
	ПараметрыИстории.Вставить("ГраницаСохранения",     0);
	ПараметрыИстории.Вставить("СчетчикСдвига",         0);
	
	АдресПараметровИстории = ПоместитьВоВременноеХранилище(ПараметрыИстории, УникальныйИдентификатор);
	
КонецПроцедуры

&НаСервере
Функция ИзмененныеСвойстваТочек()
	
	Если НЕ ТекущаяТочкаМодифицированность Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыОтбора = Новый Структура("ИдентификаторТочки", ТекущаяТочкаИдентификатор);
	НайденыеСтроки  = ТочкиМаршрута.НайтиСтроки(ПараметрыОтбора);
	Если НайденыеСтроки.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	СвойстваТочки = НайденыеСтроки[0];
	
	ИзмененныеСвойстваТочек = Новый ТаблицаЗначений;
	ИзмененныеСвойстваТочек.Колонки.Добавить("ИдентификаторТочки", Новый ОписаниеТипов("Число",
												Новый КвалификаторыЧисла(10, 0, ДопустимыйЗнак.Любой)));
	ИзмененныеСвойстваТочек.Колонки.Добавить("НаименованиеСвойства");															   
	ИзмененныеСвойстваТочек.Колонки.Добавить("ЗначениеДоИзменения");
	ИзмененныеСвойстваТочек.Колонки.Добавить("ЗначениеПослеИзменения");
	
	Если СвойстваТочки.Наименование <> ТекущаяТочкаНаименование Тогда
		ИзмененноеСвойство = ИзмененныеСвойстваТочек.Добавить();
		ИзмененноеСвойство.ИдентификаторТочки     = ТекущаяТочкаИдентификатор;
		ИзмененноеСвойство.НаименованиеСвойства   = "Наименование";
		ИзмененноеСвойство.ЗначениеДоИзменения    = СвойстваТочки.Наименование;
		ИзмененноеСвойство.ЗначениеПослеИзменения = ТекущаяТочкаНаименование;
	КонецЕсли;
	Если СвойстваТочки.Действие <> ТекущаяТочкаДействие Тогда
		ИзмененноеСвойство = ИзмененныеСвойстваТочек.Добавить();
		ИзмененноеСвойство.ИдентификаторТочки     = ТекущаяТочкаИдентификатор;
		ИзмененноеСвойство.НаименованиеСвойства   = "Действие";
		ИзмененноеСвойство.ЗначениеДоИзменения    = СвойстваТочки.Действие;
		ИзмененноеСвойство.ЗначениеПослеИзменения = ТекущаяТочкаДействие;
	КонецЕсли;
	Если СвойстваТочки.Условие <> ТекущаяТочкаУсловие Тогда
		ИзмененноеСвойство = ИзмененныеСвойстваТочек.Добавить();
		ИзмененноеСвойство.ИдентификаторТочки     = ТекущаяТочкаИдентификатор;
		ИзмененноеСвойство.НаименованиеСвойства   = "Условие";
		ИзмененноеСвойство.ЗначениеДоИзменения    = СвойстваТочки.Условие;
		ИзмененноеСвойство.ЗначениеПослеИзменения = ТекущаяТочкаУсловие;
	КонецЕсли;
	Если СвойстваТочки.КодТочки <> ТекущаяТочкаКодТочки Тогда
		ИзмененноеСвойство = ИзмененныеСвойстваТочек.Добавить();
		ИзмененноеСвойство.ИдентификаторТочки     = ТекущаяТочкаИдентификатор;
		ИзмененноеСвойство.НаименованиеСвойства   = "КодТочки";
		ИзмененноеСвойство.ЗначениеДоИзменения    = СвойстваТочки.КодТочки;
		ИзмененноеСвойство.ЗначениеПослеИзменения = ТекущаяТочкаКодТочки;
	КонецЕсли;
	Если СвойстваТочки.ВыборВарианта <> ТекущаяТочкаВыборВарианта Тогда
		ИзмененноеСвойство = ИзмененныеСвойстваТочек.Добавить();
		ИзмененноеСвойство.ИдентификаторТочки     = ТекущаяТочкаИдентификатор;
		ИзмененноеСвойство.НаименованиеСвойства   = "ВыборВарианта";
		ИзмененноеСвойство.ЗначениеДоИзменения    = СвойстваТочки.ВыборВарианта;
		ИзмененноеСвойство.ЗначениеПослеИзменения = ТекущаяТочкаВыборВарианта;
	КонецЕсли;
	
	Возврат ИзмененныеСвойстваТочек;
	
КонецФункции

&НаСервере
Процедура ДобавитьНовуюСхемуВИсторию()
	
	ПараметрыИстории      = ПолучитьИзВременногоХранилища(АдресПараметровИстории);
	
	ИсторияИзмененийСхемы = ПараметрыИстории.ИсторияИзмененийСхемы;
	ГлубинаХранения       = ПараметрыИстории.ГлубинаХранения;
	ГраницаСохранения     = ПараметрыИстории.ГраницаСохранения;
	УказательТекущейСхемы = ПараметрыИстории.УказательТекущейСхемы;
	
	Если ГлубинаХранения = 1 Тогда
		Возврат;
	КонецЕсли;
	
	Если ИсторияИзмененийСхемы.Количество() < ГлубинаХранения Тогда
		ИсторияИзмененийСхемы.Добавить(Неопределено);
	КонецЕсли;
	
	СхемаXDTO = СериализаторXDTO.ЗаписатьXDTO(ГрафическаяСхема);
	СохраняемыеПараметры = Новый Структура;
	СохраняемыеПараметры.Вставить("Схема", СхемаXDTO);
	СохраняемыеПараметры.Вставить("ИзмененныеСвойстваТочек", ИзмененныеСвойстваТочек());
	
	ИсторияИзмененийСхемы[УказательТекущейСхемы] = СохраняемыеПараметры;
	
	УказательТекущейСхемы = УказательТекущейСхемы + 1;
	Если УказательТекущейСхемы = ГлубинаХранения Тогда
		УказательТекущейСхемы = 0;
	КонецЕсли;
	
	Если УказательТекущейСхемы = ГраницаСохранения Тогда
		ГраницаСохранения = ГраницаСохранения + 1;
	КонецЕсли;
	
	Если ГраницаСохранения = ГлубинаХранения Тогда
		ГраницаСохранения = 0;
	КонецЕсли;
	
	Если ИсторияИзмененийСхемы.Количество() > 1 Тогда
		Элементы.ГрафическаяСхемаИсторияОтменитьИзменение.Доступность = Истина;
	КонецЕсли;
	Элементы.ГрафическаяСхемаИсторияВернутьИзменение.Доступность = Ложь;
	
	ПараметрыИстории.УказательТекущейСхемы = УказательТекущейСхемы;
	ПараметрыИстории.ГраницаСохранения     = ГраницаСохранения;
	ПараметрыИстории.СчетчикСдвига         = 0;
	
	ПоместитьВоВременноеХранилище(ПараметрыИстории, АдресПараметровИстории);
	
КонецПроцедуры

&НаСервере
Процедура ИсторияОтменитьИзменениеНаСервере()
	
	ПараметрыИстории      = ПолучитьИзВременногоХранилища(АдресПараметровИстории);
	
	ИсторияИзмененийСхемы      = ПараметрыИстории.ИсторияИзмененийСхемы;
	ГлубинаХранения            = ПараметрыИстории.ГлубинаХранения;
	ГраницаСохранения          = ПараметрыИстории.ГраницаСохранения;
	УказательТекущейСхемы      = ПараметрыИстории.УказательТекущейСхемы;
	СчетчикСдвига              = ПараметрыИстории.СчетчикСдвига;
	
	УказательТекущейСхемы = УказательТекущейСхемы - 1;
	Если УказательТекущейСхемы < 0 Тогда
		УказательТекущейСхемы = ГлубинаХранения - 1;
	КонецЕсли;
	
	ИндексИзвлекаемогоЭлемента = УказательТекущейСхемы - 1;
	Если ИндексИзвлекаемогоЭлемента < 0 Тогда
		ИндексИзвлекаемогоЭлемента = ГлубинаХранения - 1;
	КонецЕсли;
	
	СохраняемыеПараметры = ИсторияИзмененийСхемы[ИндексИзвлекаемогоЭлемента];
	ГрафическаяСхема     = СериализаторXDTO.ПрочитатьXDTO(СохраняемыеПараметры.Схема);
	
	// Измененные свойства точек хранятся в элементе массива, на котором выполнялись преобразования.
	ИзмененныеСвойстваТочек = ИсторияИзмененийСхемы[УказательТекущейСхемы].ИзмененныеСвойстваТочек;
	Если ИзмененныеСвойстваТочек <> Неопределено Тогда
		Для каждого ИзмененноеСвойство Из ИзмененныеСвойстваТочек Цикл
			ПараметрыОтбора = Новый Структура("ИдентификаторТочки", ИзмененноеСвойство.ИдентификаторТочки);
			НайденыеСтроки  = ТочкиМаршрута.НайтиСтроки(ПараметрыОтбора);
			Если НайденыеСтроки.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			СвойстваТочки = НайденыеСтроки[0];
			ЭтоСвойстваТекущейТочки = (ТекущаяТочкаИдентификатор = ИзмененноеСвойство.ИдентификаторТочки);
			Если ИзмененноеСвойство.НаименованиеСвойства = "Наименование" Тогда
				СвойстваТочки.Наименование = ИзмененноеСвойство.ЗначениеДоИзменения;
				Если ЭтоСвойстваТекущейТочки Тогда
					ТекущаяТочкаНаименование = ИзмененноеСвойство.ЗначениеДоИзменения;
				КонецЕсли;
			ИначеЕсли ИзмененноеСвойство.НаименованиеСвойства = "Действие" Тогда
				СвойстваТочки.Действие = ИзмененноеСвойство.ЗначениеДоИзменения;
				Если ЭтоСвойстваТекущейТочки Тогда
					ТекущаяТочкаДействие = ИзмененноеСвойство.ЗначениеДоИзменения;
				КонецЕсли;
			ИначеЕсли ИзмененноеСвойство.НаименованиеСвойства = "Условие" Тогда
				СвойстваТочки.Условие = ИзмененноеСвойство.ЗначениеДоИзменения;
				Если ЭтоСвойстваТекущейТочки Тогда
					ТекущаяТочкаУсловие = ИзмененноеСвойство.ЗначениеДоИзменения;
				КонецЕсли;
			ИначеЕсли ИзмененноеСвойство.НаименованиеСвойства = "КодТочки" Тогда
				СвойстваТочки.КодТочки = ИзмененноеСвойство.ЗначениеДоИзменения;
				Если ЭтоСвойстваТекущейТочки Тогда
					ТекущаяТочкаКодТочки = ИзмененноеСвойство.ЗначениеДоИзменения;
				КонецЕсли;
			ИначеЕсли ИзмененноеСвойство.НаименованиеСвойства = "ВыборВарианта" Тогда
				СвойстваТочки.ВыборВарианта = ИзмененноеСвойство.ЗначениеДоИзменения;
				Если ЭтоСвойстваТекущейТочки Тогда
					ТекущаяТочкаВыборВарианта = ИзмененноеСвойство.ЗначениеДоИзменения;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	СчетчикСдвига        = СчетчикСдвига + 1;
	
	Элементы.ГрафическаяСхемаИсторияВернутьИзменение.Доступность = Истина;
	Если УказательТекущейСхемы = (ГраницаСохранения + 1) Тогда
		Элементы.ГрафическаяСхемаИсторияОтменитьИзменение.Доступность = Ложь;
	КонецЕсли;
	
	ПараметрыИстории.УказательТекущейСхемы = УказательТекущейСхемы;
	ПараметрыИстории.СчетчикСдвига         = СчетчикСдвига;
	
	ПоместитьВоВременноеХранилище(ПараметрыИстории, АдресПараметровИстории);
	
	УстановитьСвойстваТекущейСтрокиТочекМаршрута(ЭтотОбъект);
	ПриИзмененииГрафическойСхемы(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ИсторияВернутьИзменениеНаСервере()
	
	ПараметрыИстории      = ПолучитьИзВременногоХранилища(АдресПараметровИстории);
	
	ИсторияИзмененийСхемы = ПараметрыИстории.ИсторияИзмененийСхемы;
	ГлубинаХранения       = ПараметрыИстории.ГлубинаХранения;
	ГраницаСохранения     = ПараметрыИстории.ГраницаСохранения;
	УказательТекущейСхемы = ПараметрыИстории.УказательТекущейСхемы;
	СчетчикСдвига         = ПараметрыИстории.СчетчикСдвига;
	
	УказательТекущейСхемы = УказательТекущейСхемы + 1;
	Если УказательТекущейСхемы = ГлубинаХранения Тогда
		УказательТекущейСхемы = 0;
	КонецЕсли;
	
	ИндексИзвлекаемогоЭлемента = УказательТекущейСхемы - 1;
	Если ИндексИзвлекаемогоЭлемента < 0 Тогда
		ИндексИзвлекаемогоЭлемента = ГлубинаХранения - 1;
	КонецЕсли;
	
	СохраняемыеПараметры = ИсторияИзмененийСхемы[ИндексИзвлекаемогоЭлемента];
	ГрафическаяСхема     = СериализаторXDTO.ПрочитатьXDTO(СохраняемыеПараметры.Схема);
	Если СохраняемыеПараметры.ИзмененныеСвойстваТочек <> Неопределено Тогда
		Для каждого ИзмененноеСвойство Из СохраняемыеПараметры.ИзмененныеСвойстваТочек Цикл
			ПараметрыОтбора = Новый Структура("ИдентификаторТочки", ИзмененноеСвойство.ИдентификаторТочки);
			НайденыеСтроки  = ТочкиМаршрута.НайтиСтроки(ПараметрыОтбора);
			Если НайденыеСтроки.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			СвойстваТочки = НайденыеСтроки[0];
			ЭтоСвойстваТекущейТочки = (ТекущаяТочкаИдентификатор = ИзмененноеСвойство.ИдентификаторТочки);
			Если ИзмененноеСвойство.НаименованиеСвойства = "Наименование" Тогда
				СвойстваТочки.Наименование = ИзмененноеСвойство.ЗначениеПослеИзменения;
				Если ЭтоСвойстваТекущейТочки Тогда
					ТекущаяТочкаНаименование = ИзмененноеСвойство.ЗначениеПослеИзменения;
				КонецЕсли;
			ИначеЕсли ИзмененноеСвойство.НаименованиеСвойства = "Действие" Тогда
				СвойстваТочки.Действие = ИзмененноеСвойство.ЗначениеПослеИзменения;
				Если ЭтоСвойстваТекущейТочки Тогда
					ТекущаяТочкаДействие = ИзмененноеСвойство.ЗначениеПослеИзменения;
				КонецЕсли;
			ИначеЕсли ИзмененноеСвойство.НаименованиеСвойства = "Условие" Тогда
				СвойстваТочки.Условие = ИзмененноеСвойство.ЗначениеПослеИзменения;
				Если ЭтоСвойстваТекущейТочки Тогда
					ТекущаяТочкаУсловие = ИзмененноеСвойство.ЗначениеПослеИзменения;
				КонецЕсли;
			ИначеЕсли ИзмененноеСвойство.НаименованиеСвойства = "КодТочки" Тогда
				СвойстваТочки.КодТочки = ИзмененноеСвойство.ЗначениеПослеИзменения;
				Если ЭтоСвойстваТекущейТочки Тогда
					ТекущаяТочкаКодТочки = ИзмененноеСвойство.ЗначениеПослеИзменения;
				КонецЕсли;
			ИначеЕсли ИзмененноеСвойство.НаименованиеСвойства = "ВыборВарианта" Тогда
				СвойстваТочки.ВыборВарианта = ИзмененноеСвойство.ЗначениеДоИзменения;
				Если ЭтоСвойстваТекущейТочки Тогда
					ТекущаяТочкаВыборВарианта = ИзмененноеСвойство.ЗначениеДоИзменения;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	СчетчикСдвига        = СчетчикСдвига - 1;
	
	Если СчетчикСдвига = 0 Тогда
		Элементы.ГрафическаяСхемаИсторияВернутьИзменение.Доступность = Ложь;
	КонецЕсли;
	Элементы.ГрафическаяСхемаИсторияОтменитьИзменение.Доступность = Истина;
	
	ПараметрыИстории.УказательТекущейСхемы = УказательТекущейСхемы;
	ПараметрыИстории.СчетчикСдвига         = СчетчикСдвига;
	
	ПоместитьВоВременноеХранилище(ПараметрыИстории, АдресПараметровИстории);
	
	УстановитьСвойстваТекущейСтрокиТочекМаршрута(ЭтотОбъект);
	ПриИзмененииГрафическойСхемы(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область РаботаПомощникомСозданияТочек

&НаСервере
Процедура СоздатьТочкиВыбранныеВПомощнике(Знач АдресХранищаРезультатаВыбора)
	
	ПараметрыВводаТочек      = ПолучитьИзВременногоХранилища(АдресХранищаРезультатаВыбора);
	КодТекущейТочки          = ПараметрыВводаТочек.КодТекущейТочки;
	ПользовательскоеДействие = ПараметрыВводаТочек.Действие;
	ТаблицаТочек             = ПараметрыВводаТочек.ТаблицаТочек;
	
	ЭлементыПоИдентификаторам = Новый Соответствие;
	ПараметрыРазмещения       = бит_ГрафическиеСхемы.НовыеПараметрыРазмещенияЭлементовСхемы();
	ТаблицаСвязей             = бит_ГрафическиеСхемы.НоваяТаблицаСвязейЭлементовГрафическойСхемы();
	СхемаXDTO                 = СериализаторXDTO.ЗаписатьXDTO(ГрафическаяСхема);
	ЭлементыСхемы             = СхемаXDTO.item;	
	
	СчетчикИндекс          = 0;
	ЭлементРодитель        = Неопределено;
	Для каждого ЭлементСхемы Из ЭлементыСхемы Цикл
		СчетчикИндекс = Макс(ЭлементСхемы.itemId, СчетчикИндекс);
		ЭлементыПоИдентификаторам.Вставить(ЭлементСхемы.itemId, ЭлементСхемы);
		Если КодТекущейТочки = ЭлементСхемы.itemCode Тогда
			ЭлементРодитель = ЭлементСхемы;
		КонецЕсли;
	КонецЦикла;
	
	Если ЭлементРодитель = Неопределено Тогда
		ТекстСообщения = НСтр("ru = 'Не удалось определить текущий элемент схемы.';
								|en = 'Cant match current cheme element.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ИсходящаяЛинияРодителя = Неопределено;
	ТочкаПродолжения       = Неопределено;
	Для каждого ЭлементСхемы Из ЭлементыСхемы Цикл
		ТипЭлемента = бит_ГрафическиеСхемы.ТипЭлементаXDTOГрафическойСхемы(ЭлементСхемы);
		Если ТипЭлемента <> Перечисления.бит_ЭлементыГрафическойСхемы.Линия Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЭлементСхемы.connectFromItemId = ЭлементРодитель.itemId Тогда
			ИсходящаяЛинияРодителя = ЭлементСхемы;
			ТочкаПродолжения       = ЭлементыПоИдентификаторам.Получить(ИсходящаяЛинияРодителя.connectToItemId);
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	СчетчикИндекс = СчетчикИндекс + 1;
	
	ТочкаРазделения   = бит_ГрафическиеСхемы.НовыйЭлементСхемы(Перечисления.бит_ЭлементыГрафическойСхемы.Разделение,
																СчетчикИндекс);
	ЭлементыПоИдентификаторам.Вставить(СчетчикИндекс, ТочкаРазделения);
	СчетчикИндекс     = СчетчикИндекс + 1;
	ГраницыРазмещения = бит_ГрафическиеСхемы.ГраницыРазмещенияЭлементаСхемы(ПараметрыРазмещения, 2, 1);
	бит_ГрафическиеСхемы.РазместитьЭлементНаСхеме(ТочкаРазделения, ГраницыРазмещения, ПараметрыРазмещения);
	ЭлементыСхемы.Добавить(ТочкаРазделения);
	ДобавитьТочкуМаршрута(ТочкаРазделения);
	
	СоединительнаяЛиния = бит_ГрафическиеСхемы.НовыйЭлементСхемы(Перечисления.бит_ЭлементыГрафическойСхемы.Линия,
																СчетчикИндекс);
	ЭлементыПоИдентификаторам.Вставить(СчетчикИндекс, СоединительнаяЛиния);
	СчетчикИндекс       = СчетчикИндекс + 1;
	ЭлементыСхемы.Добавить(СоединительнаяЛиния);
	бит_ГрафическиеСхемы.УстановитьПривязкуСоединительнойЛинии(СоединительнаяЛиния, ТаблицаСвязей, ЭлементРодитель,
																ТочкаРазделения);
	
	ТочкаСлияния      = бит_ГрафическиеСхемы.НовыйЭлементСхемы(Перечисления.бит_ЭлементыГрафическойСхемы.Слияние,
																СчетчикИндекс);
	ЭлементыПоИдентификаторам.Вставить(СчетчикИндекс, ТочкаСлияния);
	СчетчикИндекс     = СчетчикИндекс + 1;
	ГраницыРазмещения = бит_ГрафическиеСхемы.ГраницыРазмещенияЭлементаСхемы(ПараметрыРазмещения, 4, 1);
	бит_ГрафическиеСхемы.РазместитьЭлементНаСхеме(ТочкаСлияния, ГраницыРазмещения, ПараметрыРазмещения);
	ЭлементыСхемы.Добавить(ТочкаСлияния);
	ДобавитьТочкуМаршрута(ТочкаСлияния);
	
	ИменаДоступныхПараметров = Новый СписокЗначений;
	Для каждого КолонкаТаблицы Из ТаблицаТочек.Колонки Цикл
		ИменаДоступныхПараметров.Добавить(КолонкаТаблицы.Имя);
	КонецЦикла;
	
	ВидДобавляемыхДействий = Перечисления.бит_ЭлементыГрафическойСхемы.Действие;
	Если ЗначениеЗаполнено(ПользовательскоеДействие)
		И (ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПользовательскоеДействие, "Назначение")
			= Перечисления.бит_НазначенияПользовательскихДействий.ПодчиненныйПроцесс) Тогда
		ВидДобавляемыхДействий = Перечисления.бит_ЭлементыГрафическойСхемы.ВложенныйПроцесс;
	КонецЕсли;
	
	НомерДобавляемого = 1;
	Для каждого СтрокаТабличцыТочек Из ТаблицаТочек Цикл
		НовыйЭлемент      = бит_ГрафическиеСхемы.НовыйЭлементСхемы(ВидДобавляемыхДействий, СчетчикИндекс);
		ЭлементыПоИдентификаторам.Вставить(СчетчикИндекс, НовыйЭлемент);
		СчетчикИндекс     = СчетчикИндекс + 1;
		ГраницыРазмещения = бит_ГрафическиеСхемы.ГраницыРазмещенияЭлементаСхемы(ПараметрыРазмещения, 3, НомерДобавляемого);
		бит_ГрафическиеСхемы.РазместитьЭлементНаСхеме(НовыйЭлемент, ГраницыРазмещения, ПараметрыРазмещения);
		ЭлементыСхемы.Добавить(НовыйЭлемент);
		
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("ПользовательскоеДействие", ПользовательскоеДействие);
		СтруктураПараметров.Вставить("ИменаДоступныхПараметров", ИменаДоступныхПараметров);
		СтруктураПараметров.Вставить("СтрокаТабличцыТочек",      СтрокаТабличцыТочек);
		ДобавитьТочкуМаршрута(НовыйЭлемент, СтруктураПараметров);
		
		СоединительнаяЛиния = бит_ГрафическиеСхемы.НовыйЭлементСхемы(Перечисления.бит_ЭлементыГрафическойСхемы.Линия,
																	СчетчикИндекс);
		ЭлементыПоИдентификаторам.Вставить(СчетчикИндекс, СоединительнаяЛиния);
		СчетчикИндекс       = СчетчикИндекс + 1;
		ЭлементыСхемы.Добавить(СоединительнаяЛиния);
		бит_ГрафическиеСхемы.УстановитьПривязкуСоединительнойЛинии(СоединительнаяЛиния, ТаблицаСвязей, ТочкаРазделения,
																	НовыйЭлемент);
		
		СоединительнаяЛиния = бит_ГрафическиеСхемы.НовыйЭлементСхемы(Перечисления.бит_ЭлементыГрафическойСхемы.Линия,
																	СчетчикИндекс);
		ЭлементыПоИдентификаторам.Вставить(СчетчикИндекс, СоединительнаяЛиния);
		СчетчикИндекс       = СчетчикИндекс + 1;
		ЭлементыСхемы.Добавить(СоединительнаяЛиния);
		бит_ГрафическиеСхемы.УстановитьПривязкуСоединительнойЛинии(СоединительнаяЛиния, ТаблицаСвязей, НовыйЭлемент, ТочкаСлияния);
		
		НомерДобавляемого = НомерДобавляемого + 1;
	КонецЦикла;
	
	Если ИсходящаяЛинияРодителя <> Неопределено Тогда
		бит_ГрафическиеСхемы.УстановитьПривязкуСоединительнойЛинии(ИсходящаяЛинияРодителя, ТаблицаСвязей, ТочкаСлияния,
																ТочкаПродолжения);
	Иначе														
		СоединительнаяЛиния = бит_ГрафическиеСхемы.НовыйЭлементСхемы(Перечисления.бит_ЭлементыГрафическойСхемы.Линия,
																		СчетчикИндекс);
		ЭлементыПоИдентификаторам.Вставить(СчетчикИндекс, СоединительнаяЛиния);
		СчетчикИндекс       = СчетчикИндекс + 1;
		ЭлементыСхемы.Добавить(СоединительнаяЛиния);
		бит_ГрафическиеСхемы.УстановитьПривязкуСоединительнойЛинии(СоединительнаяЛиния, ТаблицаСвязей, ТочкаСлияния);
	КонецЕсли;
	
	ПараметрыРазмещения.МенятьГраниСоединенияЛиний = Ложь;
	бит_ГрафическиеСхемы.РазместитьЛинииСвязей(ТаблицаСвязей, ЭлементыПоИдентификаторам, ПараметрыРазмещения);
	ПараметрыРазмещения.МенятьГраниСоединенияЛиний = Истина;
	
	ГрафическаяСхема = СериализаторXDTO.ПрочитатьXDTO(СхемаXDTO);
	
	АвторазмещениеЭлементовНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьТочкуМаршрута(НоваяТочкаМаршрута, СтруктураПараметров = Неопределено)
	
	ВидыЭлементов = бит_УправлениеПроцессами.ВидыЭлементовГрафическойСхемы();
	ВидТочки      = ВидыЭлементов[НоваяТочкаМаршрута.itemType];
	
	СтрокаТаблицы = ТочкиМаршрута.Добавить();
	СтрокаТаблицы.ВидТочки           = ВидТочки;
	СтрокаТаблицы.ИдентификаторТочки = НоваяТочкаМаршрута.itemId;
	СтрокаТаблицы.Наименование       = НоваяТочкаМаршрута.itemTitle.item[0].content;
	СтрокаТаблицы.КодТочки           = НоваяТочкаМаршрута.itemCode;
	СтрокаТаблицы.Модифицированность = Истина;
	СтрокаТаблицы.НоваяТочка         = Истина;
	
	Если ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Действие
		ИЛИ ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Обработка
		ИЛИ ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.ПодчиненныйПроцесс Тогда
		СтрокаТаблицы.Действие = СтруктураПараметров.ПользовательскоеДействие;
		
		ПредставлениеТочки = Строка(СтрокаТаблицы.Действие);
		Для каждого ТекущийПараметр Из Объект.ПараметрыАлгоритма Цикл
			Если НЕ ТекущийПараметр.Динамический Тогда
				Продолжить;
			КонецЕсли;
			НовыйПараметрТочки = СтрокаТаблицы.ПараметрыТочки.Добавить();
			ЗаполнитьЗначенияСвойств(НовыйПараметрТочки, ТекущийПараметр);
			
			Если СтруктураПараметров.ИменаДоступныхПараметров.НайтиПоЗначению(НовыйПараметрТочки.Имя) <> Неопределено Тогда
				ЗначениеПараметра = СтруктураПараметров.СтрокаТабличцыТочек[НовыйПараметрТочки.Имя];
				НовыйПараметрТочки.Значение = НовыйПараметрТочки.Тип.ПривестиЗначение(ЗначениеПараметра);
				
				ПредставлениеПараметра = Строка(НовыйПараметрТочки.Значение);
				Если НЕ ПустаяСтрока(ПредставлениеПараметра) Тогда
					ПредставлениеТочки = ПредставлениеТочки + ". " + СокрЛП(ПредставлениеПараметра);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		СтрокаТаблицы.Наименование = ПредставлениеТочки;
		НоваяТочкаМаршрута.itemTitle.item[0].content =  ПредставлениеТочки;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ПроверитьИспользованиеАлгоритма(Отказ)
	
	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	УправлениеДопИнформацией();
	
	Если РазрешенаЗаписьИспользуемогоАлгоритма Тогда
		Возврат;
	КонецЕсли;
	
	
	Если ТочкиМаршрутаКУдалению.Количество() = 0
		ИЛИ НЕ АлгоритмИспользуется Тогда
		Возврат;
	КонецЕсли;
	
	Отказ = Истина;
	ТекстОшибки = НСтр("ru='Алгоритм используется. Удаление точек может вызвать несоответствие списка виз карте маршрута. Принять риски и продолжить?'");
	Оповещение  = Новый ОписаниеОповещения("ВопросРазренитьЗаписьИспользуемогоАлгоритмаЗавершение", ЭтотОбъект);
	Вопрос      = РежимДиалогаВопрос.ДаНет;
	ПоказатьВопрос(Оповещение, ТекстОшибки, Вопрос, 0);
	
КонецПроцедуры

// Процедура - обработчик оповещения "ВопросРазренитьЗаписьИспользуемогоАлгоритмаЗавершение".
// 
&НаКлиенте
Процедура ВопросРазренитьЗаписьИспользуемогоАлгоритмаЗавершение(Ответ, Параметры) Экспорт

	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	РазрешенаЗаписьИспользуемогоАлгоритма = Истина;
	Записать();
	
КонецПроцедуры

#КонецОбласти 