#Область СлужебныеПроцедурыИФункции

#Область РаботаСРегламентнымЗаданием

&НаСервере
Функция КлючРегламентногоЗадания()
	
	Если Объект.Ссылка.Пустая() Тогда
		ВызватьИсключение НСтр("ru = 'Получение ключа задания для несохраненного элемента.'");
	КонецЕсли;
	
	УникальныйИдентификаторАлгоритма = Объект.Ссылка.UUID();
	КлючЗадания = "СтартоватьПроцесс_" + УникальныйИдентификаторАлгоритма;
	
	Возврат КлючЗадания;
	
КонецФункции

&НаСервере
Процедура ПрочитатьДанныеРегламентногоЗадания()
	
	РегламентноеЗадание = Неопределено;
	
	Если НЕ Объект.Ссылка.Пустая() Тогда
		УстановитьПривилегированныйРежим(Истина);
		Отбор = Новый Структура;
		Отбор.Вставить("Ключ", КлючРегламентногоЗадания());
		Отбор.Вставить("Метаданные", Метаданные.РегламентныеЗадания.бит_СтартПериодическихПроцессовБФ);
		МассивЗаданий = РегламентныеЗаданияСервер.НайтиЗадания(Отбор);
		Если МассивЗаданий.Количество() > 0 Тогда
			РегламентноеЗадание = МассивЗаданий[0];
			ИдентификаторРегламентногоЗадания = РегламентноеЗадание.УникальныйИдентификатор;
		КонецЕсли;
		УстановитьПривилегированныйРежим(Ложь)
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИдентификаторРегламентногоЗадания) Тогда
		СтартоватьПоРасписанию         = РегламентноеЗадание.Использование;
		РасписаниеРегламентногоЗадания = РегламентноеЗадание.Расписание;
		НадписьРасписание              = РасписаниеРегламентногоЗадания;
	Иначе
		СтартоватьПоРасписанию = Ложь;
		НадписьРасписание      = НСтр("ru = '<Расписание не задано>'"); 
	КонецЕсли;
	
	Элементы.НадписьРасписание.Доступность = СтартоватьПоРасписанию;
	
КонецПроцедуры

// Процедура окончание выбора расписания задания. 
//
// Параметры:
//  РезультатВыбора         - Структура.
//  ДополнительныеПараметры - Структура.
//
&НаКлиенте 
Процедура УстановитьРасписанияРегламентногоЗадания(РасписаниеЗадания, ДополнительныеПараметры) Экспорт
	
	Если РасписаниеЗадания = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НадписьРасписание              = РасписаниеЗадания;
	РасписаниеРегламентногоЗадания = РасписаниеЗадания;
	
	УстановитьРасписанияРегламентногоЗаданияНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьРасписанияРегламентногоЗаданияНаСервере()
	
	УстановитьПривилегированныйРежим(Истина);
	РегламентныеЗаданияСервер.УстановитьРасписаниеРегламентногоЗадания(ИдентификаторРегламентногоЗадания,
																		РасписаниеРегламентногоЗадания);
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьИспользованиеРегламентногоЗадания()
	
	УстановитьПривилегированныйРежим(Истина);
	Если СтартоватьПоРасписанию Тогда
		Если ЗначениеЗаполнено(ИдентификаторРегламентногоЗадания) Тогда
			РегламентныеЗаданияСервер.УстановитьИспользованиеРегламентногоЗадания(ИдентификаторРегламентногоЗадания, Истина);
		Иначе
			ПараметрыЗадания = Новый Структура;
			ПараметрыЗадания.Вставить("Использование", Истина);
		
			ПараметрыВыполненияЗадания = Новый Массив;
			ПараметрыВыполненияЗадания.Добавить(Объект.Ссылка);
			
			НаименованиеЗадания = СтрШаблон(НСтр("ru = 'Старт процесса ""%1""'"), Объект.Наименование);
			
			ПараметрыЗадания.Вставить("Метаданные",    Метаданные.РегламентныеЗадания.бит_СтартПериодическихПроцессовБФ);
			ПараметрыЗадания.Вставить("Параметры",     ПараметрыВыполненияЗадания);
			ПараметрыЗадания.Вставить("Наименование",  НаименованиеЗадания);
			ПараметрыЗадания.Вставить("Ключ",          КлючРегламентногоЗадания());
			
			РегламентноеЗадание = РегламентныеЗаданияСервер.ДобавитьЗадание(ПараметрыЗадания);
			ИдентификаторРегламентногоЗадания = РегламентноеЗадание.УникальныйИдентификатор;
		КонецЕсли;
		РасписаниеРегламентногоЗадания = РегламентныеЗаданияСервер.РасписаниеРегламентногоЗадания(ИдентификаторРегламентногоЗадания);
		НадписьРасписание              = РасписаниеРегламентногоЗадания;
	Иначе
		Если ЗначениеЗаполнено(ИдентификаторРегламентногоЗадания) Тогда
			РегламентныеЗаданияСервер.УстановитьИспользованиеРегламентногоЗадания(ИдентификаторРегламентногоЗадания, Ложь);
		КонецЕсли;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	
	Элементы.НадписьРасписание.Доступность = СтартоватьПоРасписанию;
	
КонецПроцедуры

// Процедура - обработчик оповещения "ПередЗаписьюОтключениеРегЗаданияЗавершение".
// 
&НаКлиенте
Процедура ПередЗаписьюОтключениеРегЗаданияЗавершение(Ответ, Параметры) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда
		СтартоватьПоРасписанию = Ложь;
		УстановитьИспользованиеРегламентногоЗадания();
		Записать();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

