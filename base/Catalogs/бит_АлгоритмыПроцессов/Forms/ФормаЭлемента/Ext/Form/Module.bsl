КонецПроцедуры

&НаСервере
Процедура ОбработатьИзменениеТекущейТочкиУсловиеНаСервере()
	
	ТекущаяТочкаМодифицированность = Истина;
	
	Если ЗначениеЗаполнено(ТекущаяТочкаУсловие) Тогда
		ТекущаяТочкаНаименование = Строка(ТекущаяТочкаУсловие);
		ПриИзмененииНаименованияТекущейТочки();
	КонецЕсли; 
	
	ВыделитьЭлементСхемы(ТекущаяТочкаУсловие, Ложь, Строка(ТекущаяТочкаИдентификатор), ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзменениеТекущейТочкиУсловие()
	
	ОбработатьИзменениеТекущейТочкиУсловиеНаСервере();

КонецПроцедуры

&НаСервере
Процедура ОбработатьИзменениеВыбораВарианта()
	
	ТекущаяТочкаМодифицированность = Истина;
	
	Если ЗначениеЗаполнено(ТекущаяТочкаВыборВарианта) Тогда
		ТекущаяТочкаНаименование = Строка(ТекущаяТочкаВыборВарианта);
		ПриИзмененииНаименованияТекущейТочки();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьИзменениеВарантовТекущейТочки()
	
	ТекущаяТочкаМодифицированность = Истина;
	
	СхемаXDTO     = СериализаторXDTO.ЗаписатьXDTO(ГрафическаяСхема);
	ЭлементыСхемы = СхемаXDTO.item;
	
	СвойстваЭлементов         = бит_ГрафическиеСхемы.ОписаниеСвойствЭлементовСхемы(ЭлементыСхемы);
	ЭлементыПоИдентификаторам = СвойстваЭлементов.ЭлементыПоИдентификаторам;
	ТаблицаСвязей             = СвойстваЭлементов.ТаблицаСвязей;
	
	ЭлементВариантыВыбора     = ЭлементыПоИдентификаторам.Получить(ТекущаяТочкаИдентификатор);
	Если ЭлементВариантыВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВариантыСхемы            = ЭлементВариантыВыбора.transition;
	ВариантыПользователя     = ТекущаяТочкаВарианты.Выгрузить();
	КолВариантовСхемы        = ВариантыСхемы.Количество();
	КолВариантовПользователя = ВариантыПользователя.Количество();
	
	Если КолВариантовПользователя < КолВариантовСхемы Тогда
		
		// Удален вариант.
		ИндексУдаляемогоВарианта = 0;
		Для каждого ВариантСхемы Из ВариантыСхемы Цикл
			СтрокаВариантаПользователя = ВариантыПользователя.Найти(ВариантСхемы.name, "Имя");
			Если СтрокаВариантаПользователя = Неопределено Тогда
				Прервать; // Нашли удаленную строку.
			КонецЕсли;
			ИндексУдаляемогоВарианта = ИндексУдаляемогоВарианта + 1;
		КонецЦикла;
		
		Отбор = Новый Структура("ЭлементИсточник", ТекущаяТочкаИдентификатор);
		ИсходящиеСвязиВыбораВарианта = ТаблицаСвязей.НайтиСтроки(Отбор);
		Для каждого СтрокаСвязи Из ИсходящиеСвязиВыбораВарианта Цикл
			НомерВарианта = Окр((СтрокаСвязи.ГраньИсточника - 5) / 2);
			
			Если НомерВарианта = (ИндексУдаляемогоВарианта + 1) Тогда
				// Удаление исходящих линий удаляемого элемента.
				ИдентификаторЛинии = СтрокаСвязи.ЛинияСвязи;
				ТекущийИндекс = 0;
				Для каждого ЭлементСхемы Из ЭлементыСхемы Цикл
					Если ЭлементСхемы.itemId = ИдентификаторЛинии Тогда
						ЭлементыСхемы.Удалить(ТекущийИндекс);
						Прервать;
					КонецЕсли;
					ТекущийИндекс = ТекущийИндекс + 1;
				КонецЦикла;
			ИначеЕсли НомерВарианта > (ИндексУдаляемогоВарианта + 1) Тогда
				// Смещение граней связи.
				ЭлементСхемы = ЭлементыПоИдентификаторам.Получить(СтрокаСвязи.ЛинияСвязи);
				ЭлементСхемы.portIndexFrom = ЭлементСхемы.portIndexFrom - 2;
				СтрокаСвязи.ГраньИсточника = ЭлементСхемы.portIndexFrom;
			ИначеЕсли НомерВарианта < (ИндексУдаляемогоВарианта + 1) Тогда
				// Смещение координат линии связи.
				ЭлементСхемы       = ЭлементыПоИдентификаторам.Получить(СтрокаСвязи.ЛинияСвязи);
				ТочкиЛинииСвязи    = ЭлементСхемы.point;
				ОрдинатаДоСмещения = ТочкиЛинииСвязи[0].y;
				Смещение           = 20;
				Для каждого ТочкаЛинии Из ТочкиЛинииСвязи Цикл
					Если ТочкаЛинии.y = ОрдинатаДоСмещения Тогда
						ТочкаЛинии.y = ТочкаЛинии.y + Смещение;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		
		ВариантыСхемы.Удалить(ИндексУдаляемогоВарианта);
		
	ИначеЕсли КолВариантовПользователя > КолВариантовСхемы Тогда
		
		// Добавлен вариант.
		ИмяНовогоВарианта = "ВариантN";
		
		НовыйВариант = СериализаторXDTO.Фабрика.Создать(СериализаторXDTO.Фабрика.Тип("http://v8.1c.ru/8.2/data/graphscheme","Transition"));
		НовыйВариант.backColor   = Новый Цвет;
		НовыйВариант.name        = ИмяНовогоВарианта;
		
		ТипЛокализованнаяСтрока  = СериализаторXDTO.Фабрика.Тип("http://v8.1c.ru/8.1/data/core","LocalStringType");
		НовыйВариант.description = СериализаторXDTO.Фабрика.Создать(ТипЛокализованнаяСтрока);
		
		ТипЭлементЛокализации   = СериализаторXDTO.Фабрика.Тип("http://v8.1c.ru/8.1/data/core","LocalStringItemType");
		НовыйЭлементЛокализации = СериализаторXDTO.Фабрика.Создать(ТипЭлементЛокализации);
		НовыйЭлементЛокализации.lang    = "#";
		НовыйЭлементЛокализации.content = ИмяНовогоВарианта;
		НовыйВариант.description.item.Добавить(НовыйЭлементЛокализации);
		
		ВариантыСхемы.Добавить(НовыйВариант);
		
		// Увеличим высоту элемента варианты выбора.
		ЭлементВариантыВыбора.rectBottom = ЭлементВариантыВыбора.rectBottom + 20;
		ЭлементВариантыВыбора.point[2].y = ЭлементВариантыВыбора.point[2].y + 20;
		ЭлементВариантыВыбора.point[3].y = ЭлементВариантыВыбора.point[3].y + 20;
		
		// Добавим новую исходящую линию для варианта.
		МаксИдентификатор = 0;
		Для каждого ЭлементИдентификатора Из ЭлементыПоИдентификаторам Цикл
			МаксИдентификатор = Макс(МаксИдентификатор, ЭлементИдентификатора.Ключ);
		КонецЦикла;
		ИдентификаторЛинии  = МаксИдентификатор + 1;
		
		СоединительнаяЛиния = бит_ГрафическиеСхемы.НовыйЭлементСхемы(Перечисления.бит_ЭлементыГрафическойСхемы.Линия,
																	ИдентификаторЛинии);
		ЭлементыПоИдентификаторам.Вставить(ИдентификаторЛинии, СоединительнаяЛиния);
		
		бит_ГрафическиеСхемы.УстановитьПривязкуСоединительнойЛинии(СоединительнаяЛиния, ТаблицаСвязей,
												ЭлементВариантыВыбора,, КолВариантовСхемы * 2 + 7);
																	
		КоординатыТочки1 = бит_ГрафическиеСхемы.НовыеКоординатыЭлементаXDTO();
		КоординатыТочки1.x = ЭлементВариантыВыбора.rectRight - 1;
		КоординатыТочки1.y = ЭлементВариантыВыбора.rectBottom - 10;
		НоваяТочкаXDTO   = бит_ГрафическиеСхемы.НоваяТочкаXDTO(КоординатыТочки1);
		СоединительнаяЛиния.point.Добавить(НоваяТочкаXDTO);
		
		КоординатыТочки2 = бит_ГрафическиеСхемы.НовыеКоординатыЭлементаXDTO();
		КоординатыТочки2.x = КоординатыТочки1.x + 30;
		КоординатыТочки2.y = КоординатыТочки1.y;
		НоваяТочкаXDTO   = бит_ГрафическиеСхемы.НоваяТочкаXDTO(КоординатыТочки2);
		СоединительнаяЛиния.point.Добавить(НоваяТочкаXDTO);
		
		ЭлементыСхемы.Добавить(СоединительнаяЛиния);
	КонецЕсли;
	
	Индекс = 0;
	Для каждого ВариантСхемы Из ВариантыСхемы Цикл
		НовоеИмя = ВариантыПользователя.Получить(Индекс).Имя;
		Если ПустаяСтрока(НовоеИмя) Тогда
			НовоеИмя = СтрШаблон("Вариант %1", Индекс + 1);
		КонецЕсли;
		ВариантСхемы.name = НовоеИмя;
		ВариантСхемы.description.item[0].content = НовоеИмя;
		
		Индекс = Индекс + 1;
	КонецЦикла;
	
	ГрафическаяСхема = СериализаторXDTO.ПрочитатьXDTO(СхемаXDTO);
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьИзменениеТекущейТочкиДействиеНаСервере()
	
	ТекущаяТочкаМодифицированность = Истина;
	
	Если ЗначениеЗаполнено(ТекущаяТочкаДействие) Тогда
		ТекущаяТочкаНаименование = Строка(ТекущаяТочкаДействие);
		ПриИзмененииНаименованияТекущейТочки();
	КонецЕсли; 
	
	Затемнить = Ложь;
	Если Объект.ВидАлгоритма = Перечисления.бит_ВидыАлгоритмов.Визирование
		И ТекущаяТочкаВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.ПодчиненныйПроцесс Тогда
		Затемнить = Истина;
	КонецЕсли;
	
	ВыделитьЭлементСхемы(ТекущаяТочкаДействие, Затемнить, Строка(ТекущаяТочкаИдентификатор), ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзменениеТекущейТочкиДействие()
	
	ОбработатьИзменениеТекущейТочкиДействиеНаСервере();

КонецПроцедуры 

