// Выполнет замену дублей ключей.
//
Процедура ЗаменитьДублиКлючейАналитики() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДанныеСправочника.Ссылка КАК Ссылка,
	|	ДанныеСправочника.ПометкаУдаления КАК ПометкаУдаления,
	|	Аналитика.КлючАналитики КАК КлючАналитики
	|ИЗ
	|	Справочник.бит_КлючиДоступаЦФОСтатьиОборотов КАК ДанныеСправочника
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_АналитикаЦФОСтатьяОборотов КАК ДанныеРегистра
	|		ПО ДанныеСправочника.Ссылка = ДанныеРегистра.КлючАналитики
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_АналитикаЦФОСтатьяОборотов КАК Аналитика
	|		ПО ДанныеСправочника.СтатьяОборотов = Аналитика.СтатьяОборотов
	|			И ДанныеСправочника.ЦФО = Аналитика.ЦФО
	|ГДЕ
	|	ДанныеРегистра.КлючАналитики ЕСТЬ NULL";

	// Сформируем соответствие ключей аналитики.
	СоответствиеАналитик = Новый Соответствие;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
	
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			
			СоответствиеАналитик.Вставить(Выборка.Ссылка, Выборка.КлючАналитики);
			
			Если Не Выборка.ПометкаУдаления Тогда
				СправочникОбъект = Выборка.Ссылка.ПолучитьОбъект();
				// АПК:280-выкл - Допустимо пропустить обработку исключения, так как
				// это не останавливающая операция.
				Попытка
					СправочникОбъект.УстановитьПометкуУдаления(Истина, Ложь);
				Исключение
					// Обработка не требуется.
				КонецПопытки;
				// АПК:280-вкл.
			КонецЕсли;

		КонецЦикла;
		
		Для каждого КлючЗначение Из СоответствиеАналитик Цикл
			ПарыЗамен = Новый Соответствие;
			ПарыЗамен.Вставить(КлючЗначение, КлючЗначение.Значение);
			
			ПараметрыЗамены = ОбщегоНазначения.ПараметрыЗаменыСсылок();
			ПараметрыЗамены.ВключатьБизнесЛогику 	= Ложь;
			ПараметрыЗамены.ЗаменаПарыВТранзакции 	= Ложь;
			ПараметрыЗамены.ПривилегированнаяЗапись = Истина;
			
			ОбщегоНазначения.ЗаменитьСсылки(ПарыЗамен, ПараметрыЗамены);
		КонецЦикла; 
	КонецЕсли;
		
КонецПроцедуры

