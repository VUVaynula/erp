#Область СлужебныйПрограммныйИнтерфейс

// Функция получает ключ СтатьяОборотов, ЦФО для текущего документа.
// Параметры:
//	РеквизитыДокумента - Структура или ВыборкаИзРезультатаЗапроса - Данные документа.
//
// Возвращаемое значение:
//	СправочникСсылка.бит_КлючиДоступаЦФОСтатьиОборотов - Найденный ключ.
//
Функция КлючиЦФОСтатьяОборотовДокумента(ЦФО, СтатьяОборотов) Экспорт
	
	РеквизитыКлюча = Новый Структура("ЦФО, СтатьяОборотов", ЦФО, СтатьяОборотов); 

	УстановитьПривилегированныйРежим(Истина);
		
	МенеджерЗаписи = РегистрыСведений.бит_АналитикаЦФОСтатьяОборотов.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, РеквизитыКлюча);
	МенеджерЗаписи.Прочитать();
	
	Если МенеджерЗаписи.Выбран() Тогда
		Результат = МенеджерЗаписи.КлючАналитики;
	Иначе
		Результат = СоздатьКлючАналитики(РеквизитыКлюча);
	КонецЕсли;
	
	Возврат Результат;

КонецФункции
 
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НаименованиеКлючаЦФОСтатьяОборотов(СправочникОбъект)
	
	Наименование = "";
	НаименованиеЗаполнено = Ложь;
		
	Если ЗначениеЗаполнено(СправочникОбъект.ЦФО) Тогда
		Наименование = Наименование	+ СправочникОбъект.ЦФО + ", ";
		НаименованиеЗаполнено = Истина;
	Иначе
		Наименование = Наименование	+ "<...>, ";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СправочникОбъект.СтатьяОборотов) Тогда
		Наименование = Наименование	+ СправочникОбъект.СтатьяОборотов;
		НаименованиеЗаполнено = Истина;
	Иначе
		Наименование = Наименование	+ "<...>";
	КонецЕсли;
	
	Если НЕ НаименованиеЗаполнено Тогда
		Наименование = "<...>";
	КонецЕсли;	
		
	Возврат Наименование;

КонецФункции

Функция КлючЦФОСтатьяОборотов(ЗначенияАналитик)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Ключ.СтатьяОборотов КАК СтатьяОборотов,
	|	Ключ.ЦФО КАК ЦФО,
	|	Ключ.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.бит_КлючиДоступаЦФОСтатьиОборотов КАК Ключ
	|ГДЕ
	|	Ключ.СтатьяОборотов = &СтатьяОборотов
	|	И Ключ.ЦФО = &ЦФО
	|	И НЕ Ключ.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("СтатьяОборотов", ЗначенияАналитик.СтатьяОборотов);
	Запрос.УстановитьПараметр("ЦФО",	  ЗначенияАналитик.ЦФО);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат = Выборка.Ссылка;
	Иначе
		Результат = Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.ПустаяСсылка();
	КонецЕсли;
	
	Возврат Результат;
		
КонецФункции

Функция СоздатьКлючАналитики(ПараметрыАналитики)

	МенеджерЗаписи = РегистрыСведений.бит_АналитикаЦФОСтатьяОборотов.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, ПараметрыАналитики);
		
	Результат = КлючЦФОСтатьяОборотов(ПараметрыАналитики);
	
	// Создание нового ключа аналитики.
	Если Не ЗначениеЗаполнено(Результат) Тогда
		СправочникОбъект = Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(СправочникОбъект, ПараметрыАналитики);
		СправочникОбъект.Наименование = НаименованиеКлючаЦФОСтатьяОборотов(СправочникОбъект);
		СправочникОбъект.Записать();

		Результат = СправочникОбъект.Ссылка;
	КонецЕсли;

	МенеджерЗаписи.КлючАналитики = Результат;
	МенеджерЗаписи.Записать(Ложь);

	Возврат Результат;

КонецФункции

