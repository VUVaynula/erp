
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаОбъектаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
		
	ЗаполнитьСписокОбработокДоставки();
	
	Если НЕ ЗначениеЗаполнено(Элементы.ОбработкаДоставки.СписокВыбора) Тогда
		ВызватьИсключение НСтр("ru = 'Нет доступа к обработкам доставки оповещений.'; 
							|en = 'There is no access to notification delivery processing.'");
		
	КонецЕсли;
	
	Если Параметры.Ключ.Пустая() Тогда
		Если НЕ ЗначениеЗаполнено(Объект.ОбработкаДоставки) Тогда
			Объект.ОбработкаДоставки = Элементы.ОбработкаДоставки.СписокВыбора[0].Значение;
			ЗаполнитьНастройкиДоставки();
		КонецЕсли;
	Иначе
		ЗаполнитьОписания();
	КонецЕсли;
	
	ОбработкаДоставкиПредыдущая = Объект.ОбработкаДоставки;

	УправлениеФормой(ЭтотОбъект); 
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") И ИсточникВыбора.ВладелецФормы = ЭтотОбъект Тогда
		 Объект.НастройкиДоставки.Очистить();
		 Для каждого КиЗ Из ВыбранноеЗначение Цикл
		 	 НоваяСтрока = Объект.НастройкиДоставки.Добавить();
			 НоваяСтрока.ИмяНастройки      = КиЗ.Ключ;
			 НоваяСтрока.ЗначениеНастройки = КиЗ.Значение;
		 КонецЦикла; 
		 Модифицированность = Истина;
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	НепроверяемыеРеквизиты = Новый Массив();
	
	Если НЕ Объект.СпособТранспорта = Перечисления.бит_фн_СпособыТранспортаОповещений.ЭлектроннаяПочта1С Тогда
		НепроверяемыеРеквизиты.Добавить("EMAILУчетнаяЗапись");
	КонецЕсли;
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОбработкаДоставкиПриИзменении(Элемент)
	
	ЗаполнитьНастройкиДоставки();
	УправлениеФормой(ЭтотОбъект);
	
	ОбработкаДоставкиПредыдущая = Объект.ОбработкаДоставки;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаДоставкиОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкиДоставкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Настройки = Новый Структура;
	
	Для каждого СтрокаТаблицы Из Объект.НастройкиДоставки Цикл
		Настройки.Вставить(СтрокаТаблицы.ИмяНастройки,СтрокаТаблицы.ЗначениеНастройки);
	КонецЦикла; 
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("НастройкиДоставки", Настройки);
	
	ПолноеИмяФормы = СтрШаблон("Обработка.%1.Форма.Настройки", ИмяОбработкиДоставки);
	ОткрытьФорму(ПолноеИмяФормы,ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОбновитьНастройки(Команда)
	
	ТекстВопроса =  НСтр("ru='Настройки доставки будут очищены и перезаполнены. Продолжить?';
	                     |en='Your delivery will be cleaned and refill. Continue?'");	
	Оповещение = Новый ОписаниеОповещения("ВопросОбОчисткеИПерезаполненииНастроекЗавершение", ЭтотОбъект);	
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 30, КодВозвратаДиалога.Нет);
	
КонецПроцедуры

// Процедура - обработчик оповещения "ВопросОбОчисткеИПерезаполненииНастроекЗавершение".
// 
&НаКлиенте
Процедура ВопросОбОчисткеИПерезаполненииНастроекЗавершение(Ответ, ДополнительныеДанные) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда
		ЗаполнитьНастройкиДоставки();
		УправлениеФормой(ЭтотОбъект);
	КонецЕсли; 	

КонецПроцедуры // ВопросОбОчисткеИПерезаполненииНастроекЗавершение() 

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()

	УсловноеОформление.Элементы.Очистить();
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НастройкиДоставкиЗначениеНастройки");
	// АПК:277-вкл
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Объект.НастройкиДоставки.ИмяНастройки", ВидСравненияКомпоновкиДанных.Содержит, "Пароль");
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Текст", 
		НСтр("ru = '************************************************'; 
			 |en = '************************************************'"));
	
КонецПроцедуры
  
&НаСервере
Процедура ЗаполнитьНастройкиДоставки()
	
	ОбъектОбработкаДоставки = бит_ОповещенияСервер.ПолучитьОбработкуДоставки(Объект.ОбработкаДоставки);
	
	Если ОбъектОбработкаДоставки = Неопределено Тогда
		ВызватьИсключение НСтр("ru = 'Не удалось получить обработку доставки.'");
	КонецЕсли;
	
	// Проверим, что выбранная обработка является обработкой доставки.
	ОбработкаКорректна = бит_ОповещенияСервер.ОбработкаДоставкиКорректна(ОбъектОбработкаДоставки, Строка(Объект.ОбработкаДоставки), Истина);
	
	Если НЕ ОбработкаКорректна Тогда
		Объект.ОбработкаДоставки = ОбработкаДоставкиПредыдущая;
		Возврат;
	КонецЕсли; 
	
	ИмяОбработкиДоставки = "";
	Объект.НастройкиДоставки.Очистить();			
	
	НастройкиДоставки    = бит_ОповещенияСервер.НастройкиДоставки(ОбъектОбработкаДоставки);
	НастройкиПоУмолчанию = ОбъектОбработкаДоставки.НастройкиПоУмолчанию();
	
	Для каждого КиЗ Из НастройкиДоставки Цикл
		
		НоваяСтрока = Объект.НастройкиДоставки.Добавить();
		НоваяСтрока.ИмяНастройки      = КиЗ.Ключ;
		НоваяСтрока.ЗначениеНастройки = КиЗ.Значение;
		
		// Если значение настроки пусто - установим значение по-умолчанию.
		Если НЕ ЗначениеЗаполнено(КиЗ.Значение) Тогда
			Если НастройкиПоУмолчанию.Свойство(КиЗ.Ключ) Тогда
				НоваяСтрока.ЗначениеНастройки = НастройкиПоУмолчанию[КиЗ.Ключ];
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла;
	
	ИмяОбработкиДоставки 	= ИмяОбработкиДоставки();
	Объект.СпособТранспорта = бит_ОповещенияСервер.ОпределитьСпособТранспортаПоИмениОбработки(ИмяОбработкиДоставки);
	
	ЗаполнитьОписания();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)

	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;

	ЭтоЭлектроннаяПочта1С = Объект.СпособТранспорта = ПредопределенноеЗначение("Перечисление.бит_фн_СпособыТранспортаОповещений.ЭлектроннаяПочта1С"); 
	
	Элементы.EMAILУчетнаяЗапись.Видимость      = ЭтоЭлектроннаяПочта1С;
	Элементы.ФормаОбновитьНастройки.Видимость  = НЕ ЭтоЭлектроннаяПочта1С;
	
	Если ЭтоЭлектроннаяПочта1С Тогда
		Элементы.НастройкиДоставки.Видимость = Ложь;
	Иначе	
		Элементы.НастройкиДоставки.Видимость = Объект.НастройкиДоставки.Количество() <> 0;
	КонецЕсли;
	
КонецПроцедуры // УправлениеФормой()

&НаСервере
Процедура ЗаполнитьОписания()
	
	Если Объект.СпособТранспорта = Перечисления.бит_фн_СпособыТранспортаОповещений.ЭлектроннаяПочта1С Тогда
		СтрокиТаблицы = Объект.НастройкиДоставки.НайтиСтроки(Новый Структура("ИмяНастройки", "EMAILУчетнаяЗапись"));
		Если СтрокиТаблицы.Количество() = 0 Тогда
			EMAILУчетнаяЗапись = Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты;
		Иначе
			EMAILУчетнаяЗапись = СтрокиТаблицы[0].ЗначениеНастройки;
		КонецЕсли; 
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ИмяОбработкиДоставки) Тогда
		ИмяОбработкиДоставки = ИмяОбработкиДоставки();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если ТекущийОбъект.СпособТранспорта = Перечисления.бит_фн_СпособыТранспортаОповещений.ЭлектроннаяПочта1С Тогда
	
		СтрокиТаблицы = ТекущийОбъект.НастройкиДоставки.НайтиСтроки(Новый Структура("ИмяНастройки", "EMAILУчетнаяЗапись"));
		Если СтрокиТаблицы.Количество() = 0 Тогда
			СтрокаТаблицы = ТекущийОбъект.НастройкиДоставки.Добавить();
			СтрокаТаблицы.ИмяНастройки 		= "EMAILУчетнаяЗапись";
			СтрокаТаблицы.ЗначениеНастройки = EMAILУчетнаяЗапись;
		Иначе
			СтрокиТаблицы[0].ЗначениеНастройки = EMAILУчетнаяЗапись;
		КонецЕсли; 
	
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокОбработокДоставки()
		
	ОбъектыМД = Новый Массив();   
	ОбъектыМД.Добавить(Метаданные.Обработки.бит_ДоставкаОповещенийСистемаВзаимодействия);
	ОбъектыМД.Добавить(Метаданные.Обработки.бит_ДоставкаОповещенийЭлектроннойПочтой1С);
	ОбъектыМД.Добавить(Метаданные.Обработки.бит_ДоставкаОповещенийPush);
	ОбъектыМД.Добавить(Метаданные.Обработки.бит_ДоставкаОповещенийЭлектроннойПочтой);
	
	Если бит_ЛицензированиеБФПереопределяемый.СборкаДоступна("УУ") 
	 ИЛИ бит_ЛицензированиеБФПереопределяемый.СборкаДоступна("УХ") Тогда
	
		ОбъектыМД.Добавить(Метаданные.Обработки.бит_ДоставкаОповещенийTelegram);
	КонецЕсли;
	
	Для каждого ОбъектМД Из ОбъектыМД Цикл
		ОбъектСистемы = бит_ПраваДоступа.ПолучитьОбъектДоступаПоМетаданным(ОбъектМД);
		Если НЕ ОбъектСистемы = Неопределено Тогда
			Элементы.ОбработкаДоставки.СписокВыбора.Добавить(ОбъектСистемы);
		КонецЕсли; 
	КонецЦикла; 

КонецПроцедуры // ЗаполнитьДоступныеОбъектыСистемы()

&НаСервере
Функция ИмяОбработкиДоставки()

	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ОбработкаДоставки, "ИмяОбъекта")

КонецФункции
 
#КонецОбласти

