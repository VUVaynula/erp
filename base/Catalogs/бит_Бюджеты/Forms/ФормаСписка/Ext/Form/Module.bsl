#Область СлужебныеПроцедурыИФункции
	
#Область ДлительнаяОперацияЗаполнениеНаименованийСтатей

&НаКлиенте
Процедура НачатьЗаполнениеНаименованийСтатей()
	
	ВыбранныеСтроки = Элементы.Список.ВыделенныеСтроки;
	
	ДлительнаяОперация    = НачатьЗаполнениеНаименованийСтатейНаСервере(ВыбранныеСтроки);
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗаполнениеНаименованийСтатейЗавершение", ЭтотОбъект);
	ПараметрыОжидания     = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);

КонецПроцедуры

&НаСервере
Функция НачатьЗаполнениеНаименованийСтатейНаСервере(Знач ВыбранныеСтроки)

	  ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	  ВыполняемыйМетод    = "Справочники.бит_Бюджеты.ЗаполнитьНаименованияСтатей";
	  ВсеСтатьи 		  = Новый Массив;

	  Возврат ДлительныеОперации.ВыполнитьПроцедуру(ПараметрыВыполнения, ВыполняемыйМетод, ВыбранныеСтроки, ВсеСтатьи);

 КонецФункции
  
&НаКлиенте
Процедура ЗаполнениеНаименованийСтатейЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка при выполнении, по причине: %1'"); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрШаблон(ТекстСообщения, Результат.КраткоеПредставлениеОшибки));
	Иначе
		ОповеститьОбИзменении(Тип("СправочникСсылка.бит_СтатьиБюджета"));
	КонецЕсли; 
	
КонецПроцедуры 
  
#КонецОбласти

#КонецОбласти
