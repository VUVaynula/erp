&НаСервере
Процедура ПолучитьСКД(Знач СпособЗаполнения = Неопределено)

	СКД = Неопределено;
	Если ЗначениеЗаполнено(АдресСхемыКомпоновкиДанных) И СпособЗаполнения = Неопределено Тогда
		СКД = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновкиДанных);
		ЗагрузитьНастройки = Ложь;
	Иначе
		ПараметрыЗаполнения = Новый Структура("ИсточникДанных, Наименование");
		ЗаполнитьЗначенияСвойств(ПараметрыЗаполнения, Объект);

		СКД = Справочники.бит_НастройкиОтчетов.ЗаполнитьСхемуКомпоновки(ПараметрыЗаполнения,  СпособЗаполнения);
		ЗагрузитьНастройки = Истина;
	КонецЕсли;

	АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СКД, Новый УникальныйИдентификатор);
	Если ЗагрузитьНастройки Тогда
		ЗагрузитьНастройкиВарианта("", Истина);
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция ПараметрыМакетовСхемы(ТекущаяСхема)

	ТаблицаПараметров = Новый ТаблицаЗначений;
	ТаблицаПараметров.Колонки.Добавить("Параметр");
	
	Для каждого МакетСхемы Из ТекущаяСхема.Макеты Цикл
		Для каждого СтрокаТаблицыОбласти Из МакетСхемы.Макет Цикл
			Для каждого ЯчейкаТаблицыОбласти Из СтрокаТаблицыОбласти.Ячейки Цикл
				Для каждого ПолеОбластиКд Из ЯчейкаТаблицыОбласти.Элементы Цикл
					
					// Значение поля области компоновки данных     						
					ЗначениеПоля = ПолеОбластиКд.Значение;
					// Если тип значения = Строка, то нужно подставить заголовки.
					Если ТипЗнч(ЗначениеПоля) = Тип("Строка") Тогда
						
						// Поиск вхождений параметров для замены: [ИмяПараметра].
						МассивСтрПарам = бит_СтрокиКлиентСервер.РазобратьСтрокуСРазделителями(ЗначениеПоля, "[");
						Для каждого СтрокаПоиска Из МассивСтрПарам Цикл
							
							ПозицияЗакрытия = Найти(СтрокаПоиска, "]");
							Если ПозицияЗакрытия = 0 Тогда
								Продолжить;
							Иначе	
								СтрокаПараметр = Лев(СтрокаПоиска, ПозицияЗакрытия-1);
								Если ЗначениеЗаполнено(СтрокаПараметр) Тогда
								 	НоваяСтрока = ТаблицаПараметров.Добавить();
									НоваяСтрока.Параметр = СтрокаПараметр;
								КонецЕсли;  									
							КонецЕсли;
						
						КонецЦикла;
						
					КонецЕсли;
					
				КонецЦикла;		
			КонецЦикла;			
		КонецЦикла; 		
	КонецЦикла;
	
	Если ТаблицаПараметров.Количество() = 0 Тогда
		ПараметрыМакетов = Новый Массив;
	Иначе
		ТаблицаПараметров.Свернуть("Параметр");
		ТаблицаПараметров.Сортировать("Параметр");
		ПараметрыМакетов = ТаблицаПараметров.ВыгрузитьКолонку("Параметр");
	КонецЕсли;

	Возврат ПараметрыМакетов;
	
КонецФункции

&НаСервере
Процедура ДобавитьПараметр(ИмяПараметра, Значение)

	НоваяСтрока = Объект.Параметры.Добавить();
	НоваяСтрока.Параметр     = ИмяПараметра;
	НоваяСтрока.ВидПараметра = Перечисления.бит_ВидыПараметровПроизвольныхОтчетов.ТекстНаРазныхЯзыках;
	НоваяСтрока.Значение     = Значение;
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗаголовкиПолейНаСервере()
	
	СхемыКомпоновки = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновкиДанных);
	Если СхемыКомпоновки = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Объект.Параметры.Очистить();
	
	Добавленные = Новый Соответствие;

	Для каждого НаборДанных Из СхемыКомпоновки.НаборыДанных Цикл
		ПоляНабораДанных = НаборДанных.Поля;
		Для каждого ПолеНабора Из ПоляНабораДанных Цикл
			Если Добавленные.Получить(ПолеНабора.Поле) = Неопределено Тогда
				ЗаголовокПоля = "";
				Если ЗначениеЗаполнено(ПолеНабора.Заголовок) Тогда
					ЗаголовокПоля = СтрШаблон("ru = ""%1""", ПолеНабора.Заголовок);
				КонецЕсли;
				Добавленные.Вставить(ПолеНабора.Поле, ЗаголовокПоля);
				ДобавитьПараметр(СокрЛП(ПолеНабора.Поле), ЗаголовокПоля);   		
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	ПараметрыМакетов = ПараметрыМакетовСхемы(СхемыКомпоновки);
	Для каждого ИмяПараметра Из ПараметрыМакетов Цикл   		
		Если Добавленные.Получить(ИмяПараметра) = Неопределено Тогда
			ЗаголовокПоля = "";
			Добавленные.Вставить(ИмяПараметра, ЗаголовокПоля);
			ДобавитьПараметр(ИмяПараметра, ЗаголовокПоля);   		
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	ЗаполнитьКэшЗначений();
	ОбновитьКнопкиВариантовОтчета();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьКомандыВариантовОтчета()

	КомандыВариантовОтчета.Очистить();
	
	ПредопределенныйВариант = Справочники.бит_НастройкиОтчетов.ПредопределенныйВариант();
	КлючОтчета				= Метаданные.Отчеты.бит_УниверсальныйОтчетПоИсточникамДанных.ПолноеИмя();
	ИдентификаторОтчета 	= ОбщегоНазначения.ИдентификаторОбъектаМетаданных(Метаданные.Отчеты.бит_УниверсальныйОтчетПоИсточникамДанных);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИдентификаторОтчета", ИдентификаторОтчета);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВариантыОтчетов.Ссылка КАК Ссылка,
	|	ВариантыОтчетов.Настройки КАК Настройки,
	|	ВариантыОтчетов.КлючВарианта КАК КлючВарианта,
	|	ВариантыОтчетов.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ВариантыОтчетов КАК ВариантыОтчетов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ИдентификаторыОбъектовМетаданных КАК ИдентификаторыОбъектовМетаданных
	|		ПО ВариантыОтчетов.Отчет = ИдентификаторыОбъектовМетаданных.Ссылка
	|			И (ИдентификаторыОбъектовМетаданных.Ссылка = &ИдентификаторОтчета)
	|ГДЕ
	|	НЕ ВариантыОтчетов.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка 		 = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Настройка = ХранилищаНастроек.ХранилищеВариантовОтчетов.Загрузить(КлючОтчета, Выборка.КлючВарианта);
		Если ТипЗнч(Настройка) = Тип("НастройкиКомпоновкиДанных") Тогда
			ЗначениеПараметра = бит_ОтчетыБФКлиентСервер.ПолучитьПараметр(Настройка, "НастройкаОтчета");
			
			Если ЗначениеПараметра <> Неопределено И ЗначениеПараметра.Значение = Объект.Ссылка Тогда
				КонтрольнаяСумма = ОбщегоНазначения.КонтрольнаяСуммаСтрокой(Выборка.Ссылка);
				НоваяСтрока = КомандыВариантовОтчета.Добавить();
				НоваяСтрока.ИмяКоманды	  = "Подключаемый_СформироватьУниверсальныйОтчет" + КонтрольнаяСумма;
				НоваяСтрока.ВариантОтчета = Выборка.Ссылка;
				НоваяСтрока.Заголовок	  = Выборка.Наименование;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ ЗначениеЗаполнено(КомандыВариантовОтчета) Тогда
		КонтрольнаяСумма = ОбщегоНазначения.КонтрольнаяСуммаСтрокой(ПредопределенныйВариант);
		НоваяСтрока = КомандыВариантовОтчета.Добавить();
		НоваяСтрока.ИмяКоманды	  			= "Подключаемый_СформироватьУниверсальныйОтчет" + КонтрольнаяСумма;
		НоваяСтрока.ВариантОтчета 			= ПредопределенныйВариант;
		НоваяСтрока.Заголовок	  			= НСтр("ru = 'Сформировать отчет'; en = 'Generate Report'");
		НоваяСтрока.ПредопределенныйВариант = Истина;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОбновитьКнопкиВариантовОтчета()

	Для каждого СтрокаТаблицы Из КомандыВариантовОтчета Цикл
		КомандаФормы = Команды.Найти(СтрокаТаблицы.ИмяКоманды);
		Если КомандаФормы <> Неопределено Тогда
			Команды.Удалить(КомандаФормы);		
		КонецЕсли;
		КнопкаФормы = Элементы.Найти(СтрокаТаблицы.ИмяКоманды); 
		Если КнопкаФормы <> Неопределено Тогда
			Элементы.Удалить(КнопкаФормы);		
		КонецЕсли;
	КонецЦикла;
	
	ОбновитьКомандыВариантовОтчета();
	
	Если НЕ ЗначениеЗаполнено(КомандыВариантовОтчета) Тогда
		Возврат;
	КонецЕсли;
	
	РазмещениеКоманд = "";
	Если КомандыВариантовОтчета.Количество() = 1  Тогда
		РазмещениеКоманд = Элементы.ГруппаВариантыОтчета;
		КартинкаКнопки	 = БиблиотекаКартинок.СформироватьОтчет;
	Иначе	
		РазмещениеКоманд = Элементы.ПодменюВариантыОтчета;
		КартинкаКнопки	 = Новый Картинка;
	КонецЕсли;
	
	Для каждого СтрокаТаблицы Из КомандыВариантовОтчета Цикл
		КомандаФормы = Команды.Добавить(СтрокаТаблицы.ИмяКоманды);
		КомандаФормы.Действие  = "Подключаемый_СформироватьУниверсальныйОтчет";
		КомандаФормы.Заголовок = СтрокаТаблицы.Заголовок ;
		
		КнопкаФормы = Элементы.Добавить(СтрокаТаблицы.ИмяКоманды, Тип("КнопкаФормы"), РазмещениеКоманд); 
		КнопкаФормы.ИмяКоманды 	= СтрокаТаблицы.ИмяКоманды;
		КнопкаФормы.Картинка   	= КартинкаКнопки;
		КнопкаФормы.Отображение = ОтображениеКнопки.КартинкаИТекст;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПредложитьЗаписатьОбъект(ПараметрыКоманды)

	ТекстСообщения = НСтр("ru = 'Данные еще не записаны.
                           |Сформировать отчет можно только после записи данных.
                           |Записать данные?'; 
						   |en = 'The data has not been recorded yet.
                           |You can generate a report only after recording the data.
                           |Write down the data?'");
	
	Оповещение = Новый ОписаниеОповещения("ПредложитьЗаписатьОбъектЗавершение", ЭтотОбъект, ПараметрыКоманды);
	ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура ПредложитьЗаписатьОбъектЗавершение(Результат, Дополнительно) Экспорт

	Если Результат = КодВозвратаДиалога.Да Тогда
		Если ПроверитьЗаполнение() Тогда
			Попытка
				Записать();		
			Исключение
				ТекстСообщения = НСтр("ru = 'Не удалось записать справочник по причине: %1.'; 
									|en = 'The directory could not be recorded for the reason: %1.'");
				ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
				ВызватьИсключение ТекстСообщения;
			КонецПопытки;
			СформироватьУниверсальныйОтчет(Дополнительно.Команда);
		КонецЕсли;	
	КонецЕсли;	

КонецПроцедуры

#КонецОбласти

