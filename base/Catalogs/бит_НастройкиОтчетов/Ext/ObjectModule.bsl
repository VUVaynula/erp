#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий
	
Процедура ПередЗаписью(Отказ)
		
	Если ОбменДанными.Загрузка Тогда
		Возврат;			
	КонецЕсли; 
		
	СохраненнаяСхема	 	 = СхемаКомпоновкиДанных.Получить();
	СохраненныйВариантОтчета = ВариантОтчета.Получить();
	
	Если ТипЗнч(СохраненнаяСхема) <> Тип("СхемаКомпоновкиДанных") Тогда
		СохраненнаяСхема = Отчеты.бит_УниверсальныйОтчетПоИсточникамДанных.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	КонецЕсли;
	НастройкиПоУмолчанию = СохраненнаяСхема.НастройкиПоУмолчанию;
	
	Если ТипЗнч(СохраненныйВариантОтчета) = Тип("Строка") Тогда
		Попытка
			СохраненныйВариантОтчета = ОбщегоНазначения.ЗначениеИзСтрокиXML(СохраненныйВариантОтчета);	
		Исключение
			СохраненныйВариантОтчета = НастройкиПоУмолчанию;
		КонецПопытки;
	Иначе
		СохраненныйВариантОтчета = НастройкиПоУмолчанию;	
	КонецЕсли;
	
	Справочники.бит_НастройкиОтчетов.ДобавитьФиксированныеПереметры(СохраненнаяСхема);
	Справочники.бит_НастройкиОтчетов.ДобавитьФиксированныеПереметры(СохраненныйВариантОтчета);
	
	СхемаКомпоновкиДанных = Новый ХранилищеЗначения(СохраненнаяСхема, Новый СжатиеДанных(9));
	ВариантОтчета		  = Новый ХранилищеЗначения(ОбщегоНазначения.ЗначениеВСтрокуXML(СохраненныйВариантОтчета), 
													Новый СжатиеДанных(9));

КонецПроцедуры
	
Процедура ПриЗаписи(Отказ)
		
	Если ОбменДанными.Загрузка Тогда
		Возврат;			
	КонецЕсли; 
		
КонецПроцедуры
	
#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#КонецОбласти

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли