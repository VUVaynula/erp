	Таблица.Колонки.Добавить("ИмяПараметра");
	Таблица.Колонки.Добавить("ВидПараметра");
	Таблица.Колонки.Добавить("ЗначениеПараметра");
	Таблица.Колонки.Добавить("ДоступныеТипы");
	
