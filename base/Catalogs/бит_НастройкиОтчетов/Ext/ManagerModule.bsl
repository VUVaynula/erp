#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ПрограммныйИнтерфейс

#Область ДляВызоваИзДругихПодсистем

// Переносит сохраненные настройки в данные подсистемы "Варианты отчетов".
//
Процедура ПеренестиСохраненныхНастройкиВПодсистемуВариантыОтчетов() Экспорт

	ПрототипСсылка = ПредопределенныйВариант();
	Если Не ЗначениеЗаполнено(ПрототипСсылка) Тогда
		ВызватьИсключение НСтр("ru = 'Не найден вариант-прототип.'");
	КонецЕсли;
	
	ДанныеДляПереноса = ДанныеДляПереноса();
	Для каждого Данные Из ДанныеДляПереноса Цикл
		ПеренестиСохраненнуюНастройку(Данные, ПрототипСсылка);
	КонецЦикла;	

КонецПроцедуры

// Добавляет фиксированные переметры в сохраенные настройки. 
//
Процедура ДобавитьФиксированныеПереметрыСКДПриПереходеНаНовуюВерсию() Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бит_НастройкиОтчетов.Ссылка КАК Ссылка,
	|	бит_НастройкиОтчетов.СхемаКомпоновкиДанных КАК СхемаКомпоновкиДанных,
	|	бит_НастройкиОтчетов.ВариантОтчета КАК ВариантОтчета
	|ИЗ
	|	Справочник.бит_НастройкиОтчетов КАК бит_НастройкиОтчетов
	|ГДЕ
	|	НЕ бит_НастройкиОтчетов.ПометкаУдаления
	|	И НЕ бит_НастройкиОтчетов.ЭтоГруппа";
	
	Выборка= Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НачатьТранзакцию();
		Попытка			
			ПодготовитьСхемуКомпоновкиДанных(Выборка.Ссылка);
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			бит_ОбновлениеИнформационнойБазыБФ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Выборка.Ссылка);
		КонецПопытки;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ДобавитьФиксированныеПереметры(СхемаКомпоновкиДанных) Экспорт
	
	Если ТипЗнч(СхемаКомпоновкиДанных) = Тип("СхемаКомпоновкиДанных") Тогда
		Настройки = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;
	Иначе
		Настройки = СхемаКомпоновкиДанных;
	КонецЕсли;
	
	ОсновнаяСхема			= Отчеты.бит_УниверсальныйОтчетПоИсточникамДанных.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	ПредопределенныйВариант = ОсновнаяСхема.НастройкиПоУмолчанию;
	ФиксированныеПараметры	= НовыеФиксированныеПараметры();

	Для каждого ФиксированныйПереметр Из ФиксированныеПараметры Цикл
		ИмяПараметра = ФиксированныйПереметр.Ключ;
		Если ТипЗнч(СхемаКомпоновкиДанных) = Тип("СхемаКомпоновкиДанных") Тогда
			Параметр = бит_ОтчетыБФСервер.ПолучитьПараметрСКД(СхемаКомпоновкиДанных,  ИмяПараметра);
			Если Параметр = Неопределено Тогда
				ПараметрИсточник = бит_ОтчетыБФСервер.ПолучитьПараметрСКД(ОсновнаяСхема,  ИмяПараметра);
				НовыйПараметр = бит_ОтчетыБФСервер.ДобавитьПараметр(СхемаКомпоновкиДанных, ИмяПараметра); 
				ЗаполнитьЗначенияСвойств(НовыйПараметр, ПараметрИсточник);
			КонецЕсли;
		КонецЕсли;

		Параметр = бит_ОтчетыБФКлиентСервер.ПолучитьПараметр(Настройки, ИмяПараметра);
		Если Параметр = Неопределено Тогда
			ПараметрИсточник = бит_ОтчетыБФКлиентСервер.ПолучитьПараметр(ПредопределенныйВариант,  ИмяПараметра);
			НовыйПараметр = Настройки.ПараметрыДанных.Элементы.Добавить();
			ЗаполнитьЗначенияСвойств(НовыйПараметр,ПараметрИсточник); 
		КонецЕсли;
	КонецЦикла;

	Если ТипЗнч(Настройки) = Тип("НастройкиКомпоновкиДанных") Тогда
		РежимыОтображенияФиксированныхПараметров = РежимыОтображенияФиксированныхПараметров(Настройки);
		УстановитьРежимыОтображенияФиксированныхПараметров(Настройки, РежимыОтображенияФиксированныхПараметров);
	КонецЕсли;
		
КонецПроцедуры

Функция ДоступныеЗначенияПараметровИзНастройкиОтчета(НастройкаОтчета) Экспорт

	Если НЕ ЗначениеЗаполнено(НастройкаОтчета) Тогда
		Возврат Новый Структура;	
	КонецЕсли;
	
	Период = Новый СтандартныйПериод(ВариантСтандартногоПериода.ЭтотГод);
	
	РеквизитыНастройки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(НастройкаОтчета, 
							"ВариантОтчета, ИсточникДанных, Язык");
	
	ВариантИзНастройки = РеквизитыНастройки.ВариантОтчета.Получить();
	Если ТипЗнч(ВариантИзНастройки) = Тип("Строка") Тогда
		ОсновнойВариантОтчета = ОбщегоНазначения.ЗначениеИзСтрокиXML(ВариантИзНастройки);
		ПараметрПериод = бит_ОтчетыБФКлиентСервер.ПолучитьПараметр(ОсновнойВариантОтчета, "Период");
		Если ПараметрПериод <> Неопределено Тогда
			Период = ПараметрПериод.Значение;		
		КонецЕсли;
	КонецЕсли; 
	
	НастройкиИсточника = НовыеНастройкиИсточника();

	бит_МеханизмПолученияДанных.ОбновитьТаблицуПараметров(РеквизитыНастройки.ИсточникДанных, 
			НастройкиИсточника.ПараметрыИсточника, Истина);
			
	бит_МеханизмПолученияДанных.ЗаполнитьОтборВОтчете(РеквизитыНастройки.ИсточникДанных, 
			НастройкиИсточника.ОтборыИсточника);
	
	ДоступныеЗначения = Новый Структура;
	ДоступныеЗначения.Вставить("Период",			 Период);
	ДоступныеЗначения.Вставить("Язык",				 РеквизитыНастройки.Язык);
	ДоступныеЗначения.Вставить("НастройкиИсточника", Новый ХранилищеЗначения(НастройкиИсточника));
	
	Возврат ДоступныеЗначения;
	
КонецФункции

// Функция заполняет схему компоновки данных по умолчанию.
// 
// 
// Возвращаемое значение:
//   СКД   - СхемаКомпоновкиДанных.
// 
Функция ЗаполнитьСхемуКомпоновки(ПараметрыЗаполнения, СпособЗаполнения = "") Экспорт
	
	ИсточникДанных = ПараметрыЗаполнения.ИсточникДанных;
	Наименование   = ПараметрыЗаполнения.Наименование;
	
	СКД = Новый СхемаКомпоновкиДанных;
	
	ИсточникиДанныхКомпоновки = СКД.ИсточникиДанных.Добавить();
	ИсточникиДанныхКомпоновки.Имя                = "ИсточникДанных1";
	ИсточникиДанныхКомпоновки.ТипИсточникаДанных = "Local";
	
	НаборДанных = СКД.НаборыДанных.Добавить(Тип("НаборДанныхОбъектСхемыКомпоновкиДанных"));
	НаборДанных.Имя 		   = "мТаблицаРезультат";
	НаборДанных.ИмяОбъекта 	   = "мТаблицаРезультат";
	НаборДанных.ИсточникДанных = ИсточникиДанныхКомпоновки.Имя;
	
	// Поля набора данных.
	Если ТипЗнч(ИсточникДанных) = Тип("СправочникСсылка.бит_ИсточникиДанных") Тогда
		
		РеквизитыИсточника = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ИсточникДанных, "ЗапросБД, Поля");
		РеквизитыИсточника.Поля = РеквизитыИсточника.Поля.Выгрузить();
		
		ТекстЗапроса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РеквизитыИсточника.ЗапросБД, "ТекстЗапроса");
		
		Схема = Новый СхемаЗапроса;
		Схема.УстановитьТекстЗапроса(ТекстЗапроса);
		
		ЗапросПакета = Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество()-1]; // Может быть НЕ ВЫБОР
		
		Для каждого ПолеИсточника Из РеквизитыИсточника.Поля Цикл
			
			Если ПолеИсточника.Использование Тогда
				
				ИмяПоля = ?(НЕ ПустаяСтрока(ПолеИсточника.Синоним),ПолеИсточника.Синоним,ПолеИсточника.Имя);
				ЭтоИзмерение = ВРЕГ(ПолеИсточника.ВидПоля) = ВРЕГ("Поле");
				Если ЭтоИзмерение Тогда
					Колонка = ЗапросПакета.Колонки.Найти(ПолеИсточника.Имя);
					Если НЕ Колонка = Неопределено  Тогда
					    ОписаниеТипов = Колонка.ТипЗначения;
					Иначе	
					    ОписаниеТипов = Неопределено;
					КонецЕсли; 
				Иначе	
					ОписаниеТипов = ОбщегоНазначения.ОписаниеТипаЧисло(15, 3);
				КонецЕсли; 
				ДобавитьПолеНабораДанныхКомпоновки(НаборДанных, ИмяПоля,, ОписаниеТипов, ЭтоИзмерение);			
				
				// Заполним ресурсы компоновки
				Если НЕ ЭтоИзмерение Тогда
					ПолеИтога = СКД.ПоляИтога.Добавить();
					ПолеИтога.Выражение   = "Сумма(" + ИмяПоля + ")";
					ПолеИтога.ПутьКДанным = ИмяПоля;
				КонецЕсли; 
			КонецЕсли; 
		КонецЦикла; 
		
	ИначеЕсли ТипЗнч(ИсточникДанных) = Тип("СправочникСсылка.бит_СпособыКомпоновкиИсточниковДанных") Тогда	
		
		// Добавим поля, специфичные для работы через способы компоновки источников данных.
		ОписаниеЭлементыДанных = Новый ОписаниеТипов("СправочникСсылка.бит_ЭлементыДанных");
		ДобавитьПолеНабораДанныхКомпоновки(НаборДанных, "Кодификатор"		 , НСтр("ru = 'Кодификатор'; en = 'Codifier'"));				
		ДобавитьПолеНабораДанныхКомпоновки(НаборДанных, "ЭлементДанных"		 , НСтр("ru = 'Элемент данных'; en = 'Data element'") , ОписаниеЭлементыДанных);
		ДобавитьПолеНабораДанныхКомпоновки(НаборДанных, "ГруппаЭлементДанных", НСтр("ru = 'Группа элементов данных'; en = 'Group of data elements'") , ОписаниеЭлементыДанных);
		
		РеквизитыИсточника = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ИсточникДанных, "КолонкиТаблицы, НеРассчитыватьИтогиПоГруппам");
		РеквизитыИсточника.КолонкиТаблицы = РеквизитыИсточника.КолонкиТаблицы.Выгрузить();
		Для каждого ПолеИсточника Из РеквизитыИсточника.КолонкиТаблицы Цикл
			
			ИмяПоля = ПолеИсточника.ИмяКолонки;
			ЭтоИзмерение = ВРЕГ(ПолеИсточника.ВидКолонки) = ВРЕГ("Поле");
			Если ЭтоИзмерение Тогда
				ОписаниеТипов = ПолеИсточника.ОписаниеТипов.Получить();
			Иначе	
				ОписаниеТипов = ОбщегоНазначения.ОписаниеТипаЧисло(15, 3);
			КонецЕсли; 
			ДобавитьПолеНабораДанныхКомпоновки(НаборДанных, ИмяПоля,, ОписаниеТипов, ЭтоИзмерение);			
			
			// Заполним ресурсы компоновки
			Если НЕ ЭтоИзмерение Тогда
				ПолеИтога = СКД.ПоляИтога.Добавить();
				Если РеквизитыИсточника.НеРассчитыватьИтогиПоГруппам Тогда
					ПолеИтога.Выражение = "Сумма(" + ИмяПоля + ")";
				Иначе	
					ПолеИтога.Выражение = ИмяПоля;
				КонецЕсли; 
				ПолеИтога.ПутьКДанным = ИмяПоля;
			КонецЕсли; 
		КонецЦикла; 
	КонецЕсли; 
		
	// Поля
	Для каждого ПолеНабора Из НаборДанных.Поля Цикл
		ВыбранноеПоле  = СКД.НастройкиПоУмолчанию.Выбор.Элементы.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
		ПолеКомпоновки = Новый  ПолеКомпоновкиДанных(ПолеНабора.ПутьКДанным);
		ВыбранноеПоле.Поле          = ПолеКомпоновки;
		ВыбранноеПоле.Использование = Истина;
	КонецЦикла; 
	
	// Структура
	Если СпособЗаполнения = "ИерархияЭлементовДанных" Тогда
		
		ГруппировкаКомпоновки = СКД.НастройкиПоУмолчанию.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
		ВыбранноеПоле         = ГруппировкаКомпоновки.Выбор.Элементы.Добавить(Тип("АвтовыбранноеПолеКомпоновкиДанных"));
		ВыбранноеПоле.Использование = Истина;
		
		ВыбранноеПоле         = ГруппировкаКомпоновки.Выбор.Элементы.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
		ВыбранноеПоле.Использование = Истина;
		ВыбранноеПоле.Поле      	= Новый  ПолеКомпоновкиДанных("ЭлементДанных.Кодификатор");
		
		ВыбранноеПоле         = ГруппировкаКомпоновки.Выбор.Элементы.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
		ВыбранноеПоле.Использование = Истина;
		ВыбранноеПоле.Поле      	= Новый  ПолеКомпоновкиДанных("ЭлементДанных");
		
		ПолеГруппировки = ГруппировкаКомпоновки.ПоляГруппировки.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
		ПолеГруппировки.Использование  = Истина;
		ПолеГруппировки.Поле           = Новый  ПолеКомпоновкиДанных("ЭлементДанных");
		ПолеГруппировки.ТипГруппировки = ТипГруппировкиКомпоновкиДанных.ТолькоИерархия;
		ПолеГруппировки.ТипДополнения  = ТипДополненияПериодаКомпоновкиДанных.БезДополнения;
		
	Иначе	
		
		ГруппировкаКомпоновки = СКД.НастройкиПоУмолчанию.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
		ВыбранноеПоле         = ГруппировкаКомпоновки.Выбор.Элементы.Добавить(Тип("АвтовыбранноеПолеКомпоновкиДанных"));
		ВыбранноеПоле.Использование = Истина;
		
	КонецЕсли; 
	
	// Заголовок отчета
	ЗначениеПараметра = СКД.НастройкиПоУмолчанию.ПараметрыВывода.Элементы.Найти("Title");
	ЗначениеПараметра.Использование = Истина;
	ЗначениеПараметра.Значение      = Наименование;
	
	// Вывод заголовка
	ЗначениеПараметра = СКД.НастройкиПоУмолчанию.ПараметрыВывода.Элементы.Найти("TitleOutput");
	ЗначениеПараметра.Использование = Истина;
	ЗначениеПараметра.Значение      = ТипВыводаТекстаКомпоновкиДанных.Выводить;
	
	// Вывод итогов по горизонтали
	ЗначениеПараметра = СКД.НастройкиПоУмолчанию.ПараметрыВывода.Элементы.Найти("HorizontalOverallPlacement");
	ЗначениеПараметра.Использование = Истина;
	ЗначениеПараметра.Значение      = РасположениеИтоговКомпоновкиДанных.Нет;
	
	// Вывод итогов по вертикали
	ЗначениеПараметра = СКД.НастройкиПоУмолчанию.ПараметрыВывода.Элементы.Найти("VerticalOverallPlacement");
	ЗначениеПараметра.Использование = Истина;
	ЗначениеПараметра.Значение      = РасположениеИтоговКомпоновкиДанных.Нет;
	
	// Способ вывода реквизитов
	ЗначениеПараметра = СКД.НастройкиПоУмолчанию.ПараметрыВывода.Элементы.Найти("AttributePlacement");
	ЗначениеПараметра.Использование = Истина;
	ЗначениеПараметра.Значение      = РасположениеРеквизитовКомпоновкиДанных.Отдельно;
	
	ДобавитьФиксированныеПереметры(СКД);
	
	Возврат СКД;
	
КонецФункции // ЗаполнитьСхемуКомпоновки()

Функция РежимыОтображенияФиксированныхПараметров(Настройки) Экспорт
	
	РежимыОтображения = Новый Структура();
	РежимыОтображения.Вставить("Период", 		  		   РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ);
	РежимыОтображения.Вставить("НастройкаОтчета", 		   РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ);
	РежимыОтображения.Вставить("НастройкаПулаПодключений", РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный);
	РежимыОтображения.Вставить("Язык", 					   РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный);
	РежимыОтображения.Вставить("ВалютДокумента", 		   РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный);
	РежимыОтображения.Вставить("НастройкиИсточника", 	   РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный);
	
	Параметры = Настройки.ПараметрыДанных.Элементы;
	
	Для Каждого РежимОтображения Из РежимыОтображения Цикл 
		
		НайденныйПараметр = Параметры.Найти(РежимОтображения.Ключ);
		
		Если НайденныйПараметр <> Неопределено Тогда 
			РежимыОтображения[РежимОтображения.Ключ] = НайденныйПараметр.РежимОтображения;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат РежимыОтображения;
	
КонецФункции

Функция НовыеНастройкиИсточника() Экспорт

	ПараметрыИсточника = НовыеПараметрыИсточника();
	ОтборыИсточника    = НовыеОтборыИсточника();
	НастройкиИсточника = Новый Структура("ПараметрыИсточника, ОтборыИсточника", 
							ПараметрыИсточника, ОтборыИсточника);
							
	Возврат НастройкиИсточника;						

КонецФункции

