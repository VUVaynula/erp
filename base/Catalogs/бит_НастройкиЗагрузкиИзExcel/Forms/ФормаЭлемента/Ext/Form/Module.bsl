		МассивИменРеквизитов.Добавить(ДопТекст + ТекСтрока.ИмяРеквизита);
		
		ТекСтрока.ИмяВФайле = ДопТекст + ТекСтрока.ИмяРеквизита; 
		
	КонецЦикла;
	
