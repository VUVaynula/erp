		Возврат;
	КонецЕсли;
	
	Попытка
		Записать();
	Исключение
		ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());		
		ТекстСообщения = НСтр("ru='Не удалось записать настройку по причине: %1';
							  |en='Could not write configuration for a reason: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ТекстОшибки);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;
	
	// Выгрузим структуру колонок из имен колонки "Имя в файле".
