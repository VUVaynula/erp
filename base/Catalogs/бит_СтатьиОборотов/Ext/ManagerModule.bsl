Процедура СкопироватьШаблоныПроводок(ОбъектКопирования, Ссылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ОбъектКопирования", ОбъектКопирования);
	Запрос.УстановитьПараметр("Ссылка", 		   Ссылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	&Ссылка КАК ОбъектСШаблонами,
	|	ШаблоныПроводок.ШаблонПроводки КАК ШаблонПроводки,
	|	ЛОЖЬ КАК Назначено
	|ИЗ
	|	РегистрСведений.бит_ШаблоныПроводокБюджетированияСтатейОборотов КАК ШаблоныПроводок
	|ГДЕ
	|	ШаблоныПроводок.ОбъектСШаблонами = &ОбъектКопирования";	
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка			 = РезультатЗапроса.Выбрать();
	
	НаборЗаписей = РегистрыСведений.бит_ШаблоныПроводокБюджетированияСтатейОборотов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ОбъектСШаблонами.Установить(Ссылка);
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(НаборЗаписей.Добавить(), Выборка);
	КонецЦикла;
	НаборЗаписей.Записать();
	
КонецПроцедуры

Процедура УстановитьШаблоныПроводокСвязаннымСтатьям(ОбъектСШаблонами) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ОбъектСШаблонами", ОбъектСШаблонами);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бит_СтатьиОборотов.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(ИндивидуальныеНастройки.Назначено, ЛОЖЬ) КАК Назначено,
	|	бит_СтатьиОборотов.ЭтоГруппа КАК ЭтоГруппа
	|ПОМЕСТИТЬ СтатьиОборотов
	|ИЗ
	|	Справочник.бит_СтатьиОборотов КАК бит_СтатьиОборотов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_НаличиеШаблоновПроводокБюджетирования КАК ИндивидуальныеНастройки
	|		ПО бит_СтатьиОборотов.Ссылка = ИндивидуальныеНастройки.ОбъектСШаблонами
	|ГДЕ
	|	бит_СтатьиОборотов.Ссылка В ИЕРАРХИИ(&ОбъектСШаблонами)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтатьиОборотов.Ссылка КАК Ссылка
	|ИЗ
	|	СтатьиОборотов КАК СтатьиОборотов
	|ИТОГИ ПО
	|	Ссылка ИЕРАРХИЯ
	|;
