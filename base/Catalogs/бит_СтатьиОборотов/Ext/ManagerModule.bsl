	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШаблоныПроводок.ОбъектСШаблонами КАК ОбъектСШаблонами,
	|	ШаблоныПроводок.ШаблонПроводки КАК ШаблонПроводки
	|ИЗ
	|	РегистрСведений.бит_ШаблоныПроводокБюджетированияСтатейОборотов КАК ШаблоныПроводок
	|ГДЕ
	|	ШаблоныПроводок.ОбъектСШаблонами = &ОбъектСШаблонами";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();	
	ИерархияСтатей 	 = РезультатЗапроса[1].Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);	
	ПроверкаИерархии = РезультатЗапроса[2].Выгрузить();
	ШаблоныПроводок  = РезультатЗапроса[3].Выгрузить();

	ПроверкаИерархии.Индексы.Добавить("Ссылка");

	// Обход дерева значений без рекурсии.
	Стек = Новый Массив; 
	Для каждого СтрокаТаблицы Из ИерархияСтатей.Строки Цикл
		
		Стек.Добавить(СтрокаТаблицы);
	
		Пока Стек.Количество() > 0 Цикл
			
			ТекущийОбъект = Стек.Получить(Стек.ВГраница());
			Стек.Удалить(Стек.ВГраница());
			
			ПропуститьУзел 		= Ложь;
			ФормироватьПроводки = Ложь;
			РезультатПроверки 	= ПроверкаИерархии.Найти(ТекущийОбъект.Ссылка, "Ссылка");
			
			ФормироватьПроводки = РезультатПроверки <> Неопределено И НЕ РезультатПроверки.Назначено;

			Если РезультатПроверки <> Неопределено Тогда
				ПропуститьУзел = РезультатПроверки.ЭтоГруппа И РезультатПроверки.Назначено И ТекущийОбъект.Ссылка <> ОбъектСШаблонами;
			КонецЕсли;
			
			Если ТекущийОбъект.Ссылка <> ОбъектСШаблонами
			   И ФормироватьПроводки Тогда
				НаборЗаписей = РегистрыСведений.бит_ШаблоныПроводокБюджетированияСтатейОборотов.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.ОбъектСШаблонами.Установить(ТекущийОбъект.Ссылка);
				Для каждого Запись Из ШаблоныПроводок Цикл
					НоваяСтрока = НаборЗаписей.Добавить();
					НоваяСтрока.ОбъектСШаблонами = ТекущийОбъект.Ссылка;
					НоваяСтрока.ШаблонПроводки 	 = Запись.ШаблонПроводки;
				КонецЦикла;
				НаборЗаписей.Записать();
			КонецЕсли;
			Если НЕ ПропуститьУзел Тогда
				Для каждого Элемент Из ТекущийОбъект.Строки Цикл
					Стек.Добавить(Элемент);
				КонецЦикла; 
			КонецЕсли;
		КонецЦикла;
	КонецЦикла; 

КонецПроцедуры

Процедура СкопироватьГруппуСтатейОборотовСПодчиненными(ОбъектКопирования) Экспорт
	
	ТаблицаСсылок = Новый ТаблицаЗначений(); 
	ТаблицаСсылок.Колонки.Добавить("ЧтоЗаменить");
	ТаблицаСсылок.Колонки.Добавить("НаЧтоЗаменить");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ОбъектКопирования);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бит_СтатьиОборотов.Ссылка КАК Ссылка,
	|	бит_СтатьиОборотов.Родитель,
	|	бит_СтатьиОборотов.Ссылка = &Ссылка КАК ЭтоИсточник
	|ИЗ
	|	Справочник.бит_СтатьиОборотов КАК бит_СтатьиОборотов
	|ГДЕ
	|	бит_СтатьиОборотов.Ссылка В ИЕРАРХИИ(&Ссылка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка ИЕРАРХИЯ";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка 		 = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Значение = Выборка.Ссылка.Скопировать();
		
		Родитель = Выборка.Родитель;
		Если НЕ Выборка.ЭтоИсточник Тогда
			ОбработатьСсылкуВТаблицеСсылок(Родитель, ТаблицаСсылок);
		КонецЕсли; 
		
		Ссылка = Выборка.Ссылка;
		ОбработатьСсылкуВТаблицеСсылок(Ссылка, ТаблицаСсылок);

		Значение.Родитель = Родитель;
		Значение.УстановитьСсылкуНового(Ссылка);
		Значение.УстановитьНовыйКод();
		Значение.ОбменДанными.Загрузка = Истина;
		
		Значение.Записать();
		
	КонецЦикла;
	
КонецПроцедуры
	
Процедура ОбновитьЗаполненныеЭлементыПриПереходеНаНовуюВерсию() Экспорт

	МетаданныеОбъекта = ПустаяСсылка().Метаданные();
	ОбновлениеИнформационнойБазы.ОбновитьПредопределенныеЭлементы(МетаданныеОбъекта);

КонецПроцедуры

Процедура ОбновитьЭлементыКурсовыхРазницБДР() Экспорт

	Элементы = Новый Массив;
	Элементы.Добавить(Справочники.бит_СтатьиОборотов.КурсовыеРазницыБДРОтрицательные);
	Элементы.Добавить(Справочники.бит_СтатьиОборотов.КурсовыеРазницыБДРПоложительные);
	
	МетаданныеОбъекта	= ПустаяСсылка().Метаданные(); 
	ПараметрыОбновления = ОбновлениеИнформационнойБазы.ПараметрыОбновленияПредопределенныхЭлементов();
	ПараметрыОбновления.Элементы  = Элементы;
	
	ОбновлениеИнформационнойБазы.ОбновитьПредопределенныеЭлементы(МетаданныеОбъекта, ПараметрыОбновления);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НовыеНастройкиСтатьи()
	
	Настройки = Новый Структура;
	
	Настройки.Вставить("Измерения",       Новый Структура);
	Настройки.Вставить("Учет_Сумма",      Ложь);
	Настройки.Вставить("Учет_Количество", Ложь);
	Настройки.Вставить("ЭтоКоэффициент",  Ложь);
	Настройки.Вставить("СтавкаНДС",       Неопределено);
	Настройки.Вставить("ТипСтатьи",       Перечисления.бит_ТипыСтатейОборотов.ПустаяСсылка());
	Настройки.Вставить("Код",             "");
	Настройки.Вставить("Кодификатор",     "");
	
	Возврат Настройки;
	
КонецФункции

Функция ЗначениеИзВыборки(Поле, ЗначениеПоУмолчанию, ПоляВыборки, Выборка, КэшПровеки)

	ВыборкаСодержитПоле = КэшПровеки.Получить(Поле);
	Если ВыборкаСодержитПоле = Неопределено Тогда
		ВыборкаСодержитПоле = (ПоляВыборки.Колонки.Найти(Поле) <> Неопределено);
		КэшПровеки.Вставить(Поле, ВыборкаСодержитПоле);
	КонецЕсли;
	
	Если ВыборкаСодержитПоле Тогда
		ЗначениеИзВыборки = Выборка[Поле];
	Иначе
		ЗначениеИзВыборки = ЗначениеПоУмолчанию;
	КонецЕсли; 	

	Возврат ЗначениеИзВыборки;
	
КонецФункции

Функция НовыеНастройкиАналитики(ИмяАналитики)
	
	НастройкиАналитики = Новый Структура; 
	НастройкиАналитики.Вставить("Имя",				  ИмяАналитики);
	НастройкиАналитики.Вставить("Учет",				  Ложь);
	НастройкиАналитики.Вставить("Обязательный",		  Ложь);
	НастройкиАналитики.Вставить("ИмяТипаПоУмолчанию", "");
	НастройкиАналитики.Вставить("ТипПоУмолчанию", 	  Неопределено);

	Возврат НастройкиАналитики;
	
КонецФункции

Процедура ОбработатьСсылкуВТаблицеСсылок(ЧтоЗаменить, ТаблицаСсылок)
		
	СтрокаСсылка = ТаблицаСсылок.Найти(ЧтоЗаменить,"ЧтоЗаменить");
	Если СтрокаСсылка = Неопределено Тогда
		НаЧтоЗаменить = Справочники.бит_СтатьиОборотов.ПолучитьСсылку(Новый УникальныйИдентификатор());
		НоваяСтрока = ТаблицаСсылок.Добавить();
		НоваяСтрока.ЧтоЗаменить   = ЧтоЗаменить;
		НоваяСтрока.НаЧтоЗаменить = НаЧтоЗаменить;
		ЧтоЗаменить = НаЧтоЗаменить;
	Иначе
		ЧтоЗаменить = СтрокаСсылка.НаЧтоЗаменить;
	КонецЕсли;

КонецПроцедуры

