&НаСервере
Процедура ПодготовитьФормуНаСервере()

	ШаблоныПроводок.Очистить();
	ПрочитатьШаблоныПроводок(Объект.Ссылка);

КонецПроцедуры

&НаСервере
Процедура ПрочитатьШаблоныПроводок(ОбъектСШаблонами)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШаблоныПроводок.ШаблонПроводки КАК ШаблонПроводки,
	|	ШаблоныПроводок.ШаблонПроводки.СчетДТ КАК СчетДТ,
	|	ШаблоныПроводок.ШаблонПроводки.СчетКТ КАК СчетКТ,
	|	ШаблоныПроводок.ШаблонПроводки.КоэффициентСумма КАК КоэффициентСумма,
	|	ШаблоныПроводок.ШаблонПроводки.КоэффициентКоличество КАК КоэффициентКоличество,
	|	ШаблоныПроводок.ШаблонПроводки.Содержание КАК Содержание,
	|	ШаблоныПроводок.Назначено КАК Назначено
	|ИЗ
	|	РегистрСведений.бит_ШаблоныПроводокБюджетированияСтатейОборотов КАК ШаблоныПроводок
	|ГДЕ
	|	ШаблоныПроводок.ОбъектСШаблонами = &ОбъектСШаблонами
	|
	|УПОРЯДОЧИТЬ ПО
	|	ШаблоныПроводок.ШаблонПроводки";
	
	Запрос.УстановитьПараметр("ОбъектСШаблонами", ОбъектСШаблонами);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка			 = РезультатЗапроса.Выбрать();
	
	ИндивидуальнаяНастройкаШаблоновПроводок = Ложь;
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ШаблоныПроводок.Добавить(), Выборка);
		ИндивидуальнаяНастройкаШаблоновПроводок = Выборка.Назначено;
	КонецЦикла;

	КоличествоШаблонов = ШаблоныПроводок.Количество();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДобавленныеКолонкиТаблицыШаблоныПроводок(ИдентификаторСтроки)

	СтрокаТаблицы 	 = ШаблоныПроводок.НайтиПоИдентификатору(ИдентификаторСтроки);
	РеквизитыШаблона = НовыеДанныеСтрокиШаблоныПроводок();
	
	Если ЗначениеЗаполнено(СтрокаТаблицы.ШаблонПроводки) Тогда
		РеквизитыШаблона = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаТаблицы.ШаблонПроводки,
			"СчетДТ, СчетКТ, КоэффициентСумма, КоэффициентКоличество, Содержание");
	КонецЕсли;	
	
	ЗаполнитьЗначенияСвойств(СтрокаТаблицы, РеквизитыШаблона);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция НовыеДанныеСтрокиШаблоныПроводок()

	ДанныеСтроки = Новый Структура;
	ДанныеСтроки.Вставить("СчетДТ",				   Неопределено);
	ДанныеСтроки.Вставить("СчетКТ", 			   Неопределено);
	ДанныеСтроки.Вставить("КоэффициентСумма", 	   0);
	ДанныеСтроки.Вставить("КоэффициентКоличество", 0);
	ДанныеСтроки.Вставить("Содержание", 		   "");
	Возврат ДанныеСтроки;

КонецФункции

&НаКлиенте
Процедура ОбработатьЗаписьШаблонаПроводкиБюджетирования(ШаблонПроводки)

	Для каждого СтрокаТаблицы Из ШаблоныПроводок Цикл
		Если СтрокаТаблицы.ШаблонПроводки = ШаблонПроводки Тогда
			ЗаполнитьДобавленныеКолонкиТаблицыШаблоныПроводок(СтрокаТаблицы.ПолучитьИдентификатор());
		КонецЕсли;	
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура НазначитьШаблоныПроводок(ТекущийОбъект)

	НаборЗаписей = РегистрыСведений.бит_ШаблоныПроводокБюджетированияСтатейОборотов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ОбъектСШаблонами.Установить(ТекущийОбъект.Ссылка);
	
	Для каждого СтрокаТаблицы Из ШаблоныПроводок Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ШаблонПроводки) Тогда
			Продолжить;	
		КонецЕсли;
		Запись = НаборЗаписей.Добавить();
		Запись.ОбъектСШаблонами = ТекущийОбъект.Ссылка;
		Запись.ШаблонПроводки	= СтрокаТаблицы.ШаблонПроводки;
		Запись.Назначено 	  	= ИндивидуальнаяНастройкаШаблоновПроводок;
	КонецЦикла;
	
	НаборЗаписей.Записать();

	ИзмененыШаблоныПроводок = Ложь;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьШаблоныПроводокПоУмолчанию()

	ШаблоныПроводок.Очистить();
	ПрочитатьШаблоныПроводок(Объект.Родитель);
	
	ИндивидуальнаяНастройкаШаблоновПроводок = Ложь;
	ИзмененыШаблоныПроводок 						  = Истина;

КонецПроцедуры

