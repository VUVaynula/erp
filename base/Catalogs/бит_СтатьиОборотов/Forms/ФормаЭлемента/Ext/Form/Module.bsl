&НаКлиенте
Процедура НастроитьМаскуКодификатора(Команда)

	Отборы = Новый Структура;
	Отборы.Вставить("ОбъектСистемы", ОбъектСистемы);
	Отборы.Вставить("ИмяРеквизита",  "Кодификатор");
	
	ПараметрыФормы = Новый Структура("Отбор", Отборы);
	ОткрытьФорму("РегистрСведений.бит_МаскиКодов.ФормаСписка", ПараметрыФормы, ЭтотОбъект, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьШаблонИзИсточника(Команда)
	
	ПараметрыФормы = Новый Структура("ВыборГруппИЭлементов", ИспользованиеГруппИЭлементов.ГруппыИЭлементы);
 	Оповещение	   = Новый ОписаниеОповещения("ДобавитьШаблонИзИсточникаЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("Справочник.бит_СтатьиОборотов.ФормаВыбора", ПараметрыФормы, ЭтотОбъект, ЭтотОбъект,,, Оповещение);

КонецПроцедуры

// Обработчик завершения открытия формы.
//  См. Синтакс-помощник: ОткрытьФорму().
//
&НаКлиенте
Процедура ДобавитьШаблонИзИсточникаЗавершение(Результат, Дополнительно) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПрочитатьШаблоныПроводок(Результат);
	
	ИзмененыШаблоныПроводок							  = Истина;
	ИндивидуальнаяНастройкаШаблоновПроводок = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодборШаблоновПроводок(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("МножественныйВыбор", Истина);

	Оповещение = Новый ОписаниеОповещения("ПодборШаблоновПроводокЗавершение", ЭтотОбъект);

	ОткрытьФорму("Справочник.бит_ШаблоныПроводокБюджетирования.ФормаВыбора", ПараметрыФормы, ЭтотОбъект, ЭтотОбъект,,,
		Оповещение);
		
КонецПроцедуры
	
// Обработчик завершения открытия формы.
//  См. Синтакс-помощник: ОткрытьФорму().
//
&НаКлиенте
Процедура ПодборШаблоновПроводокЗавершение(Результат, Дополнительно) Экспорт

	Если НЕ ЗначениеЗаполнено(Результат) Тогда
		Возврат;	
	КонецЕсли;
	
	ИзмененСоставСтрок = Ложь;
	Для каждого Элемент Из Результат Цикл
		УжеПодобран = Ложь;
		Для каждого СтрокаТаблицы Из ШаблоныПроводок Цикл
			Если СтрокаТаблицы.ШаблонПроводки = Элемент Тогда
				УжеПодобран = Истина;
				Прервать;		
			КонецЕсли;
		КонецЦикла;
		Если НЕ УжеПодобран Тогда
			НоваяСтрока = ШаблоныПроводок.Добавить();
			НоваяСтрока.ШаблонПроводки = Элемент;
			ИзмененСоставСтрок = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

