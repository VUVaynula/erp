КонецПроцедуры

&НаКлиенте
Процедура ФормаОплатыПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(Объект.ФормаОплаты) Тогда
		Объект.ВидОперации = Неопределено;
	Иначе
		ДоступныеЗначения = ДоступныеЗначенияВидовОпераций(Объект.ФормаОплаты);
		Если ДоступныеЗначения.НайтиПоЗначению(Объект.ВидОперации) = Неопределено Тогда
			Объект.ВидОперации = ДоступныеЗначения[0].Значение;
		КонецЕсли; 
	КонецЕсли;
	
	УстановитьПараметрыВыбораВидаОперации(ЭтотОбъект);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ИспользоватьРазрезПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.РазрезыБюджетирования.ТекущиеДанные;
	Если ТекущиеДанные.ИспользоватьРазрез = Ложь Тогда
		Если Параметры.Ключ.Пустая() Тогда
			ЕстьДвиженияПоСтатье = Ложь;
		Иначе
			ЕстьДвиженияПоСтатье = ЕстьДвиженияПоСтатье(Объект.Ссылка, ТекущиеДанные.ИмяРеквизита);
		КонецЕсли;
		Если ЕстьДвиженияПоСтатье Тогда
			Оповещение = Новый ОписаниеОповещения("ИспользоватьРазрезПриИзмененииЗавершение", ЭтотОбъект);
			ТекстСообщения1 = НСтр("ru = 'По данной статье есть движения.'; en = 'There are movements under this article.'");
			ТекстСообщения2 = НСтр("ru = 'Для корректной работы системы после изменений необходимо самостоятельно перепровести документы с движениями по статье.';
				|en = 'For the correct operation of the system after the changes it is necessary to independently rewrite documents with movements according to the article.'");
			ТекстСообщения3 = НСтр("ru = 'Данные по отключенной аналитике будут удалены. Продолжить?'; en = 'Disabled analytics data will be deleted. Proceed?'");
			ТекстСообщения = НСтр("ru = '%1 %2 %3'; en = '%1 %2 %3'"); 
			ТекстСообщения = СтрШаблон(ТекстСообщения, ТекстСообщения1, ТекстСообщения2, ТекстСообщения3); 			
			ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет, 20, КодВозвратаДиалога.Нет);
		Иначе
			ТекущиеДанные.Обязательный = Ложь;
		КонецЕсли; 
	КонецЕсли; 
	
	РазрезыБюджетированияУстановитьЗаголовок(ЭтотОбъект);
	
КонецПроцедуры

// Процедура обработчик оповещения "ИспользоватьРазрезПриИзмененииЗавершение".
//
// Параметры:
// Результат - КодВозвратаДиалога
// ДополнительныеДанные - Структура.
//
&НаКлиенте
Процедура ИспользоватьРазрезПриИзмененииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ТекущиеДанные = Элементы.РазрезыБюджетирования.ТекущиеДанные;
	Если Результат = КодВозвратаДиалога.Да Тогда
		ТекущиеДанные.Обязательный = Ложь;
	Иначе	
		ТекущиеДанные.ИспользоватьРазрез = Истина;
	КонецЕсли;
	РазрезыБюджетированияУстановитьЗаголовок(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПанельОсновнаяПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	// СтандартныеПодсистемы.Свойства
	Если ЭтотОбъект.ПараметрыСвойств.Свойство(ТекущаяСтраница.Имя)
		И Не ЭтотОбъект.ПараметрыСвойств.ВыполненаОтложеннаяИнициализация Тогда
		СвойстваВыполнитьОтложеннуюИнициализацию();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаКлиенте
Процедура ИндивидуальнаяНастройкаШаблоновПроводокПриИзменении(Элемент)
	
	Если ИндивидуальнаяНастройкаШаблоновПроводок Тогда
		ИзмененыШаблоныПроводок = Истина;
	Иначе	
		ЗаполнитьШаблоныПроводокПоУмолчанию();
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура РодительПриИзменении(Элемент)
	
	Если НЕ ИндивидуальнаяНастройкаШаблоновПроводок Тогда
		ЗаполнитьШаблоныПроводокПоУмолчанию();	
	КонецЕсли;
	
