КонецПроцедуры // НаименованиеПриИзменении()

&НаКлиенте
Процедура НаименованиеПолноеПриИзменении(Элемент)

	УстановитьФлагФормироватьНаименованиеПолноеАвтоматически();

КонецПроцедуры // НаименованиеПолноеПриИзменении()

&НаКлиенте
Процедура НаименованиеПолноеОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ВыбранноеЗначение <> Неопределено Тогда
	
		Объект.НаименованиеПолное = ВыбранноеЗначение;
		ФормироватьНаименованиеПолноеАвтоматически = Истина;
	
	КонецЕсли;
	
КонецПроцедуры // НаименованиеПолноеОбработкаВыбора()

&НаКлиенте
Процедура НаименованиеПолноеАвтоПодбор(Элемент, Текст, ДанныеВыбора, Параметры, Ожидание, СтандартнаяОбработка)
	
	Элемент.СписокВыбора.Очистить();
	
	Элемент.СписокВыбора.Добавить(Объект.Наименование);
	
КонецПроцедуры // НаименованиеПолноеАвтоПодбор()

&НаКлиенте
Процедура Учет_КоличествоПриИзменении(Элемент)
	
	НовоеЗначение = Объект.Учет_Количество;
	ПриИзмененииВидаУчета(Объект.Учет_Количество);
	
	Если Объект.Учет_Количество <> НовоеЗначение Тогда
		Возврат;
	КонецЕсли;
	
	УправлениеФормойПриИзмененииУчетаКоличества(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура Учет_СуммаПриИзменении(Элемент)
	
	НовоеЗначение = Объект.Учет_Сумма;
	ПриИзмененииВидаУчета(Объект.Учет_Сумма);
	
	Если Объект.Учет_Сумма <> НовоеЗначение Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ Объект.Учет_Сумма Тогда
		Объект.ЭтоКоэффициент = Ложь;
	КонецЕсли; 
	
	УправлениеФормойПриИзмененииУчетаСуммы();
	
КонецПроцедуры

&НаКлиенте
Процедура ТипСтатьиПриИзменении(Элемент)
	
	ТипыСтатейБДР 					 = ПредопределенноеЗначение("Перечисление.бит_ТипыСтатейОборотов.БДР");
	ТипыСтатейНефинансовыйПоказатель = ПредопределенноеЗначение("Перечисление.бит_ТипыСтатейОборотов.НефинансовыйПоказатель");
	ТипыСтатейФинансовыйПоказатель	 = ПредопределенноеЗначение("Перечисление.бит_ТипыСтатейОборотов.ФинансовыйПоказатель");
	
	Если Объект.ТипСтатьи = ТипыСтатейБДР Тогда
		
		Объект.СтавкаНДС = СтавкаНДСБезНДС();
		
	ИначеЕсли Объект.ТипСтатьи = ТипыСтатейНефинансовыйПоказатель ИЛИ Объект.ТипСтатьи = ТипыСтатейФинансовыйПоказатель Тогда
		
		Объект.СтавкаНДС   = СтавкаНДСБезНДС();
		Объект.ВидСтатьи   = ПредопределенноеЗначение("Справочник.бит_ВидыСтатейОборотов.ПустаяСсылка");
		Объект.РасходДоход = ПредопределенноеЗначение("Перечисление.бит_РасходДоход.ПустаяСсылка");
		
	КонецЕсли; 
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры // ТипСтатьиПриИзменении()

&НаКлиенте
Процедура РасходДоходПриИзменении(Элемент)
	
	Объект.ВидОперации = Неопределено;
	
