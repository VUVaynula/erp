
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбъектСистемы = Параметры.ОбъектСистемы;
	
	ОбновитьСоставРеквизитов();
	
	УстановитьТекущийРеквизит(Параметры.ТекущийРеквизит);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРеквизитыОбъекта

&НаКлиенте
Процедура РеквизитыОбъектаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ОбработатьВыборРеквизита();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаВыбрать(Команда)
	
	ОбработатьВыборРеквизита();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбновитьСоставРеквизитов()
	
	МетаданныеОбъекта = Метаданные.НайтиПоПолномуИмени(ОбъектСистемы.ИмяОбъектаПолное);
	
	СтрокиРеквизитов = РеквизитыОбъекта.ПолучитьЭлементы();
	СтрокиРеквизитов.Очистить();
	
	ТаблицаРеквизитов = Новый ТаблицаЗначений;
	ТипСтрока         = Новый ОписаниеТипов("Строка", ,
							Новый КвалификаторыСтроки(0, ДопустимаяДлина.Переменная));
	ТипРеквизита      = Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.ДополнительныеРеквизитыИСведения, Строка", ,
				   			Новый КвалификаторыСтроки(100, ДопустимаяДлина.Переменная));
	ТаблицаРеквизитов.Колонки.Добавить("ПутьКДанным",   ТипРеквизита);
	ТаблицаРеквизитов.Колонки.Добавить("ТипЗначения",   ТипСтрока);
	ТаблицаРеквизитов.Колонки.Добавить("Представление", ТипСтрока);
	Для каждого Реквизит Из МетаданныеОбъекта.СтандартныеРеквизиты Цикл
		ДобавитьОписаниеРеквизита(ТаблицаРеквизитов, Реквизит);
	КонецЦикла;
	Для каждого Реквизит Из МетаданныеОбъекта.Реквизиты Цикл
		ДобавитьОписаниеРеквизита(ТаблицаРеквизитов, Реквизит);
	КонецЦикла;
	
	СсылкаНаОбъект = Новый(ОбъектСистемы.ТипЗначенияОбъекта.Получить());
	Если УправлениеСвойствами.ИспользоватьДопРеквизиты(СсылкаНаОбъект) Тогда
		ДополнительныеРекизиты = УправлениеСвойствами.СвойстваОбъекта(СсылкаНаОбъект, , Ложь);
		ЗначенияРеквзитов      = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(ДополнительныеРекизиты,
									"Имя, Заголовок, ТипЗначения, Ссылка");
		Для каждого ЭлементСоответствия Из ЗначенияРеквзитов Цикл
			ДанныеРеквизита = ЭлементСоответствия.Значение;
			ДобавитьОписаниеРеквизита(ТаблицаРеквизитов, ДанныеРеквизита, Истина);
		КонецЦикла;
	КонецЕсли;
	
	ТаблицаРеквизитов.Сортировать("Представление, ПутьКДанным");
	
	Для каждого СтрокаРеквизита Из ТаблицаРеквизитов Цикл
		СтрокаДереваРеквизитов = СтрокиРеквизитов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДереваРеквизитов, СтрокаРеквизита);
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьОписаниеРеквизита(ТаблицаРеквизитов, Реквизит, ЭтоДопРеквизит = Ложь)
	
	ИмяРеквизита = Реквизит.Имя;
	Если СтрНачинаетсяС(ИмяРеквизита, "Удалить") Тогда
		Возврат;
	КонецЕсли;
	
	ПредставлениеРеквизита = ?(ЭтоДопРеквизит, Реквизит.Заголовок, Реквизит.Синоним);
	Если ПустаяСтрока(ПредставлениеРеквизита) Тогда
		ПредставлениеРеквизита = бит_ОбщегоНазначенияКлиентСервер.РазбитьНаОтдельныеСлова(ИмяРеквизита);
	КонецЕсли;
	
	СтрокаРеквизита = ТаблицаРеквизитов.Добавить();
	Если ЭтоДопРеквизит Тогда
		СтрокаРеквизита.ПутьКДанным   = Реквизит.Ссылка;
		СтрокаРеквизита.ТипЗначения   = Реквизит.ТипЗначения;
	Иначе
		СтрокаРеквизита.ПутьКДанным   = ИмяРеквизита;
		СтрокаРеквизита.ТипЗначения   = Реквизит.Тип;
	КонецЕсли;
	СтрокаРеквизита.Представление = ПредставлениеРеквизита;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВыборРеквизита()
	
	ТекущиеДанные = Элементы.РеквизитыОбъекта.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		ОповеститьОВыборе(ТекущиеДанные.ПутьКДанным);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьТекущийРеквизит(ТекущийРеквизит)
	
	Если ПустаяСтрока(ТекущийРеквизит) Тогда
		Возврат;
	КонецЕсли;
	
	СтрокиРеквизитов = РеквизитыОбъекта.ПолучитьЭлементы();
	Для каждого СтрокаРеквизита Из СтрокиРеквизитов Цикл
		Если СтрокаРеквизита.ПутьКДанным = ТекущийРеквизит Тогда
			Элементы.РеквизитыОбъекта.ТекущаяСтрока = СтрокаРеквизита.ПолучитьИдентификатор();
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти