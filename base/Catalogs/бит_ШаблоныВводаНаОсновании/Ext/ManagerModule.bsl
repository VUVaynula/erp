#Область СлужебныйПрограммныйИнтерфейс

Функция НовыеПараметрыПравилЗаполнения() Экспорт
	
	Параметры = Новый Структура;
	Параметры.Вставить("ОбъектОснование",    Справочники.бит_ОбъектыСистемы.ПустаяСсылка());
	Параметры.Вставить("ОбъектПриемник",     Справочники.бит_ОбъектыСистемы.ПустаяСсылка());
	Параметры.Вставить("РеквизитПриемника");
	Параметры.Вставить("СпособЗаполнения",   Перечисления.бит_СпособыЗаполненияРеквизитовПоШаблону.ИзДанныхОснования);
	Параметры.Вставить("РеквизитИсточника");
	Параметры.Вставить("ФиксированноеЗначение");
	Параметры.Вставить("ИдентификаторСтроки");
	Возврат Параметры;
	
КонецФункции

Процедура ЗаполнитьПоШаблону(Шаблон, Основание, Приемник) Экспорт
	
	ПравилаЗаполненияПолей = ПравилаЗаполненияПолей(Шаблон, Основание);
	ДанныеОснования        = ДанныеОснования(Основание, ПравилаЗаполненияПолей, Шаблон);
	ЗаполнитьПриемникПоДаннымОснования(ДанныеОснования, Приемник, ПравилаЗаполненияПолей);
	
КонецПроцедуры

Процедура ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, СведенияОбОбъекте, Параметры) Экспорт
	
	ПолноеИмяОбъекта = СведенияОбОбъекте.ПолноеИмя;
	Если ПолноеИмяОбъекта = "Справочник.бит_ВнутренниеДокументы" Тогда
		// Для внутренних документов особые правила подбора шаблонов в записимости от вида документа.
		//	Правила заполнения см. Справочник.бит_ВнутренниеДокументы.ДобавитьКомандыСозданияНаОсновании(). 
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ШаблоныВводаНаОсновании.Ссылка КАК Шаблон,
	|	ШаблоныВводаНаОсновании.Наименование КАК ПредставлениеШаблона,
	|	ОбъектыСистемы.ИмяОбъектаПолное КАК ИмяПримника
	|ИЗ
	|	Справочник.бит_ШаблоныВводаНаОсновании КАК ШаблоныВводаНаОсновании
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_ОбъектыСистемы КАК ОбъектыСистемы
	|		ПО (ШаблоныВводаНаОсновании.ОбъектОснование = &ОбъектСистемы)
	|			И ШаблоныВводаНаОсновании.ОбъектПриемник = ОбъектыСистемы.Ссылка
	|			И (НЕ ШаблоныВводаНаОсновании.ПометкаУдаления)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ШаблоныВводаНаОсновании.Наименование";
	Запрос.УстановитьПараметр("ОбъектСистемы",
		Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(ПолноеИмяОбъекта));
		
	ВыборкаШаблонов = Запрос.Выполнить().Выбрать();
	Пока ВыборкаШаблонов.Следующий() Цикл
		КомандаСоздатьНаОсновании = КомандыСозданияНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Менеджер      = ВыборкаШаблонов.ИмяПримника;
		КомандаСоздатьНаОсновании.Представление = ВыборкаШаблонов.ПредставлениеШаблона;
		КомандаСоздатьНаОсновании.РежимЗаписи   = "Записывать";
		КомандаСоздатьНаОсновании.ДополнительныеПараметры.Вставить("ШаблонВводаНаОсновании", ВыборкаШаблонов.Шаблон);
	КонецЦикла;

КонецПроцедуры

Процедура СоздатьШаблоныПоУмолчанию() Экспорт
	
	ШаблоныПоУмолчанию = НовоеОписаниеШаблоновПоУмолчанию();
	
	ДобавитьОписаниеШаблона(ШаблоныПоУмолчанию, Метаданные.Документы.бит_ИсковоеТребование, Метаданные.Задачи.бит_Задача);
	ДобавитьОписаниеШаблона(ШаблоныПоУмолчанию, Метаданные.Документы.бит_Претензия, Метаданные.Задачи.бит_Задача);
	
	ПроверитьСоздатьШаблоны(ШаблоныПоУмолчанию);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПравилаЗаполненияПолей(Шаблон, Основание)
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ПравилаЗаполненияПолей.РеквизитПриемника КАК РеквизитПриемника,
	|	ПравилаЗаполненияПолей.СпособЗаполнения КАК СпособЗаполнения,
	|	ПравилаЗаполненияПолей.РеквизитИсточника КАК РеквизитИсточника,
	|	ПравилаЗаполненияПолей.ФиксированноеЗначение КАК ФиксированноеЗначение,
	|	ТИПЗНАЧЕНИЯ(ПравилаЗаполненияПолей.РеквизитПриемника) = ТИП(СТРОКА) КАК ЭтоРеквизит
	|ПОМЕСТИТЬ ПравилаЗаполненияПолей
	|ИЗ
	|	Справочник.бит_ШаблоныВводаНаОсновании.ПравилаЗаполненияПолей КАК ПравилаЗаполненияПолей
	|ГДЕ
	|	ПравилаЗаполненияПолей.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПравилаЗаполненияПолей.РеквизитПриемника КАК РеквизитПриемника,
	|	ПравилаЗаполненияПолей.СпособЗаполнения КАК СпособЗаполнения,
	|	ПравилаЗаполненияПолей.РеквизитИсточника КАК РеквизитИсточника,
	|	ПравилаЗаполненияПолей.ФиксированноеЗначение КАК ФиксированноеЗначение,
	|	ПравилаЗаполненияПолей.ЭтоРеквизит КАК ЭтоРеквизит
	|ИЗ
	|	ПравилаЗаполненияПолей КАК ПравилаЗаполненияПолей
	|ГДЕ
	|	&УсловиеТипаРеквизита";
	УсловиеТипаРеквизита = "";
	Если УправлениеСвойствами.ИспользоватьДопРеквизиты(Основание) Тогда
		УсловиеТипаРеквизита = "ИСТИНА";
	Иначе
		УсловиеТипаРеквизита = "ПравилаЗаполненияПолей.ЭтоРеквизит";
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеТипаРеквизита", УсловиеТипаРеквизита);
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылка", Шаблон);
	ПравилаЗаполненияПолей = Запрос.Выполнить().Выгрузить();
	ПравилаЗаполненияПолей.Индексы.Добавить("СпособЗаполнения");
	
	Возврат ПравилаЗаполненияПолей;
	
КонецФункции

Функция ДанныеОснования(Основание, ПравилаЗаполненияПолей, Шаблон)
	
	ДанныеОснования = Новый Соответствие;
	
	МетаданныеОснования   = Основание.Метаданные();
	РеквизитыОснования    = Новый Массив;
	ДопРеквизитыОснования = Новый Массив;
	Отбор = Новый Структура("СпособЗаполнения", Перечисления.бит_СпособыЗаполненияРеквизитовПоШаблону.ИзДанныхОснования);
	ПравилаЗаполненияИзДанныхОснования = ПравилаЗаполненияПолей.НайтиСтроки(Отбор);
	Для каждого ПравилоЗаполнения Из ПравилаЗаполненияИзДанныхОснования Цикл
		РеквизитИсточника = ПравилоЗаполнения.РеквизитИсточника;
		Если ТипЗнч(РеквизитИсточника) = Тип("Строка") Тогда
			Если ОбщегоНазначения.ЕстьРеквизитОбъекта(РеквизитИсточника, МетаданныеОснования)
				ИЛИ ОбщегоНазначения.ЭтоСтандартныйРеквизит(МетаданныеОснования.СтандартныеРеквизиты, РеквизитИсточника) Тогда
				РеквизитыОснования.Добавить(РеквизитИсточника);
			Иначе
				ТекстСообщения = НСтр("ru='Ошибка в шаблоне ввода на основании ""%1"": не найден реквизит источника с именем ""%2"".'");
				ТекстСообщения = СтрШаблон(ТекстСообщения, Шаблон, РеквизитИсточника);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			КонецЕсли;
		ИначеЕсли ТипЗнч(РеквизитИсточника) = Тип("ПланВидовХарактеристикСсылка.ДополнительныеРеквизитыИСведения") Тогда
			ДопРеквизитыОснования.Добавить(РеквизитИсточника);
		КонецЕсли;
	КонецЦикла;
	РеквизитыОснованияСтрокой = СтрСоединить(РеквизитыОснования, ",");
	
	Если НЕ ПустаяСтрока(РеквизитыОснованияСтрокой) Тогда
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Основание, РеквизитыОснованияСтрокой);
		Для каждого ЭлементСтруктуры Из ЗначенияРеквизитов Цикл
			ДанныеОснования.Вставить(ЭлементСтруктуры.Ключ, ЭлементСтруктуры.Значение);
		КонецЦикла;
	КонецЕсли;
	Если ДопРеквизитыОснования.Количество() > 0 Тогда
		ЗначенияДопРеквизитов = УправлениеСвойствами.ЗначенияСвойств(Основание, , Ложь, ДопРеквизитыОснования);
		Для каждого СтрокаСвойства Из ЗначенияДопРеквизитов Цикл
			ДанныеОснования.Вставить(СтрокаСвойства.Свойство, СтрокаСвойства.Значение);
		КонецЦикла;
	КонецЕсли;
	
	Возврат ДанныеОснования;
	
КонецФункции

Процедура ЗаполнитьПриемникПоДаннымОснования(ДанныеОснования, Приемник, ПравилаЗаполненияПолей)
	
	ЕстьДополнительныеРеквизиты = ПриемникСодержитДополнительныеРеквизиты(Приемник);
	
	ЗначенияРеквизитов = Новый Структура;
	Для каждого ПравилоЗаполнения Из ПравилаЗаполненияПолей Цикл
		ЗначениеЗаполнения = Неопределено;
		Если ПравилоЗаполнения.СпособЗаполнения = Перечисления.бит_СпособыЗаполненияРеквизитовПоШаблону.ИзДанныхОснования Тогда
			ЗначениеЗаполнения = ДанныеОснования.Получить(ПравилоЗаполнения.РеквизитИсточника);
		ИначеЕсли ПравилоЗаполнения.СпособЗаполнения = Перечисления.бит_СпособыЗаполненияРеквизитовПоШаблону.ФиксированноеЗначение Тогда
			ЗначениеЗаполнения = ПравилоЗаполнения.ФиксированноеЗначение;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ЗначениеЗаполнения) Тогда
			Продолжить;
		КонецЕсли;
		
		РеквизитПриемника = ПравилоЗаполнения.РеквизитПриемника;
		Если ПравилоЗаполнения.ЭтоРеквизит Тогда
			ЗначенияРеквизитов.Вставить(РеквизитПриемника, ЗначениеЗаполнения);
		ИначеЕсли ЕстьДополнительныеРеквизиты Тогда
			СтрокаДопРеквизита = Приемник.ДополнительныеРеквизиты.Добавить();
			СтрокаДопРеквизита.Свойство = РеквизитПриемника;
			СтрокаДопРеквизита.Значение = ЗначениеЗаполнения;
		КонецЕсли;
	КонецЦикла;
	ЗаполнитьЗначенияСвойств(Приемник, ЗначенияРеквизитов);
	
КонецПроцедуры

Функция ПриемникСодержитДополнительныеРеквизиты(Приемник)
	
	Если ТипЗнч(Приемник) = Тип("ФормаКлиентскогоПриложения") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Приемник.Метаданные().ТабличныеЧасти.Найти("ДополнительныеРеквизиты") <> Неопределено;
	
КонецФункции

Функция НовоеОписаниеШаблоновПоУмолчанию()
	
	ШаблоныПоУмолчанию = Новый ТаблицаЗначений;
	
	ТипОбъектыСистемы  = Новый ОписаниеТипов("СправочникСсылка.бит_ОбъектыСистемы");
	ШаблоныПоУмолчанию.Колонки.Добавить("ОбъектОснование", ТипОбъектыСистемы);
	ШаблоныПоУмолчанию.Колонки.Добавить("ОбъектПриемник",  ТипОбъектыСистемы);
	
	Возврат ШаблоныПоУмолчанию;
	
КонецФункции

Процедура ДобавитьОписаниеШаблона(ОписаниеШаблонов, МетаданныеОснования, МетаданныеПриемника)
	
	НовыйШаблон = ОписаниеШаблонов.Добавить();
	НовыйШаблон.ОбъектОснование = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоОбъектуМетаданных(МетаданныеОснования);
	НовыйШаблон.ОбъектПриемник  = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоОбъектуМетаданных(МетаданныеПриемника);
	
КонецПроцедуры

Процедура ПроверитьСоздатьШаблоны(ОписаниеШаблонов)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОписаниеШаблонов.ОбъектОснование КАК ОбъектОснование,
	|	ОписаниеШаблонов.ОбъектПриемник КАК ОбъектПриемник
	|ПОМЕСТИТЬ ОписаниеНовыхШаблонов
	|ИЗ
	|	&ОписаниеШаблонов КАК ОписаниеШаблонов";
	Запрос.УстановитьПараметр("ОписаниеШаблонов", ОписаниеШаблонов);
	Запрос.Выполнить();
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОписаниеНовыхШаблонов.ОбъектОснование КАК ОбъектОснование,
	|	ОписаниеНовыхШаблонов.ОбъектПриемник КАК ОбъектПриемник
	|ИЗ
	|	ОписаниеНовыхШаблонов КАК ОписаниеНовыхШаблонов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_ШаблоныВводаНаОсновании КАК ШаблоныВводаНаОсновании
	|		ПО ОписаниеНовыхШаблонов.ОбъектОснование = ШаблоныВводаНаОсновании.ОбъектОснование
	|			И ОписаниеНовыхШаблонов.ОбъектПриемник = ШаблоныВводаНаОсновании.ОбъектПриемник
	|ГДЕ
	|	ШаблоныВводаНаОсновании.ОбъектОснование ЕСТЬ NULL";	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НовыйШаблон = Справочники.бит_ШаблоныВводаНаОсновании.СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(НовыйШаблон, Выборка);
		
		МетаданныеПриемника = Справочники.бит_ОбъектыСистемы.ОбъектМетаданныхПоОбъектуСистемы(Выборка.ОбъектПриемник);
		НовыйШаблон.Наименование = ОбщегоНазначения.ПредставлениеОбъекта(МетаданныеПриемника);
		
		НовыйШаблон.Записать();
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли