
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КлючиДоступаЦФОСтатьиОборотов.Ссылка КАК КлючДоступаЦФОСтатьяОборотов
	|ПОМЕСТИТЬ КлючиДоступа
	|ИЗ
	|	Справочник.бит_КлючиДоступаЦФОСтатьиОборотов.ГруппыДоступа КАК КлючиДоступаЦФОСтатьиОборотов
	|ГДЕ
	|	КлючиДоступаЦФОСтатьиОборотов.ГруппаДоступа = &ГруппаДоступа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КлючиДоступа.КлючДоступаЦФОСтатьяОборотов.ЦФО КАК ЦФО
	|ИЗ
	|	КлючиДоступа КАК КлючиДоступа
	|
	|СГРУППИРОВАТЬ ПО
	|	КлючиДоступа.КлючДоступаЦФОСтатьяОборотов.ЦФО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КлючиДоступа.КлючДоступаЦФОСтатьяОборотов.СтатьяОборотов КАК СтатьяОборотов
	|ИЗ
	|	КлючиДоступа КАК КлючиДоступа
	|
	|СГРУППИРОВАТЬ ПО
	|	КлючиДоступа.КлючДоступаЦФОСтатьяОборотов.СтатьяОборотов";
	
	Запрос.УстановитьПараметр("ГруппаДоступа", Объект.Ссылка);
	
	Результат = Запрос.ВыполнитьПакет();
	СписокЦФО.Загрузить(Результат[1].Выгрузить());
	СписокСтатей.Загрузить(Результат[2].Выгрузить());
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ВыбранныеЦФО    = СписокЦФО.Выгрузить();
	ВыбранныеСтатьи = СписокСтатей.Выгрузить();
	
	Если ВыбранныеЦФО.Количество() = 0 Тогда
		НоваяСтрока = ВыбранныеЦФО.Добавить();
		НоваяСтрока.ЦФО = Справочники.Подразделения.ПустаяСсылка();
	КонецЕсли;
	
	Если ВыбранныеСтатьи.Количество() = 0 Тогда
		НоваяСтрока = ВыбранныеСтатьи.Добавить();
		НоваяСтрока.СтатьяОборотов = Справочники.бит_СтатьиОборотов.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СписокЦФО",    ВыбранныеЦФО);
	Запрос.УстановитьПараметр("СписокСтатей", ВыбранныеСтатьи);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СписокЦФО.ЦФО КАК ЦФО
		|ПОМЕСТИТЬ СписокЦФО
		|ИЗ
		|	&СписокЦФО КАК СписокЦФО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СписокСтатей.СтатьяОборотов КАК СтатьяОборотов
		|ПОМЕСТИТЬ СписокСтатей
		|ИЗ
		|	&СписокСтатей КАК СписокСтатей
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СписокЦФО.ЦФО КАК ЦФО,
		|	СписокСтатей.СтатьяОборотов КАК СтатьяОборотов
		|ИЗ
		|	СписокЦФО КАК СписокЦФО,
		|	СписокСтатей КАК СписокСтатей";
	
	// АПК:1328-выкл.
	РезультатЗапроса = Запрос.Выполнить();
	// АПК:1328-вкл.
	Выборка = РезультатЗапроса.Выбрать();
	
	СписокКлючейДоступа = Новый Массив;
	Пока Выборка.Следующий() Цикл
		КлючДоступа = Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.КлючиЦФОСтатьяОборотовДокумента(Выборка.ЦФО, Выборка.СтатьяОборотов);
		СписокКлючейДоступа.Добавить(КлючДоступа);
	КонецЦикла;
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущаяГруппаДоступа", Объект.Ссылка);
	Запрос.УстановитьПараметр("СписокКлючей", 	  СписокКлючейДоступа);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.Ссылка КАК КлючДоступа,
	|	СУММА(ВЫБОР
	|			КОГДА Таблица.ГруппаДоступа = &ТекущаяГруппаДоступа
	|				ТОГДА 1
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК РесурсГруппаДоступа
	|ПОМЕСТИТЬ ВТ_ТаблицаГруппыДоступа
	|ИЗ
	|	Справочник.бит_КлючиДоступаЦФОСтатьиОборотов.ГруппыДоступа КАК Таблица
	|ГДЕ
	|	НЕ Таблица.Ссылка.ЭтоГруппа
	|
	|СГРУППИРОВАТЬ ПО
	|	Таблица.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Таблица.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ВТ_ТаблицаГруппыДоступа.РесурсГруппаДоступа, 0) = 0
	|			ТОГДА &ТекущаяГруппаДоступа
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.бит_ГруппыКлючейДоступаЦФОСтатьиОборотов.ПустаяСсылка)
	|	КОНЕЦ КАК ГруппаДоступа
	|ИЗ
	|	Справочник.бит_КлючиДоступаЦФОСтатьиОборотов КАК Таблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ТаблицаГруппыДоступа КАК ВТ_ТаблицаГруппыДоступа
	|		ПО (ВТ_ТаблицаГруппыДоступа.КлючДоступа = Таблица.Ссылка)
	|ГДЕ
	|	(Таблица.Ссылка В (&СписокКлючей)
	|				И ЕСТЬNULL(ВТ_ТаблицаГруппыДоступа.РесурсГруппаДоступа, 0) = 0
	|			ИЛИ НЕ Таблица.Ссылка В (&СписокКлючей)
	|				И ЕСТЬNULL(ВТ_ТаблицаГруппыДоступа.РесурсГруппаДоступа, 0) = 1)";	
	
	НачатьТранзакцию();
		
	Попытка
		
		ТаблицаКлючейДоступа = Запрос.Выполнить().Выбрать();
		Пока ТаблицаКлючейДоступа.Следующий() Цикл
			
			КлючДоступаСсылка = ТаблицаКлючейДоступа.Ссылка;
			КлючДоступаОбъект = КлючДоступаСсылка.ПолучитьОбъект();
			Если НЕ ЗначениеЗаполнено(ТаблицаКлючейДоступа.ГруппаДоступа) Тогда
				СтрокаТаблицы =  КлючДоступаОбъект.ГруппыДоступа.Найти(Объект.Ссылка, "ГруппаДоступа");
				КлючДоступаОбъект.ГруппыДоступа.Удалить(СтрокаТаблицы);
			Иначе	
				НоваяСтрока = КлючДоступаОбъект.ГруппыДоступа.Добавить(); 
				НоваяСтрока.ГруппаДоступа = ТаблицаКлючейДоступа.ГруппаДоступа;
			КонецЕсли; 
			// АПК:1327-выкл - Допустимо оставить запись без
			// предварительной управляемой блокировки объекта, так как только
			// для RLS и пользователем не редактируется.
			КлючДоступаОбъект.Записать();
			// АПК:1327-вкл.
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ШаблонСообщения = НСтр("ru='Не удалось обновить элемент справочника.""%1""';
		                       |en='Could not update the directory entry.""%1""'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Установка группы запрета изменения'", ОбщегоНазначения.КодОсновногоЯзыка()), 
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Справочники.бит_КлючиДоступаЦФОСтатьиОборотов,
			КлючДоступаСсылка, 
			ТекстСообщения);
		ВызватьИсключение ТекстСообщения;
		
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПодборСтатейОборотов(Команда)
	
	ПараметрыПередачи = Новый Структура();
	ПараметрыПередачи.Вставить("МножественныйВыбор", Истина);
	ПараметрыПередачи.Вставить("ВыборГруппИЭлементов", ИспользованиеГруппИЭлементов.ГруппыИЭлементы);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПодборСтатейОборотовЗавершение", ЭтотОбъект);
	ОткрытьФорму("Справочник.бит_СтатьиОборотов.ФормаВыбора",ПараметрыПередачи,, ЭтотОбъект,,, ОписаниеОповещения,  РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

// Процедура - Описание оповещения процедуры ПодборСтатейОборотов. 
//
// Параметры:
//  Результат				 - Массив - Значение выбора.
//  ДополнительныеПараметры	 - Произвольный.
//
&НаКлиенте
Процедура ПодборСтатейОборотовЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ВыбранныеЗначения = РазвернутьРезультатВыбора(Результат, "Справочник.бит_СтатьиОборотов", Истина);

	Для каждого Значение Из ВыбранныеЗначения Цикл
		НайденныеСтроки = СписокСтатей.НайтиСтроки(Новый Структура("СтатьяОборотов", Значение));
		Если НайденныеСтроки.Количество() = 0 Тогда		
			НоваяСтрока = СписокСтатей.Добавить();
			НоваяСтрока.СтатьяОборотов = Значение;
		КонецЕсли; 
	КонецЦикла; 
	
	КоличествоСтатей = СписокСтатей.Количество();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодборЦФО(Команда)
	
	ПараметрыПередачи = Новый Структура();
	ПараметрыПередачи.Вставить("МножественныйВыбор", Истина);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПодборЦФОЗавершение", ЭтотОбъект);
	ОткрытьФорму("Справочник.Подразделения.ФормаВыбора",ПараметрыПередачи,, ЭтотОбъект,,, ОписаниеОповещения,  РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

// Процедура - Описание оповещения процедуры ПодборЦФО. 
//
// Параметры:
//  Результат				 - Массив - Значение выбора.
//  ДополнительныеПараметры	 - Произвольный.
//
&НаКлиенте
Процедура ПодборЦФОЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ВыбранныеЗначения = РазвернутьРезультатВыбора(Результат, "Справочник.Подразделения", Ложь);

	Для каждого Значение Из ВыбранныеЗначения Цикл
		НайденныеСтроки = СписокЦФО.НайтиСтроки(Новый Структура("ЦФО", Значение));
		Если НайденныеСтроки.Количество() = 0 Тогда		
			НоваяСтрока = СписокЦФО.Добавить();
			НоваяСтрока.ЦФО = Значение;
		КонецЕсли; 
	КонецЦикла; 
	
	КоличествоСтатей = СписокЦФО.Количество();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция РазвернутьРезультатВыбора(Знач РезультатВыбора, Знач ИмяТаблицы, Знач ЕстьГруппы)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РезультатВыбора", РезультатВыбора);
	ТекстЗапрос = 
	"ВЫБРАТЬ
	|	Т.Ссылка
	|ИЗ
	|	#Таблица КАК Т
	|ГДЕ
	|	Т.Ссылка В ИЕРАРХИИ(&РезультатВыбора)
	|	И НЕ Т.ПометкаУдаления
	|	И &ЕстьГруппы";
	
	ТекстЗапрос  	 = СтрЗаменить(ТекстЗапрос, "#Таблица", ИмяТаблицы);
	ТекстЗапрос  	 = СтрЗаменить(ТекстЗапрос, "&ЕстьГруппы", ?(ЕстьГруппы,"НЕ ЭтоГруппа", "Истина"));
	Запрос.Текст 	 = ТекстЗапрос;
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");	
	
КонецФункции 

#КонецОбласти