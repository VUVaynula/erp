
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаОбъектаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	КоличествоСубконтоМУ = 4;
	
	бит_БухгалтерскийУчет.УстановитьНачальныеСвойстваСубконтоТаблицы(
		Объект.Способы,
		ПараметрыУстановкиСвойствСубконтоСчетЗатрат(ЭтотОбъект));

	УстановитьУсловноеОформление();
	
	УстановитьПараметрыВыбораДляСчетов();
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСпособы

&НаКлиенте
Процедура СпособыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТекущиеДанные = Элементы.Способы.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НоваяСтрока Тогда
		ТекущиеДанные.Коэффициент = 1;
		ТекущиеДанные.Основной = Ложь;
		
		Если Объект.Способы.Количество() = 1 Тогда
			НазначитьОсновнойСпособ();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СпособыСчетЗатратПриИзменении(Элемент)
	
	бит_БухгалтерияКлиентСервер.УстановитьСвойстваСубконтоСтрокиПриИзмененииСчета(
		ЭтотОбъект,
		Элементы.Способы.ТекущиеДанные,
		ПараметрыУстановкиСвойствСубконтоСчетЗатрат(ЭтотОбъект));
			
КонецПроцедуры

&НаКлиенте
Процедура СпособыСубконтоНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
		
	НачалоВыбораСубконтоСчетУчета(Элемент, ДанныеВыбора, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура НачалоВыбораСубконтоСчетУчета(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ДанныеОбъекта = бит_БухгалтерияКлиентСервер.ДанныеУстановкиПараметровСубконто(
		Элементы.Способы.ТекущиеДанные,
		ПараметрыУстановкиСвойствСубконтоСчетЗатрат(ЭтотОбъект));
	
	ОбщегоНазначенияБПКлиент.НачалоВыбораЗначенияСубконто(ЭтотОбъект, Элемент, СтандартнаяОбработка, ДанныеОбъекта);
	
КонецПроцедуры

&НаКлиенте
Процедура СпособыСубконто1ПриИзменении(Элемент)
	ПриИзмененииСубконтоСчетУчета(1);
КонецПроцедуры

&НаКлиенте
Процедура СпособыСубконто2ПриИзменении(Элемент)
	ПриИзмененииСубконтоСчетУчета(2)
КонецПроцедуры

&НаКлиенте
Процедура СпособыСубконто3ПриИзменении(Элемент)
	ПриИзмененииСубконтоСчетУчета(3)
КонецПроцедуры

&НаКлиенте
Процедура СпособыСубконто4ПриИзменении(Элемент)
	ПриИзмененииСубконтоСчетУчета(4)
КонецПроцедуры


#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НазначитьОсновным(Команда)
	
	НазначитьОсновнойСпособ();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПараметрыУстановкиСвойствСубконтоСчетЗатрат(Форма)
	
	Результат = бит_БухгалтерияКлиентСервер.НовыеПараметрыУстановкиСвойствСубконто();
	                       
	Результат.ПоляФормы.Субконто1   = "СпособыСубконто1";
	Результат.ПоляОбъекта.Субконто1 = "Субконто1";
	Результат.ПоляФормы.Субконто2   = "СпособыСубконто2";
	Результат.ПоляОбъекта.Субконто2 = "Субконто2";
	Результат.ПоляФормы.Субконто3   = "СпособыСубконто3";
	Результат.ПоляОбъекта.Субконто3 = "Субконто3";
	Результат.ПоляФормы.Субконто4   = "СпособыСубконто4";
	Результат.ПоляОбъекта.Субконто4 = "Субконто4";
	Результат.ПоляОбъекта.СчетУчета = "СчетЗатрат";
	
	Результат.ДопРеквизиты.Вставить("Организация", Форма.Объект.Организация);

	Возврат Результат;

КонецФункции

// Процедура дополняет условное оформление формы.
// 
&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
		
	// Фиксация 1 субконто для сохранения внешнего вида формы
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	
	// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "СпособыСубконто1");
	// АПК:277-вкл

	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.Способы.Субконто1Доступность", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);
		
	// Субконто
	Для Сч = 2 По 4 Цикл

		// СубконтоДт
		ЭлементУО = УсловноеОформление.Элементы.Добавить();

		// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
		КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "СпособыСубконто" + Сч);
        // АПК:277-вкл

		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Объект.Способы.Субконто" + Сч + "Доступность", ВидСравненияКомпоновкиДанных.Равно, Ложь);

		ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
				
	КонецЦикла;
															   															   
КонецПроцедуры

// Процедура устанвливает параметры выбора для элементов формы. 
// 
// Параметры:
//  МассивЭлементов - Массив.
// 
&НаСервере
Процедура УстановитьПараметрыВыбораДляСчетов()

	МассивЭлементов = Новый Массив;
	МассивЭлементов.Добавить(Элементы.СпособыСчетЗатрат);
	
	бит_РаботаСДиалогамиСервер.УстановитьПараметрыВыбораДляЭлементов(МассивЭлементов);
	
КонецПроцедуры // УстановитьПараметрыВыбораДляСчетов() 

&НаКлиенте
Функция ПолучитьЗначениеСубконтоТабПоле(ТекущаяСтрока,ИмяТабличногоПоля,ИмяЭлемента)

	ЗначениеСубконто = Неопределено;
	
	Если НЕ ТекущаяСтрока = Неопределено Тогда
		
		ИмяРеквизита      = СтрЗаменить(ИмяЭлемента,ИмяТабличногоПоля,"");
		ЗначениеСубконто  = ТекущаяСтрока[ИмяРеквизита];
		
	КонецЕсли; 

	Возврат ЗначениеСубконто;
	
КонецФункции // ПолучитьЗначениеСубконтоТабПоле()

&НаКлиенте
Процедура ПриИзмененииСубконтоСчетУчета(НомерСубконто)
	
	бит_БухгалтерияКлиент.УстановитьСвойстваСубконтоСтрокиПриИзмененииСубконто(
		ЭтотОбъект, Элементы.Способы.ТекущиеДанные, НомерСубконто, ПараметрыУстановкиСвойствСубконтоСчетЗатрат(ЭтотОбъект));
	
КонецПроцедуры
	
// Назначает основной способ
// 
&НаКлиенте
Процедура НазначитьОсновнойСпособ()
	
	Для каждого ТекСтр Из Объект.Способы Цикл
		ТекСтр.Основной = Ложь;
	КонецЦикла;
	
	ТекущиеДанные = Элементы.Способы.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.Основной = Истина;
	
КонецПроцедуры

#КонецОбласти

