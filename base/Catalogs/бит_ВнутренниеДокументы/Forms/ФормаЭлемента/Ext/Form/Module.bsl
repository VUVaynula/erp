КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
    ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

// СтандартныеПодсистемы.Свойства
&НаКлиенте
Процедура Подключаемый_СвойстваВыполнитьКоманду(ЭлементИлиКоманда, НавигационнаяСсылка = Неопределено, СтандартнаяОбработка = Неопределено)
    УправлениеСвойствамиКлиент.ВыполнитьКоманду(ЭтотОбъект, ЭлементИлиКоманда, СтандартнаяОбработка);
КонецПроцедуры
// Конец СтандартныеПодсистемы.Свойства

&НаКлиенте
Процедура КомандаОтправитьНаСогласование(Команда)
	
	Объект.ОтправленНаСогласование = НЕ Объект.ОтправленНаСогласование;
	Если НЕ Записать() Тогда
		Объект.ОтправленНаСогласование = НЕ Объект.ОтправленНаСогласование;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаЗаполнитьНомер(Команда)
	
	ОповещениеВопрос = Новый ОписаниеОповещения("ЗаполнитьНомерЗавершение", ЭтотОбъект);
	Если ЗначениеЗаполнено(Объект.Номер) И НЕ ИзмененыЗначимыеРеквизиты("Номер") Тогда		
		ТекстВопроса = НСтр("ru = 'Перезаполнить номер?';
							|en = 'Are you sure you want to refill the number?'");
		ПоказатьВопрос(ОповещениеВопрос, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 15, КодВозвратаДиалога.Нет);		
	Иначе		
		ВыполнитьОбработкуОповещения(ОповещениеВопрос, КодВозвратаДиалога.Да); 
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ШаблонЗаполненияРеквизитов

&НаСервере
Процедура ПроверитьШаблоныЗаполненияРеквизитов()

	ШаблонДляНомераУстановлен = Ложь;
	
	ИмяРеквизита = "Номер";
	ИмяШаблона   = "СтруктураШаблона_Номер";
	
	// Поиск сохраненной структуры шаблона.
	Если СтруктураШаблоновЗаполненияРеквизитов = Неопределено Тогда
		СтруктураШаблоновЗаполненияРеквизитов = Новый Структура;
		СтруктураШаблоновЗаполненияРеквизитов.Вставить(ИмяШаблона);
	КонецЕсли;
	
	ПараметрыШаблонаТекущий = СтруктураШаблоновЗаполненияРеквизитов[ИмяШаблона];
	
	// Поиск новой структуры шаблона.
	// ++ ЕРП
	//ПараметрыШаблона = Справочники.бит_ШаблоныЗаполненияРеквизитов.СформироватьСтруктуруПараметровШаблона(Объект, ИмяРеквизита);
	ПараметрыШаблона = Неопределено;
	// -- ЕРП
	Если ПараметрыШаблона = Неопределено Тогда
		Элементы.Номер.ТолькоПросмотр     = Ложь;
		Элементы.ЗаполнитьНомер.Видимость = Ложь;
		Если ПараметрыШаблонаТекущий <> Неопределено Тогда
			СтруктураШаблоновЗаполненияРеквизитов.Вставить(ИмяШаблона, ПараметрыШаблона);
			Объект[ИмяРеквизита] = "";
		КонецЕсли;   	
	Иначе
		Элементы.Номер.ТолькоПросмотр     = Истина;
		Элементы.ЗаполнитьНомер.Видимость = Истина;
		СтруктураШаблоновЗаполненияРеквизитов.Вставить(ИмяШаблона, ПараметрыШаблона);
		
		Если ПараметрыШаблонаТекущий = Неопределено
			И ЗначениеЗаполнено(Объект.Номер)Тогда
			ЗапомнитьЗначенияЗначимыхРеквизитов(ИмяРеквизита);			
		КонецЕсли;	
	КонецЕсли;

	ШаблонДляНомераУстановлен = (СтруктураШаблоновЗаполненияРеквизитов["СтруктураШаблона_Номер"] <> Неопределено);
	
КонецПроцедуры

&НаСервере
Процедура ЗапомнитьЗначенияЗначимыхРеквизитов(ИмяРеквизита)

	Если НЕ ЗначениеЗаполнено(Объект[ИмяРеквизита]) Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураШаблона = СтруктураШаблоновЗаполненияРеквизитов["СтруктураШаблона_Номер"];
	Если СтруктураШаблона <> Неопределено Тогда
		СтруктураЗначимыхРеквизитов = СтруктураШаблона.СтруктураЗначимыхРеквизитов;
		СтруктураЗначимыхРеквизитов = СтруктураШаблоновЗаполненияРеквизитов["СтруктураШаблона_Номер"].СтруктураЗначимыхРеквизитов;
		// ++ ЕРП
		//Справочники.бит_ШаблоныЗаполненияРеквизитов.ЗапомнитьЗначенияЗначимыхРеквизитов(Объект, СтруктураЗначимыхРеквизитов);
		// -- ЕРП
	КонецЕсли;
  	
КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
// 
&НаКлиенте
Процедура ЗаполнитьНомерЗавершение(Ответ, ДопПараметры) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда
		ОчиститьСообщения();
		ЗаполнитьЗначениеРеквизитаПоШаблону("Номер");
		СгенерироватьНаименованиеДокумента(Объект);
		Модифицированность = Истина;
	КонецЕсли;	

КонецПроцедуры

&НаСервере
Функция ЗаполнитьЗначениеРеквизитаПоШаблону(ИмяРеквизита)
	
	СтруктураШаблона  = СтруктураШаблоновЗаполненияРеквизитов["СтруктураШаблона_Номер"];
	// ++ ЕРП
	//  ЗначениеРезультат = Справочники.бит_ШаблоныЗаполненияРеквизитов.СформироватьЗначениеРеквизитаПоШаблону(Объект,
	//																										ИмяРеквизита,
	//																										СтруктураШаблона);
	ЗначениеРезультат = Неопределено;
	// -- ЕРП
	Объект[ИмяРеквизита] = ЗначениеРезультат;
	Если СтруктураШаблона <> Неопределено Тогда
		ЗапомнитьЗначенияЗначимыхРеквизитов(ИмяРеквизита);
	КонецЕсли;
	
	Если ИмяРеквизита = "Номер" Тогда
		СгенерироватьНаименованиеДокумента(Объект);
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ИзмененыЗначимыеРеквизиты(Знач ИмяРеквизита, Знач ПредставлениеЗаполняемогоРеквизита = Неопределено)

	Изменены = Ложь;
	Если ЗначениеЗаполнено(Объект[ИмяРеквизита]) Тогда
		СтруктураШаблона = СтруктураШаблоновЗаполненияРеквизитов["СтруктураШаблона_Номер"];
		Если СтруктураШаблона <> Неопределено Тогда
			
			СтруктураЗначимыхРеквизитов = СтруктураШаблона.СтруктураЗначимыхРеквизитов;
			
			// ++ ЕРП
			//Изменены = Справочники.бит_ШаблоныЗаполненияРеквизитов.ПроверитьИзмененияЗначимыхРеквизитов(Объект
			//					, СтруктураЗначимыхРеквизитов
			//					, ПредставлениеЗаполняемогоРеквизита);
			Изменены = Ложь;
			// -- ЕРП
		КонецЕсли;
	КонецЕсли;
	
	Возврат Изменены;

КонецФункции

#КонецОбласти

