	Элемент.ИмяПредопределенныхДанных = "ПотребностиНоменклатуры";
	Элемент.Родитель = Справочники.бит_Запросы.ДоговорыИЗакупки;
	Элемент.Наименование = НСтр("ru = 'Потребности номенклатуры'", ОбщегоНазначения.КодОсновногоЯзыка());
	Элемент.Код = "000000029";
	Элемент.ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	бит_ПотребностиНоменклатурыАналитикаОбороты.ЦФО КАК ЦФО,
