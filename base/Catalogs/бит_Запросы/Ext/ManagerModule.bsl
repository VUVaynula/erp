	|							ИЛИ СоставПериметра.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1))
	|						И СоставПериметра.ТипКонсолидации = ЗНАЧЕНИЕ(Перечисление.бит_му_ТипыКонсолидации.Обычная)
	|						И СоставПериметра.МетодКонсолидации <> ЗНАЧЕНИЕ(Перечисление.бит_му_МетодыКонсолидации.ДолевоеУчастие))
	|				И ВЫБОР
	|					КОГДА Субконто1 ССЫЛКА Справочник.Контрагенты
	|						ТОГДА ИСТИНА
	|					КОГДА Субконто2 ССЫЛКА Справочник.Контрагенты
	|						ТОГДА ИСТИНА
