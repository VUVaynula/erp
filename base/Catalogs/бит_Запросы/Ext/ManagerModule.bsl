	Элемент.Родитель = Справочники.бит_Запросы.МСФО;
	Элемент.Наименование = НСтр("ru = 'МСФО.ОстаткиНачальные.СобствКонтр'", ОбщегоНазначения.КодОсновногоЯзыка());
	Элемент.Код = "000000005";
	Элемент.ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	бит_СобственныеКонтрагенты.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ СобствКонтрагентыПериметра
	|ИЗ
	|	РегистрСведений.бит_СобственныеКонтрагенты КАК бит_СобственныеКонтрагенты
	|ГДЕ
	|	бит_СобственныеКонтрагенты.ВидСвязи = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСобственныхКонтрагентов.Организация)
	|	И бит_СобственныеКонтрагенты.Объект В
	|			(ВЫБРАТЬ
	|				СоставПериметра.Организация
	|			ИЗ
	|				РегистрСведений.бит_му_СоставПериметровКонсолидации.СрезПоследних(&НачалоПериода, ПериметрКонсолидации = &ПериметрКонсолидации) КАК СоставПериметра
	|			ГДЕ
	|				(КОНЕЦПЕРИОДА(СоставПериметра.ДатаОкончания, ДЕНЬ) >= &НачалоПериода
	|					ИЛИ СоставПериметра.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1))
	|				И СоставПериметра.ТипКонсолидации = ЗНАЧЕНИЕ(Перечисление.бит_му_ТипыКонсолидации.Обычная)
	|				И СоставПериметра.МетодКонсолидации <> ЗНАЧЕНИЕ(Перечисление.бит_му_МетодыКонсолидации.ДолевоеУчастие))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
