Процедура ЗаполнитьВидыКомандПриПереходеНаНовуюВерсию() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Команды.Ссылка КАК Команда,
	|	ВЫБОР
	|		КОГДА Команды.Ссылка = ЗНАЧЕНИЕ(Справочник.бит_КомандыБотуТелеграм.ApprovList)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидыКомандТелеграм.Прочее)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.бит_ВидыКомандТелеграм.Запрос)
	|	КОНЕЦ КАК ВидКоманды
	|ИЗ
	|	Справочник.бит_КомандыБотуТелеграм КАК Команды
	|ГДЕ
	|	Команды.ВидКоманды = ЗНАЧЕНИЕ(Перечисление.бит_ВидыКомандТелеграм.ПустаяСсылка)";
	
	ВыборкаКоманд = Запрос.Выполнить().Выбрать();
	Пока ВыборкаКоманд.Следующий() Цикл
		Команда = ВыборкаКоманд.Команда.ПолучитьОбъект();
		Команда.ВидКоманды = ВыборкаКоманд.ВидКоманды;
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Команда);
	КонецЦикла;
	
КонецПроцедуры

Функция ДанныеИсполняемогоОтчета(КомандаБота, Пользователь = Неопределено) Экспорт
	
	Если КомандаБота.ВидКоманды <> Перечисления.бит_ВидыКомандТелеграм.Отчет Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыОтчета = КомандаБота.ПараметрыФормированияОтчета.Получить();
	Если ПараметрыОтчета = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Пользователь = Неопределено Тогда
		Пользователь = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	// АПК:278-выкл Допустимое исключение.
	РезультатОтчета = ВариантыОтчетов.СформироватьОтчет(ПараметрыОтчета, Ложь, Ложь);
	// АПК:278-вкл	
	
	Поток = Новый ПотокВПамяти;
	РезультатОтчета.ТабличныйДокумент.Записать(Поток, ТипФайлаТабличногоДокумента.PDF);
	ДвоичныеДанныеФайла            = Поток.ЗакрытьИПолучитьДвоичныеДанные();
	АдресФайлаВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла, Новый УникальныйИдентификатор);
	
	ДанныеОтчета = Новый Структура;
	ДанныеОтчета.Вставить("СсылкаНаДвоичныеДанныеФайла", АдресФайлаВоВременномХранилище);
	ДанныеОтчета.Вставить("ИмяФайла", КомандаБота.ТекстКлавиатуры + ".pdf");
	
	Возврат ДанныеОтчета;
	
КонецФункции
	
Процедура ОбновитьЗаполненныеЭлементыПриПереходеНаНовуюВерсию() Экспорт

	МетаданныеОбъекта = ПустаяСсылка().Метаданные();
	ОбновлениеИнформационнойБазы.ОбновитьПредопределенныеЭлементы(МетаданныеОбъекта);
	
КонецПроцедуры

