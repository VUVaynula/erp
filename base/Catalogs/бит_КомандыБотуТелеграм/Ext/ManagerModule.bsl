// Функция получает перечень и свойста предопредененных команд.
// 
// Возвращаемое значение:
//	ТаблицаЗначений.
//
Функция ОписаниеПредопределенныхКоманд() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Команды.Ссылка КАК Команда,
	|	ИСТИНА КАК ПользовательОбязателен,
	|	ВЫБОР
	|		КОГДА Команды.Ссылка = ЗНАЧЕНИЕ(Справочник.бит_КомандыБотуТелеграм.ApprovList)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ТолькоПолныеПрава
	|ИЗ
	|	Справочник.бит_КомандыБотуТелеграм КАК Команды
	|ГДЕ
	|	Команды.Предопределенный";
	
	ОписаниеКоманд = Запрос.Выполнить().Выгрузить();
	
	Возврат ОписаниеКоманд;	
	
КонецФункции

#КонецОбласти

