// Процедура открывает обработку рабочее место визирования с заполненным перечнем документов, 
// подлежащих визированию.
// 
// Параметры:
//  ОтключитьМеханизмЗащиты - Булево.
// 
Процедура УведомитьОбУстановкеВиз(ОтключитьМеханизмЗащиты) Экспорт
	
	КлючеваяОперация           = "ЕстьНеобработанныеВизы.бит_КонсольОперативногоВизирования";
	ИдентификаторЗамераВремени = ОценкаПроизводительностиКлиент.ЗамерВремени(КлючеваяОперация);
	
	ДлительнаяОперация         = бит_ОбщегоНазначенияВызовСервера.ПроверкаНаличияНеобработанныхВизВФоне(
									Новый УникальныйИдентификатор);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Неопределено);
	ПараметрыОжидания.ТекстСообщения = НСтр("ru='Проверка наличия необработанных виз.'");  
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ДополнительныеПараметры = Новый Структура("ИдентификаторЗамераВремени", ИдентификаторЗамераВремени);
	ОписаниеОповещения      = Новый ОписаниеОповещения("ПриЗавершенииУведомленияОбУстановкеВиз", ЭтотОбъект,
														ДополнительныеПараметры);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОписаниеОповещения, ПараметрыОжидания);
	
КонецПроцедуры

Процедура ПриЗавершенииУведомленияОбУстановкеВиз(ПараметрыРезультата, ДополнительныеПараметры) Экспорт
	
	Если ПараметрыРезультата = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОценкаПроизводительностиКлиент.ЗавершитьЗамерВремени(ДополнительныеПараметры.ИдентификаторЗамераВремени);
	
	Если ПараметрыРезультата.Статус = "Ошибка" Тогда
		// Ничего не делать или обработать ошибку.
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрШаблон(НСтр("en='Error during execution of %1';ru='Ошибка при выполнении: %1'"), 
		ПараметрыРезультата.КраткоеПредставлениеОшибки));
	Иначе
		ЕстьНеобработанныеВизы = ПолучитьИзВременногоХранилища(ПараметрыРезультата.АдресРезультата);
		Если ЕстьНеобработанныеВизы = Истина Тогда
			ОткрытьФорму("Обработка.бит_КонсольОперативногоВизирования.Форма",,, "бит_КонсольОперативногоВизирования");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

