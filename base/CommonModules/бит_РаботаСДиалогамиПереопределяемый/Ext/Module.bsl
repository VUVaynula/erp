// КорректировкаКонтрольныхЗначений.
Процедура СоздатьЭлементыУправленияКорректировкаКонтрольныхЗначений(ЭлементыФормы, ТаблицаФормы, ТаблицаОбъекта, 
	МестоРасположения = Неопределено, Префикс = "Объект") Экспорт

	Реквизиты = ХарактерныеРеквизиты();
	
	Для Каждого Реквизит Из Реквизиты Цикл
		// Группа колонок.
		ИмяГруппы = ТаблицаФормы + "Группа" + Реквизит.Значение;
		ГруппаКолонок = ЭлементыФормы.Добавить(ИмяГруппы, Тип("ГруппаФормы"), ЭлементыФормы[ТаблицаФормы]);
		ГруппаКолонок.Группировка = ГруппировкаКолонок.ВЯчейке;
		ГруппаКолонок.ОтображатьВШапке = Ложь;
		
		// Контроль.
		ИмяКолонкиКонтроля = ТаблицаФормы + "Контроль" + Реквизит.Значение;
		КолонкаКонтроль = ЭлементыФормы.Добавить(ИмяКолонкиКонтроля, Тип("ПолеФормы"), ГруппаКолонок); 
		КолонкаКонтроль.ПутьКДанным         = "Объект." + ТаблицаОбъекта + ".Контроль" + Реквизит.Значение;
		КолонкаКонтроль.Вид                 = ВидПоляФормы.ПолеФлажка; 
		КолонкаКонтроль.РежимРедактирования = РежимРедактированияКолонки.ВходПриВводе; 
		КолонкаКонтроль.ПоложениеЗаголовка  = ПоложениеЗаголовкаЭлементаФормы.Нет;
		
		// Разрез.
		ИмяКолонкиРазреза = ТаблицаФормы + Реквизит.Значение;
		КолонкаРазрез = ЭлементыФормы.Добавить(ИмяКолонкиРазреза, Тип("ПолеФормы"), ГруппаКолонок); 
		КолонкаРазрез.ПутьКДанным         = "Объект." + ТаблицаОбъекта + "." + Реквизит.Значение;
		КолонкаРазрез.Вид                 = ВидПоляФормы.ПолеВвода; 
		КолонкаРазрез.РежимРедактирования = РежимРедактированияКолонки.ВходПриВводе; 
		
		КолонкаРазрез.УстановитьДействие("ПриИзменении", "Подключаемый_АналитикаСтрокиПриходПриИзменении");
		КолонкаРазрез.УстановитьДействие("НачалоВыбора", "Подключаемый_АналитикаСтрокиПриходНачалоВыбора");
		КолонкаРазрез.УстановитьДействие("Очистка", 	 "Подключаемый_АналитикаСтрокиПриходОчистка");
		КолонкаРазрез.УстановитьДействие("АвтоПодбор",   "Подключаемый_АналитикаСтрокиПриходАвтоПодбор");
		
		ЭлементыФормы.Переместить(ГруппаКолонок, ЭлементыФормы[ТаблицаФормы], МестоРасположения);
	КонецЦикла;  

КонецПроцедуры

// Общий случай.
//
Процедура СоздатьЭлементыУправления(ЭлементыФормы, ТаблицаФормы, ТаблицаОбъекта, 
				МестоРасположения = Неопределено, Префикс = "Объект") Экспорт 
	
	Реквизиты = ХарактерныеРеквизиты();
	Для Каждого Реквизит Из Реквизиты Цикл
		Если ЗначениеЗаполнено(Префикс) Тогда
			ПутьКДанным = Префикс + "." + ТаблицаОбъекта;	
		Иначе	
			ПутьКДанным = ТаблицаОбъекта;
		КонецЕсли;
		
		ИмяКандидат = ТаблицаФормы + Реквизит.Значение;
		Кандидат = ЭлементыФормы.Добавить(ИмяКандидат, Тип("ПолеФормы"), ЭлементыФормы[ТаблицаФормы]); 
		Кандидат.Заголовок = Реквизит.Представление; 
		Кандидат.ПутьКДанным = ПутьКДанным + "." + Реквизит.Значение;
		Кандидат.Вид = ВидПоляФормы.ПолеВвода; 
		Кандидат.РежимРедактирования = РежимРедактированияКолонки.ВходПриВводе; 
		
		Если МестоРасположения <> Неопределено Тогда
			ЭлементыФормы.Переместить(Кандидат, ЭлементыФормы[ТаблицаФормы], МестоРасположения);	
		КонецЕсли; 
		
		Кандидат.УстановитьДействие("ПриИзменении", "Подключаемый_АналитикаСтрокиПриИзменении");
		Кандидат.УстановитьДействие("НачалоВыбора", "Подключаемый_АналитикаСтрокиНачалоВыбора");
		Кандидат.УстановитьДействие("Очистка", 		"Подключаемый_АналитикаСтрокиОчистка");
		Кандидат.УстановитьДействие("АвтоПодбор", 	"Подключаемый_АналитикаСтрокиАвтоПодбор");
	КонецЦикла; 
	
КонецПроцедуры

// Элементы шапки документов.
//
Процедура СоздатьЭлементыУправленияВкладкиОсновные(ЭлементыФормы, ГруппаФормы) Экспорт

	Реквизиты = ХарактерныеРеквизиты();
	СтандартныеОбработчики = СтандартныеОбработчикиПоля();
	
	Для Каждого Реквизит Из Реквизиты Цикл
		СоздатьЭлементВШапке(Реквизит.Значение, Реквизит.Значение, ЭлементыФормы, ГруппаФормы, 
			СтандартныеОбработчики);
	КонецЦикла; 
	
КонецПроцедуры

// Элемент шапки документа.
//
Процедура СоздатьЭлементВШапке(ПолеФормы, ПолеОбъекта, ЭлементыФормы, ГруппаФормы, ПодключаемыеОбработчики = Неопределено) Экспорт
	
	Если ЭлементыФормы.Найти(ПолеФормы) <> Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	Кандидат = ЭлементыФормы.Добавить(ПолеФормы, Тип("ПолеФормы"), ГруппаФормы); 
	Кандидат.ПутьКДанным = "Объект." + ПолеОбъекта;
	Кандидат.Вид = ВидПоляФормы.ПолеВвода; 
	
	Если ТипЗнч(ПодключаемыеОбработчики) = Тип("Структура") Тогда
		Для каждого Обработчик Из ПодключаемыеОбработчики Цикл
			Кандидат.УстановитьДействие(Обработчик.Ключ, Обработчик.Значение);
		КонецЦикла; 
	КонецЕсли; 
	
КонецПроцедуры

