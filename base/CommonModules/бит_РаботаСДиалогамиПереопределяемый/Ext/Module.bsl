Процедура ФормаОбъектаПриСозданииНаСервереБП(Отказ, СтандартнаяОбработка, ТекущаяФорма, ТекущийОбъект, СтрПар = Неопределено)

	// ++ ЕРП
	Совместимо = Истина;
	// -- ЕРП

КонецПроцедуры

Процедура ФормаОбъектаПриСозданииНаСервереУП(Отказ, СтандартнаяОбработка, ТекущаяФорма, ТекущийОбъект, СтрПар = Неопределено)

	// ++ ЕРП
	ПараметрыМодификации = Новый Структура(); 
	ПараметрыМодификации.Вставить("УстанавливатьОграничениеТипаПодразделение", Истина);
	ПараметрыМодификации.Вставить("УстанавливатьОграничениеТипаСценарий", Истина);
	
	Если ТипЗнч(СтрПар) = Тип("Структура") Тогда
		Для каждого КлючЗначение Из ПараметрыМодификации Цикл
			Значение = Неопределено;
			Если СтрПар.Свойство(КлючЗначение.Ключ, Значение) Тогда
				ПараметрыМодификации.Вставить(КлючЗначение.Ключ, Значение); 
			КонецЕсли; 
		КонецЦикла; 
	КонецЕсли; 
	
	// Проверим дату запрета редактирования
	бит_ДатыЗапретаРедактирования.УстановитьДоступностьФормыОбъекта(ТекущаяФорма, ТекущийОбъект);
	
	ПолноеИмяОбъекта = бит_ОбщегоНазначения.ПолучитьИмяОбъектаПоИмениФормы(ТекущаяФорма.ИмяФормы, Истина);
	
	// Вызов механизма разделения прав доступа
	Если НЕ бит_ПраваДоступаОсновной.МеханизмОтключен() Тогда
		Имена = бит_ОбщегоНазначенияКлиентСервер.РазобратьПолноеИмяОбъекта(ПолноеИмяОбъекта);
		Если ЗначениеЗаполнено(Имена.ИмяКоллекции)  Тогда
			ИмяТипаОбъект = Имена.ИмяКласса+"Объект."+Имена.ИмяОбъекта;				
			ТипОбъект = Тип(ИмяТипаОбъект);
			
			Об = ДанныеФормыВЗначение(ТекущийОбъект, ТипОбъект);
			бит_ПраваДоступа.ПередОткрытиемФормы(Отказ, СтандартнаяОбработка, Об, ТекущаяФорма);
		КонецЕсли; 
	КонецЕсли; 
	
	МетаОб = ТекущийОбъект.Ссылка.Метаданные();
	Для каждого МетаРеквизит Из МетаОб.Реквизиты Цикл
		// Ограничение для сценариев
		Если ПараметрыМодификации.УстанавливатьОграничениеТипаСценарий Тогда
			ЕстьТип		  = Ложь;
			ОписаниеТипов = МетаРеквизит.Тип;

			Если ОписаниеТипов.Типы().Количество() = 2
			   И ОписаниеТипов.СодержитТип(Тип("СправочникСсылка.СценарииТоварногоПланирования")) 
			   И ОписаниеТипов.СодержитТип(Тип("СправочникСсылка.СценарииПланирования")) Тогда
				
				ЭУ = ТекущаяФорма.Элементы.Найти(МетаРеквизит.Имя);
				Если НЕ ЭУ = Неопределено Тогда
					ЭУ.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.СценарииПланирования");
				КонецЕсли; 
			КонецЕсли; 
		КонецЕсли;
		
		// Ограничение для подразделений
		Если ПараметрыМодификации.УстанавливатьОграничениеТипаПодразделение Тогда
			ЕстьТип		  = Ложь;
			ОписаниеТипов = МетаРеквизит.Тип;
			Если бит_ОбщегоНазначения.ЭтоУТ() Тогда
				Если ОписаниеТипов.Типы().Количество() = 1 И ОписаниеТипов.СодержитТип(Тип("СправочникСсылка.СтруктураПредприятия")) Тогда
					ЕстьТип = Истина;	
				КонецЕсли;
			Иначе
				Если ОписаниеТипов.Типы().Количество() = 2 
				   И ОписаниеТипов.СодержитТип(Тип("СправочникСсылка.СтруктураПредприятия"))
				   И ОписаниеТипов.СодержитТип(Тип("СправочникСсылка.ПодразделенияОрганизаций")) Тогда
					ЕстьТип = Истина;	
				КонецЕсли;
			КонецЕсли;
			Если ЕстьТип Тогда
				ЭУ = ТекущаяФорма.Элементы.Найти(МетаРеквизит.Имя);
				Если НЕ ЭУ = Неопределено Тогда
					ЭУ.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.СтруктураПредприятия");
				КонецЕсли; 
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла; 
	
	Для каждого МетаТЧ Из МетаОб.ТабличныеЧасти Цикл
		Для каждого МетаРеквизитТЧ Из МетаТЧ.Реквизиты Цикл
			Если ПараметрыМодификации.УстанавливатьОграничениеТипаПодразделение Тогда
				ЕстьТип		  = Ложь;
				ОписаниеТипов = МетаРеквизитТЧ.Тип;
				Если бит_ОбщегоНазначения.ЭтоУТ() Тогда
					Если ОписаниеТипов.Типы().Количество() = 1 И ОписаниеТипов.СодержитТип(Тип("СправочникСсылка.СтруктураПредприятия")) Тогда
						ЕстьТип = Истина;	
					КонецЕсли;
				Иначе
					Если ОписаниеТипов.Типы().Количество() = 2 
					   И ОписаниеТипов.СодержитТип(Тип("СправочникСсылка.СтруктураПредприятия"))
					   И ОписаниеТипов.СодержитТип(Тип("СправочникСсылка.ПодразделенияОрганизаций")) Тогда
						ЕстьТип = Истина;	
					КонецЕсли;
				КонецЕсли;
				Если ЕстьТип Тогда
					ЭУ = ТекущаяФорма.Элементы.Найти(МетаТЧ.Имя + МетаРеквизитТЧ.Имя);
					Если НЕ ЭУ = Неопределено Тогда
						ЭУ.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.СтруктураПредприятия");
					КонецЕсли; 
				КонецЕсли; 
			КонецЕсли;
		КонецЦикла; 
	КонецЦикла;
	// -- ЕРП

КонецПроцедуры

#КонецОбласти 

Функция ХарактерныеРеквизиты()
	
	ХарактерныеРеквизиты = Новый СписокЗначений(); 	
	ШаблонЗначения 		 = "Аналитика_%1";
	ШаблонПредставления  = НСтр("ru='Аналитика %1';en='Analysis %1'");
	
	Для Индекс = 1 По 12 Цикл
		ХарактерныеРеквизиты.Добавить(СтрШаблон(ШаблонЗначения, Индекс),
			СтрШаблон(ШаблонПредставления, Индекс));
	КонецЦикла; 
	
	Возврат ХарактерныеРеквизиты;

КонецФункции

Функция СтандартныеОбработчикиПоля()

	СтандартныеОбработчики = Новый Структура; 
	СтандартныеОбработчики.Вставить("ПриИзменении", "Подключаемый_АналитикаПриИзменении");
	СтандартныеОбработчики.Вставить("НачалоВыбора", "Подключаемый_АналитикаНачалоВыбора");
	СтандартныеОбработчики.Вставить("Очистка", 		"Подключаемый_АналитикаОчистка");
	СтандартныеОбработчики.Вставить("АвтоПодбор", 	"Подключаемый_АналитикаАвтоПодбор");

	Возврат СтандартныеОбработчики;
	
КонецФункции

#КонецОбласти 
