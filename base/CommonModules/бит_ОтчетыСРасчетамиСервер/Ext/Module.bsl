// Функция изменяет текст шаблона временной таблицы.
//
// Параметры:
//  ШаблонТекстаВременнойТаблицы - Строка.
//  ТекстАналитик 				 - Строка.
//  ИсключаемыеПоля 			 - Массив.
//
Процедура ИзменитьШаблонТекстаВременнойТаблицы(ШаблонТекстаВременнойТаблицы, Знач ТекстАналитик, Знач ИсключаемыеПоля) Экспорт

	ШаблонТекстаВременнойТаблицы = СтрЗаменить(ШаблонТекстаВременнойТаблицы, "&ТекстАналитик,", ТекстАналитик);
	Для каждого ПолеИсключаемое Из ИсключаемыеПоля Цикл	
		ТекстЗаменяемый = СтрШаблон("ОборотыРезультат1.%1,", ПолеИсключаемое);
		ШаблонТекстаВременнойТаблицы = СтрЗаменить(ШаблонТекстаВременнойТаблицы, ТекстЗаменяемый, "NULL,");
		Если ПолеИсключаемое = "Аналитика_1" Тогда
			ТекстЗаменяемый = "ВТОборотыДляРасчетов.Аналитика_1 КАК";
			ШаблонТекстаВременнойТаблицы = СтрЗаменить(ШаблонТекстаВременнойТаблицы, ТекстЗаменяемый, "NULL КАК");
		Иначе 
			ТекстЗаменяемый = СтрШаблон("ОборотыРезультат1.%1", ПолеИсключаемое);
			ШаблонТекстаВременнойТаблицы = СтрЗаменить(ШаблонТекстаВременнойТаблицы, ТекстЗаменяемый, "NULL");
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

