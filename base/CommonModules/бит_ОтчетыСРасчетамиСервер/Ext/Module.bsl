// Функция формирует имя параметра, используемое в запросе.
//
// Параметры:
//  НомерПараметра - Число.
//
// Возвращаемое значение:
//  Строка - имя параметра запроса.
//
Функция ИмяПараметраЗапроса(НомерПараметра) Экспорт

	Возврат СтрШаблон("ПараметрРасчетов%1", НомерПараметра);

КонецФункции // ИмяПараметраЗапроса()

// Функция формирует номер параметра, используемое в запросе.
//
// Параметры:
//  ТекущийПараметр - ЭлементСпискаЗначений.
//
// Возвращаемое значение:
//  Строка - имя параметра запроса.
//
Функция НомерПараметраЗапроса(ТекущийПараметр) Экспорт

	Возврат СтрЗаменить(ТекущийПараметр.Представление, "ПараметрРасчетов", "");

КонецФункции // НомерПараметраЗапроса()

