// Процедура меняет текст запроса для СКД и подставляет фиксированные параметры.
//
// Параметры:
//  ИмяОтчета 			  - Строка.
//  КомпоновщикНастроек   - КомпоновщикНастроекКомпановкиДанных.
//  ТекстЗапросаСКД 	  - Строка.
//  ПараметрыСКД 	  	  - ПараметрыСхемыКомпоновкиДанных.
//
Процедура ИзменитьСКДДляРасчетов(ИмяОтчета, КомпоновщикНастроек, ТекстЗапросаСКД, ПараметрыСКД) Экспорт
	
	ТекстЗапроса = ТекстЗапросаСКД;
	
	ПараметрыОтчета = Новый Структура;
	Для каждого ЭлементПараметр Из КомпоновщикНастроек.ПользовательскиеНастройки.Элементы Цикл
		Если ТипЗнч(ЭлементПараметр) = Тип("ЗначениеПараметраНастроекКомпоновкиДанных") Тогда
			ПараметрыОтчета.Вставить(Строка(ЭлементПараметр.Параметр), ЭлементПараметр.Значение);
			Если ЭлементПараметр.Параметр = Новый ПараметрКомпоновкиДанных("Расчеты") Тогда
				ПараметрыОтчета.Вставить("ВсеРасчеты", НЕ ЭлементПараметр.Использование);
			КонецЕсли;
		КонецЕсли;	
	КонецЦикла;
			
	// Удаление лишних параметров.
	КоличествоПараметров = ПараметрыСКД.Количество();
	Сч = КоличествоПараметров-1;
	Пока Сч >= 0 Цикл
		ПараметрСхемы = ПараметрыСКД[Сч];	
		Если НЕ ЗначениеЗаполнено(ПараметрСхемы.ТипЗначения) Тогда
			ПараметрыСКД.Удалить(ПараметрСхемы);	
		КонецЕсли;	
		Сч = Сч - 1;
	КонецЦикла;
	
	Если НЕ ПараметрыОтчета.ПоБюджету ИЛИ НЕ ЗначениеЗаполнено(ПараметрыОтчета.Бюджет) Тогда
		Возврат;		
	КонецЕсли;
	
	// Список расчетов.
	Если ПараметрыОтчета.ВсеРасчеты Тогда
		РасчетыБюджета = ВсеРасчетыБюджета(ПараметрыОтчета.Бюджет);
	Иначе	
		РасчетыБюджета = ПараметрыОтчета.Расчеты;
		Если РасчетыБюджета = Неопределено Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;	
	
	// Изменение запроса по расчетам.
					
	ДанныеГруппировок = ДанныеГруппировок(ИмяОтчета, КомпоновщикНастроек, ПараметрыОтчета);		
	ВременныеГруппыРасчетов = Новый Соответствие;
	
	ПараметрыЗапроса = Новый Структура;
	ВсеПараметрыЗапроса    = Новый СписокЗначений;
	ПараметрыСтатьиПростые = Новый СписокЗначений;
	ПараметрыСтатьиСложные = Новый СписокЗначений;
	ПараметрыЗапроса.Вставить("ВсеПараметрыЗапроса"	  , ВсеПараметрыЗапроса);
	ПараметрыЗапроса.Вставить("ПараметрыСтатьиПростые", ПараметрыСтатьиПростые);
	ПараметрыЗапроса.Вставить("ПараметрыСтатьиСложные", ПараметрыСтатьиСложные);
	ПараметрыЗапроса.Вставить("ПоПериодам", ДанныеГруппировок.ГруппировкиПоПериодам.Количество() > 1);
	
	ДанныеРасчетов = ДанныеРасчетовОтчета(РасчетыБюджета, ПараметрыЗапроса);
		
	// Часть текста запроса - источник данных оборотов для расчетов.
	ТекстЗапроса = ИзменитьТекстОсновногоРезультата(ТекстЗапроса, ДанныеГруппировок);
	
	// Участки текста запроса по параметрам расчетов.
	ТекстВременныхГруппРасчетов = "";
	ДобавитьВЗапросВременныеТаблицыПоСтатьям(ИмяОтчета, ТекстВременныхГруппРасчетов, ПараметрыЗапроса, ДанныеГруппировок, ВременныеГруппыРасчетов);
	ДобавитьВЗапросВременныеТаблицыПоРасчетам(ИмяОтчета, ТекстВременныхГруппРасчетов, ПараметрыЗапроса, ДанныеРасчетов, ДанныеГруппировок, ВременныеГруппыРасчетов);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "//&ТекстВременныхГруппРасчетов", ТекстВременныхГруппРасчетов);
	
	// Данные расчетов в запросе.
	ДобавитьВЗапросТаблицыРасчетов(ИмяОтчета, ТекстЗапроса, ПараметрыЗапроса, ДанныеРасчетов, ДанныеГруппировок, ВременныеГруппыРасчетов);
	
	// Установка нового текста запроса.
	ТекстЗапросаСКД = ТекстЗапроса;
	
	// Установка параметров в СКД.
	УстановитьПараметрыОтчетаСРасчетами(ПараметрыСКД, ВсеПараметрыЗапроса);	

КонецПроцедуры // ИзменитьСКДДляРасчетов()

// Процедура формирует список параметров расчетов.
//
// Параметры:
//  СтатьяБюджета    - СправочникСсылка.бит_СтатьиБюджета.
//  ПараметрыРасчета - СписокЗначений.
//
Процедура ПараметрыРасчета(СтатьяБюджета, ПараметрыРасчета) Экспорт

	Для каждого ПараметрРасчета Из СтатьяБюджета.ПараметрыРасчета Цикл
		ЗначениеПараметра = ПараметрРасчета.ЗначениеПараметра;
		Если ЗначениеПараметра.ЭтоГруппа ИЛИ НЕ ЗначениеПараметра.ЭтоРасчет Тогда
			ПараметрыРасчета.Добавить(ЗначениеПараметра);
		Иначе
			ПараметрыРасчета(ЗначениеПараметра, ПараметрыРасчета);
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ВспомогательныеДанные

// Данные расчетов отчета.

// Процедура заполняет списки параметров.
//
// Параметры:
//  ТекущееЗначение     - СправочникСсылка.бит_СтатьиБюджета.
//  ИмяПараметра        - Строка.
//  ВсеПараметры        - СписокЗначений.
//  ВыборочныеПараметры - СписокЗначений.
//  ПараметрыРасчета 	- СписокЗначений.
//
Процедура ДополнитьСпискиПараметров(ТекущееЗначение, ИмяПараметра, ВсеПараметры, ВыборочныеПараметры, ПараметрыРасчета)

	НайденныйПараметр = ВсеПараметры.НайтиПоЗначению(ТекущееЗначение);
	Если НайденныйПараметр = Неопределено Тогда	
		// Список всех параметров.
		ВсеПараметры.Добавить(ТекущееЗначение, ИмяПараметра);
		// Список простых или сложных параметров.
		ВыборочныеПараметры.Добавить(ТекущееЗначение, ИмяПараметра);
		// Идентификатор параметра в пределах одного расчета.
		ПараметрыРасчета.Добавить(ТекущееЗначение, ИмяПараметра);
	Иначе
		ИмяПараметра = НайденныйПараметр.Представление;		
		// Список простых или сложных параметров.
		НайденныйВыборочныйПараметр = ВыборочныеПараметры.НайтиПоЗначению(ТекущееЗначение);
		Если НайденныйВыборочныйПараметр = Неопределено Тогда
			ВыборочныеПараметры.Добавить(ТекущееЗначение, ИмяПараметра);
		КонецЕсли;
		// Идентификатор параметра в пределах одного расчета.
		НайденныйПараметрРасчета = ПараметрыРасчета.НайтиПоЗначению(ТекущееЗначение);
		Если НайденныйПараметрРасчета = Неопределено Тогда
			ПараметрыРасчета.Добавить(ТекущееЗначение, ИмяПараметра);
		КонецЕсли;
	КонецЕсли;	

КонецПроцедуры	
		
// Процедура заполняет формулу расчета параметрами для запроса по статье.
//
// Параметры:
//  ПараметрыЗапроса - Структура:
//  					ВсеПараметрыЗапроса    - СписокЗначений.
//  					ПараметрыСтатьиПростые - СписокЗначений.
//  					ПараметрыСтатьиСложные - СписокЗначений.
//						ПоПериодам			   - Булево.
//  ФормулаРасчета 	 - Строка.
//  ПараметрыРасчета - СписокЗначений.
//  ТекущееИмя 		 - Строка.
//  ТекущееЗначение  - СправочникСсылка.бит_СтатьиБюджета.
//  ЭтоСложныйРасчет - Булево
//
Процедура ОпределитьПараметрВСписке(ПараметрыЗапроса, ФормулаРасчета, ПараметрыРасчета, ТекущееИмя, ТекущееЗначение, ЭтоСложныйРасчет)
			
	ВсеПараметрыЗапроса    = ПараметрыЗапроса.ВсеПараметрыЗапроса;
	ПараметрыСтатьиПростые = ПараметрыЗапроса.ПараметрыСтатьиПростые;
	ПараметрыСтатьиСложные = ПараметрыЗапроса.ПараметрыСтатьиСложные;
	ПоПериодам = ПараметрыЗапроса.ПоПериодам;
	
	КоличествоПараметров = ВсеПараметрыЗапроса.Количество();
	ИмяПараметра = ИмяПараметраЗапроса(КоличествоПараметров+1);
	
	Если ПоПериодам И ЭтоСложныйРасчет Тогда		
		ДополнитьСпискиПараметров(ТекущееЗначение, ИмяПараметра, ВсеПараметрыЗапроса, ПараметрыСтатьиСложные, ПараметрыРасчета);				
	Иначе
		ДополнитьСпискиПараметров(ТекущееЗначение, ИмяПараметра, ВсеПараметрыЗапроса, ПараметрыСтатьиПростые, ПараметрыРасчета);		
	КонецЕсли;
		
	ТекстКоличество = НСтр("ru='.Количество]';en='.Quantity]'");
	Если Найти(ФормулаРасчета, ТекстКоличество) <> 0 Тогда
		ИмяКоличествоСтарое = СтрЗаменить(ТекущееИмя, "]", ТекстКоличество);
		ИмяКоличествоНовое  = СтрШаблон("[%1.Количество]", ИмяПараметра);
		ФормулаРасчета = СтрЗаменить(ФормулаРасчета, ИмяКоличествоСтарое, ИмяКоличествоНовое);	
	КонецЕсли;	
	ФормулаРасчета = СтрЗаменить(ФормулаРасчета, ТекущееИмя, СтрШаблон("[%1]", ИмяПараметра));
	
	ПараметрыЗапроса.Вставить("ВсеПараметрыЗапроса"	  , ВсеПараметрыЗапроса);
	ПараметрыЗапроса.Вставить("ПараметрыСтатьиПростые", ПараметрыСтатьиПростые);
	ПараметрыЗапроса.Вставить("ПараметрыСтатьиСложные", ПараметрыСтатьиСложные);
		
КонецПроцедуры

// Процедура заполняет формулу расчета параметрами для запроса.
//
// Параметры:
//  ПараметрыЗапроса - Структура:
//  					ВсеПараметрыЗапроса    - СписокЗначений.
//  					ПараметрыСтатьиПростые - СписокЗначений.
//  					ПараметрыСтатьиСложные - СписокЗначений.
//						ПоПериодам			   - Булево.
//  ФормулаРасчета 	   - Строка.
//  ПараметрыРасчета   - СписокЗначений.
//  ВыборкаПараметров  - ВыборкаРезультатаЗапроса.
//  ЕстьНедоступныеСсылки - Булево
//
Процедура ЗаполнитьПараметрыПоТекущему(ПараметрыЗапроса, ФормулаРасчета, ПараметрыРасчета, ВыборкаПараметров, 
									   ЕстьНедоступныеСсылки, ЭтоСложныйРасчет)
	
	ТекущееИмя 	  	= ВыборкаПараметров.ИмяПараметра;
	ТекущееЗначение = ВыборкаПараметров.ЗначениеПараметра;
	
	Если НЕ ЗначениеЗаполнено(ТекущееЗначение) Тогда
		ТекстСообщения = НСтр("ru='Ошибка в параметрах расчетов. Пустое значение.'; 
							  |en='Error in calculation parameters. Empty value.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);	
		Возврат;
	КонецЕсли;
	
	Попытка
		НайденныйОбъект = ТекущееЗначение.ПолучитьОбъект();
	Исключение
		ЕстьНедоступныеСсылки = Истина;
		Возврат;
	КонецПопытки;
	
	Если ВыборкаПараметров.ЭтоРасчет Тогда
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Расчет", ТекущееЗначение);
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДанныеРасчетов.Ссылка КАК Ссылка,
		|	ДанныеРасчетов.ФормулаРасчета КАК ФормулаРасчета,
		|	ДанныеРасчетов.Кодификатор КАК Кодификатор,
		|	РасчетыПараметрыРасчета.ИмяПараметра КАК ИмяПараметра,
		|	РасчетыПараметрыРасчета.ЗначениеПараметра КАК ЗначениеПараметра,
		|	ЕстьNULL(СтатьиБюджета.ЭтоРасчет, ЛОЖЬ) КАК ЭтоРасчет,
		|	ЕстьNULL(СтатьиБюджета.ЭтоГруппа, ЛОЖЬ) КАК ЭтоГруппа
		|ИЗ
		|	Справочник.бит_СтатьиБюджета КАК ДанныеРасчетов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_СтатьиБюджета.ПараметрыРасчета КАК РасчетыПараметрыРасчета
		|		ПО (ДанныеРасчетов.Ссылка = РасчетыПараметрыРасчета.Ссылка)
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_СтатьиБюджета КАК СтатьиБюджета
		|			ПО (РасчетыПараметрыРасчета.ЗначениеПараметра = СтатьиБюджета.Ссылка)
		|ГДЕ
		|	ДанныеРасчетов.Ссылка = &Расчет
		|ИТОГИ ПО
		|	Ссылка";
		Результат = Запрос.Выполнить();	
		ВыборкаРасчетов = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
		Пока ВыборкаРасчетов.Следующий() Цикл
			ВыборкаПараметровНиз = ВыборкаРасчетов.Выбрать();
			ТекущаяФормулаРасчета = ВыборкаРасчетов.ФормулаРасчета;
			Пока ВыборкаПараметровНиз.Следующий() Цикл
				ЗаполнитьПараметрыПоТекущему(ПараметрыЗапроса, ТекущаяФормулаРасчета, ПараметрыРасчета, ВыборкаПараметровНиз, 
					ЕстьНедоступныеСсылки, ЭтоСложныйРасчет);	
			КонецЦикла;
			ФормулаРасчета = СтрЗаменить(ФормулаРасчета, ТекущееИмя, "(" + ТекущаяФормулаРасчета+ ")");
		КонецЦикла;
		
	Иначе
		
		ОпределитьПараметрВСписке(ПараметрыЗапроса, ФормулаРасчета, ПараметрыРасчета, ТекущееИмя, ТекущееЗначение, 
			ЭтоСложныйРасчет);		
				
	КонецЕсли;

КонецПроцедуры // ЗаполнитьПараметрыПоТекущему()

// Функция заполняет формулу расчета параметрами для запроса.
//
// Параметры:
//  ВыбранныеРасчеты - Массив.
//  ПараметрыЗапроса - Структура:
//  					ВсеПараметрыЗапроса    - СписокЗначений.
//  					ПараметрыСтатьиПростые - СписокЗначений.
//  					ПараметрыСтатьиСложные - СписокЗначений.
//						ПоПериодам			   - Булево.
//
// Возвращаемое значение:
//  ТаблицаЗначений - таблица данных расчетов.
//
Функция ДанныеРасчетовОтчета(ВыбранныеРасчеты, ПараметрыЗапроса)
	
	ДанныеРасчетов = Новый ТаблицаЗначений;
	ДанныеРасчетов.Колонки.Добавить("Расчет");
	ДанныеРасчетов.Колонки.Добавить("Кодификатор");
	ДанныеРасчетов.Колонки.Добавить("ФормулаРасчета");
	ДанныеРасчетов.Колонки.Добавить("ПараметрыРасчета");
	ДанныеРасчетов.Колонки.Добавить("ВыводитьКоличество");
	ДанныеРасчетов.Колонки.Добавить("СложныйРасчет");
		
	бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(ВыбранныеРасчеты);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВыбранныеРасчеты", ВыбранныеРасчеты);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДанныеРасчетов.Ссылка КАК Ссылка,
	|	ДанныеРасчетов.ФормулаРасчета КАК ФормулаРасчета,
	|	ДанныеРасчетов.Кодификатор КАК Кодификатор,
	|	ДанныеРасчетов.ВыводитьКоличество КАК ВыводитьКоличество,
	|	РасчетыПараметрыРасчета.ИмяПараметра КАК ИмяПараметра,
	|	РасчетыПараметрыРасчета.ЗначениеПараметра КАК ЗначениеПараметра,
	|	ЕстьNULL(СтатьиБюджета.ЭтоРасчет, ЛОЖЬ) КАК ЭтоРасчет,
	|	ЕстьNULL(СтатьиБюджета.ЭтоГруппа, ЛОЖЬ) КАК ЭтоГруппа
	|ИЗ
	|	Справочник.бит_СтатьиБюджета КАК ДанныеРасчетов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_СтатьиБюджета.ПараметрыРасчета КАК РасчетыПараметрыРасчета
	|		ПО (ДанныеРасчетов.Ссылка = РасчетыПараметрыРасчета.Ссылка)
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_СтатьиБюджета КАК СтатьиБюджета
	|			ПО (РасчетыПараметрыРасчета.ЗначениеПараметра = СтатьиБюджета.Ссылка)
	|ГДЕ
	|	ДанныеРасчетов.Ссылка В(&ВыбранныеРасчеты)
	|	
	|ИТОГИ ПО
	|	Ссылка";
	Результат = Запрос.Выполнить();	
	ВыборкаРасчетов = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	НомерРасчета = 1;
	Пока ВыборкаРасчетов.Следующий() Цикл
		
		ФормулаРасчета = ВыборкаРасчетов.ФормулаРасчета;
		ЕстьДеление   = Найти(ФормулаРасчета, "/") <> 0;
		ЕстьУмножение = Найти(ФормулаРасчета, "*") <> 0;
		ЭтоСложныйРасчет = ЕстьДеление ИЛИ ЕстьУмножение;
		
		ПараметрыРасчета = Новый СписокЗначений;
			
		ЕстьНедоступныеСсылки = Ложь;
			
		НомерСтатьи = 1;
		
		ВыборкаПараметров = ВыборкаРасчетов.Выбрать();
		Пока ВыборкаПараметров.Следующий() Цикл
			ЗаполнитьПараметрыПоТекущему(ПараметрыЗапроса, ФормулаРасчета, ПараметрыРасчета, ВыборкаПараметров, 
				ЕстьНедоступныеСсылки, ЭтоСложныйРасчет);
		КонецЦикла;
		
		Если ЕстьНедоступныеСсылки Тогда
			
			ТекстСообщения = НСтр("ru='В расчете ""%1"" есть недоступные статьи бюджета'; 
								  |en='There are unavailable budget items in the calculation ""%1""'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ВыборкаРасчетов.Ссылка);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
				
		Иначе 
			
			ДанныеРасчета = ДанныеРасчетов.Добавить();
			ДанныеРасчета.Расчет  		   = ВыборкаРасчетов.Ссылка;
			ДанныеРасчета.Кодификатор 	   = ВыборкаРасчетов.Кодификатор;
			ДанныеРасчета.ФормулаРасчета   = ФормулаРасчета;
			ДанныеРасчета.ПараметрыРасчета = ПараметрыРасчета;
			
			ДанныеРасчета.ВыводитьКоличество = ВыборкаРасчетов.ВыводитьКоличество;
			ДанныеРасчета.СложныйРасчет = ЭтоСложныйРасчет;
						
			НомерРасчета = НомерРасчета + 1;
				
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ДанныеРасчетов;
	
КонецФункции // ДанныеРасчетовОтчета()

// Данные группировок.

Процедура УдалитьПолеГруппировкиИзИсключаемыхПолей(ИсключаемыеПоля, ИмяГруппировки)

	НайденныйИД = ИсключаемыеПоля.Найти(ИмяГруппировки);
	Если НайденныйИД <> Неопределено Тогда
		ИсключаемыеПоля.Удалить(НайденныйИД);						
	КонецЕсли;	

КонецПроцедуры

Процедура ОбойтиЭлементСтруктурыКД(ЭлементСтруктураНКД, ПараметрыОтчета, ПоляГруппировок, 
		ГруппировкиПоПериодам, ИсключаемыеПоля, СчетчикУровней, УровниГруппПоПериодам)

	Если НЕ ЭлементСтруктураНКД.Использование Тогда
		Возврат;
	КонецЕсли;
	
	ПериодичностьОтчета = ПараметрыОтчета.Периодичность;
	УправлениеДетализациейРасчетов = ПараметрыОтчета.Свойство("РасчетыБезДетализации");
	Если УправлениеДетализациейРасчетов Тогда
		РасчетыБезДетализации = ПараметрыОтчета.РасчетыБезДетализации;
	Иначе
		РасчетыБезДетализации = Ложь;
	КонецЕсли;
	
	ПоляГруппировкиСтроки = ЭлементСтруктураНКД.ПоляГруппировки;
	Для Каждого ЭлементыГруппировки Из ПоляГруппировкиСтроки.Элементы Цикл
		// Поля группировки.
		ИмяПоля = Строка(ЭлементыГруппировки.Поле);
		Если ИмяПоля = "ДинамическийПериод" Тогда
			Если ПериодичностьОтчета = Перечисления.бит_ПериодичностьПланирования.День Тогда
				ИмяГруппировкиПоПериодичности = "ПериодДень";
			ИначеЕсли ПериодичностьОтчета = Перечисления.бит_ПериодичностьПланирования.Неделя Тогда
				ИмяГруппировкиПоПериодичности = "ПериодНеделя";
			ИначеЕсли ПериодичностьОтчета = Перечисления.бит_ПериодичностьПланирования.Декада Тогда	
				ИмяГруппировкиПоПериодичности = "ПериодДекада";
			ИначеЕсли ПериодичностьОтчета = Перечисления.бит_ПериодичностьПланирования.Месяц Тогда
				ИмяГруппировкиПоПериодичности = "ПериодМесяц";
			ИначеЕсли ПериодичностьОтчета = Перечисления.бит_ПериодичностьПланирования.Квартал Тогда
				ИмяГруппировкиПоПериодичности = "ПериодКвартал";
			ИначеЕсли ПериодичностьОтчета = Перечисления.бит_ПериодичностьПланирования.Полугодие Тогда
				ИмяГруппировкиПоПериодичности = "ПериодПолугодие";
			ИначеЕсли ПериодичностьОтчета = Перечисления.бит_ПериодичностьПланирования.Год Тогда
				ИмяГруппировкиПоПериодичности = "ПериодГод";
			КонецЕсли;
			ПоляГруппировок.Добавить(ИмяГруппировкиПоПериодичности);
			ГруппировкиПоПериодам.Добавить(ИмяГруппировкиПоПериодичности);
			УровниГруппПоПериодам.Добавить(СчетчикУровней);
			УдалитьПолеГруппировкиИзИсключаемыхПолей(ИсключаемыеПоля, ИмяГруппировкиПоПериодичности);		
		ИначеЕсли Найти(ИмяПоля, ".") > 0 Или Найти(ИмяПоля, "Кодификатор") > 0 Тогда
			Продолжить;
		Иначе
			Если Найти(ИмяПоля, "Период") > 0 Тогда
				ГруппировкиПоПериодам.Добавить(ИмяПоля);
				УровниГруппПоПериодам.Добавить(СчетчикУровней);
			ИначеЕсли УправлениеДетализациейРасчетов Тогда 
				Если Найти(ИмяПоля, "Статья") = 0 Тогда
					Если РасчетыБезДетализации Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			ПоляГруппировок.Добавить(ИмяПоля);
			УдалитьПолеГруппировкиИзИсключаемыхПолей(ИсключаемыеПоля, ИмяПоля);	
		КонецЕсли;
		
	КонецЦикла;
	
	// Следущий цикл.
	ПолучитьПоляГруппировкиИзКоллекцииСтруктурыКД(ЭлементСтруктураНКД, ПараметрыОтчета, 
		ПоляГруппировок, ГруппировкиПоПериодам, ИсключаемыеПоля, СчетчикУровней, УровниГруппПоПериодам);

КонецПроцедуры

Процедура ПолучитьПоляГруппировкиИзКоллекцииСтруктурыКД(НастройкиКД, ПараметрыОтчета, 
			ПоляГруппировок, ГруппировкиПоПериодам, ИсключаемыеПоля, СчетчикУровней, УровниГруппПоПериодам)
		
	КоллекцияЭлементовСтруктурыНКД = НастройкиКД.Структура;
	Для Каждого ЭлементСтруктураНКД Из КоллекцияЭлементовСтруктурыНКД Цикл
		
		Если ТипЗнч(ЭлементСтруктураНКД) = Тип("ТаблицаКомпоновкиДанных") Тогда				
			
			СчетчикУровней = СчетчикУровней + 1;
			КоллекцияЭлементовСтруктураТаблицыКД = ЭлементСтруктураНКД.Строки;
			Для Каждого ЭлементСтруктурыТаблицыКД Из КоллекцияЭлементовСтруктураТаблицыКД Цикл				
				ОбойтиЭлементСтруктурыКД(ЭлементСтруктурыТаблицыКД, ПараметрыОтчета, 
					ПоляГруппировок, ГруппировкиПоПериодам, ИсключаемыеПоля, СчетчикУровней, УровниГруппПоПериодам);				
			КонецЦикла;
			
			СчетчикУровней = СчетчикУровней + 1;
			КоллекцияЭлементовСтруктураТаблицыКД = ЭлементСтруктураНКД.Колонки;
			Для Каждого ЭлементСтруктурыТаблицыКД Из КоллекцияЭлементовСтруктураТаблицыКД Цикл				
				ОбойтиЭлементСтруктурыКД(ЭлементСтруктурыТаблицыКД, ПараметрыОтчета, 
					ПоляГруппировок, ГруппировкиПоПериодам, ИсключаемыеПоля, СчетчикУровней, УровниГруппПоПериодам);				
			КонецЦикла;
			
		ИначеЕсли ТипЗнч(ЭлементСтруктураНКД) = Тип("ГруппировкаТаблицыКомпоновкиДанных") Тогда
			
			СчетчикУровней = СчетчикУровней + 1;
			ОбойтиЭлементСтруктурыКД(ЭлементСтруктураНКД, ПараметрыОтчета, 
				ПоляГруппировок, ГруппировкиПоПериодам, ИсключаемыеПоля, СчетчикУровней, УровниГруппПоПериодам);
				
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры // ПолучитьПоляГруппировкиИзКоллекцииСтруктурыКД

// Функция формирует структуру вспомогательных для формирования запроса данных.
//
// Параметры:
//  ИмяОтчета 			  - Строка.
//  КомпоновщикНастроек   - КомпоновщикНастроекКомпановкиДанных.
//  ПараметрыОтчета 	  - Структура.
//
// Возвращаемое значение:
//  Структура: ИсключаемыеПоля - Массив,
//			   ПоляГруппировок - Массив.
//
Функция ДанныеГруппировок(ИмяОтчета, КомпоновщикНастроек, ПараметрыОтчета)

	ДанныеГруппировок = Новый Структура;
	
	ПараметрыГруппировок = Отчеты[ИмяОтчета].ПараметрыГруппировок();
	
	// Исключаемые поля.
	ИсключаемыеПоля = ПараметрыГруппировок.ИсключаемыеПоля;
	// Поля группировок.
	ПоляГруппировок = ПараметрыГруппировок.ПоляГруппировок;
	
	ГруппировкиПоПериодам = Новый Массив;
	СчетчикУровней = 0;
	УровниГруппПоПериодам = Новый Массив;
				
	// Поле группировки по настройкам структуры.
	ПолучитьПоляГруппировкиИзКоллекцииСтруктурыКД(КомпоновщикНастроек.Настройки, ПараметрыОтчета, 
											      ПоляГруппировок, ГруппировкиПоПериодам, ИсключаемыеПоля,
												  СчетчикУровней, УровниГруппПоПериодам);
		
	бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(ПоляГруппировок, Истина);
	
	бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(УровниГруппПоПериодам, Истина);
	Если УровниГруппПоПериодам.Количество() = 1 Тогда
		бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(ГруппировкиПоПериодам, Истина);	
		Если ГруппировкиПоПериодам.Количество() = 1 Тогда
			// Если всего одна группировка по периодам, то не нужен пересчет периодов отдельно.
			ГруппировкиПоПериодам = Новый Массив;
		КонецЕсли;
	Иначе
		// Если периоды на разных уровнях, то не нужен пересчет периодов отдельно.
		ГруппировкиПоПериодам = Новый Массив;
	КонецЕсли;
	
	ДанныеГруппировок.Вставить("ИсключаемыеПоля", ИсключаемыеПоля);
	ДанныеГруппировок.Вставить("ПоляГруппировок", ПоляГруппировок);
	ДанныеГруппировок.Вставить("ГруппировкиПоПериодам", ГруппировкиПоПериодам);
	
	Возврат ДанныеГруппировок;

КонецФункции // ДанныеГруппировок()

// Расчеты бюджета.

Функция ВсеРасчетыБюджета(Бюджет)

	// Все расчеты бюджета.
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	бит_СтатьиБюджета.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.бит_СтатьиБюджета КАК бит_СтатьиБюджета
	|ГДЕ
	|	бит_СтатьиБюджета.Владелец = &Владелец
	|	И бит_СтатьиБюджета.ЭтоРасчет = &ЭтоРасчет
	|	И НЕ бит_СтатьиБюджета.ПометкаУдаления
	|";
	Запрос.УстановитьПараметр("Владелец", Бюджет);
	Запрос.УстановитьПараметр("ЭтоРасчет", Истина);
	РасчетыБюджета = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Возврат РасчетыБюджета;
	
КонецФункции // ВсеРасчетыБюджета()

#КонецОбласти 

#Область ИзменениеТекстаЗапросаПоПараметрам

// Процедура добавляет в запрос временные таблицы по статьям - параметрам расчетов.
//
// Параметры:
//  ТекстВременныхГруппРасчетов	- Строка.
//  ПараметрыЗапроса 			- Структура:
//  								ВсеПараметрыЗапроса    - СписокЗначений.
//  								ПараметрыСтатьиПростые - СписокЗначений.
//  								ПараметрыСтатьиСложные - СписокЗначений.
//									ПоПериодам			   - Булево.
//  ДанныеГруппировок 			- Структура.
//  ВременныеГруппыРасчетов 	- Соответствие.
//
Процедура ДобавитьВЗапросВременныеТаблицыПоСтатьям(ИмяОтчета, ТекстВременныхГруппРасчетов, ПараметрыЗапроса, ДанныеГруппировок, ВременныеГруппыРасчетов)

	ВсеПараметрыЗапроса    = ПараметрыЗапроса.ВсеПараметрыЗапроса;
	ПараметрыСтатьиПростые = ПараметрыЗапроса.ПараметрыСтатьиПростые;
	ПараметрыСтатьиСложные = ПараметрыЗапроса.ПараметрыСтатьиСложные;
	ПоПериодам = ПараметрыЗапроса.ПоПериодам;
	
	ИсключаемыеПоля = ДанныеГруппировок.ИсключаемыеПоля;
	
	ШаблонТекстаВременнойТаблицы = Отчеты[ИмяОтчета].ШаблонТекстаВременнойТаблицы(ИсключаемыеПоля);
	
	НомерВременнойТаблицы = 1;
	
	Для каждого СтатьяПараметр Из ВсеПараметрыЗапроса Цикл
		
		ИмяСтатьиПараметра = СтатьяПараметр.Представление;
		СтатьяБюджета 	   = СтатьяПараметр.Значение;
		
		ИмяВременнойТаблицы  = СтрШаблон("ВТ%1", ИмяСтатьиПараметра);		
		ТекстВременнойГруппы = ШаблонТекстаВременнойТаблицы;
		
		ЭтоГруппа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтатьяБюджета, "ЭтоГруппа");		
		Если НЕ ЭтоГруппа Тогда
		 ТекстВременнойГруппы = СтрЗаменить(ТекстВременнойГруппы,
		 	"ОборотыРезультат1.СтатьяБюджета В ИЕРАРХИИ (&&СтатьяПараметр)", 
			"ОборотыРезультат1.СтатьяБюджета = &&СтатьяПараметр");	
		КонецЕсли;
	
		ТекстВременнойГруппы = СтрЗаменить(ТекстВременнойГруппы, "&ИмяВременнойТаблицы", ИмяВременнойТаблицы);
		ТекстВременнойГруппы = СтрЗаменить(ТекстВременнойГруппы, "&СтатьяПараметр", ИмяСтатьиПараметра);
				
		ВременныеГруппыРасчетов.Вставить(СтатьяБюджета, ИмяВременнойТаблицы);
		
		Если ПоПериодам Тогда
			// Простые.
			НайденныйПараметр = ПараметрыСтатьиПростые.НайтиПоЗначению(СтатьяБюджета);
			Если НайденныйПараметр <> Неопределено Тогда
				ТекстВременныхГруппРасчетов = ТекстВременныхГруппРасчетов + ТекстВременнойГруппы;
			КонецЕсли;
			// По периодам.
			НайденныйПараметр = ПараметрыСтатьиСложные.НайтиПоЗначению(СтатьяБюджета);
			Если НайденныйПараметр <> Неопределено Тогда
				// Изменение текста по периодам.
				Для каждого ГруппировкаПоПериоду Из ДанныеГруппировок.ГруппировкиПоПериодам Цикл				
					ТекстГруппыПериода = ТекстВременнойГруппы;
					НовоеИмяВременнойТаблицы  = СтрШаблон("%1%2", ИмяВременнойТаблицы, ГруппировкаПоПериоду);
					ТекстГруппыПериода = СтрЗаменить(ТекстГруппыПериода, ИмяВременнойТаблицы, НовоеИмяВременнойТаблицы);					
					Для каждого УдалениеПоПериоду Из ДанныеГруппировок.ГруппировкиПоПериодам Цикл
						Если ГруппировкаПоПериоду <> УдалениеПоПериоду Тогда
							ИмяЗаменяемойГруппы = СтрШаблон("ОборотыРезультат1.%1", УдалениеПоПериоду);
							ТекстГруппыПериода = СтрЗаменить(ТекстГруппыПериода, ИмяЗаменяемойГруппы, "NULL");				
						КонецЕсли;	
					КонецЦикла;					
					ТекстВременныхГруппРасчетов = ТекстВременныхГруппРасчетов + ТекстГруппыПериода;					
				КонецЦикла;
			КонецЕсли;
		Иначе	
			// Простые.
			ТекстВременныхГруппРасчетов = ТекстВременныхГруппРасчетов + ТекстВременнойГруппы;
		КонецЕсли;
		
		НомерВременнойТаблицы = НомерВременнойТаблицы + 1;
		
	КонецЦикла;
	
КонецПроцедуры // ДобавитьВЗапросВременныеТаблицыПоСтатьям()

#КонецОбласти 

#Область ИзменениеТекстаЗапросаПоРасчетам

// Функция формирует текст условия соединения.
//
// Параметры:
//  ПоляГруппировок - Массив.
//
// Возвращаемое значение:
//  Строка.
//
Функция ТекстУсловийСоединения(ПоляГруппировок)

	ТекстУсловийСоединения = "";
	Для каждого ПолеГруппировки Из ПоляГруппировок Цикл	
		Если ПолеГруппировки = "Статья" Тогда
			Продолжить;		
		КонецЕсли;
		ТекстУсловийСоединения = ТекстУсловийСоединения + "	И ОборотыРезультат1.%1 = ОборотыРезультатСледующий.%1";		
		ТекстУсловийСоединения = СтрШаблон(ТекстУсловийСоединения, ПолеГруппировки);	
	КонецЦикла;
	
	Возврат ТекстУсловийСоединения;

КонецФункции // ТекстУсловийСоединения()

// Процедура меняет часть текста запроса по статье бюджета.
//
// Параметры:
//  СтатьяБюджета 				 - СправочникСсылка.бит_СтатьяБюджета.
//  ШаблонТекстаВременнойТаблицы - Строка.
//  ВременныеГруппыРасчетов 	 - Соответствие.
//  ТекстВременныхГруппРасчетов  - Строка.
//  ТекстРасчета 				 - Строка.
//  ТекстУсловия 				 - Строка.
//  ТекстСоединения 			 - Строка.
//  НомерРасчета 				 - Число.
//  НомерПараметра 				 - Число.
//
Процедура ИзмененитьЗапросПоСтатьеБюджета(ТекущийПараметр, ВременныеГруппыРасчетов, 
			ТекстРасчета, ТекстУсловия, ТекстСоединения, НомерПараметра, ГруппировкаПоПериоду = "")

	СтатьяБюджета		= ТекущийПараметр.Значение;
	ИмяСтатьиПараметра  = ТекущийПараметр.Представление;
	ИмяВременнойТаблицы = СтрШаблон("%1%2", ВременныеГруппыРасчетов.Получить(СтатьяБюджета), ГруппировкаПоПериоду); // ВТПараметрРасчетов1
		
	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтатьяБюджета, "ЭтоГруппа") Тогда
		Если НомерПараметра = 1 Тогда
			ТекстУсловия1 = "(ОборотыРезультат1.СтатьяБюджета = &ИмяСтатьиПараметра
						   | ИЛИ &ТекстУсловия2)";
			ТекстУсловия1 = СтрЗаменить(ТекстУсловия1, "ИмяСтатьиПараметра", ИмяСтатьиПараметра);
			ТекстРасчета = СтрЗаменить(ТекстРасчета, "&ТекстУсловия", ТекстУсловия1);
		Иначе
			ТекстУсловия = ТекстУсловия + ?(ПустаяСтрока(ТекстУсловия), "", "
			| ИЛИ ") + "ОборотыРезультат&НомерПараметра.СтатьяБюджета = &ИмяСтатьиПараметра";
			ТекстУсловия = СтрЗаменить(ТекстУсловия, "&НомерПараметра", НомерПараметра);
			ТекстУсловия = СтрЗаменить(ТекстУсловия, "ИмяСтатьиПараметра", ИмяСтатьиПараметра);			
		КонецЕсли;
	Иначе
	
		Если НомерПараметра = 1 Тогда
			ТекстУсловия1 = "(ОборотыРезультат1.СтатьяБюджета = &ИмяСтатьиПараметра
			|ИЛИ &ТекстУсловия2)";
			ТекстУсловия1 = СтрЗаменить(ТекстУсловия1, "ИмяСтатьиПараметра", ИмяСтатьиПараметра);
			ТекстРасчета = СтрЗаменить(ТекстРасчета, "&ТекстУсловия", ТекстУсловия1);
		Иначе
			ТекстУсловия = ТекстУсловия + ?(ПустаяСтрока(ТекстУсловия), "", "
			| ИЛИ ") + "ОборотыРезультат&НомерПараметра.СтатьяБюджета = &ИмяСтатьиПараметра";
			ТекстУсловия = СтрЗаменить(ТекстУсловия, "&НомерПараметра", НомерПараметра);
			ТекстУсловия = СтрЗаменить(ТекстУсловия, "ИмяСтатьиПараметра", ИмяСтатьиПараметра);
		КонецЕсли;		
	КонецЕсли;	
	
	Если НомерПараметра = 1 Тогда
		ТекстРасчета = СтрЗаменить(ТекстРасчета, "ОборотыРезультат КАК", СтрШаблон("%1 КАК", ИмяВременнойТаблицы));
	Иначе
		ТекстСоединения = СтрЗаменить(ТекстСоединения, "ОборотыРезультат КАК", СтрШаблон("%1 КАК", ИмяВременнойТаблицы));
	КонецЕсли;	
		
КонецПроцедуры // ИзмененитьЗапросПоСтатьеБюджета()

// Процедура добавляет в запрос таблицу расчетов.
//
// Параметры:
//  ТекстРасчета        	- Строка.
//  НомерРасчета 			- Число.
//  ДанныеРасчета  			- Структура.
//  ВременныеГруппыРасчетов - Соответствие.
//  ТекстУсловийСоединения	- Строка.
//  ПоляГруппировок 		- Структура.
//  ГруппировкаПоПериоду	- Строка.
//
Процедура СформироватьЗапросПоРасчету(ТекстРасчета, НомерРасчета, ДанныеРасчета, ВременныеГруппыРасчетов, 
									  ТекстУсловийСоединения, ПоляГруппировок, ГруппировкаПоПериоду = "")

	ФормулаРасчета 	 = ДанныеРасчета.ФормулаРасчета;
	ПараметрыРасчета = ДанныеРасчета.ПараметрыРасчета;

	КоличествоПараметров = ПараметрыРасчета.Количество();	
		
	ТекстУсловия = "";
	ТекстСоединения = "";
		
	СчетчикПараметра = 1;
	Если КоличествоПараметров = 1 Тогда
		
		ТекущийПараметр = ПараметрыРасчета[0];
		ИзмененитьЗапросПоСтатьеБюджета(ТекущийПараметр, ВременныеГруппыРасчетов, 
			ТекстРасчета, ТекстУсловия, ТекстСоединения, СчетчикПараметра, ГруппировкаПоПериоду);
						
	ИначеЕсли КоличествоПараметров > 1 Тогда			
		
		Для каждого ТекущийПараметр Из ПараметрыРасчета Цикл
			
			Если СчетчикПараметра = 1 Тогда
				ИзмененитьЗапросПоСтатьеБюджета(ТекущийПараметр, ВременныеГруппыРасчетов, 
					ТекстРасчета, ТекстУсловия, ТекстСоединения, СчетчикПараметра, ГруппировкаПоПериоду);
				СчетчикПараметра = 2;
				Продолжить;
			КонецЕсли;
			
			НомерПараметра = НомерПараметраЗапроса(ТекущийПараметр);
														
			ТекстСоединения = ТекстСоединения + "
			|	ПОЛНОЕ СОЕДИНЕНИЕ
			|		ОборотыРезультат КАК ОборотыРезультатСледующий
			|		ПО ОборотыРезультатСледующий.СтатьяБюджета = &ПараметрСтатья
			|		&ТекстУсловийСоединения
			|";
			
			ИзмененитьЗапросПоСтатьеБюджета(ТекущийПараметр, ВременныеГруппыРасчетов, 
				ТекстРасчета, ТекстУсловия, ТекстСоединения, СчетчикПараметра, ГруппировкаПоПериоду);
							
			ТекстСоединения = СтрЗаменить(ТекстСоединения, "&ТекстУсловийСоединения", ТекстУсловийСоединения);
			ТекстСоединения = СтрЗаменить(ТекстСоединения, "ОборотыРезультатСледующий", СтрШаблон("ОборотыРезультат%1", СчетчикПараметра));
			ТекстСоединения = СтрЗаменить(ТекстСоединения, "ПараметрСтатья", ИмяПараметраЗапроса(НомерПараметра));
			СчетчикПараметра = СчетчикПараметра + 1;
			
		КонецЦикла;
		
	КонецЕсли;
		
	ТекстРасчета = СтрЗаменить(ТекстРасчета, "&ТекстСоединения", ТекстСоединения);
	Если ПустаяСтрока(ТекстУсловия) Тогда
		ТекстРасчета = СтрЗаменить(ТекстРасчета, "ИЛИ &ТекстУсловия2", ТекстУсловия);
	Иначе	
		ТекстРасчета = СтрЗаменить(ТекстРасчета, "&ТекстУсловия2", ТекстУсловия);
	КонецЕсли;		
	ТекстРасчета = СтрЗаменить(ТекстРасчета, "&НомерРасчета", НомерРасчета);
	
	Если СчетчикПараметра > 1 Тогда
		ШаблонВыбора = "
		|	ВЫБОР КОГДА НЕ ОборотыРезультат1.%1 ЕСТЬ NULL ТОГДА ОборотыРезультат1.%1
		|		  &ВыборСледующий
		|	ИНАЧЕ NULL КОНЕЦ КАК %1,";
		ШаблонВыбораГруппировок = "
		|	ВЫБОР КОГДА НЕ ОборотыРезультат1.%1 ЕСТЬ NULL ТОГДА ОборотыРезультат1.%1
		|		  &ВыборСледующий
		|	ИНАЧЕ NULL КОНЕЦ,";
		ШаблонСледущего = "&ВыборСледующий";
		Для Сч = 2 По СчетчикПараметра -1 Цикл
			ШаблонСледущего = СтрЗаменить(ШаблонСледущего, "&ВыборСледующий", 
				"		КОГДА НЕ ОборотыРезультат"+Сч+".%1 ЕСТЬ NULL ТОГДА ОборотыРезультат"+Сч+".%1
				|		&ВыборСледующий");			
		КонецЦикла;
		ШаблонСледущего = СтрЗаменить(ШаблонСледущего, "&ВыборСледующий", "");
		ШаблонВыбора = СтрЗаменить(ШаблонВыбора, "&ВыборСледующий", ШаблонСледущего);
		ШаблонВыбораГруппировок = СтрЗаменить(ШаблонВыбораГруппировок, "&ВыборСледующий", ШаблонСледущего);
		Для каждого ИмяГруппы Из ПоляГруппировок Цикл
			// Поля.
			ЗаменяемыйТекстВыбора = СтрШаблон("ОборотыРезультат1.%1 КАК %1,", ИмяГруппы);
			ТекстВыбора = СтрШаблон(ШаблонВыбора, ИмяГруппы);
			ТекстРасчета = СтрЗаменить(ТекстРасчета, ЗаменяемыйТекстВыбора, ТекстВыбора);			
			// Группировки.
			ЗаменяемыйТекстГруппировок = СтрШаблон("ОборотыРезультат1.%1,", ИмяГруппы);
			ТекстГруппировок = СтрШаблон(ШаблонВыбораГруппировок, ИмяГруппы);
			ТекстРасчета = СтрЗаменить(ТекстРасчета, ЗаменяемыйТекстГруппировок, ТекстГруппировок);
		КонецЦикла;
	КонецЕсли;
	
	ТекстРасчета = СтрЗаменить(ТекстРасчета, "&ГруппаПериод", ГруппировкаПоПериоду);	
			
КонецПроцедуры // СформироватьЗапросПоРасчету()

// Процедура добавляет в запрос временные таблицы по статьям - параметрам расчетов.
//
// Параметры:
//  ТекстЗапроса 			- Строка.
//  ПараметрыЗапроса 		- Структура:
//  							ВсеПараметрыЗапроса    - СписокЗначений.
//  							ПараметрыСтатьиПростые - СписокЗначений.
//  							ПараметрыСтатьиСложные - СписокЗначений.
//								ПоПериодам			   - Булево.
//  ДанныеГруппировок 		- Структура.
//  ВременныеГруппыРасчетов - Соответствие.
//
Процедура ДобавитьВЗапросВременныеТаблицыПоРасчетам(ИмяОтчета, ТекстВременныхГруппРасчетов, ПараметрыЗапроса, ДанныеРасчетов, ДанныеГруппировок, ВременныеГруппыРасчетов)

	ТекстРасчетов = "";	
	
	ВсеПараметрыЗапроса = ПараметрыЗапроса.ВсеПараметрыЗапроса;
		
	ИсключаемыеПоля 	  = ДанныеГруппировок.ИсключаемыеПоля;
	ПоляГруппировок 	  = ДанныеГруппировок.ПоляГруппировок;
	ГруппировкиПоПериодам = ДанныеГруппировок.ГруппировкиПоПериодам;
	
	ШаблонТекстаРасчетаСтатьи = Отчеты[ИмяОтчета].ШаблонТекстаРасчета(ИсключаемыеПоля);
	ТекстУсловийСоединения = ТекстУсловийСоединения(ПоляГруппировок);	
	
	ФиксацияГрупп = Новый ФиксированныйМассив(ПоляГруппировок);
	ФиксацияИсключаемыхПолей = Новый ФиксированныйМассив(ИсключаемыеПоля);
	
	// Дополнительные таблицы с разбитием по периодам.
	ШаблоныПоПериодам = Новый Структура;
	Для каждого ГруппировкаПоПериоду Из ГруппировкиПоПериодам Цикл
		
		ПоляГруппировокПоПериоду = Новый Массив(ФиксацияГрупп);
		ИсключаемыеПоляПоПериоду = Новый Массив(ФиксацияИсключаемыхПолей);
		
		Для каждого УдалениеПоПериоду Из ДанныеГруппировок.ГруппировкиПоПериодам Цикл				
			Если ГруппировкаПоПериоду <> УдалениеПоПериоду Тогда
				НайденноеПоле = ПоляГруппировокПоПериоду.Найти(УдалениеПоПериоду);
				Если НайденноеПоле <> Неопределено Тогда
					ПоляГруппировокПоПериоду.Удалить(НайденноеПоле);			
				КонецЕсли;
				ИсключаемыеПоляПоПериоду.Добавить(УдалениеПоПериоду);
			КонецЕсли;	
		КонецЦикла;
	
		ШаблоныПоПериоду = Новый Структура;
		ШаблоныПоПериоду.Вставить("ШаблонТекстаРасчетаСтатьи", Отчеты[ИмяОтчета].ШаблонТекстаРасчета(ИсключаемыеПоляПоПериоду));
		ШаблоныПоПериоду.Вставить("ТекстУсловийСоединения"   , ТекстУсловийСоединения(ПоляГруппировокПоПериоду));
		ШаблоныПоПериодам.Вставить(ГруппировкаПоПериоду, ШаблоныПоПериоду);
		
	КонецЦикла;
		
	НомерРасчета = 1;
	
	Для каждого ДанныеРасчета Из ДанныеРасчетов Цикл
		
		ТекущийРасчет = ДанныеРасчета.Расчет;
				
		ВсеПараметрыЗапроса.Добавить(ТекущийРасчет, СтрШаблон("Расчет%1", НомерРасчета));
		
		Если ДанныеРасчета.СложныйРасчет И ГруппировкиПоПериодам.Количество() > 1 Тогда
					
			Для каждого ГруппировкаПоПериоду Из ГруппировкиПоПериодам Цикл
				
				ШаблоныПоПериоду = ШаблоныПоПериодам[ГруппировкаПоПериоду];
				ТекстРасчета = ШаблоныПоПериоду.ШаблонТекстаРасчетаСтатьи;
				ТекстУсловийСоединенияПоПериоду = ШаблоныПоПериоду.ТекстУсловийСоединения;
								
				СформироватьЗапросПоРасчету(ТекстРасчета, НомерРасчета, ДанныеРасчета, ВременныеГруппыРасчетов, 
					ТекстУсловийСоединенияПоПериоду, ПоляГруппировок, ГруппировкаПоПериоду);
				Отчеты[ИмяОтчета].ЗаменитьТекстДляРесурсов(ТекстРасчета, 
					ДанныеРасчета.ФормулаРасчета, ДанныеРасчета.ПараметрыРасчета, НомерРасчета);
				
				ТекстРасчетов = ТекстРасчетов + ТекстРасчета;
					
			КонецЦикла;
			
		Иначе
			
			ТекстРасчета = ШаблонТекстаРасчетаСтатьи;
						
			СформироватьЗапросПоРасчету(ТекстРасчета, НомерРасчета, ДанныеРасчета, ВременныеГруппыРасчетов, 
				ТекстУсловийСоединения, ПоляГруппировок);
			Отчеты[ИмяОтчета].ЗаменитьТекстДляРесурсов(ТекстРасчета, 
				ДанныеРасчета.ФормулаРасчета, ДанныеРасчета.ПараметрыРасчета, НомерРасчета);
			
			ТекстРасчетов = ТекстРасчетов + ТекстРасчета;
		
		КонецЕсли;		
		
		НомерРасчета = НомерРасчета + 1;
			
	КонецЦикла; 
	
	ТекстВременныхГруппРасчетов = ТекстВременныхГруппРасчетов + ТекстРасчетов;
	
КонецПроцедуры // ДобавитьВЗапросВременныеТаблицыПоРасчетам()

// Процедура добавляет в запрос таблицы расчетов.
//
// Параметры:
//  ТекстЗапроса        	- Строка.
//  ВсеПараметрыЗапроса 	- СписокЗначений.
//  ВсеПараметрыСтатьи  	- СписокЗначений.
//  ДанныеРасчетов			- ТаблицаЗначений.
//  ДанныеГруппировок		- Структура.
//  ВременныеГруппыРасчетов - Соответствие.
//
Процедура ДобавитьВЗапросТаблицыРасчетов(ИмяОтчета, ТекстЗапроса, ПараметрыЗапроса, ДанныеРасчетов, ДанныеГруппировок, ВременныеГруппыРасчетов)
		
	ТекстРасчетов = "";	
	
	ВсеПараметрыЗапроса = ПараметрыЗапроса.ВсеПараметрыЗапроса;
		
	ИсключаемыеПоля 	  = ДанныеГруппировок.ИсключаемыеПоля;
	ПоляГруппировок 	  = ДанныеГруппировок.ПоляГруппировок;
	ГруппировкиПоПериодам = ДанныеГруппировок.ГруппировкиПоПериодам;
	
	ШаблонТекстаРасчетаСтатьи = Отчеты[ИмяОтчета].ШаблонТекстаРасчетаРезультат(ИсключаемыеПоля);
	ТекстУсловийСоединения = ТекстУсловийСоединения(ПоляГруппировок);	
	
	ФиксацияГрупп = Новый ФиксированныйМассив(ПоляГруппировок);
	ФиксацияИсключаемыхПолей = Новый ФиксированныйМассив(ИсключаемыеПоля);
	
	// Дополнительные таблицы с разбитием по периодам.
	ШаблоныПоПериодам = Новый Структура;
	Для каждого ГруппировкаПоПериоду Из ГруппировкиПоПериодам Цикл
		
		ПоляГруппировокПоПериоду = Новый Массив(ФиксацияГрупп);
		ИсключаемыеПоляПоПериоду = Новый Массив(ФиксацияИсключаемыхПолей);
		
		Для каждого УдалениеПоПериоду Из ДанныеГруппировок.ГруппировкиПоПериодам Цикл				
			Если ГруппировкаПоПериоду <> УдалениеПоПериоду Тогда
				НайденноеПоле = ПоляГруппировокПоПериоду.Найти(УдалениеПоПериоду);
				Если НайденноеПоле <> Неопределено Тогда
					ПоляГруппировокПоПериоду.Удалить(НайденноеПоле);			
				КонецЕсли;
				ИсключаемыеПоляПоПериоду.Добавить(УдалениеПоПериоду);
			КонецЕсли;	
		КонецЦикла;
	
		ШаблоныПоПериоду = Новый Структура;
		ШаблоныПоПериоду.Вставить("ШаблонТекстаРасчетаСтатьи", Отчеты[ИмяОтчета].ШаблонТекстаРасчетаРезультат(ИсключаемыеПоляПоПериоду));
		ШаблоныПоПериоду.Вставить("ТекстУсловийСоединения"   , ТекстУсловийСоединения(ПоляГруппировокПоПериоду));
		ШаблоныПоПериодам.Вставить(ГруппировкаПоПериоду, ШаблоныПоПериоду);
		
	КонецЦикла;
		
	НомерРасчета = 1;
	
	Для каждого ДанныеРасчета Из ДанныеРасчетов Цикл
		
		ТекущийРасчет = ДанныеРасчета.Расчет;
				
		ВсеПараметрыЗапроса.Добавить(ТекущийРасчет, СтрШаблон("Расчет%1", НомерРасчета));
		
		Если ДанныеРасчета.СложныйРасчет И ГруппировкиПоПериодам.Количество() > 1 Тогда
					
			Для каждого ГруппировкаПоПериоду Из ГруппировкиПоПериодам Цикл
				
				ШаблоныПоПериоду = ШаблоныПоПериодам[ГруппировкаПоПериоду];
				ТекстРасчета = ШаблоныПоПериоду.ШаблонТекстаРасчетаСтатьи;
				Если НЕ ДанныеРасчета.ВыводитьКоличество Тогда
					ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество5,", "0,");
					ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество4,", "0,");
					ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество3,", "0,");
					ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество2,", "0,");
					ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество1,", "0,");
					ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество," , "0,");			
				КонецЕсли;
				ТекстУсловийСоединенияПоПериоду = ШаблоныПоПериоду.ТекстУсловийСоединения;
								
				СформироватьЗапросПоРасчету(ТекстРасчета, НомерРасчета, ДанныеРасчета, ВременныеГруппыРасчетов, 
					ТекстУсловийСоединенияПоПериоду, ПоляГруппировок, ГруппировкаПоПериоду);
				Отчеты[ИмяОтчета].ЗаменитьТекстДляРесурсовРезультат(ТекстРасчета, 
					ДанныеРасчета.ФормулаРасчета, ДанныеРасчета.ПараметрыРасчета, НомерРасчета);
				
				ТекстРасчетов = ТекстРасчетов + ТекстРасчета;
					
			КонецЦикла;
			
		Иначе
			
			ТекстРасчета = ШаблонТекстаРасчетаСтатьи;
			Если НЕ ДанныеРасчета.ВыводитьКоличество Тогда
				ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество5,", "0,");
				ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество4,", "0,");
				ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество3,", "0,");
				ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество2,", "0,");
				ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество1,", "0,");
				ТекстРасчета = СтрЗаменить(ТекстРасчета, "&Количество," , "0,");
			КонецЕсли;
						
			СформироватьЗапросПоРасчету(ТекстРасчета, НомерРасчета, ДанныеРасчета, ВременныеГруппыРасчетов, 
				ТекстУсловийСоединения, ПоляГруппировок);
			Отчеты[ИмяОтчета].ЗаменитьТекстДляРесурсовРезультат(ТекстРасчета, 
				ДанныеРасчета.ФормулаРасчета, ДанныеРасчета.ПараметрыРасчета, НомерРасчета);
			
			ТекстРасчетов = ТекстРасчетов + ТекстРасчета;
		
		КонецЕсли;		
		
		НомерРасчета = НомерРасчета + 1;
			
	КонецЦикла; 
	
	ТекстЗапроса = ТекстЗапроса + ТекстРасчетов;
	
КонецПроцедуры // ДобавитьВЗапросТаблицыРасчетов()

#КонецОбласти 

// Функция формирует текст основного результата.
//
// Параметры:
//  ТекстЗапроса    - Строка.
//  ИсключаемыеПоля - Массив.
//
// Возвращаемое значение:
//  Строка.
//
Функция ИзменитьТекстОсновногоРезультата(Знач ТекстЗапроса, ДанныеГруппировок)

	ИсключаемыеПоля = ДанныеГруппировок.ИсключаемыеПоля;
	
	ТекстОсновногоРезультата = ТекстЗапроса;
	Для каждого ПолеИсключаемое Из ИсключаемыеПоля Цикл	
		ТекстЗаменяемый = СтрШаблон("ВТОборотыДляРасчетов.%1,", ПолеИсключаемое);
		ТекстОсновногоРезультата = СтрЗаменить(ТекстОсновногоРезультата, ТекстЗаменяемый, "NULL,");
		Если ПолеИсключаемое = "Аналитика_1" Тогда
			ТекстЗаменяемый = "ВТОборотыДляРасчетов.Аналитика_1 КАК";
			ТекстОсновногоРезультата = СтрЗаменить(ТекстОсновногоРезультата, ТекстЗаменяемый, "NULL КАК");
		Иначе 
			ТекстЗаменяемый = СтрШаблон("ВТОборотыДляРасчетов.%1", ПолеИсключаемое);
			ТекстОсновногоРезультата = СтрЗаменить(ТекстОсновногоРезультата, ТекстЗаменяемый, "NULL");
		КонецЕсли;		
	КонецЦикла;
			
	Возврат ТекстОсновногоРезультата;

КонецФункции

// Процедура меняет текст запроса для СКД и подставляет фиксированные параметры.
//
// Параметры:
//  ИмяОтчета 			  - Строка.
//  СхемаКомпоновкиДанных - СхемаКомпоновкиДанных.
//  КомпоновщикНастроек.
//
Процедура УстановитьПараметрыОтчетаСРасчетами(ПараметрыСКД, ВсеПараметрыЗапроса)
	
	// Установка параметров в СКД.
	Для каждого ПараметрРасчетов Из ВсеПараметрыЗапроса Цикл
		ИскомыйПараметр = Новый ПараметрКомпоновкиДанных(ПараметрРасчетов.Представление);
		ПараметрСхемы = ПараметрыСКД.Найти(ИскомыйПараметр);
		Если ПараметрСхемы = Неопределено Тогда
			ПараметрСхемы = ПараметрыСКД.Добавить();
			ПараметрСхемы.Имя = ПараметрРасчетов.Представление;			
		КонецЕсли;		
		ПараметрСхемы.Значение = ПараметрРасчетов.Значение;
		ПараметрСхемы.ОграничениеИспользования = Истина;
	КонецЦикла;	

КонецПроцедуры // УстановитьПараметрыОтчетаСРасчетами()

#КонецОбласти
	