
////////////////////////////////////////////////////////////////////////////////
// Модуль механизмов обмена Аудиторской выгрузки.
//  
////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Возвращает настройки фильтров реквизита для узла плана обмена.
//
// Параметры:
//  Узел - ПланОбменаСсылка - ссылка на узел плана обмена бит_АудиторскаяВыгрузка.
//  ПолноеИмяМетаданных - Строка - полное наименование метанных объекта выгрузки,
//   для которого выполняется получение правила.
//
// Возвращаемое значение:
//  Массив -  массив правил фильтрации для объекта.
//
Функция ФильтрыРеквизитовДляОбъектаМетаданных(Узел, ПолноеИмяМетаданных) Экспорт
	
	МассивФильтров = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ФильтрыАудиторскойВыгрузки.ИмяРеквизита КАК ИмяРеквизита,
	|	ФильтрыАудиторскойВыгрузки.ИмяТабличнойЧасти КАК ИмяТабличнойЧасти
	|ИЗ
	|	ПланОбмена.бит_АудиторскаяВыгрузка.ФильтрРеквизитов КАК ФильтрыАудиторскойВыгрузки
	|ГДЕ
	|	ФильтрыАудиторскойВыгрузки.Ссылка = &Ссылка
	|	И (ФильтрыАудиторскойВыгрузки.ОбъектСистемы = &ИмяОбъектаПолное
	|			ИЛИ ФильтрыАудиторскойВыгрузки.ОбъектСистемы.ИмяОбъектаПолное = &ИмяОбъектаПолное)";
	Запрос.УстановитьПараметр("Ссылка", Узел);
	Запрос.УстановитьПараметр("ИмяОбъектаПолное", ПолноеИмяМетаданных);
	
	ВыборкаФильтров = Запрос.Выполнить().Выбрать();
	Пока ВыборкаФильтров.Следующий() Цикл
		СтрокаФильтра = НоваяСтрокаФильтраРеквизита();
		СтрокаФильтра.ПолноеОграничение = ПустаяСтрока(ВыборкаФильтров.ИмяТабличнойЧасти)
											И ПустаяСтрока(ВыборкаФильтров.ИмяРеквизита);
		СтрокаФильтра.ИмяТабличнойЧасти = ВыборкаФильтров.ИмяТабличнойЧасти;
		СтрокаФильтра.ИмяРеквизита      = ВыборкаФильтров.ИмяРеквизита;
		МассивФильтров.Добавить(СтрокаФильтра);
	КонецЦикла;
	
	Возврат МассивФильтров;
	
КонецФункции

// Проверяет является ли эта база подчиненным узлом Аудиторской выгрузки.
//
// Возвращаемое значение:
//  Булево - Истина если является, Ложь если нет.
//
Функция ЭтоУзелАудита() Экспорт
	
	Возврат ТипЗнч(ПланыОбмена.ГлавныйУзел()) = Тип("ПланОбменаСсылка.бит_АудиторскаяВыгрузка");
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ВходитВСоставАудиторскойВыгрузки(ПолноеИмяМетаданных) Экспорт
	
	Если НЕ ОбменДаннымиВключен("бит_АудиторскаяВыгрузка") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЭтоУзелАудита()
		И НЕ ОбъектРазрешенДляВыгрузкиИзАудита(ПолноеИмяМетаданных) Тогда
		// В базе Аудита регистрация не выполняется.
		Возврат Ложь;
	КонецЕсли;
	
	МатаданныеИсточника = Метаданные.НайтиПоПолномуИмени(ПолноеИмяМетаданных);
	Возврат Метаданные.ПланыОбмена.бит_АудиторскаяВыгрузка.Состав.Содержит(МатаданныеИсточника);
	
КонецФункции

Функция ОбъектРазрешенДляВыгрузкиИзАудита(ПолноеИмяМетаданных) Экспорт
	
	Если ПолноеИмяМетаданных = "Документ.бит_ЗапросНалоговогоМониторинга" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Возвращает признак использования плана обмена в обмене данными.
// Если план обмена содержит хотя бы один узел кроме предопределенного,
// то считается, что он используется.
//
// Параметры:
//  ИмяПланаОбмена - Строка - имя плана обмена, как оно задано в конфигураторе.
//  Отправитель - ПланОбменаСсылка - значение параметра устанавливается, если необходимо
//   определить есть ли другие узлы обмена, кроме того, из
//   которого был получен объект.
//
// Возвращаемое значение:
//  Булево -  Истина - план обмена используется, Ложь - нет.
//
Функция ОбменДаннымиВключен(Знач ИмяПланаОбмена, Знач Отправитель = Неопределено) Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьСинхронизациюДанных") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1 1
	|ИЗ
	|	ПланОбмена." + ИмяПланаОбмена + " КАК ПланОбмена
	|ГДЕ
	|	НЕ ПланОбмена.ПометкаУдаления
	|	И НЕ ПланОбмена.ЭтотУзел
	|	И ПланОбмена.Ссылка <> &Отправитель";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Отправитель", Отправитель);
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НоваяСтрокаФильтраРеквизита()
	
	СтрокаФильтра = Новый Структура;
	СтрокаФильтра.Вставить("ПолноеОграничение", Ложь);
	СтрокаФильтра.Вставить("ИмяТабличнойЧасти", "");
	СтрокаФильтра.Вставить("ИмяРеквизита",      "");
	
	Возврат СтрокаФильтра;
	
КонецФункции

#КонецОбласти
