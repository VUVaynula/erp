// Возвращает числовое значение ставки НДС.
// 
// Параметры:
// СтавкаНДС - ПеречислениеСсылка.СтавкиНДС.
// 
// Возвращаемое значение:
// Результат - Число.
// 
Функция ПолучитьСтавкуНДС(Знач СтавкаНДС) Экспорт

	Возврат бит_БухгалтерскийУчет.ПолучитьСтавкуНДС(СтавкаНДС);
		
КонецФункции

#КонецОбласти

// Процедура обрабатывает изменение субконто.
//
// Параметры:
//  СтруктураСубконто 	 - Структура.
//  ИмяСубконто 	  	 - Строка.
//  ЗначениеСубконто	 - Ссылка.
//  КоличествоСубконтоМУ - Число.
//
Процедура ОбработатьИзменениеСубконто(СтруктураСубконто, ИмяСубконто, ЗначениеСубконто, КоличествоСубконтоМУ) Экспорт

	бит_БухгалтерскийУчет.ОбработатьИзменениеСубконто(СтруктураСубконто, ИмяСубконто, ЗначениеСубконто, КоличествоСубконтоМУ);
	
КонецПроцедуры

// Функция возвращает признак того, что есть исторические курсы.
//
// Параметры:
//  ИмяПланаСчетов - Строка.
//
// Возвращаемое значение:
//  Булево - есть исторические курсы.
//
Функция ЕстьИсторическиеКурсы(Знач ИмяПланаСчетов) Экспорт

	Возврат бит_БухгалтерскийУчет.ЕстьИсторическиеКурсы(ИмяПланаСчетов);
	
КонецФункции

// Процедура заполняет план счетов по умолчанию.
//
// Параметры:
//  ИмяПланаСчетов 			 - Строка.
//  МассивСтрокДляЗаполнения - Массив (По умолчанию = Неопределено).
//
Процедура ЗаполнитьПланСчетовПоУмолчанию(ИмяПланаСчетов, МассивСтрокДляЗаполнения = Неопределено) Экспорт

	бит_БухгалтерскийУчет.ЗаполнитьПланСчетовПоУмолчанию(ИмяПланаСчетов, МассивСтрокДляЗаполнения);
	
КонецПроцедуры

// Функция возвращает вид расчетов по договору.
//
// Параметры:
// 	ДоговорКонтрагента - СправочникСсылка.ДоговорыКонтрагентов.
// 
// Возвращаемое значение:
//  ПеречислениеСсылка.ВидыРасчетовПоДоговорам.
// 
Функция ОпределениеВидаРасчетовПоПараметрамДоговора(Знач ДоговорКонтрагента) Экспорт
	
	ВидРасчетовПоДоговору = бит_БухгалтерскийУчет.ОпределениеВидаРасчетовПоПараметрамДоговора(ДоговорКонтрагента);		
	Возврат ВидРасчетовПоДоговору;
	
КонецФункции

#КонецОбласти
