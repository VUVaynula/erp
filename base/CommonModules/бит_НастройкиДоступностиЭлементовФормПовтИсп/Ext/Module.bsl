////////////////////////////////////////////////////////////////////////////////
// Управление достпуностью и проверкой заполнения элементов формы.
//  
////////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

Функция ОбъектыНастройкиДоступностиЭлементов() Экспорт 

	МетаданныеОбъектов = Новый Массив;
	
	Для каждого ТипОбъекта Из Метаданные.ОпределяемыеТипы.бит_НастройкаДоступностиЭлементовДокументы.Тип.Типы() Цикл
		МетаданныеОбъектов.Добавить(Метаданные.НайтиПоТипу(ТипОбъекта));
	КонецЦикла;
	Для каждого ТипОбъекта Из Метаданные.ОпределяемыеТипы.бит_НастройкаДоступностиЭлементовОбъекты.Тип.Типы() Цикл
		МетаданныеОбъектов.Добавить(Метаданные.НайтиПоТипу(ТипОбъекта));
	КонецЦикла;
	
	ОбъектыНастройки = Новый СписокЗначений;
	ОбъектыНастройки.ЗагрузитьЗначения(
		Справочники.бит_ОбъектыСистемы.ОбъектыСистемыПоОбъектамМетаданных(МетаданныеОбъектов));
	Возврат ОбъектыНастройки;
	
КонецФункции

Функция ЭлементыИсключенияНастройкиДоступности(ИмяОбъектаСистемы) Экспорт
	
	МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ИмяОбъектаСистемы);
	Попытка
		Исключения = МенеджерОбъекта.ЭлементыИсключенияНастройкиДоступности();
	Исключение
		Исключения = Новый СписокЗначений;
	КонецПопытки;
	
	Возврат Исключения;
	
КонецФункции

Функция ЭлементыПрограммнойБлокировкиНастройкиДоступности(ИмяОбъектаСистемы) Экспорт
	
	МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ИмяОбъектаСистемы);
	Попытка
		ЭлементыФормы = МенеджерОбъекта.ЭлементыПрограммнойБлокировкиНастройкиДоступности();
	Исключение
		ЭлементыФормы = Новый СписокЗначений;
	КонецПопытки;
	
	Возврат ЭлементыФормы;
	
КонецФункции

#КонецОбласти