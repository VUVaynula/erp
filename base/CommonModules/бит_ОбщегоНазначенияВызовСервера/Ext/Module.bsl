// Возвращает структуру параметров, необходимых при запуске конфигурации.
//
// Возвращаемое значение:
//  Структура - параметры работы программы при запуске.
//
Функция ПараметрыРаботыКлиентаПриЗапуске() Экспорт
	
	ПараметрыКлиента = Новый Структура;
	
	// Для запрета обновления с неподдерживаемых версий
	// См. бит_ОбновлениеИнформационнойБазыБФ.ПриДобавленииПодсистемы()
	ВерсияДанных 	 = "БитФинанс";
	ВерсияМетаданных = бит_ОбщегоНазначенияПовтИсп.ПолучитьСведенияОПрограмме().НомерРелиза_БИТ;

	ПараметрыКлиента.Вставить("ВерсияДанных", ОбновлениеИнформационнойБазыСлужебный.ВерсияИБ(ВерсияДанных, Истина)); 
	ПараметрыКлиента.Вставить("ВерсияМетаданных",ВерсияМетаданных); 
	
	Возврат ПараметрыКлиента;
	
КонецФункции

