// Функция получает значение, получив предварительно менеджер объекта.
// 
// Параметры:
//  СтруктураИмен - Структура.
//  ИдПоиска	  - Строка.
// 
// Возвращаемое значение:
//  Произвольное значение.
// 
Функция ЗначениеЧерезМенеджерОбъекта(Знач СтруктураИмен, Знач ИдПоиска) Экспорт
	
	Менеджер = бит_ОбщегоНазначения.ПолучитьМенеджер(СтруктураИмен.ИмяКоллекции);
	НайденноеЗначение = Менеджер[СтруктураИмен.ИмяОбъекта].ПолучитьСсылку(ИдПоиска);
	Доступно = ОбщегоНазначения.СсылкаСуществует(НайденноеЗначение);
	Если НЕ Доступно Тогда					
		НайденноеЗначение = Неопределено;					
	КонецЕсли;
	
	Возврат НайденноеЗначение;
	
КонецФункции

