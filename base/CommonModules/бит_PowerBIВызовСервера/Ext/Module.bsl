#Область СлужебныйПрограммныйИнтерфейс

// Помещает во временное хранилище макет модели Power BI.
//
// Параметры:
//  ИмяМакетаМоделиОтчета	 - Строка	 - Имя макета обработки бит_ПанельУправленияPowerBI, для веб или FTP публикации данных.
// 
// Возвращаемое значение:
//  Структура - структура с полями:
//  	* Представление				- Строка - Имя файла.
//  	* АдресВоВременномХранилище	- Строка - Адрес помещенного во временное хранилище макета.
//
Функция ПоместитьФайлВоВременноеХранилищеНаСервере(ИмяМакетаМоделиОтчета) Экспорт
	
	ИмяФайла = ПолучитьИмяВременногоФайла(".pbit");
	
	МакетОчетаFTP = Обработки.бит_ПанельУправленияPowerBI.ПолучитьМакет(ИмяМакетаМоделиОтчета);
	МакетОчетаFTP.Записать(ИмяФайла);
	
	ДвоичныеДанные = Новый ДвоичныеДанные(ИмяФайла);
	АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные, Новый УникальныйИдентификатор);
	ОписаниеФайла = Новый Структура;
	ОписаниеФайла.Вставить("Представление", НСтр("ru='Bit.Finans.pbit';en='Bit.Finans.pbit'"));
	ОписаниеФайла.Вставить("АдресВоВременномХранилище", АдресВоВременномХранилище);

	Попытка
		УдалитьФайлы(ИмяФайла);
	Исключение
		ПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ИмяСобытия = НСтр("ru='Подготовка файлов Power BI.';en='Preparing the Power BI files.'", ОбщегоНазначения.КодОсновногоЯзыка());
		ТекстСообщения = НСтр("ru='Не удалось удалить временный файл по причине: %1';
							  |en='Could not delete the temporary file because: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ПредставлениеОшибки);
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
	КонецПопытки;
	
	Возврат ОписаниеФайла;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьЛицензиюPowerBI() Экспорт
	
	Возврат бит_PowerBIСлужебный.ПолучитьЛицензиюPowerBI();
	
КонецФункции

#КонецОбласти
