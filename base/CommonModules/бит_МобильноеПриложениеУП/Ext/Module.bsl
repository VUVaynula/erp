Процедура ДополнитьДанныеОбъекта(ДанныеОбъекта, Источник, ЗапросПлатежнойПозиции, ЭтоЗадача) Экспорт 
	
	Если ЗапросПлатежнойПозиции <> Неопределено
		И ТипЗнч(Источник.ОбъектВизирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
		ЗапросПлатежнойПозиции.УстановитьПараметр("ДокументПланирования", Источник.ОбъектВизирования);
		Выборка = ЗапросПлатежнойПозиции.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ДанныеОбъекта.PaymentDate = Формат(Выборка.ДатаПлан, "ДЛФ=D");
		КонецЕсли;
	КонецЕсли;
	
	ДанныеОбъекта.Executor = Строка(Источник.Инициатор);
	Если ТипЗнч(Источник.ОбъектВизирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
		Если ЗначениеЗаполнено(Источник.ОснованиеПланирования)
			И Источник.ОснованиеПланирования = Перечисления.бит_кзн_ВидыПланов.Прогноз Тогда
			ДанныеОбъекта.BasisForecast = Истина;
		Иначе
			ДанныеОбъекта.BasisForecast = Ложь;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Процедура ДополнитьДаннымиРеестраПлатежей(ОбъектВизирования, Источник) Экспорт
	
	Если ТипЗнч(Источник.ОбъектВизирования) = Тип("ДокументСсылка.бит_кзн_РеестрПлатежей") Тогда
		ДанныеРеестра = Новый Структура;
		ДанныеРеестра.Вставить("ID",           XMLСтрока(Источник.ОбъектВизирования));
		ДанныеРеестра.Вставить("Number",       Источник.Номер);
		ДанныеРеестра.Вставить("Date",         Источник.Дата);
		ДанныеРеестра.Вставить("Company",      Строка(Источник.Организация));
		ДанныеРеестра.Вставить("Comment",      Источник.Комментарий);
		ДанныеРеестра.Вставить("Applications", Новый Массив);
		Для каждого СтрокаРеестр Из Источник.ОбъектВизирования.ТаблицаПлатежи Цикл
			Имена = бит_ОбщегоНазначенияКлиентСервер.РазобратьПолноеИмяОбъекта(СтрокаРеестр.ЗаявкаПлатежнаяПозиция.Метаданные().ПолноеИмя());
			СтрокаЗаявки = Новый Структура;
			СтрокаЗаявки.Вставить("RowNumber",               СтрокаРеестр.НомерСтроки);
			СтрокаЗаявки.Вставить("ObjectName",              Имена.ИмяОбъекта);
			СтрокаЗаявки.Вставить("ApplicationID",           XMLСтрока(СтрокаРеестр.ЗаявкаПлатежнаяПозиция));
			СтрокаЗаявки.Вставить("ApplicationPresentation", Строка(СтрокаРеестр.ЗаявкаПлатежнаяПозиция));
			СтрокаЗаявки.Вставить("Amount",                  Формат(СтрокаРеестр.СуммаКОплате, "ЧН=0; ЧГ="));
			СтрокаЗаявки.Вставить("AmountPayable",           Формат(СтрокаРеестр.СуммаКОплате, "ЧН=0; ЧГ="));
			СтрокаЗаявки.Вставить("TotalSchedule",           Формат(СтрокаРеестр.СуммаПлан, "ЧН=0; ЧГ="));
			СтрокаЗаявки.Вставить("Currency",                Строка(СтрокаРеестр.ВалютаПлатежа));
			ДанныеРеестра.Applications.Добавить(СтрокаЗаявки);
		КонецЦикла; 
		ОбъектВизирования.ApplicationReestr = ДанныеРеестра;
	КонецЕсли;

КонецПроцедуры

Функция ДанныеОбъекта(ОбъектСсылка) Экспорт
	
	ОбработкаОбъект = Обработки.бит_ИнформационнаяПанель.Создать();
	ОбработкаОбъект.Объект = ОбъектСсылка;
	ДеревоИнформация = Неопределено;
	Если ТипЗнч(ОбъектСсылка) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
		ДеревоИнформация = ОбработкаОбъект.ПолучитьИнформациюПоЗаявке();
	КонецЕсли;
	
	Возврат ДеревоИнформация;

КонецФункции 

Функция ЗапросПлатежнойПозиции() Экспорт 
	
	Запрос = Новый Запрос();
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПлатежнаяПозиция.ДатаПлан КАК ДатаПлан
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПозиция
	|ГДЕ
	|	ПлатежнаяПозиция.ДокументПланирования = &ДокументПланирования
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаПлан";
	
	Возврат Запрос;
	
КонецФункции

