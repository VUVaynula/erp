Функция ПолучитьДанныеФайлаОбъекта(ИмяОбъекта, Идентификатор) Экспорт
	
	ИмяХранилищаФайлов = ИмяОбъекта+"ПрисоединенныеФайлы";
	ФайлСсылка         = Справочники[ИмяХранилищаФайлов].ПолучитьСсылку(Новый УникальныйИдентификатор(Идентификатор));
	
	Результат = Новый Структура;
	Результат.Вставить("ID");
	Результат.Вставить("VersionID");
	Результат.Вставить("Data");
	Результат.Вставить("Message");
	Результат.Вставить("StatusCode");
	Если ОбщегоНазначения.СсылкаСуществует(ФайлСсылка) Тогда
		ДанныеФайла = РаботаСФайлами.ДанныеФайла(ФайлСсылка);
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(ДанныеФайла.СсылкаНаДвоичныеДанныеФайла);		
		Если ТипЗнч(ДвоичныеДанные) = Тип("ДвоичныеДанные") Тогда
			Результат.ID         = Идентификатор;
			Результат.VersionID  = XMLСтрока(ФайлСсылка);
			Результат.Data       = Base64Строка(ДвоичныеДанные);
			Результат.Message    = "OK";
			Результат.StatusCode = 200;
		Иначе	
			Результат.Message    = "Cannot get file data";
			Результат.StatusCode = 500;
		КонецЕсли; 
	Иначе	
		ТекстСообщения        = "Cannot find file by ID %1";
		ТекстСообщения        = СтрШаблон(ТекстСообщения, Идентификатор);
		Результат.Message     = ТекстСообщения;
		Результат.StatusCode  = 404;
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции

Функция УникальнаяТабличнаяЧасть(Ссылка, ДопАналитики) Экспорт

	Результат = "";	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.бит_кзн_РеестрПлатежей") Тогда
		Результат = HTMLРеестра(Ссылка);
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств")
		ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств") Тогда	
		Результат = HTMLЗаявки(Ссылка, ДопАналитики);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НеобходимКомментарийЗадача(Организация, ОбъектСистемы, ВидРешения) Экспорт

	Результат = Новый Структура("ЗаписьСуществует, НеобходимКомментарийЗадача", Ложь, Ложь);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидРешения",    ВидРешения);
	Запрос.УстановитьПараметр("ОбъектСистемы", ОбъектСистемы);
	Запрос.УстановитьПараметр("Организация",   Организация);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВидыРешенийСогласования.Организация КАК Организация,
	|	ВидыРешенийСогласования.ОбъектСистемы КАК ОбъектСистемы,
	|	ВидыРешенийСогласования.ВидРешения КАК ВидРешения,
	|	ВидыРешенийСогласования.НеобходимКомментарийЗадача КАК НеобходимКомментарийЗадача
	|ИЗ
	|	РегистрСведений.бит_НазначениеВидовРешенийСогласования КАК ВидыРешенийСогласования
	|ГДЕ
	|	ВидыРешенийСогласования.Организация = &Организация
	|	И ВидыРешенийСогласования.ОбъектСистемы = &ОбъектСистемы
	|	И ВидыРешенийСогласования.ВидРешения = &ВидРешения";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат.ЗаписьСуществует = Истина;
		Результат.НеобходимКомментарийЗадача = Выборка.НеобходимКомментарийЗадача;
	КонецЕсли;
	
	Возврат Результат;	
	
КонецФункции

Функция ЭтоСправочник(Значение) Экспорт
	
	Результат = Ложь;
	СправочникиВизирования = Новый Массив();
