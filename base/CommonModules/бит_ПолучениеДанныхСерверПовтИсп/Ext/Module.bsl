// См. бит_ПолучениеДанных.ПолучитьМетаданныеHTTP()
// 
// Параметры:
//  НастройкаПодключения - СправочникСсылка.бит_мпд_НастройкиВнешнихПодключений.
// 
// Возвращаемое значение:
//  HTTPОтвет.
// 
Функция ПолучитьМетаданныеHTTP(НастройкаПодключения) Экспорт
	
	ПараметрыПодключения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(НастройкаПодключения,
							"Наименование, ИмяСервера, ИмяБазы, Пользователь, Пароль");
	ТекстЗапросаМета     = СтрШаблон("%1$metadata", бит_ПолучениеДанных.ПризнакОбращенияОДата());
	Путь                 = СтрШаблон("%1/%2", НастройкаПодключения.ИмяСервера, НастройкаПодключения.ИмяБазы);
	СоединениеHTTP       = Новый HTTPСоединение(Путь,,НастройкаПодключения.Пользователь,НастройкаПодключения.Пароль);
	ЗапросHTTP           = Новый HTTPЗапрос(ТекстЗапросаМета);
	ОтветHTTP            = СоединениеHTTP.Получить(ЗапросHTTP);
	Если ОтветHTTP.КодСостояния <> 200 Тогда
		ТекстСообщения = НСтр("ru='Не удалось получить метаданные по настройке ""%1"". 
								  |Код ошибки: %2.
								  |Подробности см. на: http://www.w3.org/Protocols/rfc2616/rfc2616-sec10.html';
		      				  |en='Failed to get metadata for setting ""%1"". 
								  |Error code: %2.
								  |For details, see: http://www.w3.org/Protocols/rfc2616/rfc2616-sec10.html'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, НастройкаПодключения, ОтветHTTP.КодСостояния);
		ВызватьИсключение ТекстСообщения;
	КонецЕсли; 
	
	Возврат ОтветHTTP;
	
КонецФункции

