
////////////////////////////////////////////////////////////////////////////////
// Управление достпуностью и проверкой заполнения элементов формы.
//  
////////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

// Устанавливает запрет редактирования и скрывает видимость элементов управления.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
//        - РасширениеУправляемойФормыДляОбъектов - форма объекта, где:
//    * Объект - ДанныеФормыСтруктура
//             - СправочникОбъект
//             - ДокументОбъект
//  Объект - Неопределено - взять объект из реквизита формы "Объект".
//         - СправочникОбъект
//         - ДокументОбъект
//
Процедура ЗаблокироватьЭлементы(Форма) Экспорт
	
	Если НЕ ФормаПодготовлена(Форма) Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого СтрокаПараметра Из Форма.ОграниченияРедактированияРеквизитов Цикл
		ИмяЭлемента  = СтрокаПараметра.ИмяЭлемента;
		ЭлементФормы = Форма.Элементы.Найти(ИмяЭлемента);
		Если ЭлементФормы = Неопределено Тогда
			Если ИмяЭлемента = "ВсеЭлементыФормы" Тогда 
				ЭлементФормы = Форма;
			Иначе
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		ТипЭлемента = ТипЗнч(ЭлементФормы);
		
		Если ТипЭлемента = Тип("ФормаКлиентскогоПриложения")
			И (СтрокаПараметра.УбратьВидимость
				ИЛИ СтрокаПараметра.Обязательное) Тогда
			ТекстОшибки = НСтр("ru='Некорректная настройка доступности элемента формы ""%1""'");
			ТекстОшибки = СтрШаблон(ТекстОшибки, ИмяЭлемента);
			ВызватьИсключение ТекстОшибки;
		КонецЕсли;
		
		Если СтрокаПараметра.ТолькоПросмотр Тогда
			Если СтрокаПараметра.ПрограммнаяБлокировка Тогда
				Если Форма.ЭлементыПрограммнойБлокировки.НайтиПоЗначению(ИмяЭлемента)	= Неопределено Тогда
					Форма.ЭлементыПрограммнойБлокировки.Добавить(ИмяЭлемента);
					СтрокаПараметра.ТолькоПросмотрИзменен = Истина;
				КонецЕсли;
			ИначеЕсли ТипЭлемента = Тип("КнопкаФормы") Тогда
				Если ЭлементФормы.Доступность Тогда
					ЭлементФормы.Доступность              = Ложь;
					СтрокаПараметра.ТолькоПросмотрИзменен = Истина;
				КонецЕсли;
			ИначеЕсли ТипЭлемента = Тип("ТаблицаФормы") Тогда
				Если ЭлементФормы.ИзменятьСоставСтрок Тогда
					ЭлементФормы.ИзменятьСоставСтрок      = Ложь;
					СтрокаПараметра.ТолькоПросмотрИзменен = Истина;
				КонецЕсли;
			ИначеЕсли ТипЭлемента = Тип("ПолеФормы")
				И ЭлементФормы.Вид = ВидПоляФормы.ПолеТабличногоДокумента Тогда
				Если НЕ ЭлементФормы.Защита Тогда
					ЭлементФормы.Защита                   = Истина;
					СтрокаПараметра.ТолькоПросмотрИзменен = Истина;
				КонецЕсли;
			Иначе
				Если НЕ ЭлементФормы.ТолькоПросмотр Тогда
					ЭлементФормы.ТолькоПросмотр           = Истина;
					СтрокаПараметра.ТолькоПросмотрИзменен = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если СтрокаПараметра.УбратьВидимость И ЭлементФормы.Видимость Тогда
			ЭлементФормы.Видимость            = Ложь;
			СтрокаПараметра.ВидимостьИзменена = Истина;
		КонецЕсли;
		
		Если СтрокаПараметра.Обязательное
			И НЕ (ТипЭлемента = Тип("ПолеФормы")
				И ЭлементФормы.Вид <> ВидПоляФормы.ПолеВвода) Тогда
			ЭлементФормы.АвтоОтметкаНезаполненного = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Снимает установленные ранее запреты редактирования.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
//
Процедура РазблокироватьЭлементы(Форма) Экспорт
	
	Если НЕ ФормаПодготовлена(Форма) Тогда
		Возврат;
	КонецЕсли;
	
	// Сброс старых назначеных блокировок.
	Форма.ЭлементыПрограммнойБлокировки.Очистить();
	Для каждого СтрокаПараметра Из Форма.ОграниченияРедактированияРеквизитов Цикл
		ИмяЭлемента  = СтрокаПараметра.ИмяЭлемента;
		ЭлементФормы = Форма.Элементы.Найти(ИмяЭлемента);
		Если ЭлементФормы = Неопределено Тогда
			Если ИмяЭлемента = "ВсеЭлементыФормы" Тогда 
				ЭлементФормы = Форма;
			Иначе
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если СтрокаПараметра.ТолькоПросмотрИзменен Тогда
			Если СтрокаПараметра.ПрограммнаяБлокировка Тогда
				СтрокаПараметра.ТолькоПросмотрИзменен = Ложь;
				Продолжить;
			ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("КнопкаФормы") Тогда
				ЭлементФормы.Доступность    = Истина;
			ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("ТаблицаФормы") Тогда
				Если НЕ ЭлементФормы.ИзменятьСоставСтрок Тогда
					ЭлементФормы.ИзменятьСоставСтрок  = Истина;
				КонецЕсли;
			ИначеЕсли ТипЗнч(ЭлементФормы) = Тип("ПолеФормы")
				И ЭлементФормы.Вид = ВидПоляФормы.ПолеТабличногоДокумента Тогда
				ЭлементФормы.Защита = Ложь;
			Иначе
				ЭлементФормы.ТолькоПросмотр = Ложь;
			КонецЕсли;
			СтрокаПараметра.ТолькоПросмотрИзменен = Ложь;
		КонецЕсли;
		
		Если СтрокаПараметра.ВидимостьИзменена Тогда
			ЭлементФормы.Видимость            = Истина;
			СтрокаПараметра.ВидимостьИзменена = Ложь;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ФормаПодготовлена(Форма) Экспорт
	
	Возврат ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, 
								"ОграниченияРедактированияРеквизитов");
	
КонецФункции

Функция ЭлементЗаблокированНаРедактирование(Элемент, Форма) Экспорт
	
	ИмяЭлемента = Элемент.Имя;
	Возврат Форма.ЭлементыПрограммнойБлокировки.НайтиПоЗначению(ИмяЭлемента) <> Неопределено;
	
КонецФункции

#КонецОбласти
