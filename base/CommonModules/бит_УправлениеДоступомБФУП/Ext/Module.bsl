Функция ИндексироватьПрофили(ОписанияПрофилей, ПолеПрофиля = "Имя")
	
	Результат = Новый Соответствие;
	Для Индекс = 0 По ОписанияПрофилей.ВГраница() Цикл
		
		Профиль = ОписанияПрофилей[Индекс];
		Результат.Вставить(Профиль[ПолеПрофиля], Индекс);
		
	КонецЦикла;
	Возврат Результат;
	
КонецФункции

Функция НайтиПрофиль(ИмяПрофиля, ОписанияПрофилей, ИндексПрофилей)

	ИндексПрофиля = ИндексПрофилей[ИмяПрофиля];
	Если ИндексПрофиля = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат ОписанияПрофилей[ИндексПрофиля];
	
КонецФункции

Функция ИнтегрирумыеПрофили(ОписанияПрофилей)
	
	ИндексПрофилей = ИндексироватьПрофили(ОписанияПрофилей, "Имя");
	
	ПрофильБухгалтер          = НайтиПрофиль("Бухгалтер", ОписанияПрофилей, ИндексПрофилей);
	ПрофильКазначей           = НайтиПрофиль("Казначей", ОписанияПрофилей, ИндексПрофилей);
	ПрофильКассир             = НайтиПрофиль("Кассир", ОписанияПрофилей, ИндексПрофилей);
	ПрофильМенеджерПоЗакупкам = НайтиПрофиль("МенеджерПоЗакупкам", ОписанияПрофилей, ИндексПрофилей);
	ПрофильМенеджерПоПродажам = НайтиПрофиль("МенеджерПоПродажам", ОписанияПрофилей, ИндексПрофилей);
	
	ИнтегрирумыеПрофили = Новый Структура;
	ИнтегрирумыеПрофили.Вставить("ПрофильБухгалтер",          ПрофильБухгалтер);
	ИнтегрирумыеПрофили.Вставить("ПрофильКазначей",           ПрофильКазначей);
	ИнтегрирумыеПрофили.Вставить("ПрофильКассир",             ПрофильКассир);
	ИнтегрирумыеПрофили.Вставить("ПрофильМенеджерПоЗакупкам", ПрофильМенеджерПоЗакупкам);
	ИнтегрирумыеПрофили.Вставить("ПрофильМенеджерПоПродажам", ПрофильМенеджерПоПродажам);
	
	Возврат ИнтегрирумыеПрофили;
	
КонецФункции

// Процедура выполняет копирование ролей из описания одного профиля в другой.
// 
// Параметры:
//  Источник   - Структура.ОписаниеПрофиля.
//  Приемник   - Структура.ОписаниеПрофиля.
//  Исключения - Строка.
// 
Процедура СкопироватьРолиПрофиля(Источник, Приемник, Исключения  = "")
	
	Если Источник = Неопределено  Тогда  
		Возврат;
	КонецЕсли;  
	
	МассивИсключений = бит_СтрокиКлиентСервер.РазложитьСтрокуВМассивПодстрок(Исключения, ";");
	
	Для каждого СтрРоль Из Источник.Роли Цикл
	
		Если МассивИсключений.Найти(СтрРоль) = Неопределено Тогда 		
			Приемник.Роли.Добавить(СтрРоль);  		
		КонецЕсли;         		
		
	КонецЦикла; 
	
КонецПроцедуры

// Процедура добавляет виды доступа профилю.
// 
// Параметры:
//  ОписаниеПрофиля - Структура.
// 
Процедура ДобавитьВидыДоступа(ОписаниеПрофиля, ОграничениеПоСтатьям = Ложь, ОграничениеПоПользователю = Ложь)

	ОписаниеПрофиля.ВидыДоступа.Добавить("Организации");
	ОписаниеПрофиля.ВидыДоступа.Добавить("ЦФО");
	ОписаниеПрофиля.ВидыДоступа.Добавить("КлючиДоступаЦФОСтатьиОборотов");
	ОписаниеПрофиля.ВидыДоступа.Добавить("Склады", "Предустановленный");
	Если ОграничениеПоСтатьям Тогда
		ОписаниеПрофиля.ВидыДоступа.Добавить("СтатьиОборотов");
	КонецЕсли;
	Если ОграничениеПоПользователю Тогда
		ОписаниеПрофиля.ВидыДоступа.Добавить("Пользователи");
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти
