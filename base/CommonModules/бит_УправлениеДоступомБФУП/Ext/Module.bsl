Процедура ДобавитьПрофильФинансистПолныеПрава(ОписанияПрофилей, ИнтегрирумыеПрофили)
	
	ОписаниеПрофиля = УправлениеДоступом.НовоеОписаниеПрофиляГруппДоступа();
	ОписаниеПрофиля.Идентификатор = "f712fb91-6037-4a89-b61d-aa0202ad6f7d";
	ОписаниеПрофиля.Наименование  = НСтр("ru='БИТ.Финансист(полные права)';en='BIT.Finance(full permissions)'"); 
	
	ДополнитьПрофильОбязательнымиРолями(ОписаниеПрофиля);
	
	ОписаниеПрофиля.Роли.Добавить("ДобавлениеИзменениеДатЗапретаИзменения");
	ОписаниеПрофиля.Роли.Добавить("бит_ИспользованиеОбработкиСозданиеЗаявокНаОснованииЗаказов");
	ОписаниеПрофиля.Роли.Добавить("бит_ИспользованиеОбработкиФормированиеЗаявокНРДСПоПервичнымДокументам");
	ОписаниеПрофиля.Роли.Добавить("бит_ДобавлениеИзменениеНастройкиДоступностиЭлементов");
	ОписаниеПрофиля.Роли.Добавить("бит_ФинансистПолныеПрава");
	ОписаниеПрофиля.Роли.Добавить("бит_ДобавлениеИзменениеШаблоновПроводокБюджетирования");
	ОписаниеПрофиля.Роли.Добавить("бит_ИспользованиеОбработкиФормированиеППДСПоПервичнымДокументам");
	ОписаниеПрофиля.Роли.Добавить("бит_ИспользованиеОбработкиФормированиеОтраженийФактаДДС");
	
	ПрофильБухгалтер          = ИнтегрирумыеПрофили.ПрофильБухгалтер;
	ПрофильКазначей           = ИнтегрирумыеПрофили.ПрофильКазначей;
	ПрофильКассир             = ИнтегрирумыеПрофили.ПрофильКассир;
	ПрофильМенеджерПоЗакупкам = ИнтегрирумыеПрофили.ПрофильМенеджерПоЗакупкам;
	ПрофильМенеджерПоПродажам = ИнтегрирумыеПрофили.ПрофильМенеджерПоПродажам;
		
	СкопироватьРолиПрофиля(ПрофильБухгалтер, ОписаниеПрофиля);
	СкопироватьРолиПрофиля(ПрофильКазначей, ОписаниеПрофиля);
	СкопироватьРолиПрофиля(ПрофильКассир, ОписаниеПрофиля);
	СкопироватьРолиПрофиля(ПрофильМенеджерПоЗакупкам, ОписаниеПрофиля);
    СкопироватьРолиПрофиля(ПрофильМенеджерПоПродажам, ОписаниеПрофиля);	
	
	ОписаниеПрофиля.Описание = НСтр("ru='Профиль базируется на типовом профиле ""Бухгалтер"" и дополнительно обеспечивает полный доступ к объектам Казначейства и Бюджетирования.';
	                      |en='Profile is based on the standard profile ""Accountant"" and additionally provides full access to the objects of Treasury and Budgeting.'");
	ОписанияПрофилей.Добавить(ОписаниеПрофиля);

КонецПроцедуры   

Процедура ДобавитьПрофильФинансистРЛС(ОписанияПрофилей, ИнтегрирумыеПрофили)
	
	ОписаниеПрофиля = УправлениеДоступом.НовоеОписаниеПрофиляГруппДоступа();
	ОписаниеПрофиля.Идентификатор = "4fdbc592-023b-47c5-8849-5fd5de605af8";
	ОписаниеПрофиля.Наименование  = НСтр("ru='БИТ.Финансист(ограничения на уровне записей)';en='BIT.Finance(record level restrictions)'"); 
	
	ДополнитьПрофильОбязательнымиРолями(ОписаниеПрофиля);
	
	ОписаниеПрофиля.Роли.Добавить("бит_рлс_Финансист");
	ОписаниеПрофиля.Роли.Добавить("бит_ЧтениеУстановкиКонтрольныхЗначений");
	
	ПрофильБухгалтер = ИнтегрирумыеПрофили.ПрофильБухгалтер;
	ПрофильКазначей  = ИнтегрирумыеПрофили.ПрофильКазначей;
	ПрофильКассир    = ИнтегрирумыеПрофили.ПрофильКассир;
		
	СкопироватьРолиПрофиля(ПрофильБухгалтер, ОписаниеПрофиля);
	СкопироватьРолиПрофиля(ПрофильКазначей, ОписаниеПрофиля);
	СкопироватьРолиПрофиля(ПрофильКассир, ОписаниеПрофиля);
	
	// Удалим роль, которая дает полный доступ к организациям
	ИндексРоли = ОписаниеПрофиля.Роли.Найти("ОператорОтправкиОтчетностиЧерезПредставителя");
	Если ТипЗнч(ИндексРоли) = Тип("Число") Тогда
		ОписаниеПрофиля.Роли.Удалить(ИндексРоли);
	КонецЕсли;
		
	ОписаниеПрофиля.Описание = НСтр("ru='Профиль базируется на типовом профиле ""Бухгалтер"" и дополнительно обеспечивает ввод объектов Казначейства и Бюджетирования. 
                                  |В профиле реализовано разделение RLS по ЦФО, статьям оборотов.'; 
							  |en='Profile is based on a typical profile ""Accountant"" and further provides input Object of the Treasury and Budgeting. 
                                  |The profile is implemented separation of RLS on the CFR, line items.'");
	
	ДобавитьВидыДоступа(ОписаниеПрофиля, Истина);
	ОписаниеПрофиля.ВидыДоступа.Добавить("ХозяйственныеОперации", "ВначалеВсеРазрешены");
	ОписанияПрофилей.Добавить(ОписаниеПрофиля);
			
КонецПроцедуры

Процедура ДобавитьПрофильФинансистЦФО(ОписанияПрофилей, ИнтегрирумыеПрофили)
	
	ОписаниеПрофиля = УправлениеДоступом.НовоеОписаниеПрофиляГруппДоступа();
	ОписаниеПрофиля.Идентификатор = "b0c1d106-a80a-4311-bffe-d035b8d21d09";
	ОписаниеПрофиля.Наименование  = НСтр("ru='БИТ.Финансист_ЦФО(ограничения на уровне записей)';en='BIT.Finance_FRC(record level restrictions)'"); 
	
	ДополнитьПрофильОбязательнымиРолями(ОписаниеПрофиля);
	
	ОписаниеПрофиля.Роли.Добавить("бит_рлс_ФинансистЦФО");
	ОписаниеПрофиля.Роли.Добавить("бит_ЧтениеУстановкиКонтрольныхЗначений");
	
	ПрофильБухгалтер = ИнтегрирумыеПрофили.ПрофильБухгалтер;
	ПрофильКазначей  = ИнтегрирумыеПрофили.ПрофильКазначей;
	ПрофильКассир    = ИнтегрирумыеПрофили.ПрофильКассир;
		
