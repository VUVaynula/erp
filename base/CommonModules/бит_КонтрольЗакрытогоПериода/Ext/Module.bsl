								ПараметрыЗаполнения = НовыеПараметрыЗаполненияЗаписиНабора();
								ПараметрыЗаполнения.ДанныеСтроки 		 = СтрокаТаблицы;
								ПараметрыЗаполнения.МетаданныеРегистра = МетаданныеРегистра;
