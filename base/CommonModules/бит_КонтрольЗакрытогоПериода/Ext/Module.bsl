								ПараметрыЗаполнения.Сторно			   = Истина;
		
								СформироватьЗапись(НаборЗаписей, ПараметрыЗаполнения); 
								
								ПараметрыЗаполнения = НовыеПараметрыЗаполненияЗаписиНабораСоответствияОборотов();
								ПараметрыЗаполнения.ТаблицаСоответствия = ТабСоотвОб;
								ПараметрыЗаполнения.ДанныеСтроки 	    = СтрокаТаблицы;
								ПараметрыЗаполнения.Период			    = ДатаОткрытогоПериода;
								ПараметрыЗаполнения.ВидПроводки		    = Перечисления.бит_КонтрольПериодов_ВидыПроводок.Сторно;
