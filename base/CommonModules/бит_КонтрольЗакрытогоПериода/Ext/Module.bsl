//
Процедура ОтражениеЗарплатыВБухучетеОбработкаУдаленияПроведения(Источник, Отказ)  Экспорт

	// ++ ЕРП
	Совместимо = Истина;
	// -- ЕРП
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

