								ПараметрыЗаполнения.ВидПроводки		    = Перечисления.бит_КонтрольПериодов_ВидыПроводок.ПрошлыйПериод;
		
								СформироватьЗаписьСоответствияОборотов(НаборЗаписейСоотвОб, ПараметрыЗаполнения);
								
