    СоотСсылочныхТипов.Вставить(МенеджерТипы.СправочникСсылка, Новый Структура(СтрокаКлючи, "Справочники",
		НСтр("ru = 'Справочник';en = 'Catalog'"), ИменаКоллекцииМетаданных("Справочники")));
