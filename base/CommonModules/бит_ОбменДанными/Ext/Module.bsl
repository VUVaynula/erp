		НСтр("ru = 'Документ';en = 'Document'"), ИменаКоллекцииМетаданных("Документы")));
	СоотСсылочныхТипов.Вставить(МенеджерТипы.ПеречислениеСсылка, Новый Структура(СтрокаКлючи, "Перечисления",
		НСтр("ru = 'Перечисление';en = 'Enumeration'"), ИменаКоллекцииМетаданных("Перечисления")));
	СоотСсылочныхТипов.Вставить(МенеджерТипы.ПланВидовХарактеристикСсылка, Новый Структура(СтрокаКлючи, "ПланыВидовХарактеристик",
