	Настройки.ОбъектыПечати.Добавить(Документы.бит_му_РазнесениеСальдоНаОтчетнуюДату);
	Настройки.ОбъектыПечати.Добавить(Документы.бит_му_РаспределениеПлатежейПоКредитамЗаймам);
	Настройки.ОбъектыПечати.Добавить(Документы.бит_му_РасчетОтложенныхНалогов); // Есть команды
	Настройки.ОбъектыПечати.Добавить(Документы.бит_му_РеализацияМПЗ);
	Настройки.ОбъектыПечати.Добавить(Документы.бит_му_РеклассификацияЗадолженности);
	Настройки.ОбъектыПечати.Добавить(Документы.бит_му_РеклассификацияЗадолженностиПоФинансовойАрендеОС); // Есть команды
	Настройки.ОбъектыПечати.Добавить(Документы.бит_му_СторноЭлиминационныхНачислений);
