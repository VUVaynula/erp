// Функция выполняет поиск ЦФО, синхронизированного с регл. подразделением/организацией.
// 
// Параметры:
//   ИсточникСсылка - СправочникСсылка.
// 
// Возвращаемое значение:
//  СинхрЦФО - СправочникСсылка.Подразделения, Неопределено.
// 
Функция НайтиСинхрЦФО(ИсточникСсылка)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СтруктурнаяЕдиницаРегл", ИсточникСсылка);
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Подразделения.Ссылка
	|ИЗ
	|	Справочник.Подразделения КАК Подразделения
	|ГДЕ
	|	Подразделения.СтруктурнаяЕдиницаРегл = &СтруктурнаяЕдиницаРегл";
	
	Результат = Запрос.Выполнить();				
	Выборка = Результат.Выбрать();
	СинхрЦФО = Неопределено;
	Если Выборка.Следующий() Тогда
		СинхрЦФО = Выборка.Ссылка;
	КонецЕсли; 
	
	Возврат СинхрЦФО;
	
КонецФункции

Процедура ПересчитатьЦеныНоменклатурыТЧ(ТаблицаДанных, ПараметрыРасчетаЦен)
	
	АнализируемыеПоля = Новый СписокЗначений;
	АнализируемыеПоля.Добавить("НомерСтроки");
	АнализируемыеПоля.Добавить("Период");
	АнализируемыеПоля.Добавить("СтатьяОборотов");
	АнализируемыеПоля.Добавить("Сумма");
	АнализируемыеПоля.Добавить("Норма");
	АнализируемыеПоля.Добавить(ПараметрыРасчетаЦен.АналитикаНоменклатуры);
	
	ШаблонВыбораПоля   = "ТаблицаДанных.%1 КАК %1,";
	ДополнительныеПоля = Новый Массив; // Колонки таблицы, не участвуемые непосредственно в обработке данных.
	Для каждого КолонкаТаблицыИсточника Из ТаблицаДанных.Колонки Цикл
		ИмяКолонки = КолонкаТаблицыИсточника.Имя;
		Если АнализируемыеПоля.НайтиПоЗначению(ИмяКолонки) = Неопределено Тогда
			ДополнительныеПоля.Добавить(ИмяКолонки);
		КонецЕсли;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	// Виртуализация таблицы источника.
	ТекстЗапроса = "ВЫБРАТЬ";
	Для каждого ДопПоле Из ДополнительныеПоля Цикл
		ТекстЗапроса = ТекстЗапроса + Символы.ПС + СтрШаблон(ШаблонВыбораПоля, ДопПоле);
	КонецЦикла;
	ТекстЗапроса = ТекстЗапроса + "
	|	ТаблицаДанных.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДанных.Период КАК ПериодСтрокиИсточника,
	|	ТаблицаДанных.Номенклатура КАК Номенклатура,
	|	ТаблицаДанных.СтатьяОборотов КАК СтатьяОборотов,
	|	ТаблицаДанных.Сумма КАК Сумма,
	|	ТаблицаДанных.Норма КАК Норма
	|ПОМЕСТИТЬ ТаблицаДанных
	|ИЗ
	|	&ТаблицаДанных КАК ТаблицаДанных";
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ТаблицаДанных.Номенклатура", "ТаблицаДанных." + ПараметрыРасчетаЦен.АналитикаНоменклатуры);
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ТаблицаДанных", ТаблицаДанных);
	Запрос.Выполнить();
	
	// Расчет цен номенклатуры.
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТаблицаДанных.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДанных.ПериодСтрокиИсточника КАК ПериодСтрокиИсточника,
	|	ВЫРАЗИТЬ(ТаблицаДанных.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура
	|ПОМЕСТИТЬ ЗаполняемыеПозиции
	|ИЗ
	|	ТаблицаДанных КАК ТаблицаДанных
	|ГДЕ
	|	ТаблицаДанных.СтатьяОборотов.Учет_Сумма
	|	И ТаблицаДанных.СтатьяОборотов.Учет_Количество
	|	И НЕ ТаблицаДанных.Номенклатура В (НЕОПРЕДЕЛЕНО, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка))
	|	И (НЕ &ТолькоНулевыеСуммы
	|			ИЛИ ТаблицаДанных.Сумма = 0)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	ПериодСтрокиИсточника
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаполняемыеПозиции.ПериодСтрокиИсточника КАК ПериодСтрокиИсточника,
	|	ЗаполняемыеПозиции.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатуры.Валюта КАК Валюта,
	|	ЦеныНоменклатуры.Период КАК ПериодУстановкиЦены,
	|	ЦеныНоменклатуры.Цена КАК Цена
	|ПОМЕСТИТЬ МатрицаЦенообразования
	|ИЗ
	|	ЗаполняемыеПозиции КАК ЗаполняемыеПозиции
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
	|		ПО ЗаполняемыеПозиции.Номенклатура = ЦеныНоменклатуры.Номенклатура
	|			И (ЦеныНоменклатуры.ТипЦен = &ТипЦен)
	|			И ЗаполняемыеПозиции.ПериодСтрокиИсточника >= ЦеныНоменклатуры.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МатрицаЦенообразования.ПериодСтрокиИсточника КАК ПериодСтрокиИсточника,
	|	МатрицаЦенообразования.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(МатрицаЦенообразования.ПериодУстановкиЦены) КАК ПериодПоследнейУстановкиЦены
	|ПОМЕСТИТЬ ДатыПоследнихУстановокЦен
	|ИЗ
	|	МатрицаЦенообразования КАК МатрицаЦенообразования
	|
	|СГРУППИРОВАТЬ ПО
	|	МатрицаЦенообразования.ПериодСтрокиИсточника,
	|	МатрицаЦенообразования.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДатыПоследнихУстановокЦен.ПериодСтрокиИсточника КАК ПериодСтрокиИсточника,
	|	ДатыПоследнихУстановокЦен.Номенклатура КАК Номенклатура,
	|	МатрицаЦенообразования.Валюта КАК Валюта,
	|	МатрицаЦенообразования.Цена КАК Цена
	|ПОМЕСТИТЬ АктуальныеЦеныНаДаты
	|ИЗ
	|	ДатыПоследнихУстановокЦен КАК ДатыПоследнихУстановокЦен
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МатрицаЦенообразования КАК МатрицаЦенообразования
	|		ПО ДатыПоследнихУстановокЦен.Номенклатура = МатрицаЦенообразования.Номенклатура
	|			И ДатыПоследнихУстановокЦен.ПериодСтрокиИсточника = МатрицаЦенообразования.ПериодСтрокиИсточника
	|			И ДатыПоследнихУстановокЦен.ПериодПоследнейУстановкиЦены = МатрицаЦенообразования.ПериодУстановкиЦены
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	ПериодСтрокиИсточника
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ МатрицаЦенообразования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ДатыПоследнихУстановокЦен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаполняемыеПозиции.НомерСтроки КАК НомерСтроки,
	|	АктуальныеЦеныНаДаты.Цена * ВЫБОР
	|		КОГДА АктуальныеЦеныНаДаты.Валюта = &ВалютаДокумента
	|			ТОГДА 1
	|		КОГДА КурсыВалют.Валюта ЕСТЬ NULL
	|				ИЛИ &КурсДокумента = 0
	|				ИЛИ &КратностьДокумента = 0
	|				ИЛИ КурсыВалют.Курс = 0
	|				ИЛИ КурсыВалют.Кратность = 0
	|			ТОГДА 0
	|		ИНАЧЕ КурсыВалют.Курс * &КратностьДокумента / (&КурсДокумента * КурсыВалют.Кратность)
	|	КОНЕЦ КАК Цена
	|ПОМЕСТИТЬ ЦеныСтрокИсточника
	|ИЗ
	|	АктуальныеЦеныНаДаты КАК АктуальныеЦеныНаДаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗаполняемыеПозиции КАК ЗаполняемыеПозиции
	|		ПО АктуальныеЦеныНаДаты.Номенклатура = ЗаполняемыеПозиции.Номенклатура
	|			И АктуальныеЦеныНаДаты.ПериодСтрокиИсточника = ЗаполняемыеПозиции.ПериодСтрокиИсточника
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&ДатаДокумента, ) КАК КурсыВалют
	|		ПО АктуальныеЦеныНаДаты.Валюта = КурсыВалют.Валюта
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ АктуальныеЦеныНаДаты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ЗаполняемыеПозиции";
	
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов() + "	ВЫБРАТЬ";
	Для каждого ДопПоле Из ДополнительныеПоля Цикл
		ТекстЗапроса = ТекстЗапроса + Символы.ПС + СтрШаблон(ШаблонВыбораПоля, ДопПоле);
	КонецЦикла;
	ТекстЗапроса = ТекстЗапроса + "
	|	ТаблицаДанных.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДанных.ПериодСтрокиИсточника КАК Период,
	|	ТаблицаДанных.Номенклатура КАК " + ПараметрыРасчетаЦен.АналитикаНоменклатуры + ",
	|	ТаблицаДанных.СтатьяОборотов КАК СтатьяОборотов,
	|	ВЫБОР
	|		КОГДА ЦеныСтрокИсточника.НомерСтроки ЕСТЬ NULL
	|			ИЛИ ЦеныСтрокИсточника.Цена = 0
	|			ТОГДА ТаблицаДанных.Сумма
	|		ИНАЧЕ ЦеныСтрокИсточника.Цена * ТаблицаДанных.Количество
	|	КОНЕЦ КАК Сумма,
	|	ВЫБОР
	|		КОГДА ЦеныСтрокИсточника.НомерСтроки ЕСТЬ NULL
	|			ТОГДА ТаблицаДанных.Норма
	|		ИНАЧЕ ЦеныСтрокИсточника.Цена
	|	КОНЕЦ КАК Норма
	|ИЗ
	|	ТаблицаДанных КАК ТаблицаДанных
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦеныСтрокИсточника КАК ЦеныСтрокИсточника
	|		ПО ТаблицаДанных.НомерСтроки = ЦеныСтрокИсточника.НомерСтроки
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	Если бит_ОбщегоНазначенияПовтИсп.ЭтоСемействоERP() Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ЦеныНоменклатуры.ТипЦен", "ЦеныНоменклатуры.ВидЦены");
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ТипЦен"            , ПараметрыРасчетаЦен.ТипЦен);
	Запрос.УстановитьПараметр("ТолькоНулевыеСуммы", ПараметрыРасчетаЦен.ТолькоНулевыеСуммы);
	Запрос.УстановитьПараметр("ВалютаДокумента"   , ПараметрыРасчетаЦен.СтруктураКурсаДокумента.Валюта);
	Запрос.УстановитьПараметр("КурсДокумента"     , ПараметрыРасчетаЦен.СтруктураКурсаДокумента.Курс);
	Запрос.УстановитьПараметр("КратностьДокумента", ПараметрыРасчетаЦен.СтруктураКурсаДокумента.Кратность);
	Запрос.УстановитьПараметр("ДатаДокумента"     , ПараметрыРасчетаЦен.ДатаДокумента);
	
	ТаблицаДанных = Запрос.Выполнить().Выгрузить();
	
КонецПроцедуры

Процедура ИнициализироватьКлючиАналитик(Запрос)

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИсхожныеДанные.Сценарий КАК Сценарий,
	|	ИсхожныеДанные.ЦФО КАК ЦФО
	|ПОМЕСТИТЬ УникальныеКомбинации
	|ИЗ
	|	ИсхожныеДанные КАК ИсхожныеДанные
	|
	|СГРУППИРОВАТЬ ПО
	|	ИсхожныеДанные.Сценарий,
	|	ИсхожныеДанные.ЦФО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УникальныеКомбинации.Сценарий КАК Сценарий,
	|	УникальныеКомбинации.ЦФО КАК ЦФО,
	|	КлючиАналитик.КлючАналитики КАК КлючАналитики
	|ИЗ
	|	УникальныеКомбинации КАК УникальныеКомбинации
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_АналитикаСценарийЦФО КАК КлючиАналитик
	|		ПО УникальныеКомбинации.Сценарий = КлючиАналитик.Сценарий
	|			И УникальныеКомбинации.ЦФО = КлючиАналитик.ЦФО
	|ГДЕ
	|	КлючиАналитик.КлючАналитики ЕСТЬ NULL";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка 		 = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Справочники.бит_КлючиСценарийЦФО.КлючиСценарийЦФОДокумента(Выборка);
	КонецЦикла;
	
КонецПроцедуры

// Формирует и устанавливает формулу для вычисления итогов по колонкам периодов.
// 
// Параметры:
//  Расшифровка - Структура
//  ИмяЯчейки - Строка
//  Аргументы - Массив.
// 
Функция УстановитьФормулуИтоговПоПериодам(Расшифровка,ТекОписание,Аргументы) 
	
	СтрФормула = "";
	СтрокиФормулы = Новый Массив(); 
	Арг = Новый Массив;
	
	флЭтоОбщийИтог = Найти(ТекОписание.ИмяСумма, "Итог") > 0 ИЛИ Найти(ТекОписание.ИмяКоличество, "Итог") > 0;
	СтрНачПериода = Формат(ТекОписание.Период, "ДФ=yyyyMMdd");
	СтрКонПериода = Формат(ТекОписание.КонецПериода, "ДФ=yyyyMMdd");
	
	Для каждого ИмяАрг Из Аргументы Цикл
		СтрПериод = Сред(ИмяАрг,4,8);
		Если флЭтоОбщийИтог Тогда
			флДобавлять = Истина;
		ИначеЕсли ТекОписание.ЭтоНарастающийИтог Тогда
			флДобавлять = СтрПериод < СтрКонПериода;
		Иначе	
			// BF-1692 Изменение кода. Начало. 28.11.2017{{
			флДобавлять = СтрПериод >= СтрНачПериода И СтрПериод <= СтрКонПериода; 
			// Изменение кода. Конец. 28.11.2017}}
		КонецЕсли; 
		
		Если флДобавлять Тогда
			СтрокиФормулы.Добавить("["+ИмяАрг+"]");	
			Арг.Добавить(ИмяАрг);
		КонецЕсли; 
		
	КонецЦикла; // Аргументы.
	СтрФормула = СтрСоединить(СтрокиФормулы, " + ");
	
	
	Расшифровка.Формула = СтрФормула;
	Расшифровка.Аргументы = Арг;
	
КонецФункции

Функция ФиксироватьБюджет()
	
	Если НЕ ПолучитьФункциональнуюОпцию("бит_ИспользоватьФиксациюБюджета") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	РазрешеноИзменятьЗафиксированныйБюджет = бит_ПраваДоступа.ПолучитьЗначениеДопПраваПользователя(
												Пользователи.ТекущийПользователь(), 
												ПланыВидовХарактеристик.бит_ДополнительныеПраваПользователей.РазрешеноИзменятьЗафиксированныйБюджет);
	Если РазрешеноИзменятьЗафиксированныйБюджет = Истина Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти