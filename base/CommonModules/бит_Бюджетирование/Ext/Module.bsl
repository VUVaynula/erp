// Функция получает периодичность сценария. Если значение периодичности не удалось 
// определить возвращается периодичность МЕСЯЦ.
// 
// Параметры:
//  Сценарий  - СправочникСсылка.СценарииПланирования.
// 
// Возвращаемое значение:
//   Периодичность   - СправочникСсылка.бит_ПериодичностьПланирования.
// 
Функция ПолучитьПериодичностьСценария(Сценарий) Экспорт
	
	Перем Периодичность;
	
	Если ЗначениеЗаполнено(Сценарий) Тогда
		Периодичность = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сценарий, "бит_Периодичность");
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Периодичность) Тогда
		Периодичность = Перечисления.бит_ПериодичностьПланирования.Месяц;
	КонецЕсли; 
	
	Возврат Периодичность;
	
КонецФункции

// Предназначена для получения конструкции языка запросов по значению перечисления.
// Необходимо использовать в условия применения локализации конфигурации.
//
// Параметры:
//  Периодичность	 - ПеречислениеСсылка.бит_ПериодичностьПланирования	 - значение периодичности.
// 
// Возвращаемое значение:
// 	Разворот - строка. См. синтакс-помощник "Конструкция языка запросов".  
//
Функция ПериодДляРазворотаТаблицыЗапроса(Периодичность) Экспорт

	Разворот = "Период";
	Если Периодичность  = Перечисления.бит_ПериодичностьПланирования.День Тогда
		Разворот = "День";
	ИначеЕсли Периодичность  = Перечисления.бит_ПериодичностьПланирования.Неделя Тогда
		Разворот = "Неделя";
	ИначеЕсли Периодичность  = Перечисления.бит_ПериодичностьПланирования.Декада Тогда
		Разворот = "Декада";
	ИначеЕсли Периодичность  = Перечисления.бит_ПериодичностьПланирования.Месяц Тогда
		Разворот = "Месяц";
	ИначеЕсли Периодичность  = Перечисления.бит_ПериодичностьПланирования.Квартал Тогда
		Разворот = "Квартал";
	ИначеЕсли Периодичность  = Перечисления.бит_ПериодичностьПланирования.Полугодие Тогда
		Разворот = "Полугодие";
	ИначеЕсли Периодичность  = Перечисления.бит_ПериодичностьПланирования.Год Тогда
		Разворот = "Год";
	КонецЕсли; 

	Возврат Разворот;
	
КонецФункции

Процедура ПроверитьОбязательныеРазрезыСтатейОборотов(Объект, ИмяТаблицы, Отказ, Измерения=Неопределено, НастройкиИзмерений=Неопределено) Экспорт
	
	Если Измерения = Неопределено Тогда
		Измерения = ПолучитьИзмеренияБюджетирования("Произвольные", "Синоним");
	КонецЕсли;
	
	Если НастройкиИзмерений = Неопределено Тогда
		НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	КонецЕсли;
	
	МетаОбъект	 = Объект.Метаданные();
	МетаТабЧасть = МетаОбъект.ТабличныеЧасти[ИмяТаблицы]; 
	ПредставлениеТабЧасти = МетаТабЧасть.Представление();
	
	МетаСтатьи = Метаданные.Справочники.бит_СтатьиОборотов;
	
	СтруктураОбязательныхРазрезов = Новый Структура;
	
	ИменаРеквизитов = Новый Массив;
	Для каждого ТекИзмерение Из Измерения Цикл
		ИмяРеквизита = "Обязательный_" + ТекИзмерение.Ключ;
		
		Если НЕ бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, МетаСтатьи)
			ИЛИ НЕ бит_РаботаСМетаданными.ЕстьРеквизитТабЧасти(ТекИзмерение.Ключ, МетаОбъект, ИмяТаблицы) Тогда
			Продолжить;
		КонецЕсли;
		
		СвойстваИзмерения = НастройкиИзмерений[ТекИзмерение.Ключ];
		Если СвойстваИзмерения = Неопределено Тогда
			СинонимРеквизита = ТекИзмерение.Значение;
		Иначе	
			СинонимРеквизита = СвойстваИзмерения.Синоним;
		КонецЕсли;
		
		СтруктураОбязательныхРазрезов.Вставить(ТекИзмерение.Ключ, СинонимРеквизита);
		ИменаРеквизитов.Добавить("Учет_" + ТекИзмерение.Ключ);
		ИменаРеквизитов.Добавить(ИмяРеквизита);
	КонецЦикла;
	
	ДанныеСтатей = Новый Соответствие;
	Для каждого ТекСтрока Из Объект[ИмяТаблицы] Цикл
		
		СтатьяОборотов = ТекСтрока.СтатьяОборотов;
		Если ЗначениеЗаполнено(СтатьяОборотов) Тогда
			ДанныеСтатьи = ДанныеСтатей.Получить(СтатьяОборотов);
			Если ДанныеСтатьи = Неопределено Тогда
				ДанныеСтатьи = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтатьяОборотов, ИменаРеквизитов);
				ДанныеСтатей.Вставить(СтатьяОборотов, ДанныеСтатьи);
			КонецЕсли;
			
			Для каждого КлючЗначение Из СтруктураОбязательныхРазрезов Цикл
				Если ДанныеСтатьи["Учет_"+КлючЗначение.Ключ]
					И ДанныеСтатьи["Обязательный_"+КлючЗначение.Ключ]
					И НЕ ЗначениеЗаполнено(ТекСтрока[КлючЗначение.Ключ]) Тогда
														
					ИндексСтроки   = Формат(ТекСтрока.НомерСтроки - 1, "ЧДЦ=0; ЧН=0; ЧГ=");
					Поле		   = ИмяТаблицы + "[" + ИндексСтроки + "]." + КлючЗначение.Ключ;
					ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА", ,КлючЗначение.Значение,
										ТекСтрока.НомерСтроки, ПредставлениеТабЧасти);
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Объект, Поле, ,Отказ); 
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьКлючиАналитикВНаборе(НаборДанных) Экспорт

	Если НЕ ЗначениеЗаполнено(НаборДанных) Тогда
		Возврат;	
	КонецЕсли;
	
	Таблица = Новый ТаблицаЗначений; 
	Таблица.Колонки.Добавить("ИндексВНаборе", ОбщегоНазначения.ОписаниеТипаЧисло(5));
	Таблица.Колонки.Добавить("Сценарий", 	  Новый ОписаниеТипов("СправочникСсылка.СценарииПланирования"));
	Таблица.Колонки.Добавить("ЦФО",			  Новый ОписаниеТипов("СправочникСсылка.Подразделения"));

	Индекс = 0;
	Для каждого Запись Из НаборДанных Цикл
		Если НЕ ЗначениеЗаполнено(Запись.КлючСценарийЦФО) Тогда
			НоваяСтрока = Таблица.Добавить();	
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Запись);
			НоваяСтрока.ИндексВНаборе = Индекс;
		КонецЕсли;
		Индекс = Индекс + 1;
	КонецЦикла; 
	
	Если НЕ ЗначениеЗаполнено(Таблица) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Таблица", Таблица);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.ИндексВНаборе КАК ИндексВНаборе,
	|	Таблица.Сценарий КАК Сценарий,
	|	Таблица.ЦФО КАК ЦФО
	|ПОМЕСТИТЬ ИсхожныеДанные
	|ИЗ
	|	&Таблица КАК Таблица;";
	
	Запрос.Выполнить();
	ИнициализироватьКлючиАналитик(Запрос);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИсхожныеДанные.Сценарий КАК Сценарий,
	|	ИсхожныеДанные.ЦФО КАК ЦФО,
	|	КлючиАналитик.КлючАналитики КАК КлючСценарийЦФО,
	|	ИсхожныеДанные.ИндексВНаборе КАК ИндексВНаборе
	|ИЗ
	|	ИсхожныеДанные КАК ИсхожныеДанные
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_АналитикаСценарийЦФО КАК КлючиАналитик
	|		ПО ИсхожныеДанные.Сценарий = КлючиАналитик.Сценарий
	|			И ИсхожныеДанные.ЦФО = КлючиАналитик.ЦФО";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка			 = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Запись = НаборДанных.Получить(Выборка.ИндексВНаборе);
		Запись.КлючСценарийЦФО = Выборка.КлючСценарийЦФО;
	КонецЦикла;

КонецПроцедуры

Функция СтатьиБезИтогов(Бюджет) Экспорт
	
	Результат = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Бюджет);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Таблица.Ссылка КАК Ссылка,
	|	Таблица.СтатьяОборотов КАК СтатьяОборотов
	|ИЗ
	|	Справочник.бит_СтатьиБюджета КАК Таблица
	|ГДЕ
	|	НЕ Таблица.ЭтоГруппа
	|	И Таблица.НеВключатьВИтоги
	|	И Таблица.Владелец = &Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.Ссылка, Выборка.СтатьяОборотов);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ЗависимыеОбороты

Процедура ИнициализироватьИсточникЗависимыхОборотов(Запрос, ПараметыЗаполнения)
	
	ТаблицаИсточник  = ПараметыЗаполнения.ТаблицаИсточник;
	РазделительПолей = "," + Символы.ПС + Символы.Таб;
	
	Запрос.УстановитьПараметр("ТаблицаИсточник", ТаблицаИсточник);
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	&ИменаКолонокИсточника
	|ПОМЕСТИТЬ ТаблицаИсточник
	|ИЗ &ТаблицаИсточник КАК ТаблицаИсточник";
	
	ПутиКДаннымКолонок      = Новый Массив;
	ТекстВыборкиКолонок     = "";
	ШаблонПутиКДанным       = "ТаблицаИсточник.%1 КАК %1";
	КолонкиТаблицыИсточника = ТаблицаИсточник.Колонки;
	Для каждого Колонка Из КолонкиТаблицыИсточника Цикл
		ПутиКДаннымКолонок.Добавить(СтрШаблон(ШаблонПутиКДанным, Колонка.Имя));
	КонецЦикла;
	Если КолонкиТаблицыИсточника.Найти("Сценарий") = Неопределено
		И ПараметыЗаполнения.Сценарий <> Неопределено Тогда
		ПутиКДаннымКолонок.Добавить("&Сценарий КАК Сценарий");
		Запрос.УстановитьПараметр("Сценарий", ПараметыЗаполнения.Сценарий);
	КонецЕсли;
	ТекстВыборкиКолонок = СтрСоединить(ПутиКДаннымКолонок, РазделительПолей); 
	Если ПараметыЗаполнения.ЕдиницаИзмеренияСумм <> Перечисления.бит_ЕдиницыИзмеренияСумм.Единицы Тогда
		ТекстВыборкиКолонок = СтрЗаменить(ТекстВыборкиКолонок,
										"ТаблицаИсточник.Сумма",
										"(ТаблицаИсточник.Сумма * &РазмерностьЕдиницы)");
		РазмерностьЕдиницы  = бит_ОбщегоНазначения.ПолучитьРазмерностьЕдиницыИзмеренияСумм(
								ПараметыЗаполнения.ЕдиницаИзмеренияСумм);
		Запрос.УстановитьПараметр("РазмерностьЕдиницы", РазмерностьЕдиницы);
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "&ИменаКолонокИсточника", ТекстВыборкиКолонок);
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура ИнициализироватьНастройкиЗависимыхОборотов(Запрос, ПараметыЗаполнения)
	
	ТекстЗапроса = ТекстЗапросаМатрицаЗависимыхОборотов(ПараметыЗаполнения);
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	ТекстЗапроса = ТекстЗапроса + ТекстЗапросаСрезПоследнихЗависимыхОборотов(ПараметыЗаполнения); 
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("СценарийЗависимый", ПараметыЗаполнения.СценарийЗависимый);
	Запрос.Выполнить();
	
КонецПроцедуры

Функция ТекстЗапросаМатрицаЗависимыхОборотов(ПараметыЗаполнения)
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаИсточник.НомерСтроки КАК НомерСтрокиИсточника,
	|	ЗависимыеОбороты.Период КАК Период,
	|	ЗависимыеОбороты.Сценарий КАК Сценарий,
	|	&ИзмеренияЗависимыхОборотов КАК ИзмеренияЗависимыхОборотов,
	|	ЗависимыеОбороты.ПрофильРаспределения КАК ПрофильРаспределения,
	|	ЗависимыеОбороты.КоэффициентКоличество КАК КоэффициентКоличество,
	|	ЗависимыеОбороты.КоэффициентСумма КАК КоэффициентСумма,
	|	ЗависимыеОбороты.РеквизитКоличество КАК РеквизитКоличество,
	|	ЗависимыеОбороты.РеквизитСумма КАК РеквизитСумма,
	|	ЗависимыеОбороты.ФункцияКоличество КАК ФункцияКоличество,
	|	ЗависимыеОбороты.ФункцияСумма КАК ФункцияСумма,
	|	ЗависимыеОбороты.Регистратор КАК Регистратор,
	|	ЗависимыеОбороты.НомерСтроки КАК НомерСтроки,
	|	&Приоритет КАК Приоритет
	|ПОМЕСТИТЬ МатрицаЗависимыхОборотов
	|ИЗ
	|	ТаблицаИсточник КАК ТаблицаИсточник
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_ЗависимыеОбороты КАК ЗависимыеОбороты
	|		ПО ЗависимыеОбороты.СценарийЗависимый = &СценарийЗависимый
	|			И ТаблицаИсточник.Период >= ЗависимыеОбороты.Период
	|			И (ЗависимыеОбороты.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ ЗависимыеОбороты.ДатаОкончания >= ТаблицаИсточник.Период)
	|			И (ЗависимыеОбороты.КоэффициентКоличество <> 0
	|				ИЛИ ЗависимыеОбороты.ФункцияКоличество <> ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеФункции.ПустаяСсылка)
	|				ИЛИ ЗависимыеОбороты.КоэффициентСумма <> 0
	|				ИЛИ ЗависимыеОбороты.ФункцияСумма <> ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеФункции.ПустаяСсылка))
	|			И (ЗависимыеОбороты.РеквизитКоличество <> ЗНАЧЕНИЕ(Перечисление.бит_РеквизитыДляРасчетаЗависимостей.ПустаяСсылка)
	|				ИЛИ ЗависимыеОбороты.РеквизитСумма <> ЗНАЧЕНИЕ(Перечисление.бит_РеквизитыДляРасчетаЗависимостей.ПустаяСсылка))
	|			И (ТаблицаИсточник.Сценарий = ЗависимыеОбороты.Сценарий
	|				ИЛИ ЗависимыеОбороты.Сценарий = ЗНАЧЕНИЕ(Справочник.СценарииПланирования.ПустаяСсылка))
	|			И (&УсловиеПолейСоединения)";
	
	ТекстВыборкиПолейСоединения = "";
	ШаблонВыборки               = "ЗависимыеОбороты.%1 КАК %1,
								|	ЗависимыеОбороты.%1_Зависимый КАК %1_Зависимый,";
	ТекстУсловияСоединения      = "";
	ШаблонУсловия               = "			И (ТаблицаИсточник.%1 = ЗависимыеОбороты.%1
								|				ИЛИ ЗависимыеОбороты.%1 = %2)";
	ТекстРасчетаПриоритета = "";
	ШаблонПриоритета       = "ВЫБОР
							|		КОГДА ЗависимыеОбороты.%1 = %2
							|			ТОГДА 0
							|		ИНАЧЕ 1
							|	КОНЕЦ";
	Для каждого ПолеСоединения Из ПараметыЗаполнения.ПоляСоединений Цикл
		ИмяПоля       = ПолеСоединения.Ключ;
		ПустоЗначение = ПолеСоединения.Значение;
		Если НЕ ПустаяСтрока(ТекстВыборкиПолейСоединения) Тогда
			ТекстВыборкиПолейСоединения = ТекстВыборкиПолейСоединения + "
											|	";
		КонецЕсли;
		Если НЕ ПустаяСтрока(ТекстРасчетаПриоритета) Тогда
			ТекстРасчетаПриоритета = ТекстРасчетаПриоритета + " +
											|	";
		КонецЕсли;
		ТекстВыборкиПолейСоединения = ТекстВыборкиПолейСоединения + СтрШаблон(ШаблонВыборки, ИмяПоля);
		ТекстУсловияСоединения = ТекстУсловияСоединения + Символы.ПС + СтрШаблон(ШаблонУсловия, ИмяПоля, ПустоЗначение);
		ТекстРасчетаПриоритета = ТекстРасчетаПриоритета + СтрШаблон(ШаблонПриоритета, ИмяПоля, ПустоЗначение);
	КонецЦикла;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
								"&ИзмеренияЗависимыхОборотов КАК ИзмеренияЗависимыхОборотов,",
								ТекстВыборкиПолейСоединения);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И (&УсловиеПолейСоединения)", ТекстУсловияСоединения);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Приоритет", ТекстРасчетаПриоритета);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаСрезПоследнихЗависимыхОборотов(ПараметыЗаполнения)
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	МатрицаЗависимыхОборотов.НомерСтрокиИсточника КАК НомерСтрокиИсточника,
	|	МатрицаЗависимыхОборотов.Сценарий КАК Сценарий,
	|	&ИзмеренияЗависимыхОборотов КАК ИзмеренияЗависимыхОборотов,
	|	МатрицаЗависимыхОборотов.Приоритет КАК Приоритет,
	|	МАКСИМУМ(МатрицаЗависимыхОборотов.Период) КАК МаксимальныйПериод
	|ПОМЕСТИТЬ ПоследниеПериоды
	|ИЗ
	|	МатрицаЗависимыхОборотов КАК МатрицаЗависимыхОборотов
	|
	|СГРУППИРОВАТЬ ПО
	|	МатрицаЗависимыхОборотов.НомерСтрокиИсточника,
	|	МатрицаЗависимыхОборотов.Сценарий,
	// При использовании конструктура данная группировка удалится, нужно будет вернуть руками.
	|	&ГруппировкаИзмеренийЗависимыхОборотов,
	|	МатрицаЗависимыхОборотов.Приоритет";
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
	ТекстЗапроса = ТекстЗапроса +
	"ВЫБРАТЬ
	|	МатрицаЗависимыхОборотов.НомерСтрокиИсточника КАК НомерСтрокиИсточника,
	|	МатрицаЗависимыхОборотов.Сценарий КАК Сценарий,
	|	&ИзмеренияЗависимыхОборотов КАК ИзмеренияЗависимыхОборотов,
	|	МатрицаЗависимыхОборотов.ПрофильРаспределения КАК ПрофильРаспределения,
	|	МатрицаЗависимыхОборотов.КоэффициентКоличество КАК КоэффициентКоличество,
	|	МатрицаЗависимыхОборотов.КоэффициентСумма КАК КоэффициентСумма,
	|	МатрицаЗависимыхОборотов.РеквизитКоличество КАК РеквизитКоличество,
	|	МатрицаЗависимыхОборотов.РеквизитСумма КАК РеквизитСумма,
	|	МатрицаЗависимыхОборотов.ФункцияКоличество КАК ФункцияКоличество,
	|	МатрицаЗависимыхОборотов.ФункцияСумма КАК ФункцияСумма,
	|	МатрицаЗависимыхОборотов.Регистратор КАК Регистратор,
	|	МатрицаЗависимыхОборотов.НомерСтроки КАК НомерСтроки,
	|	МатрицаЗависимыхОборотов.Приоритет КАК Приоритет
	|ПОМЕСТИТЬ ЗависимыеОборотыСрезПоследних
	|ИЗ
	|	МатрицаЗависимыхОборотов КАК МатрицаЗависимыхОборотов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоследниеПериоды КАК ПоследниеПериоды
	|		ПО МатрицаЗависимыхОборотов.НомерСтрокиИсточника = ПоследниеПериоды.НомерСтрокиИсточника
	|			И МатрицаЗависимыхОборотов.Период = ПоследниеПериоды.МаксимальныйПериод
	|			И МатрицаЗависимыхОборотов.Сценарий = ПоследниеПериоды.Сценарий
	|			И МатрицаЗависимыхОборотов.Приоритет = ПоследниеПериоды.Приоритет
	|			И (&УсловиеСоединенияСрезПоследних)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ МатрицаЗависимыхОборотов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ПоследниеПериоды
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗависимыеОборотыСрезПоследних.НомерСтрокиИсточника КАК НомерСтрокиИсточника,
	|	МАКСИМУМ(ЗависимыеОборотыСрезПоследних.Приоритет) КАК МаксимальныйПриоритет
	|ПОМЕСТИТЬ ПриоритетныеНастройкиЗависимыхОборотов
	|ИЗ
	|	ЗависимыеОборотыСрезПоследних КАК ЗависимыеОборотыСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗависимыеОборотыСрезПоследних.НомерСтрокиИсточника
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МатрицаЗависимыхОборотов.НомерСтрокиИсточника КАК НомерСтрокиИсточника,
	|	МатрицаЗависимыхОборотов.Сценарий КАК Сценарий,
	|	&ИзмеренияЗависимыхОборотов КАК ИзмеренияЗависимыхОборотов,
	|	МатрицаЗависимыхОборотов.ПрофильРаспределения КАК ПрофильРаспределения,
	|	МатрицаЗависимыхОборотов.КоэффициентКоличество КАК КоэффициентКоличество,
	|	МатрицаЗависимыхОборотов.КоэффициентСумма КАК КоэффициентСумма,
	|	МатрицаЗависимыхОборотов.РеквизитКоличество КАК РеквизитКоличество,
	|	МатрицаЗависимыхОборотов.РеквизитСумма КАК РеквизитСумма,
	|	МатрицаЗависимыхОборотов.ФункцияКоличество КАК ФункцияКоличество,
	|	МатрицаЗависимыхОборотов.ФункцияСумма КАК ФункцияСумма,
	|	МатрицаЗависимыхОборотов.Регистратор КАК Регистратор,
	|	МатрицаЗависимыхОборотов.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ НастройкиЗависимыхОборотов
	|ИЗ
	|	ЗависимыеОборотыСрезПоследних КАК МатрицаЗависимыхОборотов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПриоритетныеНастройкиЗависимыхОборотов КАК ПриоритетныеНастройкиЗависимыхОборотов
	|		ПО МатрицаЗависимыхОборотов.НомерСтрокиИсточника = ПриоритетныеНастройкиЗависимыхОборотов.НомерСтрокиИсточника
	|			И МатрицаЗависимыхОборотов.Приоритет = ПриоритетныеНастройкиЗависимыхОборотов.МаксимальныйПриоритет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ЗависимыеОборотыСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ПриоритетныеНастройкиЗависимыхОборотов";
	
	ТекстВыборкиПолейСоединения = "";
	ШаблонВыборки               = "МатрицаЗависимыхОборотов.%1 КАК %1,
								|	МатрицаЗависимыхОборотов.%1_Зависимый КАК %1_Зависимый,";
	ТекстГруппировкиПолейСоединения = "";
	ШаблонГруппировки               = "МатрицаЗависимыхОборотов.%1,
									|	МатрицаЗависимыхОборотов.%1_Зависимый,";
	ТекстУсловияСоединения      = "";
	ШаблонУсловия               = "			И МатрицаЗависимыхОборотов.%1 = ПоследниеПериоды.%1
								|			И МатрицаЗависимыхОборотов.%1_Зависимый = ПоследниеПериоды.%1_Зависимый";
	Для каждого ПолеСоединения Из ПараметыЗаполнения.ПоляСоединений Цикл
		ИмяПоля       = ПолеСоединения.Ключ;
		ПустоЗначение = ПолеСоединения.Значение;
		Если НЕ ПустаяСтрока(ТекстВыборкиПолейСоединения) Тогда
			ТекстВыборкиПолейСоединения = ТекстВыборкиПолейСоединения + "
											|	";
		КонецЕсли;
		ТекстВыборкиПолейСоединения = ТекстВыборкиПолейСоединения + СтрШаблон(ШаблонВыборки, ИмяПоля);
		
		Если НЕ ПустаяСтрока(ТекстГруппировкиПолейСоединения) Тогда
			ТекстГруппировкиПолейСоединения = ТекстГруппировкиПолейСоединения + "
											|	";
		КонецЕсли;
		ТекстГруппировкиПолейСоединения = ТекстГруппировкиПолейСоединения + СтрШаблон(ШаблонГруппировки, ИмяПоля);
		
		Если НЕ ПустаяСтрока(ТекстУсловияСоединения) Тогда
			ТекстУсловияСоединения = ТекстУсловияСоединения + Символы.ПС;
		КонецЕсли;
		ТекстУсловияСоединения = ТекстУсловияСоединения + СтрШаблон(ШаблонУсловия, ИмяПоля);
	КонецЦикла;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
								"&ИзмеренияЗависимыхОборотов КАК ИзмеренияЗависимыхОборотов,",
								ТекстВыборкиПолейСоединения);
								
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
								"&ГруппировкаИзмеренийЗависимыхОборотов,",
								ТекстГруппировкиПолейСоединения);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И (&УсловиеСоединенияСрезПоследних)", ТекстУсловияСоединения);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция НастройкиЗависимыхОборотов(Запрос, ПараметыЗаполнения)
	
	КолонкиИсточника = ПараметыЗаполнения.ТаблицаИсточник.Колонки;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	НастройкиЗависимыхОборотов.НомерСтрокиИсточника КАК НомерСтрокиИсточника,
	|	ВЫБОР
	|		КОГДА &СценарийЗависимый = ЗНАЧЕНИЕ(Справочник.СценарииПланирования.ПустаяСсылка)
	|			ТОГДА ТаблицаИсточник.Сценарий
	|		ИНАЧЕ &СценарийЗависимый
	|	КОНЕЦ КАК Сценарий,
	|	&ПоляИсточника КАК ПоляИсточника,
	|	&ПоляИзмерений КАК ПоляИзмерений,
	|	НастройкиЗависимыхОборотов.ПрофильРаспределения КАК ПрофильРаспределения,
	|	НастройкиЗависимыхОборотов.КоэффициентКоличество КАК КоэффициентКоличество,
	|	НастройкиЗависимыхОборотов.КоэффициентСумма КАК КоэффициентСумма,
	|	НастройкиЗависимыхОборотов.РеквизитКоличество КАК РеквизитКоличество,
	|	НастройкиЗависимыхОборотов.РеквизитСумма КАК РеквизитСумма,
	|	НастройкиЗависимыхОборотов.ФункцияКоличество КАК ФункцияКоличество,
	|	НастройкиЗависимыхОборотов.ФункцияСумма КАК ФункцияСумма,
	|	НастройкиЗависимыхОборотов.Регистратор КАК Регистратор,
	|	НастройкиЗависимыхОборотов.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ЗависимыеОбороты
	|ИЗ
	|	ТаблицаИсточник КАК ТаблицаИсточник
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НастройкиЗависимыхОборотов КАК НастройкиЗависимыхОборотов
	|		ПО ТаблицаИсточник.НомерСтроки = НастройкиЗависимыхОборотов.НомерСтрокиИсточника
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ТаблицаИсточник
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ НастройкиЗависимыхОборотов";
	
	ПоляИсточника        = Новый Массив;
	ПереопределяемыеПоля = Новый СписокЗначений;
	ПереопределяемыеПоля.Добавить(ВРег("НомерСтроки"));
	ПереопределяемыеПоля.Добавить(ВРег("Регистратор"));
	ПереопределяемыеПоля.Добавить(ВРег("Сценарий"));
	ШаблонВыборкиИзмерений =
	"ВЫБОР
	|		КОГДА НастройкиЗависимыхОборотов.%1_Зависимый = %2
	|			ТОГДА ТаблицаИсточник.%1
	|		ИНАЧЕ НастройкиЗависимыхОборотов.%1_Зависимый
	|	КОНЕЦ КАК %1,
	|	НастройкиЗависимыхОборотов.%1_Зависимый КАК %1_Зависимый,";
	ТекстВыборкиИзмерений  = "";
	Для каждого ПолеСоединения Из ПараметыЗаполнения.ПоляСоединений Цикл
		ИмяПоля       = ПолеСоединения.Ключ;
		ПустоЗначение = ПолеСоединения.Значение;
		Если НЕ ПустаяСтрока(ТекстВыборкиИзмерений) Тогда
			ТекстВыборкиИзмерений = ТекстВыборкиИзмерений + Символы.ПС + Символы.Таб;
		КонецЕсли;
		ТекстВыборкиИзмерений = ТекстВыборкиИзмерений + СтрШаблон(ШаблонВыборкиИзмерений, ИмяПоля, ПустоЗначение);
		ПереопределяемыеПоля.Добавить(ВРег(ИмяПоля));
	КонецЦикла;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляИзмерений КАК ПоляИзмерений,", ТекстВыборкиИзмерений);
	
	ШаблонВыборкиПолейИсточника = "ТаблицаИсточник.%1 КАК %1,";
	ТекстВыборкиПолейИсточника  = "";
	Для каждого КолонкаИсточника Из КолонкиИсточника Цикл
		ИмяПоля = КолонкаИсточника.Имя;
		Если ПереопределяемыеПоля.НайтиПоЗначению(ВРег(ИмяПоля)) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ ПустаяСтрока(ТекстВыборкиПолейИсточника) Тогда
			ТекстВыборкиПолейИсточника = ТекстВыборкиПолейИсточника + Символы.ПС + Символы.Таб;
		КонецЕсли;
		ТекстВыборкиПолейИсточника = ТекстВыборкиПолейИсточника + СтрШаблон(ШаблонВыборкиПолейИсточника, ИмяПоля);
		ПоляИсточника.Добавить(ИмяПоля);
	КонецЦикла;
	Если КолонкиИсточника.Найти("ИД") <> Неопределено
		И КолонкиИсточника.Найти("ИД_Родитель") = Неопределено Тогда
		ТекстВыборкиПолейИсточника = ТекстВыборкиПолейИсточника + "
									|	ТаблицаИсточник.ИД КАК ИД_Родитель,";
		ПоляИсточника.Добавить("ИД_Родитель");
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляИсточника КАК ПоляИсточника,", ТекстВыборкиПолейИсточника);
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.Выполнить();
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ЗависимыеОбороты.Сценарий КАК Сценарий,
	|	ЗависимыеОбороты.Сценарий.бит_Периодичность КАК ПериодичностьСценария,
	|	&ПоляИсточника КАК ПоляИсточника,
	|	&ПоляИзмерений КАК ПоляИзмерений,
	|	ЗависимыеОбороты.ЦФО КАК ЦФО,
	|	ЗависимыеОбороты.СтатьяОборотов КАК СтатьяОборотов,
	|	ЗависимыеОбороты.ПрофильРаспределения КАК ПрофильРаспределения,
	|	ЗависимыеОбороты.КоэффициентКоличество КАК КоэффициентКоличество,
	|	ЗависимыеОбороты.КоэффициентСумма КАК КоэффициентСумма,
	|	ЗависимыеОбороты.РеквизитКоличество КАК РеквизитКоличество,
	|	ЗависимыеОбороты.РеквизитСумма КАК РеквизитСумма,
	|	ЗависимыеОбороты.ФункцияКоличество КАК ФункцияКоличество,
	|	ЗависимыеОбороты.ФункцияСумма КАК ФункцияСумма,
	|	ЗависимыеОбороты.Регистратор КАК Регистратор,
	|	ЗависимыеОбороты.НомерСтроки КАК НомерСтроки,
	|	ЗависимыеОбороты.НомерСтрокиИсточника КАК НомерСтрокиИсточника
	|ИЗ
	|	ЗависимыеОбороты КАК ЗависимыеОбороты
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЗависимыеОбороты.НомерСтрокиИсточника";
	
	ШаблонВыборкиПолейИсточника = "ЗависимыеОбороты.%1 КАК %1,";
	ТекстВыборкиПолейИсточника  = "";
	Для каждого ПолеИсточника Из ПоляИсточника Цикл
		Если НЕ ПустаяСтрока(ТекстВыборкиПолейИсточника) Тогда
			ТекстВыборкиПолейИсточника = ТекстВыборкиПолейИсточника + Символы.ПС + Символы.Таб;
		КонецЕсли;
		ТекстВыборкиПолейИсточника = ТекстВыборкиПолейИсточника + СтрШаблон(ШаблонВыборкиПолейИсточника, ПолеИсточника);
	КонецЦикла;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляИсточника КАК ПоляИсточника,", ТекстВыборкиПолейИсточника);
	
	ШаблонВыборкиИзмерений =
	"ВЫБОР
	|		КОГДА ЗависимыеОбороты.СтатьяОборотов.Учет_%1
	|			ТОГДА ЗависимыеОбороты.%1
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК %1,
	|	ЗависимыеОбороты.%1_Зависимый КАК %1_Зависимый";
	ТекстВыборкиИзмерений  = "";
	Для каждого ПолеСоединения Из ПараметыЗаполнения.ПоляСоединений Цикл
		ИмяПоля = ПолеСоединения.Ключ;
		Если СтрСравнить(ИмяПоля, "СтатьяОборотов") = 0
			ИЛИ СтрСравнить(ИмяПоля, "ЦФО") = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(ТекстВыборкиИзмерений) Тогда
			ТекстВыборкиИзмерений = ТекстВыборкиИзмерений + "," + Символы.ПС + Символы.Таб;
		КонецЕсли;
		ТекстВыборкиИзмерений = ТекстВыборкиИзмерений + СтрШаблон(ШаблонВыборкиИзмерений, ИмяПоля);
	КонецЦикла;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляИзмерений КАК ПоляИзмерений", ТекстВыборкиИзмерений);
	
	Запрос.Текст = ТекстЗапроса;
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

// Процедура выполняе формирование зависимых оборотов по строке оборотов. 
// Сформированные зависимые обороты записываются в ТаблицуЗначений. Рекурсивный вызов.
// 
// Параметры:
//  ДатаЗаполнения  - Дата.
//  СтрокаТабличнойЧасти - СтрокаТаблицыЗначений.
//  ТаблицаПриемник - ТаблицаЗначений.
//  ИзмеренияБюджетирования   - Структура.
//  СтрПар - Структура.
//  УровеньРекурсии - Число.
// 
Процедура СформироватьЗависимыеОборотыВТаблицу(ДатаЗаполнения, СтрокаТабличнойЧасти,
			КолонкиИсточник, ТаблицаПриемник, ИзмеренияБюджетирования, СтрПар = Неопределено, УровеньРекурсии = 0)

	// Защита от зацикливания
	Если УровеньРекурсии>1000 Тогда
		ТекстСообщения = НСтр("ru='Превышен уровень рекурсии. Проверьте настройки зависимых оборотов на зацикливание.';
		      				  |en='Exceeded the level of recursion. Check the settings dependent on the speed loop.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения); 
		Возврат;
	КонецЕсли; 
	УровеньРекурсии = УровеньРекурсии+1;
	
	КолонкиПриемник = ТаблицаПриемник.Колонки;
	// Получаем имя справочника Сценарии бюджетирования в зависимости от текущего решения.
	ИмяСправочникаСценарии = бит_ОбщегоНазначения.ПолучитьИмяСправочникаСценарииБюджетирования();
	
	Сценарий = Справочники[ИмяСправочникаСценарии].ПустаяСсылка();	
	Если ТипЗнч(СтрПар) = Тип("Структура") И СтрПар.Свойство("Сценарий") Тогда
		
		Сценарий = СтрПар.Сценарий;
		
	Иначе	
		
		Если бит_РаботаСКоллекциями.ЕстьКолонка("Сценарий", КолонкиИсточник) Тогда		
			Сценарий = СтрокаТабличнойЧасти.Сценарий;		
		КонецЕсли; 
		
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(Сценарий) Тогда	
		Возврат;	
	КонецЕсли;

	Периодичность = Сценарий.бит_Периодичность;
	
	// Получим структуру зависимых оборотов для данной строки таблицы оборотов.
	Результат = ВыполнитьЗапросДляФормированияЗависимыхОборотов(ДатаЗаполнения, Сценарий, ИзмеренияБюджетирования, СтрокаТабличнойЧасти);
	Если Результат.Пустой() Тогда	
		Возврат;	
	КонецЕсли; 
	
	НастройкиЗависимыхОборотов = Результат.Выгрузить();
	
	ПроверяемыеПоля = ПодготовитьПроверяемыеПоляЗавОборотов();	
	
	ТекущийПриоритет = 0;
	НастройкиЗависимыхОборотов.Колонки.Добавить("Приоритет", Новый ОписаниеТипов("Число"));
	Для каждого СтрокаНастройки Из НастройкиЗависимыхОборотов Цикл		
		ВычислитьПриоритетСтрокиЗависимыхОборотов(СтрокаТабличнойЧасти, СтрокаНастройки, ПроверяемыеПоля);		
	КонецЦикла; 
	
	НастройкиЗависимыхОборотов.Сортировать("Приоритет УБЫВ");
	ТекущийПриоритет = 0;
	
	Если НастройкиЗависимыхОборотов.Количество() > 0 Тогда	
		ТекущийПриоритет = НастройкиЗависимыхОборотов[0].Приоритет;	
	КонецЕсли;	
	
	// Заполним строки зависимых оборотов
	Для Каждого СтрокаНастройки Из НастройкиЗависимыхОборотов Цикл
		
		// Применяем только строки наивысшего приоритета, например, если совпадает Статья и Проект, 
		// то эта настройка имеет приоритет перед настройкой, когда совпадает только статья.		
		Если НЕ СтрокаНастройки.Приоритет = ТекущийПриоритет Тогда		 
			Продолжить;		 
		КонецЕсли; 		

		НоваяСтрока = ТаблицаПриемник.Добавить();
		Если бит_РаботаСКоллекциями.ЕстьКолонка("Сценарий", КолонкиПриемник) Тогда			 
			НоваяСтрока.Сценарий = Сценарий;			 
		КонецЕсли;  
		НоваяСтрока.Период = СтрокаТабличнойЧасти.Период;
		НоваяСтрока.Валюта = СтрокаТабличнойЧасти.Валюта;
		 
		Если бит_РаботаСКоллекциями.ЕстьКолонка("Измерение", КолонкиПриемник)
			ИЛИ бит_РаботаСКоллекциями.ЕстьКолонка("Измерение", КолонкиИсточник) Тогда		 
			НоваяСтрока.Измерение = СтрокаТабличнойЧасти.Измерение;		 
		КонецЕсли; 
		Если бит_РаботаСКоллекциями.ЕстьКолонка("ИД", КолонкиПриемник)
			ИЛИ бит_РаботаСКоллекциями.ЕстьКолонка("ИД", КолонкиИсточник) Тогда		 
			НоваяСтрока.ИД = СтрокаТабличнойЧасти.ИД;		 
		КонецЕсли; 
		Если бит_РаботаСКоллекциями.ЕстьКолонка("ИД_Родитель", КолонкиПриемник) 
			ИЛИ бит_РаботаСКоллекциями.ЕстьКолонка("ИД", КолонкиИсточник) Тогда		 
			НоваяСтрока.ИД_Родитель = СтрокаТабличнойЧасти.ИД;		 
		КонецЕсли; 
		 
		// Заполним измерения
		ЗависимыеОборотыЗаполнитьИзмерения(ИзмеренияБюджетирования, СтрокаНастройки, СтрокаТабличнойЧасти, НоваяСтрока);

		Если бит_РаботаСКоллекциями.ЕстьКолонка("ЭтоКоэффициент", КолонкиПриемник) Тогда		 
			НоваяСтрока.ЭтоКоэффициент = НоваяСтрока.СтатьяОборотов.ЭтоКоэффициент;		 
		КонецЕсли;		 
		 
		// Заполним показатели
		ЗависимыеОборотыВыполнитьРасчет(СтрокаНастройки, СтрокаТабличнойЧасти, НоваяСтрока);
		 
		Если ЗначениеЗаполнено(СтрокаНастройки.ПрофильРаспределения) Тогда
			МассивСтрок = РаспределитьПоПрофилю(СтрокаНастройки.ПрофильРаспределения,ТаблицаПриемник,НоваяСтрока,Периодичность);
			Для каждого СозданнаяСтрока Из МассивСтрок Цикл
				СформироватьЗависимыеОборотыВТаблицу(ДатаЗаполнения,
				СозданнаяСтрока, КолонкиИсточник, ТаблицаПриемник, ИзмеренияБюджетирования, СтрПар, УровеньРекурсии);
			КонецЦикла; 
		Иначе	

			СформироватьЗависимыеОборотыВТаблицу(ДатаЗаполнения,
			НоваяСтрока, КолонкиИсточник, ТаблицаПриемник, ИзмеренияБюджетирования, СтрПар, УровеньРекурсии);

		КонецЕсли; 

	КонецЦикла; // По выборке структуры зависимых оборотов
	
КонецПроцедуры

// Функция выполняет запрос для формирования зависимых оборотов.
// 
// Параметры:
//  ДатаЗаполнения 			- Дата - дата.
//  Сценарий 				- СправочникСсылка.бит_СценарииПланирования - сценарий.
//  ИзмеренияБюджетирования - Структура - измерения.
//  СтрокаТаблицы 			- СтрокаТабличнойЧасти - СтрокаТаблицыЗначений.
// 
// Возвращаемое значение:
//  РезультатЗапроса.
// 
Функция ВыполнитьЗапросДляФормированияЗависимыхОборотов(ДатаЗаполнения, Сценарий, ИзмеренияБюджетирования, СтрокаТаблицы)

	// Получаем имена справочников в зависимости от текущего решения.
	ИмяСправочникаСценарии = бит_ОбщегоНазначения.ПолучитьИмяСправочникаСценарииБюджетирования();
	ИмяСправочникаЦФО 	   = бит_ОбщегоНазначения.ПолучитьИмяСправочникаЦФО();
	ИмяСправочникаПроекты  = бит_ОбщегоНазначения.ПолучитьИмяСправочникаПроекты();
	
	ТекстПоля    = "";
	ТекстУсловия = "";
	
	ПустоеЗначение = Неопределено;
	
	СтруктураПустых = Новый Структура;
	СтруктураПустых.Вставить("Сценарий"		 	   , "ЗНАЧЕНИЕ(Справочник." + ИмяСправочникаСценарии + ".ПустаяСсылка)");	
	СтруктураПустых.Вставить("ЦФО"			 	   , "ЗНАЧЕНИЕ(Справочник." + ИмяСправочникаЦФО + ".ПустаяСсылка)");
	СтруктураПустых.Вставить("Проект"		 	   , "ЗНАЧЕНИЕ(Справочник." + ИмяСправочникаПроекты + ".ПустаяСсылка)");
	СтруктураПустых.Вставить("СтатьяОборотов"	   , "ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.ПустаяСсылка)");
	СтруктураПустых.Вставить("Контрагент"	 	   , "ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)");
	СтруктураПустых.Вставить("ДоговорКонтрагента"  , "ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)");
    // ++ ЕРП 
	СтруктураПустых.Вставить("НоменклатурнаяГруппа", "ЗНАЧЕНИЕ(Справочник.ГруппыФинансовогоУчетаНоменклатуры.ПустаяСсылка)");
    // -- ЕРП 
	СтруктураПустых.Вставить("БанковскийСчет"	   , "ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)");
	
	Для каждого ТекИзмерение Из Метаданные.РегистрыНакопления.бит_ОборотыПоБюджетам.Измерения Цикл		
		
		ИмяИзмерения = ТекИзмерение.Имя;
		Если ИмяИзмерения = "Валюта"
			ИЛИ ИмяИзмерения = "СценарийЗависимый" Тогда
			Продолжить;		
		КонецЕсли;
		
		// Поля запроса
		ТекстПоля = ТекстПоля + Символы.ПС + "	бит_ЗависимыеОборотыСрезПоследних." + ИмяИзмерения + ",";
		Если ИмяИзмерения <> "Сценарий" Тогда
			ТекстПоля = ТекстПоля + Символы.ПС + "	бит_ЗависимыеОборотыСрезПоследних." + ИмяИзмерения + "_Зависимый,";
		КонецЕсли;
				
		// Условия
		Если Не СтруктураПустых.Свойство(ИмяИзмерения, ПустоеЗначение) Тогда
			ПустоеЗначение = "НЕОПРЕДЕЛЕНО";			
		КонецЕсли;	
		ТекстУсловия = ТекстУсловия + Символы.ПС + ?(ТекстУсловия = "", "				", "				И") 
					   + " (" + ИмяИзмерения + " = &" + ИмяИзмерения + " ИЛИ " + ИмяИзмерения + " = " + ПустоеЗначение + ")";
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|" + ТекстПоля + "
	|	бит_ЗависимыеОборотыСрезПоследних.ПрофильРаспределения,
	|	бит_ЗависимыеОборотыСрезПоследних.КоэффициентКоличество,
	|	бит_ЗависимыеОборотыСрезПоследних.КоэффициентСумма,
	|	бит_ЗависимыеОборотыСрезПоследних.РеквизитКоличество,
	|	бит_ЗависимыеОборотыСрезПоследних.РеквизитСумма,
	|   бит_ЗависимыеОборотыСрезПоследних.ФункцияКоличество,
	|   бит_ЗависимыеОборотыСрезПоследних.ФункцияСумма,
	|   бит_ЗависимыеОборотыСрезПоследних.Регистратор,
	|   бит_ЗависимыеОборотыСрезПоследних.НомерСтроки,
	|	бит_ЗависимыеОборотыСрезПоследних.ДатаОкончания
	|ИЗ
	|	РегистрСведений.бит_ЗависимыеОбороты.СрезПоследних(
	|			&ДатаЗаполнения,
	|			СценарийЗависимый = ЗНАЧЕНИЕ(Справочник.СценарииПланирования.ПустаяСсылка)
	|			И " + ТекстУсловия + "
	|			) КАК бит_ЗависимыеОборотыСрезПоследних
	|ГДЕ
	|	(бит_ЗависимыеОборотыСрезПоследних.КоэффициентКоличество <> 0
	|			ИЛИ бит_ЗависимыеОборотыСрезПоследних.ФункцияКоличество <> ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеФункции.ПустаяСсылка)
	|			ИЛИ бит_ЗависимыеОборотыСрезПоследних.КоэффициентСумма <> 0
	|			ИЛИ бит_ЗависимыеОборотыСрезПоследних.ФункцияСумма <> ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеФункции.ПустаяСсылка))
	|	И (бит_ЗависимыеОборотыСрезПоследних.РеквизитКоличество <> ЗНАЧЕНИЕ(Перечисление.бит_РеквизитыДляРасчетаЗависимостей.ПустаяСсылка)
	|			ИЛИ бит_ЗависимыеОборотыСрезПоследних.РеквизитСумма <> ЗНАЧЕНИЕ(Перечисление.бит_РеквизитыДляРасчетаЗависимостей.ПустаяСсылка))
	|	И (КонецПериода(бит_ЗависимыеОборотыСрезПоследних.ДатаОкончания,День) >= &ДатаЗаполнения
	|					ИЛИ бит_ЗависимыеОборотыСрезПоследних.ДатаОкончания = &ПустаяДата)
	|";
	
	// Установка параметров запроса			             	
	Запрос.УстановитьПараметр("ПустаяДата"    , Дата('00010101'));
	Запрос.УстановитьПараметр("ДатаЗаполнения", ДатаЗаполнения);
	Запрос.УстановитьПараметр("Сценарий"      , Сценарий);
	
	Для каждого КлючИЗначение Из ИзмеренияБюджетирования Цикл
	
		ИмяИзмерения = КлючИЗначение.Ключ;
		Если ИмяИзмерения = "Сценарий" Тогда		
			Продолжить;		
		КонецЕсли; 
		
		Запрос.УстановитьПараметр(ИмяИзмерения,СтрокаТаблицы[ИмяИзмерения]);
		
	КонецЦикла; 
	
	Результат = Запрос.Выполнить();

	Возврат Результат;
	
КонецФункции

// Функция инициализирует структуру для хранения результатов расчета зависимых оборотов.
// 
// Возвращаемое значение:
//  СтрРасчет - Строка.
// 
Функция КонструкторСтруктураРасчетаРесурса()
	
	СтрРасчет    = Новый Структура("Функция,Коэффициент,ПрофильРаспределения,ИмяРесурса,ИмяРеквизита,Результат,Аргумент");
	
	Возврат СтрРасчет;
	
КонецФункции

// Функция выполняет расчет количества и суммы для зависимых оборотов.
// 
// Параметры:
//  Выборка - ВыборкаИзРезультатаЗапроса.
//  СтрокаТабличнойЧасти - СтрокаТабличнойЧасти, СтрокаТаблицыЗначений.
//  НоваяСтрока          - СтрокаТабличнойЧасти, НоваяСтрока.
//  КомментироватьРасчет - Булево.
// 
Функция ЗависимыеОборотыВыполнитьРасчет(Выборка, СтрокаТабличнойЧасти, НоваяСтрока, КомментироватьРасчет = Ложь, Сценарий = Неопределено)
	
	ПарамРасчета = Новый Структура;
	ПарамРасчета.Вставить("Количество",  КонструкторСтруктураРасчетаРесурса());
	ПарамРасчета.Вставить("Сумма",		 КонструкторСтруктураРасчетаРесурса());
	ПарамРасчета.Вставить("Регистратор", Выборка.Регистратор);
	ПарамРасчета.Вставить("НомерСтроки", Выборка.НомерСтроки);
	
	СтатьяОборотов = НоваяСтрока.СтатьяОборотов;
	СвойстваСтатьи = бит_БюджетированиеПовтИспСервер.ПолучитьСвойстваСтатьи(СтатьяОборотов);
	
	Если СвойстваСтатьи.Количественный Тогда
		Если ЗначениеЗаполнено(Выборка.ФункцияКоличество) Тогда
			
			НоваяСтрока.Количество = бит_ОбщегоНазначения.ВыполнитьПользовательскуюФункцию(
										Выборка.ФункцияКоличество,Выборка,СтрокаТабличнойЧасти,НоваяСтрока,Сценарий);
			
			Если КомментироватьРасчет Тогда
				ПарамРасчета.Количество.Результат = НоваяСтрока.Количество;
				ПарамРасчета.Количество.Функция   = Выборка.ФункцияКоличество;
				ПарамРасчета.Количество.ИмяРесурса= "Количество";
				ПарамРасчета.Количество.ПрофильРаспределения = Выборка.ПрофильРаспределения;
			КонецЕсли; 
		ИначеЕсли ЗначениеЗаполнено(Выборка.РеквизитКоличество) Тогда
			
			ИмяРеквизита = бит_ОбщегоНазначения.ПолучитьИмяЗначенияПеречисления(
								Перечисления.бит_РеквизитыДляРасчетаЗависимостей,Выборка.РеквизитКоличество);
			НоваяСтрока.Количество = СтрокаТабличнойЧасти[ИмяРеквизита]*Выборка.КоэффициентКоличество;
			
			Если КомментироватьРасчет Тогда
				ПарамРасчета.Количество.Результат    = НоваяСтрока.Количество;
				ПарамРасчета.Количество.Коэффициент  = Выборка.КоэффициентКоличество;
				ПарамРасчета.Количество.ИмяРеквизита = ИмяРеквизита;			
				ПарамРасчета.Количество.Аргумент     = СтрокаТабличнойЧасти[ИмяРеквизита];
				ПарамРасчета.Количество.ИмяРесурса	 = "Количество";
			    ПарамРасчета.Количество.ПрофильРаспределения = Выборка.ПрофильРаспределения;
			КонецЕсли; 
		КонецЕсли; 
	Иначе
		НоваяСтрока.Количество = 0;
	КонецЕсли;
	
	Если СвойстваСтатьи.Суммовой Тогда
		Если ЗначениеЗаполнено(Выборка.ФункцияСумма) Тогда
			
			НоваяСтрока.Сумма = бит_ОбщегоНазначения.ВыполнитьПользовательскуюФункцию(Выборка.ФункцияСумма,
									Выборка,СтрокаТабличнойЧасти,НоваяСтрока,Сценарий);
			Если КомментироватьРасчет Тогда
				ПарамРасчета.Сумма.Результат = НоваяСтрока.Сумма;
				ПарамРасчета.Сумма.Функция   = Выборка.ФункцияСумма;
				ПарамРасчета.Сумма.ИмяРесурса= "Сумма";
				ПарамРасчета.Сумма.ПрофильРаспределения = Выборка.ПрофильРаспределения;
			КонецЕсли; 
		ИначеЕсли ЗначениеЗаполнено(Выборка.РеквизитСумма) Тогда
			
			ИмяРеквизита = бит_ОбщегоНазначения.ПолучитьИмяЗначенияПеречисления(
							Перечисления.бит_РеквизитыДляРасчетаЗависимостей,Выборка.РеквизитСумма);
			НоваяСтрока.Сумма = СтрокаТабличнойЧасти[ИмяРеквизита]*Выборка.КоэффициентСумма;
			
			Если КомментироватьРасчет Тогда
				ПарамРасчета.Сумма.Результат    = НоваяСтрока.Сумма;
				ПарамРасчета.Сумма.Коэффициент  = Выборка.КоэффициентСумма;
				ПарамРасчета.Сумма.ИмяРеквизита = ИмяРеквизита;
				ПарамРасчета.Сумма.Аргумент     = СтрокаТабличнойЧасти[ИмяРеквизита];
				ПарамРасчета.Сумма.ИмяРесурса	= "Сумма";
				ПарамРасчета.Сумма.ПрофильРаспределения = Выборка.ПрофильРаспределения;
			КонецЕсли; 
		КонецЕсли; 
	Иначе
		НоваяСтрока.Сумма = 0;	
	КонецЕсли;

	Возврат ПарамРасчета;
	
КонецФункции

// Процедура заполняет измерения при формировании зависимых оборотов.
// 
// Параметры:
//  ИзмеренияБюджетирования - Структура.
//  Выборка              - ВыборкаИзРезультатаЗапроса.
//  СтрокаТабличнойЧасти - СтрокаТабличнойЧасти, СтрокаТаблицыЗначений.
//  НоваяСтрока          - СтрокаТабличнойЧасти, НоваяСтрока.
// 
Процедура ЗависимыеОборотыЗаполнитьИзмерения(ИзмеренияБюджетирования, Выборка, СтрокаТабличнойЧасти, НоваяСтрока)
	
	НоваяСтрока.СтатьяОборотов = Выборка.СтатьяОборотов_Зависимый;
	
	СтатьяОборотов = НоваяСтрока.СтатьяОборотов;
	СвойстваСтатьи = бит_БюджетированиеПовтИспСервер.ПолучитьСвойстваСтатьи(СтатьяОборотов);

	Для каждого КлючИЗначение Из ИзмеренияБюджетирования Цикл
		
		ИмяИзмерения = КлючИЗначение.Ключ;
		ИмяИзмеренияЗависимый = КлючИЗначение.Ключ+"_Зависимый";
		Если ВРег(ИмяИзмерения) = ВРег("Сценарий") Тогда
			Продолжить;
		КонецЕсли; 
		
		ЗначениеИзмерения = СтрокаТабличнойЧасти[ИмяИзмерения];
		ЗначениеЗависимый = Выборка[ИмяИзмеренияЗависимый];
		
		Если ЗначениеЗаполнено(ЗначениеЗависимый)  Тогда
			НоваяСтрока[ИмяИзмерения] = ЗначениеЗависимый;
		Иначе
			НоваяСтрока[ИмяИзмерения] = ЗначениеИзмерения;
		КонецЕсли; 
		
		// Проверка допустимости установки аналитик по статье.
		
		Если ВРег(ИмяИзмерения) = ВРег("ЦФО") ИЛИ ВРег(ИмяИзмерения) = ВРег("СтатьяОборотов") Тогда
			// По цфо учет ведется всегда - реквизита учет_<...> нет.
			Продолжить;
		КонецЕсли; 
		
		ВедетсяУчет = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СвойстваСтатьи, ИмяИзмерения, Ложь);
		
		Если НЕ ВедетсяУчет Тогда
			НоваяСтрока[ИмяИзмерения] = Неопределено;
		КонецЕсли;
	КонецЦикла; // По измерениям бюджетирования
	
КонецПроцедуры

// Функция формирует комментарий выполнения расчета зависимых оборотов.
// 
// Параметры:
//  Выборка              - ВыборкаИзРезультатаЗапроса - выборка.
//  СтрокаТабличнойЧасти - СтрокаТабличнойЧасти - СтрокаТаблицыЗначений.
//  НоваяСтрока          - СтрокаТабличнойЧасти - НоваяСтрока.
// 
// Возвращаемое значение:
//  Результат - ТекстХТМЛ.
// 
Функция ЗависимыеОборотыКомментарийРасчета(ПарамРасчета)
	
	ТекстХТМЛ = "";
	
	Если ТипЗнч(ПарамРасчета) = Тип("Структура") Тогда
		
		// Заголовок
		ВремСтрока = НСтр("ru='Комментарий расчета зависимых оборотов';en='Comment to Dependent Turnovers Calculation'");
		ТекстХТМЛ  = "<p><h3>"+ВремСтрока+"</h3></p>";
		
		// Документ установки зависимых оборотов
		ВремСтрока  = НСтр("ru='Выполнен расчет по настройке:';en='Calculated according to configuration:'");
		ТекстСсылки = НСтр("ru = '%1, строка № %2';en='%1, line № %2'");
		ТекстСсылки = СтрШаблон(ТекстСсылки, ПарамРасчета.Регистратор, ПарамРасчета.НомерСтроки);
		Ссылка 		= СтрШаблон("#Документ.бит_УстановкаЗависимыхОборотов/%1/%2", 
							ПарамРасчета.Регистратор.УникальныйИдентификатор(), ПарамРасчета.НомерСтроки);
				 
		ТекстХТМЛ = ТекстХТМЛ+"<p><b><i>"+ВремСтрока+"</i></b><br><a id = ""CalcRef"" href = """+Ссылка+""" >"+ТекстСсылки+"</a><p>";
		
		// Расчет суммы и количества.
		ТекстЗаголовка = НСтр("ru='Расчет суммы:';en='The calculation of the amount of:'");
		ТекстСумма      = ЗависимыеОборотыКомментарийРасчетаРесурса(ПарамРасчета.Сумма, ТекстЗаголовка, "ЧЦ=15; ЧДЦ=2");
		ТекстЗаголовка = НСтр("ru='Расчет количества:';en='Calculating the amount of:'");
		ТекстКоличество = ЗависимыеОборотыКомментарийРасчетаРесурса(ПарамРасчета.Количество, ТекстЗаголовка, "ЧЦ=15; ЧДЦ=3");		
		
		ТекстХТМЛ = ТекстХТМЛ+"<p>";
		ТекстХТМЛ = ТекстХТМЛ+ТекстСумма;
		ТекстХТМЛ = ТекстХТМЛ+ТекстКоличество;
		
		Если ПустаяСтрока(ТекстСумма) И ПустаяСтрока(ТекстКоличество) Тогда
			ТекстХТМЛ = ТекстХТМЛ+НСтр("ru='Расчеты не выполнены.';en='Calculations are not completed.'");
		КонецЕсли; 
		ТекстХТМЛ = ТекстХТМЛ+"</p>"
	КонецЕсли; 
	
	Возврат ТекстХТМЛ;
	
КонецФункции

// Функция выводит комментарий расчета ресурса (суммы или количества).
// 
// Параметры:
//  СтрПар - Структура
//  СтрЗаголовок - Строка
//  СтрФормат    - Строка
// 
// Возвращаемое значение:
//  ТекстХТМЛ - Строка.
// 
Функция ЗависимыеОборотыКомментарийРасчетаРесурса(СтрПар, СтрЗаголовок, СтрФормат)
	
	ТекстХТМЛ = "";
	
	Если ТипЗнч(СтрПар) = Тип("Структура") И ТипЗнч(СтрПар.Результат) = Тип("Число") Тогда
		
		// Выполнялся расчет показателя
		ТекстХТМЛ = ТекстХТМЛ+"<b><i>"+СтрЗаголовок+"</b></i><br>";
		
		Если ЗначениеЗаполнено(СтрПар.ПрофильРаспределения) Тогда
			ТекстПрофильРаспределения		= "*ПрофильРаспределения";
			ТекстПрофильРаспределенияРасчет = "*%ПрофильРаспределения%";
			ТекстРезультат = "%Результат"+СтрПар.ИмяРесурса+"%";
		Иначе
			ТекстПрофильРаспределения		= "";
			ТекстПрофильРаспределенияРасчет = "";
			ТекстРезультат = Формат(СтрПар.Результат,СтрФормат);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрПар.Функция) Тогда
			
			// Расчет выполнялся через пользовательскую функцию.
			ТекстСсылки = Строка(СтрПар.Функция)+"()";
			Ссылка = "#Справочник.бит_ПользовательскиеФункции/"+Строка(СтрПар.Функция.УникальныйИдентификатор());
			
			ТекстХТМЛ = ТекстХТМЛ+ТекстРезультат+" = <a id = ""UserFunction"" href = """+Ссылка+""">"+ТекстСсылки+"</a>"+ТекстПрофильРаспределенияРасчет+"<br>";
			
		Иначе	
			
			// Расчет выполнялся умножением на коэффициент.
			ТекстХТМЛ = ТекстХТМЛ+ТекстРезультат+" = "+СтрПар.Коэффициент+"*"+СтрПар.ИмяРеквизита+ТекстПрофильРаспределения+"<br>";
			ТекстХТМЛ = ТекстХТМЛ+ТекстРезультат+" = "+СтрПар.Коэффициент+"*"+СтрПар.Аргумент+ТекстПрофильРаспределенияРасчет+"<br>";		   
			
		КонецЕсли; 
		
	КонецЕсли; 
	
	Возврат ТекстХТМЛ;
	
КонецФункции

// Функция выполняет фильтрацию строк  настроек зависимых оборотов, 
// по которым необходимо выполнять расчет для данной строки оборотов бюджета.
// 
// Параметры:
//  СтрокаТаблицыДокумента - СтрокаТаблицы - строка таблицы.
//  СтрокаЗависимыхОборотов - СтрокаТаблицы - строка оборотов.
//  ПроверяемыеПоля - Структура - поля.
//  ДатаЗаполнения - Булево - Дата.
// 
// Возвращаемое значение:
//  флВыполнено - Булево.
// 
Функция УсловиеНаПоляЗависимыхОборотов(СтрокаТаблицыДокумента, СтрокаЗависимыхОборотов, ПроверяемыеПоля, ДатаЗаполнения)

	Если СтрокаЗависимыхОборотов.Период > ДатаЗаполнения Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	Для каждого КиЗ Из ПроверяемыеПоля Цикл
		ИмяПоля = КиЗ.Ключ;
		ПустоеЗначение = КиЗ.Значение;
		
		Если НЕ (СтрокаТаблицыДокумента[ИмяПоля] = СтрокаЗависимыхОборотов[ИмяПоля] 
			ИЛИ НЕ ЗначениеЗаполнено(СтрокаЗависимыхОборотов[ИмяПоля])) Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла; 

	Если СтрокаЗависимыхОборотов.КоэффициентКоличество = 0
		И СтрокаЗависимыхОборотов.КоэффициентСумма = 0
		И НЕ ЗначениеЗаполнено(СтрокаЗависимыхОборотов.ФункцияКоличество)
		И НЕ ЗначениеЗаполнено(СтрокаЗависимыхОборотов.ФункцияСумма) Тогда
		Возврат Ложь;
	КонецЕсли; 
		
	Если НЕ ЗначениеЗаполнено(СтрокаЗависимыхОборотов.РеквизитКоличество)
		И НЕ ЗначениеЗаполнено(СтрокаЗависимыхОборотов.РеквизитСумма) Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(СтрокаЗависимыхОборотов.ДатаОкончания)
		И КонецДня(СтрокаЗависимыхОборотов.ДатаОкончания) < ДатаЗаполнения Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Процедура вычисляет приоритет настройки зависимых оборотов.
// 
// Параметры:
//  СтрокаТаблицыДокумента - СтрокаТаблицыЗначений.
//  СтрокаЗависимыхОборотов - СтрокаТаблицыЗначений.
//  ПроверяемыеПоля - Структура.
// 
Процедура ВычислитьПриоритетСтрокиЗависимыхОборотов(СтрокаТаблицыДокумента, СтрокаЗависимыхОборотов, ПроверяемыеПоля)

	Для каждого КиЗ Из ПроверяемыеПоля Цикл
	
		ИмяПоля = КиЗ.Ключ;
		ПустоеЗначение = КиЗ.Значение;
		
		Если СтрокаТаблицыДокумента[ИмяПоля] = СтрокаЗависимыхОборотов[ИмяПоля] 
			  И ЗначениеЗаполнено(СтрокаЗависимыхОборотов[ИмяПоля]) Тогда
		
			СтрокаЗависимыхОборотов.Приоритет = СтрокаЗависимыхОборотов.Приоритет + 1;
		
		КонецЕсли; 
			
	КонецЦикла; 

	ИмяПоля = "СтатьяОборотов";
	Если СтрокаТаблицыДокумента[ИмяПоля] = СтрокаЗависимыхОборотов[ИмяПоля] 
			  И ЗначениеЗаполнено(СтрокаЗависимыхОборотов[ИмяПоля]) Тогда
	
			СтрокаЗависимыхОборотов.Приоритет = СтрокаЗависимыхОборотов.Приоритет + 1;
	
	КонецЕсли; 
	
КонецПроцедуры

// Функция формирует перечень полей по которым будет выполняться проверка приоритета настроек трансляции.
// 
// Возвращаемое значение:
//  ПроверяемыеПоля - Структура.
// 
Функция ПодготовитьПроверяемыеПоляЗавОборотов()

		// Получаем имена справочников в зависимости от текущего решения.
		ИмяСправочникаСценарии = бит_ОбщегоНазначения.ПолучитьИмяСправочникаСценарииБюджетирования();
		ИмяСправочникаЦФО 	   = бит_ОбщегоНазначения.ПолучитьИмяСправочникаЦФО();
		ИмяСправочникаПроекты  = бит_ОбщегоНазначения.ПолучитьИмяСправочникаПроекты();		
		
		ПроверяемыеПоля = Новый Структура;
		ПроверяемыеПоля.Вставить("ЦФО"			 	   , "ЗНАЧЕНИЕ(Справочник." + ИмяСправочникаЦФО + ".ПустаяСсылка)");
		Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
			
			ПроверяемыеПоля.Вставить("Проект"		 	   , "ЗНАЧЕНИЕ(Справочник." + ИмяСправочникаПроекты + ".ПустаяСсылка)");
			ПроверяемыеПоля.Вставить("Контрагент"	 	   , "ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)");
			ПроверяемыеПоля.Вставить("ДоговорКонтрагента"  , "ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)");
			ПроверяемыеПоля.Вставить("НоменклатурнаяГруппа", "ЗНАЧЕНИЕ(Справочник.НоменклатурныеГруппы.ПустаяСсылка)");
			ПроверяемыеПоля.Вставить("БанковскийСчет"	   , "ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)");
			
		КонецЕсли; 
		
		КоличествоДопАналитик = бит_МеханизмДопИзмерений.ПолучитьМаксимальноеКоличествоДополнительныхИзмерений();
		Для Н = 1 По КоличествоДопАналитик Цикл
		
			ПроверяемыеПоля.Вставить("Аналитика_"+н, "Неопределено");
		
		КонецЦикла; 

	Возврат ПроверяемыеПоля;
	
КонецФункции

#КонецОбласти

#Область СинхронизацияСтруктурыПредприятияРеглИЦФО

// Функция выполняет первоначальную синхронизацию подразделений регл и ЦФО.
// 
Процедура ПервоначальнаяСинхронизацияПодразделенийРеглЦФО()
	
	Если Метаданные.Справочники.Найти("ПодразделенияОрганизаций") <> Неопределено Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Организации.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Организации КАК Организации
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПодразделенияОрганизаций.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ПодразделенияОрганизаций КАК ПодразделенияОрганизаций
		|
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка ИЕРАРХИЯ,
		|	ПодразделенияОрганизаций.Представление";
					   
		МассивРезультатов = Запрос.ВыполнитьПакет();
		
		// Синхронизация организаций.
		Выборка = МассивРезультатов[0].Выбрать();		
		Пока Выборка.Следующий() Цикл		
			СинхронизироватьСтруктурнуюЕдиницуРеглЦФО(Выборка.Ссылка);		
		КонецЦикла; 
		
		// Синхронизация подразделений.
		Выборка = МассивРезультатов[1].Выбрать();		
		Пока Выборка.Следующий() Цикл		
			СинхронизироватьСтруктурнуюЕдиницуРеглЦФО(Выборка.Ссылка);		
		КонецЦикла; 
		
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

#Область СмежностиГрафа

// Возвращает не полный список смежности графа.
// Только связанные формулами ячейки.
// Если ячейка не валяет на расчет последующих значений,
// то она не может образовывать циклы и не заносится в список (например итог).
//
// Параметры:
//  ТабДокДанные - ТабличныйДокумент.
// 
// Возвращаемое значение:
//   Структура - список смежности графа:
//    * Имя области
//    * Значение - Массив - имена зависимых по формуле областей.
//
Функция СписокСмежностиПоискаЦикла(ТабДокДанные)
	
	СписокСмежности = Новый Структура;
	Для каждого Обл Из ТабДокДанные.Области Цикл
		Если Обл.Расшифровка <> Неопределено 
			И (Обл.Расшифровка.Вид = "Формула" ИЛИ  Обл.Расшифровка.Вид = "Значение") Тогда
			
			// Обрабатываем вершины которые учавствуют формулах.
			Для каждого ИмяАргумента Из Обл.Расшифровка.Аргументы Цикл
				Если СписокСмежности.Свойство(ИмяАргумента) Тогда
					СписокСмежности[ИмяАргумента].Добавить(Обл.Имя);
				Иначе	
					СмежныеВершины = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Обл.Имя);
					СписокСмежности.Вставить(ИмяАргумента, СмежныеВершины); 
				КонецЕсли;
			КонецЦикла; // Аргументы формул.
			
		КонецЕсли;
	КонецЦикла; // Области.
	
	Возврат СписокСмежности;
	
КонецФункции

Функция ПоискЦиклаВГлубину(Вершина, СписокСмежности, МаршрутЦикла, СтатусыВершин)
	
	Результат = Ложь;
	МаршрутЦикла.Добавить(Вершина);
	
	СтатусыВершин[Вершина] = Истина; // Вершина на проверке. 
	СмежныеВершины = СписокСмежности[Вершина]; 
	Для каждого СмежнаяВершина Из СмежныеВершины Цикл
		Если СписокСмежности.Свойство(СмежнаяВершина) = Ложь Тогда
			// Достигнут конец маршрута.
			Продолжить;
		ИначеЕсли СтатусыВершин[СмежнаяВершина] = Неопределено Тогда
			// Переход на уровень ниже.
			Результат = ПоискЦиклаВГлубину(СмежнаяВершина, СписокСмежности, МаршрутЦикла, СтатусыВершин);
		ИначеЕсли СтатусыВершин[СмежнаяВершина] = Истина Тогда
			// Найден цикл, возврат к вершине в состоянии проверки.
			МаршрутЦикла.Добавить(СмежнаяВершина);
			Результат = Истина;
		КонецЕсли;
		
		Если Результат = Истина Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Результат = Ложь Тогда
		// Вершина проверена.
		СтатусыВершин[Вершина] = Ложь;
		МаршрутЦикла.Удалить(МаршрутЦикла.ВГраница());
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

// Процедура синхронизирует справочники, отражающие структуру предприятия и ЦФО.
// 
// Параметры:
//  Источник - СправочникОбъект.
// 
Функция СинхронизироватьСтруктурнуюЕдиницуРеглЦФО(Источник)
	
	СинхрЦФО = НайтиСинхрЦФО(Источник.Ссылка);
	
	МетаИсточник = Источник.Метаданные();
	
	Если НЕ ЗначениеЗаполнено(СинхрЦФО) Тогда		
		// Не удалось найти синхронизированное ЦФО - нужно создать.		
		ЦФООбъект = Справочники.Подразделения.СоздатьЭлемент();
		ЦФООбъект.УстановитьНовыйКод();			
	Иначе		
		// Нашли синхронизированное ЦФО - синхронизируем наименование и пометку удаления.
		ЦФООбъект = СинхрЦФО.ПолучитьОбъект();		
	КонецЕсли; 
	
	ЦФООбъект.Наименование = Источник.Наименование;
	ЦФООбъект.СтруктурнаяЕдиницаРегл = Источник.Ссылка;
	ЦФООбъект.ПометкаУдаления = Источник.ПометкаУдаления;
	
	Если МетаИсточник.Имя = "Организации" Тогда
		
		Если Источник.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо Тогда			
			ЦФООбъект.ЯвляетсяЮрЛицом = Истина;			
		КонецЕсли; 
		
	ИначеЕсли МетаИсточник.Имя = "ПодразделенияОрганизаций" Тогда	
		
		Если ЗначениеЗаполнено(Источник.Родитель) Тогда			
			ЦФООбъект.Родитель = НайтиСинхрЦФО(Источник.Родитель);			
		Иначе			
			ЦФООрг = НайтиСинхрЦФО(Источник.Владелец);			
			Если НЕ ЗначениеЗаполнено(ЦФООрг) Тогда			
				ЦФООрг = СинхронизироватьСтруктурнуюЕдиницуРеглЦФО(Источник.Владелец);			
			КонецЕсли; 			
			ЦФООбъект.Родитель = ЦФООрг;			
		КонецЕсли; 
		
	КонецЕсли; 
	
	ЦФООбъект.ДополнительныеСвойства.Вставить("СинхронизацияСПодразделениями", Истина);
	
	Успех = бит_ОбщегоНазначения.ЗаписатьСправочник(ЦФООбъект, "", "Ошибки", Истина);
	
	Если Успех Тогда
		ЗаписатьСоответствиеЦФОПодразделение(Источник.Ссылка, ЦФООбъект.Ссылка);
	КонецЕсли;
	
	Возврат ЦФООбъект.Ссылка;
	
КонецФункции

