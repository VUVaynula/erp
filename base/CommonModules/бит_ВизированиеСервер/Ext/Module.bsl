// 
Функция НазначеныИсполнители(ТекущийОбъект, РольИсполнителя) Экспорт

	НазначеныИсполнители = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИсполнителиЗадач.РольИсполнителя КАК РольИсполнителя,
	|	ИсполнителиЗадач.Исполнитель КАК Исполнитель,
	|	ОбъектыАдресации_1.Вид КАК ВидОбъекта_1,
	|	ОбъектыАдресации_1.Вид.Код КАК ИмяВида_1,
	|	ОбъектыАдресации_1.Вид.СпособПроверкиПринадлежности КАК СпособПроверки_1,
	|	ИсполнителиЗадач.ОбъектАдресации_1 КАК ОбъектАдресации_1,
	|	ОбъектыАдресации_2.Вид КАК ВидОбъекта_2,
	|	ОбъектыАдресации_2.Вид.Код КАК ИмяВида_2,
	|	ОбъектыАдресации_2.Вид.СпособПроверкиПринадлежности КАК СпособПроверки_2,
	|	ИсполнителиЗадач.ОбъектАдресации_2 КАК ОбъектАдресации_2,
	|	ОбъектыАдресации_3.Вид КАК ВидОбъекта_3,
	|	ОбъектыАдресации_3.Вид.Код КАК ИмяВида_3,
	|	ОбъектыАдресации_3.Вид.СпособПроверкиПринадлежности КАК СпособПроверки_3,
	|	ИсполнителиЗадач.ОбъектАдресации_3 КАК ОбъектАдресации_3
	|ИЗ
	|	РегистрСведений.бит_ИсполнителиЗадач КАК ИсполнителиЗадач
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_РолиИсполнителей.ОбъектыАдресации КАК ОбъектыАдресации_1
	|		ПО ИсполнителиЗадач.РольИсполнителя = ОбъектыАдресации_1.Ссылка
	|			И (ОбъектыАдресации_1.Имя = ""ОбъектАдресации_1"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_РолиИсполнителей.ОбъектыАдресации КАК ОбъектыАдресации_2
	|		ПО ИсполнителиЗадач.РольИсполнителя = ОбъектыАдресации_2.Ссылка
	|			И (ОбъектыАдресации_2.Имя = ""ОбъектАдресации_2"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_РолиИсполнителей.ОбъектыАдресации КАК ОбъектыАдресации_3
	|		ПО ИсполнителиЗадач.РольИсполнителя = ОбъектыАдресации_3.Ссылка
	|			И (ОбъектыАдресации_3.Имя = ""ОбъектАдресации_3"")
	|ГДЕ
	|	ИсполнителиЗадач.РольИсполнителя = &РольИсполнителя";
	Запрос.УстановитьПараметр("РольИсполнителя", РольИсполнителя);
	
	Выборка     = Запрос.Выполнить().Выбрать();
	МетаОбъект  = ТекущийОбъект.Метаданные();
	
	Пока Выборка.Следующий() Цикл
		 УсловиеВыполнено = ПроверитьПринадлежностьОбъектаВизирования(ТекущийОбъект, МетаОбъект, Выборка);
		 Если УсловиеВыполнено Тогда
		 	НазначеныИсполнители = Истина;
			Прервать;
		 КонецЕсли; 
	КонецЦикла; 
	
	Возврат НазначеныИсполнители;
	
КонецФункции

#КонецОбласти

#Область ИнтерфейсОповещенийОНовыхВизах

// Устанавливает признак "Оповещено" для указанного способа транспорта.
//
// Параметры:
//  ТаблицаВиз - ТаблицаЗначений - Таблица обработанных виз, для которых необходимо установить признак. Обязательные колонки:
//		* Объект - ДокументСсылка, СправочникСсылка - Объект визирования.
//		* Виза   - СправочникСсылка.бит_Визы.
//	СпособТранспорта - ПеречислениеСсылка.бит_фн_СпособыТранспортаОповещений.
//
Процедура УстановитьОтметкуОповещения(ТаблицаВиз, СпособТранспорта) Экспорт
	
	Если ТаблицаВиз.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ОтметкаОповещения = "";
	Если СпособТранспорта = Перечисления.бит_фн_СпособыТранспортаОповещений.Telegram Тогда
		ОтметкаОповещения = "ОповещеноТелеграм";
	ИначеЕсли СпособТранспорта = Перечисления.бит_фн_СпособыТранспортаОповещений.ЭлектроннаяПочта1С Тогда
		ОтметкаОповещения = "ОповещеноПочта";
	Иначе
		Возврат;
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаВиз.Объект КАК Объект,
	|	ТаблицаВиз.Виза КАК Виза
	|ПОМЕСТИТЬ ТаблицаВиз
	|ИЗ
	|	&ТаблицаВиз КАК ТаблицаВиз";
	Запрос.УстановитьПараметр("ТаблицаВиз", ТаблицаВиз);
	Запрос.Выполнить();
		
	НачатьТранзакцию();
	
	Попытка
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.бит_УстановленныеВизы");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		ЭлементБлокировки.ИсточникДанных = ТаблицаВиз;
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Объект", "Объект");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Виза", "Виза");
		Блокировка.Заблокировать();
		
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	УстановленныеВизы.Объект КАК Объект,
		|	УстановленныеВизы.Виза КАК Виза,
		|	УстановленныеВизы.ИД КАК ИД
		|ИЗ
		|	РегистрСведений.бит_УстановленныеВизы КАК УстановленныеВизы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаВиз КАК ТаблицаВиз
		|		ПО УстановленныеВизы.Объект = ТаблицаВиз.Объект
		|			И УстановленныеВизы.Виза = ТаблицаВиз.Виза
		|			И УстановленныеВизы.АктивнаяВиза
		|			И НЕ &ФильтрСпособаТранспорта";
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ФильтрСпособаТранспорта", "УстановленныеВизы." + ОтметкаОповещения);
		Запрос.Текст = ТекстЗапроса;
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			НаборВиз = РегистрыСведений.бит_УстановленныеВизы.СоздатьНаборЗаписей();
			НаборВиз.Отбор.Объект.Установить(Выборка.Объект);
			НаборВиз.Отбор.Виза.Установить(Выборка.Виза);
			НаборВиз.Отбор.ИД.Установить(Выборка.ИД);
			НаборВиз.Прочитать();
			// Отключим регистрацию изменения регистра в механизм оповещений.
			НаборВиз.ДополнительныеСвойства.Вставить("ОтключитьРегистрациюОповещений", Истина);
			
			Для каждого ЗаписьНабора Из НаборВиз Цикл
				ЗаписьНабора[ОтметкаОповещения] = Истина;
			КонецЦикла;
			
			НаборВиз.Записать();
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		Событие = НСтр("ru = 'Ошибка снятия отметки оповещения'", ОбщегоНазначения.КодОсновногоЯзыка());
		ЗаписьЖурналаРегистрации(
			Событие,
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Конструктор параметров, влияющих на установку статуса.
//
// Возвращаемое значение:
//	Структура - параметры для определения статуса.
//
Функция НовыеПараметрыУстановкиСтатуса() Экспорт
	
	Параметры = Новый Структура;
	
	Параметры.Вставить("РежимЗаписи",             РежимЗаписиДокумента.Запись);
	Параметры.Вставить("ТекущийСтатус",           Справочники.бит_СтатусыОбъектов.ПустаяСсылка());
	Параметры.Вставить("ДатаИзмененияСтатуса",    '00010101');
	Параметры.Вставить("ПараметрыОплаты",         Неопределено);
	Параметры.Вставить("ВнешняяУстановкаСтатуса", Истина);
	
	Параметры.Вставить("Объект",                  Неопределено);
	Параметры.Вставить("ВидСтатуса",              Перечисления.бит_ВидыСтатусовОбъектов.Статус);
	Параметры.Вставить("Статус",                  Справочники.бит_СтатусыОбъектов.ПустаяСсылка());
	Параметры.Вставить("СтатусПредыдущий",        Справочники.бит_СтатусыОбъектов.ПустаяСсылка());
	Параметры.Вставить("Пользователь",	          Пользователи.ТекущийПользователь());
	Параметры.Вставить("Алгоритм",                Справочники.бит_АлгоритмыПроцессов.ПустаяСсылка());
	
	Параметры.Вставить("РежимСообщений",          "Все");
	
	Возврат Параметры;
	
КонецФункции

// Конструктор параметров проверки условий выполнения алгоритма.
// 
// Возвращаемое значение:
//  Параметры - Структура.
//
Функция НовыеПараметрыПроверкиУсловия() Экспорт
	
	ПараметрыПроверкиУсловий = Новый Структура;
	ПараметрыПроверкиУсловий.Вставить("ТекущийОбъект");
	ПараметрыПроверкиУсловий.Вставить("Визы");
	ПараметрыПроверкиУсловий.Вставить("Алгоритм");
	ПараметрыПроверкиУсловий.Вставить("ТипыРешенийПоТочкам", Новый Соответствие);
	
	КэшПроверок = Новый Структура;
	КэшПроверок.Вставить("ВышеНетНевыполнимыхУсловий", Новый Соответствие);
	КэшПроверок.Вставить("ВышеЕстьТочкиДействия",      Новый Соответствие);
	КэшПроверок.Вставить("ВышеНетТочекДействия",       Новый Соответствие);
	КэшПроверок.Вставить("ПринятыРешенияПоВышестоящимТочкам", Новый Соответствие);
	ПараметрыПроверкиУсловий.Вставить("КэшПроверок", КэшПроверок);
	
	Возврат ПараметрыПроверкиУсловий;
	
КонецФункции

// Обработчик подписки на событие "Перед записью" документов, поддерживающих механизм установки статусов.
//
Процедура бит_ПередЗаписьюДокументаДляУстановкиСтатуса(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	Если Отказ ИЛИ Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ДействияУстановкиСтатусаПередЗаписьюОбъекта(Источник, Отказ, РежимЗаписи);
	
КонецПроцедуры

// Обработчик подписки на событие "Перед записью" справочников, поддерживающих механизм установки статусов.
//
Процедура бит_ПередЗаписьюДляУстановкиСтатуса(Источник, Отказ) Экспорт
	
	Если Отказ ИЛИ Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Источник.ДополнительныеСвойства,
		"ОтключитьОпределениеСтатуса", Ложь) Тогда
		Возврат;
	КонецЕсли;
	
	Если Источник.ПометкаУдаления Тогда
		РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения;
	Иначе
		РежимЗаписи = РежимЗаписиДокумента.Проведение;
	КонецЕсли;
	
	ДействияУстановкиСтатусаПередЗаписьюОбъекта(Источник, Отказ, РежимЗаписи);
	
КонецПроцедуры

// Обработчик подписки на событие "При записи" объектов, поддерживающих механизм установки статусов.
//
Процедура бит_ПриЗаписиДляУстановкиСтатуса(Источник, Отказ) Экспорт
	
	ДействияУстановкиСтатусаПриЗаписиОбъекта(Источник, Отказ);
	
КонецПроцедуры

// Конструктор параметров результатов выполнения операций при групповой установке статусов.
// 
// Возвращаемое значение:
//  Параметры - Структура.
//
Функция НовыйКэшОперацийУстановкиСтатусов() Экспорт
	
	КэшОпераций = Новый Структура;
	КэшОпераций.Вставить("ОбработанныеСтатусыРеестров", Новый Соответствие);
	
	Возврат КэшОпераций;
	
КонецФункции

// Операции внешней установки статуса.
//
// Параметры:
//  Объект			 - ДокументОбъект - Объект для которого устанавливается статус. 
//  ПараметрыОплаты	 - Соответствие - Параметры оплаты.
//  КэшОпераций      - Структура - см. бит_ВизированиеСервер.НовыйКэшОперацийУстановкиСтатусов().
//
Процедура ОперацииВнешнейУстановкиСтатуса(Объект, ПараметрыОплаты = Неопределено, КэшОпераций = Неопределено) Экспорт
	
	ЗаполнитьПараметрыОпределенияСтатусаПередЗаписьюОбъекта(Объект, РежимЗаписиДокумента.Запись, Истина);
	ДействияУстановкиСтатусаПриЗаписиОбъекта(Объект, Ложь, ПараметрыОплаты, КэшОпераций);
	
КонецПроцедуры

// Определяет принадлежность объекта к подсистеме
// и возвращает значение соответствующей подсистеме настройки "Принятие к учету после утверждения".
Функция ПриниматьКУчетуПослеУтверждения(Источник) Экспорт
	
	// ++
	// Временная загрушка до переноса функционала из БП.
	Возврат ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения");
	// --
	
	Результат = Ложь;
	ТипИсточника = ТипЗнч(Источник);
	Если Метаданные.ОпределяемыеТипы.бит_ОбъектыПринимаемыеКУчетуПослеУтвержденияБюджетирование.Тип.СодержитТип(ТипИсточника) Тогда
		Результат = ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения");
	ИначеЕсли Метаданные.ОпределяемыеТипы.бит_ОбъектыПринимаемыеКУчетуПослеУтвержденияУправлениеДоговорами.Тип.СодержитТип(ТипИсточника) Тогда
		Результат = ПолучитьФункциональнуюОпцию("бит_ПринятиеКУчетуПослеУтвержденияУправлениеДоговорами");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РаботаСоСтатусами

Процедура ДействияУстановкиСтатусаПередЗаписьюОбъекта(Источник, Отказ, РежимЗаписи)
	
	ЗаполнитьПараметрыОпределенияСтатусаПередЗаписьюОбъекта(Источник, РежимЗаписи);
	ПроверитьВозможностьРедактированияСтатуса(Источник, РежимЗаписи, Отказ);
	
КонецПроцедуры

Процедура ПроверитьВозможностьРедактированияСтатуса(Источник, РежимЗаписи, Отказ)
	
	МодульВизирования = МодульВизированияПереопределяемый();
	Если МодульВизирования.НеВыполнятьПроверкуСтатусаДляОбъекта(Источник) Тогда
		Возврат;
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение
		ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		
		ТекущийСтатус = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Источник.ДополнительныеСвойства, "ТекущийСтатус");
		
		// Свойство "ПропуститьПроверкуДляУстановкиСтатуса" может отключать проверку.
		ОтключитьМеханизмПроверкиСтатуса = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
													Источник.ДополнительныеСвойства, 
													"ОтключитьМеханизмПроверкиСтатуса", Ложь);
													
		Если ОтключитьМеханизмПроверкиСтатуса Тогда
			Возврат;		
		КонецЕсли;	
		
		Если Справочники.бит_СтатусыОбъектов.ЭтоБлокирующийСтатус(ТекущийСтатус) Тогда
			БлокироватьОперацию = Истина;
			
			НастройкиДоступности = бит_НастройкиДоступностиЭлементовФорм.НастройкиДоступностиЭлементов(Источник);
			Если НастройкиДоступности <> Неопределено Тогда
				НастройкаВсейФормы = НастройкиДоступности.Найти("ВсеЭлементыФормы", "ИмяЭлемента");
				Если НастройкаВсейФормы <> Неопределено Тогда
					БлокироватьОперацию = НастройкаВсейФормы.ТолькоПросмотр;
				КонецЕсли;
			КонецЕсли;
			
			Если БлокироватьОперацию Тогда
				ТекстСообщения = НСтр("ru='Объект в статусе ""%1"" не подлежит редактированию.';
										|en='Object in status ""%1"" can not be changed.'");
				ТекстСообщения = СтрШаблон(ТекстСообщения, ТекущийСтатус);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,Источник,,,Отказ);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПараметрыТекущегоСтатуса(Ссылка)

	ПараметрыСтатуса = Новый Структура;
	ПараметрыСтатуса.Вставить("Статус", Справочники.бит_СтатусыОбъектов.ПустаяСсылка());
	ПараметрыСтатуса.Вставить("ТипСтатуса", Перечисления.бит_ТипыСтатусовОбъектов.ПустаяСсылка());
	ПараметрыСтатуса.Вставить("ДатаИзмененияСтатуса", '00010101');
	ПараметрыСтатуса.Вставить("ИнформацияСтатус", 	  "");
	
	Если НЕ ЗначениеЗаполнено(Ссылка) Тогда
		Возврат ПараметрыСтатуса;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыОбъектов.Статус КАК Статус,
	|	СтатусыОбъектов.Статус.ТипСтатуса КАК ТипСтатуса,
	|	СтатусыОбъектов.ДатаИзмененияСтатуса КАК ДатаИзмененияСтатуса
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК СтатусыОбъектов
	|ГДЕ
	|	СтатусыОбъектов.Объект = &Объект
	|	И СтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус)";
	Запрос.УстановитьПараметр("Объект", Ссылка);			   

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ПараметрыСтатуса, Выборка);
	КонецЕсли;
	
	Возврат ПараметрыСтатуса;
	
КонецФункции

Функция ЗаблокированоИзменениеСтатуса(Ссылка, ПараметрыУстановкиСтатуса)
	
	СтатусДоИзменения = ПараметрыУстановкиСтатуса.ТекущийСтатус;
	
	Если НЕ Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(СтатусДоИзменения,
			Перечисления.бит_ТипыСтатусовОбъектов.Закрыт) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		ДокументЗакрытия = "бит_ЗакрытиеЗаявок";
		Возврат Документы[ДокументЗакрытия].ПроведеноЗакрытиеДокумента(Ссылка);
	Иначе
		ДокументЗакрытия = "бит_кзн_ЗакрытиеДокументовПланирования";
		Возврат Ложь; // Реализовать в ERP.
	КонецЕсли;
	
КонецФункции

Процедура ДействияПослеУстановкиСтатуса(Объект, ПараметрыУстановкиСтатуса, КэшОпераций)
	
	МодульВизирование = МодульВизированияПереопределяемый();
	МодульВизирование.ДействияПослеУстановкиСтатуса(Объект, ПараметрыУстановкиСтатуса, КэшОпераций);
	
КонецПроцедуры

Процедура ЗаполнитьПараметрыОпределенияСтатусаПередЗаписьюОбъекта(Источник, РежимЗаписи, ВнешняяУстановкаСтатуса = Ложь)
	
	МетаданныеОбъекта           = Источник.Метаданные();
	ЭтоДокумент                 = ОбщегоНазначения.ЭтоДокумент(МетаданныеОбъекта);
	НастройкиОбъектаВизирования = НастройкиОбъектаВизирования(Источник);
	ИспользоватьВизирование     = НастройкиОбъектаВизирования.ИспользоватьВизирование;
	
	ЕстьОтправкаНаСогласование         = Ложь;
	ИмяРеквизитаОтправкаНаСогласование = "";
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ОтправленНаСогласование", МетаданныеОбъекта) Тогда
		ЕстьОтправкаНаСогласование         = Истина;
		ИмяРеквизитаОтправкаНаСогласование = "ОтправленНаСогласование";
	ИначеЕсли ОбщегоНазначения.ЕстьРеквизитОбъекта("бит_ОтправленНаСогласование", МетаданныеОбъекта) Тогда
		ЕстьОтправкаНаСогласование         = Истина;
		ИмяРеквизитаОтправкаНаСогласование = "бит_ОтправленНаСогласование";
	КонецЕсли;

	ПриниматьКУчетуПослеУтверждения = ПриниматьКУчетуПослеУтверждения(Источник);
	
	ПроводитьПослеУтверждения = ИспользоватьВизирование И ЕстьОтправкаНаСогласование И ПриниматьКУчетуПослеУтверждения;
								   
	Если Источник.ДополнительныеСвойства.Свойство("ОтключитьОбновлениеВизПриПроведении")
		И Источник.ДополнительныеСвойства.ОтключитьОбновлениеВизПриПроведении Тогда
		ОбновлятьВизыПриПерепроведении = Ложь;
	Иначе
		РежимОбновленияВиз             = НастройкиОбъектаВизирования.РежимОбновленияВиз;
		ОбновлятьВизыПриПерепроведении = (РежимОбновленияВиз = Перечисления.бит_РежимыОбновленияПеречняВиз.ОбновлятьПриПерепроведении);
	КонецЕсли;
	
	ПризнакПроведения         = ?(ЭтоДокумент, Источник.Проведен, Истина);
	
	ТекущийСтатус = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Источник.ДополнительныеСвойства, "ТекущийСтатус");
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = ТекущийСтатус(Источник.Ссылка);
	КонецЕсли;
	
	ОбновитьПереченьВиз       = Ложь;
	ОчиститьВсеВизыБезусловно = Ложь;
	Если ИспользоватьВизирование И НЕ ВнешняяУстановкаСтатуса Тогда
		Если ЕстьОтправкаНаСогласование Тогда
			Если ЭтоДокумент Тогда
				Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
					Источник[ИмяРеквизитаОтправкаНаСогласование] = Истина;
				ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
					Источник[ИмяРеквизитаОтправкаНаСогласование] = Ложь;
				КонецЕсли;
			Иначе
				Если НЕ Источник[ИмяРеквизитаОтправкаНаСогласование]
					И ЗначениеЗаполнено(Источник.Ссылка)
					И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.Ссылка, ИмяРеквизитаОтправкаНаСогласование) Тогда
					// Снят с согласования.
					ОчиститьВсеВизыБезусловно = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		ВизированиеБезПроведения = (ЕстьОтправкаНаСогласование И Источник[ИмяРеквизитаОтправкаНаСогласование]);
		
		Если РежимЗаписи = РежимЗаписиДокумента.Проведение
			И ЭтоДокумент
			И (ОбновлятьВизыПриПерепроведении
				ИЛИ (НЕ ПризнакПроведения И НЕ ВизированиеБезПроведения)
				ИЛИ НЕ ВизыУстановлены(Источник.Ссылка)) Тогда
			ОбновитьПереченьВиз = Истина;
		ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.Запись
			И НЕ Источник.ПометкаУдаления
			И МетаданныеОбъекта.Проведение = Метаданные.СвойстваОбъектов.Проведение.Запретить
			И НЕ ВизыУстановлены(Источник.Ссылка) Тогда
			ОбновитьПереченьВиз = Истина;
		ИначеЕсли ВизированиеБезПроведения Тогда
			Если НЕ ЗначениеЗаполнено(ТекущийСтатус)
				ИЛИ Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ТекущийСтатус,
						Перечисления.бит_ТипыСтатусовОбъектов.Черновик) Тогда
				ОбновитьПереченьВиз = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Источник.ДополнительныеСвойства.Вставить("ЭтоНовый"                   , Источник.ЭтоНовый());
	Источник.ДополнительныеСвойства.Вставить("РежимЗаписи"                , РежимЗаписи);
	Источник.ДополнительныеСвойства.Вставить("ОбновитьПереченьВиз"        , ОбновитьПереченьВиз);
	Источник.ДополнительныеСвойства.Вставить("ОчиститьВсеВизыБезусловно"  , ОчиститьВсеВизыБезусловно);
	Источник.ДополнительныеСвойства.Вставить("ПроводитьПослеУтверждения"  , ПроводитьПослеУтверждения);
	Источник.ДополнительныеСвойства.Вставить("ВнешняяУстановкаСтатуса"    , ВнешняяУстановкаСтатуса);
	Источник.ДополнительныеСвойства.Вставить("МеханизмВизированияОтключен", НЕ ИспользоватьВизирование);
	Источник.ДополнительныеСвойства.Вставить("ТекущийСтатус"              , ТекущийСтатус);
	
КонецПроцедуры

Процедура ДействияУстановкиСтатусаПриЗаписиОбъекта(Источник, Отказ, ПараметрыОплаты = Неопределено,
													КэшОпераций = Неопределено)
	
	Если Отказ ИЛИ Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Источник.ДополнительныеСвойства,
		"ОтключитьОпределениеСтатуса", Ложь) Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеСвойства = Источник.ДополнительныеСвойства;
	
	РежимЗаписи = ДополнительныеСвойства.РежимЗаписи;
	
	Если НЕ Метаданные.ОпределяемыеТипы.бит_ОбъектыВизирования.Тип.СодержитТип(ТипЗнч(Источник.Ссылка)) Тогда
		// Для данного объекта не предусмотрено визирование.
	ИначеЕсли ДополнительныеСвойства.ОчиститьВсеВизыБезусловно
		ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		ОчиститьВсеВизыБезусловно(Источник.Ссылка);
	ИначеЕсли ДополнительныеСвойства.МеханизмВизированияОтключен Тогда
		// Для данного объекта визирование отключено.
	ИначеЕсли ДополнительныеСвойства.ОбновитьПереченьВиз Тогда
		РеквизитыОбъекта = Источник.Метаданные().Реквизиты;
		СтруктураПараметров = Новый Структура;
		Если РеквизитыОбъекта.Найти("Организация") <> Неопределено Тогда
			СтруктураПараметров.Вставить("СтруктурноеПодразделение", Источник.Организация);
		КонецЕсли;
		Если РеквизитыОбъекта.Найти("ЦФО") <> Неопределено Тогда
			СтруктураПараметров.Вставить("ЦФО", Источник.ЦФО);
		КонецЕсли;
		ОбновитьПереченьВиз(Источник.Ссылка, Источник.Дата, СтруктураПараметров);
	КонецЕсли;
	
	ВнешняяУстановкаСтатуса = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства, "ВнешняяУстановкаСтатуса", Истина);
	
	Если НЕ ВнешняяУстановкаСтатуса И РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		// В отдельных случаях установка статуса при проведении выполняется после формирования движений.
		// При этом вызов установки статусов выполняется в процедуре модуля проведения самого объекта.
		Если бит_ОбщегоНазначения.ЭтоСемействоБП()
			И Источник.Метаданные().ПолноеИмя() = "Документ.бит_ЗаявкаНаРасходованиеСредств" Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыСтатуса  = СтатусыОбъекта(Источник.Ссылка);
	СтатусДоИзменения = ПараметрыСтатуса.Статус;
	
	ПараметрыУстановкиСтатуса = НовыеПараметрыУстановкиСтатуса();
	ПараметрыУстановкиСтатуса.РежимЗаписи          = РежимЗаписи;
	ПараметрыУстановкиСтатуса.ТекущийСтатус        = СтатусДоИзменения;
	ПараметрыУстановкиСтатуса.ДатаИзмененияСтатуса = ПараметрыСтатуса.Дата;
	ПараметрыУстановкиСтатуса.ПараметрыОплаты      = ПараметрыОплаты;
	Если ДополнительныеСвойства.Свойство("ВнешняяУстановкаСтатуса") Тогда
		ПараметрыУстановкиСтатуса.ВнешняяУстановкаСтатуса = ДополнительныеСвойства.ВнешняяУстановкаСтатуса;
	КонецЕсли;
	УстановитьСтатус(Источник, ПараметрыУстановкиСтатуса, КэшОпераций);
	
КонецПроцедуры

// Функция формирует информацию о статусе.
// 
// Параметры:
//  СтруктураПараметров - Структура
//                          Статус - СправочникСсылка.бит_СтатусыОбъектов.
//                          ДатаИзмененияСтатуса - Дата.
// 
// Возвращаемое значение:
//  Строка
// 
Функция СформироватьИнформациюСтатус(СтруктураПараметров)

	Результат = Строка(СтруктураПараметров.Статус);
	Если ЗначениеЗаполнено(СтруктураПараметров.ДатаИзмененияСтатуса) Тогда
		
		ТекстРезультат = НСтр("ru='%1 (изменен:%2)';en='%1 (changed:%2)'");
		Результат = СтрШаблон(ТекстРезультат, Результат, Формат(СтруктураПараметров.ДатаИзмененияСтатуса, "ДЛФ=DT"));
				
	КонецЕсли; 

	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область РаботаСВизами

Процедура СоздатьИНазначитьВизыПоУмолчаниюСлужебный(НазначатьВизы = Истина, ВыводитьСообщения = Ложь)
	
	МодульВизирование = МодульВизированияПереопределяемый();
	
	// Создание виз и пользовательских действий.
	ТаблицаВиз = НоваяТаблицаЗаполненияВиз();
	МодульВизирование.ЗаполнитьВизыПоУмолчанию(ТаблицаВиз);
	
	ГруппаДействия = Справочники.бит_ПользовательскиеДействия.СоздатьГруппуДействий("Визирование.ДействияПоУмолчанию");
	ПараметрыВизы  = Новый Соответствие;
	
	Для каждого СтрокаВизы Из ТаблицаВиз Цикл
		Виза          = СоздатьВизу(СтрокаВизы.Наименование, СтрокаВизы.Литера);
		Действие      = Справочники.бит_ПользовательскиеДействия.СоздатьДействиеВизирования(Виза, ГруппаДействия);
		
		ОписаниеВизы  = Новый Структура("Виза, Действие", Виза, Действие);
		ПараметрыВизы.Вставить(СтрокаВизы.КлючВизы, ОписаниеВизы);
	КонецЦикла;
	
	// Создание алгоритмов.
	ДеревоАлгоримтов = НовоеДеревоЗаполненияАлгоритмов();
	МодульВизирование.ЗаполнитьАлгоритмыПоУмолчанию(ДеревоАлгоримтов);
	
	ТекстСообщения  = НСтр("ru='Алгоритмы визирования по умолчанию';en='Algorithms-of-sight by default'");
	ГруппаАлгоритмы = Справочники.бит_АлгоритмыПроцессов.СоздатьГруппуАлгоритмов(ТекстСообщения);
	
	ДатаНазначенияАлгоритма = Дата('19800101');
	НазначеныАлгоритмы      = Ложь;
	
	Для каждого СтрокаОбъекта Из ДеревоАлгоримтов.Строки Цикл
		ОбъектМетаданных       = СтрокаОбъекта.ОбъектКлючВизы;
		ПредставлениеАлгоритма = ОбъектМетаданных.Представление();
		Алгоритм               = Справочники.бит_АлгоритмыПроцессов.СоздатьАлгоритм(ПредставлениеАлгоритма,
																					ГруппаАлгоритмы,
																					Перечисления.бит_ВидыАлгоритмов.Визирование,
																					,
																					Истина);

		Если НЕ Справочники.бит_АлгоритмыПроцессов.АлгоритмГотовКРаботе(Алгоритм, Ложь) Тогда
			ПоследняяТочка = Справочники.бит_АлгоритмыПроцессов.НайтиПоследнююТочку(Алгоритм);
			
			Для каждого СтрокаВизы Из СтрокаОбъекта.Строки Цикл
				ОписаниеВизы = ПараметрыВизы[СтрокаВизы.ОбъектКлючВизы];
				Если Справочники.бит_АлгоритмыПроцессов.ДействиеВАлгоритме(Алгоритм, ОписаниеВизы.Действие) Тогда
					Продолжить;
				КонецЕсли;
				
				РеквизитыВизы  = Новый Структура("Наименование, ПользовательскоеДействие",
												Строка(ОписаниеВизы.Виза),
												ОписаниеВизы.Действие);
				Параметры      = Новый Структура("Реквизиты", РеквизитыВизы);
				ПоследняяТочка = бит_УправлениеПроцессами.ДобавитьТочкуАлгоритма(Алгоритм,
																	ПоследняяТочка,
																	Перечисления.бит_Направление.Вертикаль,
																	Перечисления.бит_ВидыТочекАлгоритмов.Действие,
																	0,
																	"Ошибки",
																	Параметры,
																	Истина);
			КонецЦикла;
			
			Справочники.бит_АлгоритмыПроцессов.ДобавитьТочкиЗавершения(Алгоритм);
			ГрафическаяСхема = Справочники.бит_АлгоритмыПроцессов.КартаМаршрутаПоТочкамАлгоритма(Алгоритм);
			АлгоритмОбъект   = Алгоритм.ПолучитьОбъект();
			АлгоритмОбъект.КартаМаршрута = Новый ХранилищеЗначения(ГрафическаяСхема, Новый СжатиеДанных(9));
			// АПК:1327-выкл Вызывается при обновлении ИБ в монопольном режиме.
			АлгоритмОбъект.Записать();
			// АПК:1327-вкл
		КонецЕсли;
		
		Если НазначатьВизы Тогда
			ОбъектСистемы = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(ОбъектМетаданных.ПолноеИмя());
			Если НЕ бит_ОбщегоНазначенияПовтИсп.МеханизмВизированияОтключен(ОбъектСистемы)
				И НетНазначенныхАлгоритмов(ОбъектСистемы) Тогда
				Справочники.бит_АлгоритмыПроцессов.НазначитьАлгоритм(Алгоритм, ОбъектСистемы, ДатаНазначенияАлгоритма);
				НазначеныАлгоритмы = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если ВыводитьСообщения Тогда
		ТекстСообщения =  НСтр("ru='Созданы алгоритмы визирования по-умолчанию.';en='Default visa algorithms created.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецЕсли; 
	
	// Назначение алгоритмов.
	Если НазначеныАлгоритмы Тогда
		Если ВыводитьСообщения Тогда
			ТекстСообщения =  НСтр("ru='Назначены алгоритмы визирования по-умолчанию.';en='Default signing algorithms set'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		КонецЕсли; 
	КонецЕсли;
	
КонецПроцедуры

Функция НоваяТаблицаЗаполненияВиз()
	
	ТипСтрока  = Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(150, ДопустимаяДлина.Переменная));
	
	ТаблицаВиз = Новый ТаблицаЗначений;
	ТаблицаВиз.Колонки.Добавить("КлючВизы",     ТипСтрока);
	ТаблицаВиз.Колонки.Добавить("Наименование", ТипСтрока);
	ТаблицаВиз.Колонки.Добавить("Литера",       ТипСтрока);
	
	Возврат ТаблицаВиз;
	
КонецФункции

Функция НовоеДеревоЗаполненияАлгоритмов()
	
	ДеревоАлгоримтов = Новый ДеревоЗначений;
	ДеревоАлгоримтов.Колонки.Добавить("ОбъектКлючВизы");
	
	Возврат ДеревоАлгоримтов;
	
КонецФункции

// Создает элемент справочника визы.
// 
Функция СоздатьВизу(НаименованиеВизы, Литера)
	
	НайденныйСпр = Справочники.бит_Визы.НайтиПоНаименованию(НаименованиеВизы);
	Если НЕ ЗначениеЗаполнено(НайденныйСпр) Тогда
		СпрОбъект = Справочники.бит_Визы.СоздатьЭлемент();
		СпрОбъект.Вид = Перечисления.бит_ВидыВиз.Утверждающая;
		СпрОбъект.ВидСвязи     = Перечисления.бит_ВидыСвязиВиз.ФизическоеЛицо;
		СпрОбъект.ОбъектСвязи  = Справочники.ФизическиеЛица.ПустаяСсылка();
		СпрОбъект.Наименование = НаименованиеВизы;
		СпрОбъект.Литера       = Литера;
		СпрОбъект.РежимПечати  = Перечисления.бит_РежимПечатиВиз.Виза;
		СпрОбъект.ОбменДанными.Загрузка = Истина;
		СпрОбъект.УстановитьНовыйКод();
		СпрОбъект.Записать();	
		ТекущаяВиза = СпрОбъект.Ссылка;
	Иначе
		ТекущаяВиза = НайденныйСпр;
	КонецЕсли; 
	
	Возврат ТекущаяВиза;
	
КонецФункции

// Выполняет заполнение виз согласно алгоритму визирования.
// 
// Параметры:
//  СтруктураПараметров  - Структура.
// 
Процедура ЗаполнитьВизыПоАлгоритму(СтруктураПараметров)

	Если НЕ ЗначениеЗаполнено(СтруктураПараметров.ТекущийОбъект) Тогда
		Возврат;
	КонецЕсли; 

	// Получим алгоритм визирования, если необходимо.
	Если НЕ СтруктураПараметров.Свойство("Алгоритм") Тогда
		АлгоритмВизирования = бит_УправлениеПроцессами.АлгоритмВизированияОбъекта(СтруктураПараметров.ТекущийОбъект);
	Иначе
		АлгоритмВизирования = СтруктураПараметров.Алгоритм;
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(АлгоритмВизирования) Тогда
		Возврат;
	КонецЕсли; 
	
	// Считаем набор виз, если необходимо.
	Если НЕ СтруктураПараметров.Свойство("НаборВизы") Тогда
		Отбор = Новый Структура;
		Отбор.Вставить("Объект",СтруктураПараметров.ТекущийОбъект.Ссылка);	
		НаборЗаписейВизы = ПрочитатьНаборВиз(Отбор);
		Если СтруктураПараметров.ОчищатьНабор Тогда
			НаборЗаписейВизы.Очистить();
		КонецЕсли; 
	Иначе	
		НаборЗаписейВизы = СтруктураПараметров.НаборВизы;
	КонецЕсли; 
	
    // Заполним визы согласно алгоритму визирования.
	СтруктураКонтекст = Новый Структура;
	СтруктураКонтекст.Вставить("ТекущийОбъект", СтруктураПараметров.ТекущийОбъект);
	СтруктураКонтекст.Вставить("Визы"         , НаборЗаписейВизы);
	
	КомментироватьВыполнение = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию("КомментироватьХодВыполненияАлгоритмовПроцессов",
									Пользователи.ТекущийПользователь());
		
	РежимСообщений = ?(КомментироватьВыполнение,"Все","Ошибки");				
	
	бит_УправлениеПроцессами.ВыполнитьАлгоритм(АлгоритмВизирования,СтруктураКонтекст,РежимСообщений);
	
	УпорядочитьВизыБезАнализаАлгоритма(НаборЗаписейВизы);
		
	Если СтруктураПараметров.ЗаписыватьНабор Тогда
		Попытка
			НаборЗаписейВизы.Записать();
		Исключение
			Событие = НСтр("ru = 'Ошибка заполенения виз по алгоритму'", ОбщегоНазначения.КодОсновногоЯзыка());
			ЗаписьЖурналаРегистрации(Событие
									,УровеньЖурналаРегистрации.Ошибка
									,
									,
									,
									ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЕсли; 
	
КонецПроцедуры

Функция УпорядочитьВизыБезАнализаАлгоритма(НаборЗаписейВизы)
	
	ТаблицаВизы = НаборЗаписейВизы.Выгрузить();
	ТаблицаВизы.Колонки.Добавить("ПринятоРешение", Новый ОписаниеТипов("Булево"));
	
	Для каждого СтрокаВизы Из ТаблицаВизы Цикл
		СтрокаВизы.ПринятоРешение = ЗначениеЗаполнено(СтрокаВизы.Решение);
	КонецЦикла;
	ТаблицаВизы.Сортировать("ПринятоРешение Убыв, АктивнаяВиза Убыв, КодСортировки");
	
	СортировкаИзменена = Ложь;
	Порядок = 1;
	Для каждого СтрокаВизы Из ТаблицаВизы Цикл
		Если СтрокаВизы.КодСортировки <> Порядок Тогда
			СтрокаВизы.КодСортировки = Порядок;
			СортировкаИзменена       = Истина;
		КонецЕсли;
		Порядок = Порядок + 1;
	КонецЦикла;
	
	Если СортировкаИзменена Тогда
		НаборЗаписейВизы.Загрузить(ТаблицаВизы);
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция СтруктурноеПодразделение(ТекущийОбъект)
	
	СтруктурноеПодразделение = Новый Структура;
	Если ТекущийОбъект <> Неопределено Тогда
		МетаОбъект = ТекущийОбъект.Метаданные();
	
		ЕстьОрганизация = бит_РаботаСМетаданными.ЕстьРеквизит("Организация", МетаОбъект);
		ЕстьЦФО			= бит_РаботаСМетаданными.ЕстьРеквизит("ЦФО", МетаОбъект);
	
		Если ЕстьОрганизация Тогда
			СтруктурноеПодразделение.Вставить("Организация", ТекущийОбъект.Организация);
		КонецЕсли;
		Если ЕстьЦФО Тогда
			СтруктурноеПодразделение.Вставить("ЦФО", ТекущийОбъект.ЦФО);
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтруктурноеПодразделение;
	
КонецФункции

Функция ПараметрыРабочегоВремени(СтруктурноеПодразделение, Период)
	
	ПустаяДата = '00010101';
	ПараметрыРабочегоВремени = Новый Структура;
	ПараметрыРабочегоВремени.Вставить("ИспользуетсяГрафик",          Ложь);
	ПараметрыРабочегоВремени.Вставить("ИспользуетсяКалендарь",       Ложь);
	ПараметрыРабочегоВремени.Вставить("УчитыватьПредпраздничныеДни", Ложь);
	ПараметрыРабочегоВремени.Вставить("НачалоРабочегоДня",           ПустаяДата);
	ПараметрыРабочегоВремени.Вставить("ВремяНачалаРабочегоДня",      0);
	ПараметрыРабочегоВремени.Вставить("ОкончаниеРабочегоДня",        ПустаяДата);
	ПараметрыРабочегоВремени.Вставить("ВремяОкончанияРабочегоДня",   0);
	ПараметрыРабочегоВремени.Вставить("РабочиеДни",                  Новый СписокЗначений);
	ПараметрыРабочегоВремени.Вставить("ПредпраздничныеДни",          Новый СписокЗначений);
	ПараметрыРабочегоВремени.Вставить("УчитыватьОбеденныйПерерыв",   Ложь);
	ПараметрыРабочегоВремени.Вставить("ВремяНачалаПерерыва",         0);
	ПараметрыРабочегоВремени.Вставить("ВремяОкончанияПерерыва",      0);
	
	ПараметрыРабочегоВремени.НачалоРабочегоДня =
		бит_НастройкиПрограммы.ВизированиеНачалоРабочегоДня(СтруктурноеПодразделение, Период);
	ПараметрыРабочегоВремени.ОкончаниеРабочегоДня =
		бит_НастройкиПрограммы.ВизированиеОкончаниеРабочегоДня(СтруктурноеПодразделение, Период);
	ПараметрыРабочегоВремени.ИспользуетсяГрафик = ЗначениеЗаполнено(ПараметрыРабочегоВремени.НачалоРабочегоДня)
													И ЗначениеЗаполнено(ПараметрыРабочегоВремени.ОкончаниеРабочегоДня);
	ПараметрыРабочегоВремени.ВремяНачалаРабочегоДня = ПараметрыРабочегоВремени.НачалоРабочегоДня
														- НачалоДня(ПараметрыРабочегоВремени.НачалоРабочегоДня);
	ПараметрыРабочегоВремени.ВремяОкончанияРабочегоДня = ПараметрыРабочегоВремени.ОкончаниеРабочегоДня
														- НачалоДня(ПараметрыРабочегоВремени.ОкончаниеРабочегоДня);
	Если ПараметрыРабочегоВремени.ИспользуетсяГрафик Тогда
		НачалоОбеденногоПерерыва    = бит_НастройкиПрограммы.НастройкаВизирования("бит_ВизированиеНачалоОбеденногоПерерыва",
										СтруктурноеПодразделение, Период, ПустаяДата);
		ОкончаниеОбеденногоПерерыва = бит_НастройкиПрограммы.НастройкаВизирования("бит_ВизированиеОкончаниеОбеденногоПерерыва",
										СтруктурноеПодразделение, Период, ПустаяДата);
		Если ЗначениеЗаполнено(НачалоОбеденногоПерерыва) И ЗначениеЗаполнено(ОкончаниеОбеденногоПерерыва) Тогда
			ПараметрыРабочегоВремени.УчитыватьОбеденныйПерерыв = Истина;
			ПараметрыРабочегоВремени.ВремяНачалаПерерыва    = НачалоОбеденногоПерерыва - НачалоДня(НачалоОбеденногоПерерыва);
			ПараметрыРабочегоВремени.ВремяОкончанияПерерыва =
				ОкончаниеОбеденногоПерерыва - НачалоДня(ОкончаниеОбеденногоПерерыва);
		КонецЕсли;
	КонецЕсли;
	
	РабочиеДни = РабочиеДниПодразделения(СтруктурноеПодразделение, Период);
	Если РабочиеДни <> Неопределено Тогда
		ПараметрыРабочегоВремени.ИспользуетсяКалендарь       = Истина;
		ПараметрыРабочегоВремени.РабочиеДни                  = РабочиеДни;
		ПараметрыРабочегоВремени.УчитыватьПредпраздничныеДни = бит_НастройкиПрограммы.НастройкаВизирования(
			"бит_ВизированиеУчитыватьПредпраздничныеДни", СтруктурноеПодразделение, Период, Ложь);
		Если ПараметрыРабочегоВремени.УчитыватьПредпраздничныеДни Тогда
			ПараметрыРабочегоВремени.ПредпраздничныеДни = РабочиеДниПодразделения(СтруктурноеПодразделение, Период, Истина);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПараметрыРабочегоВремени;
	
КонецФункции

Функция РабочиеДниПодразделения(СтруктурноеПодразделение, Период, ТолькоПредпраздничные = Ложь)
	
	ИспользоватьКалендарь = бит_НастройкиПрограммы.ИспользоватьКалендарьДляРасчетаКрайнейДаты(
								СтруктурноеПодразделение, Период);
	Календарь             = бит_НастройкиПрограммы.Календарь(СтруктурноеПодразделение, Период);

	Если НЕ ИспользоватьКалендарь
		ИЛИ НЕ ЗначениеЗаполнено(Календарь) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	РабочиеДни = Новый Массив;
	Если НЕ ТолькоПредпраздничные Тогда
		РабочиеДни.Добавить(Перечисления.ВидыДнейПроизводственногоКалендаря.Рабочий);
	КонецЕсли;
	РабочиеДни.Добавить(Перечисления.ВидыДнейПроизводственногоКалендаря.Предпраздничный);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДанныеПроизводственногоКалендаря.Дата КАК РабочийДень
	|ИЗ
	|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	|ГДЕ
	|	ДанныеПроизводственногоКалендаря.ПроизводственныйКалендарь = &Календарь
	|	И ДанныеПроизводственногоКалендаря.ВидДня В(&РабочиеДни)
	|	И ДанныеПроизводственногоКалендаря.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода";
	Запрос.УстановитьПараметр("Календарь"		, Календарь);
	Запрос.УстановитьПараметр("РабочиеДни"		, РабочиеДни);
	Запрос.УстановитьПараметр("НачалоПериода"	, НачалоДня(Период));
	Запрос.УстановитьПараметр("ОкончаниеПериода", ДобавитьМесяц(Период, 1));
	
	ТабилцаДней = Запрос.Выполнить().Выгрузить();
	РабочиеДни = Новый СписокЗначений;
	РабочиеДни.ЗагрузитьЗначения(ТабилцаДней.ВыгрузитьКолонку("РабочийДень"));
	
	Возврат РабочиеДни;
	
КонецФункции

Процедура СдвинутьСрокНаРабочийПериод(Период, ПараметрыРабочегоВремени, СчетчикВызова = 0)
	
	ГлубинаАнализаКалендаря = 30;	
	Если СчетчикВызова >= ГлубинаАнализаКалендаря Тогда
		Возврат;
	Иначе
		СчетчикВызова = СчетчикВызова + 1;
	КонецЕсли;
	
	Если ПараметрыРабочегоВремени.ИспользуетсяГрафик Тогда
		НачалоДняПериода          = НачалоДня(Период);
		ВремяПериода              = Период - НачалоДняПериода;
		ВремяНачалаРабочегоДня    = ПараметрыРабочегоВремени.ВремяНачалаРабочегоДня;
		ВремяОкончанияРабочегоДня = ВремяОкончанияРабочегоДня(Период, ПараметрыРабочегоВремени);
		
		Если ВремяПериода < ВремяНачалаРабочегоДня Тогда
			Период = НачалоДняПериода + ВремяНачалаРабочегоДня;
		ИначеЕсли ВремяПериода > ВремяОкончанияРабочегоДня Тогда
			Период = КонецДня(Период) + 1 + ВремяНачалаРабочегоДня;
		КонецЕсли;
	КонецЕсли;
	
	Если ПараметрыРабочегоВремени.ИспользуетсяКалендарь Тогда
		НачалоДняПериода = НачалоДня(Период);
		Если ПараметрыРабочегоВремени.РабочиеДни.НайтиПоЗначению(НачалоДняПериода) <> Неопределено Тогда
			Возврат;
		КонецЕсли;
			
		Период = КонецДня(Период) + 1;
		СдвинутьСрокНаРабочийПериод(Период, ПараметрыРабочегоВремени, СчетчикВызова);
	КонецЕсли;
	
КонецПроцедуры

Функция ВремяОкончанияРабочегоДня(Период, ПараметрыРабочегоВремени)
	
	ВремяОкончанияРабочегоДня = ПараметрыРабочегоВремени.ВремяОкончанияРабочегоДня;
	Если НЕ ПараметрыРабочегоВремени.УчитыватьПредпраздничныеДни
		ИЛИ НЕ ЗначениеЗаполнено(ВремяОкончанияРабочегоДня) Тогда
		Возврат ВремяОкончанияРабочегоДня;
	КонецЕсли;
	
	НачалоДняПериода = НачалоДня(Период);
	Если ПараметрыРабочегоВремени.ПредпраздничныеДни.НайтиПоЗначению(НачалоДняПериода) <> Неопределено Тогда
		ЧасВСекундах = 3600;
		ВремяОкончанияРабочегоДня = ВремяОкончанияРабочегоДня - ЧасВСекундах;
	КонецЕсли;
	
	Возврат ВремяОкончанияРабочегоДня;
	
КонецФункции

Процедура ДобавитьДниНаУстановку(Период, СекундНаУстановку, ПараметрыРабочегоВремени)
	
	СекундВДне     = 86400;
	КоличествоДней = Цел(СекундНаУстановку / СекундВДне);
	
	Если КоличествоДней = 0 Тогда
		Возврат;
	КонецЕсли;
	
	РабочееВремяСдвигаемойДаты = Период - НачалоДня(Период);
	
	СекундНаУстановку = СекундНаУстановку % СекундВДне;
	Для Сч = 1 По КоличествоДней Цикл
		Период = КонецДня(Период) + 1;
		СдвинутьСрокНаРабочийПериод(Период, ПараметрыРабочегоВремени);
	КонецЦикла;
	
	Период = НачалоДня(Период) + РабочееВремяСдвигаемойДаты;
	СдвинутьСрокНаРабочийПериод(Период, ПараметрыРабочегоВремени);
	
КонецПроцедуры

Процедура ДобавитьВремяНаУстановку(СрокИсполнения, ВремяНаУстановку, ПараметрыРабочегоВремени)
	
	Если ВремяНаУстановку = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ВремяОкончанияРабочегоДня = ВремяОкончанияРабочегоДня(СрокИсполнения, ПараметрыРабочегоВремени);
	ВремяПерерыва = ПараметрыРабочегоВремени.ВремяОкончанияПерерыва - ПараметрыРабочегоВремени.ВремяНачалаПерерыва;
	
	ОстатокРабочегоВремени = 0;
	Если ПараметрыРабочегоВремени.ИспользуетсяГрафик Тогда
		ТекущееВремя           = СрокИсполнения - НачалоДня(СрокИсполнения);
		ОстатокРабочегоВремени = ВремяОкончанияРабочегоДня - ТекущееВремя;
		Если ПараметрыРабочегоВремени.УчитыватьОбеденныйПерерыв Тогда
			Если ТекущееВремя < ПараметрыРабочегоВремени.ВремяНачалаПерерыва Тогда
				ОстатокРабочегоВремени = ОстатокРабочегоВремени - ВремяПерерыва;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ОстатокРабочегоВремени = КонецДня(СрокИсполнения) - СрокИсполнения;
	КонецЕсли;
	
	Если ВремяНаУстановку <= ОстатокРабочегоВремени Тогда
		СрокИсполнения = СрокИсполнения + ВремяНаУстановку;
		Если ПараметрыРабочегоВремени.УчитыватьОбеденныйПерерыв Тогда
			ТекущееВремя = СрокИсполнения - НачалоДня(СрокИсполнения);
			Если ТекущееВремя < ПараметрыРабочегоВремени.ВремяОкончанияПерерыва
				И ТекущееВремя > ПараметрыРабочегоВремени.ВремяНачалаПерерыва Тогда
				СрокИсполнения = СрокИсполнения + ВремяПерерыва;
			КонецЕсли;
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	ВремяНаУстановку = ВремяНаУстановку - ОстатокРабочегоВремени;
	СрокИсполнения   = КонецДня(СрокИсполнения) + 1;
	СдвинутьСрокНаРабочийПериод(СрокИсполнения, ПараметрыРабочегоВремени);
	ДобавитьВремяНаУстановку(СрокИсполнения, ВремяНаУстановку, ПараметрыРабочегоВремени);
	
КонецПроцедуры

// Удаляет из набора визы, подчиненные визам по которым не принято решение.
// 
// Параметры:
//  ТаблицаТочкиВизы  - ТаблицаЗначений.
//  НаборВизы         - РегистрСведенийНаборЗаписей.бит_УстановленныеВизы.
// 
Процедура УдалитьНижестоящиеВизы(ТаблицаТочкиВизы, НаборВизы)

	ВизыДляУдаления = Новый Массив;
	Для каждого СтрокаТаблицы Из ТаблицаТочкиВизы Цикл
		Если СтрокаТаблицы.ВходящиеТочки.Количество() = 0 Тогда
			// Начальные точки.
			НайтиВизыБезРешений(ВизыДляУдаления, СтрокаТаблицы, ТаблицаТочкиВизы);
		КонецЕсли;
	КонецЦикла;
	
	Если ВизыДляУдаления.Количество() > 0 Тогда
		УдалитьВизыПоМассиву(НаборВизы, ВизыДляУдаления);
	КонецЕсли;

КонецПроцедуры

// Удаляет из набора визы, указанные в массиве.
// 
// Параметры:
//  НаборВизы  - РегистрСведенийНаборЗаписей.бит_УстановленныеВизы.
//  МассивВиз  - Массив.
// 
Процедура УдалитьВизыПоМассиву(НаборВизы,МассивВиз)

	КоличествоНабор = НаборВизы.Количество();
	
	Для Сч = 1 По КоличествоНабор Цикл
		 // Индекс с конца.
		 ЧислоЙ = КоличествоНабор-Сч;
		 ЗаписьВизы = НаборВизы[ЧислоЙ];
		 Для Каждого Элемент Из МассивВиз Цикл
			// Поиск по ИД, т.к. одна виза может встречаться несколько раз.
		 	Если Элемент = ЗаписьВизы.ИД Тогда
				НаборВизы.Удалить(ЗаписьВизы);
				Прервать;
			КонецЕсли; 
		 КонецЦикла; // По массиву виз.
	КонецЦикла; // По набору виз. 

КонецПроцедуры

Функция ВизыУстановлены(Ссылка)
	
	Если Ссылка.Пустая() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВизыОбъекта.Виза КАК Виза
	|ИЗ
	|	РегистрСведений.бит_УстановленныеВизы КАК ВизыОбъекта
	|ГДЕ
	|	ВизыОбъекта.Объект = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат НЕ Запрос.Выполнить().Пустой();
	
КонецФункции

Процедура НайтиВизыБезРешений(ВизыДляУдаления, СтрокаВизы, ТаблицаТочкиВизы, Знач РодительБезРешения = Ложь, РезультатыПроверок = Неопределено)
	
	ТекущаяТочка = СтрокаВизы.Точка;
	
	Если РезультатыПроверок = Неопределено Тогда
		РезультатыПроверок = Новый Соответствие;
	Иначе
		Если РезультатыПроверок.Получить(ТекущаяТочка) <> Неопределено Тогда
			// Анализ данной точки уже выполнялся (цикличный алгоритм).
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если СтрокаВизы.ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Действие Тогда
		Если РодительБезРешения И ЗначениеЗаполнено(СтрокаВизы.Виза) Тогда
			// Т.к. визы могут повторяться для обработки необходим ИД.
			ВизыДляУдаления.Добавить(СтрокаВизы.ИД);
			СтрокаВизы.Виза = Справочники.бит_Визы.ПустаяСсылка();
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаВизы.Решение) Тогда
			РодительБезРешения = Истина;
		КонецЕсли;
	КонецЕсли;
	
	РезультатыПроверок.Вставить(ТекущаяТочка, РодительБезРешения);
	
	Для каждого ИсходящаяТочка Из СтрокаВизы.ИсходящиеТочки Цикл
		СтрокаИсходящейТочки = ТаблицаТочкиВизы.Найти(ИсходящаяТочка.Точка, "Точка");
		
		Если СтрокаИсходящейТочки.ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Слияние
			И РодительБезРешения Тогда
			
			ПропуститьПроверкуВетки = Ложь;
			// По текущей ветке не принято решение, однако решение может быть принято по другой ветке.
			Для каждого СтрокаВходящейТочкиСлияния Из СтрокаИсходящейТочки.ВходящиеТочки Цикл
				ВходящаяТочка     = СтрокаВходящейТочкиСлияния.Точка;
				РезультатПроверки = РезультатыПроверок.Получить(ВходящаяТочка);
				
				Если РезультатПроверки = Неопределено Тогда
					// Проверка заполнения решения по данной ветке не выполнялось.
					ПропуститьПроверкуВетки = Истина;
					Прервать;
				КонецЕсли;
				Если РезультатПроверки = Ложь Тогда
					// По данной ветке есть установленные решения.
					ПропуститьПроверкуВетки = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			Если ПропуститьПроверкуВетки Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если СтрокаИсходящейТочки <> Неопределено Тогда
			НайтиВизыБезРешений(ВизыДляУдаления, СтрокаИсходящейТочки, ТаблицаТочкиВизы, РодительБезРешения, РезультатыПроверок);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция АвтоустановкаРешенийНаборуВиз(ПараметрыКонтекста)
	
	РешенияУстановлены = Ложь;
	НаборВизы          = ПараметрыКонтекста.НаборВизы;
	
	Если НаборВизы.Количество() = 0 Тогда
		Возврат РешенияУстановлены;
	КонецЕсли;
	
	ТаблицаВиз = НаборВизы.Выгрузить();
	ТаблицаВиз.Колонки.Добавить("ИндексСтроки", Новый ОписаниеТипов("Число",
												Новый КвалификаторыЧисла(5, 0, ДопустимыйЗнак.Неотрицательный)));
	ТекущийИндекс = 0;
	Для каждого СтрокаВизы Из ТаблицаВиз Цикл
		СтрокаВизы.ИндексСтроки = ТекущийИндекс;
		ТекущийИндекс = ТекущийИндекс + 1;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаВиз.Пользователь КАК Пользователь,
	|	ТаблицаВиз.Решение КАК Решение,
	|	ТаблицаВиз.КодСортировки КАК КодСортировки,
	|	ТаблицаВиз.Объект КАК Объект,
	|	ТаблицаВиз.Виза КАК Виза,
	|	ТаблицаВиз.ИндексСтроки КАК ИндексСтроки,
	|	ТаблицаВиз.ТочкаАлгоритма КАК ТочкаАлгоритма
	|ПОМЕСТИТЬ ТаблицаВиз
	|ИЗ
	|	&ТаблицаВиз КАК ТаблицаВиз";
	Запрос.УстановитьПараметр("ТаблицаВиз", ТаблицаВиз);
	Запрос.Выполнить();
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаВиз.Объект КАК Объект,
	|	ТаблицаВиз.Виза КАК Виза,
	|	ТаблицаВиз.ИндексСтроки КАК ИндексСтроки
	|ПОМЕСТИТЬ ВизыДляАвтосогласования
	|ИЗ
	|	ТаблицаВиз КАК ТаблицаВиз
	|ГДЕ
	|	ТаблицаВиз.Решение = ЗНАЧЕНИЕ(Справочник.бит_ВидыРешенийСогласования.ПустаяСсылка)
	|	И НЕ ТаблицаВиз.ТочкаАлгоритма В (&СтекОчистки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВизыДляАвтосогласования.Объект КАК Объект,
	|	ВизыДляАвтосогласования.Виза КАК Виза
	|ИЗ
	|	ВизыДляАвтосогласования КАК ВизыДляАвтосогласования";
	Запрос.УстановитьПараметр("СтекОчистки", ПараметрыКонтекста.СтекОчистки); // Защита от зацикливания.
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		// Все визы согласованы.
		Возврат РешенияУстановлены;
	КонецЕсли;
	ВизыДляАвтосогласования = РезультатЗапроса.Выгрузить();
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаВиз.Пользователь КАК Пользователь,
	|	МАКСИМУМ(ТаблицаВиз.КодСортировки) КАК КодСортировки
	|ПОМЕСТИТЬ ПоследниеСогласованныеПозиции
	|ИЗ
	|	ТаблицаВиз КАК ТаблицаВиз
	|ГДЕ
	|	ТаблицаВиз.Решение <> ЗНАЧЕНИЕ(Справочник.бит_ВидыРешенийСогласования.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаВиз.Пользователь
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПоследниеСогласованныеПозиции.Пользователь КАК Пользователь,
	|	МАКСИМУМ(ТаблицаВиз.Решение) КАК Решение
	|ПОМЕСТИТЬ ПоследниеРешения
	|ИЗ
	|	ПоследниеСогласованныеПозиции КАК ПоследниеСогласованныеПозиции
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаВиз КАК ТаблицаВиз
	|		ПО ПоследниеСогласованныеПозиции.Пользователь = ТаблицаВиз.Пользователь
	|			И ПоследниеСогласованныеПозиции.КодСортировки = ТаблицаВиз.КодСортировки
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоследниеСогласованныеПозиции.Пользователь
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ПоследниеСогласованныеПозиции
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПоследниеРешения.Пользователь КАК Пользователь,
	|	ПоследниеРешения.Решение КАК Решение
	|ИЗ
	|	ПоследниеРешения КАК ПоследниеРешения";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		// Нет согласованных позиций.
		Возврат РешенияУстановлены;
	КонецЕсли;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПоследниеРешения.Пользователь КАК Пользователь,
	|	ПоследниеРешения.Решение КАК Решение
	|ПОМЕСТИТЬ РешенияАвтоустановки
	|ИЗ
	|	ПоследниеРешения КАК ПоследниеРешения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_НастройкиПользователей КАК НастройкиПользователей
	|		ПО ПоследниеРешения.Пользователь = НастройкиПользователей.Пользователь
	|			И (НастройкиПользователей.Настройка = ЗНАЧЕНИЕ(ПланВидовХарактеристик.бит_НастройкиПользователей.АвтоустановкаВсехВизПриСогласовании))
	|			И (НастройкиПользователей.ЗначениеНастройки = ИСТИНА)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ПоследниеРешения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РешенияАвтоустановки.Пользователь КАК Пользователь
	|ИЗ
	|	РешенияАвтоустановки КАК РешенияАвтоустановки";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		// Нет согласующих с настройками автоустановки виз.
		Возврат РешенияУстановлены;
	КонецЕсли;
	ПользователиСАвтоустановкой = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Пользователь");
	
	ТаблицаДоступа = ОтветственныеЗаУстановкуВиз(ВизыДляАвтосогласования, ПользователиСАвтоустановкой);
	Если ТаблицаДоступа.Количество() = 0 Тогда
		// Для пользователей нет доступных виз для автосогласования.
		Возврат РешенияУстановлены;
	КонецЕсли;
	
	АктивныеВизы = АктивныеВизы(ПараметрыКонтекста);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаДоступа.Виза КАК Виза,
	|	ТаблицаДоступа.Ответственный КАК Ответственный
	|ПОМЕСТИТЬ ДоступныеВизыПользователей
	|ИЗ
	|	&ТаблицаДоступа КАК ТаблицаДоступа
	|ГДЕ
	|	ТаблицаДоступа.Виза В (&АктивныеВизы)";
	Запрос.УстановитьПараметр("ТаблицаДоступа", ТаблицаДоступа);
	Запрос.УстановитьПараметр("АктивныеВизы"  , АктивныеВизы);
	Запрос.Выполнить();
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВизыДляАвтосогласования.ИндексСтроки КАК ИндексСтроки,
	|	ДоступныеВизыПользователей.Виза КАК Виза,
	|	РешенияАвтоустановки.Пользователь КАК Пользователь,
	|	РешенияАвтоустановки.Решение КАК Решение
	|ИЗ
	|	ДоступныеВизыПользователей КАК ДоступныеВизыПользователей
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РешенияАвтоустановки КАК РешенияАвтоустановки
	|		ПО ДоступныеВизыПользователей.Ответственный = РешенияАвтоустановки.Пользователь
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВизыДляАвтосогласования КАК ВизыДляАвтосогласования
	|		ПО ДоступныеВизыПользователей.Виза = ВизыДляАвтосогласования.Виза
	|ИТОГИ ПО
	|	ИндексСтроки";
	ВыборкаСтрок = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	АвтоСогласованныеТочки = Новый Массив;
	Пока ВыборкаСтрок.Следующий() Цикл
		ВыборкаРешений = ВыборкаСтрок.Выбрать();
		ВыборкаРешений.Следующий();
		
		ЗаписьВизы = НаборВизы[ВыборкаРешений.ИндексСтроки];
		ЗаписьВизы.Пользователь  = ВыборкаРешений.Пользователь;
		ЗаписьВизы.Решение       = ВыборкаРешений.Решение;
		ЗаписьВизы.Комментарий   = "Автосогласование";
		ЗаписьВизы.ДатаУстановки = ТекущаяДатаСеанса();
		
		АвтоСогласованныеТочки.Добавить(ЗаписьВизы.ТочкаАлгоритма);
		
		РешенияУстановлены       = Истина;
	КонецЦикла;
	
	ПараметрыПоследующихТочек = бит_УправлениеПроцессами.ТочкиДействияПослеТекущей(АвтоСогласованныеТочки,
																					ПараметрыКонтекста);
																					
	ТочкиОбработок = ПараметрыПоследующихТочек.ТочкиОбработок;
	бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(ТочкиОбработок);
	Справочники.бит_ПользовательскиеДействия.ВыполнитьТочкиОбработки(ТочкиОбработок, ПараметрыКонтекста);
	
	// Очистка решений по действиям цикличных процессов
	ОчищаемыеДействия = Новый СписокЗначений;
	ОчищаемыеДействия.ЗагрузитьЗначения(ПараметрыПоследующихТочек.ТочкиДействия);
	АвтоСогласованныеДействия = Новый СписокЗначений;
	АвтоСогласованныеДействия.ЗагрузитьЗначения(АвтоСогласованныеТочки);
	Если ОчищаемыеДействия.Количество() > 0 Тогда
		Для каждого СтрокаВизы Из НаборВизы Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаВизы.Решение) Тогда
				Продолжить;
			КонецЕсли;
			
			ТочкаАлгоритма = СтрокаВизы.ТочкаАлгоритма;
			
			Если ОчищаемыеДействия.НайтиПоЗначению(ТочкаАлгоритма) = Неопределено
				ИЛИ АвтоСогласованныеДействия.НайтиПоЗначению(ТочкаАлгоритма) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Если ПараметрыКонтекста.СтекОчистки.НайтиПоЗначению(ТочкаАлгоритма) = Неопределено Тогда
				ПараметрыКонтекста.СтекОчистки.Добавить(ТочкаАлгоритма);
			КонецЕсли;
			
			СтрокаВизы.Пользователь  = Неопределено;
			СтрокаВизы.Решение       = Неопределено;
			СтрокаВизы.Комментарий   = "";
			СтрокаВизы.ДатаУстановки = Дата('00010101');
		КонецЦикла;
	КонецЕсли;
	
	Возврат РешенияУстановлены;
	
КонецФункции

Функция АктивныеВизы(ПараметрыКонтекста)
	
	Алгоритм    = ПараметрыКонтекста.Алгоритм;
	ТаблицаВизы = ПараметрыКонтекста.НаборВизы.Выгрузить();
	ТаблицаВизы.Колонки.Добавить("ДоступностьВизы", Новый ОписаниеТипов("Булево"));
    ТаблицаВизы.ЗаполнитьЗначения(Истина, "ДоступностьВизы");
	
	ТаблицаТочек = бит_УправлениеПроцессами.ОписаниеТочекАлгоритма(Алгоритм, ТаблицаВизы);
	УдалитьНижестоящиеВизы(ТаблицаТочек, ТаблицаВизы);
	
	ВыполнятьПоэтапно = бит_УправлениеПроцессами.ВыполнятьАлгоритмПоэтапно(Алгоритм);
	
	ДопПараметрыПроверкиУсловий = НовыеПараметрыПроверкиУсловия();
	ДопПараметрыПроверкиУсловий.ТекущийОбъект = ПараметрыКонтекста.ТекущийОбъект;
	ДопПараметрыПроверкиУсловий.Визы          = ТаблицаВизы;
	ДопПараметрыПроверкиУсловий.Алгоритм      = Алгоритм;
	
	бит_УправлениеПроцессами.ОпределитьДоступностьТочек(ТаблицаТочек, ВыполнятьПоэтапно, ДопПараметрыПроверкиУсловий);
	
	АктивныеВизы = Новый Массив;
	Для каждого СтрокаВизы Из ТаблицаТочек Цикл
		Если СтрокаВизы.АктивнаяВиза <> Истина Тогда
			Продолжить;
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаВизы.Виза) Тогда
			АктивныеВизы.Добавить(СтрокаВизы.Виза);
		КонецЕсли;
	КонецЦикла;
	Возврат АктивныеВизы;
	
КонецФункции

Функция НетНазначенныхАлгоритмов(ОбъектСистемы)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НазначениеАлгоритмов.Алгоритм КАК Алгоритм
	|ИЗ
	|	РегистрСведений.бит_НазначениеАлгоритмов КАК НазначениеАлгоритмов
	|ГДЕ
	|	НазначениеАлгоритмов.ОбъектСистемы = &ОбъектСистемы";
	Запрос.УстановитьПараметр("ОбъектСистемы", ОбъектСистемы);
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса.Пустой();
	
КонецФункции

Процедура ОпередитьКрайниеСрокиИАктивность(ПараметрыКонтекста)
	
	Алгоритм          = ПараметрыКонтекста.Алгоритм;
	ВыполнятьПоэтапно = ПараметрыКонтекста.ВыполнятьПоэтапно;
	НаборВизы         = ПараметрыКонтекста.НаборВизы;
	ТекущийОбъект     = ПараметрыКонтекста.ТекущийОбъект;
	
	ТаблицаВизы = НаборВизы.Выгрузить();
	ТаблицаВизы.Колонки.Добавить("ДоступностьВизы", Новый ОписаниеТипов("Булево"));
	ТаблицаВизы.ЗаполнитьЗначения(Истина, "ДоступностьВизы");
	
	ТаблицаТочек = бит_УправлениеПроцессами.ОписаниеТочекАлгоритма(Алгоритм, ТаблицаВизы);
	
	Если ВыполнятьПоэтапно Тогда
		УдалитьНижестоящиеВизы(ТаблицаТочек, НаборВизы);
	КонецЕсли;
	
	ДопПараметрыПроверкиУсловий = НовыеПараметрыПроверкиУсловия();
	ДопПараметрыПроверкиУсловий.ТекущийОбъект = ТекущийОбъект;
	ДопПараметрыПроверкиУсловий.Визы          = НаборВизы;
	ДопПараметрыПроверкиУсловий.Алгоритм      = Алгоритм;
	
	бит_УправлениеПроцессами.ОпределитьДоступностьТочек(ТаблицаТочек, ВыполнятьПоэтапно, ДопПараметрыПроверкиУсловий);
	
	// Устанавливаем крайние даты и признак активности.
	Для каждого Запись Из НаборВизы Цикл
		СтрокаТаблицы = ТаблицаТочек.Найти(Запись.ИД,"ИД");
		Если СтрокаТаблицы = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если Запись.ВремяНаУстановку > 0 Тогда
			Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Решение) И НЕ СтрокаТаблицы.Доступность Тогда
				Запись.ДатаКрайняя = Дата("00010101");
			ИначеЕсли СтрокаТаблицы.Доступность И НЕ ЗначениеЗаполнено(Запись.ДатаКрайняя) Тогда
				ПараметрыРасчетаСрока = НовыеПараметрыРасчетаСрокаИсполнения();
				ПараметрыРасчетаСрока.ОбъектРасчета    = ТекущийОбъект;
				ПараметрыРасчетаСрока.ДатаОтсчета      = ТекущаяДатаСеанса();
				ПараметрыРасчетаСрока.ВремяНаУстановку = Запись.ВремяНаУстановку;
				Запись.ДатаКрайняя = СрокИсполнения(ПараметрыРасчетаСрока);
			КонецЕсли;
		КонецЕсли;
		
		Если Запись.АктивнаяВиза <> СтрокаТаблицы.АктивнаяВиза Тогда
			Запись.АктивнаяВиза = СтрокаТаблицы.АктивнаяВиза;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСПользовательскимиУсловиями

// Проверяет удовлетворяет ли объект визирования настройкам адресации роли. 
// Используется при формировании перечня ролевых виз.
// 
// Параметры:
//  ТекущийОбъект - ДокументСсылка, ДокументОбъект.
//  МетаОбъект    - ОбъектМетаданных.
//  Выборка       - ВыборкаИзРезультатаЗапроса.
// 
// Возвращаемое значение:
//  Булево.
// 
Функция ПроверитьПринадлежностьОбъектаВизирования(ТекущийОбъект, МетаОбъект,  Выборка) 
	
	Для Сч = 1 По 3 Цикл
		
		АдресацияВыполнена = Ложь;
		
		ИмяРеквизита    = Выборка["ИмяВида_" + Сч];
		ОбъектАдресации = Выборка["ОбъектАдресации_" + Сч];
		
		Если НЕ ЗначениеЗаполнено(ИмяРеквизита) Тогда
			АдресацияВыполнена = Истина;
			Продолжить;
		КонецЕсли;
			
		СпособПроверки = Выборка["СпособПроверки_" + Сч];
		Если НЕ ЗначениеЗаполнено(СпособПроверки) Тогда
			СпособПроверки = Перечисления.бит_СпособыПроверкиПринадлежностиОбъектаАдресации.Шапка;
		КонецЕсли;
		
		ПроверятьШапку    = Ложь;
		ПроверятьТабЧасть = Ложь;
		Если СпособПроверки = Перечисления.бит_СпособыПроверкиПринадлежностиОбъектаАдресации.ШапкаТабличныеЧасти Тогда
			ПроверятьШапку    = Истина;
			ПроверятьТабЧасть = Истина;
		ИначеЕсли СпособПроверки = Перечисления.бит_СпособыПроверкиПринадлежностиОбъектаАдресации.Шапка Тогда
			ПроверятьШапку    = Истина;
		ИначеЕсли СпособПроверки = Перечисления.бит_СпособыПроверкиПринадлежностиОбъектаАдресации.ТабличныеЧасти Тогда
			ПроверятьТабЧасть = Истина;
		КонецЕсли;
		
		Если ПроверятьШапку Тогда
			Если бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, МетаОбъект) Тогда
				// Проверка в реквизитах шапки.
				ЗначениеРеквизита = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущийОбъект, ИмяРеквизита);
				Если ЗначениеРеквизита = ОбъектАдресации Тогда
					АдресацияВыполнена = Истина;
					Продолжить;
				КонецЕсли;
			Иначе
				// Проверка в дополнительных реквизитах и сведениях.
				ЗначениеСвойства = УправлениеСвойствами.ЗначениеСвойства(ТекущийОбъект, ИмяРеквизита);
				Если ЗначениеСвойства = ОбъектАдресации Тогда
					АдресацияВыполнена = Истина;
					Продолжить;
				КонецЕсли;
			КонецЕсли; 
		КонецЕсли;
		
		Если ПроверятьТабЧасть Тогда
			ТабЧастьПодходит = Ложь;
			Для каждого МетаТабЧасть Из МетаОбъект.ТабличныеЧасти Цикл
				Если бит_РаботаСМетаданными.ЕстьРеквизитТабЧасти(ИмяРеквизита ,МетаОбъект ,МетаТабЧасть.Имя) Тогда
					СтрОтбор = Новый Структура(ИмяРеквизита, ОбъектАдресации);
					ТЧ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущийОбъект, МетаТабЧасть.Имя).Выгрузить();
					МассивСтрок = ТЧ.НайтиСтроки(СтрОтбор);
					ТабЧастьПодходит = ?(МассивСтрок.Количество() > 0, Истина, Ложь);
					Если ТабЧастьПодходит Тогда
						Прервать;
					КонецЕсли; 
				КонецЕсли; 
			КонецЦикла;
			Если бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
				ИмяОбъекта = МетаОбъект.Имя; 
				Если ИмяОбъекта = "бит_кзн_ЗаявкаНаРасходованиеСредств" 
					ИЛИ ИмяОбъекта = "бит_кзн_ПланируемоеПоступлениеДенежныхСредств" 
					ИЛИ ИмяОбъекта = "бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств" Тогда
					
					МодульВизирование = МодульВизированияПереопределяемый();
					// АПК:287-выкл вызывается только в ЕРП, УТ, КА.
					Если МодульВизирование.ПозицияСодержитЗначение(ТекущийОбъект, ИмяРеквизита, ОбъектАдресации) Тогда
					// АПК:287-вкл
						ТабЧастьПодходит = Истина;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			Если ТабЧастьПодходит Тогда
				АдресацияВыполнена = Истина;
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ АдресацияВыполнена Тогда
			// Если не выполнились условия по шапке или табличной части, значит объект не удовлетворяет адресации.
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#КонецОбласти