#Область ПрограммныйИнтерфейс

#Область ОбщийИнтерфейсПодсистемыВизирования

// Возвращает общий модуль, содержащий функциональность присущую текущей конфигурации.
//
// Возвращаемое значение:
//	ОбщийМодуль
//
Функция МодульВизированияПереопределяемый() Экспорт
	
	Возврат бит_ОбщегоНазначенияПереопределяемый.МодульВизирования();
	
КонецФункции

#КонецОбласти

#Область ИнтерфейсРаботыСоСтатусами

// Определяет новый статус объекта. Механизм определения статусов может быть переопределен алгоритмами.
//
// Параметры:
//  ТекущийОбъект - ДокументОбъект.
//  ПараметрыУстановкиСтатуса - Структура - состав полей см. в функции НовыеПараметрыУстановкиСтатуса.
//
// Возвращаемое значение:
//   СправочникСсылка.бит_СтатусыОбъектов - новый статус объекта.
//
Функция НовыйСтатусПоСтандартномуАлгоритму(ТекущийОбъект, ПараметрыУстановкиСтатуса) Экспорт
	
	Если Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ПараметрыУстановкиСтатуса.ТекущийСтатус,
			Перечисления.бит_ТипыСтатусовОбъектов.Закрыт) Тогда
		Возврат ПараметрыУстановкиСтатуса.ТекущийСтатус;
	КонецЕсли;
	
	РежимЗаписи = ПараметрыУстановкиСтатуса.РежимЗаписи;
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Черновик;
	КонецЕсли;
	
	МетаданныеОбъекта    = ТекущийОбъект.Метаданные();
	ЭтоДокумент          = ОбщегоНазначения.ЭтоДокумент(МетаданныеОбъекта);
	ВизированиеОтключено = МеханизмВизированияОтключен(ТекущийОбъект);
	
	ЕстьОтправкаНаСогласование         = Ложь;
	ИмяРеквизитаОтправкаНаСогласование = "";
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ОтправленНаСогласование", МетаданныеОбъекта) Тогда
		ЕстьОтправкаНаСогласование         = Истина;
		ИмяРеквизитаОтправкаНаСогласование = "ОтправленНаСогласование";
	ИначеЕсли ОбщегоНазначения.ЕстьРеквизитОбъекта("бит_ОтправленНаСогласование", МетаданныеОбъекта) Тогда
		ЕстьОтправкаНаСогласование         = Истина;
		ИмяРеквизитаОтправкаНаСогласование = "бит_ОтправленНаСогласование";
	КонецЕсли;
	
	Если ЕстьОтправкаНаСогласование И НЕ ВизированиеОтключено Тогда
		Если НЕ ТекущийОбъект[ИмяРеквизитаОтправкаНаСогласование] Тогда
			Возврат Справочники.бит_СтатусыОбъектов.Черновик;
		КонецЕсли;
	ИначеЕсли ЭтоДокумент Тогда
		Если РежимЗаписи = РежимЗаписиДокумента.Запись
			И НЕ ТекущийОбъект.Проведен Тогда
			Возврат Справочники.бит_СтатусыОбъектов.Черновик;
		КонецЕсли;
	КонецЕсли;
	
	Если ВизированиеОтключено Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Рабочий;
	КонецЕсли;
	
	СсылкаНаОбъект = ТекущийОбъект.Ссылка;
	
	Если ЕстьБлокирующиеРешения(СсылкаНаОбъект) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Отклонен;
	ИначеЕсли ВсеВизыСогласованы(СсылкаНаОбъект) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Утвержден;
	КонецЕсли;
	
	Возврат Справочники.бит_СтатусыОбъектов.НаСогласовании;
	
КонецФункции

// Получает текущий статус объекта.
// 
// Параметры:
//  Ссылка - ДокументСсылка, СправочникСсылка.
// 
// Возвращаемое значение:
//   СправочникСсылка.бит_СтатусыОбъектов.
// 
Функция ТекущийСтатус(Ссылка) Экспорт

	ТекущийСтатус = Справочники.бит_СтатусыОбъектов.ПустаяСсылка();
	
	Если НЕ ЗначениеЗаполнено(Ссылка) Тогда
		Возврат ТекущийСтатус;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыОбъектов.Статус КАК Статус
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК СтатусыОбъектов
	|ГДЕ
	|	СтатусыОбъектов.Объект = &Объект
	|	И СтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус)";
	Запрос.УстановитьПараметр("Объект", Ссылка);			   

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ТекущийСтатус = Выборка.Статус;
	КонецЕсли;
	
	Возврат ТекущийСтатус;
	
КонецФункции

// Получает текущие статусы объектов.
// 
// Параметры:
//  Объекты - Массив.
//	ВидСтатуса - ПеречислениеСсылка.бит_ВидыСтатусовОбъектов.
// 
// Возвращаемое значение:
//   Соответствие:
//		* Ключ - ДокументСсылка, СправочникСсылка.
//		* Значение - СправочникСсылка.бит_СтатусыОбъектов.
// 
Функция ТекущиеСтатусы(Объекты, ВидСтатуса) Экспорт

	ТекущиеСтатусы = Новый Соответствие;
	Для каждого Объект Из Объекты Цикл
		ТекущиеСтатусы.Вставить(Объект, Справочники.бит_СтатусыОбъектов.ПустаяСсылка());
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|   СтатусыОбъектов.Объект КАК Объект,
	|	СтатусыОбъектов.Статус КАК Статус
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК СтатусыОбъектов
	|ГДЕ
	|	СтатусыОбъектов.Объект В (&Объекты)
	|	И СтатусыОбъектов.ВидСтатуса = &ВидСтатуса";
	Запрос.УстановитьПараметр("Объекты",    Объекты);
	Запрос.УстановитьПараметр("ВидСтатуса", ВидСтатуса);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ТекущиеСтатусы.Вставить(Выборка.Объект, Выборка.Статус);
	КонецЕсли;
	
	Возврат ТекущиеСтатусы;
	
КонецФункции

// Получает параметры статусов объекта.
// 
// Параметры:
//  Ссылка - ДокументСсылка, СправочникСсылка.
// 
// Возвращаемое значение:
//   Структура - параметры статусов объекта:
//		* Статус - СправочникСсылка.бит_СтатусыОбъектов - Статус объекта,
//		* ОплатаСтатус - СправочникСсылка.бит_СтатусыОбъектов - Статус оплаты объекта.
// 
Функция СтатусыОбъекта(Ссылка) Экспорт

	ПараметрыСтатуса = Новый Структура;
	ПараметрыСтатуса.Вставить("Статус",			  Справочники.бит_СтатусыОбъектов.ПустаяСсылка());
	ПараметрыСтатуса.Вставить("СтатусПредыдущий", Справочники.бит_СтатусыОбъектов.ПустаяСсылка());	
	ПараметрыСтатуса.Вставить("Дата",			  Дата('00010101'));
	ПараметрыСтатуса.Вставить("ОплатаСтатус",	  Справочники.бит_СтатусыОбъектов.ПустаяСсылка());
	
	Если НЕ ЗначениеЗаполнено(Ссылка) Тогда
		Возврат ПараметрыСтатуса;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтатусыОбъектов.ВидСтатуса КАК ВидСтатуса,
	|	СтатусыОбъектов.Статус КАК Статус,
	|	СтатусыОбъектов.СтатусПредыдущий КАК СтатусПредыдущий,
	|	СтатусыОбъектов.Пользователь КАК Пользователь,
	|	СтатусыОбъектов.ДатаИзмененияСтатуса КАК ДатаИзмененияСтатуса
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК СтатусыОбъектов
	|ГДЕ
	|	СтатусыОбъектов.Объект = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);			   

	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Выборка.ВидСтатуса = Перечисления.бит_ВидыСтатусовОбъектов.Статус Тогда
			 ПараметрыСтатуса.Статус           = Выборка.Статус;
			 ПараметрыСтатуса.СтатусПредыдущий = Выборка.СтатусПредыдущий;
			 ПараметрыСтатуса.Дата             = Выборка.ДатаИзмененияСтатуса;
		ИначеЕсли Выборка.ВидСтатуса = Перечисления.бит_ВидыСтатусовОбъектов.СостояниеОплаты Тогда	
			ПараметрыСтатуса.ОплатаСтатус      = Выборка.Статус;
		КонецЕсли; 
	КонецЦикла; 
	
	Возврат ПараметрыСтатуса;
	
КонецФункции

// Возвращает текущий статус объекта и дату его изменения.
//
// Параметры:
//  Объект - ДокументОбъект.
//
// Возвращаемое значение:
//   Структура - параметры содержащие текущий статус и дату его изменения.
//
Функция ТекущиеПараметрыСтатуса(Объект) Экспорт
	
	ПараметрыСтатуса = Новый Структура;
	ПараметрыСтатуса.Вставить("ТекущийСтатус");
	ПараметрыСтатуса.Вставить("ДатаИзмененияСтатуса");
	
	ДополнительныеСвойства = Объект.ДополнительныеСвойства;
	
	Если ДополнительныеСвойства.Свойство("ТекущийСтатус")
		И ДополнительныеСвойства.Свойство("ДатаИзмененияСтатуса") Тогда
		ЗаполнитьЗначенияСвойств(ПараметрыСтатуса, ДополнительныеСвойства);
	Иначе
		ПараметрыРегистраВиз = СтатусыОбъекта(Объект.Ссылка);
		ПараметрыСтатуса.ТекущийСтатус        = ПараметрыРегистраВиз.Статус;
		ПараметрыСтатуса.ДатаИзмененияСтатуса = ПараметрыРегистраВиз.Дата;
		ДополнительныеСвойства.Вставить("ТекущийСтатус",        ПараметрыСтатуса.ТекущийСтатус);
		ДополнительныеСвойства.Вставить("ДатаИзмененияСтатуса", ПараметрыСтатуса.ДатаИзмененияСтатуса);
	КонецЕсли;
	
	Возврат ПараметрыСтатуса;
	
КонецФункции

// Заполняет реквизиты формы, связанные со статусом.
//
// Параметры:
//  Форма           - ФормаКлиентскогоПриложения.
//  ТекущийОбъект   - СправочникОбъект, ДокументОбъект.
//
Процедура ЗаполнитьРеквизитыСтатусаВФорме(Форма, ТекущийОбъект) Экспорт
	
	Если ТекущийОбъект = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	ПараметрыСтатуса 				  = ПараметрыТекущегоСтатуса(ТекущийОбъект.Ссылка);
	ПараметрыСтатуса.ИнформацияСтатус = СформироватьИнформациюСтатус(ПараметрыСтатуса);
	
	ЗаполнитьЗначенияСвойств(Форма, ПараметрыСтатуса);
	
КонецПроцедуры

// Установка статуса объектов визирования.
//
// Параметры:
//  ТекущийОбъект - СправочникОбъект, ДокументОбъект.
//	ПараметрыУстановкиСтатуса - Структура (необязательное) - состав полей см. НовыеПараметрыУстановкиСтатуса.
//  КэшОпераций - Структура (необязательное).
//
Процедура УстановитьСтатус(ТекущийОбъект, ПараметрыУстановкиСтатуса = Неопределено, КэшОпераций = Неопределено) Экспорт

	Если ПараметрыУстановкиСтатуса = Неопределено Тогда
		ПараметрыРегистраВиз      = СтатусыОбъекта(ТекущийОбъект.Ссылка);
		ПараметрыУстановкиСтатуса = НовыеПараметрыУстановкиСтатуса();
		ПараметрыУстановкиСтатуса.ТекущийСтатус        = ПараметрыРегистраВиз.Статус;
		ПараметрыУстановкиСтатуса.ДатаИзмененияСтатуса = ПараметрыРегистраВиз.Дата;
		Если ТекущийОбъект.ДополнительныеСвойства.Свойство("РежимЗаписи") Тогда
			ПараметрыУстановкиСтатуса.РежимЗаписи = ТекущийОбъект.ДополнительныеСвойства.РежимЗаписи;
		Иначе
			МетаданныеОбъекта = ТекущийОбъект.Метаданные();
			Если НЕ ОбщегоНазначения.ЭтоДокумент(МетаданныеОбъекта) Тогда
				ПараметрыУстановкиСтатуса.РежимЗаписи = РежимЗаписиДокумента.Проведение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗаблокированоИзменениеСтатуса(ТекущийОбъект.Ссылка, ПараметрыУстановкиСтатуса) Тогда
		Возврат;
	КонецЕсли;
	
	АлгоритмИзмененияСтатуса = бит_УправлениеПроцессами.АлгоритмУстановкиСтатусаОбъекта(ТекущийОбъект);
	
	СтатусДоИзменения = ПараметрыУстановкиСтатуса.ТекущийСтатус;
	
	Если ЗначениеЗаполнено(АлгоритмИзмененияСтатуса) Тогда
		
		// Выполнение установки статуса согласно алгоритму изменения статусов.
		КомментироватьВыполнение = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию("КомментироватьХодВыполненияАлгоритмовПроцессов",
									Пользователи.ТекущийПользователь());
			
        РежимСообщений = ?(КомментироватьВыполнение, "Все", "Ошибки");			
			
		СтруктураКонтекст = Новый Структура;
		СтруктураКонтекст.Вставить("ТекущийОбъект", ТекущийОбъект);
		ПараметрыОплаты   = ПараметрыУстановкиСтатуса.ПараметрыОплаты;
		Если ПараметрыОплаты <> Неопределено Тогда
			СтруктураКонтекст.Вставить("ОплатаЗаявки", ПараметрыОплаты);
		КонецЕсли;
		
		бит_УправлениеПроцессами.ВыполнитьАлгоритм(АлгоритмИзмененияСтатуса, СтруктураКонтекст, РежимСообщений);
		
		ПараметрыРегистраВиз      = СтатусыОбъекта(ТекущийОбъект.Ссылка);
		ПараметрыУстановкиСтатуса.ТекущийСтатус        = ПараметрыРегистраВиз.Статус;
		ПараметрыУстановкиСтатуса.ДатаИзмененияСтатуса = ПараметрыРегистраВиз.Дата;
		
	Иначе
		
		ИмяПолное 		= ТекущийОбъект.Метаданные().ПолноеИмя();
		МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ИмяПолное);
		Если бит_ОбщегоНазначения.ОбъектБИТ(ТекущийОбъект) Тогда
			НовыйСтатус = МенеджерОбъекта.НовыйСтатусОбъекта(ТекущийОбъект, ПараметрыУстановкиСтатуса);
		Иначе
			// Механизм статусов подключен к типовому или новому проектному объекту. В этом случае наименование экспортной
			// функции должно содержать приставку "бит_" - для минимизации потери кода при обновлених. Подробнее см. файл
			// документации "Механизм визирования и статусов" в составе поставки.
			НовыйСтатус = МенеджерОбъекта.бит_НовыйСтатусОбъекта(ТекущийОбъект, ПараметрыУстановкиСтатуса);
		КонецЕсли;
		
		Если НовыйСтатус <> ПараметрыУстановкиСтатуса.ТекущийСтатус Тогда
			ПараметрыУстановкиСтатуса.ДатаИзмененияСтатуса = ТекущаяДатаСеанса();
			ПараметрыУстановкиСтатуса.Объект               = ТекущийОбъект.Ссылка;
			ПараметрыУстановкиСтатуса.Статус               = НовыйСтатус;
			ПараметрыУстановкиСтатуса.СтатусПредыдущий     = ПараметрыУстановкиСтатуса.ТекущийСтатус;
			
			ДействиеВыполнено = УстановитьСтатусОбъекта(ПараметрыУстановкиСтатуса);
			Если ДействиеВыполнено Тогда
				ПараметрыУстановкиСтатуса.ТекущийСтатус = НовыйСтатус;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если СтатусДоИзменения <> ПараметрыУстановкиСтатуса.ТекущийСтатус Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ТекущийСтатус",        ПараметрыУстановкиСтатуса.ТекущийСтатус);
		ТекущийОбъект.ДополнительныеСвойства.Вставить("ДатаИзмененияСтатуса", ПараметрыУстановкиСтатуса.ДатаИзмененияСтатуса);
		
		Если КэшОпераций = Неопределено Тогда
			КэшОпераций = НовыйКэшОперацийУстановкиСтатусов();
		КонецЕсли;
		ДействияПослеУстановкиСтатуса(ТекущийОбъект, ПараметрыУстановкиСтатуса, КэшОпераций);
	КонецЕсли;
	
КонецПроцедуры

// Функция выполняет установку статуса для объекта.
// 
// Параметры:
//  ПараметрыУстановкиСтатуса - Структура - см. НовыеПараметрыУстановкиСтатуса().
// 
// Возвращаемое значение:
//   Булево - Признак успешной установки статуса.
// 
Функция УстановитьСтатусОбъекта(ПараметрыУстановкиСтатуса) Экспорт
	
	ДействиеВыполнено = Ложь;
	Если НЕ ЗначениеЗаполнено(ПараметрыУстановкиСтатуса.Объект) Тогда
		Возврат ДействиеВыполнено;
	КонецЕсли;
	
	РежимСообщений = ПараметрыУстановкиСтатуса.РежимСообщений;
	ТекущийОбъект  = ПараметрыУстановкиСтатуса.Объект;
	Статус         = ПараметрыУстановкиСтатуса.Статус;
	
	ВыводитьОшибки     = ?(РежимСообщений="Все" ИЛИ РежимСообщений="Ошибки",Истина,Ложь);
	ВыводитьИнформацию = ?(РежимСообщений="Все",Истина,Ложь);
	
	МенеджерЗаписи = РегистрыСведений.бит_СтатусыОбъектов.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, ПараметрыУстановкиСтатуса);
	
	Попытка
		МенеджерЗаписи.Записать();
		ДействиеВыполнено = Истина;
	Исключение
		Если ВыводитьОшибки Тогда
			ТекстСообщения = НСтр("ru='Не удалось установить статус ""%1"" для объекта ""%2"" %3';
								  |en='Failed to set the status ""%1"" for the object ""%2"" %3'") ;
			ТекстСообщения = СтрШаблон(ТекстСообщения, Статус, ТекущийОбъект, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ТекущийОбъект); 
		КонецЕсли; 
		ИмяСобытия = НСтр("ru = 'бит_Визирование';en='бит_Визирование'", ОбщегоНазначения.КодОсновногоЯзыка());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,, ТекущийОбъект, 
								 ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ДействиеВыполнено = Ложь;
	КонецПопытки;
	
	Возврат ДействиеВыполнено;
	
КонецФункции

// Выполняет проведение/отмену проведения документа в зависимости от статуса документа. 
// Используется в режиме "ПроводитьПослеУтверждения".
// 
// Параметры:
//  ДокОбъект - ДокументОбъект.
//  МетаОбъект - ОбъектМетаданных.
//  ПроводитьПослеУтверждения - Булево.
//  РежимСообщений - Строка.
// 
// Возвращаемое значение:
//  Булево.
// 
Функция ПровестиВСтатусеУтверждено(ДокОбъект, МетаОбъект, ПроводитьПослеУтверждения, РежимСообщений) Экспорт
	
	Выполнено = Ложь;
	Если ПроводитьПослеУтверждения 
		И бит_РаботаСМетаданными.ЕстьРеквизит("ОтправленНаСогласование", МетаОбъект)
		И ДокОбъект.ОтправленНаСогласование
		И Метаданные.Документы.Содержит(МетаОбъект) Тогда
		
		ПараметрыСтатуса = СтатусыОбъекта(ДокОбъект.Ссылка);
		
		ТекущийСтатус = ПараметрыСтатуса.Статус;
		
		Отклонен	 = Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ТекущийСтатус,
							Перечисления.бит_ТипыСтатусовОбъектов.Отклонен);
		Утвержден	 = Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ТекущийСтатус,
							Перечисления.бит_ТипыСтатусовОбъектов.Утвержден);
		БылУтвержден = Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ПараметрыСтатуса.СтатусПредыдущий,
							Перечисления.бит_ТипыСтатусовОбъектов.Утвержден);
		
		ОбновитьДвижения = Ложь;
		Если Утвержден Тогда
			ОбновитьДвижения = Истина;
		ИначеЕсли ДокОбъект.Проведен И (Отклонен ИЛИ БылУтвержден) Тогда
			ОбновитьДвижения = Истина;
		КонецЕсли;
		
		Если ОбновитьДвижения Тогда
			ДокОбъект.ДополнительныеСвойства.Вставить("ОтключитьОбновлениеВизПриПроведении", Истина);
			Выполнено = бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ДокОбъект, РежимЗаписиДокумента.Проведение, "", РежимСообщений, Ложь);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Выполнено;
	
КонецФункции

#КонецОбласти

#Область ИнтерфейсРаботыСВизами

// Функция получает список ответственных, которым доступна установка виз.
// 
// Параметры:
//  НаборВиз - ТаблицаЗначений - Таблица виз, для которой необходимо определить ответственных.
//  ОтборОтветственные - Массив, СписокЗначений, Неопределено - Фильтр по списку ответственных.
//
// Возвращаемое значение:
//	ТаблицаЗначений - Таблица ответственных за установку виз.
//
Функция ОтветственныеЗаУстановкуВиз(НаборВиз, ОтборОтветственные = Неопределено) Экспорт
	
	ТаблицаДоступа = Новый ТаблицаЗначений;
	ТаблицаДоступа.Колонки.Добавить("ОбъектВизирования", Метаданные.ОпределяемыеТипы.бит_ОбъектыВизирования.Тип);
	ТаблицаДоступа.Колонки.Добавить("Виза",              Новый ОписаниеТипов("СправочникСсылка.бит_Визы"));
	ТаблицаДоступа.Колонки.Добавить("Ответственный",     Новый ОписаниеТипов("СправочникСсылка.Пользователи"));
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	// Получение списка объектов и виз, по которым необходимо получить ответственных.
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НаборВиз.Объект КАК Объект,
	|	НаборВиз.Виза КАК Виза,
	|	АВТОНОМЕРЗАПИСИ() КАК Порядок
	|ПОМЕСТИТЬ НаборВиз
	|ИЗ
	|	&НаборВиз КАК НаборВиз";
	Запрос.УстановитьПараметр("НаборВиз", НаборВиз);
	Запрос.Выполнить();
	
	// Формирование матрицы доступа пользователей к визам.
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Пользователи.Ссылка КАК Ответственный
	|ПОМЕСТИТЬ ВсеПользователи
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ГруппыПользователейПользователиГруппы.Пользователь КАК Ответственный,
	|	ГруппыПользователейПользователиГруппы.Ссылка КАК ПользовательГруппа
	|ПОМЕСТИТЬ ПользователиИГруппы
	|ИЗ
	|	Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейПользователиГруппы
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВсеПользователи.Ответственный,
	|	ЗНАЧЕНИЕ(Справочник.ГруппыПользователей.ВсеПользователи)
	|ИЗ
	|	ВсеПользователи КАК ВсеПользователи
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВсеПользователи.Ответственный,
	|	ВсеПользователи.Ответственный
	|ИЗ
	|	ВсеПользователи КАК ВсеПользователи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВсеПользователи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПользователиИГруппы.Ответственный КАК Ответственный,
	|	ПользователиИГруппы.ПользовательГруппа КАК ПользовательГруппа,
	|	бит_ПраваУстановкиВиз.Виза КАК ВизаГруппа,
	|	бит_ПраваУстановкиВиз.ПользовательскоеУсловие КАК ПользовательскоеУсловие
	|ПОМЕСТИТЬ ПраваДоступаПоГруппам
	|ИЗ
	|	ПользователиИГруппы КАК ПользователиИГруппы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_ПраваУстановкиВиз КАК бит_ПраваУстановкиВиз
	|		ПО ПользователиИГруппы.ПользовательГруппа = бит_ПраваУстановкиВиз.Пользователь
	|			И (&ОтборОтветственные)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
	|		ПО ПользователиИГруппы.Ответственный = Пользователи.Ссылка
	|			И (НЕ Пользователи.ПометкаУдаления)
	|			И (НЕ Пользователи.Недействителен)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ПользователиИГруппы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПраваДоступаПоГруппам.Ответственный КАК Ответственный,
	|	НаборВиз.Виза КАК Виза,
	|	ВЫБОР
	|		КОГДА ПраваДоступаПоГруппам.ПользовательскоеУсловие = ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеУсловия.ПустаяСсылка)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПолныйДоступ,
	|	ПраваДоступаПоГруппам.ПользовательскоеУсловие КАК ПользовательскоеУсловие
	|ПОМЕСТИТЬ МатицаДоступаКВизам
	|ИЗ
	|	ПраваДоступаПоГруппам КАК ПраваДоступаПоГруппам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НаборВиз КАК НаборВиз
	|		ПО (ПраваДоступаПоГруппам.ВизаГруппа = НаборВиз.Виза
	|				ИЛИ ПраваДоступаПоГруппам.ВизаГруппа = ЗНАЧЕНИЕ(Справочник.бит_ГруппыВиз.ВсеВизы))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПраваДоступаПоГруппам.Ответственный,
	|	НаборВиз.Виза,
	|	ВЫБОР
	|		КОГДА ПраваДоступаПоГруппам.ПользовательскоеУсловие = ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеУсловия.ПустаяСсылка)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ,
	|	ПраваДоступаПоГруппам.ПользовательскоеУсловие
	|ИЗ
	|	ПраваДоступаПоГруппам КАК ПраваДоступаПоГруппам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_ГруппыВиз.ВизыГруппы КАК бит_ГруппыВизВизыГруппы
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ НаборВиз КАК НаборВиз
	|			ПО бит_ГруппыВизВизыГруппы.Виза = НаборВиз.Виза
	|		ПО ПраваДоступаПоГруппам.ВизаГруппа = бит_ГруппыВизВизыГруппы.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ПраваДоступаПоГруппам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НаборВиз.Объект КАК ОбъектВизирования,
	|	НаборВиз.Виза КАК Виза,
	|	ЕСТЬNULL(МатицаДоступаКВизам.Ответственный, ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)) КАК Ответственный,
	|	ЕСТЬNULL(МатицаДоступаКВизам.ПолныйДоступ, ИСТИНА) КАК ПолныйДоступ,
	|	МатицаДоступаКВизам.ПользовательскоеУсловие КАК УсловиеДоступа
	|ИЗ
	|	НаборВиз КАК НаборВиз
	|		ЛЕВОЕ СОЕДИНЕНИЕ МатицаДоступаКВизам КАК МатицаДоступаКВизам
	|		ПО НаборВиз.Виза = МатицаДоступаКВизам.Виза
	|
	|УПОРЯДОЧИТЬ ПО
	|	НаборВиз.Порядок
	|ИТОГИ
	|	МАКСИМУМ(ПолныйДоступ)
	|ПО
	|	ОбъектВизирования,
	|	Виза,
	|	Ответственный";
	
	Если ОтборОтветственные = Неопределено Тогда
		ТекстОтбораОтвественых = "ИСТИНА";
	Иначе
		ТекстОтбораОтвественых = "ПользователиИГруппы.Ответственный В (&Ответственные)";
		Запрос.УстановитьПараметр("Ответственные", ОтборОтветственные); 
	КонецЕсли;
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "&ОтборОтветственные", ТекстОтбораОтвественых);
	
	ВыборкаОбъектов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОбъектов.Следующий() Цикл
		ВыборкаВиз = ВыборкаОбъектов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаВиз.Следующий() Цикл
			ВыборкаОтветственных = ВыборкаВиз.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаОтветственных.Следующий() Цикл
				ВизаДоступна         = Ложь;
				Если ВыборкаОтветственных.ПолныйДоступ Тогда
					ВизаДоступна = Истина;
				Иначе
					ВыборкаУсловий = ВыборкаОтветственных.Выбрать();
					Пока ВыборкаУсловий.Следующий() Цикл
						ПараметрыУсловия = Новый Структура;
						ПараметрыУсловия.Вставить("ТекущийОбъект",       ВыборкаУсловий.ОбъектВизирования);
						ПараметрыУсловия.Вставить("ТекущийПользователь", ВыборкаУсловий.Ответственный);
						УсловиеВыполнено = бит_УправлениеПроцессами.ПроверитьПользовательскоеУсловие(ВыборкаУсловий.УсловиеДоступа,
												ПараметрыУсловия,,,"Ошибки");
						Если УсловиеВыполнено Тогда
							ВизаДоступна = Истина;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				Если ВизаДоступна Тогда
					СтрокаДоступа = ТаблицаДоступа.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаДоступа, ВыборкаОтветственных);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТаблицаДоступа;
	
КонецФункции

// Функция получает список возможных решений при визировании.
//
// Параметры:
//  СтруктураПараметров - Структура - см. НовыеПараметрыОпределенияСпискаРешений()
//
// Возвращаемое значение:
//   СписокЗначений - Список доступных решений.
// 
Функция ДоступныеРешения(СтруктураПараметров) Экспорт

	СписокРешений = Новый СписокЗначений;
	
	Запрос = Новый Запрос;
	Если СтруктураПараметров.Свойство("Организация") Тогда
		Запрос.УстановитьПараметр("Организация",СтруктураПараметров.Организация);
	Иначе	
		Запрос.УстановитьПараметр("Организация",Справочники.Организации.ПустаяСсылка());
	КонецЕсли; 
	Если СтруктураПараметров.Свойство("ОбъектСистемы") Тогда
		Запрос.УстановитьПараметр("ОбъектСистемы",СтруктураПараметров.ОбъектСистемы);
	Иначе	
		Запрос.УстановитьПараметр("ОбъектСистемы",Справочники.бит_ОбъектыСистемы.ПустаяСсылка());
	КонецЕсли; 
	
	Запрос.Текст =  
	"ВЫБРАТЬ
	|	НазначениеВидовРешений.ВидРешения КАК ВидРешения,
	|	МАКСИМУМ(НазначениеВидовРешений.КодСортировки) КАК КодСортировки,
	|	НазначениеВидовРешений.ВидРешения.Представление КАК ВидРешенияПредставление,
	|	НазначениеВидовРешений.ПользовательскоеУсловие КАК ПользовательскоеУсловие,
	|	НЕ НазначениеВидовРешений.ПользовательскоеУсловие = ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеУсловия.ПустаяСсылка) КАК ОграничениеИспользования
	|ИЗ
	|	РегистрСведений.бит_НазначениеВидовРешенийСогласования КАК НазначениеВидовРешений
	|ГДЕ
	|	(НазначениеВидовРешений.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
	|			ИЛИ НазначениеВидовРешений.Организация = &Организация)
	|	И (НазначениеВидовРешений.ОбъектСистемы = ЗНАЧЕНИЕ(Справочник.бит_ОбъектыСистемы.ПустаяСсылка)
	|			ИЛИ НазначениеВидовРешений.ОбъектСистемы = &ОбъектСистемы)
	|	И НЕ НазначениеВидовРешений.ВидРешения.Отключено
	|	И НЕ НазначениеВидовРешений.ВидРешения.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	НазначениеВидовРешений.ВидРешения,
	|	НазначениеВидовРешений.ВидРешения.Представление,
	|	НазначениеВидовРешений.ПользовательскоеУсловие
	|
	|УПОРЯДОЧИТЬ ПО
	|	КодСортировки,
	|	ОграничениеИспользования
	|ИТОГИ ПО
	|	ВидРешения";
	
	ПараметрыУсловия = Новый Структура;
	ПараметрыУсловия.Вставить("ТекущийПользователь", Пользователи.ТекущийПользователь());
	ПараметрыУсловия.Вставить("ТекущийОбъект",       СтруктураПараметров.ТекущийОбъект);
	
	
	ВыборкаРешений = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаРешений.Следующий() Цикл
		Выборка = ВыборкаРешений.Выбрать();
		Пока Выборка.Следующий() Цикл
			Если Выборка.ОграничениеИспользования
				И (СтруктураПараметров.ТекущийОбъект = Неопределено
					ИЛИ НЕ бит_УправлениеПроцессами.ПроверитьПользовательскоеУсловие(Выборка.ПользовательскоеУсловие, ПараметрыУсловия)) Тогда
				Продолжить;
			КонецЕсли;
			
			СписокРешений.Добавить(Выборка.ВидРешения, Выборка.ВидРешенияПредставление);
			Прервать;
		КонецЦикла;
	КонецЦикла;

	Возврат СписокРешений;
	
КонецФункции

// Функция возвращает структуру параметров определения доступного списка решений по визе.
// 
// Возвращаемое значение:
//   Структура.
//
Функция НовыеПараметрыОпределенияСпискаРешений() Экспорт
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ОбъектСистемы", Справочники.бит_ОбъектыСистемы.ПустаяСсылка()); 
	СтруктураПараметров.Вставить("Организация",   Справочники.Организации.ПустаяСсылка());
	СтруктураПараметров.Вставить("ТекущийОбъект", Неопределено);
	
	Возврат СтруктураПараметров;
	
КонецФункции

// Получает список объектов системы, на которые распространяется механизм визирования.
// 
// Возвращаемое значение:
//  СписокЗначений
// 
Функция ВизируемыеОбъектыСистемы() Экспорт

	ВизируемыеОбъекты = Новый СписокЗначений;
	МассивТипов = Метаданные.ОпределяемыеТипы.бит_ОбъектыВизирования.Тип.Типы();
	Для каждого ТекущийТип Из МассивТипов Цикл
		МетаОбъект = Метаданные.НайтиПоТипу(ТекущийТип);
		Если МетаОбъект <> Неопределено Тогда
			ОбъектСистемы = бит_ПраваДоступа.ПолучитьОбъектДоступаПоМетаданным(МетаОбъект);
			Если ЗначениеЗаполнено(ОбъектСистемы) Тогда			
				ВизируемыеОбъекты.Добавить(ОбъектСистемы);
				
				Если бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
					ПолноеИмяМетаданных = МетаОбъект.ПолноеИмя();
					ИмяВедомогоОбъекта  = "";
					Если ПолноеИмяМетаданных = "Документ.бит_кзн_ЗаявкаНаРасходованиеСредств" Тогда
						ИмяВедомогоОбъекта = "Документ.бит_кзн_ПлатежнаяПозиция";
					ИначеЕсли ПолноеИмяМетаданных = "Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств" Тогда
						ИмяВедомогоОбъекта = "Документ.бит_кзн_ПозицияПоступления";
					КонецЕсли;
					
					Если Не ПустаяСтрока(ИмяВедомогоОбъекта) Тогда
						ВедомыйОбъект = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(ИмяВедомогоОбъекта);
						Если ВедомыйОбъект <> Неопределено Тогда
							ВизируемыеОбъекты.Добавить(ВедомыйОбъект);
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла;
	
	Возврат ВизируемыеОбъекты;
	
КонецФункции

// Проверяет признак отключенного механизма визирования для объекта.
// 
// Параметры:
//  Объект - ДокументОбъект; СправочникОбъект; ДокументСсылка; СправочникСсылка.
// 
// Возвращаемое значение:
//   Булево - Истина если механизм визирования не используется.
// 
Функция МеханизмВизированияОтключен(Объект) Экспорт
	
	ПолноеИмяМетаданных = Объект.Метаданные().ПолноеИмя();
	
	Если бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
		Если ПолноеИмяМетаданных = "Документ.бит_кзн_ПлатежнаяПозиция" Тогда
			ПолноеИмяМетаданных = "Документ.бит_кзн_ЗаявкаНаРасходованиеСредств";
		ИначеЕсли ПолноеИмяМетаданных = "Документ.бит_кзн_ПозицияПоступления" Тогда
			ПолноеИмяМетаданных = "Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств";
		КонецЕсли;
	КонецЕсли;
	
	Возврат бит_ОбщегоНазначенияПовтИсп.МеханизмВизированияОтключен(ПолноеИмяМетаданных);
	
КонецФункции

// Возвращает настройки для объекта визирования из регистра сведений бит_НастройкиОбъектовВизирования.
// 
// Параметры:
//  Объект - Строка, ДокументОбъект, СправочникОбъект, ДокументСсылка, СправочникСсылка.
// 
// Возвращаемое значение:
//   Структура
//		* ИспользоватьВизирование - Булево, 
//		* РежимОбновленияВиз      - ПеречислениеСсылка.бит_РежимыОбновленияПеречняВиз.
//
Функция НастройкиОбъектаВизирования(Объект) Экспорт
	
	ПолноеИмяМетаданных = "";
	Если ТипЗнч(Объект) = Тип("Строка") Тогда
		ПолноеИмяМетаданных = Объект;
	Иначе
		ПолноеИмяМетаданных = Объект.Метаданные().ПолноеИмя();
	КонецЕсли;
	
	Если ПолноеИмяМетаданных = "Документ.бит_кзн_ПлатежнаяПозиция"
		Или ПолноеИмяМетаданных = "Документ.бит_кзн_ПозицияПоступления" Тогда
		ПолноеИмяМетаданных = "Документ.бит_кзн_ЗаявкаНаРасходованиеСредств";
	КонецЕсли;
	
	Возврат бит_ОбщегоНазначенияПовтИсп.НастройкиОбъектаВизирования(ПолноеИмяМетаданных);
	
КонецФункции

// Создает и назначает визы объектам визирования.
// 
// Параметры:
//  НазначатьВизы - Булево, по умолчанию Истина.
//  ВыполнятьВТранзакции - Булево.
//  ВыводитьСообщения    - Булево.
// 
Процедура СоздатьИНазначитьВизыПоУмолчанию(НазначатьВизы = Истина, ВыполнятьВТранзакции = Ложь, ВыводитьСообщения = Ложь) Экспорт
	
	Если ВыполнятьВТранзакции Тогда
		НачатьТранзакцию();
		Попытка
			СоздатьИНазначитьВизыПоУмолчаниюСлужебный(НазначатьВизы, ВыводитьСообщения);
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ВызватьИсключение ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки;
	Иначе
		СоздатьИНазначитьВизыПоУмолчаниюСлужебный(НазначатьВизы, ВыводитьСообщения);
	КонецЕсли; 
	
КонецПроцедуры

// Очищает все визы в таб. части Визы независимо от наличия доступа у пользователя.
// 
// Параметры:
//  ТекущийОбъект  - ДокументСсылка.
// 
Процедура ОчиститьВсеВизыБезусловно(ТекущийОбъект) Экспорт

	Отбор = Новый Структура;
	Отбор.Вставить("Объект",ТекущийОбъект);
	
	НаборВизы = ПрочитатьНаборВиз(Отбор);
	НаборВизы.Очистить();
	
	бит_ОбщегоНазначения.ЗаписатьНаборЗаписейРегистра(НаборВизы);

КонецПроцедуры

// Возвращает список виз, доступных для установки данному  пользователю, либо группе пользователей.
// 
// Параметры:
//  ТекущийПользователь - СправочникСсылка.Пользователи,СправочникСсылка.ГруппыПользователей 
// 						- Пользователь для которого получаем список виз.
//  ТекущийОбъект       - ДокументОбъект, ДокументСсылка - объект.
// 
// Возвращаемое значение:
//	СписокЗначений - Список виз пользователя.
// 
Функция ВизыПользователя(ТекущийПользователь, ТекущийОбъект) Экспорт

	СписокВиз      = Новый СписокЗначений;
	РежимСообщений = "Нет";
	
	ИмяТабЧасти = бит_ОбщегоНазначения.ИмяТабЧастиГруппыПользователей();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущийПользователь", ТекущийПользователь);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫБОР
	|		КОГДА бит_ПраваУстановкиВиз.Виза ССЫЛКА Справочник.бит_ГруппыВиз
	|			ТОГДА ВЫБОР
	|					КОГДА бит_ПраваУстановкиВиз.Виза = ЗНАЧЕНИЕ(Справочник.бит_ГруппыВиз.ВсеВизы)
	|						ТОГДА ЗНАЧЕНИЕ(Справочник.бит_ГруппыВиз.ВсеВизы)
	|					ИНАЧЕ ЕСТЬNULL(бит_ГруппыВизВизыГруппы.Виза, ЗНАЧЕНИЕ(Справочник.бит_Визы.ПустаяСсылка))
	|				КОНЕЦ
	|		ИНАЧЕ бит_ПраваУстановкиВиз.Виза
	|	КОНЕЦ КАК Виза,
	|	бит_ПраваУстановкиВиз.ПользовательскоеУсловие
	|ИЗ
	|	РегистрСведений.бит_ПраваУстановкиВиз КАК бит_ПраваУстановкиВиз
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_ГруппыВиз.ВизыГруппы КАК бит_ГруппыВизВизыГруппы
	|		ПО бит_ПраваУстановкиВиз.Виза = бит_ГруппыВизВизыГруппы.Ссылка
	|ГДЕ
	|	(бит_ПраваУстановкиВиз.Пользователь В
	|				(ВЫБРАТЬ
	|					ГруппыПользователейПользователиГруппы.Ссылка
	|				ИЗ
	|					Справочник.ГруппыПользователей.%ИмяТабЧасти% КАК ГруппыПользователейПользователиГруппы
	|				ГДЕ
	|					ГруппыПользователейПользователиГруппы.Пользователь = &ТекущийПользователь)
	|			ИЛИ бит_ПраваУстановкиВиз.Пользователь = &ТекущийПользователь
	|			ИЛИ бит_ПраваУстановкиВиз.Пользователь = ЗНАЧЕНИЕ(Справочник.ГруппыПользователей.ВсеПользователи))";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ИмяТабЧасти%", ИмяТабЧасти);
		
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ПользовательскоеУсловие) И НЕ ТекущийОбъект = Неопределено Тогда
			ПараметрыУсловия = Новый Структура;
			ПараметрыУсловия.Вставить("ТекущийОбъект",       ТекущийОбъект);
			ПараметрыУсловия.Вставить("ТекущийПользователь", ТекущийПользователь);
			ВизаДоступна = бит_УправлениеПроцессами.ПроверитьПользовательскоеУсловие(Выборка.ПользовательскоеУсловие
					                                                     ,ПараметрыУсловия
																		 ,
																		 ,
																		 ,РежимСообщений);
		Иначе	
			ВизаДоступна = Истина;
		КонецЕсли; 
		
		Если ВизаДоступна Тогда
			СписокВиз.Добавить(Выборка.Виза);	
		КонецЕсли; 
	КонецЦикла; 
			   
   Возврат СписокВиз;

КонецФункции

// Устанавливает крайние даты визирования.
// 
// Параметры:
//  ТекущийОбъект - ДокументСсылка.
//  НаборВизы     - РегистрСведенийНаборЗаписей.бит_УстановленныеВизы (По умолчанию = Неопределено).
//  Записывать 	  - Булево (По умолчанию = Истина).
// 
Процедура УстановитьКрайниеДатыВизирования(ТекущийОбъект, НаборВизы = Неопределено, Записывать = Истина) Экспорт

	Если НаборВизы = Неопределено Тогда
		Отбор = Новый Структура;
		Отбор.Вставить("Объект", ТекущийОбъект.Ссылка);
		НаборВизы = ПрочитатьНаборВиз(Отбор);
	КонецЕсли; 
	
	ТаблицаВизы = НаборВизы.Выгрузить();
	
	ТаблицаВизы.Колонки.Добавить("ДоступностьВизы", Новый ОписаниеТипов("Булево"));
	ТаблицаВизы.ЗаполнитьЗначения(Истина, "ДоступностьВизы");
	
	Алгоритм = Справочники.бит_АлгоритмыПроцессов.ПустаяСсылка();
	
	Для Каждого СтрокаВизы Из ТаблицаВизы Цикл
		Если ЗначениеЗаполнено(СтрокаВизы.Алгоритм) Тогда
			Алгоритм = СтрокаВизы.Алгоритм;
			Прервать;
		КонецЕсли; 
	КонецЦикла; 
	
	ТаблицаТочкиВизы = бит_УправлениеПроцессами.ОписаниеТочекАлгоритма(Алгоритм, ТаблицаВизы);
	
	// Определяем, какие точки алгоритма доступны.
	ДопПараметрыПроверкиУсловий = НовыеПараметрыПроверкиУсловия();
	ДопПараметрыПроверкиУсловий.ТекущийОбъект = ТекущийОбъект;
	ДопПараметрыПроверкиУсловий.Визы          = ТаблицаВизы;
	ДопПараметрыПроверкиУсловий.Алгоритм      = Алгоритм;
			
	ВыполнятьПоэтапно = бит_УправлениеПроцессами.ВыполнятьАлгоритмПоэтапно(Алгоритм);
	бит_УправлениеПроцессами.ОпределитьДоступностьТочек(ТаблицаТочкиВизы, ВыполнятьПоэтапно, ДопПараметрыПроверкиУсловий);

	ЕстьИзменения = Ложь;
	// Устанавливаем крайние даты и признак активности.
	Для каждого Запись Из НаборВизы Цикл
		СтрокаТаблицы = ТаблицаТочкиВизы.Найти(Запись.ИД,"ИД");
		Если СтрокаТаблицы = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если Запись.ВремяНаУстановку > 0 Тогда
			Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Решение) И НЕ СтрокаТаблицы.Доступность Тогда
				Запись.ДатаКрайняя = Дата("00010101");
				ЕстьИзменения    = Истина;
			ИначеЕсли СтрокаТаблицы.Доступность И НЕ ЗначениеЗаполнено(Запись.ДатаКрайняя) Тогда
				ПараметрыРасчетаСрока = НовыеПараметрыРасчетаСрокаИсполнения();
				ПараметрыРасчетаСрока.ОбъектРасчета    = ТекущийОбъект;
				ПараметрыРасчетаСрока.ДатаОтсчета      = ТекущаяДатаСеанса();
				ПараметрыРасчетаСрока.ВремяНаУстановку = Запись.ВремяНаУстановку;
				Запись.ДатаКрайняя = СрокИсполнения(ПараметрыРасчетаСрока);
				
				ЕстьИзменения    = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если Запись.АктивнаяВиза <> СтрокаТаблицы.АктивнаяВиза Тогда
			Запись.АктивнаяВиза = СтрокаТаблицы.АктивнаяВиза;
			ЕстьИзменения     = Истина;
		КонецЕсли;
	КонецЦикла; // По набору виз.
	
	Если УпорядочитьВизыБезАнализаАлгоритма(НаборВизы) Тогда
		ЕстьИзменения = Истина;
	КонецЕсли;

	Если ЕстьИзменения И Записывать Тогда
		бит_ОбщегоНазначения.ЗаписатьНаборЗаписейРегистра(НаборВизы);
	КонецЕсли; 	
	
КонецПроцедуры

// Проверяет принято ли по всем утверждающим визам решение "Согласовано".
// 
// Параметры:
//  СсылкаНаОбъект  - СправочникСсылка,ДокументСсылка.
// 
// Возвращаемое значение:
//   ВсеВизыСогласованы - Булево.
// 
Функция ВсеВизыСогласованы(СсылкаНаОбъект) Экспорт
	
	Если МеханизмВизированияОтключен(СсылкаНаОбъект) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	УстановленныеВизы.Решение КАК Решение
	|ПОМЕСТИТЬ РешенияПоОбъекту
	|ИЗ
	|	РегистрСведений.бит_УстановленныеВизы КАК УстановленныеВизы
	|ГДЕ
	|	УстановленныеВизы.Объект = &Объект
	|	И УстановленныеВизы.Виза.Вид = ЗНАЧЕНИЕ(Перечисление.бит_ВидыВиз.Утверждающая)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЕСТЬNULL(РешенияПоОбъекту.Решение.ТипРешения, ЗНАЧЕНИЕ(Перечисление.бит_ТипыРешений.ПустаяСсылка))) КАК КоличествоВидовРешений,
	|	СУММА(ВЫБОР
	|			КОГДА РешенияПоОбъекту.Решение.ТипРешения = ЗНАЧЕНИЕ(Перечисление.бит_ТипыРешений.Согласующее)
	|				ТОГДА 1
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК КоличествоСогласовано
	|ИЗ
	|	РешенияПоОбъекту КАК РешенияПоОбъекту";
	Запрос.УстановитьПараметр("Объект",  СсылкаНаОбъект);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Если Выборка.КоличествоВидовРешений <> 1 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат (Выборка.КоличествоСогласовано > 0);
	
КонецФункции

// Определяет есть ли отклоняющие решения по указанному объекту.
// 
// Параметры:
//  СсылкаНаОбъект  - СправочникСсылка,ДокументСсылка.
// 
// Возвращаемое значение:
//   ЕстьБлокирующиеРешения - Булево.
// 
Функция ЕстьБлокирующиеРешения(СсылкаНаОбъект) Экспорт
	
	Если МеханизмВизированияОтключен(СсылкаНаОбъект) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	УстановленныеВизы.Решение КАК Решение
	|ИЗ
	|	РегистрСведений.бит_УстановленныеВизы КАК УстановленныеВизы
	|ГДЕ
	|	УстановленныеВизы.Объект = &Объект
	|	И УстановленныеВизы.Решение.ТипРешения = ЗНАЧЕНИЕ(Перечисление.бит_ТипыРешений.Отклоняющее)";
	Запрос.УстановитьПараметр("Объект",  СсылкаНаОбъект);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат НЕ РезультатЗапроса.Пустой();
	
КонецФункции

// Читает набор записей регистра сведений бит_УстановленныеВизы согласно отбору.
// 
// Параметры:
//  СтруктураОтбор  - Структура.
// 
// Возвращаемое значение:
//   РегистрСведенийНаборЗаписей.бит_УстановленныеВизы.
// 
Функция ПрочитатьНаборВиз(СтруктураОтбор) Экспорт
	
	Если СтруктураОтбор.Свойство("Объект") Тогда
		
		ИмяПолное 		= СтруктураОтбор.Объект.Метаданные().ПолноеИмя();
		МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ИмяПолное);
		ПустаяСсылка 	= МенеджерОбъекта.ПустаяСсылка();

		Если Метаданные.РегистрыСведений.бит_УстановленныеВизы.Измерения.Объект.Тип.СодержитТип(ТипЗнч(ПустаяСсылка)) Тогда
		     НаборЗаписей = бит_ОбщегоНазначения.ПрочитатьНаборЗаписейРегистраСведений(СтруктураОтбор,"бит_УстановленныеВизы");
		Иначе	
			ВызватьИсключение НСтр("ru='Установленные визы: неизвестный тип объекта.';en='Established Visas: unknown object type.'");			
		КонецЕсли;	
	Иначе
		НаборЗаписей = бит_ОбщегоНазначения.ПрочитатьНаборЗаписейРегистраСведений(СтруктураОтбор,"бит_УстановленныеВизы");
	КонецЕсли; 
	
	Возврат НаборЗаписей;
	
КонецФункции

// Выполняет обновление набора виз для объекта.
// 
// Параметры:
//  ТекущийОбъект  - ДокументСсылка.
//  ДатаЗаполнения - Дата.
//  СтруктураПараметров - Структура.
// 
Процедура ОбновитьПереченьВиз(ТекущийОбъект, ДатаЗаполнения, СтруктураПараметров)  Экспорт

	Если НЕ СтруктураПараметров.Свойство("Алгоритм") Тогда
		Алгоритм = бит_УправлениеПроцессами.АлгоритмВизированияОбъекта(ТекущийОбъект);
	Иначе
		Алгоритм = СтруктураПараметров.Алгоритм;
	КонецЕсли; 												
	
	// Заполнение виз по алгоритму.												
	СтруктураПараметровАлгоритм = Новый Структура;
	СтруктураПараметров.Вставить("ТекущийОбъект"  ,ТекущийОбъект);
	СтруктураПараметров.Вставить("Алгоритм"       ,Алгоритм);
	СтруктураПараметров.Вставить("ОчищатьНабор"   ,Истина);
	СтруктураПараметров.Вставить("ЗаписыватьНабор",Истина);
	
	ЗаполнитьВизыПоАлгоритму(СтруктураПараметров);

КонецПроцедуры

// Конструктор параметров проверки условий выполнения алгоритма.
// 
// Возвращаемое значение:
//  Параметры - Структура.
//
Функция НовыеПараметрыРасчетаСрокаИсполнения() Экспорт
	
	ПараметрыРасчета = Новый Структура;
	ПараметрыРасчета.Вставить("ОбъектРасчета",    Неопределено);
	ПараметрыРасчета.Вставить("ДатаОтсчета",      '00010101');
	ПараметрыРасчета.Вставить("ВремяНаУстановку", 0); // Минуты.
	ПараметрыРасчета.Вставить("ПараметрыОбъекта", Неопределено);
	
	Возврат ПараметрыРасчета;
	
КонецФункции

// Функция вычисляет сроки установки визы на основании данных производственного календаря.
// 
// Параметры:
// 	ПараметрыРасчета - Структура. см. НовыеПараметрыРасчетаСрокаИсполнения().
// 
// Возвращаемое значение:
// 	Дата.
//
Функция СрокИсполнения(ПараметрыРасчета) Экспорт
	
	СекундВМинуте            = 60;
	СрокИсполнения           = ПараметрыРасчета.ДатаОтсчета;
	СтруктурноеПодразделение = СтруктурноеПодразделение(ПараметрыРасчета.ОбъектРасчета);
	ПараметрыРабочегоВремени = ПараметрыРабочегоВремени(СтруктурноеПодразделение, СрокИсполнения);
	
	СекундНаУстановку = ПараметрыРасчета.ВремяНаУстановку * СекундВМинуте;
	Если НЕ ПараметрыРабочегоВремени.ИспользуетсяГрафик
		И НЕ ПараметрыРабочегоВремени.ИспользуетсяКалендарь Тогда
		Возврат СрокИсполнения + СекундНаУстановку;
	КонецЕсли;
	
	СдвинутьСрокНаРабочийПериод(СрокИсполнения, ПараметрыРабочегоВремени);
	ДобавитьДниНаУстановку(СрокИсполнения, СекундНаУстановку, ПараметрыРабочегоВремени);	
	ДобавитьВремяНаУстановку(СрокИсполнения, СекундНаУстановку, ПараметрыРабочегоВремени);
	
	Возврат СрокИсполнения;	
	
КонецФункции

// Получает алгоритм визирования исходя из текущего набора виз для объекта.
// 
// Параметры:
//  НаборВизы  - РегистрыСведенийНаборЗаписей.бит_УстановленныеВизы.
// 
// Возвращаемое значение:
//  Алгоритм   - СправочникСсылка.бит_АлгоритмыПроцессов.
// 
Функция ПолучитьАлгоритмПоНаборуВиз(НаборВизы) Экспорт

	Алгоритм = Справочники.бит_АлгоритмыПроцессов.ПустаяСсылка();
	Для Каждого СтрокаВизы Из НаборВизы Цикл
		Если ЗначениеЗаполнено(СтрокаВизы.Алгоритм) Тогда
			Алгоритм = СтрокаВизы.Алгоритм;
			Прервать;
		КонецЕсли; 
	КонецЦикла; 

	Возврат Алгоритм;
	
КонецФункции

// Продолжает выполнение алгоритма визирования.
// 
// Параметры:
//  ТекущийОбъект  - ДокументОбъект.
//  НаборВизы      - РегистрСведенийНаборЗаписей.бит_УстановленныеВизы (По умолчанию = Неопределено).
//  ЗаписыватьВизы - Булево (По умолчанию = Истина).
// 
Процедура ДовыполнитьАлгоритмВизирования(ТекущийОбъект, НаборВизы = Неопределено, ЗаписыватьВизы = Истина) Экспорт

	Если НаборВизы = Неопределено Тогда
		Отбор = Новый Структура;
		Отбор.Вставить("Объект", ТекущийОбъект.Ссылка);		
		НаборВизы = ПрочитатьНаборВиз(Отбор);	
	КонецЕсли; 
	
	Алгоритм = ПолучитьАлгоритмПоНаборуВиз(НаборВизы);
	
	ВыполнятьПоэтапно = бит_УправлениеПроцессами.ВыполнятьАлгоритмПоэтапно(Алгоритм);
	
	ПараметрыКонтекста = Новый Структура;
	ПараметрыКонтекста.Вставить("Алгоритм",          Алгоритм);
	ПараметрыКонтекста.Вставить("ВыполнятьПоэтапно", ВыполнятьПоэтапно);
	ПараметрыКонтекста.Вставить("НаборВизы",         НаборВизы);
	ПараметрыКонтекста.Вставить("СтекОчистки",       Новый СписокЗначений);
	ПараметрыКонтекста.Вставить("ТекущийОбъект",     ТекущийОбъект);
	
	Если НЕ ВыполнятьПоэтапно Тогда
		Если НЕ ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ТекущийОбъект.ДополнительныеСвойства,
															"РежимОчисткиРешения",
															Ложь) Тогда
			Пока АвтоустановкаРешенийНаборуВиз(ПараметрыКонтекста) Цикл
				ОпередитьКрайниеСрокиИАктивность(ПараметрыКонтекста);
			КонецЦикла;
			
			Если ЗаписыватьВизы И НаборВизы.Модифицированность() Тогда
				Если НаборВизы.ПроверитьЗаполнение() Тогда
					НаборВизы.Записать();
				КонецЕсли; 
			КонецЕсли;
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	СтруктураКонтекст = Новый Структура;
	СтруктураКонтекст.Вставить("ТекущийОбъект", ТекущийОбъект);
	СтруктураКонтекст.Вставить("Визы"         , НаборВизы);
	
	КомментироватьВыполнение = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию("КомментироватьХодВыполненияАлгоритмовПроцессов",
								Пользователи.ТекущийПользователь());
		
	РежимСообщений = ?(КомментироватьВыполнение, "Все", "Ошибки");				
	
	бит_УправлениеПроцессами.ВыполнитьАлгоритм(Алгоритм, СтруктураКонтекст, РежимСообщений);
	Если НЕ ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ТекущийОбъект.ДополнительныеСвойства,
															"РежимОчисткиРешения",
															Ложь) Тогда
		Пока АвтоустановкаРешенийНаборуВиз(ПараметрыКонтекста) Цикл
			бит_УправлениеПроцессами.ВыполнитьАлгоритм(Алгоритм, СтруктураКонтекст, РежимСообщений);
		КонецЦикла;
	КонецЕсли;

	ОпередитьКрайниеСрокиИАктивность(ПараметрыКонтекста);
    	
	Если ЗаписыватьВизы И НаборВизы.Модифицированность() Тогда
		Если НаборВизы.ПроверитьЗаполнение() Тогда
			НаборВизы.Записать();
		КонецЕсли; 
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ИнтерфейсПользовательскихУсловий

// Определяет есть ли решение определенного вида.
// Может вызываться при вычислении пользовательских условий.
// 
// Параметры:
//  ТекущийОбъект  - ДокументОбъект,ДокументСсылка.
//  Решение        - СправочникСсылка.бит_ВидыРешенийСогласования.
//  НаборВизы      - РегистрСведенийНаборЗаписей.бит_УстановленныеВизы,ТаблицаЗначений.
// 
// Возвращаемое значение:
//   Булево.
// 
Функция ПринятоРешение(ТекущийОбъект, Решение, НаборВизы = Неопределено) Экспорт

	Если МеханизмВизированияОтключен(ТекущийОбъект) Тогда
		Возврат Истина;
	КонецЕсли;
	
	РешениеПринято = Ложь;
	
	Если НаборВизы = Неопределено Тогда
		Отбор = Новый Структура;
		Отбор.Вставить("Объект",ТекущийОбъект);
		НаборВизы = ПрочитатьНаборВиз(Отбор);
	КонецЕсли; 

	Для каждого Запись Из НаборВизы Цикл
		Если Запись.Решение = Решение Тогда
			РешениеПринято = Истина;
			Прервать;
		КонецЕсли; 
	КонецЦикла; 
	
	Возврат РешениеПринято;
	
КонецФункции

// Определяет какое решение было принято по визе.
// Может вызываться при вычислении пользовательских условий.
// 
// Параметры:
//  ТекущийОбъект  - ДокументОбъект,ДокументСсылка.
//  НаборВизы      - РегистрСведенийНаборЗаписей.бит_УстановленныеВизы,ТаблицаЗначений.
//  Виза           - СправочникСсылка.бит_Визы.
// 
// Возвращаемое значение:
//  СправочникСсылка.бит_ВидыРешенийСогласования.
// 
Функция ПринятоРешениеПоВизе(ТекущийОбъект, Виза, НаборВизы = Неопределено) Экспорт

	Если МеханизмВизированияОтключен(ТекущийОбъект) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Решение = Справочники.бит_ВидыРешенийСогласования.ПустаяСсылка();
	
	Если НаборВизы = Неопределено Тогда
		Отбор = Новый Структура;
		Отбор.Вставить("Объект",ТекущийОбъект);
		НаборВизы = ПрочитатьНаборВиз(Отбор);
	КонецЕсли; 
	
	Для Каждого Запись Из НаборВизы Цикл
		Если Запись.Виза = Виза Тогда
			Решение = Запись.Решение;
			Прервать;
		КонецЕсли; 
	КонецЦикла; 

	Возврат Решение;
	
КонецФункции

// Проверяет получены ли все утверждающие визы по данному объекту для перехода в данный статус. 
// Если статус не заполнен проверяется заполнение всех утверждающих виз. 
// Может вызываться при вычислении пользовательских условий.
// 
// Параметры:
//  ТекущийОбъект  - ДокументСсылка.
//  Статус         - СправочникСсылка.СтатусыОбъектов.
// 
// Возвращаемое значение:
//   Булево.
// 
Функция ВизыПолучены(ТекущийОбъект, Статус = Неопределено) Экспорт

	Если МеханизмВизированияОтключен(ТекущийОбъект) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	ТекстЗапроса =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Визы.Виза КАК Виза,
	|	Визы.Статус КАК Статус,
	|	Визы.Решение КАК Решение,
	|	ВЫБОР
	|		КОГДА Визы.Решение.ТипРешения = ЗНАЧЕНИЕ(Перечисление.бит_ТипыРешений.Согласующее)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Согласовано
	|ИЗ
	|	РегистрСведений.бит_УстановленныеВизы КАК Визы
	|ГДЕ
	|	Визы.Объект = &Объект
	|	И &УсловиеСтатуса
	|	И Визы.Виза.Вид = ЗНАЧЕНИЕ(Перечисление.бит_ВидыВиз.Утверждающая)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Согласовано";
	Если ЗначениеЗаполнено(Статус) Тогда
		УсловиеСтатуса = "Визы.Статус = &Статус";
		Запрос.УстановитьПараметр("Статус", Статус);
	Иначе
		УсловиеСтатуса = "ИСТИНА";
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеСтатуса", УсловиеСтатуса);
	Запрос.УстановитьПараметр("Объект", ТекущийОбъект.Ссылка);
	Запрос.Текст = ТекстЗапроса;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Согласовано;
	
КонецФункции

// Проверяет все ли решения по вышестоящим визам совпадают с указанным.
// 
// Параметры:
//  ТекущийОбъект  - ДокументОбъект,ДокументСсылка.
//  Виза           - СправочникСсылка.бит_Визы.
//  Решение        - СправочникСсылка.бит_ВидыРешенийСогласования.
//  НаборВизы      - РегистрСведенийНаборЗаписей.бит_УстановленныеВизы,ТаблицаЗначений.
// 
// Возвращаемое значение:
//  Булево.
// 
Функция ПринятоРешениеПоВышестоящимВизам(ТекущийОбъект, Виза, Решение, НаборВизы = Неопределено) Экспорт

	Если МеханизмВизированияОтключен(ТекущийОбъект) Тогда
		Возврат Истина;
	КонецЕсли;
	
	ПринятоРешение = Ложь;
	
	Если НаборВизы = Неопределено Тогда
		Отбор = Новый Структура;
		Отбор.Вставить("Объект",ТекущийОбъект);
		НаборВизы = ПрочитатьНаборВиз(Отбор);
	КонецЕсли; 
	
	ТаблицаВиз = НаборВизы.Выгрузить();
	СтрокаВизы = ТаблицаВиз.Найти(Виза, "Виза");
	Если СтрокаВизы = Неопределено Тогда
		// В случае поэтапного алгоритма проверяемой визы может еще не быть в наборе
		//	в таком случае проверяем решение по всем текущим визам.
		ПорядокПроверяемойВизы = 0;
	Иначе
		ПорядокПроверяемойВизы = СтрокаВизы.КодСортировки;
		ТаблицаВиз.Сортировать("КодСортировки");
	КонецЕсли;
	
	Для Каждого СтрокаВизы Из ТаблицаВиз Цикл
		Если ПорядокПроверяемойВизы > 0 И СтрокаВизы.КодСортировки >= ПорядокПроверяемойВизы Тогда
			// Текущая или последующие визы.
			Прервать;
		КонецЕсли;
		
		Если СтрокаВизы.Решение = Решение Тогда
			ПринятоРешение = Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;

	Возврат ПринятоРешение;
	
КонецФункции

// Проверяет приняты ли хоть какие-то решения по вышестоящим визам.
// 
// Параметры:
//  ТекущийОбъект  - ДокументОбъект,ДокументСсылка - документ.
//  Виза           - СправочникСсылка.бит_Визы - виза.
//  НаборВизы      - РегистрСведенийНаборЗаписей.бит_УстановленныеВизы.
// 
// Возвращаемое значение:
//  Булево.
// 
Функция ПринятыРешенияПоВышестоящимВизам(ТекущийОбъект, Виза, НаборВизы = Неопределено) Экспорт

	Если МеханизмВизированияОтключен(ТекущийОбъект) Тогда
		Возврат Истина;
	КонецЕсли;
	
	ПринятоРешение = Ложь;
	
	Если НаборВизы = Неопределено Тогда
		Отбор = Новый Структура;
		Отбор.Вставить("Объект",ТекущийОбъект);
		НаборВизы = ПрочитатьНаборВиз(Отбор);
	КонецЕсли; 
	
	ТаблицаВиз = НаборВизы.Выгрузить();
	СтрокаВизы = ТаблицаВиз.Найти(Виза, "Виза");
	Если СтрокаВизы = Неопределено Тогда
		// В случае поэтапного алгоритма проверяемой визы может еще не быть в наборе
		//	в таком случае проверяем решение по всем текущим визам.
		ПорядокПроверяемойВизы = 0;
	Иначе
		ПорядокПроверяемойВизы = СтрокаВизы.КодСортировки;
		ТаблицаВиз.Сортировать("КодСортировки");
	КонецЕсли;
	
	Для Каждого СтрокаВизы Из ТаблицаВиз Цикл
		Если ПорядокПроверяемойВизы > 0 И СтрокаВизы.КодСортировки >= ПорядокПроверяемойВизы Тогда
			// Текущая или последующие визы.
			Прервать;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаВизы.Решение) Тогда
			ПринятоРешение = Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;

	Возврат ПринятоРешение;
	
КонецФункции

// Проверяет доступна ли пользователю роль исполнителя.
// 
// Параметры:
//  ТекущийОбъект   - ЛюбаяСсылка.
//  РольИсполнителя - СправочникСсылка.бит_РолиИсполнителей.
//	ТекущийПользователь - СправочникСсылка.Пользователи.
// 
// Возвращаемое значение:
//  Булево.
// 
Функция ДоступнаРольИсполнителя(ТекущийОбъект, РольИсполнителя, ТекущийПользователь) Экспорт

	РольДоступна = Ложь;
	
	Если НЕ ЗначениеЗаполнено(ТекущийПользователь) Тогда
		ТекущийПользователь = Пользователи.ТекущийПользователь();
	КонецЕсли; 

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИсполнителиЗадач.РольИсполнителя КАК РольИсполнителя,
	|	ИсполнителиЗадач.Исполнитель КАК Исполнитель,
	|	ОбъектыАдресации_1.Вид КАК ВидОбъекта_1,
	|	ОбъектыАдресации_1.Вид.Код КАК ИмяВида_1,
	|	ОбъектыАдресации_1.Вид.СпособПроверкиПринадлежности КАК СпособПроверки_1,
	|	ИсполнителиЗадач.ОбъектАдресации_1 КАК ОбъектАдресации_1,
	|	ОбъектыАдресации_2.Вид КАК ВидОбъекта_2,
	|	ОбъектыАдресации_2.Вид.Код КАК ИмяВида_2,
	|	ОбъектыАдресации_2.Вид.СпособПроверкиПринадлежности КАК СпособПроверки_2,
	|	ИсполнителиЗадач.ОбъектАдресации_2 КАК ОбъектАдресации_2,
	|	ОбъектыАдресации_3.Вид КАК ВидОбъекта_3,
	|	ОбъектыАдресации_3.Вид.Код КАК ИмяВида_3,
	|	ОбъектыАдресации_3.Вид.СпособПроверкиПринадлежности КАК СпособПроверки_3,
	|	ИсполнителиЗадач.ОбъектАдресации_3 КАК ОбъектАдресации_3
	|ИЗ
	|	РегистрСведений.бит_ИсполнителиЗадач КАК ИсполнителиЗадач
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_РолиИсполнителей.ОбъектыАдресации КАК ОбъектыАдресации_1
	|		ПО ИсполнителиЗадач.РольИсполнителя = ОбъектыАдресации_1.Ссылка
	|			И (ОбъектыАдресации_1.Имя = ""ОбъектАдресации_1"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_РолиИсполнителей.ОбъектыАдресации КАК ОбъектыАдресации_2
	|		ПО ИсполнителиЗадач.РольИсполнителя = ОбъектыАдресации_2.Ссылка
	|			И (ОбъектыАдресации_2.Имя = ""ОбъектАдресации_2"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_РолиИсполнителей.ОбъектыАдресации КАК ОбъектыАдресации_3
	|		ПО ИсполнителиЗадач.РольИсполнителя = ОбъектыАдресации_3.Ссылка
	|			И (ОбъектыАдресации_3.Имя = ""ОбъектАдресации_3"")
	|ГДЕ
	|	ИсполнителиЗадач.Исполнитель = &ТекущийПользователь
	|	И ИсполнителиЗадач.РольИсполнителя = &РольИсполнителя";
	Запрос.УстановитьПараметр("РольИсполнителя"    , РольИсполнителя);
	Запрос.УстановитьПараметр("ТекущийПользователь", ТекущийПользователь);
	
	Выборка     = Запрос.Выполнить().Выбрать();
	МетаОбъект  = ТекущийОбъект.Метаданные();
	
	Пока Выборка.Следующий() Цикл
		 УсловиеВыполнено = ПроверитьПринадлежностьОбъектаВизирования(ТекущийОбъект, МетаОбъект, Выборка);
		 Если УсловиеВыполнено Тогда
		 	РольДоступна = Истина;
			Прервать;
		 КонецЕсли; 
	КонецЦикла; 
	
	Возврат РольДоступна;
	
КонецФункции

// Проверяет наличие назначенных исполнителей по роли.
// 
// Параметры:
//  ТекущийОбъект   - ЛюбаяСсылка.
//  РольИсполнителя - СправочникСсылка.бит_РолиИсполнителей.
// 
// Возвращаемое значение:
