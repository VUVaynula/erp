
#Область ПрограммныйИнтерфейс

// Процедура - Основная процедура работы с Ботом Telegram.
//
Процедура ОбработатьОповещенияБоту() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.бит_ОповещенияТелеграм);
	Если НЕ ПолучитьФункциональнуюОпцию("бит_ПолучатьИнформациюОтБотаТелеграм") Тогда
		ВызватьИсключение НСтр("ru='Регламентное задание недоступно по функциональным опциям.';
		|en='Scheduled task is not available for functional options.'");
	КонецЕсли;
	
	ГлавныйБот = бит_ТелеграмПовтИсп.ГлавныйБот();
	
	СлужебныеОповещения(ГлавныйБот);
	ОповеститьОНовыхВизах(ГлавныйБот);
	ОбслужитьСообщенияЧатов();
	
КонецПроцедуры

// Функция - возвращает HTTPСоединение созданное средствами 1с.
// 
// Возвращаемое значение:
//  HTTPСоединение - HTTPСоединение.
//
Функция НовоеHTTPСоединение() Экспорт

	НастройкиПрокси = бит_ТелеграмПовтИсп.НастройкиПрокси();
	
	Если НастройкиПрокси = Неопределено Тогда
		НастройкиПрокси = НоваяСтруктураПрокси();
	КонецЕсли; 
	
	ЗащищенноеСоединение = ОбщегоНазначенияКлиентСервер.НовоеЗащищенноеСоединение();
	Соединение = ?(НЕ НастройкиПрокси.ВключитьПрокси
					, Новый HTTPСоединение("api.telegram.org",,,,,5,ЗащищенноеСоединение)
					, Новый HTTPСоединение("api.telegram.org",,,,НовыеНастройкиПрокси(НастройкиПрокси),5,ЗащищенноеСоединение));
	
	Возврат Соединение;
	
КонецФункции

// Функция - Новая структура прокси.
// 
// Возвращаемое значение:
//  СтруктураПрокси - Структура.
//
Функция НоваяСтруктураПрокси() Экспорт 

	СтруктураПрокси = Новый Структура("ВключитьПрокси, Сервер, Порт, АутентификацияОС, Логин, Пароль");
									
	СтруктураПрокси.ВключитьПрокси 		= Ложь;
	СтруктураПрокси.Сервер 				= "";
	СтруктураПрокси.Порт 				= 0;
	СтруктураПрокси.АутентификацияОС 	= Ложь;
	СтруктураПрокси.Логин 				= "";
	СтруктураПрокси.Пароль 				= "";
	
	Возврат СтруктураПрокси;

КонецФункции // СтруктураПрокси()
 
// Процедура - фиксирует в реестре обмена новое сообщение из базы.
//
// Параметры:
//  ТекстСообщения	 - Строка - Текст сообщения.
//  Чат				 - СправочникСсылка.бит_ЧатыTelegram - чат.
//
Процедура НовоеСообщениеЧатуИзБазы(ТекстСообщения, Чат) Экспорт 

	ИДСообщения = НовоеИДСообщенияДляОтправки();
	
	стрСообщенияТелеграмИсходящее = Новый Структура();
	
	стрСообщенияТелеграмИсходящее.Вставить("ВидЗапросаТелеграм"	, Перечисления.бит_ВидыЗапросовТелеграм.СообщениеЧатуИзБазы);
	стрСообщенияТелеграмИсходящее.Вставить("Состояние"			, Перечисления.бит_ВидыСостоянийТелеграм.ОжидаетОтправления);
	стрСообщенияТелеграмИсходящее.Вставить("Чат"				, Чат);
	стрСообщенияТелеграмИсходящее.Вставить("СообщениеИД"		, ИДСообщения);
	стрСообщенияТелеграмИсходящее.Вставить("Сообщение"			, ТекстСообщения);
	стрСообщенияТелеграмИсходящее.Вставить("ДатаОтправки"		, ТекущаяДатаСеанса());
	
	НоваяЗаписьВРеестрОбмена(стрСообщенияТелеграмИсходящее);

КонецПроцедуры // НовоеСообщениеЧатуИзБазы()

// Процедура - фиксирует в реестре обмена новое сообщение о статусе.
//
// Параметры:
//  СтатусРегистрации	 - ПеречислениеСсылка.бит_СтатусРегистрацииТелеграм - статус.
//  Чат					 - СправочникСсылка.бит_ЧатыTelegram - чат.
//
Процедура НовоеСообщениеОСтатусеРегистрации(СтатусРегистрации, Чат) Экспорт 

	ИДСообщения = НовоеИДСообщенияДляОтправки();
	
	Если СтатусРегистрации = Перечисления.бит_СтатусРегистрацииТелеграм.Запрещено Тогда	
		ТекстСообщения = НСтр("ru='Статус регистрации вашего чата: заблокирован.';
							  |en='Registration status of your chat: locked.'");		
	ИначеЕсли СтатусРегистрации = Перечисления.бит_СтатусРегистрацииТелеграм.ОжидаетРегистрации Тогда	
		ТекстСообщения = НСтр("ru='Статус регистрации вашего чата: на рассмотрении.';
							  |en='Registration status of your chat: pending.'");		
	ИначеЕсли СтатусРегистрации = Перечисления.бит_СтатусРегистрацииТелеграм.Разрешено Тогда	
		ТекстСообщения = НСтр("ru='Статус регистрации вашего чата: разрешен доступ к командам.';
							  |en='Registration status of your chat: allow access to commands.'")
						 + НовыйТекстКлавиатурыСДоступнымиКомандами(ДоступныеКомандыЧату(Чат), Истина);		
	Иначе	
		Возврат;
	КонецЕсли; 
	
	стрСообщенияТелеграмИсходящее = Новый Структура();
	
	стрСообщенияТелеграмИсходящее.Вставить("ВидЗапросаТелеграм", Перечисления.бит_ВидыЗапросовТелеграм.ПодтверждениеРегистрации);
	стрСообщенияТелеграмИсходящее.Вставить("Состояние"		   , Перечисления.бит_ВидыСостоянийТелеграм.ОжидаетОтправления);
	стрСообщенияТелеграмИсходящее.Вставить("Чат"			   , Чат);
	стрСообщенияТелеграмИсходящее.Вставить("СообщениеИД"	   , ИДСообщения);
	стрСообщенияТелеграмИсходящее.Вставить("Сообщение"		   , ТекстСообщения);
	стрСообщенияТелеграмИсходящее.Вставить("ДатаОтправки"	   , ТекущаяДатаСеанса());
	
	НоваяЗаписьВРеестрОбмена(стрСообщенияТелеграмИсходящее);

КонецПроцедуры

// Функция - Проверить наличие администраторов бота.
//
// Параметры:
//  БотТелеграм	 - СправочникСсылка.бит_БотыTelegram - боты.
// 
// Возвращаемое значение:
//  Результат - Булево.
//
Функция ПроверитьНаличиеАдминистраторовБота(БотТелеграм) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Бот", БотТелеграм);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЧатыДляСлужебныхОповещений.Чат
	               |ИЗ
	               |	РегистрСведений.бит_ЧатыДляСлужебныхОповещенийТелеграм КАК ЧатыДляСлужебныхОповещений
	               |ГДЕ
	               |	ЧатыДляСлужебныхОповещений.Бот = &Бот";
	
	РезультатЗапроса = Запрос.Выполнить().Пустой();
	
	Возврат НЕ РезультатЗапроса;
	
КонецФункции

// Функция определяет дату сообщений Telegram, до которой записи считаются не актуальными.
//
// Возвращаемое значение:
//	Дата.
//
Функция ГраницаАктуальнойИсторииТелеграм() Экспорт
	
	ХранениеИсторииДней = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_СрокХраненияИсторииТелеграм");
	Если НЕ ЗначениеЗаполнено(ХранениеИсторииДней) Тогда
		ХранениеИсторииДней = 3;
	КонецЕсли;
	
	АктуальнаяДата = ТекущаяДатаСеанса() - (ХранениеИсторииДней * 86400);
	Возврат АктуальнаяДата;
	
КонецФункции

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции

#Область ОповещенияНовыхВиз

Процедура ОповеститьОНовыхВизах(БотДляОповещений)
	
	Если НЕ бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_ОповещенияВТелеграмОНовыхВизах") Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(БотДляОповещений) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	бит_УстановленныеВизы.Объект КАК Объект,
	|	бит_УстановленныеВизы.Виза КАК Виза
	|ИЗ
	|	РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы
	|ГДЕ
	|	бит_УстановленныеВизы.АктивнаяВиза
	|	И НЕ бит_УстановленныеВизы.ОповещеноТелеграм";
	ВизыДляОповещений = Запрос.Выполнить().Выгрузить();
	
	ПолучателиОповещений = ПолучателиОповещенийТелеграм();
	Если ПолучателиОповещений.Количество() > 0
		И ВизыДляОповещений.Количество() > 0 Тогда
		ОтветственныеЗаВизы = бит_ВизированиеСервер.ОтветственныеЗаУстановкуВиз(ВизыДляОповещений, ПолучателиОповещений);
		ОправитьОповещенияОВизах(ОтветственныеЗаВизы, БотДляОповещений);
	КонецЕсли;
	
	бит_ВизированиеСервер.УстановитьОтметкуОповещения(ВизыДляОповещений
													, Перечисления.бит_фн_СпособыТранспортаОповещений.Telegram);
	
КонецПроцедуры

Функция ПолучателиОповещенийТелеграм()
	
	Возврат бит_ОповещенияСервер.ПолучателиОповещений(Перечисления.бит_фн_СпособыТранспортаОповещений.Telegram);
	
КонецФункции

Процедура ОправитьОповещенияОВизах(ОтветственныеЗаВизы, БотДляОповещений)
	
	Если ОтветственныеЗаВизы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Токен = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БотДляОповещений, "Токен");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОтветственныеЗаВизы.ОбъектВизирования КАК ОбъектВизирования,
	|	ОтветственныеЗаВизы.Ответственный КАК Ответственный
	|ПОМЕСТИТЬ ОтветственныеЗаВизы
	|ИЗ
	|	&ОтветственныеЗаВизы КАК ОтветственныеЗаВизы";
	Запрос.УстановитьПараметр("ОтветственныеЗаВизы", ОтветственныеЗаВизы);
	Запрос.Выполнить();
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОтветственныеЗаВизы.ОбъектВизирования КАК ОбъектВизирования,
	|	ОтветственныеЗаВизы.Ответственный КАК Ответственный,
	|	ЧатыTelegram.Ссылка КАК ЧатТелеграм,
	|	ЧатыTelegram.ИД КАК ЧатИД
	|ИЗ
	|	ОтветственныеЗаВизы КАК ОтветственныеЗаВизы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_ЧатыTelegram КАК ЧатыTelegram
	|		ПО ОтветственныеЗаВизы.Ответственный = ЧатыTelegram.Пользователь
	|			И (ЧатыTelegram.ОсновнойБот = &ОсновнойБот)
	|			И (НЕ ЧатыTelegram.ПометкаУдаления)
	|			И (ЧатыTelegram.СтатусРегистрации = ЗНАЧЕНИЕ(Перечисление.бит_СтатусРегистрацииТелеграм.Разрешено))";
	Запрос.УстановитьПараметр("ОсновнойБот", БотДляОповещений);
	ВыборкаОповещений = Запрос.Выполнить().Выбрать();
	
	МассивОповещений = Новый Массив;
	Пока ВыборкаОповещений.Следующий() Цикл
		ДобавитьОповещениеНовойВизы(ВыборкаОповещений, МассивОповещений);
	КонецЦикла;
	
	ПараметрыИсходящихСообщений = НовыеПараметрыПакетаИсходящихСообщений();
	ПараметрыИсходящихСообщений.Bot             = Токен;
	ПараметрыИсходящихСообщений.МассивСообщений = МассивОповещений;
	
	ОтправитьПакетСообщенийБоту(ПараметрыИсходящихСообщений);	
	
КонецПроцедуры

Процедура ДобавитьОповещениеНовойВизы(ПараметрыОповещения, МассивОповещений)
	
	ОбъектВизирования = ПараметрыОповещения.ОбъектВизирования;
	Пользователь      = ПараметрыОповещения.Ответственный;
	
	// Заголовок объекта.
	ОтветЗаголовок = "Новая виза на согласование: %1 <b><a href=""%2"">%3</a></b>";
	ОтветЗаголовок = СтрШаблон(ОтветЗаголовок, КодEmoji("clipboard"),
								ПолучитьНавигационнуюСсылку(ОбъектВизирования),
								ОбъектВизирования);
	
	// Команды согласования.
	МетаданныеОбъекта = ОбъектВизирования.Метаданные();
	ОбъектСистемы     = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(МетаданныеОбъекта.ПолноеИмя());
	
	ПараметрыОпределенияСР = бит_ВизированиеСервер.НовыеПараметрыОпределенияСпискаРешений();
	ПараметрыОпределенияСР.ОбъектСистемы = ОбъектСистемы;
	ПараметрыОпределенияСР.ТекущийОбъект = ОбъектВизирования.ПолучитьОбъект();
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Организация", МетаданныеОбъекта) Тогда
		Организация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектВизирования, "Организация");
		ПараметрыОпределенияСР.Вставить("Организация", Организация);
	КонецЕсли;
	ДоступныеРешения = бит_ВизированиеСервер.ДоступныеРешения(ПараметрыОпределенияСР);
	
	КонструкторКоманд = НовыйКонструкторПанелиКоманд();
	Для каждого Решение Из ДоступныеРешения Цикл
		СхемаИдентификаторов = СхемаИдентификаторовОбъекта(Решение.Значение);
		ОбъектСтрокой        = СхемаИдентификаторов.ИДТипа + "," + СхемаИдентификаторов.ИДОбъекта;
		ДобавитьКоманду(КонструкторКоманд.Команды, "/ApprovAction," + ОбъектСтрокой, Решение.Представление);
	КонецЦикла;
	ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/AddApprovComment", НСтр("ru = 'Ввести комментарий';en = 'Add comment'"),
						КодEmoji("memo"));
	ИмяСправочникаХранения = РаботаСФайламиСлужебный.ИмяСправочникаХраненияФайлов(ОбъектВизирования);
	Если ЗначениеЗаполнено(ИмяСправочникаХранения) Тогда
		ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/ApprovAttachment", НСтр("ru = 'Вложения';en = 'Attachment'"),
						КодEmoji("paperclip"));
	КонецЕсли;
	
	ДоступныеКоманды = ПараметрыОповещения.ЧатТелеграм.ДоступныеКоманды;
	Если ДоступныеКоманды.Найти(Справочники.бит_КомандыБотуТелеграм.ApprovList) <> Неопределено Тогда
		ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/ApprovList", НСтр("ru = 'Все визы';en = 'All visa'"),
						КодEmoji("bookmark_tabs"));
	КонецЕсли;
							
	КонструкторКоманд.КоличествоКомандВСтроке = 2;
	ТелоКоманд = ТекстПанелиКоманд(КонструкторКоманд);
	
	
	// Получение данных об объекте визирования.
	АдресВХранилище = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор); 
	МатрицаДоступа  = Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа(Пользователь);
	
	ПараметрыПолучения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
	ПараметрыПолучения.МатрицаДоступа		            = МатрицаДоступа;
	ПараметрыПолучения.ВыводитьВТаблицуЗначений		    = Истина;
	ПараметрыПолучения.Ответственный                    = Пользователь;
	ПараметрыПолучения.ВозвращатьПорядокИЗаголовкиПолей = Истина;
	ПараметрыПолучения.ВозвращатьТаблицуВиз             = Истина;
	ПараметрыПолучения.Отбор.ОбъектВизирования          = ОбъектВизирования;
	
	НастройкиПоУмолчанию = Обработки.бит_КонсольОперативногоВизирования.НастройкаПоУмолчанию(Пользователь);
	Если ЗначениеЗаполнено(НастройкиПоУмолчанию) Тогда
		НастройкиКомпоновщика = НастройкиПоУмолчанию.ХранилищеНастроек.Получить().НастройкиКомпоновщика;
		ПараметрыПолучения.НастройкиКомпоновщика         = НастройкиКомпоновщика;
		ПараметрыПолучения.ПолучатьНастройкиКомпоновщика = Истина;
	КонецЕсли;
	
	Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
	
	Результат = ПолучитьИзВременногоХранилища(АдресВХранилище);
	ТаблицаДокументов      = Результат.РезультатТаблицаЗначений;
	ПорядокИЗаголовкиПолей = Результат.ПорядокИЗаголовкиПолей;
	ТаблицаВизы            = Результат.ТаблицаВизы;
	ТаблицаВизы.Индексы.Добавить("ИД");
	
	ИДСтрокиВизирования = Неопределено;
	Виза                = Неопределено;
	
	ШаблонОписанияПоля  = "<b>%1:</b> <code>%2</code>";
	ШаблонУточненияВизы = "
	|
	|%1 <b>%2</b>: %3.
	|%1 <b>%4:</b> <i>%5.</i>";
	ОписаниеЭУ = Обработки.бит_КонсольОперативногоВизирования.ИдентификаторЭлементаУправленияКартинки();
	КолонкиТаблицыДокументов = ТаблицаДокументов.Колонки;
	Для каждого СтрокаТаблицыВывода Из ТаблицаДокументов Цикл
		ЭлементУправления = СтрокаТаблицыВывода.ЭлементУправления; 
		Если НЕ ЗначениеЗаполнено(ЭлементУправления) Тогда
			Продолжить;
		КонецЕсли;
		Если СтрНайти(ЭлементУправления, ОписаниеЭУ) = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ОтветТелоСообщения  = "";
		ИДСтрокиВизирования = СтрЗаменить(ЭлементУправления, ОписаниеЭУ, "");
		
		Для каждого ПолеВывода Из ПорядокИЗаголовкиПолей Цикл
			ИмяПоляВывода = ПолеВывода.Имя ;
			Если КолонкиТаблицыДокументов.Найти(ИмяПоляВывода) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ЗначениеПоля = СтрокаТаблицыВывода[ИмяПоляВывода];
			Если ТипЗнч(ЗначениеПоля) = Тип("Массив") Тогда
				ЗначениеПоля = СтрСоединить(ЗначениеПоля, ";");
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(ЗначениеПоля) Тогда
				Продолжить;
			КонецЕсли;
			ЗначениеПоляСтрокой = ЗначениеПоляДляВывода(ЗначениеПоля);
			ОтветТелоСообщения = ОтветТелоСообщения + Символы.ПС;
			ОтветТелоСообщения = ОтветТелоСообщения + СтрШаблон(ШаблонОписанияПоля, ПолеВывода.Заголовок, ЗначениеПоляСтрокой);
		КонецЦикла;
		
		ИсходныеДанныеВизы = ТаблицаВизы.Найти(ИДСтрокиВизирования, "ИД");
		Виза               = ИсходныеДанныеВизы.Виза;
		
		ОтветТелоСообщения = ОтветТелоСообщения + СтрШаблон(ШаблонУточненияВизы, КодEmoji("memo"),
								Виза, НСтр("ru = 'Ожидается принятие решения по визе';en = 'Expected decision on visa'"),
								НСтр("ru = 'Комментарий решения';en = 'Desition comment'"),
								НСтр("ru = 'Не введен';en = 'Absent'"));
								
		ТекстОтвета = ОтветЗаголовок + ОтветТелоСообщения;
								
		ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
		ПараметрыСообщения.ИДЧата         = ПараметрыОповещения.ЧатИД;
		ПараметрыСообщения.Чат            = ПараметрыОповещения.ЧатТелеграм;
		ПараметрыСообщения.Текст          = ТекстОтвета; 
		ПараметрыСообщения.Гипертекст     = Истина;
		ПараметрыСообщения.КомандныйТекст = ТелоКоманд;
		ПараметрыСообщения.Параметры.Вставить("ОбъектВизирования", ОбъектВизирования);
		ПараметрыСообщения.Параметры.Вставить("ИДВизы", ИДСтрокиВизирования);
		ПараметрыСообщения.Параметры.Вставить("Виза", Виза);
		МассивОповещений.Добавить(ПараметрыСообщения);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

Процедура СлужебныеОповещения(БотТелеграм)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Бот", БотТелеграм);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЧатыДляСлужебныхОповещений.Чат КАК Чат,
	|	РеестрОбменаСТелеграм.ВидЗапросаТелеграм КАК ВидЗапросаТелеграм,
	|	РеестрОбменаСТелеграм.СообщениеИД КАК СообщениеИД,
	|	РеестрОбменаСТелеграм.Состояние КАК Состояние,
	|	РеестрОбменаСТелеграм.Сообщение КАК Сообщение,
	|	РеестрОбменаСТелеграм.ДатаОтправки КАК ДатаОтправки,
	|	ЧатыДляСлужебныхОповещений.Чат.ИД КАК ЧатИД
	|ИЗ
	|	РегистрСведений.бит_ЧатыДляСлужебныхОповещенийТелеграм КАК ЧатыДляСлужебныхОповещений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_РеестрОбменаСТелеграм КАК РеестрОбменаСТелеграм
	|		ПО ЧатыДляСлужебныхОповещений.Чат = РеестрОбменаСТелеграм.Чат
	|			И (РеестрОбменаСТелеграм.Состояние = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСостоянийТелеграм.ОжидаетОтправления))
	|			И (ЧатыДляСлужебныхОповещений.Бот = &Бот)
	|			И (ЧатыДляСлужебныхОповещений.Чат.ОсновнойБот = &Бот)
	|			И (ЧатыДляСлужебныхОповещений.Регистрация
	|					И РеестрОбменаСТелеграм.ВидЗапросаТелеграм = ЗНАЧЕНИЕ(Перечисление.бит_ВидыЗапросовТелеграм.РегистрацияЧата)
	|				ИЛИ ЧатыДляСлужебныхОповещений.Помощь
	|					И РеестрОбменаСТелеграм.ВидЗапросаТелеграм = ЗНАЧЕНИЕ(Перечисление.бит_ВидыЗапросовТелеграм.ПомощьЧату))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеестрОбменаСТелеграм.Чат,
	|	РеестрОбменаСТелеграм.ВидЗапросаТелеграм,
	|	РеестрОбменаСТелеграм.СообщениеИД,
	|	РеестрОбменаСТелеграм.Состояние,
	|	РеестрОбменаСТелеграм.Сообщение,
	|	РеестрОбменаСТелеграм.ДатаОтправки,
	|	РеестрОбменаСТелеграм.Чат.ИД
	|ИЗ
	|	РегистрСведений.бит_РеестрОбменаСТелеграм КАК РеестрОбменаСТелеграм
	|ГДЕ
	|	РеестрОбменаСТелеграм.Состояние = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСостоянийТелеграм.ОжидаетОтправления)
	|	И РеестрОбменаСТелеграм.ВидЗапросаТелеграм В (ЗНАЧЕНИЕ(Перечисление.бит_ВидыЗапросовТелеграм.СообщениеЧатуИзБазы), ЗНАЧЕНИЕ(Перечисление.бит_ВидыЗапросовТелеграм.ПодтверждениеРегистрации))
	|	И РеестрОбменаСТелеграм.Чат.ОсновнойБот = &Бот";
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		Попытка
			Блокировка        = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.бит_РеестрОбменаСТелеграм");
			ЭлементБлокировки.УстановитьЗначение("Чат",                Выборка.Чат);
			ЭлементБлокировки.УстановитьЗначение("ВидЗапросаТелеграм", Выборка.ВидЗапросаТелеграм);
			ЭлементБлокировки.УстановитьЗначение("СообщениеИД",        Выборка.СообщениеИД);
			Блокировка.Заблокировать();
			
			ОтправитьСообщениеБоту(БотТелеграм.Токен, Формат(Выборка.ЧатИД, "ЧГ=0"), Выборка.Сообщение);
			
			НаборЗаписей = РегистрыСведений.бит_РеестрОбменаСТелеграм.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Чат.Установить(Выборка.Чат);
			НаборЗаписей.Отбор.ВидЗапросаТелеграм.Установить(Выборка.ВидЗапросаТелеграм);
			НаборЗаписей.Отбор.СообщениеИД.Установить(Выборка.СообщениеИД);
			
			НоваяЗапись              		= НаборЗаписей.Добавить();
			НоваяЗапись.Чат				 	= Выборка.Чат;
			НоваяЗапись.ВидЗапросаТелеграм 	= Выборка.ВидЗапросаТелеграм;
			НоваяЗапись.СообщениеИД 		= Выборка.СообщениеИД;
			НоваяЗапись.Сообщение 		 	= Выборка.Сообщение;
			НоваяЗапись.Состояние 		 	= Перечисления.бит_ВидыСостоянийТелеграм.Отправлено;
			НоваяЗапись.ДатаОтправки 		= ТекущаяДатаСеанса();
			НаборЗаписей.Записать();
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ВызватьИсключение ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки;
		
	КонецЦикла; 
	
КонецПроцедуры

Процедура ОбслужитьСообщенияЧатов()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	БотыTelegram.Ссылка КАК Бот
	|ИЗ
	|	Справочник.бит_БотыTelegram КАК БотыTelegram
	|ГДЕ
	|	БотыTelegram.ОбслуживатьЧаты
	|	И НЕ БотыTelegram.ПометкаУдаления";
	ВыборкаБотов = Запрос.Выполнить().Выбрать();
	Пока ВыборкаБотов.Следующий() Цикл
		СообщенияБота(ВыборкаБотов.Бот);
	КонецЦикла;
	
КонецПроцедуры

Процедура СообщенияБота(БотТелеграм)
	
	ОтборОбновлений = Новый Структура("Бот", БотТелеграм);
	СтруктураЗаписи = РегистрыСведений.бит_НомераОбновленийTelegram.Получить(ОтборОбновлений);
	НачальнаяВерсияОбновленияТелеграм = СтруктураЗаписи.НомерОбновления;
	
	ВерсияОбновленияТелеграм = НачальнаяВерсияОбновленияТелеграм;
	Ответ = ПолучитьСообщенияБота(ВерсияОбновленияТелеграм, БотТелеграм.Токен);
	
	ЧтениеДжейсон = Новый ЧтениеJSON();
	ЧтениеДжейсон.УстановитьСтроку(Ответ);
	
	стрОтвета = ПрочитатьJSON(ЧтениеДжейсон);
	Если стрОтвета.Свойство("ok")
		И стрОтвета.ok Тогда
		
		Для Каждого стрСообщенияТелеграм Из стрОтвета.result Цикл
			
			Если ВерсияОбновленияТелеграм = стрСообщенияТелеграм.update_id Тогда
				Продолжить;
			КонецЕсли;
			
			ПараметрыИсходящихСообщений = НовоеСообщениеБоту(стрСообщенияТелеграм, БотТелеграм);
			ОтправитьПакетСообщенийБоту(ПараметрыИсходящихСообщений, стрСообщенияТелеграм);
			
			ВерсияОбновленияТелеграм = стрСообщенияТелеграм.update_id;
			
		КонецЦикла;
	КонецЕсли;
	
	Если НачальнаяВерсияОбновленияТелеграм <> ВерсияОбновленияТелеграм Тогда
		
		НомераОбновлений = РегистрыСведений.бит_НомераОбновленийTelegram.СоздатьМенеджерЗаписи();
		НомераОбновлений.Бот             = БотТелеграм;
		НомераОбновлений.НомерОбновления = ВерсияОбновленияТелеграм;
		НомераОбновлений.Записать();
	
	КонецЕсли; 
	
КонецПроцедуры

Процедура ОтправитьСообщениеБоту(ТокенБота, ЧатИД, Текст, ПараметрыОтправки = Неопределено)
	
	СоединениеТелеграм = НовоеHTTPСоединение();
	
	ЗапросТелеграм = Новый HTTPЗапрос("/bot"+ТокенБота+"/sendMessage?chat_id="+Формат(ЧатИД, "ЧГ=0")+"&text="+Текст);
	РезультатЗапроса = СоединениеТелеграм.ОтправитьДляОбработки(ЗапросТелеграм);
	
КонецПроцедуры

Процедура ОтправитьПакетСообщенийБоту(ПараметрыИсходящихСообщений, стрСообщенияТелеграм = Неопределено)
	
	МассивСообщений = ПараметрыИсходящихСообщений.МассивСообщений;
	Если МассивСообщений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ШаблонЗапроса = "/bot%1/%2?chat_id=%3%4%5";
	СоединениеТелеграм = НовоеHTTPСоединение();
	Для каждого Сообщение Из МассивСообщений Цикл
		ИДРедактируемогоСообщения = Сообщение.ИДРедактируемогоСообщения;
		
		Сообщение.Текст = ИсключитьСлужебныеСимволы(Сообщение.Текст);
		
		Если Сообщение.УдалениеСообщения Тогда
			КомандаЗапроса  = "deleteMessage";
			СтрокаРедактора = "&message_id=" + Формат(ИДРедактируемогоСообщения, "ЧГ=0");
			ТестСообщения   = "";
		ИначеЕсли ЗначениеЗаполнено(ИДРедактируемогоСообщения) Тогда
			КомандаЗапроса  = "editMessageText";
			СтрокаРедактора = "&message_id=" + Формат(ИДРедактируемогоСообщения, "ЧГ=0");
			ТестСообщения   = "&text=" + Сообщение.Текст + ?(Сообщение.Гипертекст, "&parse_mode=html","")
								+ Сообщение.КомандныйТекст;
		ИначеЕсли Сообщение.ОтправкаФайла Тогда
			КомандаЗапроса  = "sendDocument";
			СтрокаРедактора = "";
		Иначе
			КомандаЗапроса  = "sendMessage";
			СтрокаРедактора = "";
			ТестСообщения   = "&text=" + Сообщение.Текст + ?(Сообщение.Гипертекст, "&parse_mode=html","")
								+ Сообщение.КомандныйТекст;
		КонецЕсли;
		ИДЧата = Сообщение.ИДЧата;
		Чат    = Сообщение.Чат;
		Если НЕ ЗначениеЗаполнено(ИДЧата) Тогда
			ИДЧата = ПараметрыИсходящихСообщений.ИДЧата;
			Чат    = ПараметрыИсходящихСообщений.Чат;
		КонецЕсли;
		ИДЧата = Формат(ИДЧата, "ЧГ=0");
		
		ТекстЗапроса = СтрШаблон(ШаблонЗапроса, ПараметрыИсходящихСообщений.Bot,
								КомандаЗапроса, ИДЧата, СтрокаРедактора, ТестСообщения);
								
		Если Сообщение.ОтправкаФайла Тогда
			
			ПараметрыФайла = Сообщение.ПараметрыФайла;
			
			ДанныеФайла = ПолучитьИзВременногоХранилища(ПараметрыФайла.СсылкаНаДвоичныеДанныеФайла);
			
			Разделитель = Строка(Новый УникальныйИдентификатор());
			
			// Формируем основное составное сообщение
			Поток        = Новый ПотокВПамяти();
			ЗаписьДанных = Новый ЗаписьДанных(Поток, КодировкаТекста.UTF8, ПорядокБайтов.LittleEndian, Символы.ВК + Символы.ПС, Символы.ПС, Истина);
			
			// chat_id
			ЗаписьДанных.ЗаписатьСтроку("--" + Разделитель);
			ЗаписьДанных.ЗаписатьСтроку("Content-Disposition: form-data; name=""chat_id""");
			ЗаписьДанных.ЗаписатьСтроку("");
			ЗаписьДанных.ЗаписатьСтроку(ИДЧата);
			
			// disable_notification
			ЗаписьДанных.ЗаписатьСтроку("--" + Разделитель);
			ЗаписьДанных.ЗаписатьСтроку("Content-Disposition: form-data; name=""disable_notification""");
			ЗаписьДанных.ЗаписатьСтроку("");
			ЗаписьДанных.ЗаписатьСтроку("True");
			
			Если Не ПустаяСтрока(Сообщение.Текст) Тогда 
				// caption
				ЗаписьДанных.ЗаписатьСтроку("--" + Разделитель);
				ЗаписьДанных.ЗаписатьСтроку("Content-Disposition: form-data; name=""caption""");
				ЗаписьДанных.ЗаписатьСтроку("");
				ЗаписьДанных.ЗаписатьСтроку(Сообщение.Текст);        
				
				// parse_mode
				ЗаписьДанных.ЗаписатьСтроку("--" + Разделитель);
				ЗаписьДанных.ЗаписатьСтроку("Content-Disposition: form-data; name=""parse_mode""");
				ЗаписьДанных.ЗаписатьСтроку("");
				ЗаписьДанных.ЗаписатьСтроку("HTML");
			КонецЕсли;
			
			// document    
			ЗаписьДанных.ЗаписатьСтроку("--" + Разделитель);
			ЗаписьДанных.ЗаписатьСтроку(СтрШаблон("Content-Disposition: form-data; name=""document""; filename=""%1""",
													ПараметрыФайла.ИмяФайла));
			ЗаписьДанных.ЗаписатьСтроку("");   
			ЗаписьДанных.Закрыть();    
			
			// Добавим файл
			ЗаписьДанных.Записать(ДанныеФайла);
			
			// Завершение записи
			ЗаписьДанных = Новый ЗаписьДанных(Поток, КодировкаТекста.UTF8, ПорядокБайтов.LittleEndian, Символы.ВК + Символы.ПС, Символы.ПС, Ложь);
			ЗаписьДанных.ЗаписатьСтроку("");
			ЗаписьДанных.ЗаписатьСтроку("--" + Разделитель + "--");
			ЗаписьДанных.Закрыть();
			
			ДанныеТела   = Поток.ЗакрытьИПолучитьДвоичныеДанные();   
			
			Заголовки   = Новый Соответствие;
			Заголовки.Вставить("Content-Type",      "multipart/form-data; boundary=" + Разделитель);
			Заголовки.Вставить("Accept",            "*/*");
			Заголовки.Вставить("Cache-Control",     "no-cache");
			Заголовки.Вставить("Host",              "api.telegram.org");
			Заголовки.Вставить("Accept-Encoding",   "gzip, deflate");
			Заголовки.Вставить("Content-Length",    Формат(ДанныеТела.Размер(), "ЧДЦ=0; ЧН=0; ЧГ=0"));
			Заголовки.Вставить("Connection",        "close");
			
			ЗапросТелеграм = Новый HTTPЗапрос(ТекстЗапроса, Заголовки);
			ЗапросТелеграм.УстановитьТелоИзДвоичныхДанных(ДанныеТела);
		Иначе
			ЗапросТелеграм = Новый HTTPЗапрос(ТекстЗапроса);
		КонецЕсли;
		РезультатЗапроса = СоединениеТелеграм.ОтправитьДляОбработки(ЗапросТелеграм);
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.ОткрытьПоток(РезультатЗапроса.ПолучитьТелоКакПоток());
		ОбъектXDTO = ФабрикаXDTO.ПрочитатьJSON(ЧтениеJSON);
		
		Если Сообщение.УдалениеСообщения Тогда
			Продолжить;
		КонецЕсли;
		
		Если ОбъектXDTO.ok = Истина Тогда
			СообщениеИД = ОбъектXDTO.result.message_id;
			
			ПараметрыКлюча = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.НовыеПараметрыКлюча();
			ПараметрыКлюча.Чат         = Чат;
			ПараметрыКлюча.СообщениеИД = СообщениеИД;
			РегистрыСведений.бит_ПараметрыСообщенийТелеграм.СохранитьПараметрыСообщения(ПараметрыКлюча, Сообщение.Параметры);
			
			Если стрСообщенияТелеграм <> Неопределено Тогда
				стрСообщенияТелеграм.Вставить("ОтветноеСообщениеИД", СообщениеИД);
			КонецЕсли;
		КонецЕсли;
		
		Если стрСообщенияТелеграм <> Неопределено Тогда
			стрСообщенияТелеграм.Вставить("ОтветноеСообщение", Сообщение.Текст);
			НоваяЗаписьВРеестрОбмена(стрСообщенияТелеграм);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ИсключитьСлужебныеСимволы(ИсходныйТекст)
	
	Если ПустаяСтрока(ИсходныйТекст) Тогда
		Возврат ИсходныйТекст;
	КонецЕсли;
	
	Текст = ИсходныйТекст;
	
	ПрефиксРазметки = "##";
	
	СлужебныеРазметки = Новый Массив;
	СлужебныеРазметки.Добавить("reply_markup");
	СлужебныеРазметки.Добавить("parse_mode");
	
	Для каждого Разметка Из СлужебныеРазметки Цикл
		Текст = СтрЗаменить(Текст, "&" + Разметка, ПрефиксРазметки + Разметка);
	КонецЦикла;
	
	Текст = СтрЗаменить(Текст, "&", "");
	
	Для каждого Разметка Из СлужебныеРазметки Цикл
		Текст = СтрЗаменить(Текст, ПрефиксРазметки + Разметка, "&" + Разметка);
	КонецЦикла;
	
	Возврат Текст;
	
КонецФункции

Процедура ОтправитьОповещениеБоту(ТокенБота, ЧатИД, Текст)
	
	СоединениеТелеграм = НовоеHTTPСоединение();
	
	ЗапросТелеграм = Новый HTTPЗапрос("/bot"+ТокенБота+"/sendChatAction?chat_id="+Формат(ЧатИД, "ЧГ=0")+"&action="+Текст);
	РезультатЗапроса = СоединениеТелеграм.ОтправитьДляОбработки(ЗапросТелеграм);
	
КонецПроцедуры

Функция ПолучитьСообщенияБота(ВерсияОбновленияТелеграм, ТокенБота)
	
	Попытка
		
		СоединениеТелеграм = НовоеHTTPСоединение();
		
		ЗапросТелеграм = Новый HTTPЗапрос("/bot"+ТокенБота+"/getUpdates"+?(Формат(ВерсияОбновленияТелеграм, "ЧГ=0") ="", "", "?offset="+Формат(ВерсияОбновленияТелеграм, "ЧГ=0")));
		
		РезультатЗапроса = СоединениеТелеграм.ОтправитьДляОбработки(ЗапросТелеграм);
		
		Ответ = РезультатЗапроса.ПолучитьТелоКакСтроку();
		
	Исключение
		Ответ = "{""ok"":false}";
	КонецПопытки;
	
	Возврат Ответ;
	
КонецФункции

Процедура НовыйСправочникЧатТелеграм(ЧатИД, НаименованиеЧата, БотТелеграм)

	СпрОб = Справочники.бит_ЧатыTelegram.СоздатьЭлемент();
	СпрОб.Наименование 	= НаименованиеЧата;
	СпрОб.ИД 			= ЧатИД;
	СпрОб.ОсновнойБот 	= БотТелеграм;
	СпрОб.СтатусРегистрации = Перечисления.бит_СтатусРегистрацииТелеграм.ОжидаетРегистрации;
	СпрОб.ДополнительныеСвойства.Вставить("Автоматически", Истина);
	СпрОб.Записать();

КонецПроцедуры

Функция СформироватьИмяПользователяЧата(ДанныеПользователя)
	
	ИмяПользователя = "";
	Если ДанныеПользователя.Свойство("last_name") Тогда
		ИмяПользователя = ДанныеПользователя.last_name;
	КонецЕсли;
	Если ДанныеПользователя.Свойство("first_name") Тогда
		ИмяПользователя = ИмяПользователя + " " + ДанныеПользователя.first_name;
	КонецЕсли;
	Если ДанныеПользователя.Свойство("username") Тогда
		ИмяПользователя = ИмяПользователя + "(" + ДанныеПользователя.username + ")";
	КонецЕсли;
	
	Возврат СокрЛП(ИмяПользователя);
	
КонецФункции

#Область ФормированиеСообщенияБоту

Функция НовыеПараметрыИсходящегоСообщения()
	
	ПараметрыСообщения = Новый Структура;
	ПараметрыСообщения.Вставить("Текст",                       "");
	ПараметрыСообщения.Вставить("КомандныйТекст",              "");
	ПараметрыСообщения.Вставить("Гипертекст",                  Ложь);
	ПараметрыСообщения.Вставить("ИДРедактируемогоСообщения",   0);
	ПараметрыСообщения.Вставить("УдалениеСообщения",           Ложь);
	ПараметрыСообщения.Вставить("Параметры",                   Новый Структура);
	ПараметрыСообщения.Вставить("ОтправкаФайла",               Ложь);
	ПараметрыСообщения.Вставить("ПараметрыФайла",              Новый Структура);
	// Чат и ИДЧата заполняются, если необходимо переопределить назначение чата общего пакета.
	ПараметрыСообщения.Вставить("Чат",                         Справочники.бит_ЧатыTelegram.ПустаяСсылка());
	ПараметрыСообщения.Вставить("ИДЧата",                      0);
	
	Возврат ПараметрыСообщения;
	
КонецФункции

Функция НовоеСообщениеБоту(стрСообщенияТелеграм, БотТелеграм)
	
	ПараметрыИсходящихСообщений = НовыеПараметрыПакетаИсходящихСообщений();
	ПараметрыИсходящихСообщений.Bot = БотТелеграм.Токен;
	
	ТекстОтвета = "";
	
	Если стрСообщенияТелеграм.Свойство("callback_query") Тогда
	
		ЧатИД 				= стрСообщенияТелеграм.callback_query.message.chat.id;
		СообщениеИД 		= стрСообщенияТелеграм.callback_query.message.message_id;
		Сообщение 			= стрСообщенияТелеграм.callback_query.data;
		ДатаОтправки 		= Дата(1970,1,1) + СтрЗаменить(Строка(стрСообщенияТелеграм.callback_query.message.date), " ", "");
		ТипЧата 			= стрСообщенияТелеграм.callback_query.message.chat.type;
		ИмяПользователяЧата = СформироватьИмяПользователяЧата(стрСообщенияТелеграм.callback_query.from); 
		
		// это параметр
		Если СтрРазделить(Сообщение, "/", Ложь).Количество()>1 Тогда
			
			ТекстОтвета = НажатиеНаКнопкуПериода(стрСообщенияТелеграм.callback_query.message.text, СтрРазделить(Сообщение, "/", Ложь), ЧатИД);
			
		КонецЕсли;
		
	ИначеЕсли стрСообщенияТелеграм.Свойство("message") Тогда 	
		
		Если НЕ стрСообщенияТелеграм.message.Свойство("contact") Тогда
		
			ЧатИД 				= стрСообщенияТелеграм.message.chat.id;
			СообщениеИД 		= стрСообщенияТелеграм.message.message_id;
			Сообщение 			= ?(стрСообщенияТелеграм.message.Свойство("text"), стрСообщенияТелеграм.message.text, "");
			ДатаОтправки 		= Дата(1970,1,1) + СтрЗаменить(Строка(стрСообщенияТелеграм.message.date), " ", "");
			ТипЧата 			= стрСообщенияТелеграм.message.chat.type;
			ИмяПользователяЧата = СформироватьИмяПользователяЧата(стрСообщенияТелеграм.message.from); 
			
		Иначе
			ТекстСообщения = НСтр("ru='Ваши контакты отправлены администратору.&reply_markup={""hide_keyboard"":true}';
								  |en='Your contacts are sent to the administrator.&reply_markup={""hide_keyboard"":true}'");
			ОтправитьСообщениеБоту(БотТелеграм.Токен, стрСообщенияТелеграм.message.contact.user_id, ТекстСообщения);
			ОтправитьКонтактПоСлужебнымЧатам(БотТелеграм,стрСообщенияТелеграм.message.contact.phone_number,СформироватьИмяПользователяЧата(стрСообщенияТелеграм.message.contact));
			Возврат ПараметрыИсходящихСообщений;
		КонецЕсли; 
	Иначе	
		Возврат ПараметрыИсходящихСообщений;
	КонецЕсли; 
	
	стрСообщенияТелеграм.Вставить("Состояние"			, Перечисления.бит_ВидыСостоянийТелеграм.Получено);
	стрСообщенияТелеграм.Вставить("ВидЗапросаТелеграм"	, Перечисления.бит_ВидыЗапросовТелеграм.ПустаяСсылка());
	стрСообщенияТелеграм.Вставить("ЧатИД"				, ЧатИД);
	стрСообщенияТелеграм.Вставить("СообщениеИД"			, СообщениеИД);
	стрСообщенияТелеграм.Вставить("Сообщение"			, Сообщение);
	стрСообщенияТелеграм.Вставить("ДатаОтправки"		, МестноеВремя(ДатаОтправки,ЧасовойПоясСеанса()));
	стрСообщенияТелеграм.Вставить("БотТелеграм"         , БотТелеграм);
	
	ПараметрыИсходящихСообщений.ИДЧата = ЧатИД;
	
	ПеречислениеРегистрация = Перечисления.бит_ВидыЗапросовТелеграм.РегистрацияЧата;
	
	Если НЕ ПустаяСтрока(стрСообщенияТелеграм.Сообщение) Тогда
		ЭтоТекст = Истина;
		СообщениеОтБота = стрСообщенияТелеграм.Сообщение;
	Иначе
		ЭтоТекст = Ложь;
		СообщениеОтБота = "";
	КонецЕсли;
	
	Если НЕ ТекстОтвета = "" Тогда
		
		стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
		
		ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
		ПараметрыСообщения.Текст  = ТекстОтвета; 
		ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
		Возврат ПараметрыИсходящихСообщений;
		
	КонецЕсли; 
	
	ДанныеЧата = Справочники.бит_ЧатыTelegram.ДанныеЧатаПоИдентификатору(стрСообщенияТелеграм.ЧатИД, БотТелеграм);
	
	Если НЕ ЗначениеЗаполнено(ДанныеЧата.Чат) Тогда
		Если ТипЧата = "private" Тогда
			стрСообщенияТелеграм.ВидЗапросаТелеграм = ПеречислениеРегистрация;
			ТекстОтвета = РегистрацияЧата(СообщениеОтБота, БотТелеграм, стрСообщенияТелеграм,ИмяПользователяЧата);
			
			Если НЕ ПустаяСтрока(ТекстОтвета) Тогда
				ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
				ПараметрыСообщения.Текст = ТекстОтвета; 
				ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
			КонецЕсли;
		КонецЕсли;
		
		Возврат ПараметрыИсходящихСообщений;
	КонецЕсли;
	
	ПараметрыИсходящихСообщений.Чат = ДанныеЧата.Чат;
	
	Если ДанныеЧата.СтатусРегистрации = Перечисления.бит_СтатусРегистрацииТелеграм.ОжидаетРегистрации Тогда
		
		стрСообщенияТелеграм.ВидЗапросаТелеграм = ПеречислениеРегистрация;
		ТекстОтвета = НСтр("ru='Регистрация чата находится на рассмотрении.';en='chat Registration is pending.'");
		
		ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
		ПараметрыСообщения.Текст = ТекстОтвета; 
		ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
		
	ИначеЕсли ДанныеЧата.СтатусРегистрации = Перечисления.бит_СтатусРегистрацииТелеграм.Запрещено Тогда
		
		стрСообщенияТелеграм.ВидЗапросаТелеграм = ПеречислениеРегистрация;
		ТекстОтвета = НСтр("ru='Чат заблокирован.';en='Chat is disabled.'");
		
		ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
		ПараметрыСообщения.Текст = ТекстОтвета; 
		ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
		
	Иначе
		Если СтрСравнить(СообщениеОтБота, "/help") = 0 Тогда
			
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПомощьЧату;
			ТекстОтвета = НСтр("ru='Ваша просьба отправлена. Хотите отправить администратору свои контакты?&reply_markup={""keyboard"":[[{""text"":""Отправить контакты"",""request_contact"":true}]],""resize_keyboard"":true,""one_time_keyboard"":true}';
		      				   |en='Your request has been sent. Want to send your contacts to the administrator?&reply_markup={""keyboard"":[[{""text"":""Send contacts"",""request_contact"":true}]],""resize_keyboard"":true,""one_time_keyboard"":true}'");
			
			ОповеститьСлужебныеЧаты(БотТелеграм,стрСообщенияТелеграм,ИмяПользователяЧата,,Истина);
			
			ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
			ПараметрыСообщения.Текст = ТекстОтвета; 
			ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
			
		ИначеЕсли СтрСравнить(СообщениеОтБота, "/more") = 0 Тогда
			
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			ТекстОтвета = НовыйСписокСоВсемиКомандами(ДоступныеКомандыЧату(ДанныеЧата.Чат));
			
			Если НЕ ПустаяСтрока(ТекстОтвета) Тогда
				ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
				ПараметрыСообщения.Текст = ТекстОтвета; 
				ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
			КонецЕсли;
			
		ИначеЕсли СтрСравнить(СообщениеОтБота, "/hideKeyboard") = 0 Тогда
			
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			ТекстОтвета = НСтр("ru='Скрыть клавиатуру.&reply_markup={""hide_keyboard"":true}';
							   |en='Hide Keyboard.&reply_markup={""hide_keyboard"":true}'");
			
			ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
			ПараметрыСообщения.Текст = ТекстОтвета; 
			ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
			
		ИначеЕсли СтрНачинаетсяС(СообщениеОтБота, "/ApprovList") Тогда
			
			// Список виз на согласовании пользователя.
			ОтправитьОповещениеБоту(БотТелеграм.Токен, стрСообщенияТелеграм.ЧатИД, "upload_document");
			
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			ПараметрыСообщения = СписокВизНаСогласование(ДанныеЧата.Чат, СообщениеОтБота, стрСообщенияТелеграм);
			ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
			
		ИначеЕсли СтрНачинаетсяС(СообщениеОтБота, "/ApprovObject") Тогда
			
			// Открыть визу на согласовании.
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			МассивСообщенийОтвета = ВизированиеОбъекта(ДанныеЧата.Чат, СообщениеОтБота, стрСообщенияТелеграм);
			
			Для каждого СообщениеОтвета Из МассивСообщенийОтвета Цикл
				ПараметрыИсходящихСообщений.МассивСообщений.Добавить(СообщениеОтвета);
			КонецЦикла;
			
		ИначеЕсли СтрНачинаетсяС(СообщениеОтБота, "/ApprovAction") Тогда
			
			// Принятие решения по визе.
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			МассивСообщенийОтвета = ПринятиеРешенияПоВизе(ДанныеЧата.Чат, СообщениеОтБота, стрСообщенияТелеграм);
			
			Для каждого СообщениеОтвета Из МассивСообщенийОтвета Цикл
				ПараметрыИсходящихСообщений.МассивСообщений.Добавить(СообщениеОтвета);
			КонецЦикла;
			
		ИначеЕсли СтрНачинаетсяС(СообщениеОтБота, "/AddApprovComment") Тогда
			
			// Запрос ввести комментарий.
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			ОтправитьЗапросВвестиКомментарийВизирования(ПараметрыИсходящихСообщений, стрСообщенияТелеграм);
			                                        
		ИначеЕсли СтрНачинаетсяС(СообщениеОтБота, "/ApprovAttachment") Тогда
			
			// Запрос ввести комментарий.
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			ПоказатьВложенияОбъектаВизирования(ПараметрыИсходящихСообщений, стрСообщенияТелеграм);
			
		ИначеЕсли СтрНачинаетсяС(СообщениеОтБота, "/SendAttachment") Тогда
			
			// Запрос ввести комментарий.
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			ОтправитьВложение(ПараметрыИсходящихСообщений, стрСообщенияТелеграм, СообщениеОтБота);
			
		ИначеЕсли СтрНачинаетсяС(СообщениеОтБота, "/ApprovFilter") Тогда
			
			// Установка отбора для списка виз.
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			УправлениеОтборомСпискаВиз(ПараметрыИсходящихСообщений, стрСообщенияТелеграм);
			
		ИначеЕсли СтрНачинаетсяС(СообщениеОтБота, "/SetFilter") Тогда
			
			// Выбор значения отбора.
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			УстановитьЗначениеФильтраВиз(ПараметрыИсходящихСообщений, стрСообщенияТелеграм);
			
		ИначеЕсли СтрНачинаетсяС(СообщениеОтБота, "/ApprovNotify") Тогда
			
			// Настройка оповещений при получении новых виз.
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			УправлениеОповещениямиНовыхВиз(ПараметрыИсходящихСообщений, стрСообщенияТелеграм);
			
		ИначеЕсли НЕ ЭтоТекст Тогда
			
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			ТекстОтвета = НСтр("ru='Для ввода команды используется текст.';en='To enter a command using the text.'");
			
			ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
			ПараметрыСообщения.Текст = ТекстОтвета; 
			ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
			
		// произвольный период с командой
		ИначеЕсли СтрРазделить(СокрЛП(СообщениеОтБота), "/", Ложь).Количество() > 1 Тогда 
			
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			РазделительныйМассив = СтрРазделить(СокрЛП(СообщениеОтБота), "/", Ложь);
			ТекстОтвета = КомандаСПроизвольнымПериодом(РазделительныйМассив, РазделительныйМассив.Количество(), ДанныеЧата.Чат);
			
			Если НЕ ПустаяСтрока(ТекстОтвета) Тогда
				ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
				ПараметрыСообщения.Текст = ТекстОтвета; 
				ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
			КонецЕсли;
			
		Иначе
			стрСообщенияТелеграм.ВидЗапросаТелеграм = Перечисления.бит_ВидыЗапросовТелеграм.ПроизвольнаяКоманда;
			
			ПараметрыКлюча             = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.НовыеПараметрыКлюча();
			ПараметрыКлюча.Чат         = ДанныеЧата.Чат;
			ПараметрыКлюча.СообщениеИД = стрСообщенияТелеграм.СообщениеИД - 1;
			ПараметрыПредыдущегоСообщения = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.ПараметрыСообщения(ПараметрыКлюча);
			
			Команда = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыПредыдущегоСообщения, "Команда", "");
			
			Если Команда = "/AddApprovComment" Тогда
				ВвестиКомментарийВизирования(ПараметрыИсходящихСообщений, стрСообщенияТелеграм, ПараметрыПредыдущегоСообщения);
			Иначе
				ТекстОтвета = ВыполнитьКомандуТелеграм(СообщениеОтБота, ДанныеЧата.Чат, Новый Массив, ПараметрыИсходящихСообщений);
				
				Если НЕ ПустаяСтрока(ТекстОтвета) Тогда
					ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
					ПараметрыСообщения.Текст = ТекстОтвета; 
					ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
			
		Если ПараметрыИсходящихСообщений.МассивСообщений.Количество() = 0 Тогда
			ДобавитьПанельДоступныхКоманд(ПараметрыИсходящихСообщений);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПараметрыИсходящихСообщений;
	
КонецФункции

Функция НовыеПараметрыПакетаИсходящихСообщений()
	
	ПараметрыИсходящихСообщений = Новый Структура;
	ПараметрыИсходящихСообщений.Вставить("МассивСообщений", Новый Массив);
	ПараметрыИсходящихСообщений.Вставить("Bot",             Неопределено);
	ПараметрыИсходящихСообщений.Вставить("Чат",             Справочники.бит_ЧатыTelegram.ПустаяСсылка());
	ПараметрыИсходящихСообщений.Вставить("ИДЧата",          0);
	
	Возврат ПараметрыИсходящихСообщений;
	
КонецФункции

Процедура ДобавитьПанельДоступныхКоманд(ПараметрыИсходящихСообщений)
	
	ТекстОтвета = "%1 <b>%2</b>";
	ТекстОтвета = СтрШаблон(ТекстОтвета,
							КодEmoji("speech_balloon"),
							НСтр("ru='Доступные команды:';en='Available commands:'"));
	ТаблицаКоманд = ДоступныеКомандыЧату(ПараметрыИсходящихСообщений.Чат);
	ТекстОтвета   = ТекстОтвета + НовыйТекстКлавиатурыСДоступнымиКомандами(ТаблицаКоманд, Истина);
	
	ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
	ПараметрыСообщения.Текст      = ТекстОтвета; 
	ПараметрыСообщения.Гипертекст = Истина;
	ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыСообщения);
	
КонецПроцедуры

Функция РегистрацияЧата(СообщениеОтБота, БотТелеграм, стрСообщенияТелеграм, ИмяПользователяЧата)

	ПараметрыБота = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(БотТелеграм, "НуженПинКод, ПинКод");
	Если СтрСравнить(СообщениеОтБота, "/start") = 0 Тогда
		Действие = "ЗапроситьРегистрацию";
	ИначеЕсли СтрСравнить(СообщениеОтБота, "/registration") = 0 Тогда
		Если ПараметрыБота.НуженПинКод Тогда
			Действие = "ЗапроситьПинКод";
		Иначе
			Действие = "СоздатьЧат";
		КонецЕсли;
	ИначеЕсли ПараметрыБота.НуженПинКод Тогда
		Если СообщениеОтБота = ПараметрыБота.ПинКод Тогда
			Действие = "СоздатьЧат";
		Иначе
			Действие = "ЗапроситьПинКод";
		КонецЕсли;
	Иначе
		Действие = "ЗапроситьРегистрацию";
	КонецЕсли;
	
	Если Действие = "ЗапроситьРегистрацию" Тогда
		ТекстОтвета = НСтр("ru='Пройдите регистрацию нажав /registration';en='Please register by clicking /registration'");
	ИначеЕсли Действие = "ЗапроситьПинКод" Тогда
		ТекстОтвета = НСтр("ru='Необходимо ввести пин код.';en='You must enter a PIN code.'");
	Иначе
		НовыйСправочникЧатТелеграм(стрСообщенияТелеграм.ЧатИД, ИмяПользователяЧата, БотТелеграм);
		ТекстОтвета = НСтр("ru='Регистрация на рассмотрении.';en='Registration under review.'");
		ОповеститьСлужебныеЧаты(БотТелеграм, стрСообщенияТелеграм, ИмяПользователяЧата, Истина);
	КонецЕсли;

	Возврат ТекстОтвета;
	
КонецФункции

Функция НажатиеНаКнопкуПериода(ТекстКомандыСПериодом, РазделительныйМассив, ЧатИД)

	стрЧата = НайтиЧат(ЧатИД);
	
	Если стрЧата = Неопределено Тогда
	
		ТекстОтвета = НСтр("ru='Не найден Чат.';en='Chat is not found.'");
		Возврат ТекстОтвета;
		
	КонецЕсли; 
	
	МассивПараметров = Новый Массив;
	
	ИмяКоманды = "/"+СтрРазделить(ТекстКомандыСПериодом, "/", Ложь)[1];
	Если РазделительныйМассив[1] = "Дата" Тогда
		
		Если ВариантСтандартнойДатыНачала[РазделительныйМассив[0]] = ВариантСтандартнойДатыНачала.ПроизвольнаяДата Тогда
			
			ТекстОтвета = НСтр("ru='Введите Период в формате ГГГГ.ММ.ДД и имя /команды. Например: ""';
							   |en='Enter a period in YYYY.MM.DD format and name /team. For example: ""'")
						  + Формат(ТекущаяДатаСеанса(), "ДФ=yyyy.MM.dd") + " " 
						  + ИмяКоманды + """";
			
		Иначе	
			Вариант = Новый СтандартнаяДатаНачала(ВариантСтандартнойДатыНачала[РазделительныйМассив[0]]);
			СтруктураПараметра = Новый Структура("Период", Вариант.Дата); 
			МассивПараметров.Добавить(СтруктураПараметра);
			
			ТекстОтвета = ВыполнитьКомандуТелеграм(ИмяКоманды, стрЧата.Чат, МассивПараметров);
			
		КонецЕсли; 
	Иначе	
		Если ВариантСтандартногоПериода[РазделительныйМассив[0]] = ВариантСтандартногоПериода.ПроизвольныйПериод Тогда
			
			ТекстОтвета = НСтр("ru='Введите НачалоПериода и КонецПериода в формате ГГГГ.ММ.ДД и имя /команды. Например: ""';
							   |en='Enter NachaloPerioda and KonetsPerioda in YYYY.MM.DD format and name /team. For example: ""'")
						  + Формат(НачалоМесяца(ТекущаяДатаСеанса()), "ДФ=yyyy.MM.dd") + ":" 
						  + Формат(КонецМесяца(ТекущаяДатаСеанса()), "ДФ=yyyy.MM.dd") + " " 
						  + ИмяКоманды + """";
			
		Иначе	
			Вариант = Новый СтандартныйПериод(ВариантСтандартногоПериода[РазделительныйМассив[0]]);
			СтруктураПараметра = Новый Структура; 
			СтруктураПараметра.Вставить("НачалоПериода"	, Вариант.ДатаНачала); 
			СтруктураПараметра.Вставить("КонецПериода"	, Вариант.ДатаОкончания); 
			МассивПараметров.Добавить(СтруктураПараметра);
			
			ТекстОтвета = ВыполнитьКомандуТелеграм(ИмяКоманды, стрЧата.Чат, МассивПараметров);
			
		КонецЕсли; 
	КонецЕсли; 
	
	Возврат ТекстОтвета;

КонецФункции

Функция КомандаСПроизвольнымПериодом(РазделительныйМассив, КоличествоЭлементов, Чат)

	МассивПараметров = Новый Массив;
	
	Попытка
		
		МассивДат = СтрРазделить(СокрЛП(РазделительныйМассив[0]), ":", Ложь);
		
		Если МассивДат.Количество() = 2 Тогда
		
			НачалоПериода 	= Дата(СтрЗаменить(МассивДат[0],".",""));
			КонецПериода 	= Дата(СтрЗаменить(МассивДат[1],".",""));
			
			СтруктураПараметра = Новый Структура;
			СтруктураПараметра.Вставить("НачалоПериода"	, НачалоПериода); 
			СтруктураПараметра.Вставить("КонецПериода"	, КонецПериода);
			
		Иначе
			
			Период = Дата(СтрЗаменить(МассивДат[0],".",""));
			
			СтруктураПараметра = Новый Структура("Период", Период); 
			
		КонецЕсли; 
		
		ИмяКоманды = "/"+РазделительныйМассив[1];
		
		МассивПараметров.Добавить(СтруктураПараметра);
		
	Исключение
		ТекстОтвета = НСтр("ru='Не удалось преобразовать дату, повторите попытку.';en='Failed to convert a date, try again.'");
		Возврат ТекстОтвета;
	КонецПопытки; 
	
	ТекстОтвета = ВыполнитьКомандуТелеграм(ИмяКоманды, Чат, МассивПараметров);
	
	Возврат ТекстОтвета;
	
КонецФункции

Функция НовыйСписокСоВсемиКомандами(ТаблицаКоманд)

	ТекстОтвета = "";
	
	Для каждого ком Из ТаблицаКоманд Цикл
	
		ТекстОтвета = ТекстОтвета + ком.Наименование + " " + ком.Определение + Символы.ПС;
	
	КонецЦикла; 
	
	ТекстОтвета = ТекстОтвета + "/help" + " " + НСтр("ru='Помощь';en='Help'")  + Символы.ПС;
	ТекстОтвета = ТекстОтвета + "/hideKeyboard" + " " + НСтр("ru='Скрыть нижнюю клавиатуру';en='Hide the lower keyboard'")  + Символы.ПС;
	
	Возврат ТекстОтвета;

КонецФункции

Функция СписокВизНаСогласование(Чат, КомандаСтрокой, СтруктураВходящегоСообщения)
	
	ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
	
	ТекстОтвета = "";
	
	Пользователь = Чат.Пользователь;
	НастройкиВизирования = НастройкиВизированияТелеграм(Пользователь);
	
	АдресВХранилище = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор); 
	МатрицаДоступа  = Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа(Пользователь);
	
	ПараметрыПолучения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
	ПараметрыПолучения.МатрицаДоступа		    = МатрицаДоступа;
	ПараметрыПолучения.ВыводитьВТаблицуЗначений = Истина;
	ПараметрыПолучения.ЭтоМобильноеПриложение   = Истина;
	ПараметрыПолучения.Ответственный            = Пользователь;
	ПараметрыПолучения.Отбор.ВнешниеОтборы      = НастройкиВизирования.Отбор;
	
	Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
	
	Результат         = ПолучитьИзВременногоХранилища(АдресВХранилище);
	ТаблицаДокументов = Результат.РезультатТаблицаЗначений;
	ИтогоВиз          = ТаблицаДокументов.Количество();
	
	НомерПорции = 1;
	РазделениеКоманды = СтрРазделить(КомандаСтрокой, ",");
	Если РазделениеКоманды.Количество() > 1 Тогда
		НомерПорции = Число(СтрРазделить(КомандаСтрокой, ",")[1]);
		ПараметрыСообщения.ИДРедактируемогоСообщения = СтруктураВходящегоСообщения.СообщениеИД;
	КонецЕсли;
	НачалоСписка    = (НомерПорции - 1) * 10 + 1;
	ОкончаниеСписка = Мин(НомерПорции * 10, ИтогоВиз);
	
	Если ИтогоВиз = 0 Тогда
	    ТелоСообщения = "<i>%1</i>";
		ТелоСообщения = СтрШаблон(ТелоСообщения, НСтр("ru='Список виз на согласование пуст.';en='Approv list is empty.'"));
	ИначеЕсли ИтогоВиз > 10 Тогда
		ТелоСообщения = "<i>%1 %2-%3 %4 %5:</i>";
		ТелоСообщения = СтрШаблон(ТелоСообщения, НСтр("ru='Список виз на согласование';en='Approv list'"),
							НачалоСписка, ОкончаниеСписка, НСтр("ru = 'из';en = 'from'"), ИтогоВиз);
	Иначе
		ТелоСообщения = "<i>%1:</i>";
		ТелоСообщения = СтрШаблон(ТелоСообщения, НСтр("ru='Список виз на согласование';en='Approv list'"));
	КонецЕсли;
	ТелоСообщения = ТелоСообщения + Символы.ПС;
	
	КонструкторКоманд = НовыйКонструкторПанелиКоманд();
	
	ШаблонСтрокиДокумента = "<b>%1.</b> <code>%2 %3 %4.</code>";
	
	ПорядковыйНомер = 0;
	Для каждого СтрокаДокумента Из ТаблицаДокументов Цикл
		
		ПорядковыйНомер = ПорядковыйНомер + 1;
		
		Если ПорядковыйНомер < НачалоСписка Тогда
			Продолжить;
		ИначеЕсли ПорядковыйНомер > ОкончаниеСписка Тогда
			Прервать;
		КонецЕсли;
		
		ПредставлениеОбъекта = СтрокаДокумента.ТипОбъектаВизирования;
		Если НЕ ПустаяСтрока(СтрокаДокумента.Номер) Тогда
			// Убираем незначимые нули.
			НомерОбъекта  = СтрокаДокумента.Номер;
			Префикс       = "";
			ИсключеныНули = Ложь;
			Пока Истина Цикл
				ПервыйСимвол = Лев(НомерОбъекта, 1);
				Если ПустаяСтрока(ПервыйСимвол)
					ИЛИ КодСимвола(ПервыйСимвол) >= КодСимвола("1")
						И КодСимвола(ПервыйСимвол) <= КодСимвола("9") Тогда
					Прервать;
				КонецЕсли;
				Если ПервыйСимвол = "0" ИЛИ ПервыйСимвол = "-" Тогда
					ИсключеныНули = Истина;
				Иначе
					Префикс = Префикс + ПервыйСимвол;
				КонецЕсли;
				НомерОбъекта = Сред(НомерОбъекта, 2);
			КонецЦикла;
			Если ИсключеныНули Тогда
				Префикс = Префикс + "...";
			КонецЕсли;
			ПредставлениеОбъекта = ПредставлениеОбъекта + " №" + Префикс + СокрЛП(НомерОбъекта);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаДокумента.Дата) Тогда
			ПредставлениеОбъекта = ПредставлениеОбъекта + " " + НСтр("ru='от';en='date'")
									+ " " + Формат(СтрокаДокумента.Дата, "ДЛФ=D");
		КонецЕсли;
		
		ТелоСообщения = ТелоСообщения + Символы.ПС;
		ТелоСообщения = ТелоСообщения + СтрШаблон(ШаблонСтрокиДокумента, ПорядковыйНомер, ПредставлениеОбъекта,
													НСтр("ru = 'на сумму';en = 'amount'"),
													СтрокаДокумента.СуммаДокумента);
													
		СхемаИдентификаторов = СхемаИдентификаторовОбъекта(СтрокаДокумента.ОбъектВизирования);
		ДобавитьКоманду(КонструкторКоманд.Команды,
							"/ApprovObject," + СхемаИдентификаторов.ИДТипа + "," + СхемаИдентификаторов.ИДОбъекта,
							Строка(ПорядковыйНомер));
		
	КонецЦикла;

	УстановленныеОтборы = НастройкиВизирования.Отбор;
	Если УстановленныеОтборы.Количество() > 0 Тогда
		ЗаголовокОтборы = "<i>%1: </i>";
		ЗаголовокОтборы = СтрШаблон(ЗаголовокОтборы, НСтр("ru = 'Установлены отборы по полям';
													 	|en = 'Got filter on fields'"));
		ТелоСообщения = ТелоСообщения + Символы.ПС + Символы.ПС + ЗаголовокОтборы;
		МассивПолейОтборов = Новый Массив;						
		Для каждого ЭлементОтбора Из УстановленныеОтборы Цикл
			МассивПолейОтборов.Добавить(ЭлементОтбора.Значение.Представление);
		КонецЦикла;
		ТелоСообщения = ТелоСообщения + СтрСоединить(МассивПолейОтборов, ", ") + ".";
	КонецЕсли;
	
	Если НомерПорции > 2 Тогда
		ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/ApprovList,1", "", КодEmoji("rewind"));
	КонецЕсли;
	
	Если НомерПорции > 1 Тогда
		ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/ApprovList," + (НомерПорции - 1),
							"", КодEmoji("arrow_backward"));
	КонецЕсли;
	
	ЗаголовокКоманды = НСтр("ru = 'к списку команд';en = 'to command list'");
	ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/Home", ЗаголовокКоманды, КодEmoji("speech_balloon"));
	
	Если ОкончаниеСписка < ИтогоВиз Тогда
		ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/ApprovList," + (НомерПорции + 1),
							"", КодEmoji("arrow_forward"));
	КонецЕсли;
	
	Если ОкончаниеСписка + 10 < ИтогоВиз Тогда
		ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/ApprovList," + (Цел((ИтогоВиз-1) / 10) + 1),
							"", КодEmoji("fast_forward"));
	КонецЕсли;
	
	ЗаголовокКоманды = НСтр("ru = 'Отбор';en = 'Filter'");
	ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/ApprovFilter", ЗаголовокКоманды, КодEmoji("ticket"));
	
	Если бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_ОповещенияВТелеграмОНовыхВизах") Тогда
		ЗаголовокКоманды = НСтр("ru = 'Оповещения';en = 'Notify'");
		ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/ApprovNotify", ЗаголовокКоманды, КодEmoji("bell"));
	КонецЕсли;
	
	ПараметрыСообщения.Текст          = ТелоСообщения;
	ПараметрыСообщения.КомандныйТекст = ТекстПанелиКоманд(КонструкторКоманд);
	ПараметрыСообщения.Гипертекст     = Истина;
	
	Возврат ПараметрыСообщения;
	
КонецФункции

// Функция раскладывает объект на идентификаторы: типа объекта и идентификатор ссылки.
//
// Параметры:
//	СсылкаНаОбъект - любая ссылка.
// Возвращаемое значение:
//	Структура.
Функция СхемаИдентификаторовОбъекта(СсылкаНаОбъект)
	
	МетаданныеОбъекта = СсылкаНаОбъект.Метаданные();
	ОбъектСистемы     = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(МетаданныеОбъекта.ПолноеИмя());
	
	Если Метаданные.Документы.Содержит(МетаданныеОбъекта) Тогда
		ПрефиксТипа = "D"; // Documents.
		Индекс = Метаданные.Документы.Индекс(МетаданныеОбъекта);
	ИначеЕсли Метаданные.Справочники.Содержит(МетаданныеОбъекта) Тогда
		ПрефиксТипа = "C"; // Catalogs.
		Индекс = Метаданные.Справочники.Индекс(МетаданныеОбъекта);
	КонецЕсли;
	
	ИдентификаторТипа = ПрефиксТипа + Формат(Индекс, "ЧГ=");
	
	СтруктураИдентификаторов = Новый Структура;
	СтруктураИдентификаторов.Вставить("ИДТипа", ИдентификаторТипа);
	СтруктураИдентификаторов.Вставить("ИДОбъекта", СсылкаНаОбъект.UUID());
	
	Возврат СтруктураИдентификаторов;
	
КонецФункции

Функция СсылкаНаОбъектПоИдентификаторам(ИДТипа, ИДОбъекта)
	
	УникальныйИдентификатор = Новый УникальныйИдентификатор(ИДОбъекта);
	ИндексТипа              = Число(Сред(ИДТипа, 2));
	
	КодТипа = Лев(ИДТипа, 1);
	Если КодТипа = "D" Тогда
		ИмяМетаданного = Метаданные.Документы[ИндексТипа].Имя;
		СсылкаНаОбъект = Документы[ИмяМетаданного].ПолучитьСсылку(УникальныйИдентификатор);
	ИначеЕсли КодТипа = "C" Тогда
		ИмяМетаданного = Метаданные.Справочники[ИндексТипа].Имя;
		СсылкаНаОбъект = Справочники[ИмяМетаданного].ПолучитьСсылку(УникальныйИдентификатор);
	Иначе
		СсылкаНаОбъект = Неопределено;
	КонецЕсли;
	
	Возврат СсылкаНаОбъект;
	
КонецФункции

Функция ВизированиеОбъекта(Чат, КомандаСтрокой, СтруктураВходящегоСообщения)
	
	МассивСообщений = Новый Массив;
	
	Пользователь = Чат.Пользователь;
	
	МассивПараметров = СтрРазделить(КомандаСтрокой, ",");
	Команда          = МассивПараметров[0];
	ИДТипа           = МассивПараметров[1];
	ИДОбъекта        = МассивПараметров[2];
	
	ОбъектВизирования = СсылкаНаОбъектПоИдентификаторам(ИДТипа, ИДОбъекта);
	
	// Заголовок объекта.
	ОтветЗаголовок = "%1 <b><a href=""%2"">%3</a></b>";
	ОтветЗаголовок = СтрШаблон(ОтветЗаголовок, КодEmoji("clipboard"),
								ПолучитьНавигационнуюСсылку(ОбъектВизирования),
								ОбъектВизирования);
	
	// Команды согласования.
	МетаданныеОбъекта = ОбъектВизирования.Метаданные();
	ОбъектСистемы     = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(МетаданныеОбъекта.ПолноеИмя());
	
	ПараметрыОпределенияСР = бит_ВизированиеСервер.НовыеПараметрыОпределенияСпискаРешений();
	ПараметрыОпределенияСР.ОбъектСистемы = ОбъектСистемы;
	ПараметрыОпределенияСР.ТекущийОбъект = ОбъектВизирования.ПолучитьОбъект();
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Организация", МетаданныеОбъекта) Тогда
		Организация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектВизирования, "Организация");
		ПараметрыОпределенияСР.Вставить("Организация", Организация);
	КонецЕсли;
	ДоступныеРешения = бит_ВизированиеСервер.ДоступныеРешения(ПараметрыОпределенияСР);
	
	КонструкторКоманд = НовыйКонструкторПанелиКоманд();
	Для каждого Решение Из ДоступныеРешения Цикл
		СхемаИдентификаторов = СхемаИдентификаторовОбъекта(Решение.Значение);
		ОбъектСтрокой        = СхемаИдентификаторов.ИДТипа + "," + СхемаИдентификаторов.ИДОбъекта;
		ДобавитьКоманду(КонструкторКоманд.Команды, "/ApprovAction," + ОбъектСтрокой, Решение.Представление);
	КонецЦикла;
	ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/AddApprovComment", НСтр("ru = 'Ввести комментарий';en = 'Add comment'"),
						КодEmoji("memo"));
	ИмяСправочникаХранения = РаботаСФайламиСлужебный.ИмяСправочникаХраненияФайлов(ОбъектВизирования);
	Если ЗначениеЗаполнено(ИмяСправочникаХранения) Тогда
		ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/ApprovAttachment", НСтр("ru = 'Вложения';en = 'Attachment'"),
						КодEmoji("paperclip"));
	КонецЕсли;
	ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/ApprovList", НСтр("ru = 'Все визы';en = 'All visa'"),
						КодEmoji("bookmark_tabs"));
							
							
	КонструкторКоманд.КоличествоКомандВСтроке = 2;
	ТелоКоманд = ТекстПанелиКоманд(КонструкторКоманд);
	
	
	// Получение данных об объекте визирования.
	АдресВХранилище = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор); 
	МатрицаДоступа  = Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа(Пользователь);
	
	ПараметрыПолучения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
	ПараметрыПолучения.МатрицаДоступа		            = МатрицаДоступа;
	ПараметрыПолучения.ВыводитьВТаблицуЗначений         = Истина;
	ПараметрыПолучения.Ответственный                    = Пользователь;
	ПараметрыПолучения.ВозвращатьПорядокИЗаголовкиПолей = Истина;
	ПараметрыПолучения.ВозвращатьТаблицуВиз             = Истина;
	ПараметрыПолучения.Отбор.ОбъектВизирования          = ОбъектВизирования;
	
	НастройкиПоУмолчанию = Обработки.бит_КонсольОперативногоВизирования.НастройкаПоУмолчанию(Пользователь);
	Если ЗначениеЗаполнено(НастройкиПоУмолчанию) Тогда
		НастройкиКомпоновщика = НастройкиПоУмолчанию.ХранилищеНастроек.Получить().НастройкиКомпоновщика;
		ПараметрыПолучения.НастройкиКомпоновщика         = НастройкиКомпоновщика;
		ПараметрыПолучения.ПолучатьНастройкиКомпоновщика = Истина;
	КонецЕсли;
	
	Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
	
	Результат = ПолучитьИзВременногоХранилища(АдресВХранилище);
	ТаблицаДокументов      = Результат.РезультатТаблицаЗначений;
	ПорядокИЗаголовкиПолей = Результат.ПорядокИЗаголовкиПолей;
	ТаблицаВизы            = Результат.ТаблицаВизы;
	ТаблицаВизы.Индексы.Добавить("ИД");
	
	ИДСтрокиВизирования = Неопределено;
	Виза                = Неопределено;
	ВизыНайдены         = Ложь;
	
	ШаблонОписанияПоля  = "<b>%1:</b> <code>%2</code>";
	ШаблонУточненияВизы = "
	|
	|%1 <b>%2</b>: %3.
	|%1 <b>%4:</b> <i>%5.</i>";
	ОписаниеЭУ = Обработки.бит_КонсольОперативногоВизирования.ИдентификаторЭлементаУправленияКартинки();
	КолонкиТаблицыДокументов = ТаблицаДокументов.Колонки;
	Для каждого СтрокаТаблицыВывода Из ТаблицаДокументов Цикл
		ЭлементУправления = СтрокаТаблицыВывода.ЭлементУправления; 
		Если НЕ ЗначениеЗаполнено(ЭлементУправления) Тогда
			Продолжить;
		КонецЕсли;
		Если СтрНайти(ЭлементУправления, ОписаниеЭУ) = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ОтветТелоСообщения  = "";
		ИДСтрокиВизирования = СтрЗаменить(ЭлементУправления, ОписаниеЭУ, "");
		
		Для каждого ПолеВывода Из ПорядокИЗаголовкиПолей Цикл
			ИмяПоляВывода = ПолеВывода.Имя ;
			Если КолонкиТаблицыДокументов.Найти(ИмяПоляВывода) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ЗначениеПоля = СтрокаТаблицыВывода[ИмяПоляВывода];
			Если ТипЗнч(ЗначениеПоля) = Тип("Массив") Тогда
				ЗначениеПоля = СтрСоединить(ЗначениеПоля, ";");
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(ЗначениеПоля) Тогда
				Продолжить;
			КонецЕсли;
			ЗначениеПоляСтрокой = ЗначениеПоляДляВывода(ЗначениеПоля);
			ОтветТелоСообщения  = ОтветТелоСообщения + Символы.ПС;
			ОтветТелоСообщения  = ОтветТелоСообщения + СтрШаблон(ШаблонОписанияПоля, ПолеВывода.Заголовок, ЗначениеПоляСтрокой);
		КонецЦикла;
		
		ИсходныеДанныеВизы = ТаблицаВизы.Найти(ИДСтрокиВизирования, "ИД");
		Виза               = ИсходныеДанныеВизы.Виза;
		
		ОтветТелоСообщения = ОтветТелоСообщения + СтрШаблон(ШаблонУточненияВизы, КодEmoji("memo"),
								Виза, НСтр("ru = 'Ожидается принятие решения по визе';en = 'Expected decision on visa'"),
								НСтр("ru = 'Комментарий решения';en = 'Desition comment'"),
								НСтр("ru = 'Не введен';en = 'Absent'"));
								
		ТекстОтвета = ОтветЗаголовок + ОтветТелоСообщения;
								
		ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
		ПараметрыСообщения.Текст          = ТекстОтвета; 
		ПараметрыСообщения.Гипертекст     = Истина;
		ПараметрыСообщения.КомандныйТекст = ТелоКоманд;
		ПараметрыСообщения.Параметры.Вставить("ОбъектВизирования", ОбъектВизирования);
		ПараметрыСообщения.Параметры.Вставить("ИДВизы", ИДСтрокиВизирования);
		ПараметрыСообщения.Параметры.Вставить("Виза", Виза);
		МассивСообщений.Добавить(ПараметрыСообщения);
		
		ВизыНайдены = Истина;
	КонецЦикла;
	
	Если НЕ ВизыНайдены Тогда
		ТекстОтвета = ОтветЗаголовок + Символы.ПС + НСтр("ru = 'Все ваши визы по данному объекту обработаны.';
														|en = 'All you visas for this object approved.'");
		ПараметрыСообщения = НовыеПараметрыИсходящегоСообщения();
		ПараметрыСообщения.Текст      = ТекстОтвета;
		ПараметрыСообщения.Гипертекст = Истина;
		ПараметрыСообщения.Параметры.Вставить("ОбъектВизирования", ОбъектВизирования);
		ПараметрыСообщения.Параметры.Вставить("ИДВизы", ИДСтрокиВизирования);
		ПараметрыСообщения.Параметры.Вставить("Виза", Виза);
		МассивСообщений.Добавить(ПараметрыСообщения);
	КонецЕсли;
			
	Возврат МассивСообщений;
	
КонецФункции

Функция ЗначениеПоляДляВывода(ЗначениеПоля)
	
	ЗначениеПоляСтрокой = "";
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПоля) Тогда
		Возврат ЗначениеПоляСтрокой;
	КонецЕсли;
	
	ЗначениеПоляСтрокой = Строка(ЗначениеПоля);
	
	ЗарезервированныеСимволы = Новый Соответствие;
	ЗарезервированныеСимволы.Вставить("#", "№");
	
	Для каждого Элемент Из ЗарезервированныеСимволы Цикл
		ЗначениеПоляСтрокой = СтрЗаменить(ЗначениеПоляСтрокой, Элемент.Ключ, Элемент.Значение);
	КонецЦикла;
	
	Возврат ЗначениеПоляСтрокой;
	
КонецФункции

Функция ПринятиеРешенияПоВизе(Чат, КомандаСтрокой, СтруктураВходящегоСообщения)
	
	МассивСообщений = Новый Массив;
	
	Пользователь = Чат.Пользователь;
	
	МассивПараметров = СтрРазделить(КомандаСтрокой, ",");
	Команда          = МассивПараметров[0];
	ИДТипа           = МассивПараметров[1];
	ИДОбъекта        = МассивПараметров[2];
	
	ПринятоеРешение     = СсылкаНаОбъектПоИдентификаторам(ИДТипа, ИДОбъекта);
	ИсходноеСообщениеИД = СтруктураВходящегоСообщения.СообщениеИД;
	
	ПараметрыКлюча = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.НовыеПараметрыКлюча();
	ПараметрыКлюча.Чат          = Чат;
	ПараметрыКлюча.СообщениеИД  = ИсходноеСообщениеИД;
	ПараметрыОбъектаВизирования = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.ПараметрыСообщения(ПараметрыКлюча);
	
	ОбъектВизирования = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыОбъектаВизирования, "ОбъектВизирования",
																		Неопределено);
	Если НЕ ЗначениеЗаполнено(ОбъектВизирования) Тогда
		Возврат МассивСообщений;
	КонецЕсли;
	
	ТекстОтвета                = "";
	СхемаИдентификаторов       = СхемаИдентификаторовОбъекта(ПараметрыОбъектаВизирования.ОбъектВизирования);
	КомандаПолученияВизОбъекта = "/ApprovObject," + СхемаИдентификаторов.ИДТипа + "," + СхемаИдентификаторов.ИДОбъекта;
	МассивСообщенийВизирования = ВизированиеОбъекта(Чат, КомандаПолученияВизОбъекта, СтруктураВходящегоСообщения);
	Для каждого СообщениеВизы Из МассивСообщенийВизирования Цикл
		Если СообщениеВизы.Параметры.ИДВизы = ПараметрыОбъектаВизирования.ИДВизы Тогда
			ТекстОтвета = СообщениеВизы.Текст;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ПустаяСтрока(ТекстОтвета) Тогда
		// Не удалось получить исходный текст согласования визы -
		// возможно виза уже обработана или больше не доступна текущему пользователю.
		Возврат МассивСообщений;
	КонецЕсли;
	
	КомментарийРешения = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыОбъектаВизирования, "КомментарийРешения", "");
	
	Если ПустаяСтрока(КомментарийРешения) Тогда
		ПараметрыПроверки = РегистрыСведений.бит_УстановленныеВизы.НовыеПараметрыНуженКомментарий();
		ПараметрыПроверки.Объект          = ПараметрыОбъектаВизирования.ОбъектВизирования;
		ПараметрыПроверки.РешениеКонечное = ПринятоеРешение;
		ПараметрыПроверки.Комментарий     = КомментарийРешения;
		ПараметрыПроверки.Виза            = ПараметрыОбъектаВизирования.Виза;
		
		Если РегистрыСведений.бит_УстановленныеВизы.НуженКомментарий(ПараметрыПроверки) Тогда
			ШаблонСообщения = НСтр("ru='Для принятия решения ""%1"" необходимо заполнить комментарий.';
										|en='It need to fill comment to make a decision ""%1"".'");
			ШаблонСообщения = СтрШаблон(ШаблонСообщения, ПринятоеРешение);
					
			НовоеСообщение = НовыеПараметрыИсходящегоСообщения();
			НовоеСообщение.Текст = ШаблонСообщения;
			МассивСообщений.Добавить(НовоеСообщение);
			Возврат МассивСообщений;
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыРешения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыПринятияРешения();
	ПараметрыРешения.ОбъектВизирования         = ПараметрыОбъектаВизирования.ОбъектВизирования;
	ПараметрыРешения.ИДВизы                    = ПараметрыОбъектаВизирования.ИДВизы;
	ПараметрыРешения.ТекущийПользователь       = Пользователь;
	ПараметрыРешения.Решение                   = ПринятоеРешение;
	ПараметрыРешения.Комментарий               = КомментарийРешения;
	ПараметрыРешения.ДатаУстановкиРешения      = ТекущаяДатаСеанса();
    ПараметрыРешения.ПроводитьПослеУтверждения = бит_ВизированиеСервер.ПриниматьКУчетуПослеУтверждения(ПараметрыОбъектаВизирования.ОбъектВизирования);
	
	Если НЕ Обработки.бит_КонсольОперативногоВизирования.УстановитьРешениеПоВизе(ПараметрыРешения) Тогда
		// Не удалось установить решение по визе.
		Возврат МассивСообщений;
	КонецЕсли;
	
	НачалоМетки1 = СтрНайти(ТекстОтвета, КодEmoji("memo"));
	НачалоМетки2 = СтрНайти(ТекстОтвета, КодEmoji("check_mark"));
	Если НачалоМетки1 = 0 Тогда
		КонецОписанияВизы = НачалоМетки2;
	ИначеЕсли НачалоМетки2 = 0 Тогда
		КонецОписанияВизы = НачалоМетки1;
	Иначе
		КонецОписанияВизы = Мин(НачалоМетки1, НачалоМетки2);
	КонецЕсли;
	
	ТекстОтвета = Лев(ТекстОтвета, КонецОписанияВизы - 1);
	
	ШаблонПринятогоРешения = "%1 <b>%2</b>: %3.";
	Если ЗначениеЗаполнено(ПринятоеРешение) Тогда
		ТекстОтвета = ТекстОтвета + СтрШаблон(ШаблонПринятогоРешения, КодEmoji("check_mark"), ПараметрыОбъектаВизирования.Виза,
												ПринятоеРешение);
	Иначе
		ТекстОтвета = ТекстОтвета + СтрШаблон(ШаблонПринятогоРешения, КодEmoji("memo"), ПараметрыОбъектаВизирования.Виза,
												НСтр("ru = 'Ожидается принятие решения по визе';en = 'Expected decision on visa'"));
	КонецЕсли;
	
	ШаблонКомментария  =
	"
	|%1 <b>Комментарий решения:</b> <i>%2</i>";
	Если ПустаяСтрока(КомментарийРешения) Тогда
		ТекстОтвета = ТекстОтвета + СтрШаблон(ШаблонКомментария, КодEmoji("memo"), НСтр("ru = 'Не введен.';
																				   	|en = 'Empty.'"));
	Иначе
		ТекстОтвета = ТекстОтвета + СтрШаблон(ШаблонКомментария, КодEmoji("check_mark"), КомментарийРешения);
	КонецЕсли;
	
	НовоеСообщение = НовыеПараметрыИсходящегоСообщения();
	НовоеСообщение.Текст                     = ТекстОтвета; 
	НовоеСообщение.Гипертекст                = Истина;
	НовоеСообщение.ИДРедактируемогоСообщения = ИсходноеСообщениеИД;
	НовоеСообщение.Параметры                 = ПараметрыОбъектаВизирования;
	
	МассивСообщений.Добавить(НовоеСообщение);
	
	Возврат МассивСообщений;
	
КонецФункции

Процедура ОтправитьЗапросВвестиКомментарийВизирования(ПараметрыИсходящихСообщений, ПараметрыСообщения)
	
	ШаблонСообщения = "%1 <i>%2</i>";
	ТекстОтвета = СтрШаблон(ШаблонСообщения, КодEmoji("speech_balloon"),
								НСтр("ru='Введите комментарий:';en='Enter comment:'"));
	
	ПараметрыНовогоСообщения = НовыеПараметрыИсходящегоСообщения();
	ПараметрыНовогоСообщения.Текст      = ТекстОтвета;
	ПараметрыНовогоСообщения.Гипертекст = Истина;
	
	ПараметрыНовогоСообщения.Параметры.Вставить("Команда",         ПараметрыСообщения.Сообщение);
	ПараметрыНовогоСообщения.Параметры.Вставить("ИсточникКоманды", ПараметрыСообщения.СообщениеИД);
	
	ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыНовогоСообщения);
	
КонецПроцедуры

Процедура ВвестиКомментарийВизирования(ПараметрыИсходящихСообщений, ПараметрыСообщения, ПараметрыПредыдущегоСообщения)
	
	Чат = ПараметрыИсходящихСообщений.Чат;
	
	ПараметрыКлюча              = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.НовыеПараметрыКлюча();
	ПараметрыКлюча.Чат          = ПараметрыИсходящихСообщений.Чат;
	ПараметрыКлюча.СообщениеИД  = ПараметрыПредыдущегоСообщения.ИсточникКоманды;
	ПараметрыОбъектаВизирования = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.ПараметрыСообщения(ПараметрыКлюча);
	
	ИДВизы = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыОбъектаВизирования, "ИДВизы", "");
	Если ПустаяСтрока(ИДВизы) Тогда
		// Не удалось определить идентификатор визы.
		Возврат;
	КонецЕсли;
	
	Комментарий = ПараметрыСообщения.Сообщение;
	ПараметрыОбъектаВизирования.Вставить("КомментарийРешения", Комментарий);
	
	ТекстОтвета                = "";
	ТекстКоманд                = "";
	СхемаИдентификаторов       = СхемаИдентификаторовОбъекта(ПараметрыОбъектаВизирования.ОбъектВизирования);
	КомандаПолученияВизОбъекта = "/ApprovObject," + СхемаИдентификаторов.ИДТипа + "," + СхемаИдентификаторов.ИДОбъекта;
	МассивСообщенийВизирования = ВизированиеОбъекта(Чат, КомандаПолученияВизОбъекта, ПараметрыСообщения);
	Для каждого СообщениеВизы Из МассивСообщенийВизирования Цикл
		Если СообщениеВизы.Параметры.ИДВизы = ИДВизы Тогда
			ТекстОтвета = СообщениеВизы.Текст;
			ТекстКоманд = СообщениеВизы.КомандныйТекст;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ПустаяСтрока(ТекстОтвета) Тогда
		// Не удалось получить исходный текст согласования визы -
		// возможно виза уже обработана или больше не доступна текущему пользователю.
		Возврат;
	КонецЕсли;
	
	НачалоМетки1 = СтрНайти(ТекстОтвета, КодEmoji("memo"));
	НачалоМетки2 = СтрНайти(ТекстОтвета, КодEmoji("check_mark"));
	Если НачалоМетки1 = 0 Тогда
		КонецОписанияВизы = НачалоМетки2;
	ИначеЕсли НачалоМетки2 = 0 Тогда
		КонецОписанияВизы = НачалоМетки1;
	Иначе
		КонецОписанияВизы = Мин(НачалоМетки1, НачалоМетки2);
	КонецЕсли;
	
	ТекстОтвета = Лев(ТекстОтвета, КонецОписанияВизы - 1);
	
	ШаблонПринятогоРешения = "%1 <b>%2</b>: %3.";
	ПринятоеРешение = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыОбъектаВизирования, "ПринятоеРешение", Неопределено);
	Если ЗначениеЗаполнено(ПринятоеРешение) Тогда
		ТекстОтвета = ТекстОтвета + СтрШаблон(ШаблонПринятогоРешения, КодEmoji("check_mark"), ПараметрыОбъектаВизирования.Виза,
												ПринятоеРешение);
	Иначе
		ТекстОтвета = ТекстОтвета + СтрШаблон(ШаблонПринятогоРешения, КодEmoji("memo"), ПараметрыОбъектаВизирования.Виза,
												НСтр("ru = 'Ожидается принятие решения по визе';en = 'Expected decision on visa'"));
	КонецЕсли;
	
	ШаблонКомментария =
	"
	|%1 <b>Комментарий решения:</b> <i>%2</i>";
	Если ПустаяСтрока(ПараметрыОбъектаВизирования.КомментарийРешения) Тогда
		ТекстОтвета = ТекстОтвета + СтрШаблон(ШаблонКомментария, КодEmoji("memo"),  НСтр("ru = 'Не введен.';
																				   	|en = 'Empty.'"));
	Иначе
		ТекстОтвета = ТекстОтвета + СтрШаблон(ШаблонКомментария, КодEmoji("check_mark"),
												ПараметрыОбъектаВизирования.КомментарийРешения);
	КонецЕсли;
	
	НовоеСообщение = НовыеПараметрыИсходящегоСообщения();
	НовоеСообщение.Текст                      = ТекстОтвета; 
	НовоеСообщение.Гипертекст                 = Истина;
	НовоеСообщение.КомандныйТекст             = ТекстКоманд;
	НовоеСообщение.ИДРедактируемогоСообщения  = ПараметрыПредыдущегоСообщения.ИсточникКоманды;
	НовоеСообщение.Параметры                  = ПараметрыОбъектаВизирования;
	
	ПараметрыИсходящихСообщений.МассивСообщений.Добавить(НовоеСообщение);
	
	
	// Удалим вспомогательные сообщения.
	
	// А. Введенный пользователем комментарий.
	КомандаУдаления = НовыеПараметрыИсходящегоСообщения();
	КомандаУдаления.ИДРедактируемогоСообщения = ПараметрыСообщения.СообщениеИД;
	КомандаУдаления.УдалениеСообщения         = Истина;
	ПараметрыИсходящихСообщений.МассивСообщений.Добавить(КомандаУдаления);
	
	// Б. Запрос бота ввести комментарий.
	КомандаУдаления = НовыеПараметрыИсходящегоСообщения();
	КомандаУдаления.ИДРедактируемогоСообщения = ПараметрыСообщения.СообщениеИД - 1;
	КомандаУдаления.УдалениеСообщения         = Истина;
	ПараметрыИсходящихСообщений.МассивСообщений.Добавить(КомандаУдаления);
	
	
КонецПроцедуры

Процедура ПоказатьВложенияОбъектаВизирования(ПараметрыИсходящихСообщений, СтруктураВходящегоСообщения)
	
	КонструкторКоманд = НовыйКонструкторПанелиКоманд();
	ТекстОтвета       = СообщениеВыборФайлаВложения(ПараметрыИсходящихСообщений,
													СтруктураВходящегоСообщения,
													КонструкторКоманд);
	Если ТекстОтвета = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыНовогоСообщения = НовыеПараметрыИсходящегоСообщения();
	ПараметрыНовогоСообщения.Текст          = ТекстОтвета;
	ПараметрыНовогоСообщения.Гипертекст     = Истина;
	ПараметрыНовогоСообщения.КомандныйТекст = ТекстПанелиКоманд(КонструкторКоманд);
	
	ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыНовогоСообщения);
	
КонецПроцедуры

Функция СообщениеВыборФайлаВложения(ПараметрыИсходящихСообщений, СтруктураВходящегоСообщения, КонструкторКоманд)
	
	ПараметрыКлюча = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.НовыеПараметрыКлюча();
	ПараметрыКлюча.Чат          = ПараметрыИсходящихСообщений.Чат;
	ПараметрыКлюча.СообщениеИД  = СтруктураВходящегоСообщения.СообщениеИД;
	ПараметрыОбъектаВизирования = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.ПараметрыСообщения(ПараметрыКлюча);
	
	ОбъектВизирования = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыОбъектаВизирования, "ОбъектВизирования",
																		Неопределено);

	Если ОбъектВизирования = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИмяСправочникаХранения = РаботаСФайламиСлужебный.ИмяСправочникаХраненияФайлов(ОбъектВизирования);
	Если НЕ ЗначениеЗаполнено(ИмяСправочникаХранения) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ШаблонЗаголовок = "%1 <b>%2</b>";
	ТекстОтвета     = СтрШаблон(ШаблонЗаголовок, КодEmoji("paperclip"), ОбъектВизирования) + Символы.ПС; 
	
	ШаблонОшибки    = "<i>%1.</i>";
	
	Пользователь = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыИсходящихСообщений.Чат, "Пользователь");
	
	РазрешеноПросматриватьВложения = бит_ПраваДоступа.ПолучитьЗначениеДопПраваПользователя(
										Пользователь, 
										ПланыВидовХарактеристик.бит_ДополнительныеПраваПользователей.ПросмотрВложенийЧерезTelegram);
	Если РазрешеноПросматриватьВложения <> Истина Тогда
		ТекстОтвета = ТекстОтвета + Символы.ПС
						+ СтрШаблон(ШаблонОшибки, НСтр("ru='Нет прав на просмотр вложений через Telegram';
												  	|en='No rights to view attachments via Telegram'"));
		Возврат ТекстОтвета;
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СправочникХраненияФайлов.Ссылка КАК Файл
	|ИЗ
	|	&ИмяСправочника КАК СправочникХраненияФайлов
	|ГДЕ
	|	СправочникХраненияФайлов.ВладелецФайла = &ВладелецФайла
	|	И НЕ СправочникХраненияФайлов.ПометкаУдаления
	|	И &ЭтоГруппа = ЛОЖЬ
	|	И &Служебный = ЛОЖЬ";
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ИмяСправочника", "Справочник." + ИмяСправочникаХранения);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Служебный",
		?(РаботаСФайламиСлужебный.ЕстьРеквизитСлужебный(ИмяСправочникаХранения),
		"СправочникХраненияФайлов.Служебный", "ЛОЖЬ"));
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ЭтоГруппа", 
		?(Метаданные.Справочники[ИмяСправочникаХранения].Иерархический,
		"СправочникХраненияФайлов.ЭтоГруппа", "ЛОЖЬ"));
		
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ВладелецФайла", ОбъектВизирования);
	
	РезультатЗапросаФайлов = Запрос.Выполнить();
	Если РезультатЗапросаФайлов.Пустой() Тогда
		ТекстОтвета = ТекстОтвета + Символы.ПС
						+ СтрШаблон(ШаблонОшибки,НСтр("ru = 'Нет файлов вложения';en = 'No files'"));
		Возврат ТекстОтвета;
	КонецЕсли;
	
	ВыборкаФайлов = РезультатЗапросаФайлов.Выбрать();
	Сч = 1;
	Пока ВыборкаФайлов.Следующий() Цикл
		ШаблонСтрокиФайла = "<b>%1.</b> <code>%2.</code>";
		ФайлСсылка  = ВыборкаФайлов.Файл;
		ТекстОтвета = ТекстОтвета + Символы.ПС + СтрШаблон(ШаблонСтрокиФайла, Сч, ФайлСсылка);
		
		СхемаИдентификаторов = СхемаИдентификаторовОбъекта(ФайлСсылка);
		ОбъектСтрокой        = СхемаИдентификаторов.ИДТипа + "," + СхемаИдентификаторов.ИДОбъекта;
		ДобавитьКоманду(КонструкторКоманд.Команды, "/SendAttachment," + ОбъектСтрокой, Сч);
		
		Сч = Сч + 1;
	КонецЦикла;
	
	Возврат ТекстОтвета;
	
КонецФункции

Процедура ОтправитьВложение(ПараметрыИсходящихСообщений, СтруктураВходящегоСообщения, КомандаСтрокой)
	
	МассивПараметров = СтрРазделить(КомандаСтрокой, ",");
	Команда          = МассивПараметров[0];
	ИДТипа           = МассивПараметров[1];
	ИДОбъекта        = МассивПараметров[2];
	ФайлСсылка       = СсылкаНаОбъектПоИдентификаторам(ИДТипа, ИДОбъекта);
	
	ДанныеФайла = РаботаСФайлами.ДанныеФайла(ФайлСсылка);
	
	ПараметрыНовогоСообщения = НовыеПараметрыИсходящегоСообщения();
	ПараметрыНовогоСообщения.ОтправкаФайла  = Истина;
	ПараметрыНовогоСообщения.ПараметрыФайла = ДанныеФайла;
	
	ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыНовогоСообщения);
	
КонецПроцедуры

Процедура УправлениеОтборомСпискаВиз(ПараметрыИсходящихСообщений, ПараметрыСообщения)
	
	ПараметрыНовогоСообщения = НовыеПараметрыИсходящегоСообщения();
	
	ПараметрыОтзыва = Новый Структура;
	
	ЭтоРедактированиеПоля = Ложь;
	КомандаСтрокой        = ПараметрыСообщения.Сообщение;
	МассивПараметров      = СтрРазделить(КомандаСтрокой, ",");
	Для каждого ОткрытыйПараметр Из МассивПараметров Цикл
		Если СтрНачинаетсяС(ОткрытыйПараметр, "EditDimension") Тогда
			ЭтоРедактированиеПоля = Истина;
			ПараметрыОтзыва.Вставить("НомерПоля", Число(СтрЗаменить(ОткрытыйПараметр, "EditDimension", "")));
			ПараметрыНовогоСообщения.ИДРедактируемогоСообщения = ПараметрыСообщения.СообщениеИД;
		ИначеЕсли ОткрытыйПараметр = "StayHere" Тогда
			ПараметрыНовогоСообщения.ИДРедактируемогоСообщения = ПараметрыСообщения.СообщениеИД;
		ИначеЕсли СтрНачинаетсяС(ОткрытыйПараметр, "Batch") Тогда
			ПараметрыОтзыва.Вставить("НомерПорции", Число(СтрЗаменить(ОткрытыйПараметр, "Batch", "")));
		КонецЕсли;	
	КонецЦикла;
	ЭтоОкноВыбораПоля = НЕ ЭтоРедактированиеПоля;
	
	Пользователь = ПараметрыИсходящихСообщений.Чат.Пользователь;
	
	АдресВХранилище = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор); 
	МатрицаДоступа  = Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа(Пользователь);
	
	ПараметрыПолучения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
	ПараметрыПолучения.МатрицаДоступа		            = МатрицаДоступа;
	ПараметрыПолучения.ВыводитьВТаблицуЗначений         = Истина;
	ПараметрыПолучения.ЭтоМобильноеПриложение           = Истина;
	ПараметрыПолучения.Ответственный                    = Пользователь;
	ПараметрыПолучения.ВозвращатьПорядокИЗаголовкиПолей = Истина;
	ПараметрыПолучения.ВозвращатьТаблицуВиз             = Истина;
	
	Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
	
	Результат              = ПолучитьИзВременногоХранилища(АдресВХранилище);
	ТаблицаДокументов      = Результат.РезультатТаблицаЗначений;
	ПорядокИЗаголовкиПолей = Результат.ПорядокИЗаголовкиПолей;
	ТаблицаВизы            = Результат.ТаблицаВизы;
	КолонкиТаблицыВиз      = ТаблицаВизы.Колонки;
	
	СписокУпорядочиванияПолей = Новый СписокЗначений;
	Для каждого ПолеЗаголовка Из ПорядокИЗаголовкиПолей Цикл
		Если КолонкиТаблицыВиз.Найти(ПолеЗаголовка.Имя) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		СписокУпорядочиванияПолей.Добавить(ПолеЗаголовка.Имя, ПолеЗаголовка.Заголовок);
	КонецЦикла;
	СписокУпорядочиванияПолей.СортироватьПоПредставлению();
	
	КонструкторКоманд = НовыйКонструкторПанелиКоманд();
		
	Если ЭтоОкноВыбораПоля Тогда
		
		КонструкторКоманд.КоличествоКомандВСтроке = 2;
		
		ТекстОтвета = "<i>%1.</i>" + Символы.ПС;
		ТекстОтвета = СтрШаблон(ТекстОтвета, НСтр("ru = 'Установка отбора списка виз';en = 'Setting filter for approv list'"));
		
		ПорядковыйНомер = 1;
		Для каждого ПолеТаблицы Из СписокУпорядочиванияПолей Цикл
			ДобавитьКоманду(КонструкторКоманд.Команды, "/ApprovFilter,EditDimension" + ПорядковыйНомер, ПолеТаблицы.Представление);
			ПорядковыйНомер = ПорядковыйНомер + 1;
		КонецЦикла;
		
		ПараметрыНовогоСообщения.Текст = ТекстОтвета;
		
		ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/SetFilter,ClearAll",
						НСтр("ru = 'Очистить все отборы';en = 'Clear all filters'"),
						КодEmoji("multiplication_x"));
		
	ИначеЕсли ЭтоРедактированиеПоля Тогда
		
		КонструкторКоманд.КоличествоКомандВСтроке = 8;
		
		ПолеФильтра = СписокУпорядочиванияПолей[ПараметрыОтзыва.НомерПоля - 1];
		
		ТекстОтвета = "<i>%1</i> <b>%2</b>" + Символы.ПС;
		ТекстОтвета = СтрШаблон(ТекстОтвета, НСтр("ru = 'Отбор по полю';en = 'Filter by field'"), ПолеФильтра.Представление);
		
		ШаблонСтрокиОтбора = "<b>%1.</b> <code>%2</code>";
		
		ИмяПоля = ПолеФильтра.Значение;
		ПараметрыНовогоСообщения.Параметры.Вставить("ИмяПоляФильтра", ИмяПоля);
		ПараметрыНовогоСообщения.Параметры.Вставить("ПредставлениеПоляФильтра", ПолеФильтра.Представление);
		
		НомерПорции = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыОтзыва, "НомерПорции", 0);
		ПараметрыПорции = НовыеПараметрыПорции();
		ПараметрыПорции.НомерПорции = НомерПорции;
		
		ВариантыФильтра = ВариантыФильтраПоля(ТаблицаВизы, ИмяПоля, ПараметрыПорции);
		ПорядковыйНомер = ПараметрыПорции.ПервыйЭлемент;
		Для каждого ВариантФильтра Из ВариантыФильтра Цикл
			ПорядковыйНомерСтрокой = Формат(ПорядковыйНомер, "ЧГ=");
			ТекстОтвета = ТекстОтвета + Символы.ПС + СтрШаблон(ШаблонСтрокиОтбора, ПорядковыйНомерСтрокой,
																ВариантФильтра.ПредставлениеЗначения);
			ДобавитьКоманду(КонструкторКоманд.Команды, "/SetFilter,SelectChoise_" + ПорядковыйНомерСтрокой, Строка(ПорядковыйНомер));
			
			ПараметрыНовогоСообщения.Параметры.Вставить("ЗначениеПоляФильтра_" + ПорядковыйНомерСтрокой, ВариантФильтра.ЗначениеПоля);
			ПорядковыйНомер = ПорядковыйНомер + 1;
		КонецЦикла;
		ПараметрыНовогоСообщения.Текст = ТекстОтвета;
		
		ШаблонКомандыПорции = "/ApprovFilter,EditDimension%1,Batch%2";
		Если ПараметрыПорции.СмещениеВНачалоСтека Тогда
			ДанныеНажатия = СтрШаблон(ШаблонКомандыПорции, ПараметрыОтзыва.НомерПоля, 0); 
			ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, ДанныеНажатия, "", КодEmoji("rewind"));
		КонецЕсли;
		Если ПараметрыПорции.СмещениеШагНазад Тогда
			ДанныеНажатия = СтрШаблон(ШаблонКомандыПорции, ПараметрыОтзыва.НомерПоля, НомерПорции - 1); 
			ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, ДанныеНажатия, "", КодEmoji("arrow_backward"));
		КонецЕсли;
		
		ЗаголовокКоманды = НСтр("ru = 'Отключить фильтр';en = 'Clear filter'");
		ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/SetFilter,SelectChoise_0", ЗаголовокКоманды, КодEmoji("multiplication_x"));
		ЗаголовокКоманды = НСтр("ru = 'Выбрать другое поле';en = 'Choose another field'");
		ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, "/ApprovFilter,StayHere", ЗаголовокКоманды, КодEmoji("ticket"));
		
		Если ПараметрыПорции.СмещениеШагВперед Тогда
			ДанныеНажатия = СтрШаблон(ШаблонКомандыПорции, ПараметрыОтзыва.НомерПоля, НомерПорции + 1); 
			ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, ДанныеНажатия, "", КодEmoji("arrow_forward"));
		КонецЕсли;
		Если ПараметрыПорции.СмещениеВКонецСписка Тогда
			ПоследняяПорция = Цел(ПараметрыПорции.ВсегоЭлементов / ПараметрыПорции.ОграничениеПорции);
			ДанныеНажатия   = СтрШаблон(ШаблонКомандыПорции, ПараметрыОтзыва.НомерПоля, ПоследняяПорция); 
			ДобавитьКоманду(КонструкторКоманд.КомандыНавигации, ДанныеНажатия, "", КодEmoji("fast_forward"));
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыНовогоСообщения.КомандныйТекст = ТекстПанелиКоманд(КонструкторКоманд);
	ПараметрыНовогоСообщения.Гипертекст     = Истина;
	
	ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыНовогоСообщения);
	
КонецПроцедуры

Функция НовыеПараметрыПорции()
	
	ПараметрыПорции = Новый Структура;
	ПараметрыПорции.Вставить("ОграничениеПорции",    20);
	ПараметрыПорции.Вставить("НомерПорции",          0);
	ПараметрыПорции.Вставить("СмещениеВНачалоСтека", Ложь);
	ПараметрыПорции.Вставить("СмещениеШагНазад",     Ложь);
	ПараметрыПорции.Вставить("СмещениеШагВперед",    Ложь);
	ПараметрыПорции.Вставить("СмещениеВКонецСписка", Ложь);
	ПараметрыПорции.Вставить("ВсегоЭлементов",       0);
	ПараметрыПорции.Вставить("ПервыйЭлемент",        1);
	ПараметрыПорции.Вставить("ПоследнийЭлемент",     0);
	
	Возврат ПараметрыПорции;
	
КонецФункции

Процедура РассчитатьПараметрыПорций(ПараметрыПорции)
	
	ВсегоЭлементов = ПараметрыПорции.ВсегоЭлементов;
	
	ПараметрыПорции.СмещениеВНачалоСтека = (ПараметрыПорции.НомерПорции > 1);
	ПараметрыПорции.СмещениеШагНазад     = (ПараметрыПорции.НомерПорции > 0);
	ПараметрыПорции.СмещениеШагВперед    = ((ПараметрыПорции.НомерПорции + 1) * ПараметрыПорции.ОграничениеПорции
											< ВсегоЭлементов);
	ПараметрыПорции.СмещениеВКонецСписка = ((ПараметрыПорции.НомерПорции + 2) * ПараметрыПорции.ОграничениеПорции
											< ВсегоЭлементов);
	ПараметрыПорции.ПервыйЭлемент        = Мин(ПараметрыПорции.НомерПорции * ПараметрыПорции.ОграничениеПорции + 1,
												Макс(ВсегоЭлементов - ПараметрыПорции.ОграничениеПорции, 1));
	ПараметрыПорции.ПоследнийЭлемент     = Мин((ПараметрыПорции.НомерПорции + 1) * ПараметрыПорции.ОграничениеПорции,
												ВсегоЭлементов);
	
КонецПроцедуры

Функция ВариантыФильтраПоля(Знач ТаблицаДанных, ИмяПоля, ПараметрыПорции)
	
	ДоступныеВарианты = Новый Массив;
	
	ОписаниеТипаДанных = ТаблицаДанных.Колонки[ИмяПоля].ТипЗначения;
	Если ОписаниеТипаДанных.СодержитТип(Тип("Дата")) Тогда
		ДобавитьВариантФильтра(ДоступныеВарианты, '00010101', "<i>Не заполнено</i>");
		
		НовыйВариант = ВариантСтандартногоПериода.Сегодня;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
		
		НовыйВариант = ВариантСтандартногоПериода.ЭтаНеделя;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
		
		НовыйВариант = ВариантСтандартногоПериода.ЭтотМесяц;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
		
		НовыйВариант = ВариантСтандартногоПериода.ЭтотГод;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
		
		НовыйВариант = ВариантСтандартногоПериода.Завтра;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
		
		НовыйВариант = ВариантСтандартногоПериода.СледующаяНеделя;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
		
		НовыйВариант = ВариантСтандартногоПериода.СледующийМесяц;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
		
		НовыйВариант = ВариантСтандартногоПериода.СледующийГод;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
		
		НовыйВариант = ВариантСтандартногоПериода.Вчера;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
		
		НовыйВариант = ВариантСтандартногоПериода.ПрошлаяНеделя;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
		
		НовыйВариант = ВариантСтандартногоПериода.ПрошлыйМесяц;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
		
		НовыйВариант = ВариантСтандартногоПериода.ПрошлыйГод;
		ДобавитьВариантФильтра(ДоступныеВарианты, НовыйВариант, Строка(НовыйВариант));
	Иначе
		ТаблицаДанных.Свернуть(ИмяПоля);
		ТаблицаДанных.Сортировать(ИмяПоля);
		
		
		ПараметрыПорции.ВсегоЭлементов = ТаблицаДанных.Количество();
		РассчитатьПараметрыПорций(ПараметрыПорции);
		
		Сч = 0;
		Для каждого СтрокаДанных Из ТаблицаДанных Цикл
			Сч = Сч + 1;
			Если Сч < ПараметрыПорции.ПервыйЭлемент Тогда
				Продолжить;
			ИначеЕсли Сч > ПараметрыПорции.ПоследнийЭлемент Тогда
				Прервать;
			КонецЕсли;
			ЗначениеПоля = СтрокаДанных[ИмяПоля];
			Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
				ПредставлениеЗначения = Строка(ЗначениеПоля);
			Иначе
				ПредставлениеЗначения = "<i>Не заполнено</i>";
			КонецЕсли;
			
			ДобавитьВариантФильтра(ДоступныеВарианты, ЗначениеПоля, ПредставлениеЗначения);
		КонецЦикла;
	КонецЕсли;
	
	Возврат ДоступныеВарианты;
	
КонецФункции

Процедура ДобавитьВариантФильтра(ДоступныеВарианты, Знач ЗначениеПоля, ПредставлениеЗначения)
	
	Если ТипЗнч(ЗначениеПоля) = Тип("ВариантСтандартногоПериода") Тогда
		ПризнакСтандартногоВарианта = "/StandardPeriodVariant:";
		ЗначениеПоля = ПризнакСтандартногоВарианта + ЗначениеВСтрокуВнутр(ЗначениеПоля);
	КонецЕсли;
	
	НовыйВариант = Новый Структура;
	НовыйВариант.Вставить("ЗначениеПоля",          ЗначениеПоля);
	НовыйВариант.Вставить("ПредставлениеЗначения", ПредставлениеЗначения);
	ДоступныеВарианты.Добавить(НовыйВариант);
	
КонецПроцедуры

Процедура УстановитьЗначениеФильтраВиз(ПараметрыИсходящихСообщений, ПараметрыСообщения)
	
	КомандаУдаления = НовыеПараметрыИсходящегоСообщения();
	КомандаУдаления.ИДРедактируемогоСообщения = ПараметрыСообщения.СообщениеИД;
	КомандаУдаления.УдалениеСообщения         = Истина;
	ПараметрыИсходящихСообщений.МассивСообщений.Добавить(КомандаУдаления);
	
	ПараметрыНовогоСообщения = НовыеПараметрыИсходящегоСообщения();
	
	ЭтоРедактированиеПоля = Ложь;
	КомандаСтрокой        = ПараметрыСообщения.Сообщение;
	МассивПараметров      = СтрРазделить(КомандаСтрокой, ",");
	
	НомерВыбранногоФильтра = Неопределено;
	Для каждого ОткрытыйПараметр Из МассивПараметров Цикл
		Если СтрНачинаетсяС(ОткрытыйПараметр, "SelectChoise_") Тогда
			НомерВыбранногоФильтра = Число(СтрЗаменить(ОткрытыйПараметр, "SelectChoise_", ""));
		ИначеЕсли ОткрытыйПараметр = "ClearAll" Тогда
			НомерВыбранногоФильтра = -1;
		КонецЕсли;
	КонецЦикла;
	Если НомерВыбранногоФильтра = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Пользователь         = ПараметрыИсходящихСообщений.Чат.Пользователь;
	НастройкиВизирования = НастройкиВизированияТелеграм(Пользователь);
	
	Если НомерВыбранногоФильтра = -1 Тогда
		НастройкиВизирования.Отбор.Очистить();
	Иначе
		ПараметрыКлюча             = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.НовыеПараметрыКлюча();
		ПараметрыКлюча.Чат         = ПараметрыИсходящихСообщений.Чат;
		ПараметрыКлюча.СообщениеИД = ПараметрыСообщения.СообщениеИД;
		ПараметрыУстановкиФильтра  = РегистрыСведений.бит_ПараметрыСообщенийТелеграм.ПараметрыСообщения(ПараметрыКлюча);
	
		ИмяПоляФильтра = ПараметрыУстановкиФильтра.ИмяПоляФильтра;
		Если НомерВыбранногоФильтра = 0 Тогда
			// Очистка фильтра по полю.
			Если НастройкиВизирования.Отбор.Свойство(ИмяПоляФильтра) Тогда
				НастройкиВизирования.Отбор.Удалить(ИмяПоляФильтра);
			КонецЕсли;
		Иначе
			ЭлементОтбора                = Обработки.бит_КонсольОперативногоВизирования.НовыйЭлементВнешнегоОтбора();
			ЭлементОтбора.ЛевоеЗначение  = ИмяПоляФильтра;
			ЭлементОтбора.ПравоеЗначение = ПараметрыУстановкиФильтра["ЗначениеПоляФильтра_" + НомерВыбранногоФильтра];
			ЭлементОтбора.Представление  = ПараметрыУстановкиФильтра.ПредставлениеПоляФильтра;
			НастройкиВизирования.Отбор.Вставить(ИмяПоляФильтра, ЭлементОтбора);
		КонецЕсли;
	КонецЕсли;
	
	СохранитьНастройкиВизирования(НастройкиВизирования, Пользователь);
	
	НовоеСообщение = СписокВизНаСогласование(ПараметрыИсходящихСообщений.Чат, "/ApprovList", ПараметрыСообщения);
	ПараметрыИсходящихСообщений.МассивСообщений.Добавить(НовоеСообщение);
	
КонецПроцедуры

Функция НастройкиВизированияТелеграм(Пользователь)
	
	НастройкиВизирования = бит_ОтчетыСервер.НайтиНастройкуПоУмолчаниюДляОбъекта("ВизированиеТелеграм",,, Пользователь);
	
	Если ЗначениеЗаполнено(НастройкиВизирования) Тогда
		
		СтруктураНастроек = НастройкиВизирования.ХранилищеНастроек.Получить();
		
	Иначе
		
		СтруктураНастроек = Новый Структура;
		СтруктураНастроек.Вставить("Отбор", Новый Структура);
		
	КонецЕсли;
	
	Возврат СтруктураНастроек;
	
КонецФункции

Процедура СохранитьНастройкиВизирования(НастройкиВизирования, Пользователь)
	
	НастраиваемыйОбъект = "ВизированиеТелеграм";
	
	ТекущаяНастройка = бит_ОтчетыСервер.НайтиНастройкуПоУмолчаниюДляОбъекта("ВизированиеТелеграм",,, Пользователь);
	Если ЗначениеЗаполнено(ТекущаяНастройка) Тогда
		НачатьТранзакцию();
		Попытка
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить(ОбщегоНазначения.ИмяТаблицыПоСсылке(ТекущаяНастройка));
			ЭлементБлокировки.УстановитьЗначение("Ссылка", ТекущаяНастройка);
			Блокировка.Заблокировать();
			
			ЗаблокироватьДанныеДляРедактирования(ТекущаяНастройка);
			ОбъектНастройки = ТекущаяНастройка.ПолучитьОбъект();
			ОбъектНастройки.ХранилищеНастроек = Новый ХранилищеЗначения(НастройкиВизирования);
			ОбъектНастройки.Записать();
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ВызватьИсключение;
		КонецПопытки;
	 
	Иначе
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("НаименованиеНастройки"  , "Настройки визирования Telegram"); // АПК:1297 Не локализуется, строковой параметр.
		СтруктураПараметров.Вставить("ТипНастройки"			  , Перечисления.бит_ТипыСохраненныхНастроек.Обработки);
		СтруктураПараметров.Вставить("НастраиваемыйОбъект"	  , "ВизированиеТелеграм");
		СтруктураПараметров.Вставить("Ответственный"		  , Пользователь);
		СтруктураПараметров.Вставить("СтруктураНастройки"	  , НастройкиВизирования);
		НоваяНастройка  = Справочники.бит_СохраненныеНастройки.СоздатьНастройку(СтруктураПараметров);
		ОбъектНастройки = НоваяНастройка.ПолучитьОбъект();
		ОбъектНастройки.ИспользоватьПриОткрытии = Истина;
		ОбъектНастройки.Записать();
		бит_ОтчетыСервер.ИзменитьИспользоватьПриОткрытии(НоваяНастройка, Истина, Пользователь);
	КонецЕсли;
	
КонецПроцедуры

Процедура УправлениеОповещениямиНовыхВиз(ПараметрыИсходящихСообщений, ПараметрыСообщения)
	
	ПараметрыНовогоСообщения = НовыеПараметрыИсходящегоСообщения();
	
	ПараметрыОтзыва = Новый Структура;
	
	ОперацияОповещения = "ПоказатьНастройки";
	КомандаСтрокой     = ПараметрыСообщения.Сообщение;
	МассивПараметров   = СтрРазделить(КомандаСтрокой, ",");
	Для каждого ОткрытыйПараметр Из МассивПараметров Цикл
		Если СтрНачинаетсяС(ОткрытыйПараметр, "EnableNotify") Тогда
			ОперацияОповещения = "ВключитьОповещения";
		ИначеЕсли СтрНачинаетсяС(ОткрытыйПараметр, "DisableNotify") Тогда
			ОперацияОповещения = "ОтключитьОповещения";
		КонецЕсли;	
	КонецЦикла;
	
	Пользователь = ПараметрыИсходящихСообщений.Чат.Пользователь;
	
	ОповещенияВключены = Ложь;
	Если ОперацияОповещения = "ПоказатьНастройки" Тогда
		МенеджерЗаписи = РегистрыСведений.бит_НастройкиПользователей.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Настройка    = ПланыВидовХарактеристик.бит_НастройкиПользователей.ОповещатьОНовыхВизахВТелеграм;
		МенеджерЗаписи.Пользователь = Пользователь;
		МенеджерЗаписи.Прочитать();
		Если МенеджерЗаписи.Выбран() Тогда
			ОповещенияВключены = МенеджерЗаписи.ЗначениеНастройки;
		Иначе
			ОповещенияВключены = Ложь;
		КонецЕсли;
	Иначе
		Если ОперацияОповещения = "ВключитьОповещения" Тогда
			ОповещенияВключены = Истина;
		Иначе
			ОповещенияВключены = Ложь;
		КонецЕсли;
		
		МенеджерЗаписи = РегистрыСведений.бит_НастройкиПользователей.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Настройка         = ПланыВидовХарактеристик.бит_НастройкиПользователей.ОповещатьОНовыхВизахВТелеграм;
		МенеджерЗаписи.Пользователь      = Пользователь;
		МенеджерЗаписи.ЗначениеНастройки = ОповещенияВключены;
		МенеджерЗаписи.Записать();		
		
		ПараметрыНовогоСообщения.ИДРедактируемогоСообщения = ПараметрыСообщения.СообщениеИД;
	КонецЕсли;
	
	ТекстОтвета = "<i>%1.</i>" + Символы.ПС;
	ТекстОтвета = СтрШаблон(ТекстОтвета, НСтр("ru = 'Настройка оповещений о новых визах';en = 'Setting up notifications about new visas'"));
	
	Если ОповещенияВключены Тогда
		СостояниеОповещений = КодEmoji("bell") + " " + НСтр("ru = 'Оповещения включены';en = 'Notifications are enable'");
	Иначе
		СостояниеОповещений = КодEmoji("no_bell") + " " + НСтр("ru = 'Оповещения отключены';en = 'Notifications are disable'");
	КонецЕсли;
	ТекстОтвета = ТекстОтвета + СостояниеОповещений;
	
	ПараметрыНовогоСообщения.Текст = ТекстОтвета;
	
	КонструкторКоманд = НовыйКонструкторПанелиКоманд();
	КонструкторКоманд.КоличествоКомандВСтроке = 2;
	
	ЗаголовокКоманды = НСтр("ru = 'Включить оповещения';en = 'Enable notification'");
	ДобавитьКоманду(КонструкторКоманд.Команды, "/ApprovNotify,EnableNotify", ЗаголовокКоманды, КодEmoji("bell"));
	
	ЗаголовокКоманды = НСтр("ru = 'Отключить оповещения';en = 'Disable notification'");
	ДобавитьКоманду(КонструкторКоманд.Команды, "/ApprovNotify,DisableNotify", ЗаголовокКоманды, КодEmoji("no_bell"));
	
	ПараметрыНовогоСообщения.КомандныйТекст = ТекстПанелиКоманд(КонструкторКоманд);
	ПараметрыНовогоСообщения.Гипертекст     = Истина;
	
	ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыНовогоСообщения);
	
КонецПроцедуры

#КонецОбласти 

Функция НовыеНастройкиПрокси(СтрНастройки) 

	Если СтрНастройки = Неопределено Тогда
		Возврат Неопределено;	
	КонецЕсли; 
	
	Если СтрНастройки.ВключитьПрокси Тогда
	
		Прокси = Новый ИнтернетПрокси();
		
		Если СтрНастройки.АутентификацияОС Тогда
			Прокси.Установить("https", СтрНастройки.Сервер, СтрНастройки.Порт);
		Иначе	
			Прокси.Установить("https", СтрНастройки.Сервер, СтрНастройки.Порт, СтрНастройки.Логин, СтрНастройки.Пароль, Ложь);
		КонецЕсли; 
		
	Иначе	
		Прокси = Неопределено;
	КонецЕсли; 

	Возврат Прокси;
	
КонецФункции // СформироватьНастройкиПрокси()

Функция НайтиЧат(НомерЧата)
	
	СтрЧата = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЧатИД", НомерЧата);
	Запрос.Текст = "ВЫБРАТЬ
	               |	бит_ЧатыTelegram.Ссылка КАК Чат,
	               |	бит_ЧатыTelegram.СтатусРегистрации
	               |ИЗ
	               |	Справочник.бит_ЧатыTelegram КАК бит_ЧатыTelegram
	               |ГДЕ
	               |	бит_ЧатыTelegram.ИД = &ЧатИД
	               |	И бит_ЧатыTelegram.ПометкаУдаления = ЛОЖЬ";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		СтрЧата = Новый Структура;
		СтрЧата.Вставить("СтатусРегистрации", Выборка.СтатусРегистрации);
		СтрЧата.Вставить("Чат"				, Выборка.Чат);
	КонецЕсли;
	
	Возврат СтрЧата;
	
КонецФункции

Процедура НоваяЗаписьВРеестрОбмена(стрСообщенияТелеграм)
	
	СообщениеИД 	   = стрСообщенияТелеграм.СообщениеИД;
	ВидЗапросаТелеграм = стрСообщенияТелеграм.ВидЗапросаТелеграм;
	Сообщение 		   = стрСообщенияТелеграм.Сообщение;
	Состояние 		   = стрСообщенияТелеграм.Состояние;
	ДатаОтправки 	   = стрСообщенияТелеграм.ДатаОтправки;
	
	Если стрСообщенияТелеграм.Свойство("Чат") Тогда
		
		ЧатТелеграм = стрСообщенияТелеграм.Чат;
		
	ИначеЕсли стрСообщенияТелеграм.Свойство("ЧатИД") Тогда
		
		стрЧата = НайтиЧат(стрСообщенияТелеграм.ЧатИД);
		Если стрЧата = Неопределено Тогда
		
			ЧатТелеграм = Справочники.бит_ЧатыTelegram.ПустаяСсылка();
		Иначе	
			ЧатТелеграм = стрЧата.Чат;
		КонецЕсли; 
		
	Иначе	
		ЧатТелеграм = Справочники.бит_ЧатыTelegram.ПустаяСсылка();
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.бит_РеестрОбменаСТелеграм.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Чат.Установить(ЧатТелеграм);
	НаборЗаписей.Отбор.ВидЗапросаТелеграм.Установить(ВидЗапросаТелеграм);
	НаборЗаписей.Отбор.СообщениеИД.Установить(СообщениеИД);
	
	НоваяЗапись              		= НаборЗаписей.Добавить();
	НоваяЗапись.Чат				 	= ЧатТелеграм;
	НоваяЗапись.ВидЗапросаТелеграм 	= ВидЗапросаТелеграм;
	НоваяЗапись.СообщениеИД 		= СообщениеИД;
	НоваяЗапись.Сообщение 		 	= Сообщение;
	НоваяЗапись.Состояние 		 	= Состояние;
	НоваяЗапись.ДатаОтправки 		= ДатаОтправки;
	НаборЗаписей.Записать();
	
	Если стрСообщенияТелеграм.Свойство("ОтветноеСообщение") Тогда
		
		Если стрСообщенияТелеграм.Свойство("ОтветноеСообщениеИД") Тогда
			СообщениеИД = стрСообщенияТелеграм.ОтветноеСообщениеИД;
		Иначе
			СообщениеИД = СообщениеИД+1;
		КонецЕсли;
		
		НаборЗаписей = РегистрыСведений.бит_РеестрОбменаСТелеграм.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Чат.Установить(ЧатТелеграм);
		НаборЗаписей.Отбор.ВидЗапросаТелеграм.Установить(ВидЗапросаТелеграм);
		НаборЗаписей.Отбор.СообщениеИД.Установить(СообщениеИД);
		
		НоваяЗапись              		= НаборЗаписей.Добавить();
		НоваяЗапись.Чат				 	= ЧатТелеграм;
		НоваяЗапись.ВидЗапросаТелеграм 	= ВидЗапросаТелеграм;
		НоваяЗапись.СообщениеИД 		= СообщениеИД;
		НоваяЗапись.Сообщение 		 	= стрСообщенияТелеграм.ОтветноеСообщение;
		НоваяЗапись.Состояние 		 	= Перечисления.бит_ВидыСостоянийТелеграм.Отправлено;
		НоваяЗапись.ДатаОтправки 		= ТекущаяДатаСеанса();
		НаборЗаписей.Записать();
		
	КонецЕсли;

КонецПроцедуры

Процедура ОповеститьСлужебныеЧаты(БотТелеграм, стрСообщенияТелеграм, ИмяПользователяЧата, ЭтоРегистрация=Ложь, ЭтоПомощь=Ложь)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Помощь"		, ЭтоПомощь);
	Запрос.УстановитьПараметр("Регистрация"	, ЭтоРегистрация);
	Запрос.УстановитьПараметр("Бот"			, БотТелеграм);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЧатыДляСлужебныхОповещений.Чат,
	               |	ЧатыДляСлужебныхОповещений.Чат.Наименование КАК Имя
	               |ИЗ
	               |	РегистрСведений.бит_ЧатыДляСлужебныхОповещенийТелеграм КАК ЧатыДляСлужебныхОповещений
	               |ГДЕ
	               |	ЧатыДляСлужебныхОповещений.Помощь = &Помощь
	               |	И ЧатыДляСлужебныхОповещений.Бот = &Бот
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ЧатыДляСлужебныхОповещений.Чат,
	               |	ЧатыДляСлужебныхОповещений.Чат.Наименование
	               |ИЗ
	               |	РегистрСведений.бит_ЧатыДляСлужебныхОповещенийТелеграм КАК ЧатыДляСлужебныхОповещений
	               |ГДЕ
	               |	ЧатыДляСлужебныхОповещений.Регистрация = &Регистрация
	               |	И ЧатыДляСлужебныхОповещений.Бот = &Бот";
				   
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		стрСообщенияТелеграмИсходящее = Новый Структура();
		
		Если ЭтоРегистрация Тогда
		
			ТекстСообщения = НСтр("ru='Чат %1 отправил запрос на регистрацию.';en='Chat %1 has sent a registration request.'");
			стрСообщенияТелеграмИсходящее.Вставить("ВидЗапросаТелеграм"	, Перечисления.бит_ВидыЗапросовТелеграм.РегистрацияЧата);
		Иначе	
			ТекстСообщения = НСтр("ru='Чату %1 нужна помощь.';en='Chat %1 needs help.'");
			стрСообщенияТелеграмИсходящее.Вставить("ВидЗапросаТелеграм"	, Перечисления.бит_ВидыЗапросовТелеграм.ПомощьЧату);
		КонецЕсли; 
		
		ТекстСообщения = СтрЗаменить(ТекстСообщения,"%1", ИмяПользователяЧата);
		
		стрСообщенияТелеграмИсходящее.Вставить("Состояние"			, Перечисления.бит_ВидыСостоянийТелеграм.ОжидаетОтправления);
		стрСообщенияТелеграмИсходящее.Вставить("Чат"				, Выборка.Чат);
		стрСообщенияТелеграмИсходящее.Вставить("СообщениеИД"		, стрСообщенияТелеграм.СообщениеИД+2);
		стрСообщенияТелеграмИсходящее.Вставить("Сообщение"			, ТекстСообщения);
		стрСообщенияТелеграмИсходящее.Вставить("ДатаОтправки"		, ТекущаяДатаСеанса());
		
		НоваяЗаписьВРеестрОбмена(стрСообщенияТелеграмИсходящее);
		
	КонецЦикла;
	
КонецПроцедуры

Функция НовоеИДСообщенияДляОтправки()

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	бит_РеестрОбменаСТелеграм.СообщениеИД КАК СообщениеИД
	|ИЗ
	|	РегистрСведений.бит_РеестрОбменаСТелеграм КАК бит_РеестрОбменаСТелеграм
	|
	|УПОРЯДОЧИТЬ ПО
	|	СообщениеИД УБЫВ";
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
	
		ИДСообщения = Выборка.СообщениеИД+1;
	
	КонецЦикла;
	
	ИДСообщения = ?(ЗначениеЗаполнено(ИДСообщения), ИДСообщения, 1);
	
	Возврат ИДСообщения;
	
КонецФункции

Процедура ОтправитьКонтактПоСлужебнымЧатам(БотТелеграм, НомерТелефона, ИмяПользователяЧата)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Бот", БотТелеграм);
	Запрос.Текст = "ВЫБРАТЬ
	|	ЧатыДляСлужебныхОповещений.Чат,
	|	ЧатыДляСлужебныхОповещений.Чат.ИД
	|ИЗ
	|	РегистрСведений.бит_ЧатыДляСлужебныхОповещенийТелеграм КАК ЧатыДляСлужебныхОповещений
	|ГДЕ
	|	ЧатыДляСлужебныхОповещений.Помощь = ИСТИНА
	|	И ЧатыДляСлужебныхОповещений.Бот = &Бот";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ОтправитьКонтактыБоту(БотТелеграм.Токен, Формат(Выборка.ЧатИД,"ЧГ=0"),НомерТелефона,ИмяПользователяЧата);
	КонецЦикла;	

КонецПроцедуры

Процедура ОтправитьКонтактыБоту(ТокенБота, ЧатИД, НомерТелефона, ИмяПользователя)
	
	СоединениеТелеграм = НовоеHTTPСоединение();
	
	ЗапросТелеграм = Новый HTTPЗапрос("/bot"+ТокенБота+"/sendContact?chat_id="+Формат(ЧатИД, "ЧГ=0")+"&phone_number="+НомерТелефона+"&first_name="+ИмяПользователя);
	РезультатЗапроса = СоединениеТелеграм.ОтправитьДляОбработки(ЗапросТелеграм);
	
КонецПроцедуры

Функция ДоступныеКомандыЧату(Чат)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Чат", Чат);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	""/"" + КомандаБоту.Наименование КАК Наименование,
	|	""/"" + КомандаБоту.НаименованиеВВерхнемРегистре КАК НаименованиеВРег,
	|	КомандаБоту.Определение КАК Определение,
	|	КомандаБоту.ТекстКлавиатуры КАК ТекстКлавиатуры,
	|	КомандаБоту.Запрос КАК Запрос,
	|	КомандаБоту.ИспользоватьТолькоПериод КАК ИспользоватьТолькоПериод,
	|	КомандаБоту.ИспользоватьНачалоИКонецПериода КАК ИспользоватьНачалоИКонецПериода,
	|	ДоступныеКоманды.НомерСтроки КАК НомерСтроки,
	|	КомандаБоту.Параметры.(
	|		Ссылка КАК Ссылка,
	|		НомерСтроки КАК НомерСтроки,
	|		Наименование КАК Наименование,
	|		Значение КАК Значение
	|	) КАК Параметры,
	|	КомандаБоту.ВидКоманды КАК ВидКоманды,
	|	КомандаБоту.ИсполняемыйОтчет КАК ИсполняемыйОтчет,
	|	КомандаБоту.Ссылка КАК Команда
	|ИЗ
	|	Справочник.бит_ЧатыTelegram.ДоступныеКоманды КАК ДоступныеКоманды
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_КомандыБотуТелеграм КАК КомандаБоту
	|		ПО ДоступныеКоманды.КомандаТелеграм = КомандаБоту.Ссылка
	|ГДЕ
	|	ДоступныеКоманды.Ссылка = &Чат";
				   
	ТаблицаКоманд = Запрос.Выполнить().Выгрузить();

	Возврат ТаблицаКоманд;
	
КонецФункции

Функция ДоступныеВариантыДатыНачала()

	ОписаниеСтрока = Новый ОписаниеТипов("Строка");
	
	ТаблицаВариантов = Новый ТаблицаЗначений;
	ТаблицаВариантов.Колонки.Добавить("Наименование"   ,ОписаниеСтрока);
	ТаблицаВариантов.Колонки.Добавить("ТекстКлавиатуры",ОписаниеСтрока);
	
	Для каждого эл Из ВариантСтандартнойДатыНачала Цикл
		
		Если эл = ВариантСтандартнойДатыНачала.НачалоЭтогоДня
			ИЛИ эл = ВариантСтандартнойДатыНачала.НачалоЭтойНедели
			ИЛИ эл = ВариантСтандартнойДатыНачала.НачалоЭтогоМесяца
			ИЛИ эл = ВариантСтандартнойДатыНачала.НачалоЭтогоКвартала
			ИЛИ эл = ВариантСтандартнойДатыНачала.НачалоЭтогоГода
			ИЛИ эл = ВариантСтандартнойДатыНачала.ПроизвольнаяДата
			Тогда
		
			СтрокаТаблицы = ТаблицаВариантов.Добавить();
			СтрокаТаблицы.Наименование 		= СтрЗаменить(эл, " ", "")+"/Дата";
			СтрокаТаблицы.ТекстКлавиатуры 	= эл;
		
		КонецЕсли; 
	
	КонецЦикла; 

	Возврат ТаблицаВариантов;
	
КонецФункции

Функция ДоступныеВариантыПериода()

	ОписаниеСтрока = Новый ОписаниеТипов("Строка");
	
	ТаблицаВариантов = Новый ТаблицаЗначений;
	ТаблицаВариантов.Колонки.Добавить("Наименование"   ,ОписаниеСтрока);
	ТаблицаВариантов.Колонки.Добавить("ТекстКлавиатуры",ОписаниеСтрока);
	
	Для каждого эл Из ВариантСтандартногоПериода Цикл
		
		Если эл = ВариантСтандартногоПериода.Сегодня
			ИЛИ эл = ВариантСтандартногоПериода.ЭтаНеделя
			ИЛИ эл = ВариантСтандартногоПериода.ЭтотМесяц
			ИЛИ эл = ВариантСтандартногоПериода.ЭтотКвартал
			ИЛИ эл = ВариантСтандартногоПериода.ЭтотГод
			ИЛИ эл = ВариантСтандартногоПериода.ПроизвольныйПериод
			Тогда
		
			СтрокаТаблицы = ТаблицаВариантов.Добавить();
			СтрокаТаблицы.Наименование 		= СтрЗаменить(эл, " ", "")+"/Период";
			СтрокаТаблицы.ТекстКлавиатуры 	= эл;
		
		КонецЕсли; 
	
	КонецЦикла; 

