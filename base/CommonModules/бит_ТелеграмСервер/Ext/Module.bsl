КонецФункции

Функция НовыйТекстКлавиатурыСДоступнымиКомандами(ТаблицаКнопок, ЭтоКоманды)

	КоличествоКоманд = ТаблицаКнопок.Количество();
	Если КоличествоКоманд = 0 Тогда
		Возврат Символы.ПС + НСтр("ru='Нет доступных команд вашему чату. Назначить их можно в справочнике Чаты Telegram.';
							      |en='None of the available commands to your chat. Assign them to be in the directory Chats Telegram.'");
	КонецЕсли; 
	
	Если ЭтоКоманды Тогда
	
		ТаблицаКнопок.Сортировать("ТекстКлавиатуры Убыв");
	
	КонецЕсли; 
	
	ТекстКлавиатуры = "&reply_markup={""inline_keyboard"":[[";
	
	Сч=0;
	счетчик = 0;
	КоличествоКомандВСтроке = 2;
	Если ЭтоКоманды Тогда
		МаксимальноеКоличествоКоманд = 9;
	Иначе	
		МаксимальноеКоличествоКоманд = 25;
	КонецЕсли; 
	МаксимальнаяДлинаТекстаКлавиатуры = 25;
	Для каждого СтрКоманды Из ТаблицаКнопок Цикл
		
		счетчик = счетчик + 1;
		Если счетчик < МаксимальноеКоличествоКоманд Тогда
			
			Если СтрДлина(СтрКоманды.ТекстКлавиатуры)>МаксимальнаяДлинаТекстаКлавиатуры Тогда
				Сч=КоличествоКомандВСтроке-1;
			КонецЕсли; 
			
			// Установка предопределенных декораций отдельным командам.
			Если СтрСравнить(СтрКоманды.Наименование, "/ApprovList") = 0 Тогда
				СтрКоманды.ТекстКлавиатуры = КодEmoji("bookmark_tabs") + " " + СтрКоманды.ТекстКлавиатуры;
			КонецЕсли;
			
			ТекстКлавиатуры = ТекстКлавиатуры + "{""text"":""" + СтрКоманды.ТекстКлавиатуры + """,""callback_data"":""" + СтрКоманды.Наименование + """}";
		Иначе 
			// АПК:1297-выкл Строковый параметр.
			ТекстКлавиатуры = ТекстКлавиатуры + "{""text"":""Больше команд"",""callback_data"":""/more""}]";
			// АПК:1297-вкл
			Прервать;
		КонецЕсли; 
		
		Если КоличествоКоманд=счетчик Тогда
		
			ТекстКлавиатуры = ТекстКлавиатуры + "]";
			Прервать;
		КонецЕсли; 
		
		Если КоличествоКомандВСтроке=Сч+1 Тогда
		
			ТекстКлавиатуры = ТекстКлавиатуры + "],[";
			Сч=0;
		Иначе
		
			ТекстКлавиатуры = ТекстКлавиатуры + ",";
			Сч=Сч+1;
		КонецЕсли; 
		
	КонецЦикла; 
	
	ТекстКлавиатуры = ТекстКлавиатуры + "]}";
	
	Возврат ТекстКлавиатуры;
	
КонецФункции

Функция ВыполнитьКомандуТелеграм(ИмяКоманды, Чат, МассивПараметров, ПараметрыИсходящихСообщений = Неопределено)

	ТекстОтвета = "";
	ТаблицаКоманд = ДоступныеКомандыЧату(Чат);
	
	СтрОтбор = Новый Структура("НаименованиеВРег", ВРег(ИмяКоманды)); 
	МассивСтрок = ТаблицаКоманд.НайтиСтроки(СтрОтбор);
	
	Если МассивСтрок.Количество()>0 Тогда
	
		СтрокаКоманды = МассивСтрок[0];
		
		Если СтрокаКоманды.ВидКоманды = Перечисления.бит_ВидыКомандТелеграм.Отчет Тогда
			
			ДанныеОтчета = Справочники.бит_КомандыБотуТелеграм.ДанныеИсполняемогоОтчета(СтрокаКоманды.Команда, Чат.Пользователь);
			
			ПараметрыНовогоСообщения = НовыеПараметрыИсходящегоСообщения();
			ПараметрыНовогоСообщения.ОтправкаФайла  = Истина;
			ПараметрыНовогоСообщения.ПараметрыФайла = ДанныеОтчета;
			
			ПараметрыИсходящихСообщений.МассивСообщений.Добавить(ПараметрыНовогоСообщения);
			
			ДобавитьПанельДоступныхКоманд(ПараметрыИсходящихСообщений);
			
		ИначеЕсли ЗначениеЗаполнено(СтрокаКоманды.Запрос) Тогда
			
			Если СтрокаКоманды.ИспользоватьТолькоПериод И МассивПараметров.Количество() = 0 Тогда
				
				ТекстОтвета = НСтр("ru='Выберите вариант для ';en='Select an option for'")
							  + СтрокаКоманды.Наименование
							  + НовыйТекстКлавиатурыСДоступнымиКомандами(ДоступныеВариантыДатыНачала(), Ложь);
				
			ИначеЕсли СтрокаКоманды.ИспользоватьНачалоИКонецПериода	И МассивПараметров.Количество() = 0 Тогда
				
				ТекстОтвета = НСтр("ru='Выберите вариант для ';en='Select an option for'")
							 + СтрокаКоманды.Наименование
							 + НовыйТекстКлавиатурыСДоступнымиКомандами(ДоступныеВариантыПериода(), Ложь);
								
			Иначе
				Попытка
					
					Запрос = Новый Запрос;
					Запрос.Текст = СтрокаКоманды.Запрос;
					
					// Приходящие параметры
					Для каждого парам Из МассивПараметров Цикл
						
						Для каждого стр Из парам Цикл
						
							Запрос.УстановитьПараметр(стр.Ключ, стр.Значение);
						
						КонецЦикла; 
					
					КонецЦикла; 
					
					// Параметры команды
					Для каждого парам Из СтрокаКоманды.Параметры Цикл
						
						Если СтрНайти(парам.Значение, "ТекущаяДатаСеанса()")>0 Тогда
						
							Запрос.УстановитьПараметр(парам.Наименование, НачалоДня(ТекущаяДатаСеанса()));
						Иначе	
							Запрос.УстановитьПараметр(парам.Наименование, парам.Значение);
						КонецЕсли; 
					КонецЦикла; 
					
					Результат = Запрос.Выполнить();
					Выборка = Результат.Выбрать();
					
					Пока Выборка.Следующий() Цикл
					
						Для каждого КолонкаЗапроса Из Результат.Колонки Цикл
							
							Если СтрНайти(КолонкаЗапроса.Имя, "Сумма")>0 Тогда
							
								ТекстОтвета = ТекстОтвета + " " + Формат(Выборка[КолонкаЗапроса.Имя], "ЧДЦ=2");
								
							Иначе	
								ТекстОтвета = ТекстОтвета + " " + Выборка[КолонкаЗапроса.Имя];
							КонецЕсли; 
						
						КонецЦикла; 
						
						ТекстОтвета = ТекстОтвета + Символы.ПС;
						
					КонецЦикла;
					
					Если Результат.Пустой() Тогда
					
						ТекстОтвета = НСтр("ru='Нет данных.';en='No data.'");
					
					КонецЕсли; 
					
				Исключение
					ТекстОтвета = НСтр("ru='Не удалось получить данные.';en='Unable to get data.'");
				КонецПопытки; 
			
			КонецЕсли; 
			
		Иначе	
			
			ТекстОтвета = НСтр("ru='Не заполнен текст запроса команды.';en='Not full text query commands.'");
		
		КонецЕсли; 
		
	КонецЕсли; 

	Возврат ТекстОтвета;
	
КонецФункции

Функция КодEmoji(Emoji)
	
	Если Emoji = "speech_balloon" Тогда
		Возврат "%F0%9F%92%AC";
	ИначеЕсли Emoji = "bookmark_tabs" Тогда
		Возврат "%F0%9F%93%91";
	ИначеЕсли Emoji = "arrow_forward" Тогда
		Возврат "%E2%96%B6";
	ИначеЕсли Emoji = "arrow_backward" Тогда
		Возврат "%E2%97%80";
	ИначеЕсли Emoji = "fast_forward" Тогда
		Возврат "%E2%8F%A9";
	ИначеЕсли Emoji = "rewind" Тогда
		Возврат "%E2%8F%AA";
	ИначеЕсли Emoji = "clipboard" Тогда
		Возврат "%F0%9F%93%8B";
	ИначеЕсли Emoji = "memo" Тогда
		Возврат "%F0%9F%93%9D";
	ИначеЕсли Emoji = "check_mark" Тогда
		Возврат "%E2%9C%94";
	ИначеЕсли Emoji = "ticket" Тогда
		Возврат "%F0%9F%8E%AB";
	ИначеЕсли Emoji = "multiplication_x" Тогда
		Возврат "%E2%9C%96";
	ИначеЕсли Emoji = "paperclip" Тогда
		Возврат "%F0%9F%93%8E";
	ИначеЕсли Emoji = "bell" Тогда
		Возврат "%F0%9F%94%94";
	ИначеЕсли Emoji = "no_bell" Тогда
		Возврат "%F0%9F%94%95";
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция НовыйКонструкторПанелиКоманд()
	
	КонструкторКоманд = Новый Структура;
	КонструкторКоманд.Вставить("Команды",                 Новый Массив);
	КонструкторКоманд.Вставить("КомандыНавигации",        Новый Массив);
	КонструкторКоманд.Вставить("КоличествоКомандВСтроке", 5); // Максимум 8 - ограничение Telegram.
	
	Возврат КонструкторКоманд;
	
КонецФункции

Функция НоваяКоманда()
	
	СтруктураКоманды = Новый Структура;
	СтруктураКоманды.Вставить("ДанныеОтзыва", "");
	СтруктураКоманды.Вставить("Текст",        "");
	СтруктураКоманды.Вставить("Emoji",        "");
	
	Возврат СтруктураКоманды;
	
КонецФункции

Процедура ДобавитьКоманду(МассивКоманд, ДанныеНажатия, Представление, Картинка = "")
	
	СтруктураКоманды = НоваяКоманда();
	СтруктураКоманды.ДанныеОтзыва = ДанныеНажатия;
	СтруктураКоманды.Текст        = Представление;
	СтруктураКоманды.Emoji        = Картинка;
	
	МассивКоманд.Добавить(СтруктураКоманды);
	
КонецПроцедуры

Функция ТекстПанелиКоманд(КонструкторКоманд)
	
	ТелоКоманд          = ТекстГруппыКоманд(КонструкторКоманд, КонструкторКоманд.Команды);
	ТелоКомандНавигации = ТекстГруппыКоманд(КонструкторКоманд, КонструкторКоманд.КомандыНавигации);
	
	Если НЕ ПустаяСтрока(ТелоКоманд)
		И НЕ ПустаяСтрока(ТелоКомандНавигации) Тогда
		ТелоКомандОбщее = ТелоКоманд + "," + ТелоКомандНавигации;
	Иначе
		ТелоКомандОбщее = ТелоКоманд + ТелоКомандНавигации;
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(ТелоКомандОбщее) Тогда
		ТелоКомандОбщее = ИсключитьСлужебныеСимволы(ТелоКомандОбщее);
		ТелоКомандОбщее = "&reply_markup={""inline_keyboard"":[" + ТелоКомандОбщее + "]}";
	КонецЕсли;
	
	Возврат ТелоКомандОбщее;
	
КонецФункции

Функция ТекстГруппыКоманд(КонструкторКоманд, ГруппаКоманд)
	
	Если ГруппаКоманд.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	ШаблонКоманды    = "{""text"":""%1"",""callback_data"":""%2""}";
	ТелоГруппыКоманд = "";
	
	ПорядковыйНомер = 1;
	ТелоКоманд      = "";
	
	Для каждого Команда Из ГруппаКоманд Цикл
		
		Если НЕ ПустаяСтрока(ТелоКоманд) Тогда
			ТелоКоманд = ТелоКоманд + ",";
		КонецЕсли;
		
		ПредставлениеКоманды = Команда.Текст;
		Если НЕ ПустаяСтрока(Команда.Emoji) Тогда
			ПредставлениеКоманды = Команда.Emoji + " " + ПредставлениеКоманды;	
		КонецЕсли;		
		
		ТелоКоманд = ТелоКоманд + СтрШаблон(ШаблонКоманды, ПредставлениеКоманды, Команда.ДанныеОтзыва);
		
		Если ПорядковыйНомер % КонструкторКоманд.КоличествоКомандВСтроке = 0 Тогда
			ТелоГруппыКоманд = ТелоГруппыКоманд + ?(ПустаяСтрока(ТелоГруппыКоманд), "", ",")
								+ "[" + ТелоКоманд + "]";
			ТелоКоманд      = "";
		КонецЕсли;
		
		ПорядковыйНомер = ПорядковыйНомер + 1;
	КонецЦикла;
	
	Если НЕ ПустаяСтрока(ТелоКоманд) Тогда
		ТелоГруппыКоманд = ТелоГруппыКоманд + ?(ПустаяСтрока(ТелоГруппыКоманд), "", ",")
								+ "[" + ТелоКоманд + "]";
	КонецЕсли;

	Возврат ТелоГруппыКоманд;
	
КонецФункции

#КонецОбласти 
