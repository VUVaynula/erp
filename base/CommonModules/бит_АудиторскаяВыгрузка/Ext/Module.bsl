#Область ПрограммныйИнтерфейс

// Получает таблицу правил регистрации объекта для заданного плана обмена.
//
// Параметры:
//  ИмяПланаОбмена   - Строка - имя плана обмена как оно задано в конфигураторе.
//  ПолноеИмяОбъекта - Строка - полное имя объекта метаданных,
//                   для которого необходимо получить правила регистрации.
//
// Возвращаемое значение:
//   ТаблицаЗначений - таблица правил регистрации объекта по заданному плану обмена.
//
Функция ПравилаРегистрацииОбъекта(Знач ИмяПланаОбмена, Знач ПолноеИмяОбъекта) Экспорт
	
	// АПК:277-выкл
	ПравилаРегистрацииОбъектовПланаОбмена = ОбменДаннымиСобытия.ПравилаРегистрацииОбъектовПланаОбмена(ИмяПланаОбмена);
	// АПК:277-вкл
	
	ТаблицаПравилРегистрации = ПравилаРегистрацииОбъектовПланаОбмена.Скопировать(Новый Структура("ОбъектМетаданныхИмя", ПолноеИмяОбъекта));
	ДополнитьСтандартнымиПравиламиРегистрации(ИмяПланаОбмена, ПолноеИмяОбъекта, ТаблицаПравилРегистрации);
	
	Возврат ТаблицаПравилРегистрации;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура бит_АудиторскаяВыгрузкаРегистрацияПередЗаписью(Источник, Отказ) Экспорт
	
	МетаданныеИсточника = Источник.Метаданные();
	ПолноеИмяМетаданных = МетаданныеИсточника.ПолноеИмя();
	Если НЕ бит_АудиторскаяВыгрузкаПовтИсп.ВходитВСоставАудиторскойВыгрузки(ПолноеИмяМетаданных) Тогда
		Возврат;
	КонецЕсли;
	
	ОбменДаннымиСобытия.МеханизмРегистрацииОбъектовПередЗаписью("бит_АудиторскаяВыгрузка", Источник, Отказ);
	
КонецПроцедуры

