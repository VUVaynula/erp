// Функция возвращает номер версии выбранной системы лицензирования.
// 
// Возвращаемое значение:
//  Число - номер версии системы лицензирования 1 или 2.
//
Функция СистемаЛицензированияБФ() Экспорт
	
	Результат = 1;
	СистемаЛицензирования20 = Константы.бит_СистемаЛицензирования20.Получить();
	Если СистемаЛицензирования20 Тогда
		Результат = 2;	
	КонецЕсли;
	Возврат Результат;
	
КонецФункции

// Возвращает кодировку для передачи файлов вложений хранимых в формате UTF-8 without BOM.
//
// Возвращаемое значение:
//  Строка.
//
Функция КодировкаФайловВложенийБезСигнатуры() Экспорт
	
	КодировкаФайлов = Константы.бит_КодировкаФайловВложенийБезСигнатуры.Получить();
	Если КодировкаФайлов.Пустая() Тогда
		КодировкаФайлов = Перечисления.бит_КодировкиФайловВложений.CESU8;
	КонецЕсли;
	
	Если КодировкаФайлов = Перечисления.бит_КодировкиФайловВложений.UTF8 Тогда
		Возврат "UTF-8";
	ИначеЕсли КодировкаФайлов = Перечисления.бит_КодировкиФайловВложений.UTF8_WithoutBOM Тогда
		Возврат "utf-8_WithoutBOM";
	КонецЕсли;
		
	Возврат "CESU-8";
	
КонецФункции

