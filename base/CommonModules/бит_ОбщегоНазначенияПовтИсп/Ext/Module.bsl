// Функция получает модуль лицензирования.
// 
// Возвращаемое значение:
//   ОбщийМодуль
//   МодульМенеджераОбъекта
// 
Функция МодульЛицензированияБФ() Экспорт
	
	ИмяМодуля = "бит_ЛицензированиеБФБП";
	Если ЭтоERP() Тогда
		ИмяМодуля = "бит_ЛицензированиеБФУП";
	ИначеЕсли ЭтоКомплекснаяАвтоматизация() Тогда
		ИмяМодуля = "бит_ЛицензированиеБФКА";
	ИначеЕсли ЭтоУТ() Тогда
		ИмяМодуля = "бит_ЛицензированиеБФУТ";
	КонецЕсли;
	
	Возврат ОбщегоНазначения.ОбщийМодуль(ИмяМодуля);
	
КонецФункции

// Возвращает массив имен измерений, имеющих составной тип.
//
// Параметры:
//  ПолноеИмяМетаданного - Строка.
// 
// Возвращаемое значение:
//  Массив.
//
Функция ИзмеренияСоставногоТипа(ПолноеИмяМетаданного) Экспорт
	
	ИзмеренияСоставногоТипа = Новый Массив;
	
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(ПолноеИмяМетаданного);
	Для каждого Измерение Из ОбъектМетаданных.Измерения Цикл
		Если Измерение.Тип.Типы().Количество() > 1 Тогда
			ИзмеренияСоставногоТипа.Добавить(Измерение.Имя);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ИзмеренияСоставногоТипа;
	
КонецФункции

// Возвращает объект системы по полному имени метаданного.
//
// Параметры:
//  ИмяОбъектаПолное - Строка.
// 
// Возвращаемое значение:
//  СправочникСсылка.бит_ОбъектыСистемы.
//
Функция ОбъектСистемыПоПолномуИмени(ИмяОбъектаПолное) Экспорт
	
	Возврат Справочники.бит_ОбъектыСистемы.НайтиПоРеквизиту("ИмяОбъектаПолное", ИмяОбъектаПолное);
	
КонецФункции

// Возвращает объект метаданных по объекту системы.
//
// Параметры:
//  ОбъектСистемы - СправочникСсылка.бит_ОбъектыСистемы - Объект системы.
// 
// Возвращаемое значение:
//  ОбъектМетаданных.
//
Функция ОбъектМетаданныхПоОбъектуСистемы(ОбъектСистемы) Экспорт
	
	ИмяОбъектаПолное = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектСистемы, "ИмяОбъектаПолное");
	Возврат Метаданные.НайтиПоПолномуИмени(ИмяОбъектаПолное);
	
КонецФункции

// Проверяет отключение механизма визирования для объекта.
//
// Параметры:
//  Объект - Строка, СправочникСсыка.бит_ОбъектыСистемы.
// 
// Возвращаемое значение:
//  Булево.
//
Функция МеханизмВизированияОтключен(Объект) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Объект) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТипОбъекта = ТипЗнч(Объект);
	Если ТипОбъекта = Тип("Строка") Тогда
		ОбъектСистемы = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(Объект);
	ИначеЕсли ТипОбъекта = Тип("СправочникСсылка.бит_ОбъектыСистемы") Тогда
		ОбъектСистемы = Объект;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	бит_НастройкиОбъектовВизирования.ОбъектСистемы КАК ОбъектСистемы
	|ИЗ
	|	РегистрСведений.бит_НастройкиОбъектовВизирования КАК бит_НастройкиОбъектовВизирования
	|ГДЕ
	|	бит_НастройкиОбъектовВизирования.ОбъектСистемы = &ОбъектСистемы
	|	И бит_НастройкиОбъектовВизирования.ИспользоватьВизирование";
	Запрос.УстановитьПараметр("ОбъектСистемы", ОбъектСистемы);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Пустой();
	
КонецФункции

// Возвращает настройки для объекта визирования из регистра сведений бит_НастройкиОбъектовВизирования.
// 
// Параметры:
//  Объект - ДокументОбъект; СправочникОбъект; ДокументСсылка; СправочникСсылка.
// 
// Возвращаемое значение:
//   Структура
//		* ИспользоватьВизирование - Булево, 
//		* РежимОбновленияВиз      - ПеречислениеСсылка.бит_РежимыОбновленияПеречняВиз.
//
Функция НастройкиОбъектаВизирования(Объект) Экспорт
	
	Настройки = Новый Структура;
	Настройки.Вставить("ИспользоватьВизирование", Ложь);
	Настройки.Вставить("РежимОбновленияВиз",      Перечисления.бит_РежимыОбновленияПеречняВиз.ОбновлятьПриПерепроведении);
	Настройки.Вставить("РежимКонтроляВложений",   Перечисления.бит_ВидыКонтроля.НеКонтролировать);
	
	Если НЕ ЗначениеЗаполнено(Объект) Тогда
		Возврат Настройки;
	КонецЕсли;
	
	ТипОбъекта = ТипЗнч(Объект);
	Если ТипОбъекта = Тип("Строка") Тогда
		ОбъектСистемы = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(Объект);
	ИначеЕсли ТипОбъекта = Тип("СправочникСсылка.бит_ОбъектыСистемы") Тогда
		ОбъектСистемы = Объект;
	Иначе
		Возврат Настройки;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	бит_НастройкиОбъектовВизирования.ОбъектСистемы КАК ОбъектСистемы,
	|	бит_НастройкиОбъектовВизирования.ИспользоватьВизирование КАК ИспользоватьВизирование,
	|	ВЫБОР
	|		КОГДА бит_НастройкиОбъектовВизирования.РежимОбновленияВиз = ЗНАЧЕНИЕ(Перечисление.бит_РежимыОбновленияПеречняВиз.ПоУмолчанию)
	|			ТОГДА &РежимОбновленияВизПоУмолчанию
	|		ИНАЧЕ бит_НастройкиОбъектовВизирования.РежимОбновленияВиз
	|	КОНЕЦ КАК РежимОбновленияВиз,
	|	ВЫБОР
	|		КОГДА бит_НастройкиОбъектовВизирования.РежимКонтроляВложений = ЗНАЧЕНИЕ(Перечисление.бит_ВидыКонтроля.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидыКонтроля.НеКонтролировать)
	|		ИНАЧЕ бит_НастройкиОбъектовВизирования.РежимКонтроляВложений
	|	КОНЕЦ КАК РежимКонтроляВложений
	|ИЗ
	|	РегистрСведений.бит_НастройкиОбъектовВизирования КАК бит_НастройкиОбъектовВизирования
	|ГДЕ
	|	бит_НастройкиОбъектовВизирования.ОбъектСистемы = &ОбъектСистемы";
	Запрос.УстановитьПараметр("ОбъектСистемы", ОбъектСистемы);
	Запрос.УстановитьПараметр("РежимОбновленияВизПоУмолчанию",
								бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_РежимОбновленияПеречняВиз"));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Настройки, Выборка);
	КонецЕсли;
	
	Возврат Настройки;
	
КонецФункции

