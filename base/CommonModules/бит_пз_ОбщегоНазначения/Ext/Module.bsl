
#Область СлужебныйПрограммныйИнтерфейс

//  Функция создает документ ЗаказПоставщику. 
// 
// Параметры:
// 	ДокументОснование - ДокументСсылка.бит_пз_ЗаявкаНаЗатраты, ДокументСсылка.бит_пз_СводнаяЗаявкаНаЗатраты.
// 
// Возвращаемое значение:
//  Структура.
// 
Функция СоздатьДокументЗаказПоставщику(ДокументОснование) Экспорт 

	ДокОб = Документы.ЗаказПоставщику.СоздатьДокумент();
	ДокОб.Дата = ТекущаяДата();
	ДокОб.Организация 			= ДокументОснование.Организация;
	ДокОб.Контрагент			= ДокументОснование.Контрагент;
	ДокОб.Договор 				= ДокументОснование.Договор;
	ДокОб.Валюта				= ДокументОснование.ВалютаДокумента;
	ДокОб.Склад 				= ДокументОснование.Склад;
	ДокОб.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика;
	ДокОб.Статус 				= Перечисления.СтатусыЗаказовПоставщикам.Согласован;
	ДокОб.ЖелаемаяДатаПоступления = ДокументОснование.ЖелаемаяДатаПоступления;
	
	Если ЗначениеЗаполнено(ДокОб.Контрагент) Тогда	
		ДокОб.Партнер = ДокОб.Контрагент.Партнер;	
	КонецЕсли; 
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.бит_пз_ЗаявкаНаЗатраты") Тогда	
		ТабличнаяЧастьОснование = ДокументОснование.Товары.Выгрузить();		
	Иначе	
		ТабличнаяЧастьОснование = ДокументОснование.ЗаявкиНаЗатраты.Выгрузить();
	КонецЕсли; 
	
	ДокОб.Товары.Загрузить(ТабличнаяЧастьОснование);	
	Для каждого СтрТовары Из ДокОб.Товары Цикл	
		СтрТовары.КоличествоУпаковок = СтрТовары.Количество;	
	КонецЦикла; 
	
	Успешно = бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ДокОб, РежимЗаписиДокумента.Запись);	
	Если Успешно Тогда
		
		// Заполним дополнительные аналитики документа.
		НаборЗаписей = РегистрыСведений.бит_ДополнительныеАналитики.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Объект.Установить(ДокОб.Ссылка);
		
		Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.бит_пз_ЗаявкаНаЗатраты") Тогда
		
			НоваяЗапись = НаборЗаписей.Добавить();
			НоваяЗапись.Объект    = ДокОб.Ссылка;	
			НоваяЗапись.Аналитика = ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ЗаявкаНаЗатраты;
			НоваяЗапись.ЗначениеАналитики = ДокументОснование;
			
		ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.бит_пз_СводнаяЗаявкаНаЗатраты") Тогда	
			
			НоваяЗапись = НаборЗаписей.Добавить();
			НоваяЗапись.Объект    = ДокОб.Ссылка;	
			НоваяЗапись.Аналитика = ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.СводнаяЗаявкаНаЗатраты;
			НоваяЗапись.ЗначениеАналитики = ДокументОснование;
			
		КонецЕсли; 
		
		// Установка запрета на автоматическое перезаполнение аналитик
		СтруктураПараметров = Новый Структура("ЗапретитьПерезаполнениеАналитик", Истина);
		бит_МеханизмДопИзмерений.ЗаписатьДополнительныеПараметрыОбъекта(ДокОб.Ссылка, СтруктураПараметров);
		
		Если Не бит_ОбщегоНазначения.ЗаписатьНаборЗаписейРегистра(НаборЗаписей) Тогда
			Отказ = Истина;
		КонецЕсли; 																			
		
	КонецЕсли; 
	
	СтрукВоз = Новый Структура("Ссылка, ФормаОткрытия", ДокОб.Ссылка, "ФормаДокумента");
	
	Возврат СтрукВоз;
	
КонецФункции // СоздатьДокументЗаказПоставщику()

#КонецОбласти 	
