			СтрокаОстатка.Сумма 	 = СтрокаОстатка.Сумма - Сумма;
			СтрокаОстатка.Количество = СтрокаОстатка.Количество - Количество;
			
			НоваяСтрока = ТаблицаИсполнениеБюджета.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДокумента);
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОстатка, "Сценарий, СценарийКонтролируемый, РежимКонтроля");
			НоваяСтрока.СуммаСценарийИсполнение 	 = Сумма;
			НоваяСтрока.КоличествоСценарийИсполнение = Количество;
			
			// Все списано.
			Если ОсталосьПогаситьСумма <= 0 И ОсталосьПогаситьКоличество <= 0 Тогда
				Прервать;			
			КонецЕсли;
		КонецЦикла;
		
		// Нераспределенное исполнение добавим отдельной строкой в таблицу исполнения бюджета.
		Если ОсталосьПогаситьСумма > 0 ИЛИ ОсталосьПогаситьКоличество > 0 Тогда
			НоваяСтрока = ТаблицаИсполнениеБюджета.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДокумента);
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизиты, "СценарийКонтролируемый");
			НоваяСтрока.СуммаСценарийСверхЛимита 	  = ОсталосьПогаситьСумма;
			НоваяСтрока.КоличествоСценарийСверхЛимита = ОсталосьПогаситьКоличество;
		КонецЕсли;
		
		Если НЕ Реквизиты.СверхБюджета И КонтролироватьБюджет И СтрокаДокумента.КонтролироватьПоСтатье Тогда
			
			КонтролироватьСумму		 = СтрокаДокумента.КонтролироватьСумму;
			КонтролироватьКоличество = СтрокаДокумента.КонтролироватьКоличество;
			
			Если (ОсталосьПогаситьСумма > 0 И КонтролироватьСумму) 
			 ИЛИ (ОсталосьПогаситьКоличество > 0 И КонтролироватьКоличество) Тогда
				СтрокаТаблицыОшибок = ТаблицаОшибок.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТаблицыОшибок, СтрокаДокумента);
				СтрокаТаблицыОшибок.Сумма					   = СводныйОстатокСумма;
				СтрокаТаблицыОшибок.Количество				   = СводныйОстатокКоличество;
				СтрокаТаблицыОшибок.ОсталосьПогаситьСумма 	   = ОсталосьПогаситьСумма;
				СтрокаТаблицыОшибок.ОсталосьПогаситьКоличество = ОсталосьПогаситьКоличество;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла; 
	
	Для каждого СтрокаТаблицы Из ТаблицаОшибок Цикл
		Если СтрокаТаблицы.КонтролироватьСумму И СтрокаТаблицы.ОсталосьПогаситьСумма > 0 Тогда
			ВывестиСообщениеОПривышенииСуммыЛимитов(СтрокаТаблицы.Сумма, 
				СтрокаТаблицы.ОсталосьПогаситьСумма, Реквизиты, 
				СтрокаТаблицы.ИмяСписка, СтрокаТаблицы.СинонимСписка, СтрокаТаблицы.НомерСтроки, Отказ);
		КонецЕсли;
		Если СтрокаТаблицы.КонтролироватьКоличество И СтрокаТаблицы.ОсталосьПогаситьКоличество > 0 Тогда
			ВывестиСообщениеОПривышенииКоличестваЛимитов(СтрокаТаблицы.Количество, 
				СтрокаТаблицы.ОсталосьПогаситьКоличество, Реквизиты, 
				СтрокаТаблицы.ИмяСписка, СтрокаТаблицы.СинонимСписка, СтрокаТаблицы.НомерСтроки, Отказ);
		КонецЕсли;	
	КонецЦикла;
	
	Если ЭтоАдресВременногоХранилища(АдресВХранилище) И ТаблицаОшибок.Количество() > 0 Тогда
		ПроблемныеСтроки = ТаблицаОшибок.СкопироватьКолонки();
		Для каждого СтрокаТаблицы Из ТаблицаОшибок Цикл
			НоваяСтрока = ПроблемныеСтроки.Добавить();	
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
			НоваяСтрока.Сумма 	   = НоваяСтрока.ОсталосьПогаситьСумма - Мин(0, НоваяСтрока.Сумма);
			НоваяСтрока.Количество = НоваяСтрока.ОсталосьПогаситьКоличество - Мин(0, НоваяСтрока.Количество);
		КонецЦикла; 

		Группировки = ПереченьИзмеренийКонтроля();
		ПроблемныеСтроки.Свернуть(Группировки + ", Период", "Сумма, Количество");

		Результат = Новый Структура; 
		Результат.Вставить("ЕстьДанныеКорректировки", ПроблемныеСтроки.Количество() > 0);
		Результат.Вставить("АдресКорректировки", ПоместитьВоВременноеХранилище(ПроблемныеСтроки, 
			Новый УникальныйИдентификатор()));
		ПоместитьВоВременноеХранилище(Результат, АдресВХранилище);
	КонецЕсли;

КонецПроцедуры

Процедура ОтметитьВозвратЛимита(ИсполнениеБюджета, ТаблицаОстатки, ТаблицаИсполнениеБюджета, Реквизиты, Отказ)

	Измерения = ПереченьИзмеренийКонтроля();
	
	КонтролироватьВозвратЛимита = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Реквизиты, 
									"КонтролироватьВозвратЛимита", Ложь); 
	
	ТаблицаОшибок = ИсполнениеБюджета.СкопироватьКолонки();
	ТаблицаОшибок.Колонки.Добавить("ОсталосьПогаситьСумма", Новый ОписаниеТипов("Число"));
	ТаблицаОшибок.Колонки.Добавить("ОсталосьПогаситьКоличество", ОбщегоНазначения.ОписаниеТипаЧисло(15, 3));
	
	ИмяСписка 	= "";
	НомерСтроки = "";

	Для каждого СтрокаДокумента Из ИсполнениеБюджета Цикл
		///////////////////////////////////////////////////////////////////////////////////////////////
		// Этот фрагмент кода оставлен для групп поддержки, работающих у заказчика.
		// Если новая модель с более жесткими настройками УКЗ не вписывается в бизнесмодель заказчика,
		// можно попробовать этот вариант.
		//Если СтрокаДокумента.ИмяСписка = ИмяСписка И  СтрокаДокумента.НомерСтроки = НомерСтроки Тогда
		//	// В результате некорректной настройки УКЗ к строке ТЧ документа может быть подобрано
		//	// несколько строк настройки. Это прибодит к дублированию строк ТЧ.
		//	// Принято решение, что в таком случае обрабатывается ситуация, где разрезов контроля максимальное. 
		//	Продолжить;		
		//КонецЕсли;
		///////////////////////////////////////////////////////////////////////////////////////////////
		
		ИмяСписка	= СтрокаДокумента.ИмяСписка;
		НомерСтроки = СтрокаДокумента.НомерСтроки;

		ОсталосьПогаситьСумма	   = СтрокаДокумента.Сумма;
		ОсталосьПогаситьКоличество = СтрокаДокумента.Количество;
		
		Если ОсталосьПогаситьСумма > 0 ИЛИ ОсталосьПогаситьКоличество > 0 Тогда
			Отбор = Новый Структура(Измерения);
			Отбор.Вставить("Период");		
			ЗаполнитьЗначенияСвойств(Отбор, СтрокаДокумента);
			РезультатПоиска = ТаблицаОстатки.НайтиСтроки(Отбор);			
		Иначе
			РезультатПоиска = Новый Массив;
		КонецЕсли;
			
		СводныйОстатокСумма 	 = 0;
		СводныйОстатокКоличество = 0;
		
		Для каждого СтрокаОстатка Из РезультатПоиска Цикл
			
			СводныйОстатокСумма = СтрокаОстатка.СуммаСверхЛимита + СтрокаОстатка.СуммаИсполнение
								+ СводныйОстатокСумма;
			СводныйОстатокКоличество = СтрокаОстатка.КоличествоСверхЛимита + СтрокаОстатка.КоличествоИсполнение
									 + СводныйОстатокКоличество;
			
			// Количество и сумма - не связанные ресурсы. 
			// Поэтому списываются непосредственно и коэффициент списания не вычисляется.
			
			// Списываем "сверх лимита".
			Сумма 	   = 0;
			Количество = 0;

			Если ОсталосьПогаситьСумма > 0 И СтрокаОстатка.СуммаСверхЛимита > 0 Тогда
				Сумма = Мин(ОсталосьПогаситьСумма, СтрокаОстатка.СуммаСверхЛимита);
				ОсталосьПогаситьСумма = ОсталосьПогаситьСумма - Сумма;
			КонецЕсли;
			
			Если ОсталосьПогаситьКоличество > 0 И СтрокаОстатка.КоличествоСверхЛимита > 0 Тогда
				Количество = Мин(ОсталосьПогаситьКоличество, СтрокаОстатка.КоличествоСверхЛимита);
				ОсталосьПогаситьКоличество = ОсталосьПогаситьКоличество - Количество;
			КонецЕсли;
			
			Если Сумма <> 0 ИЛИ Количество <> 0 Тогда
				СтрокаОстатка.СуммаСверхЛимита 	 	= СтрокаОстатка.СуммаСверхЛимита - Сумма;
				СтрокаОстатка.КоличествоСверхЛимита = СтрокаОстатка.КоличествоСверхЛимита - Количество;
				
				НоваяСтрока = ТаблицаИсполнениеБюджета.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДокумента);
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОстатка, "Сценарий, СценарийКонтролируемый, РежимКонтроля");
				НоваяСтрока.СуммаСценарийСверхЛимита  	  = - Сумма;
				НоваяСтрока.КоличествоСценарийСверхЛимита = - Количество;
			КонецЕсли;
			
			// Списываем "исполнение".
			Сумма 	   = 0;
			Количество = 0;

			Если ОсталосьПогаситьСумма > 0 И СтрокаОстатка.СуммаИсполнение > 0 Тогда
				Сумма = Мин(ОсталосьПогаситьСумма, СтрокаОстатка.СуммаИсполнение);
				ОсталосьПогаситьСумма = ОсталосьПогаситьСумма - Сумма;
			КонецЕсли;
			
			Если ОсталосьПогаситьКоличество > 0 И СтрокаОстатка.КоличествоИсполнение > 0 Тогда
				Количество = Мин(ОсталосьПогаситьКоличество, СтрокаОстатка.КоличествоИсполнение);
				ОсталосьПогаситьКоличество = ОсталосьПогаситьКоличество - Количество;
			КонецЕсли;
			
			Если Сумма <> 0 ИЛИ Количество <> 0 Тогда
				СтрокаОстатка.СуммаИсполнение 	   = СтрокаОстатка.СуммаИсполнение - Сумма;
				СтрокаОстатка.КоличествоИсполнение = СтрокаОстатка.КоличествоИсполнение - Количество;
				
				НоваяСтрока = ТаблицаИсполнениеБюджета.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДокумента);
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОстатка, "Сценарий, СценарийКонтролируемый, РежимКонтроля");
				НоваяСтрока.СуммаСценарийИсполнение 	 = - Сумма;
				НоваяСтрока.КоличествоСценарийИсполнение = - Количество;
			КонецЕсли;
			
			// Все списано.
			Если ОсталосьПогаситьСумма <= 0 И ОсталосьПогаситьКоличество <= 0 Тогда
				Прервать;			
			КонецЕсли;
		КонецЦикла;
		
		Если (ОсталосьПогаситьСумма > 0 ИЛИ ОсталосьПогаситьКоличество > 0)
		   И КонтролироватьВозвратЛимита Тогда
			СтрокаТаблицыОшибок = ТаблицаОшибок.Добавить();
			СтрокаТаблицыОшибок = ТаблицаОшибок.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицыОшибок, СтрокаДокумента);
			СтрокаТаблицыОшибок.Сумма					   = СводныйОстатокСумма;
			СтрокаТаблицыОшибок.Количество				   = СводныйОстатокКоличество;
			СтрокаТаблицыОшибок.ОсталосьПогаситьСумма 	   = ОсталосьПогаситьСумма;
			СтрокаТаблицыОшибок.ОсталосьПогаситьКоличество = ОсталосьПогаситьКоличество;
		КонецЕсли;
	КонецЦикла; 
	
	Для каждого СтрокаТаблицы Из ТаблицаОшибок Цикл
		Если СтрокаТаблицы.ОсталосьПогаситьСумма > 0 Тогда
			ВывестиСообщениеОПривышенииСуммыЛимитов(СтрокаТаблицы.Сумма, 
				СтрокаТаблицы.ОсталосьПогаситьСумма, Реквизиты, 
				СтрокаТаблицы.ИмяСписка, СтрокаТаблицы.СинонимСписка, СтрокаТаблицы.НомерСтроки, Отказ);
		КонецЕсли;
		Если СтрокаТаблицы.ОсталосьПогаситьКоличество > 0 Тогда
			ВывестиСообщениеОПривышенииКоличестваЛимитов(СтрокаТаблицы.Количество, 
				СтрокаТаблицы.ОсталосьПогаситьКоличество, Реквизиты, 
				СтрокаТаблицы.ИмяСписка, СтрокаТаблицы.СинонимСписка, СтрокаТаблицы.НомерСтроки, Отказ);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

Процедура ОтметитьПрогнозИсполнениеБюджета(ИсполнениеБюджета, ТаблицаОстатки, ТаблицаИсполнениеБюджета, Реквизиты)

	Измерения			 = ПереченьИзмеренийКонтроля();
	КонтролироватьБюджет = Реквизиты.КонтролироватьБюджет;
		
	ИмяСписка 	= "";
	НомерСтроки = "";
	
	ТаблицаИсполнениеБюджета.Колонки.Добавить("СуммаКонОстаток", ОбщегоНазначения.ОписаниеТипаЧисло(15, 2));
	ТаблицаИсполнениеБюджета.Колонки.Добавить("КоличествоКонОстаток", ОбщегоНазначения.ОписаниеТипаЧисло(15, 3));

	ТаблицаИсполнениеБюджета.Колонки.СуммаСценарийКонтроль.Имя 		   = "СуммаНачОстаток";
	ТаблицаИсполнениеБюджета.Колонки.КоличествоСценарийКонтроль.Имя    = "КоличествоНачОстаток";
	ТаблицаИсполнениеБюджета.Колонки.СуммаСценарийИсполнение.Имя 	   = "СуммаИсполнение";
	ТаблицаИсполнениеБюджета.Колонки.КоличествоСценарийИсполнение.Имя  = "КоличествоИсполнение";
	ТаблицаИсполнениеБюджета.Колонки.СуммаСценарийСверхЛимита.Имя 	   = "СуммаСверхЛимита";
	ТаблицаИсполнениеБюджета.Колонки.КоличествоСценарийСверхЛимита.Имя = "КоличествоСверхЛимита";
	
	Для каждого СтрокаДокумента Из ИсполнениеБюджета Цикл
		
		ИмяСписка	= СтрокаДокумента.ИмяСписка;
		НомерСтроки = СтрокаДокумента.НомерСтроки;
		
		ОсталосьПогаситьСумма	   = СтрокаДокумента.Сумма;
		ОсталосьПогаситьКоличество = СтрокаДокумента.Количество;
		
		Если ОсталосьПогаситьСумма > 0 ИЛИ ОсталосьПогаситьКоличество > 0 Тогда
			Отбор = Новый Структура(Измерения);
			Отбор.Вставить("Период");		
			ЗаполнитьЗначенияСвойств(Отбор, СтрокаДокумента);
			РезультатПоиска = ТаблицаОстатки.НайтиСтроки(Отбор);			
		Иначе
			РезультатПоиска = Новый Массив;
		КонецЕсли;
		
		Для каждого СтрокаОстатка Из РезультатПоиска Цикл
			
			// Количество и сумма - не связанные ресурсы. 
			// Поэтому списываются непосредственно и коэффициент списания не вычисляется.
			Сумма 	   = 0;
			Количество = 0;
			
			СуммаСверхЛимита 	  = 0;
			КоличествоСверхЛимита = 0;

			Если ОсталосьПогаситьСумма > 0 И СтрокаОстатка.Сумма > 0 Тогда
				Сумма = Мин(ОсталосьПогаситьСумма, СтрокаОстатка.Сумма);
				ОсталосьПогаситьСумма = ОсталосьПогаситьСумма - Сумма;
			КонецЕсли;
			
			Если ОсталосьПогаситьКоличество > 0 И СтрокаОстатка.Количество > 0 Тогда
				Количество = Мин(ОсталосьПогаситьКоличество, СтрокаОстатка.Количество);
				ОсталосьПогаситьКоличество = ОсталосьПогаситьКоличество - Количество;
			КонецЕсли;
			
			СуммаНачОстаток	   = СтрокаОстатка.Сумма;
			КоличествоНачОстаток = СтрокаОстатка.Количество;

			Если Реквизиты.НеУчитыватьСверхБюджета И Реквизиты.СверхБюджета И НЕ Реквизиты.СписатьЛимиты Тогда
				// Остаток не уменьшается.
				СуммаСверхЛимита 	  = Сумма;
				КоличествоСверхЛимита = Количество;
				
				Сумма	   = 0;
				Количество = 0;
			Иначе	
				СтрокаОстатка.Сумма 	 = СтрокаОстатка.Сумма - Сумма;
				СтрокаОстатка.Количество = СтрокаОстатка.Количество - Количество;
			КонецЕсли;
			
			НоваяСтрока = ТаблицаИсполнениеБюджета.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДокумента);
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОстатка, "Сценарий, СценарийКонтролируемый, РежимКонтроля");
			НоваяСтрока.СуммаИсполнение 	 = Сумма; // Оборот
			НоваяСтрока.КоличествоИсполнение = Количество; // Оборот
			НоваяСтрока.СуммаНачОстаток	   	 = СуммаНачОстаток; // Нач. ост.
			НоваяСтрока.КоличествоНачОстаток = КоличествоНачОстаток; // Нач. ост.
			НоваяСтрока.СуммаКонОстаток		 = СтрокаОстатка.Сумма; // Кон. ост.
			НоваяСтрока.КоличествоКонОстаток = СтрокаОстатка.Количество; // Кон. ост.
			
			НоваяСтрока.СуммаСверхЛимита 	  = СуммаСверхЛимита;
			НоваяСтрока.КоличествоСверхЛимита = КоличествоСверхЛимита;
			
			// Все списано.
			Если ОсталосьПогаситьСумма <= 0 И ОсталосьПогаситьКоличество <= 0 Тогда
				Прервать;			
			КонецЕсли;
		КонецЦикла;
		
		// Нераспределенное исполнение добавим отдельной строкой в таблицу исполнения бюджета.
		Если ОсталосьПогаситьСумма > 0 ИЛИ ОсталосьПогаситьКоличество > 0 Тогда
			НоваяСтрока = ТаблицаИсполнениеБюджета.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДокумента);
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизиты, "СценарийКонтролируемый");
			Если НЕ Реквизиты.СверхБюджета И КонтролироватьБюджет И СтрокаДокумента.КонтролироватьПоСтатье Тогда
				НоваяСтрока.СуммаКонОстаток		 = - ОсталосьПогаситьСумма;
				НоваяСтрока.КоличествоКонОстаток = - ОсталосьПогаситьКоличество;
				НоваяСтрока.СуммаИсполнение 	 = ОсталосьПогаситьСумма;
				НоваяСтрока.КоличествоИсполнение = ОсталосьПогаситьКоличество;
			Иначе	
				НоваяСтрока.СуммаСверхЛимита 	  = ОсталосьПогаситьСумма;
				НоваяСтрока.КоличествоСверхЛимита = ОсталосьПогаситьКоличество;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла; 

	// В результате обработки таблица может иметь несколько строк с одинаковыми номерами.
	// Это случай когда происходит списание, а потом отражается Сверхбюджета.
	// Сгруппируем строки.
	Ресурсы = Новый Массив;
	Ресурсы.Добавить("СуммаКонОстаток");
	Ресурсы.Добавить("СуммаНачОстаток");
	Ресурсы.Добавить("СуммаИсполнение");
	Ресурсы.Добавить("СуммаСверхЛимита");
	Ресурсы.Добавить("КоличествоКонОстаток");
	Ресурсы.Добавить("КоличествоНачОстаток");
	Ресурсы.Добавить("КоличествоИсполнение");
	Ресурсы.Добавить("КоличествоСверхЛимита");

	Группировки = Новый Массив;
	Для каждого Колонка Из ТаблицаИсполнениеБюджета.Колонки Цикл
		Если Ресурсы.Найти(Колонка.Имя) = Неопределено Тогда
			Группировки.Добавить(Колонка.Имя);
		КонецЕсли;
	КонецЦикла;
	
	ТаблицаИсполнениеБюджета.Свернуть(СтрСоединить(Группировки, ","), СтрСоединить(Ресурсы, ","));

КонецПроцедуры

Процедура УстановитьПараметрыПоИзмерениямКонтроля(ИсполнениеБюджета, Запрос, Номер = "") 

	ИзмеренияКонтроля = СтрРазделить(ПереченьИзмеренийКонтроля(), ",");
	
	// Теперь незаполненное значение трактуется как значение,
	// а не как "не контролируется", как было ранее.
	Для каждого Элемент Из ИзмеренияКонтроля Цикл
		
		Значение = ИсполнениеБюджета.ВыгрузитьКолонку(Элемент);
		бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(Значение);		 
		
		Запрос.УстановитьПараметр(Элемент + Номер, Значение);
	КонецЦикла; 

КонецПроцедуры

Функция ТекстЗапросаОстаткиКонтрольныеЗначения(Периодичность, Номер, РежимКонтроля)

	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	КонтрольныеЗначения.Период КАК Период,
	|	КонтрольныеЗначения.РежимКонтроля КАК РежимКонтроля,
	|	КонтрольныеЗначения.Сценарий КАК Сценарий,
	|	КонтрольныеЗначения.СценарийКонтролируемый КАК СценарийКонтролируемый,
	|	КонтрольныеЗначения.СтатьяОборотов КАК СтатьяОборотов,
	|	КонтрольныеЗначения.ЦФО КАК ЦФО,
	|	СУММА(ЕСТЬNULL(КонтрольныеЗначения.КоличествоСценарийКонтрольОборот, 0) - ЕСТЬNULL(КонтрольныеЗначения.КоличествоСценарийИсполнениеОборот, 0) - ВЫБОР
	|			КОГДА &НеУчитыватьСверхБюджета
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(КонтрольныеЗначения.КоличествоСценарийСверхЛимитаОборот, 0)
	|		КОНЕЦ) КАК Количество,
	|	СУММА(ЕСТЬNULL(КонтрольныеЗначения.СуммаСценарийКонтрольОборот, 0) - ЕСТЬNULL(КонтрольныеЗначения.СуммаСценарийИсполнениеОборот, 0) - ВЫБОР
	|			КОГДА &НеУчитыватьСверхБюджета
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(КонтрольныеЗначения.СуммаСценарийСверхЛимитаОборот, 0)
	|		КОНЕЦ) КАК Сумма,
	|	СУММА(КонтрольныеЗначения.СуммаСценарийИсполнениеОборот) КАК СуммаИсполнение,
	|	СУММА(КонтрольныеЗначения.СуммаСценарийСверхЛимитаОборот) КАК СуммаСверхЛимита,
	|	СУММА(КонтрольныеЗначения.КоличествоСценарийИсполнениеОборот) КАК КоличествоИсполнение,
	|	СУММА(КонтрольныеЗначения.КоличествоСценарийСверхЛимитаОборот) КАК КоличествоСверхЛимита,
	|	СУММА(КонтрольныеЗначения.СуммаСценарийКонтрольОборот) КАК СуммаКонтроль,
	|	СУММА(КонтрольныеЗначения.КоличествоСценарийКонтрольОборот) КАК КоличествоКонтроль
	|ИЗ
	|	РегистрНакопления.бит_КонтрольныеЗначенияБюджетов.Обороты(&ДатаНачала, &ДатаОкончания, Месяц, ) КАК КонтрольныеЗначения
	|
	|СГРУППИРОВАТЬ ПО
	|	КонтрольныеЗначения.Период,
	|	КонтрольныеЗначения.РежимКонтроля,
	|	КонтрольныеЗначения.Сценарий,
	|	КонтрольныеЗначения.СценарийКонтролируемый,
	|	КонтрольныеЗначения.СтатьяОборотов,
	|	КонтрольныеЗначения.ЦФО";
	
	Схема = Новый СхемаЗапроса;
	Схема.УстановитьТекстЗапроса(ТекстЗапроса);
	
	ЗапросВыбора = Схема.ПакетЗапросов[0];
	Оператор  	 = ЗапросВыбора.Операторы[0];
	Таблица   	 = Оператор.Источники.НайтиПоПсевдониму("КонтрольныеЗначения").Источник;
	Параметры 	 = Таблица.Параметры;

	Если Номер = 1 Тогда
		ЗапросВыбора.ВыбиратьРазрешенные = Истина;
	КонецЕсли;
	
	ШаблонПоляЗапроса = "КонтрольныеЗначения.Аналитика_%1";
	
	ИзмеренияРегистра = СтрРазделить(ПереченьИзмеренийКонтроля(), ",");
	ИзмеренияРегистра.Добавить("СценарийКонтролируемый");
	ИзмеренияРегистра.Добавить("РежимКонтроля");
	
	ПоляВТ = ОбщегоНазначения.СкопироватьРекурсивно(ИзмеренияРегистра);
	Индекс = ПоляВТ.ВГраница();
	Пока Индекс >= 0 Цикл
		Поле = "ИсполнениеБюджета." + ПоляВТ[Индекс];
		ПоляВТ[Индекс] = Поле;
		Индекс = Индекс - 1;
	КонецЦикла;

	ИзмеренияРегистра = СтрСоединить(ИзмеренияРегистра, "," + Символы.ПС);
	ПоляВТ 			  = СтрСоединить(ПоляВТ, "," + Символы.ПС);
	
	ТекстУсловияИзмеренияРегистра = "(%1) В (ВЫБРАТЬ %2 ИЗ ВТ_ИсполнениеБюджета КАК ИсполнениеБюджета)";
	ТекстУсловияИзмеренияРегистра = СтрШаблон(ТекстУсловияИзмеренияРегистра, ИзмеренияРегистра, ПоляВТ); 
	
	Для Индекс = 1 По 12 Цикл
		Оператор.ВыбираемыеПоля.Добавить(СтрШаблон(ШаблонПоляЗапроса, Индекс));
		Оператор.Группировка.Добавить(СтрШаблон(ШаблонПоляЗапроса, Индекс));
	КонецЦикла;
	
	Параметры[0].Выражение = Новый ВыражениеСхемыЗапроса("&ДатаНачала" + Номер);
	Параметры[1].Выражение = Новый ВыражениеСхемыЗапроса("&ДатаОкончания" + Номер);
	
	Если ЗначениеЗаполнено(Периодичность) Тогда
		ПериодчностьСтр = бит_ОбщегоНазначенияКлиентСервер.ПериодичностьПланированияСтрокой(Периодичность);
		Параметры[2].Выражение = Новый ВыражениеСхемыЗапроса(ПериодчностьСтр);
	Иначе
		// После удаления периодичности таблицы Обороты, пропадает поле Период.
		// Установим в поле выбора значение начала периода.
		ПолеПериод = Оператор.ВыбираемыеПоля.Найти("Период");
		Индекс 	   = Оператор.ВыбираемыеПоля.Индекс(ПолеПериод);
		Оператор.ВыбираемыеПоля.Установить(Индекс, Новый ВыражениеСхемыЗапроса("&ДатаНачала" + Номер));
		Параметры[2].Выражение = Новый ВыражениеСхемыЗапроса("");
	КонецЕсли;

	Параметры[3].Выражение = Новый ВыражениеСхемыЗапроса(ТекстУсловияИзмеренияРегистра);// Условия отбора.
	
	Возврат Схема.ПолучитьТекстЗапроса();
	
КонецФункции

Функция ОстаткиПоКонтрольнымЗначениям(ИсполнениеБюджета, РезультатСортировки, Реквизиты) 
		
	Запрос 				 = Новый Запрос;
	ИтоговыйТекстЗапроса = "";
	Номер 				 = 1;
	ИзмеренияКонтроля	 = СтрРазделить(ПереченьИзмеренийКонтроля(), ",");
	
	ИтоговыйТекстЗапроса = ТекстЗапросаВременнаяТаблицаДокументаДляОстаткиКонтрольныеЗначения();
	
	Для каждого Элемент Из РезультатСортировки Цикл
		
		НачалоПериода = Элемент.НачалоПериода;
		КонецПериода  = Элемент.КонецПериода;
		Периодичность = Элемент.Периодичность;
		Таблица 	  = Элемент.Таблица;
		
		УстановитьПараметрыПоИзмерениямКонтроля(Таблица, Запрос, Формат(Номер, "ЧГ="));
		
		Запрос.УстановитьПараметр("ДатаНачала" + Номер, НачалоПериода);
		Запрос.УстановитьПараметр("ДатаОкончания" + Номер, КонецПериода);
		
		ТекстЗапроса = ТекстЗапросаОстаткиКонтрольныеЗначения(Периодичность, Номер, Реквизиты.РежимКонтроля);
		Если Номер = 1 Тогда
			Разделитель = "";
		Иначе	
			Разделитель = 
			"			
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|";
		КонецЕсли;
		ИтоговыйТекстЗапроса = ИтоговыйТекстЗапроса + Разделитель + ТекстЗапроса;
		Номер = Номер + 1;
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("РежимКонтроля", 			 Реквизиты.РежимКонтроля);
	Запрос.УстановитьПараметр("СценарийКонтролируемый",  Реквизиты.СценарийКонтролируемый);
	Запрос.УстановитьПараметр("НеУчитыватьСверхБюджета", Реквизиты.НеУчитыватьСверхБюджета);
	Запрос.УстановитьПараметр("ИсполнениеБюджета", 		ИсполнениеБюджета);
	Запрос.УстановитьПараметр("Сценарий",				Реквизиты.Сценарий);
	
	Если ТранзакцияАктивна() Тогда
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.бит_КонтрольныеЗначенияБюджетов");
		
		ЭлементБлокировки.УстановитьЗначение("Период", 				   Новый Диапазон(НачалоПериода, КонецПериода));
		ЭлементБлокировки.УстановитьЗначение("РежимКонтроля", 		   Реквизиты.РежимКонтроля);
		ЭлементБлокировки.УстановитьЗначение("СценарийКонтролируемый", Реквизиты.СценарийКонтролируемый);
		
		ЭлементБлокировки.ИсточникДанных = ИсполнениеБюджета;
		Для каждого Элемент Из ИзмеренияКонтроля Цикл
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных(Элемент, Элемент);
		КонецЦикла; 
		Блокировка.Заблокировать();
	КонецЕсли; 
	
	Запрос.Текст = ИтоговыйТекстЗапроса;
	Остатки = Запрос.Выполнить().Выгрузить();
	
	Возврат Остатки;
	
КонецФункции

Функция ТекстЗапросаВременнаяТаблицаДокументаДляОстаткиКонтрольныеЗначения()
		
	// Помещаю данные документа в запрос для наложения отбора в таблице остатков.
	ИтоговыйТекстЗапроса = 
	"ВЫБРАТЬ
	|	&Сценарий КАК Сценарий,
	|	&СценарийКонтролируемый КАК СценарийКонтролируемый,
	|	&РежимКонтроля КАК РежимКонтроля,
	|	&ИзмеренияКонтроля
	|ПОМЕСТИТЬ ВТ_ИсполнениеБюджета
	|ИЗ &ИсполнениеБюджета КАК ИсполнениеБюджета";
	
	ПоляИсполнениеБюджета = СтрРазделить(ПереченьИзмеренийКонтроля(), ",");
	Индекс = ПоляИсполнениеБюджета.ВГраница();
	Пока Индекс >= 0 Цикл
		Поле = "ИсполнениеБюджета." + ПоляИсполнениеБюджета[Индекс];
		ПоляИсполнениеБюджета[Индекс] = Поле;
		Индекс = Индекс - 1;
	КонецЦикла;
	
	ЧтоЗаменить	  		 = "&ИзмеренияКонтроля";
	НаЧтоЗаменить 		 = СтрСоединить(ПоляИсполнениеБюджета, ", " + Символы.ПС);
	ИтоговыйТекстЗапроса = СтрЗаменить(ИтоговыйТекстЗапроса, ЧтоЗаменить, НаЧтоЗаменить);
	
	Возврат ИтоговыйТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();

КонецФункции 

Функция СортировкаСтрокТаблицыКонтрольныхЗначений(ИсполнениеБюджета)

	РезультатСортировки = Новый Массив;
	
	ПараметрыКонтроля = ИсполнениеБюджета.Скопировать(, "Периодичность, НачалоПериода, КонецПериода");
	ПараметрыКонтроля.Свернуть("Периодичность, НачалоПериода, КонецПериода");
	
	ИсполнениеБюджета.Индексы.Добавить("Периодичность, НачалоПериода, КонецПериода");
	
	Для Каждого ТекущиеПараметры Из ПараметрыКонтроля Цикл
		Отбор = Новый Структура("Периодичность, НачалоПериода, КонецПериода");
		ЗаполнитьЗначенияСвойств(Отбор, ТекущиеПараметры);
		
		НовыйЭлемент = Новый Структура("НачалоПериода, КонецПериода, Периодичность, Таблица");
		ЗаполнитьЗначенияСвойств(НовыйЭлемент, ТекущиеПараметры);
		НовыйЭлемент.Таблица = ИсполнениеБюджета.Скопировать(Отбор);
		
		РезультатСортировки.Добавить(НовыйЭлемент);
	КонецЦикла; 
	
	Возврат РезультатСортировки;
	
КонецФункции

Процедура ПодготовитьТаблицуИсполнениеБюджетаДляЦелейКонтроля(ИсполнениеБюджета, ИсполнениеБюджетаРеквизиты)

	Если ИсполнениеБюджетаРеквизиты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты = ИсполнениеБюджетаРеквизиты[0];

	Если Реквизиты.РежимКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
		Периодичность = ПериодичностьКонтроляСценария(Реквизиты.СценарийКонтролируемый);
		Сценарий 	  = Реквизиты.СценарийКонтролируемый;
	Иначе
		Периодичность = ПериодичностьКонтроляСценария(Реквизиты.Сценарий);
		Сценарий 	  = Реквизиты.Сценарий;
	КонецЕсли;
	
	// Нормализация таблицы:
	// - обеспечиваем ожидаемый набор полей,
	// - очищаем неиспользуемые аналитики.
	ТаблицаДляЦелейКонтроля = ПустаяТаблицаИсполнениеБюджетаДляЦелейКонтроля();
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсполнениеБюджета, ТаблицаДляЦелейКонтроля);
	ОчиститьНеИспользуемыеАналитики(ТаблицаДляЦелейКонтроля);
	
	Запрос = Новый Запрос(); 
	Запрос.УстановитьПараметр("ИсполнениеБюджета", 		ТаблицаДляЦелейКонтроля);
	Запрос.УстановитьПараметр("Периодичность", 	   		Периодичность);
	Запрос.УстановитьПараметр("СценарийКонтролируемый", Сценарий);
