Функция ПредставлениеИзмеренийКонтроля()

	ИзмеренияКонтроля 		= ИзмеренияКонтроля();
	ИзмеренияБюджетирования = бит_Бюджетирование.НастройкиИзмеренийБюджетирования();
	
	ПредставлениеПолей = Новый Структура; 
	Для каждого КлючЗначение Из ИзмеренияКонтроля Цикл
		СвойстваПоля = ИзмеренияБюджетирования.Получить(КлючЗначение.Ключ);
		Если СвойстваПоля = Неопределено Тогда
			ПредставлениеПолей.Вставить(КлючЗначение.Ключ, "");
		Иначе	
			ПредставлениеПолей.Вставить(КлючЗначение.Ключ, СвойстваПоля.Синоним);
		КонецЕсли;
	КонецЦикла; 
	
	Возврат ПредставлениеПолей;

