	|		КОГДА 11
	|			ТОГДА НАЧАЛОПЕРИОДА(ВременнаяТаблица.Период, ПОЛУГОДИЕ)
	|		КОГДА 12
	|			ТОГДА НАЧАЛОПЕРИОДА(ВременнаяТаблица.Период, ГОД)
	|		ИНАЧЕ НАЧАЛОПЕРИОДА(ВременнаяТаблица.Период, ДЕНЬ)
	|	КОНЕЦ,
	|	ВЫБОР &КодПериода
	|		КОГДА 6
	|			ТОГДА КОНЕЦПЕРИОДА(ВременнаяТаблица.Период, ДЕНЬ)
	|		КОГДА 7
	|			ТОГДА КОНЕЦПЕРИОДА(ВременнаяТаблица.Период, НЕДЕЛЯ)
	|		КОГДА 8
	|			ТОГДА КОНЕЦПЕРИОДА(ВременнаяТаблица.Период, ДЕКАДА)
	|		КОГДА 9
	|			ТОГДА КОНЕЦПЕРИОДА(ВременнаяТаблица.Период, МЕСЯЦ)
	|		КОГДА 10
	|			ТОГДА КОНЕЦПЕРИОДА(ВременнаяТаблица.Период, КВАРТАЛ)
	|		КОГДА 11
	|			ТОГДА КОНЕЦПЕРИОДА(ВременнаяТаблица.Период, ПОЛУГОДИЕ)
	|		КОГДА 12
	|			ТОГДА КОНЕЦПЕРИОДА(ВременнаяТаблица.Период, ГОД)
	|		ИНАЧЕ КОНЕЦПЕРИОДА(ВременнаяТаблица.Период, ДЕНЬ)
	|	КОНЕЦ,
	|	&Периодичность,
	|	&СценарийКонтролируемый,
	|	ВременнаяТаблица.Сумма,
	|	ВременнаяТаблица.Количество,
	|	ВременнаяТаблица.КонтролироватьСумму,
	|	ВременнаяТаблица.КонтролироватьКоличество,
	|	ВременнаяТаблица.КонтролироватьПоСтатье,
	|	ВременнаяТаблица.ИмяСписка,
	|	ВременнаяТаблица.СинонимСписка,
	|	&РежимКонтроля,
	|	0,
	|	ВременнаяТаблица.Аналитика_1,
	|	ВременнаяТаблица.Аналитика_2,
	|	ВременнаяТаблица.Аналитика_3,
	|	ВременнаяТаблица.Аналитика_4,
	|	ВременнаяТаблица.Аналитика_5,
	|	ВременнаяТаблица.Аналитика_6,
	|	ВременнаяТаблица.Аналитика_7,
	|	ВременнаяТаблица.Аналитика_8,
	|	ВременнаяТаблица.Аналитика_9,
	|	ВременнаяТаблица.Аналитика_10,
	|	ВременнаяТаблица.Аналитика_11,
	|	ВременнаяТаблица.Аналитика_12
	|ИЗ
	|	ВременнаяТаблица КАК ВременнаяТаблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ СрезПоследних КАК СрезПоследних
	|		ПО ВременнаяТаблица.НомерСтроки = СрезПоследних.НомерСтроки
	|			И ВременнаяТаблица.ИмяСписка = СрезПоследних.ИмяСписка
	|ГДЕ
	|	СрезПоследних.НомерСтроки ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИмяСписка,
	|	НомерСтроки,
	|	Приоритет УБЫВ";
	
	РезультатЗапроса  = Запрос.Выполнить();
	ИсполнениеБюджета = РезультатЗапроса.Выгрузить();
	
КонецПроцедуры

Функция НастройкиСтатей(Статьи)
	
	НастройкиСтатей = Новый Структура;
	НастройкиПолей  = Новый Структура;
	ДанныеСтатей	= Новый Соответствие; 
	
	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		НастройкиПолей.Вставить("Аналитика_1",	"Контрагент");
		НастройкиПолей.Вставить("Аналитика_2",	"ДоговорКонтрагента");
		НастройкиПолей.Вставить("Аналитика_3",	"Проект");
		НастройкиПолей.Вставить("Аналитика_4",	"НоменклатурнаяГруппа");
		НастройкиПолей.Вставить("Аналитика_5",	"БанковскийСчет");
		НастройкиПолей.Вставить("Аналитика_6",	"Аналитика_1");
		НастройкиПолей.Вставить("Аналитика_7",	"Аналитика_2");
		НастройкиПолей.Вставить("Аналитика_8",	"Аналитика_3");
		НастройкиПолей.Вставить("Аналитика_9",	"Аналитика_4");
		НастройкиПолей.Вставить("Аналитика_10",	"Аналитика_5");
		НастройкиПолей.Вставить("Аналитика_11",	"Аналитика_6");
		НастройкиПолей.Вставить("Аналитика_12",	"Аналитика_7");
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	СтатьиОборотов.Ссылка КАК СтатьяОборотов,
		|	СтатьиОборотов.Учет_Количество КАК Количество,
		|	СтатьиОборотов.Учет_Сумма КАК Сумма,
		|	СтатьиОборотов.Учет_Контрагент КАК Контрагент,
		|	СтатьиОборотов.Учет_ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	СтатьиОборотов.Учет_Проект КАК Проект,
		|	СтатьиОборотов.Учет_НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
		|	СтатьиОборотов.Учет_БанковскийСчет КАК БанковскийСчет,
		|	СтатьиОборотов.Учет_Аналитика_1 КАК Аналитика_1,
		|	СтатьиОборотов.Учет_Аналитика_2 КАК Аналитика_2,
		|	СтатьиОборотов.Учет_Аналитика_3 КАК Аналитика_3,
		|	СтатьиОборотов.Учет_Аналитика_4 КАК Аналитика_4,
		|	СтатьиОборотов.Учет_Аналитика_5 КАК Аналитика_5,
		|	СтатьиОборотов.Учет_Аналитика_6 КАК Аналитика_6,
		|	СтатьиОборотов.Учет_Аналитика_7 КАК Аналитика_7
		|ИЗ
		|	Справочник.бит_СтатьиОборотов КАК СтатьиОборотов
		|ГДЕ
		|	СтатьиОборотов.Ссылка В(&СтатьиОборотов)";
	Иначе
		НастройкиПолей.Вставить("Аналитика_1",	"Аналитика_1");
		НастройкиПолей.Вставить("Аналитика_2",	"Аналитика_2");
		НастройкиПолей.Вставить("Аналитика_3",	"Аналитика_3");
		НастройкиПолей.Вставить("Аналитика_4",	"Аналитика_4");
		НастройкиПолей.Вставить("Аналитика_5",	"Аналитика_5");
		НастройкиПолей.Вставить("Аналитика_6",	"Аналитика_6");
		НастройкиПолей.Вставить("Аналитика_7",	"Аналитика_7");
		НастройкиПолей.Вставить("Аналитика_8",	"Аналитика_8");
		НастройкиПолей.Вставить("Аналитика_9",	"Аналитика_9");
		НастройкиПолей.Вставить("Аналитика_10",	"Аналитика_10");
		НастройкиПолей.Вставить("Аналитика_11",	"Аналитика_11");
		НастройкиПолей.Вставить("Аналитика_12",	"Аналитика_12");
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	СтатьиОборотов.Ссылка КАК СтатьяОборотов,
		|	СтатьиОборотов.Учет_Количество КАК Количество,
		|	СтатьиОборотов.Учет_Сумма КАК Сумма,
		|	СтатьиОборотов.Учет_Аналитика_1 КАК Аналитика_1,
		|	СтатьиОборотов.Учет_Аналитика_2 КАК Аналитика_2,
		|	СтатьиОборотов.Учет_Аналитика_3 КАК Аналитика_3,
		|	СтатьиОборотов.Учет_Аналитика_4 КАК Аналитика_4,
		|	СтатьиОборотов.Учет_Аналитика_5 КАК Аналитика_5,
		|	СтатьиОборотов.Учет_Аналитика_6 КАК Аналитика_6,
		|	СтатьиОборотов.Учет_Аналитика_7 КАК Аналитика_7,
		|	СтатьиОборотов.Учет_Аналитика_8 КАК Аналитика_8,
		|	СтатьиОборотов.Учет_Аналитика_9 КАК Аналитика_9,
		|	СтатьиОборотов.Учет_Аналитика_10 КАК Аналитика_10,
		|	СтатьиОборотов.Учет_Аналитика_11 КАК Аналитика_11,
		|	СтатьиОборотов.Учет_Аналитика_12 КАК Аналитика_12
		|ИЗ
		|	Справочник.бит_СтатьиОборотов КАК СтатьиОборотов
		|ГДЕ
		|	СтатьиОборотов.Ссылка В(&СтатьиОборотов)";
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("СтатьиОборотов",	Статьи);
	Запрос.Текст = ТекстЗапроса;
	Результат 	 = Запрос.Выполнить();
	Выборка 	 = Результат.Выбрать();
	
	Шаблон = Новый Структура;
	Для каждого Колонка Из Результат.Колонки Цикл
		Шаблон.Вставить(Колонка.Имя, Неопределено);
	КонецЦикла;
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Шаблон, Выборка);
		ДанныеСтатей.Вставить(Выборка.СтатьяОборотов, Новый ФиксированнаяСтруктура(Шаблон));
	КонецЦикла;
	
	НастройкиСтатей.Вставить("НастройкиПолей", НастройкиПолей);
	НастройкиСтатей.Вставить("ДанныеСтатей",   ДанныеСтатей);
	
	Возврат НастройкиСтатей;
	
КонецФункции

Функция ОборотыПоКонтрольнымЗначениям(Реквизиты)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Регистратор",			 Реквизиты.Регистратор);
	Запрос.УстановитьПараметр("НеУчитыватьСверхБюджета", Реквизиты.НеУчитыватьСверхБюджета);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КонтрольныеЗначения.Период КАК Период,
	|	КонтрольныеЗначения.РежимКонтроля КАК РежимКонтроля,
	|	КонтрольныеЗначения.СценарийКонтролируемый КАК СценарийКонтролируемый,
	|	КонтрольныеЗначения.Сценарий КАК Сценарий,
	|	КонтрольныеЗначения.ЦФО КАК ЦФО,
	|	КонтрольныеЗначения.СтатьяОборотов КАК СтатьяОборотов,
	|	СУММА(-КонтрольныеЗначения.СуммаСценарийКонтроль) КАК СуммаКонтроль,
	|	СУММА(-КонтрольныеЗначения.СуммаСценарийИсполнение) КАК СуммаИсполнение,
	|	СУММА(-КонтрольныеЗначения.СуммаСценарийСверхЛимита) КАК СуммаСверхЛимита,
	|	СУММА(-КонтрольныеЗначения.КоличествоСценарийКонтроль) КАК КоличествоКонтроль,
	|	СУММА(-КонтрольныеЗначения.КоличествоСценарийИсполнение) КАК КоличествоИсполнение,
	|	СУММА(-КонтрольныеЗначения.КоличествоСценарийСверхЛимита) КАК КоличествоСверхЛимита,
	|	СУММА(ЕСТЬNULL(КонтрольныеЗначения.КоличествоСценарийИсполнение, 0) - ВЫБОР
	|			КОГДА &НеУчитыватьСверхБюджета
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(КонтрольныеЗначения.КоличествоСценарийСверхЛимита, 0)
	|		КОНЕЦ) КАК Количество,
	|	СУММА(ЕСТЬNULL(КонтрольныеЗначения.СуммаСценарийИсполнение, 0) + ВЫБОР
	|			КОГДА &НеУчитыватьСверхБюджета
	|				ТОГДА 0
	|			ИНАЧЕ ЕСТЬNULL(КонтрольныеЗначения.СуммаСценарийСверхЛимита, 0)
	|		КОНЕЦ) КАК Сумма,
	|	КонтрольныеЗначения.Аналитика_1 КАК Аналитика_1,
	|	КонтрольныеЗначения.Аналитика_2 КАК Аналитика_2,
	|	КонтрольныеЗначения.Аналитика_3 КАК Аналитика_3,
	|	КонтрольныеЗначения.Аналитика_4 КАК Аналитика_4,
	|	КонтрольныеЗначения.Аналитика_5 КАК Аналитика_5,
	|	КонтрольныеЗначения.Аналитика_6 КАК Аналитика_6,
	|	КонтрольныеЗначения.Аналитика_7 КАК Аналитика_7,
	|	КонтрольныеЗначения.Аналитика_8 КАК Аналитика_8,
	|	КонтрольныеЗначения.Аналитика_9 КАК Аналитика_9,
	|	КонтрольныеЗначения.Аналитика_10 КАК Аналитика_10,
	|	КонтрольныеЗначения.Аналитика_11 КАК Аналитика_11,
	|	КонтрольныеЗначения.Аналитика_12 КАК Аналитика_12
	|ИЗ
	|	РегистрНакопления.бит_КонтрольныеЗначенияБюджетов КАК КонтрольныеЗначения
	|ГДЕ
	|	КонтрольныеЗначения.Регистратор = &Регистратор
	|
	|СГРУППИРОВАТЬ ПО
	|	КонтрольныеЗначения.Период,
	|	КонтрольныеЗначения.РежимКонтроля,
	|	КонтрольныеЗначения.СценарийКонтролируемый,
	|	КонтрольныеЗначения.Сценарий,
	|	КонтрольныеЗначения.СтатьяОборотов,
	|	КонтрольныеЗначения.ЦФО,
	|	КонтрольныеЗначения.Аналитика_1,
	|	КонтрольныеЗначения.Аналитика_2,
	|	КонтрольныеЗначения.Аналитика_3,
	|	КонтрольныеЗначения.Аналитика_4,
	|	КонтрольныеЗначения.Аналитика_5,
	|	КонтрольныеЗначения.Аналитика_6,
	|	КонтрольныеЗначения.Аналитика_7,
	|	КонтрольныеЗначения.Аналитика_8,
	|	КонтрольныеЗначения.Аналитика_9,
	|	КонтрольныеЗначения.Аналитика_10,
	|	КонтрольныеЗначения.Аналитика_11,
	|	КонтрольныеЗначения.Аналитика_12";	
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса.Выгрузить();

КонецФункции

Процедура СторнироватьОборотыДокументаИзОстатков(Остатки, Обороты)

	Если НЕ ЗначениеЗаполнено(Обороты) Тогда
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Обороты, Остатки);

	Группировки = ПереченьИзмеренийКонтроля();
	Группировки = Группировки + ", Период, Сценарий, СценарийКонтролируемый, РежимКонтроля";

	Ресурсы = Новый Массив;
	Ресурсы.Добавить("СуммаКонтроль");
	Ресурсы.Добавить("СуммаИсполнение");
	Ресурсы.Добавить("СуммаСверхЛимита");
	Ресурсы.Добавить("КоличествоКонтроль");
	Ресурсы.Добавить("КоличествоИсполнение");
	Ресурсы.Добавить("КоличествоСверхЛимита");
	Ресурсы.Добавить("Количество");
	Ресурсы.Добавить("Сумма");
	
	Остатки.Свернуть(Группировки, СтрСоединить(Ресурсы, ","));
	
КонецПроцедуры

#КонецОбласти 