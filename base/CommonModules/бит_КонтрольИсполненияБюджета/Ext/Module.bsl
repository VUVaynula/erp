#Область ИсполнениеБюджета

// Подготавливает таблицу исполнения для записи в регистр контрольных значений.
//
Функция ПодготовитьТаблицуИсполнениеБюджета(ИсполнениеБюджета, ИсполнениеБюджетаРеквизиты, 
			Отказ, АдресВХранилище = "") Экспорт
	
	Если НЕ ЗначениеЗаполнено(ИсполнениеБюджета) ИЛИ НЕ ЗначениеЗаполнено(ИсполнениеБюджетаРеквизиты) Тогда
		Возврат ПустаяТаблицаКонтрольныеЗначения();
	КонецЕсли;
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ИсполнениеБюджетаРеквизиты[0]);
									
	ПодготовитьТаблицуИсполнениеБюджетаДляЦелейКонтроля(ИсполнениеБюджета, ИсполнениеБюджетаРеквизиты);
	РезультатСортировки = СортировкаСтрокТаблицыКонтрольныхЗначений(ИсполнениеБюджета);
	
	ТаблицаИсполнениеБюджета = ПустаяТаблицаКонтрольныеЗначения();

	Если Реквизиты.НеУчитыватьСверхБюджета И Реквизиты.СверхБюджета И НЕ Реквизиты.СписатьЛимиты Тогда
		Для каждого СтрокаДокумента Из ИсполнениеБюджета Цикл
			Если СтрокаДокумента.Сумма = 0 И СтрокаДокумента.Количество = 0 Тогда
				Продолжить;		
			КонецЕсли; 
			НоваяСтрока = ТаблицаИсполнениеБюджета.Добавить(); 
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДокумента);
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизиты, "Сценарий, СценарийКонтролируемый, РежимКонтроля");
			НоваяСтрока.КоличествоСценарийСверхЛимита = СтрокаДокумента.Количество;
			НоваяСтрока.СуммаСценарийСверхЛимита 	  = СтрокаДокумента.Сумма;
		КонецЦикла;
	Иначе
		ТаблицаОстатки = ОстаткиПоКонтрольнымЗначениям(ИсполнениеБюджета, РезультатСортировки, Реквизиты);
		
		ОтметитьИсполнениеБюджета(ИсполнениеБюджета, ТаблицаОстатки, 
			ТаблицаИсполнениеБюджета, Реквизиты, Отказ, АдресВХранилище);
	КонецЕсли;
		
	Возврат ТаблицаИсполнениеБюджета;
	
КонецФункции
	
#КонецОбласти 

#Область КорректировкаЛимитов

Функция ПодготовитьТаблицуКорректировкиЛимитов(ИсполнениеБюджета, ИсполнениеБюджетаРеквизиты, Отказ) Экспорт
	
	Если ИсполнениеБюджетаРеквизиты.Количество() = 0 Тогда
		Возврат ПустаяТаблицаКонтрольныеЗначения();	
	КонецЕсли; 

	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ИсполнениеБюджетаРеквизиты[0]);

	ИсполнениеБюджета.Индексы.Добавить("ГруппаСтрок");
	
	УвеличениеЛимита = ИсполнениеБюджета.Скопировать(
		Новый Структура("ГруппаСтрок", "УвеличениеЛимита"));
	УменьшениеЛимита = ИсполнениеБюджета.Скопировать(
		Новый Структура("ГруппаСтрок", "УменьшениеЛимита"));
	ВозвратЛимита = ИсполнениеБюджета.Скопировать(
		Новый Структура("ГруппаСтрок", "ВозвратЛимита"));
	
	ТаблицаИсполнениеБюджета = ПустаяТаблицаКонтрольныеЗначения();
	Для Каждого СтрокаТаблицы Из УвеличениеЛимита Цикл
		НоваяСтрока = ТаблицаИсполнениеБюджета.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизиты);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		НоваяСтрока.СуммаСценарийКонтроль 	   = СтрокаТаблицы.Сумма;
		НоваяСтрока.КоличествоСценарийКонтроль = СтрокаТаблицы.Количество;
	КонецЦикла;

	Если УменьшениеЛимита.Количество() > 0 Тогда
		РезультатСортировки = СортировкаСтрокТаблицыКонтрольныхЗначений(УменьшениеЛимита);
		ТаблицаОстатки 		= ОстаткиПоКонтрольнымЗначениям(УменьшениеЛимита, РезультатСортировки, Реквизиты);
		ОтметитьУменьшениеЛимита(УменьшениеЛимита, ТаблицаОстатки, ТаблицаИсполнениеБюджета, Реквизиты, Отказ, "");
	КонецЕсли;
	
	Если ВозвратЛимита.Количество() > 0 Тогда
		РезультатСортировки = СортировкаСтрокТаблицыКонтрольныхЗначений(ВозвратЛимита);
		ТаблицаОстатки  	= ОстаткиПоКонтрольнымЗначениям(ВозвратЛимита, РезультатСортировки, Реквизиты);
		ОтметитьВозвратЛимита(ВозвратЛимита, ТаблицаОстатки, ТаблицаИсполнениеБюджета, Реквизиты, Отказ);		
	КонецЕсли;
	
	Возврат ТаблицаИсполнениеБюджета;
	
КонецФункции

Процедура СформироватьДвиженияКорректировкиСроковКонтроля(КонтрольныеЗначения, КонтрольныеЗначенияРеквизиты, Движения) Экспорт

	Если НЕ ЗначениеЗаполнено(КонтрольныеЗначения) ИЛИ НЕ ЗначениеЗаполнено(КонтрольныеЗначенияРеквизиты)  Тогда
		Возврат;	
	КонецЕсли;
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(КонтрольныеЗначенияРеквизиты[0]);
	
	Проводки = Движения.бит_СрокиКонтроляПоБюджету;
	Проводки.Записывать = Истина;
	
	Для Каждого СтрокаТаблицы Из КонтрольныеЗначения Цикл
		Проводка = Проводки.Добавить();
		ЗаполнитьЗначенияСвойств(Проводка, СтрокаТаблицы);
		ЗаполнитьЗначенияСвойств(Проводка, Реквизиты);
	КонецЦикла;

КонецПроцедуры

#КонецОбласти 

#Область УстановкаЛимитов

Процедура СформироватьДвиженияПоСрокамКонтроля(КонтрольныеЗначения, КонтрольныеЗначенияРеквизиты, Движения) Экспорт

	Если КонтрольныеЗначенияРеквизиты.Количество() = 0 Тогда
		Возврат;	
	КонецЕсли;
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(КонтрольныеЗначенияРеквизиты[0]);
	
	Проводки = Движения.бит_СрокиКонтроляПоБюджету;
	Проводки.Записывать = Истина;
	
	Для Каждого СтрокаТаблицы Из КонтрольныеЗначения Цикл
		Проводка = Проводки.Добавить();
		ЗаполнитьЗначенияСвойств(Проводка, СтрокаТаблицы);
		ЗаполнитьЗначенияСвойств(Проводка, Реквизиты);
	КонецЦикла;

КонецПроцедуры
	
#КонецОбласти 

#Область АктуализацияБюджета

Функция ПодготовитьТаблицуВозвратЛимита(ВозвратЛимита, ИсполнениеБюджетаРеквизиты, Отказ) Экспорт

	Если НЕ ЗначениеЗаполнено(ВозвратЛимита) ИЛИ НЕ ЗначениеЗаполнено(ИсполнениеБюджетаРеквизиты) Тогда
		Возврат ПустаяТаблицаКонтрольныеЗначения();	
	КонецЕсли; 

	Реквизиты 				 = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ИсполнениеБюджетаРеквизиты[0]);
	ТаблицаИсполнениеБюджета = ПустаяТаблицаКонтрольныеЗначения();
	
	ПодготовитьТаблицуИсполнениеБюджетаДляЦелейКонтроля(ВозвратЛимита, ИсполнениеБюджетаРеквизиты);
	РезультатСортировки = СортировкаСтрокТаблицыКонтрольныхЗначений(ВозвратЛимита);
	
	ТаблицаОстаткиВозвратЛимита = ОстаткиПоКонтрольнымЗначениям(ВозвратЛимита, РезультатСортировки, Реквизиты);
	ОтметитьВозвратЛимита(ВозвратЛимита, ТаблицаОстаткиВозвратЛимита, ТаблицаИсполнениеБюджета, Реквизиты, Отказ);
	
	Возврат ТаблицаИсполнениеБюджета;
	
КонецФункции
	
#КонецОбласти 

Функция ПрогнозИсполненияБюджета(ИсполнениеБюджета, ИсполнениеБюджетаРеквизиты) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ИсполнениеБюджета) ИЛИ НЕ ЗначениеЗаполнено(ИсполнениеБюджетаРеквизиты) Тогда
		Возврат Новый ТаблицаЗначений; 
	КонецЕсли;

	ЧастиРассчета = Новый Структура;
	ЧастиРассчета.Вставить("ОстаткиКонтрольныхЗначений");
	ЧастиРассчета.Вставить("ПрогнозИсполненияБюджета");
	ЧастиРассчета.Вставить("ПериодыКонтроля");
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ИсполнениеБюджетаРеквизиты[0]);
									
	ПодготовитьТаблицуИсполнениеБюджетаДляЦелейКонтроля(ИсполнениеБюджета, ИсполнениеБюджетаРеквизиты);
	РезультатСортировки = СортировкаСтрокТаблицыКонтрольныхЗначений(ИсполнениеБюджета);

	ЧастиРассчета.ПериодыКонтроля = РезультатСортировки;
	
	ПрогнозИсполненияБюджета = ПустаяТаблицаКонтрольныеЗначения();
	
	ТаблицаОстатки = ОстаткиПоКонтрольнымЗначениям(ИсполнениеБюджета, РезультатСортировки, Реквизиты);
	ТаблицаОбороты = ОборотыПоКонтрольнымЗначениям(Реквизиты);
	
	СторнироватьОборотыДокументаИзОстатков(ТаблицаОстатки, ТаблицаОбороты);
	
	ЧастиРассчета.ОстаткиКонтрольныхЗначений = ТаблицаОстатки.Скопировать();

	ОтметитьПрогнозИсполнениеБюджета(ИсполнениеБюджета, ТаблицаОстатки, 
			ПрогнозИсполненияБюджета, Реквизиты);
			
	ЧастиРассчета.ПрогнозИсполненияБюджета = ПрогнозИсполненияБюджета;
	
	Возврат ЧастиРассчета;
	
КонецФункции

Процедура СформироватьДвиженияКонтрольныеЗначенияБюджетов(ТаблицаДвижений, Движения) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ТаблицаДвижений) Тогда
		Возврат;	
	КонецЕсли;
	
	НаборЗаписей = Движения.бит_КонтрольныеЗначенияБюджетов;
	НаборЗаписей.Записывать = Истина;
	
	Для каждого СтрокаДокумента Из ТаблицаДвижений Цикл
		Если СтрокаДокумента.СуммаСценарийИсполнение = 0 И СтрокаДокумента.СуммаСценарийСверхЛимита = 0 
		   И СтрокаДокумента.СуммаСценарийКонтроль = 0 И СтрокаДокумента.КоличествоСценарийИсполнение = 0 
		   И СтрокаДокумента.КоличествоСценарийСверхЛимита = 0 И СтрокаДокумента.КоличествоСценарийКонтроль = 0 Тогда
			Продолжить;		
		КонецЕсли; 
		НоваяСтрока = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДокумента);
	КонецЦикла; 

КонецПроцедуры

Функция ПереченьИзмеренийКонтроля() Экспорт 

	ПредставлениеИзмерений = ПредставлениеИзмеренийКонтроля();
	
	Возврат ОбщегоНазначенияКлиентСервер.КлючиСтруктурыВСтроку(ИзмеренияКонтроля(), ",");	

КонецФункции

Функция ИзмеренияКонтроля() Экспорт 

	Измерения = Новый Структура; 
	МетаденныеРегистра = Метаданные.РегистрыСведений.бит_СрокиКонтроляПоБюджету.Измерения;
	
	Для каждого Измерение Из МетаденныеРегистра Цикл
		Если Измерение.Имя = "СценарийКонтролируемый" ИЛИ Измерение.Имя = "РежимКонтроля" Тогда
			Продолжить;		
		КонецЕсли;
		
		ПустаяСсылка = Неопределено;
		Если Измерение.Тип.Типы().Количество() = 1 Тогда
			ОбъектМетаданных = Метаданные.НайтиПоТипу(Измерение.Тип.Типы()[0]);
			МенеджерТаблицы  = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ОбъектМетаданных.ПолноеИмя());
  			ПустаяСсылка 	 = МенеджерТаблицы.ПустаяСсылка();
		КонецЕсли;
		Измерения.Вставить(Измерение.Имя, ПустаяСсылка);
	КонецЦикла;
	
	Возврат Измерения;	

КонецФункции

Функция ПустаяТаблицаКонтрольныеЗначения() Экспорт

	КонтрольныеЗначения = Новый ТаблицаЗначений;
	КонтрольныеЗначения.Колонки.Добавить("ИмяСписка",     ОбщегоНазначения.ОписаниеТипаСтрока(50));
	КонтрольныеЗначения.Колонки.Добавить("СинонимСписка", ОбщегоНазначения.ОписаниеТипаСтрока(50));
	КонтрольныеЗначения.Колонки.Добавить("Период",        ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	КонтрольныеЗначения.Колонки.Добавить("НомерСтроки",   ОбщегоНазначения.ОписаниеТипаЧисло(5, 0));
	
	Измерения = Метаданные.РегистрыНакопления.бит_КонтрольныеЗначенияБюджетов.Измерения;
	Для Каждого Измерение Из Измерения Цикл
		КонтрольныеЗначения.Колонки.Добавить(Измерение.Имя, Измерение.Тип);
	КонецЦикла;
	
	Ресурсы = Метаданные.РегистрыНакопления.бит_КонтрольныеЗначенияБюджетов.Ресурсы;
	Для Каждого Ресурс Из Ресурсы Цикл
		КонтрольныеЗначения.Колонки.Добавить(Ресурс.Имя, Ресурс.Тип);
	КонецЦикла;
	
	Реквизиты = Метаданные.РегистрыНакопления.бит_КонтрольныеЗначенияБюджетов.Реквизиты;
	Для Каждого Реквизит Из Реквизиты Цикл
		КонтрольныеЗначения.Колонки.Добавить(Реквизит.Имя, Реквизит.Тип);
	КонецЦикла;
	
	Возврат КонтрольныеЗначения;

КонецФункции

Функция КодПериодичности(Периодичность) Экспорт
	
	Коды = Новый Соответствие; 
	Коды.Вставить(Перечисления.бит_ПериодичностьПланирования.День, 6);
	Коды.Вставить(Перечисления.бит_ПериодичностьПланирования.Неделя, 7);
	Коды.Вставить(Перечисления.бит_ПериодичностьПланирования.Декада, 8);
	Коды.Вставить(Перечисления.бит_ПериодичностьПланирования.Месяц, 9);
	Коды.Вставить(Перечисления.бит_ПериодичностьПланирования.Квартал, 10);
	Коды.Вставить(Перечисления.бит_ПериодичностьПланирования.Полугодие, 11);
	Коды.Вставить(Перечисления.бит_ПериодичностьПланирования.Год, 12);

	Код = Коды.Получить(Периодичность);
	Если Код = Неопределено Тогда
		Код = 0;
	КонецЕсли;
	
	Возврат Код;
	
КонецФункции

Процедура ОчиститьНеИспользуемыеАналитики(Данные) Экспорт 
	
	НастройкиСтатей = НастройкиСтатей(Данные.ВыгрузитьКолонку("СтатьяОборотов"));
	НастройкиПолей	= НастройкиСтатей.НастройкиПолей;
	ДанныеСтатей 	= НастройкиСтатей.ДанныеСтатей;
	
	Для каждого СтрокаТаблицы Из Данные Цикл
		ПравилаУчета = ДанныеСтатей.Получить(СтрокаТаблицы.СтатьяОборотов);
		Для Инд = 1 По 12 Цикл
			ИмяПоля 	 = НастройкиПолей["Аналитика_" + Строка(Инд)];
			ОписаниеТипа = Данные.Колонки[ИмяПоля].ТипЗначения;
			Если ПравилаУчета = Неопределено Тогда
				ВедетсяУчет = Ложь;
			Иначе	
				ВедетсяУчет = ПравилаУчета[ИмяПоля];
			КонецЕсли;
			Если НЕ ВедетсяУчет Тогда
				СтрокаТаблицы[ИмяПоля] = ОписаниеТипа.ПривестиЗначение(Неопределено);
			Иначе
				// Не заполненые значения составного типа очистить.
				Если НЕ ЗначениеЗаполнено(СтрокаТаблицы[ИмяПоля]) Тогда
					СтрокаТаблицы[ИмяПоля] = ОписаниеТипа.ПривестиЗначение(Неопределено);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

КонецПроцедуры

Функция ПустаяТаблицаИсполнениеБюджетаДляЦелейКонтроля() Экспорт

	КонтрольныеЗначения = Новый ТаблицаЗначений;
	КонтрольныеЗначения.Колонки.Добавить("ИмяСписка",     ОбщегоНазначения.ОписаниеТипаСтрока(50));
	КонтрольныеЗначения.Колонки.Добавить("СинонимСписка", ОбщегоНазначения.ОписаниеТипаСтрока(50));
	КонтрольныеЗначения.Колонки.Добавить("Период",        ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	КонтрольныеЗначения.Колонки.Добавить("НомерСтроки",   ОбщегоНазначения.ОписаниеТипаЧисло(5, 0));
	
	КонтрольныеЗначения.Колонки.Добавить("Сумма",   				 ОбщегоНазначения.ОписаниеТипаЧисло(15, 2));
	КонтрольныеЗначения.Колонки.Добавить("Количество",   			 ОбщегоНазначения.ОписаниеТипаЧисло(15, 3));
	КонтрольныеЗначения.Колонки.Добавить("КонтролироватьСумму",   	 Новый ОписаниеТипов("Булево"));
	КонтрольныеЗначения.Колонки.Добавить("КонтролироватьКоличество", Новый ОписаниеТипов("Булево"));
	КонтрольныеЗначения.Колонки.Добавить("КонтролироватьПоСтатье",   Новый ОписаниеТипов("Булево"));
	
	Измерения = Метаданные.РегистрыНакопления.бит_КонтрольныеЗначенияБюджетов.Измерения;
	Для Каждого Измерение Из Измерения Цикл
		КонтрольныеЗначения.Колонки.Добавить(Измерение.Имя, Измерение.Тип);
	КонецЦикла;
		
	Возврат КонтрольныеЗначения;

