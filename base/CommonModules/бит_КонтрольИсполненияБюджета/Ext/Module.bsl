Процедура ВывестиСообщениеОПривышенииСуммыЛимитов(Сумма, СуммаОсталосьПогасить, Реквизиты, ИмяСписка, СинонимСписка, НомерСтроки, Отказ)

	ТекстОшибки = НСтр("ru='Указанная сумма превышает лимит бюджета. Остаток: %1; Не хватает: %2 (%3)'; 
					   |en='The specified amount exceeds the budget limit. Remaining: %1; Missing: %2 (%3)'");
	
	НеХватает 	= СуммаОсталосьПогасить - Мин(0, Сумма);
	ТекстОшибки = СтрШаблон(ТекстОшибки, Сумма, НеХватает, Реквизиты.ВалютаСценария);
	
	ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(
		?(ЗначениеЗаполнено(СинонимСписка), "Колонка", "Поле"), "Корректность",
		НСтр("ru='Сумма';en='Amount'"), НомерСтроки, СинонимСписка, ТекстОшибки);
		
	Если НЕ ЗначениеЗаполнено(СинонимСписка) Тогда
		ПолеОбъекта = "Сумма";
	Иначе
		ПолеОбъекта = ИмяСписка + "[" + Формат(НомерСтроки - 1, "ЧН=0; ЧГ=") + "].Сумма";
	КонецЕсли;
	
	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Реквизиты.Регистратор, ПолеОбъекта, "Объект", Отказ);

