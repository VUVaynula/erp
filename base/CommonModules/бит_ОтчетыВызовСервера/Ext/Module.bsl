////////////////////////////////////////////////////////////////////////////////
// Процедуры и функции, используемые для работы в отчетах.
//
////////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

#Область ВыводРезультатаДополниетльныеОпции

// Процедура выводит копию результата в отдельном окне.
// 
// Параметры:
//  Результат - ТабличныйДокумент.
//
// Возвращаемое значение:
//  Табличный документ.
//
Функция СформироватьКопиюРезультата(Знач Результат) Экспорт
	
	ТабДок = бит_ОтчетыСервер.СформироватьКопиюРезультата(Результат);
	
	Возврат ТабДок;
		
КонецФункции

#КонецОбласти

#Область Расшифровки

// Функция получает пользовательские настройки отчета - расшифровки.
// 
// Параметры:
//  ИмяОтчета  	 - Строка.
//  ДопПараметры - Структура.
//  
// Возвращаемое значение:
//  ПользовательскиеНастройкиКомпоновщикаДанных.
// 
Функция ПолучитьПользовательскиеНастройкиОтчета(Знач ИмяОтчета, Знач ДопПараметры) Экспорт
    
    ПользовательскиеНастройки = бит_ОтчетыСервер.ПолучитьПользовательскиеНастройкиОтчета(ИмяОтчета, ДопПараметры);
	Возврат ПользовательскиеНастройки;
	
КонецФункции

// Функция получает данные расшифровки.
// 
// Параметры:
//  Расшифровка 	  - ИдентификаторРасшифровкиКомпоновкиДанных.
//  ДанныеРасшифровки - Строка.
//  
// Возвращаемое значение:
//  Любое значение.
// 
Функция ПолучитьДанныеРасшифровки(Расшифровка, ДанныеРасшифровки, ДополнительныеПунктыМеню) Экспорт
	
	СтруктураРасшифровки = бит_ОтчетыСервер.ПолучитьДанныеРасшифровки(Расшифровка, ДанныеРасшифровки, ДополнительныеПунктыМеню);				                            			
	Возврат СтруктураРасшифровки;
	
КонецФункции

// Функция получает ссылку для обработки расшифровки.
// 
// Параметры:
//  Расшифровка 	  - ИдентификаторРасшифровкиКомпоновкиДанных.
//  ДанныеРасшифровки - Строка.
//  
// Возвращаемое значение:
//  Любое значение.
// 
Функция ПолучитьСсылкуРасшифровки(Знач Расшифровка, Знач ДанныеРасшифровки) Экспорт
	
	ЗначениеРасшифровки = бит_ОтчетыСервер.ПолучитьСсылкуРасшифровки(Расшифровка, ДанныеРасшифровки);	
	Возврат ЗначениеРасшифровки;
	
КонецФункции

#КонецОбласти

// Функция получает рамки настроек отчетов.
// 
// Возвращаемое значение:
//  Структура - рамки настроек отчетов из элементов стиля.
// 
Функция РамкиНастроекОтчетов() Экспорт

	РамкиНастроек = бит_ОтчетыСервер.РамкиНастроекОтчетов();	
	Возврат РамкиНастроек;
	
КонецФункции

#КонецОбласти
