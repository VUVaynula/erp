	СтрокаОбъекта.ОбъектКлючВизы = МетаданныеОбъекта;
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "Казначей";
	
	МетаданныеОбъекта = МетаданныеДокументы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств;
	СтрокаОбъекта = ДеревоАлгоримтов.Строки.Добавить();
	СтрокаОбъекта.ОбъектКлючВизы = МетаданныеОбъекта;
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "Казначей";
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "ФинансовыйДиректор";
	
	МетаданныеОбъекта = МетаданныеДокументы.бит_кзн_ЗаявкаНаРасходованиеСредств;
	СтрокаОбъекта = ДеревоАлгоримтов.Строки.Добавить();
	СтрокаОбъекта.ОбъектКлючВизы = МетаданныеОбъекта;
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "Казначей";
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "ФинансовыйДиректор";
	
	МетаданныеОбъекта = МетаданныеДокументы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств;
	СтрокаОбъекта = ДеревоАлгоримтов.Строки.Добавить();
	СтрокаОбъекта.ОбъектКлючВизы = МетаданныеОбъекта;
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "Казначей";
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "ФинансовыйДиректор";
	
	МетаданныеОбъекта = МетаданныеДокументы.бит_мдм_ЗаявкаНаИзменение;
	СтрокаОбъекта = ДеревоАлгоримтов.Строки.Добавить();
	СтрокаОбъекта.ОбъектКлючВизы = МетаданныеОбъекта;
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "ОтветственныйНСИ";
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "СпециалистМДМ";
	
	МетаданныеОбъекта = МетаданныеДокументы.бит_мдм_ЗаявкаНаУдаление;
	СтрокаОбъекта = ДеревоАлгоримтов.Строки.Добавить();
	СтрокаОбъекта.ОбъектКлючВизы = МетаданныеОбъекта;
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "ОтветственныйНСИ";
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "СпециалистМДМ";
	
	МетаданныеОбъекта = МетаданныеДокументы.Найти("бит_ОтветНаЗапросНалоговогоМониторинга");
	Если МетаданныеОбъекта <> Неопределено Тогда
		СтрокаОбъекта = ДеревоАлгоримтов.Строки.Добавить();
		СтрокаОбъекта.ОбъектКлючВизы = МетаданныеОбъекта;
		СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
		СтрокаВизы.ОбъектКлючВизы = "НалоговыйИнспектор";
	КонецЕсли;
	
	МетаданныеСтандартныхАлгоритмов = Новый Массив;
	МетаданныеСтандартныхАлгоритмов.Добавить(МетаданныеДокументы.бит_АктуализацияБюджета);
	МетаданныеСтандартныхАлгоритмов.Добавить(МетаданныеДокументы.бит_БюджетнаяОперация);
	МетаданныеСтандартныхАлгоритмов.Добавить(МетаданныеДокументы.бит_ДополнительныеУсловияПоДоговору);
	МетаданныеСтандартныхАлгоритмов.Добавить(МетаданныеДокументы.бит_кзн_РеестрПлатежей);
	МетаданныеСтандартныхАлгоритмов.Добавить(МетаданныеДокументы.бит_КорректировкаБюджета);
	МетаданныеСтандартныхАлгоритмов.Добавить(МетаданныеДокументы.бит_КорректировкаКонтрольныхЗначений);
	МетаданныеСтандартныхАлгоритмов.Добавить(МетаданныеДокументы.бит_ПротоколРасхожденийБюджета);
	МетаданныеСтандартныхАлгоритмов.Добавить(МетаданныеДокументы.бит_ФормаВводаБюджета);
	МетаданныеСтандартныхАлгоритмов.Добавить(Метаданные.Справочники.бит_ВнутренниеДокументы);
	Для каждого МетаданныеОбъекта Из МетаданныеСтандартныхАлгоритмов Цикл
		ДобавитьСтандартныйАлгоритмПроверенУтвержден(ДеревоАлгоримтов, МетаданныеОбъекта);
	КонецЦикла;
	
КонецПроцедуры

Функция ОбъектыВизированияОтлюченныеПоУмолчанию() Экспорт
	
