#Область СлужебныйПрограммныйИнтерфейс

Процедура ДействияПослеУстановкиСтатуса(Объект, ПараметрыУстановкиСтатуса, КэшОпераций) Экспорт
	
	ТипОбъекта = ТипЗнч(Объект);
	ТипСсылки  = ТипЗнч(Объект.Ссылка);
	Если ТипОбъекта = Тип("ДокументОбъект.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию")
		ИЛИ ТипОбъекта = Тип("ДокументОбъект.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда
		Если ПараметрыУстановкиСтатуса.ВнешняяУстановкаСтатуса Тогда
			СсылкаНаОбъект = Объект.Ссылка;
			РезультатПоискаПоз  = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(СсылкаНаОбъект);
			РезультатПоискаПост = Документы.бит_кзн_ПозицияПоступления.НайтиПозициюПоОснованию(СсылкаНаОбъект);
				
			ПозицияОб = РезультатПоискаПоз.Позиция.ПолучитьОбъект();
			бит_ВизированиеСервер.УстановитьСтатус(ПозицияОб);
			ПоступлениеОб = РезультатПоискаПост.Позиция.ПолучитьОбъект();
			бит_ВизированиеСервер.УстановитьСтатус(ПоступлениеОб);
		КонецЕсли;
	ИначеЕсли ТипОбъекта = Тип("ДокументОбъект.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
		Если ПараметрыУстановкиСтатуса.ВнешняяУстановкаСтатуса Тогда
			СсылкаНаОбъект  = Объект.Ссылка;
			РезультатПоиска = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(СсылкаНаОбъект);
			Для каждого Позиция Из РезультатПоиска.МассивПозиций Цикл
				ПозицияОб = Позиция.ПолучитьОбъект();
				бит_ВизированиеСервер.УстановитьСтатус(ПозицияОб);
			КонецЦикла;
		КонецЕсли;
	ИначеЕсли ТипОбъекта = Тип("ДокументОбъект.бит_кзн_ПланируемоеПоступлениеДенежныхСредств") Тогда
		Если ПараметрыУстановкиСтатуса.ВнешняяУстановкаСтатуса Тогда
			СсылкаНаОбъект  = Объект.Ссылка;
			РезультатПоиска = Документы.бит_кзн_ПозицияПоступления.НайтиПозициюПоОснованию(СсылкаНаОбъект);
			Для каждого Позиция Из РезультатПоиска.МассивПозиций Цикл
				ПозицияОб = Позиция.ПолучитьОбъект();
				бит_ВизированиеСервер.УстановитьСтатус(ПозицияОб);
			КонецЦикла;
		КонецЕсли;
	ИначеЕсли ТипОбъекта = Тип("ДокументОбъект.бит_кзн_ПлатежнаяПозиция") Тогда
		Документы.бит_кзн_ПлатежнаяПозиция.ОбновитьСтатусыСвязанныхРеестров(Объект.Ссылка);
	ИначеЕсли Метаданные.ОпределяемыеТипы.бит_ДоговорыКонтрагентов.Тип.СодержитТип(ТипСсылки) Тогда
		Объект.ДополнительныеСвойства.Вставить("ОтключитьОпределениеСтатуса", Истина);
		УстановитьСтатусДоговораПоСтатусуВизирования(Объект);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДополнитьКонтекстПользовательскогоУсловия(ПользовательскоеУсловие, СтруктураКонтекст) Экспорт
	
	КодУсловия = ПользовательскоеУсловие.КодУсловия;
	
	Если ТипЗнч(СтруктураКонтекст.ТекущийОбъект.Ссылка) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция") Тогда		
		   
		Если НЕ СтруктураКонтекст.Свойство("ОплатаЗаявки") Тогда
			СтруктураОплат = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.ПолучитьОплатыПоПозиции(СтруктураКонтекст.ТекущийОбъект.Ссылка);
			СтруктураКонтекст.Вставить("ОплатаЗаявки",СтруктураОплат);
		КонецЕсли; 
		
	ИначеЕсли ТипЗнч(СтруктураКонтекст.ТекущийОбъект.Ссылка) = Тип("ДокументСсылка.бит_кзн_ПозицияПоступления") Тогда		
		
		СтруктураОплат = Документы.бит_кзн_ПозицияПоступления.СтруктураОплатыПоПозиции(СтруктураКонтекст.ТекущийОбъект.Ссылка);
		Если НЕ СтруктураКонтекст.Свойство("ОплатаЗаявки") Тогда
			СтруктураКонтекст.Вставить("ОплатаЗаявки",СтруктураОплат);
		КонецЕсли;
		Если НЕ СтруктураКонтекст.Свойство("ОплатаПоступления") Тогда
			СтруктураКонтекст.Вставить("ОплатаПоступления",СтруктураОплат);
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(СтруктураКонтекст.ТекущийОбъект.Ссылка) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
		
		Если НЕ СтруктураКонтекст.Свойство("ОплатаЗаявки") Тогда
			СтруктураОплат = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.ПолучитьОплатыПоЗаявке(СтруктураКонтекст.ТекущийОбъект.Ссылка);
			СтруктураКонтекст.Вставить("ОплатаЗаявки",СтруктураОплат);
		КонецЕсли; 
		
	ИначеЕсли ТипЗнч(СтруктураКонтекст.ТекущийОбъект.Ссылка) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств")
		ИЛИ ТипЗнч(СтруктураКонтекст.ТекущийОбъект.Ссылка) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда
		
		Если НЕ СтруктураКонтекст.Свойство("ОплатаЗаявки") Тогда
			СтруктураОплат = Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.СтруктураОплатыПоЗаявкеНаПеремещение(СтруктураКонтекст.ТекущийОбъект.Ссылка);
			СтруктураКонтекст.Вставить("ОплатаЗаявки",СтруктураОплат);
		КонецЕсли; 
		
	ИначеЕсли ТипЗнч(СтруктураКонтекст.ТекущийОбъект.Ссылка) = Тип("ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств") Тогда
		
		Если НЕ СтруктураКонтекст.Свойство("ОплатаПоступления") Тогда			
			СтруктураОплат = Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ПолучитьОплатыПоПоступлению(СтруктураКонтекст.ТекущийОбъект.Ссылка);
			СтруктураКонтекст.Вставить("ОплатаПоступления",СтруктураОплат);
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(СтруктураКонтекст.ТекущийОбъект.Ссылка) = Тип("ДокументСсылка.бит_пз_ЗаявкаНаЗатраты") Тогда
		
		Если НЕ СтруктураКонтекст.Свойство("ПланируемыеЗатраты") Тогда			
			ПланируемыеЗатраты = Документы.бит_пз_ЗаявкаНаЗатраты.ПолучитьОстаткиДляУстановкиСтатуса(СтруктураКонтекст.ТекущийОбъект.Ссылка);
			СтруктураКонтекст.Вставить("ПланируемыеЗатраты", ПланируемыеЗатраты);
		КонецЕсли;
				
    КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьПозициюПользовательскогоУсловия(РезультатПроверкиПозиций, СтрокаУсловия, СтруктураКонтекст) Экспорт
	
	РезультатУсловия  = Ложь;
	ОбъектПроверки    = СтруктураКонтекст.ТекущийОбъект.Ссылка;
	ЛевоеПоле         = СтрокаУсловия.Свойство;
	ЗначениеСравнения = ЗначениеПоляСравнения(СтрокаУсловия, СтруктураКонтекст);
	
	Если СтрНачинаетсяС(ЛевоеПоле, "ЗначениеЗаполнено(РеквизитыПозиции.")
		И СтрЗаканчиваетсяНа(ЛевоеПоле, ")") Тогда
		Поле = СтрЗаменить(ЛевоеПоле, "ЗначениеЗаполнено(РеквизитыПозиции.", "");
		Поле = Лев(Поле, СтрДлина(Поле) - 1);
		ЗначенияПоляПозиций = ЗначенияПоляПозиций(ОбъектПроверки, Поле);
		ЗаполненоЗначение   = Ложь;
		Для каждого ЗначениеПоля Из ЗначенияПоляПозиций Цикл
			Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
				ЗаполненоЗначение = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если СтрокаУсловия.ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.НеРавно Тогда
			РезультатУсловия = (ЗаполненоЗначение <> ЗначениеСравнения);
		Иначе
			РезультатУсловия = (ЗаполненоЗначение = ЗначениеСравнения);
		КонецЕсли;
	Иначе
		Поле             = СтрЗаменить(ЛевоеПоле, "РеквизитыПозиции.", "");
		РезультатУсловия = УловиеПозицииВыполнено(ОбъектПроверки, Поле, СтрокаУсловия.ВидСравнения, ЗначениеСравнения);
	КонецЕсли;
	РезультатПроверкиПозиций.Вставить(СтрокаУсловия.ИД, РезультатУсловия);
	
КонецПроцедуры

Процедура ПользовательскоеУсловиеПозицияСодержитЗначение(РезультатыПроверок, ПользовательскоеУсловие, СтрокаТаблицы, СтруктураКонтекст) Экспорт
	
	ИмяРеквизита = Справочники.бит_ПользовательскиеУсловия.ПолучитьПараметрУсловия(ПользовательскоеУсловие.ПараметрыУсловий,
																					СтрокаТаблицы.ИД,
																					"ИмяРеквизита",
																					"UnrealAttribute");
	ПроверяемоеЗначение = Справочники.бит_ПользовательскиеУсловия.ПолучитьПараметрУсловия(ПользовательскоеУсловие.ПараметрыУсловий,
																					СтрокаТаблицы.ИД,
																					"Значение",
																					Неопределено);
	СодержитЗначение = ПозицияСодержитЗначение(СтруктураКонтекст.ТекущийОбъект, ИмяРеквизита, ПроверяемоеЗначение);												
	РезультатыПроверок.Вставить(СтрокаТаблицы.ИД, СодержитЗначение);
	
КонецПроцедуры

// Функция определяет, есть ли в позициях документа 
// планирования указанные значения указанного реквизита.
//
// Параметры:
//  ТекущийОбъект - ДокументОбъект, ДокументСсылка 
//  ИмяРеквизита - Строка
//  ТекущееЗначение - Произвольный
//
// Возвращаемое значение:
//  Результат - Строка.
//
Функция ПозицияСодержитЗначение(ТекущийОбъект, ИмяРеквизита, ТекущееЗначение) Экспорт
	
	Если ТекущийОбъект = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", ТекущийОбъект.Ссылка);
	Запрос.УстановитьПараметр("ТекущееЗначение"     , ТекущееЗначение);
	
	Если ТипЗнч(ТекущийОбъект) = Тип("ДанныеФормыСтруктура") Тогда
		ИмяОбъекта = ТекущийОбъект.Ссылка.Метаданные().Имя;
	Иначе
		ИмяОбъекта = ТекущийОбъект.Метаданные().Имя;
	КонецЕсли; 
	
	ТекстЗапроса = "";
	Если ИмяОбъекта = Метаданные.Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.Имя
		ИЛИ ИмяОбъекта = Метаданные.Документы.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию.Имя Тогда
		
		Если бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, Метаданные.Документы.бит_кзн_ПлатежнаяПозиция) 
			И бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, Метаданные.Документы.бит_кзн_ПозицияПоступления) Тогда
			
			ТекстЗапроса = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	бит_кзн_ПлатежнаяПозиция.Ссылка
			|ИЗ
			|	Документ.бит_кзн_ПлатежнаяПозиция КАК бит_кзн_ПлатежнаяПозиция
			|ГДЕ
			|	бит_кзн_ПлатежнаяПозиция.ДокументПланирования = &ДокументПланирования
			|	И НЕ бит_кзн_ПлатежнаяПозиция.ПометкаУдаления
			|	И бит_кзн_ПлатежнаяПозиция.%1 = &ТекущееЗначение
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	бит_кзн_ПозицияПоступления.Ссылка
			|ИЗ
			|	Документ.бит_кзн_ПозицияПоступления КАК бит_кзн_ПозицияПоступления
			|ГДЕ
			|	бит_кзн_ПозицияПоступления.ДокументПланирования = &ДокументПланирования
			|	И НЕ бит_кзн_ПозицияПоступления.ПометкаУдаления
			|	И бит_кзн_ПозицияПоступления.%1 = &ТекущееЗначение";
			
			ТекстЗапроса = СтрШаблон(ТекстЗапроса, ИмяРеквизита);
			
		Иначе
			Возврат Ложь;
		КонецЕсли;
		
	ИначеЕсли ИмяОбъекта = Метаданные.Документы.бит_кзн_ПлатежнаяПозиция.Имя Тогда
		
		Если бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, Метаданные.Документы.бит_кзн_ПлатежнаяПозиция) Тогда
			
			ТекстЗапроса = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	бит_кзн_ПлатежнаяПозиция.Ссылка
			|ИЗ
			|	Документ.бит_кзн_ПлатежнаяПозиция КАК бит_кзн_ПлатежнаяПозиция
			|ГДЕ
			|	бит_кзн_ПлатежнаяПозиция.Ссылка = &ДокументПланирования
			|	И бит_кзн_ПлатежнаяПозиция.%1 = &ТекущееЗначение";
			
			ТекстЗапроса = СтрШаблон(ТекстЗапроса, ИмяРеквизита);
			
		Иначе
			Возврат Ложь;
		КонецЕсли;
		
	ИначеЕсли ИмяОбъекта = Метаданные.Документы.бит_кзн_ПозицияПоступления.Имя Тогда
		
		Если бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, Метаданные.Документы.бит_кзн_ПозицияПоступления) Тогда
			
			ТекстЗапроса = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	бит_кзн_ПозицияПоступления.Ссылка
			|ИЗ
			|	Документ.бит_кзн_ПозицияПоступления КАК бит_кзн_ПозицияПоступления
			|ГДЕ
			|	бит_кзн_ПозицияПоступления.Ссылка = &ДокументПланирования
			|	И бит_кзн_ПозицияПоступления.%1 = &ТекущееЗначение";
			
			ТекстЗапроса = СтрШаблон(ТекстЗапроса, ИмяРеквизита);
			
		Иначе
			Возврат Ложь;
		КонецЕсли;
		
	Иначе	
		
		ИмяПоз = ИмяПозиций(ИмяОбъекта);
		МетаПозиция = Метаданные.Документы[ИмяПоз];
		
		Если бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, МетаПозиция) Тогда
			
			ТекстЗапроса =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Позициии.Ссылка
			|ИЗ
			|	Документ.%1 КАК Позициии
			|ГДЕ
			|	Позициии.ДокументПланирования = &ДокументПланирования
			|	И Позициии.%2 = &ТекущееЗначение";
			
			ТекстЗапроса = СтрШаблон(ТекстЗапроса, ИмяПоз, ИмяРеквизита);
			
		Иначе	
			Возврат Ложь;
		КонецЕсли; 
		
	КонецЕсли;
	
	Запрос.Текст     = ТекстЗапроса;
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат НЕ РезультатЗапроса.Пустой();

КонецФункции

Процедура ПользовательскоеУсловиеПозицияСодержитЗначениееВГруппе(РезультатыПроверок, ПользовательскоеУсловие, СтрокаТаблицы, СтруктураКонтекст) Экспорт
	
	ИмяРеквизита        = Справочники.бит_ПользовательскиеУсловия.ПолучитьПараметрУсловия(ПользовательскоеУсловие.ПараметрыУсловий,
																							СтрокаТаблицы.ИД,
																							"ИмяРеквизита",
																							"UnrealAttribute");
	ПроверяемоеЗначение = Справочники.бит_ПользовательскиеУсловия.ПолучитьПараметрУсловия(ПользовательскоеУсловие.ПараметрыУсловий,
																							СтрокаТаблицы.ИД,
																							"Значение",
																							Неопределено);
	СодержитЗначение    = ПозицияСодержитЗначениеВГруппе(СтруктураКонтекст.ТекущийОбъект, ИмяРеквизита, ПроверяемоеЗначение);												
	РезультатыПроверок.Вставить(СтрокаТаблицы.ИД, СодержитЗначение);
	
КонецПроцедуры

Процедура ПользовательскоеУсловиеСуммаПозиций(РезультатыПроверок, СтрокаТаблицы, СтруктураКонтекст) Экспорт
	
	ТекущийОбъект = СтруктураКонтекст.ТекущийОбъект;
	СуммаПозиций  = 0;
	
	ИмяОбъекта = ТекущийОбъект.Метаданные().Имя;
	ИмяПоз = ИмяПозиций(ИмяОбъекта);	
	Запрос = Новый Запрос; 
	Запрос.УстановитьПараметр("ДокументПланирования", ТекущийОбъект.Ссылка);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СУММА(бит_кзн_ПлатежнаяПозиция.СуммаДокумента) КАК СуммаДокумента
	|ИЗ
	|	#Таблица КАК бит_кзн_ПлатежнаяПозиция
	|ГДЕ
	|	бит_кзн_ПлатежнаяПозиция.ДокументПланирования = &ДокументПланирования
	|	И НЕ бит_кзн_ПлатежнаяПозиция.ПометкаУдаления";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"#Таблица", СтрШаблон("Документ.%1",ИмяПоз));
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		СуммаПозиций = ?(ТипЗнч(Выборка.СуммаДокумента) = Тип("Число"), Выборка.СуммаДокумента, 0);
	КонецЕсли; 
	
	РезультатыПроверок.Вставить(СтрокаТаблицы.ИД, СуммаПозиций);
	
КонецПроцедуры

// Функция определяет имя позиции по имени объекта.
//
// Параметры:
//  ИмяОбъекта - строка
//
// Возвращаемое значение:
//  ИмяПоз - Строка.
//
Функция ИмяПозиций(ИмяОбъекта) Экспорт
	
	Если ИмяОбъекта = Метаданные.Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.Имя Тогда
		ИмяПоз = Метаданные.Документы.бит_кзн_ПлатежнаяПозиция.Имя;
	ИначеЕсли ИмяОбъекта = Метаданные.Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Имя Тогда
		ИмяПоз = Метаданные.Документы.бит_кзн_ПозицияПоступления.Имя;
	Иначе	
		ИмяПоз = Метаданные.Документы.бит_кзн_ПозицияПоступления.Имя;
	КонецЕсли; 
	
	Возврат ИмяПоз;
	
КонецФункции

Процедура ЗаполнитьОбъектыСистемыВПоставляемыхГруппах(ТаблицаОбъектов) Экспорт
	
	Менеджер = Справочники.бит_СтатусыОбъектов;
	
	Менеджер.ДобавитьВОбъектыСистемы(Менеджер.СтатусыРеестраПлатежей,
									Метаданные.Документы.бит_кзн_РеестрПлатежей,
									ТаблицаОбъектов);
	Менеджер.ДобавитьВОбъектыСистемы(Менеджер.СтатусыДоговорыКонтрагентов,
									Метаданные.Справочники.ДоговорыКонтрагентов,
									ТаблицаОбъектов);
	Менеджер.ДобавитьВОбъектыСистемы(Менеджер.СтатусыЗаявкиНаЗатраты,
									Метаданные.Документы.бит_пз_ЗаявкаНаЗатраты,
									ТаблицаОбъектов);
	Менеджер.ДобавитьВОбъектыСистемы(Менеджер.СтатусыЗаявкиНаПеремещениеДС,
									Метаданные.Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств,
									ТаблицаОбъектов);
	Менеджер.ДобавитьВОбъектыСистемы(Менеджер.СтатусыЗаявкиНаРасходованиеСредств,
									Метаданные.Документы.бит_кзн_ЗаявкаНаРасходованиеСредств,
									ТаблицаОбъектов);
	Менеджер.ДобавитьВОбъектыСистемы(Менеджер.СтатусыПланируемоеПоступлениеДС,
									Метаданные.Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств,
									ТаблицаОбъектов);
	Менеджер.ДобавитьВОбъектыСистемы(Менеджер.СтатусыСводнойЗаявкиНаЗатраты,
									Метаданные.Документы.бит_пз_СводнаяЗаявкаНаЗатраты,
									ТаблицаОбъектов);
	Менеджер.ДобавитьВОбъектыСистемы(Менеджер.СтатусыЗаявкиНаПереводСредствВДругуюОрганизацию, 
									Метаданные.Документы.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию,
									ТаблицаОбъектов);
	
КонецПроцедуры

