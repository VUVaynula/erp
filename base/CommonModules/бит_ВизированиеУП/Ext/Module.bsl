	Элемент.Объект						= ОбъектСистемы;
	Элемент.ЗапретИзмененияВложений		= Ложь;
	Элемент.ТипСтатуса					= Перечисления.бит_ТипыСтатусовОбъектов.Исполнен;

	Элемент = Элементы.Добавить();
	Элемент.ИмяПредопределенныхДанных	= "СводнаяЗаявкаНаЗатраты_ЧастичноИсполнена";
	Элемент.Родитель					= Справочники.бит_СтатусыОбъектов.СтатусыСводнойЗаявкиНаЗатраты;
	Элемент.Наименование				= НСтр("ru = 'Частично исполнена'; en = 'Partially executed'", КодОсновногоЯзыка);
	Элемент.Код							= "000000152";
	Элемент.Порядок						= 1;
	Элемент.Объект						= ОбъектСистемы;
	Элемент.ЗапретИзмененияВложений		= Ложь;
	Элемент.ТипСтатуса					= Перечисления.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен;
	
	#КонецОбласти
	
КонецПроцедуры

Функция НеВыполнятьПроверкуСтатусаДляОбъекта(Объект)Экспорт
	
	ТипСсылки = ТипЗнч(Объект.Ссылка);
	Если Метаданные.ОпределяемыеТипы.бит_ДоговорыКонтрагентов.Тип.СодержитТип(ТипСсылки)
		ИЛИ ТипСсылки = Тип("СправочникСсылка.СоглашенияСКлиентами")
		ИЛИ ТипСсылки = Тип("СправочникСсылка.СоглашенияСПоставщиками") Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЗначениеПоляСравнения(СтрокаУсловия, СтруктураКонтекст)
	
	ЗначениеСравнения = СтруктураКонтекст.ЗначенияПользовательскихУсловий.Получить(СтрокаУсловия.ИД);
	Если ТипЗнч(ЗначениеСравнения) = Тип("Строка") Тогда
		Если СтрСравнить(ЗначениеСравнения, "Прочее.ТекущийПользователь") = 0 Тогда
			ЗначениеСравнения = СтруктураКонтекст.Прочее.ТекущийПользователь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЗначениеСравнения;
	
КонецФункции

Функция ЗначенияПоляПозиций(ДокументПланирования, Поле)
	
	ЗначенияПоля = Новый Массив;
	
	ТипДокумента  = ТипЗнч(ДокументПланирования);
	МетаДокументы = Метаданные.Документы;
	
	СтекПутиРеквизита = СтрРазделить(Поле, ".");
	Если СтекПутиРеквизита.Количество() = 0 Тогда
		Возврат ЗначенияПоля;
	КонецЕсли;
	ИмяПоляРеквизита = СтекПутиРеквизита[0];
	
	ЭтоПлатежнаяПозиция         = (ТипДокумента = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция"));
	ЭтоПозицияПоступления       = (ТипДокумента = Тип("ДокументСсылка.бит_кзн_ПозицияПоступления"));
									
	РеквизитыПозиции = МетаДокументы.бит_кзн_ПлатежнаяПозиция.Реквизиты;
	ПроверятьПлатежныеПозиции   = ЭтоПлатежнаяПозиция
									ИЛИ РеквизитыПозиции.ДокументПланирования.Тип.СодержитТип(ТипДокумента)
									И (РеквизитыПозиции.Найти(ИмяПоляРеквизита) <> Неопределено);
	РеквизитыПозиции = МетаДокументы.бит_кзн_ПозицияПоступления.Реквизиты;
	ПроверятьПозицииПоступления = ЭтоПозицияПоступления
									ИЛИ РеквизитыПозиции.ДокументПланирования.Тип.СодержитТип(ТипДокумента)
									И (РеквизитыПозиции.Найти(ИмяПоляРеквизита) <> Неопределено);
									
	Если НЕ ПроверятьПлатежныеПозиции И НЕ ПроверятьПозицииПоступления Тогда
		Возврат ЗначенияПоля;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Если ПроверятьПлатежныеПозиции И ПроверятьПозицииПоступления Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ПлатежныеПозиции.Комментарий КАК Ссылка
		|ИЗ
		|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
		|ГДЕ
		|	ПлатежныеПозиции.ДокументПланирования = &ДокументПланирования
		|		ИЛИ ПлатежныеПозиции.Ссылка = &ДокументПланирования
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПозицияПоступления.Комментарий
		|ИЗ
		|	Документ.бит_кзн_ПозицияПоступления КАК ПозицияПоступления
		|ГДЕ
		|	ПозицияПоступления.ДокументПланирования = &ДокументПланирования
		|		ИЛИ ПозицияПоступления.Ссылка = &ДокументПланирования";
	Иначе
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ДокументыПозиции.Комментарий КАК Ссылка
		|ИЗ
		|	&ДокументыПозиции КАК ДокументыПозиции
		|ГДЕ
		|	ДокументыПозиции.ДокументПланирования = &ДокументПланирования";
		ДокументПозиции = ?(ПроверятьПлатежныеПозиции, "Документ.бит_кзн_ПлатежнаяПозиция",
							"Документ.бит_кзн_ПозицияПоступления");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ДокументыПозиции", ДокументПозиции);
		Если ЭтоПлатежнаяПозиция ИЛИ ЭтоПозицияПоступления Тогда
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
							"ДокументыПозиции.ДокументПланирования",
							"ДокументыПозиции.Ссылка");
		КонецЕсли;
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, ".Комментарий", "." + Поле);
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументПланирования);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		ЗначенияПоля = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
	КонецЕсли;
	
	Возврат ЗначенияПоля;
	
КонецФункции

Функция УловиеПозицииВыполнено(ДокументПланирования, Знач Поле, ВидСравнения, Знач ПравоеЗначение)
	
	ТипДокумента  = ТипЗнч(ДокументПланирования);
	МетаДокументы = Метаданные.Документы;
	ЭтоПлатежнаяПозиция         = (ТипДокумента = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция"));
	ЭтоПозицияПоступления       = (ТипДокумента = Тип("ДокументСсылка.бит_кзн_ПозицияПоступления"));
	ПроверятьПлатежныеПозиции   = ЭтоПлатежнаяПозиция
									ИЛИ МетаДокументы.бит_кзн_ПлатежнаяПозиция.Реквизиты.ДокументПланирования.Тип.СодержитТип(ТипДокумента);
	ПроверятьПозицииПоступления = ЭтоПозицияПоступления
									ИЛИ МетаДокументы.бит_кзн_ПозицияПоступления.Реквизиты.ДокументПланирования.Тип.СодержитТип(ТипДокумента);
	
	Если НЕ ПроверятьПлатежныеПозиции И НЕ ПроверятьПозицииПоступления Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Если ПроверятьПлатежныеПозиции И ПроверятьПозицииПоступления Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ПлатежныеПозиции.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ДокументыПозиции
		|ИЗ
		|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
		|ГДЕ
		|	(ПлатежныеПозиции.Ссылка = &ДокументПланирования
		|			ИЛИ ПлатежныеПозиции.ДокументПланирования = &ДокументПланирования
		|				И НЕ ПлатежныеПозиции.ПометкаУдаления)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПозицияПоступления.Ссылка
		|ИЗ
		|	Документ.бит_кзн_ПозицияПоступления КАК ПозицияПоступления
		|ГДЕ
		|	(ПозицияПоступления.Ссылка = &ДокументПланирования
		|			ИЛИ ПозицияПоступления.ДокументПланирования = &ДокументПланирования
		|				И НЕ ПозицияПоступления.ПометкаУдаления)";
	Иначе
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ДокументыПозиции.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ДокументыПозиции
		|ИЗ
		|	&ДокументыПозиции КАК ДокументыПозиции
		|ГДЕ
		|	ДокументыПозиции.ДокументПланирования = &ДокументПланирования
		|	И НЕ ДокументыПозиции.ПометкаУдаления";
		ДокументПозиции = ?(ПроверятьПлатежныеПозиции, "Документ.бит_кзн_ПлатежнаяПозиция",
							"Документ.бит_кзн_ПозицияПоступления");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ДокументыПозиции", ДокументПозиции);
		Если ЭтоПлатежнаяПозиция ИЛИ ЭтоПозицияПоступления Тогда
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
							"ДокументыПозиции.ДокументПланирования",
							"ДокументыПозиции.Ссылка");
		КонецЕсли;
	КонецЕсли;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументПланирования);
	Запрос.Выполнить();
	ТекстЗапроса =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДокументыПозиции.Ссылка КАК Ссылка
	|ИЗ
	|	ДокументыПозиции КАК ДокументыПозиции
	|ГДЕ
	|	&УсловиеПроверки";
	
	Если ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.Равно
		ИЛИ ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.НачинаетсяС Тогда
		ШаблонУсловия = "%1 = %2";
	ИначеЕсли ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.НеРавно
		ИЛИ ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.НеНачинаетсяС Тогда
		ШаблонУсловия = "%1 <> %2";
	ИначеЕсли ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.Больше Тогда
		ШаблонУсловия = "%1 > %2";
	ИначеЕсли ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.Меньше Тогда
		ШаблонУсловия = "%1 < %2";
	ИначеЕсли ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.БольшеИлиРавно Тогда
		ШаблонУсловия = "%1 >= %2";
	ИначеЕсли ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.МеньшеИлиРавно Тогда
		ШаблонУсловия = "%1 <= %2";
	ИначеЕсли ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.ВГруппе
		ИЛИ ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.ВГруппеИзСписка Тогда
		ШаблонУсловия = "%1 В ИЕРАРХИИ (%2)";
	ИначеЕсли ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.НЕВГруппе
		ИЛИ ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.НеВГруппеИзСписка Тогда
		ШаблонУсловия = "НЕ %1 В ИЕРАРХИИ (%2)";
	ИначеЕсли ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.Содержит Тогда
		ШаблонУсловия = "%1 ПОДОБНО %2";
	ИначеЕсли ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.НеСодержит Тогда
		ШаблонУсловия = "НЕ %1 ПОДОБНО %2";
	ИначеЕсли ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.ВСписке Тогда
		ШаблонУсловия = "%1 В (%2)";
	ИначеЕсли ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.НеВСписке Тогда
		ШаблонУсловия = "НЕ %1 В (%2)";
	КонецЕсли;
	
	ПутьКПолю = "ДокументыПозиции.Ссылка." + Поле;
	Если ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.НачинаетсяС
		ИЛИ ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.НеНачинаетсяС Тогда
		ШаблонПути         = "ПОДСТРОКА(%1, %2)";
		КоличествоСимволов = Формат(СтрДлина(ПравоеЗначение), "ЧГ=");
		ПутьКПолю          = СтрШаблон(ШаблонПути, ПутьКПолю, КоличествоСимволов);
	КонецЕсли;
	
	Если ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.Содержит
		ИЛИ ВидСравнения = Перечисления.бит_ВидыСравненияТрансляции.НеСодержит Тогда
		ПравоеЗначение = "%" + ПравоеЗначение + "%";
	КонецЕсли;
	
	Если ТипЗнч(ПравоеЗначение) = Тип("Строка")
		И СтрНачинаетсяС(ПравоеЗначение, "РеквизитыПозиции.") Тогда
		ПутьКПравомуЗначению = СтрЗаменить(ПравоеЗначение, "РеквизитыПозиции.", "ДокументыПозиции.Ссылка.");
		УсловиеПроверки      = СтрШаблон(ШаблонУсловия, ПутьКПолю, ПутьКПравомуЗначению);
	Иначе
		УсловиеПроверки = СтрШаблон(ШаблонУсловия, ПутьКПолю, "&ПараметрУсловия");
		Запрос.УстановитьПараметр("ПараметрУсловия", ПравоеЗначение);
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеПроверки", УсловиеПроверки);
	Запрос.Текст = ТекстЗапроса;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат НЕ РезультатЗапроса.Пустой();
	
КонецФункции

// Функция определяет, есть ли в позициях документа 
// планирования указанные значения указанного реквизита.
//
// Параметры:
//  ТекущийОбъект - ДокументОбъект, ДокументСсылка 
//  ИмяРеквизита - Строка
//  ТекущееЗначение - Произвольный
//
// Возвращаемое значение:
//  Результат - Строка.
//
Функция ПозицияСодержитЗначениеВГруппе(ТекущийОбъект, ИмяРеквизита, ТекущееЗначение)
	
	Если ТекущийОбъект = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", ТекущийОбъект.Ссылка);
	Запрос.УстановитьПараметр("ТекущееЗначение"     , ТекущееЗначение);
	
	Если ТипЗнч(ТекущийОбъект) = Тип("ДанныеФормыСтруктура") Тогда
		ИмяОбъекта = ТекущийОбъект.Ссылка.Метаданные().Имя;
	Иначе
		ИмяОбъекта = ТекущийОбъект.Метаданные().Имя;
	КонецЕсли; 
	
	ТекстЗапроса = "";
	
	Если ИмяОбъекта = Метаданные.Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.Имя
		ИЛИ ИмяОбъекта = Метаданные.Документы.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию.Имя Тогда
		
		Если бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, Метаданные.Документы.бит_кзн_ПлатежнаяПозиция) 
			И бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, Метаданные.Документы.бит_кзн_ПозицияПоступления) Тогда
			
			ТекстЗапроса = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	бит_кзн_ПлатежнаяПозиция.Ссылка
			|ИЗ
			|	Документ.бит_кзн_ПлатежнаяПозиция КАК бит_кзн_ПлатежнаяПозиция
			|ГДЕ
			|	бит_кзн_ПлатежнаяПозиция.ДокументПланирования = &ДокументПланирования
			|	И НЕ бит_кзн_ПлатежнаяПозиция.ПометкаУдаления
			|	И бит_кзн_ПлатежнаяПозиция.%1 В ИЕРАРХИИ (&ТекущееЗначение)
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	бит_кзн_ПозицияПоступления.Ссылка
			|ИЗ
			|	Документ.бит_кзн_ПозицияПоступления КАК бит_кзн_ПозицияПоступления
			|ГДЕ
			|	бит_кзн_ПозицияПоступления.ДокументПланирования = &ДокументПланирования
			|	И НЕ бит_кзн_ПозицияПоступления.ПометкаУдаления
			|	И бит_кзн_ПозицияПоступления.%1 В ИЕРАРХИИ (&ТекущееЗначение)";
			
			ТекстЗапроса = СтрШаблон(ТекстЗапроса, ИмяРеквизита);
			
		Иначе	
			Возврат Ложь;
		КонецЕсли;
		
	ИначеЕсли ИмяОбъекта = Метаданные.Документы.бит_кзн_ПлатежнаяПозиция.Имя Тогда
		
		Если бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, Метаданные.Документы.бит_кзн_ПлатежнаяПозиция) Тогда
			
			ТекстЗапроса = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	бит_кзн_ПлатежнаяПозиция.Ссылка
			|ИЗ
			|	Документ.бит_кзн_ПлатежнаяПозиция КАК бит_кзн_ПлатежнаяПозиция
			|ГДЕ
			|	бит_кзн_ПлатежнаяПозиция.Ссылка = &ДокументПланирования
			|	И бит_кзн_ПлатежнаяПозиция.%1 В ИЕРАРХИИ (&ТекущееЗначение)";
			
			ТекстЗапроса = СтрШаблон(ТекстЗапроса, ИмяРеквизита);
			
		Иначе
			Возврат Ложь;
		КонецЕсли;
		
	ИначеЕсли ИмяОбъекта = Метаданные.Документы.бит_кзн_ПозицияПоступления.Имя Тогда
		
		Если бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, Метаданные.Документы.бит_кзн_ПозицияПоступления) Тогда
			
			ТекстЗапроса = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	бит_кзн_ПозицияПоступления.Ссылка
			|ИЗ
			|	Документ.бит_кзн_ПозицияПоступления КАК бит_кзн_ПозицияПоступления
			|ГДЕ
			|	бит_кзн_ПозицияПоступления.Ссылка = &ДокументПланирования
			|	И бит_кзн_ПозицияПоступления.%1 В ИЕРАРХИИ (&ТекущееЗначение)";
			
			ТекстЗапроса = СтрШаблон(ТекстЗапроса, ИмяРеквизита);
			
		Иначе
			Возврат Ложь;
		КонецЕсли;
		
	Иначе	
		
		ИмяПоз = ИмяПозиций(ИмяОбъекта);
		МетаПозиция = Метаданные.Документы[ИмяПоз];
		
		Если бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, МетаПозиция) Тогда
			
			ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	Позициии.Ссылка
			|ИЗ
			|	Документ.%1 КАК Позициии
			|ГДЕ
			|	Позициии.ДокументПланирования = &ДокументПланирования
			|	И Позициии.%2 В ИЕРАРХИИ (&ТекущееЗначение)";
			
			ТекстЗапроса = СтрШаблон(ТекстЗапроса, ИмяПоз, ИмяРеквизита);
			
		Иначе	
			Возврат Ложь;
		КонецЕсли; 
		
	КонецЕсли; 
	
	Запрос.Текст     = ТекстЗапроса;
	РезультатЗапроса = Запрос.Выполнить();
	Возврат НЕ РезультатЗапроса.Пустой();

КонецФункции

Процедура ДобавитьСтандартныйАлгоритмПроверенУтвержден(ДеревоАлгоримтов, МетаданныеОбъекта)
	
	СтрокаОбъекта = ДеревоАлгоримтов.Строки.Добавить();
	СтрокаОбъекта.ОбъектКлючВизы = МетаданныеОбъекта;
	
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "ДокументПроверен";
	СтрокаВизы = СтрокаОбъекта.Строки.Добавить();
	СтрокаВизы.ОбъектКлючВизы = "ДокументУтвержден";
	
КонецПроцедуры

// Устанавливает статус договора контрагента. 
//
// Параметры:
//  ТекущийОбъект - СправочникСсылка.
//
Процедура УстановитьСтатусДоговораПоСтатусуВизирования(ТекущийОбъект)
	
	ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(ТекущийОбъект.Ссылка);
	
	Если Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ТекущийСтатус,
				Перечисления.бит_ТипыСтатусовОбъектов.Утвержден) Тогда

		Если ТипЗнч(ТекущийОбъект) = Тип("СправочникОбъект.СоглашенияСКлиентами") Тогда
			ТекущийОбъект.Статус = Перечисления.СтатусыСоглашенийСКлиентами.Действует;
		ИначеЕсли ТипЗнч(ТекущийОбъект) = Тип("СправочникОбъект.СоглашенияСПоставщиками") Тогда
			ТекущийОбъект.Статус = Перечисления.СтатусыСоглашенийСПоставщиками.Действует;
		Иначе 
			ТекущийОбъект.Статус = Перечисления.СтатусыДоговоровКонтрагентов.Действует;
		КонецЕсли;
		
	ИначеЕсли Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ТекущийСтатус,
				Перечисления.бит_ТипыСтатусовОбъектов.Закрыт) Тогда
		
		Если ТипЗнч(ТекущийОбъект) = Тип("СправочникОбъект.СоглашенияСКлиентами") Тогда
			ТекущийОбъект.Статус = Перечисления.СтатусыСоглашенийСКлиентами.Закрыто;
		ИначеЕсли ТипЗнч(ТекущийОбъект) = Тип("СправочникОбъект.СоглашенияСПоставщиками") Тогда
			ТекущийОбъект.Статус = Перечисления.СтатусыСоглашенийСПоставщиками.Закрыто;
		Иначе 
			ТекущийОбъект.Статус = Перечисления.СтатусыДоговоровКонтрагентов.Закрыт;
		КонецЕсли;
		
	Иначе
		
		Если ТипЗнч(ТекущийОбъект) = Тип("СправочникОбъект.СоглашенияСКлиентами") Тогда
			ТекущийОбъект.Статус = Перечисления.СтатусыСоглашенийСКлиентами.НеСогласовано;
		ИначеЕсли ТипЗнч(ТекущийОбъект) = Тип("СправочникОбъект.СоглашенияСПоставщиками") Тогда
			ТекущийОбъект.Статус = Перечисления.СтатусыСоглашенийСПоставщиками.НеСогласовано;
		Иначе 
			ТекущийОбъект.Статус = Перечисления.СтатусыДоговоровКонтрагентов.НеСогласован;
		КонецЕсли;

	КонецЕсли;
	
	ТекущийОбъект.Записать();
		
КонецПроцедуры

#КонецОбласти