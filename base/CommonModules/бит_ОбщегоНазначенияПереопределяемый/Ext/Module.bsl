#Область ПровекаПозиций

Функция ИспользуетсяМеханизмПозиций(Источник) Экспорт
	
	// ++ ЕРП
	Если ТипЗнч(Источник) = Тип("Тип") Тогда
		Если Источник = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию")
			ИЛИ Источник = Тип("ДокументОбъект.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию")
			ИЛИ Источник = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств")
			ИЛИ Источник = Тип("ДокументОбъект.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств")
			ИЛИ Источник = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств")
			ИЛИ Источник = Тип("ДокументОбъект.бит_кзн_ЗаявкаНаРасходованиеСредств")
			ИЛИ Источник = Тип("ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств")
			ИЛИ Источник = Тип("ДокументОбъект.бит_кзн_ПланируемоеПоступлениеДенежныхСредств")
			ИЛИ Источник = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция")
			ИЛИ Источник = Тип("ДокументОбъект.бит_кзн_ПлатежнаяПозиция")
			ИЛИ Источник = Тип("ДокументСсылка.бит_кзн_ПозицияПоступления")
			ИЛИ Источник = Тип("ДокументОбъект.бит_кзн_ПозицияПоступления") Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;
	// -- ЕРП
	
	Возврат Ложь;
	
КонецФункции

