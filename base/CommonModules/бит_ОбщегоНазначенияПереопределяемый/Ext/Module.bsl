// См. СозданиеНаОснованииПереопределяемый.ПриОпределенииОбъектовСКомандамиСозданияНаОсновании.
//
Процедура ПриОпределенииОбъектовСКомандамиСозданияНаОсновании(Объекты) Экспорт
	
	Объекты.Добавить(Метаданные.Документы.бит_ИсковоеТребование);
	Объекты.Добавить(Метаданные.Документы.бит_Претензия);
	Объекты.Добавить(Метаданные.Документы.бит_УтверждениеСоставаИнвесторов);
	Объекты.Добавить(Метаданные.Справочники.бит_ВнутренниеДокументы);
	
КонецПроцедуры

#КонецОбласти 

#Область СлужебныйПрограммныйИнтерфейс 

#Область ПроведениеОтменаПроведения

Процедура ОбработкаПроведенияНачало(ДокументОбъект, ВыборочноОчищатьРегистры = Истина) Экспорт

	Если НЕ ВыборочноОчищатьРегистры Тогда
		Регистры = Новый Массив; 
		Для каждого Проводки Из ДокументОбъект.Движения Цикл
			Регистры.Добавить(Проводки.Метаданные().Имя);
		КонецЦикла; 
		ПроведениеДокументов.ОчиститьДвиженияДокумента(ДокументОбъект, СтрСоединить(Регистры, ","));
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроведенияЗавершение(ДокументОбъект, Отказ) Экспорт

	ДопПараметры = ПроведениеДокументов.ДопПараметрыИнициализироватьДанныеДокументаДляПроведения();
	ДопПараметры.ДополнительныеСвойства = ДокументОбъект.ДополнительныеСвойства;
	
	ПроведениеДокументов.ОбработкаПроведенияДокумента(ДокументОбъект, Отказ, ДопПараметры);

КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(ДокументОбъект, Отказ) Экспорт
	
	ПроведениеДокументов.ПриЗаписиДокумента(ДокументОбъект, Отказ);
	
КонецПроцедуры

Процедура ПередЗаписьюДокумента(ДокументОбъект, РежимЗаписи, РежимПроведения) Экспорт
	
	ПроведениеДокументов.ПередЗаписьюДокумента(ДокументОбъект, РежимЗаписи, РежимПроведения);
	
	ДокументОбъект.ДополнительныеСвойства.Вставить("Проведен"   , ДокументОбъект.Проведен);
	ДокументОбъект.ДополнительныеСвойства.Вставить("ЭтоНовый"   , ДокументОбъект.ЭтоНовый());
	ДокументОбъект.ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписи);
		
КонецПроцедуры

