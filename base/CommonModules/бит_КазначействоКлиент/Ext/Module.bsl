
#Область ПрограммныйИнтерфейс

#Область КомандыВводаНаОсновании

// Обработчик подключенной команды.
//
// Параметры:
//   ПараметрКоманды - Массив Из ЛюбаяСсылка - ссылки выбранных объектов, для которых выполняется команда.
//   ПараметрыВыполнения - см. ПодключаемыеКомандыКлиент.ПараметрыВыполненияКоманды
//
Процедура СоздатьЗаявкуНаРасходованиеСредств(ПараметрКоманды, ПараметрыВыполнения) Экспорт
	
	ПараметрыВыполненияКоманды = Новый Структура("Источник,Уникальность,Окно,НавигационнаяСсылка");
	ЗаполнитьЗначенияСвойств(ПараметрыВыполненияКоманды, ПараметрыВыполнения.ОписаниеКоманды.ДополнительныеПараметры);

	Если НЕ ПараметрыВыполнения.ОписаниеКоманды.МножественныйВыбор Тогда
		Основание = ПараметрКоманды;
	Иначе
		Основание = ПараметрКоманды[0];
	КонецЕсли;
	
	ТипыСОсобойОбработкойЗаполнения = Новый Массив; 
	ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.ПриобретениеТоваровУслуг"));
	ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.ЗаказПоставщику"));
	ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.ПриобретениеУслугПрочихАктивов"));
	ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.АвансовыйОтчет"));
	ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.ЗаявкаНаВозвратТоваровОтКлиента"));
	
	// ++ Локализация
	Если НЕ бит_ОбщегоНазначенияВызовСервера.ЭтоУТ() Тогда
		ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.ЗаказПереработчику2_5"));
		ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.ЗаказПереработчику"));
	КонецЕсли;
	Если бит_ОбщегоНазначенияКлиентСерверПереопределяемый.ЕстьДоговорыАренды() Тогда
		ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("СправочникСсылка.ДоговорыАренды"));
	КонецЕсли;
	// -- Локализация
	
	Если ТипыСОсобойОбработкойЗаполнения.Найти(ТипЗнч(Основание)) <> Неопределено Тогда
		МодульСтрокой		   = "Документ.бит_кзн_ЗаявкаНаРасходованиеСредств";
		ПараметрыОткрытияФормы = бит_КазначействоВызовСервера.ПараметрыФормыВводНаОсновании(МодульСтрокой, Основание);
		
		ОткрытьФорму(ПараметрыОткрытияФормы.ИмяФормы, ПараметрыОткрытияФормы.ПараметрыФормы,
				ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно);
	Иначе
		ПараметрыФормы = Новый Структура("Основание", Основание);
		ОткрытьФорму("Документ.бит_кзн_ПлатежнаяПозиция.ФормаОбъекта", ПараметрыФормы, ПараметрыВыполненияКоманды.Источник,
			ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно);
	КонецЕсли;
	
КонецПроцедуры

// Обработчик подключенной команды.
//
// Параметры:
//   ПараметрКоманды - Массив Из ЛюбаяСсылка - ссылки выбранных объектов, для которых выполняется команда.
//   ПараметрыВыполнения - см. ПодключаемыеКомандыКлиент.ПараметрыВыполненияКоманды
//
Процедура СоздатьПланируемоеПоступлениеСредств(ПараметрКоманды, ПараметрыВыполнения) Экспорт
	
	ПараметрыВыполненияКоманды = Новый Структура("Источник,Уникальность,Окно,НавигационнаяСсылка");
	ЗаполнитьЗначенияСвойств(ПараметрыВыполненияКоманды, ПараметрыВыполнения.ОписаниеКоманды.ДополнительныеПараметры);

	Если НЕ ПараметрыВыполнения.ОписаниеКоманды.МножественныйВыбор Тогда
		Основание = ПараметрКоманды;
	Иначе
		Основание = ПараметрКоманды[0];
	КонецЕсли;
	
	ТипыСОсобойОбработкойЗаполнения = Новый Массив; 
	ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.ЗаказКлиента"));
	ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.СчетНаОплатуКлиенту"));
	ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.РеализацияУслугПрочихАктивов"));
	ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.РеализацияТоваровУслуг"));
	ТипыСОсобойОбработкойЗаполнения.Добавить(Тип("ДокументСсылка.АктВыполненныхРабот"));

	Если ТипыСОсобойОбработкойЗаполнения.Найти(ТипЗнч(Основание)) <> Неопределено Тогда
		МодульСтрокой		   = "Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств";
		ПараметрыОткрытияФормы = бит_КазначействоВызовСервера.ПараметрыФормыВводНаОсновании(МодульСтрокой, Основание);
		
		ОткрытьФорму(ПараметрыОткрытияФормы.ИмяФормы, ПараметрыОткрытияФормы.ПараметрыФормы,
				ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно);
	Иначе
		ПараметрыФормы = Новый Структура("Основание", Основание);
		ОткрытьФорму("Документ.бит_кзн_ПозицияПоступления.ФормаОбъекта", ПараметрыФормы, ПараметрыВыполненияКоманды.Источник,
			ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

// Возвращает параметры подбора расчетных документов.
//
// Возвращаемое значение:
//	ПараметрыВыбора - Структура:
//		Организация - СправочникСсылка.Организации - Организация документа
//		Контрагент - СправочникСсылка.Контрагенты - Контрагент документа
//		ЭтоРасчетыСКлиентами - Булево - Признак расчетов с клиентами
//		Элемент - ПолеФормы - Поле для выбора документа расчетов
//		Партнер - СправочникСсылка.Партнеры - Партнер документа
//		Соглашение - Соглашение с клиентом или соглашение с поставщиком
//		ВыборОснованияПлатежа - Булево
//		ИсключитьХозяйственнуюОперацию - Булево
//		ПлатежиПо275ФЗ - Булево
//		ДоговорСУчастникомГОЗ - Булево
//		Валюта - СправочникСсылка.Валюты - Валюта документа
//		Сумма - Число - Сумма документа
//
Функция НовыеПараметрыВыбораРасчетныхДокументов() Экспорт
	
	ПараметрыВыбора = Новый Структура;
	ПараметрыВыбора.Вставить("Организация");
	ПараметрыВыбора.Вставить("Контрагент");
	ПараметрыВыбора.Вставить("ЭтоРасчетыСКлиентами");
	ПараметрыВыбора.Вставить("Элемент");
	ПараметрыВыбора.Вставить("Партнер",                        Неопределено);
	ПараметрыВыбора.Вставить("Соглашение",                     Неопределено);
	ПараметрыВыбора.Вставить("ВыборОснованияПлатежа",          Ложь);
	ПараметрыВыбора.Вставить("ИсключитьХозяйственнуюОперацию", Ложь);
	ПараметрыВыбора.Вставить("ПлатежиПо275ФЗ",                 Ложь);
	ПараметрыВыбора.Вставить("ДоговорСУчастникомГОЗ",          Ложь);
	ПараметрыВыбора.Вставить("Валюта",                         Неопределено);
	ПараметрыВыбора.Вставить("Сумма",                          0);
	
	Возврат ПараметрыВыбора;
	
КонецФункции

// Процедура вызывается из модуля формы документов при обработке оповещения
//
// Параметры:
//   Форма - Управляемая форма, для которой производится обработка оповещения
//   ДокументСсылка - ссылка на документ формы
//   ИмяСобытия - имя обрабатываемого события
//   Параметр - параметр, переданный в обработку оповещения
//   Источник - источник, переданный в обработку оповещения
Процедура ОбработкаОповещенияФормыДокумента(Форма, ДокументСсылка, ИмяСобытия, Параметр, Источник) Экспорт
	
	Если ИмяСобытия = "ВыполненаЗаписьДокумента" Тогда
		Если ДокументСсылка = Параметр.ДокументСсылка Тогда 
			Форма.Прочитать();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры	

Функция НовыеПараметрыДокументаДляПолученияДанныхБюджета() Экспорт

	ПараметрыДокумента = Новый Структура;
	
	ПараметрыДокумента.Вставить("ВалютаДокумента", ПредопределенноеЗначение("Справочник.Валюты.ПустаяСсылка"));
	ПараметрыДокумента.Вставить("Дата",            '00010101');
	ПараметрыДокумента.Вставить("ЕдиницаИзмеренияСумм",
									ПредопределенноеЗначение("Перечисление.бит_ЕдиницыИзмеренияСумм.Единицы"));
	ПараметрыДокумента.Вставить("ЕдиницаИзмеренияСуммДокумента",
									ПредопределенноеЗначение("Перечисление.бит_ЕдиницыИзмеренияСумм.Единицы"));
	ПараметрыДокумента.Вставить("КратностьДокумента", 1);
	ПараметрыДокумента.Вставить("КурсДокумента",      1);
	ПараметрыДокумента.Вставить("Параметр",
									ПредопределенноеЗначение("ПланВидовХарактеристик.бит_ВидыПроизвольныхПараметров.ПустаяСсылка"));
	ПараметрыДокумента.Вставить("Сценарий", ПредопределенноеЗначение("Справочник.СценарииПланирования.ПустаяСсылка"));
	
	Возврат ПараметрыДокумента;
	
КонецФункции

#КонецОбласти