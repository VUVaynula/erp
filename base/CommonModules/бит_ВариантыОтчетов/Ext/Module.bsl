// См. ВариантыОтчетовПереопределяемый.ОпределитьРазделыСВариантамиОтчетов(). 
//
Процедура ОпределитьРазделыСВариантамиОтчетов(Разделы) Экспорт
	
	Разделы.Добавить(Метаданные.Подсистемы.бит_КомИнт_Казначейство.Подсистемы.Отчеты, 
					 НСтр("ru='Отчеты по Казначейству';en='Reports on Treasury'"));

	Разделы.Добавить(Метаданные.Подсистемы.бит_Бюджетирование.Подсистемы.СтандартныеОтчеты, 
					 НСтр("ru='Стандартные отчеты бюджетирование';en='Standard report budgeting'"));
					 
	Разделы.Добавить(Метаданные.Подсистемы.бит_Бюджетирование.Подсистемы.Отчеты, 
					 НСтр("ru='Отчеты по бюджетированию';en='Budgeting reports'"));
					 
	// ++ НЕ УТ
	Разделы.Добавить(Метаданные.Подсистемы.бит_КомИнт_МСФО.Подсистемы.СтандартныеОтчеты,
					 НСтр("ru='Стандартные отчеты МСФО';en='Standard IFRS reports'"));
					 
	Разделы.Добавить(Метаданные.Подсистемы.бит_КомИнт_МСФО.Подсистемы.Отчеты, 
					 НСтр("ru='Отчеты по МСФО';en='Report IFRS'"));
	// -- НЕ УТ
	
	Разделы.Добавить(Метаданные.Подсистемы.бит_КомИнт_УправленческийУчет, 
					 НСтр("ru = 'Отчеты по управленческому учету'; en = 'Reports Managerial Accounting'"));
					 
	Разделы.Добавить(Метаданные.Подсистемы.бит_КомИнт__Настройки, 
					 НСтр("ru = 'Отчеты по настройкам БИТ.ФИНАНС'; en = 'Reports on settings'"));				 
					 
	Разделы.Добавить(Метаданные.Подсистемы.бит_КомИнт_ПолучениеДанных, 
					 НСтр("ru = 'Отчеты ""Получения данных""'"));
					 					 
КонецПроцедуры

