// См. ВариантыОтчетовПереопределяемый.ОпределитьОбъектыСКомандамиОтчетов().
Процедура ОпределитьОбъектыСКомандамиОтчетов(Объекты) Экспорт

	Объекты.Добавить(Метаданные.Документы.бит_кзн_ЗаявкаНаРасходованиеСредств);
	Объекты.Добавить(Метаданные.Документы.бит_кзн_ПлатежнаяПозиция);
	Объекты.Добавить(Метаданные.Документы.бит_кзн_ЗакрытиеДокументовПланирования);
	Объекты.Добавить(Метаданные.Документы.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию);
	Объекты.Добавить(Метаданные.Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств);
	Объекты.Добавить(Метаданные.Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств);
	Объекты.Добавить(Метаданные.Документы.бит_кзн_ПозицияПоступления);
	Объекты.Добавить(Метаданные.Документы.бит_кзн_РеестрПлатежей);
	Объекты.Добавить(Метаданные.Документы.бит_ОтражениеФактаДДС);
	
КонецПроцедуры

// См. ВариантыОтчетовПереопределяемый.ЗарегистрироватьИзмененияКлючейВариантовОтчетов();
//
Процедура ЗарегистрироватьИзмененияКлючейВариантовОтчетов(Изменения) Экспорт
	
	// ++ НЕ УТ
	Изменение = Изменения.Добавить();
	Изменение.Отчет = Метаданные.Отчеты.бит_КарточкаСчетаБюджетирование;
	Изменение.СтароеИмяВарианта = "бит_КарточкаСчета";
	Изменение.АктуальноеИмяВарианта = "КарточкаСчета";
	
	Изменение = Изменения.Добавить();
	Изменение.Отчет = Метаданные.Отчеты.бит_ОборотноСальдоваяВедомостьБюджетирование;
	Изменение.СтароеИмяВарианта = "бит_ОборотноСальдоваяВедомость";
	Изменение.АктуальноеИмяВарианта = "ОборотноСальдоваяВедомость";
	
	Изменение = Изменения.Добавить();
	Изменение.Отчет = Метаданные.Отчеты.бит_ОборотноСальдоваяВедомостьПоСчетуБюджетирование;
	Изменение.СтароеИмяВарианта = "бит_ОборотноСальдоваяВедомостьПоСчету";
	Изменение.АктуальноеИмяВарианта = "ОборотноСальдоваяВедомостьПоСчету";
	// -- НЕ УТ

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Отключает указанный отчет со всеми его вариантами от механизма "Варианты отчетов".
//
// Параметры:
//  ОписаниеОтчета - СтрокаДереваЗначений - Передается "как есть" из ВариантыОтчетов.ОписаниеОтчета().
//
Процедура ОтключитьОтчет(ОписаниеОтчета) Экспорт
	
	ОписаниеОтчета.Включен = Ложь;
	
КонецПроцедуры

Процедура РазместитьОтчетыБюджетированияПриПереходеНаНовуюВерсию() Экспорт

	ПодсистемаОтчеты 			 = Метаданные.Подсистемы.бит_Бюджетирование.Подсистемы.Отчеты;	
	ВсеОтчеты			 		 = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ПодсистемаОтчеты);
	ОтчетыПланирование			 = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ПодсистемаОтчеты.Подсистемы.Планирование);
	ОтчетыПланФактныйАнализ		 = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ПодсистемаОтчеты.Подсистемы.ПланФактныйАнализ);
	ОтчетыКонтрольЛимитов		 = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ПодсистемаОтчеты.Подсистемы.КонтрольЛимитов);
	ОтчетыСкользящееПланирование = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ПодсистемаОтчеты.Подсистемы.СкользящееПланирование);
	ОтчетыСоответствияАналитик	 = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(ПодсистемаОтчеты.Подсистемы.СоответствияАналитикШаблоныПроводок);
		
	ОписаниеОтчета = Новый Соответствие;
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_ОборотыБюджета, ОтчетыПланирование);
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_ОборотыБюджетаИОстаткиПоСчетам, ОтчетыПланирование);
	// ++ НЕ УТ
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_ОборотыБюджетаСРасчетами, ОтчетыПланирование);
	// -- НЕ УТ
	
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_АнализПричинРасхожденийБюджета, ОтчетыПланФактныйАнализ);
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_ПланФактныйАнализБюджета, ОтчетыПланФактныйАнализ);
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_ПланФактныйАнализБюджетаИОстаткиПоСчетам, ОтчетыПланФактныйАнализ);
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_ПланФактныйАнализБюджетаСРасчетами, ОтчетыПланФактныйАнализ);
	
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_КонтрольныеЗначенияБюджета, ОтчетыКонтрольЛимитов);
	
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_ПрогнозИсполненияБюджета, ОтчетыСкользящееПланирование);
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_ПрогнозИсполненияБюджетаСРасчетами, ОтчетыСкользящееПланирование);
	
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_УниверсальныеСоответствияАналитик, ОтчетыСоответствияАналитик);
	ОписаниеОтчета.Вставить(Метаданные.Отчеты.бит_ШаблоныПроводокБюджетирования, ОтчетыСоответствияАналитик);

	Для каждого КлючЗначение Из ОписаниеОтчета Цикл
		РазместитьОтчет(КлючЗначение.Ключ, КлючЗначение.Значение, ВсеОтчеты);
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура РазместитьОтчет(МетаданныеОтчета, Размещение, СтароеРазмещение)

	Отчет				 = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(МетаданныеОтчета);
	КлючиВариантовОтчета = ВариантыОтчетов.КлючиВариантовОтчета(МетаданныеОтчета.ПолноеИмя());
	
	Для каждого КлючВарианта Из КлючиВариантовОтчета Цикл
		ВариантОтчета = ВариантыОтчетов.ВариантОтчета(Отчет, КлючВарианта.Значение);
		
		НачатьТранзакцию();
		Попытка
			ВариантОбъект = ВариантОтчета.ПолучитьОбъект();
			Для каждого СтрокаТаблицы Из ВариантОбъект.Размещение Цикл
				Если СтрокаТаблицы.Подсистема = СтароеРазмещение Тогда
					СтрокаТаблицы.Подсистема = Размещение;
				КонецЕсли;
			КонецЦикла;
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ВариантОбъект);
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ТекстСообщения = НСтр("ru = 'Не удалось обработать справочик: %1 по причине:
									|%2'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ВариантОтчета, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(), 
				УровеньЖурналаРегистрации.Предупреждение,
				Метаданные.Справочники.ВариантыОтчетов, ВариантОтчета, ТекстСообщения);
		КонецПопытки;
	КонецЦикла;

КонецПроцедуры
	
#КонецОбласти
