#Область СлужебныйПрограммныйИнтерфейс

#Область ПлатежиПо275ФЗ

Процедура ЗаполнитьПодтверждающиеДокументы(Объект, УникальныйИдентификатор) Экспорт
	
	// ++ НЕ УТ
	Объект.ПодтверждающиеДокументы.Загрузить(
		ПолучитьИзВременногоХранилища(ДенежныеСредстваСерверЛокализация.ПодтверждающиеДокументыФЗ275(
			Объект.ТипПлатежаФЗ275, УникальныйИдентификатор, Объект.ДоговорСЗаказчиком)));
	// -- НЕ УТ
	
КонецПроцедуры

Процедура ЗаполнитьПредметыОплаты(ЭлементПредметОплаты, ТипПлатежаФЗ275, ТоварыРаботыУслугиСТарифнымРегулированием) Экспорт
	
	// ++ НЕ УТ
	ЭлементПредметОплаты.СписокВыбора.Очистить();
	Если ТипПлатежаФЗ275 = Справочники.ТипыПлатежейФЗ275.ОплатаТоваровРаботУслугПоРегулируемымЦенам Тогда
		Для каждого ПредметОплаты Из ТоварыРаботыУслугиСТарифнымРегулированием Цикл
			ЭлементПредметОплаты.СписокВыбора.Добавить(ПредметОплаты.Наименование);
		КонецЦикла;
	КонецЕсли;
	// -- НЕ УТ
	
КонецПроцедуры

Процедура ПроверитьЗаполнитьТипПлатежа275ФЗ(Объект, ПараметрыЗаполнения) Экспорт
	
	// ++ НЕ УТ
	Если ЗначениеЗаполнено(Объект.ТипПлатежаФЗ275) Тогда
		Возврат;
	КонецЕсли;
	
	ВидОперации = бит_Казначейство.ХозяйственнаяОперацияУП(Объект.ХозяйственнаяОперация);
	ПараметрыПлатежа = Новый Структура;
	ПараметрыПлатежа.Вставить("ПлатежиПо275ФЗ",        Объект.ПлатежиПо275ФЗ);
	ПараметрыПлатежа.Вставить("ХозяйственнаяОперация", ВидОперации);
	ПараметрыПлатежа.Вставить("ДоговорСУчастникомГОЗ", Объект.ДоговорСУчастникомГОЗ);
	ПараметрыПлатежа.Вставить("ОплатаРасходовПоТарифамСГосрегулированием",
								ПараметрыЗаполнения.ОплатаРасходовПоТарифамСГосрегулированием);
	ПараметрыПлатежа.Вставить("ИностранныйИсполнительВУтвержденномПеречнеГОЗ",
								ПараметрыЗаполнения.ИностранныйИсполнительВУтвержденномПеречнеГОЗ);
	ПараметрыПлатежа.Вставить("БанковскийСчет", Неопределено);

	ДоступныеТипыПлатежа275ФЗ = Справочники.ТипыПлатежейФЗ275.ДоступныеТипыПлатежа275ФЗ(ПараметрыПлатежа);
	Если ДоступныеТипыПлатежа275ФЗ.Количество() Тогда
		Объект.ТипПлатежаФЗ275 = ДоступныеТипыПлатежа275ФЗ[0];
		ЗаполнитьПодтверждающиеДокументы(Объект, ПараметрыЗаполнения.УникальныйИдентификатор);
	Иначе
		Объект.ТипПлатежаФЗ275 = Неопределено;
	КонецЕсли;
	// -- НЕ УТ
	
КонецПроцедуры

#КонецОбласти

Процедура ЗаполнитьПлатежныйДокумент(ПлатежныйДокумент, ПараметрыЗаполнения) Экспорт
	
	// ++ НЕ УТ
	Безналичные = ПараметрыЗаполнения.Безналичные;
	Ведомость   = ПараметрыЗаполнения.Ведомость;
	
	Если НЕ Безналичные
		И ТипЗнч(Ведомость) = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыРаздатчиком") Тогда
		Для каждого СтрокаВедомости Из Ведомость.Зарплата Цикл
			СтрокаВыплаты = ПлатежныйДокумент.ВыплатаЗаработнойПлаты.Добавить();
			СтрокаВыплаты.ФизическоеЛицо = СтрокаВедомости.ФизическоеЛицо;
			СтрокаВыплаты.Сумма          = СтрокаВедомости.КВыплате;
		КонецЦикла;
	КонецЕсли;
	// -- НЕ УТ
	
КонецПроцедуры

Процедура ПрименитьОграниченияВидовОперацийПоФункциональнымОпциям(ВидыОпераций) Экспорт
	
	// ++ НЕ УТ 
	Если НЕ ВнеоборотныеАктивы.ИспользуетсяУправлениеВНА() Тогда
		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(ВидыОпераций,
			Перечисления.бит_ВидыОперацийКазначейства.ОплатаАрендодателю);
	КонецЕсли;
	
	ВыдачаЗаймаСотрудникуНеДоступна = НЕ ПолучитьФункциональнуюОпцию("ИспользоватьЗаймыСотрудникам") 
									  И ПолучитьФункциональнуюОпцию("ИспользоватьНачислениеЗарплаты")
									  ИЛИ НЕ ПолучитьФункциональнуюОпцию("ИспользоватьНачислениеЗарплаты");
									  
	Если ВыдачаЗаймаСотрудникуНеДоступна Тогда
		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(ВидыОпераций,
			Перечисления.бит_ВидыОперацийКазначейства.ВыдачаЗаймаСотруднику);
	КонецЕсли;								  
	// -- НЕ УТ
	
КонецПроцедуры

#КонецОбласти
