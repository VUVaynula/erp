
#Область ПрограммныйИнтерфейс

// Обработчик события формы ПриСозданииНаСервере, который встраивается в формы документов,
// чтобы определить доступность чтения объекта.
//
// Параметры:
//  Форма	 - ФормаКлиентскогоПриложения - форма документа.
//
Процедура ПриСозданииНаСервере(Форма) Экспорт
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ДоступЗапрещен") Тогда
		Возврат;
	КонецЕсли; 
	
	Если Форма.ДоступЗапрещен Тогда
		ВызватьИсключение НСтр("ru = 'Нарушение прав доступа'; en = 'Access violation.'");
	КонецЕсли; 
	
КонецПроцедуры

// Обработчик события формы ПриЧтенииНаСервере, который встраивается в формы документов,
// чтобы определить доступность чтения объекта.
//
// Параметры:
//	Форма				 - ФормаКлиентскогоПриложения.
//  ПроверочнаяТаблица	 - ДокументТабличнаяЧасть - табличная часть проверяемого документа.
//  НаименованиеТаблицы	 - Строка	 -  наименование табличной части.
//
Процедура ПриЧтенииНаСервере(Форма, ПроверочнаяТаблица, НаименованиеТаблицы) Экспорт
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ДоступЗапрещен") Тогда
		Возврат;
	КонецЕсли;
	
	Если Форма.ДоступЗапрещен Тогда
		Возврат;
	КонецЕсли;
	
	Форма.ДоступЗапрещен = бит_УправлениеДоступомБФСлужебный.ДоступЗапрещен(ПроверочнаяТаблица, НаименованиеТаблицы);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// См. комментарий к одноименной процедуре в модуле УправлениеДоступомПереопределяемый.
Процедура ПриЗаполненииВидовДоступа(ВидыДоступа) Экспорт

	// ++ЕРП
	ВидДоступа = ВидыДоступа.Добавить();
	ВидДоступа.Имя = "ЦФО";
	ВидДоступа.Представление    = НСтр("ru = 'ЦФО'");
	ВидДоступа.ТипЗначений      = Тип("СправочникСсылка.Подразделения");
	
	ВидДоступа = ВидыДоступа.Добавить();
	ВидДоступа.Имя = "СтатьиОборотов";
	ВидДоступа.Представление    = НСтр("ru = 'Статьи оборотов'");
	ВидДоступа.ТипЗначений      = Тип("СправочникСсылка.бит_СтатьиОборотов");
	// --ЕРП
			
	ВидДоступа = ВидыДоступа.Добавить();
	ВидДоступа.Имя = "КлючиДоступаЦФОСтатьиОборотов";
	ВидДоступа.Представление    	  = НСтр("ru = 'ЦФО/Статьи оборотов'");
	ВидДоступа.ТипЗначений      	  = Тип("СправочникСсылка.бит_КлючиДоступаЦФОСтатьиОборотов");
	ВидДоступа.ТипГруппЗначений 	  = Тип("СправочникСсылка.бит_ГруппыКлючейДоступаЦФОСтатьиОборотов");
	ВидДоступа.НесколькоГруппЗначений = Истина;
	
	ВидДоступа = ВидыДоступа.Добавить();
	ВидДоступа.Имя           = "ВидыПроизвольныхФорм";
	ВидДоступа.Представление = НСтр("ru = 'Виды произвольных форм'; en = 'Forms formalities'");
	ВидДоступа.ТипЗначений   = Тип("СправочникСсылка.бит_ВидыПроизвольныхФорм");
	
	ВидДоступа = ВидыДоступа.Добавить();
	ВидДоступа.Имя           = "ВидыФормСбораДанных";
	ВидДоступа.Представление = НСтр("ru = 'Виды форм сбора данных'; en = 'Types of data collection forms'");
	ВидДоступа.ТипЗначений   = Тип("СправочникСсылка.бит_ВидыФормСбораДанных");
	
	ВидДоступа = ВидыДоступа.Добавить();
	ВидДоступа.Имя = "ВидыВнутреннихДокументов";
	ВидДоступа.Представление = НСтр("ru = 'Виды внутренних документов'; en = 'Types of internal documents'");
	ВидДоступа.ТипЗначений   = Тип("СправочникСсылка.бит_ВидыВнутреннихДокументов");
	
	Если Метаданные.Справочники.Найти("бит_мдм_ОписанияОбъектовОбмена") <> Неопределено Тогда
		
		// Есть МДМ
		
		ВидДоступа = ВидыДоступа.Добавить();
		ВидДоступа.Имя           = "бит_мдм_ОписанияОбъектовОбмена";
		ВидДоступа.Представление = НСтр("ru='Описания объектов обмена (БИТ.ФИНАНС.MDM)';
		                                |en='Descriptions of objects sharing (BIT.FINANS.MDM)'");
		ВидДоступа.ТипЗначений   = Тип("СправочникСсылка.бит_мдм_ОписанияОбъектовОбмена");
		
	КонецЕсли; 
	
	Если Метаданные.Справочники.Найти("бит_ВидыПроформ") <> Неопределено Тогда
        
        ВидДоступа = ВидыДоступа.Добавить();
		ВидДоступа.Имя           = "бит_ВидыПроформ";
		ВидДоступа.Представление = НСтр("ru='Виды проформ (БИТ.ФИНАНС)';
		                                |en='Forms formalities (BIT.FINANS)'");
		ВидДоступа.ТипЗначений   = Тип("СправочникСсылка.бит_ВидыПроформ");
        
    КонецЕсли;
	
КонецПроцедуры

// См. комментарий к одноименной процедуре в модуле УправлениеДоступомПереопределяемый. 
Процедура ПриЗаполненииИспользованияВидаДоступа(ВидДоступа, Использование) Экспорт
		
	УстановитьПривилегированныйРежим(Истина);
	
	// ++ЕРП
	Если ВидДоступа = "КлючиДоступаЦФОСтатьиОборотов" Тогда
		
		Использование = Константы.бит_ИспользоватьГруппыДоступаЦФОСтатьиОборотов.Получить();
		
	ИначеЕсли ВидДоступа = "ЦФО" ИЛИ ВидДоступа = "СтатьиОборотов" Тогда
		
		Использование = Не Константы.бит_ИспользоватьГруппыДоступаЦФОСтатьиОборотов.Получить();

	КонецЕсли;
	// --ЕРП
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

#КонецОбласти

