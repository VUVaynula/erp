КонецПроцедуры

// Процедура устанавливает признак неактивности у нижестоящих задач.
// Требуется для цикличных алгоритмов.
//
// Параметры:
// 	ПараметрыДеактивации - Структура. См. НовыеПараметрыДеактивации().
//
Процедура ДеактивироватьНижестоящиеЗадачи(ПараметрыДеактивации) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТочкиАлгоритмов.Ссылка КАК ТочкаАлгоритма,
	|	ТочкиАлгоритмов.ВидТочки КАК ВидТочки,
	|	ТочкиАлгоритмов.ПользовательскоеУсловие КАК ПользовательскоеУсловие,
	|	ТочкиАлгоритмов.ПользовательскийВыборВарианта КАК ПользовательскийВыборВарианта
	|ПОМЕСТИТЬ ТочкиАлгоритмов
	|ИЗ
	|	Справочник.бит_ТочкиАлгоритмов КАК ТочкиАлгоритмов
	|ГДЕ
	|	ТочкиАлгоритмов.Владелец = &Алгоритм
	|	И ТочкиАлгоритмов.АктивнаяТочкаМаршрута
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТочкиАлгоритмов.ТочкаАлгоритма КАК ТочкаАлгоритма,
	|	ЗадачиПроцесса.Ссылка КАК ЗадачаПроцесса
	|ПОМЕСТИТЬ ЗадачиПроцесса
	|ИЗ
	|	ТочкиАлгоритмов КАК ТочкиАлгоритмов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Задача.бит_Задача КАК ЗадачиПроцесса
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_НеактивныеЗадачи КАК НеактивныеЗадачи
	|			ПО ЗадачиПроцесса.Ссылка = НеактивныеЗадачи.НеактивнаяЗадача
	|		ПО ТочкиАлгоритмов.ТочкаАлгоритма = ЗадачиПроцесса.ТочкаАлгоритма
	|			И (ЗадачиПроцесса.БизнесПроцесс = &БизнесПроцесс)
	|ГДЕ
	|	НеактивныеЗадачи.НеактивнаяЗадача ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТочкиАлгоритмов.ТочкаАлгоритма КАК ТочкаАлгоритма,
	|	ТочкиАлгоритмов.ВидТочки КАК ВидТочки,
	|	ТочкиАлгоритмов.ПользовательскоеУсловие КАК ПользовательскоеУсловие,
	|	ТочкиАлгоритмов.ПользовательскийВыборВарианта КАК ПользовательскийВыборВарианта,
	|	ЕСТЬNULL(ЗадачиПроцесса.ЗадачаПроцесса, ЗНАЧЕНИЕ(Задача.бит_Задача.ПустаяСсылка)) КАК Задача
	|ИЗ
	|	ТочкиАлгоритмов КАК ТочкиАлгоритмов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЗадачиПроцесса КАК ЗадачиПроцесса
	|		ПО ТочкиАлгоритмов.ТочкаАлгоритма = ЗадачиПроцесса.ТочкаАлгоритма
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТочкиАлгоритмов.ТочкаАлгоритма КАК ТочкаАлгоритма,
	|	ИсходящиеТочки.Точка КАК ИсходящаяТочка,
	|	ИсходящиеТочки.ЗначениеУсловия КАК ЗначениеУсловия
	|ИЗ
	|	ТочкиАлгоритмов КАК ТочкиАлгоритмов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_ТочкиАлгоритмов.ИсходящиеТочки КАК ИсходящиеТочки
	|		ПО ТочкиАлгоритмов.ТочкаАлгоритма = ИсходящиеТочки.Ссылка";
	Запрос.УстановитьПараметр("Алгоритм",      ПараметрыДеактивации.Алгоритм);
	Запрос.УстановитьПараметр("БизнесПроцесс", ПараметрыДеактивации.БизнесПроцесс);
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ТочкиАлгоритма    = РезультатыЗапроса[2].Выгрузить();
	ТочкиАлгоритма.Индексы.Добавить("ТочкаАлгоритма");
	ИсходящиеТочки    = РезультатыЗапроса[3].Выгрузить();
	ИсходящиеТочки.Индексы.Добавить("ТочкаАлгоритма");
	
	ПараметрыДеактивации.ТочкиАлгоритма = ТочкиАлгоритма;
	ПараметрыДеактивации.ИсходящиеТочки = ИсходящиеТочки;
	
	ТекущаяТочка      = ПараметрыДеактивации.ТекущаяТочка;
	НижестоящиеЗадачи = Новый Массив;
	СтекПроверки      = Новый СписокЗначений;
	Отбор             = Новый Структура("ТочкаАлгоритма", ТекущаяТочка);
	ТекущиеИсходящиеТочки = ИсходящиеТочки.НайтиСтроки(Отбор);
	Для каждого СтрокаИсходящей Из ТекущиеИсходящиеТочки Цикл
		ДобавитьНижестоящиеЗадачи(СтрокаИсходящей.ИсходящаяТочка, ПараметрыДеактивации, НижестоящиеЗадачи, СтекПроверки);
	КонецЦикла;
	
	Для каждого Задача Из НижестоящиеЗадачи Цикл
		Менеджер = РегистрыСведений.бит_НеактивныеЗадачи.СоздатьМенеджерЗаписи();
		Менеджер.НеактивнаяЗадача = Задача;
		Менеджер.Записать();
	КонецЦикла;
	
КонецПроцедуры

Функция НовыеПараметрыДеактивации() Экспорт
	
	Параметры = Новый Структура;
	Параметры.Вставить("ТекущаяТочка",  Справочники.бит_ТочкиАлгоритмов.ПустаяСсылка());
	Параметры.Вставить("Алгоритм",      Справочники.бит_АлгоритмыПроцессов.ПустаяСсылка());
	Параметры.Вставить("БизнесПроцесс", БизнесПроцессы.бит_Процесс.ПустаяСсылка());
	Параметры.Вставить("ТочкиАлгоритма");
	Параметры.Вставить("ИсходящиеТочки");
	
	Возврат Параметры;
	
КонецФункции

#КонецОбласти

#Область ПроцедурыРаботыСТочкамиАлгоритма

// АПК:134-выкл Количество параметров более 7 для совместимости с предыдущими версиями библиотеки.

// Функция добавляет точку в указанный алгоритм и привязывает ее к входящей точки.
// 
// Параметры:
//  Алгоритм  - СправочникСсылка.бит_АлгоритмыПроцессов
//  ТочкаВходящая - СправочникСсылка.бит_ТочкиАлгоритмов
//  Направление   - ПеречислениеСсылка.бит_Направление
//  ВидТочки      - ПеречислениеСсылка.бит_ВидыТочекАлгоритмов
//  КоличествоТочек - Число
//  РежимСообщений  - Строка
//  СтрПар - Структура.
// 
// Возвращаемое значение:
//   НоваяТочка   - СправочникСсылка.бит_ТочкиАлгоритмов.
// 
Функция ДобавитьТочкуАлгоритма(Алгоритм, ТочкаВходящая, Направление, ВидТочки, КоличествоТочек,
								РежимСообщений = "Ошибки", СтрПар = Неопределено, ПервоначальноеЗаполнение = Ложь) Экспорт

	НоваяТочка = Справочники.бит_ТочкиАлгоритмов.ПустаяСсылка();
	
	ТочкаОб = Справочники.бит_ТочкиАлгоритмов.СоздатьЭлемент();
	ТочкаОб.ВидТочки     = ВидТочки;
	ТочкаОб.Наименование = Строка(ВидТочки)+" "+КоличествоТочек;
	ТочкаОб.Владелец     = Алгоритм;
	
	Если ПервоначальноеЗаполнение Тогда
		ТочкаОб.ДополнительныеСвойства.Вставить("ПроверитьЗаполнение", Ложь);
	КонецЕсли;
	
	Если ТипЗнч(СтрПар) = Тип("Структура") И СтрПар.Свойство("Реквизиты") Тогда
	
		Для каждого КиЗ Из СтрПар.Реквизиты Цикл
		
			ТочкаОб[КиЗ.Ключ] = КиЗ.Значение;
		
		КонецЦикла; 
	
	КонецЕсли; 	
	
	Если ЗначениеЗаполнено(ТочкаВходящая) Тогда
		
		НоваяСтрока = ТочкаОб.ВходящиеТочки.Добавить();
		НоваяСтрока.Точка       = ТочкаВходящая;
		НоваяСтрока.Направление = Направление;
		
	КонецЕсли; 
	
	флДействиеВыполнено = бит_ОбщегоНазначения.ЗаписатьСправочник(ТочкаОб,,РежимСообщений);
	Если флДействиеВыполнено  Тогда
	
		НоваяТочка = ТочкаОб.Ссылка;
		КоличествоТочек = КоличествоТочек+1;
		
		Если ЗначениеЗаполнено(ТочкаВходящая) Тогда
			
			ТочкаВхОб = ТочкаВходящая.ПолучитьОбъект();
			
			НоваяСтрока = ТочкаВхОб.ИсходящиеТочки.Добавить();
			НоваяСтрока.Точка = ТочкаОб.Ссылка;
			НоваяСтрока.Направление = Направление;
			
			Если ПервоначальноеЗаполнение Тогда
				ТочкаВхОб.ДополнительныеСвойства.Вставить("ПроверитьЗаполнение", Ложь);
			КонецЕсли;
			
			бит_ОбщегоНазначения.ЗаписатьСправочник(ТочкаВхОб,,РежимСообщений);
			
		КонецЕсли; 

	КонецЕсли; 
	
	Возврат НоваяТочка;
	
КонецФункции
