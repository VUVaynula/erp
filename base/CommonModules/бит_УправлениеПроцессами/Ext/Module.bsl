	Результат.Вставить(4, ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.Условие"));
	Результат.Вставить(5, ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.Действие"));
	Результат.Вставить(6, ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.ВыборВарианта"));
	Результат.Вставить(7, ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.Разделение"));
	Результат.Вставить(8, ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.Слияние"));
	Результат.Вставить(9, ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.Обработка"));
	Результат.Вставить(10, ПредопределенноеЗначение("Перечисление.бит_ВидыТочекАлгоритмов.ПодчиненныйПроцесс"));
	
	Возврат Результат;
	
КонецФункции

Функция ЗначениеСвойстваЭлемента(ЭлементDOM, ИмяСвойства) Экспорт
	
	СписокЭлементовDOM = ЭлементDOM.ПолучитьЭлементыПоИмени(ИмяСвойства);
	
	Если СписокЭлементовDOM.Количество() > 0 Тогда
		Возврат СписокЭлементовDOM[0].ТекстовоеСодержимое;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область ПроцедурыПостроенияАлгоритма

// Функция получает таблицу точек алгоритма.
// 
// Параметры:
//  Алгоритм      - СправочникСсылка.бит_АлгоритмыПроцессов
//  ТаблицаВизы   - ТаблицаЗначений
//  ТаблицаЗадачи - ТаблицаЗначений.
// 
// Возвращаемое значение:
//   ТаблицаЗначений.
// 
Функция ОписаниеТочекАлгоритма(Алгоритм, ТаблицаВизы = Неопределено, ТаблицаЗадачи = Неопределено) Экспорт

	Если ТаблицаВизы = Неопределено Тогда
		ТаблицаВизы = КонструкторТаблицыВиз();
	КонецЕсли; 
	
	ТаблицаТочки = ПолучитьТочкиАлгоритма(Алгоритм);
	
	// Полное соединение выполняем с использованием ТаблицЗначений, 
	// т.к. это в несколько раз быстрее, чем при использовании запроса.
	ТаблицаТочкиВизы = КонструкторТаблицыТочкиВизы();
	ПолноеСоединениеТочкиВизы(ТаблицаТочкиВизы,ТаблицаТочки,ТаблицаВизы);
	
	// Заполнение данных задач при необходимости.
	Если ТипЗнч(ТаблицаЗадачи) = Тип("ТаблицаЗначений") Тогда
		ЗаполнитьДанныеЗадач(ТаблицаТочкиВизы, ТаблицаЗадачи);
	КонецЕсли; 
	
	// Создадим колонки вручную, т.к. на Postgres запросом данные выбрать не удается.
	ТаблицаТочкиВизы.Колонки.Добавить("ВходящиеТочки",  Новый ОписаниеТипов("ТаблицаЗначений"));
	ТаблицаТочкиВизы.Колонки.Добавить("ИсходящиеТочки", Новый ОписаниеТипов("ТаблицаЗначений"));
	
	// Если таблица исходящих/входящих NULL инициализируем ее пустой таблицей с необходимой структурой.
	Для каждого СтрокаТаблицы Из ТаблицаТочкиВизы Цикл
		
		// Т.к. запросом для Postgres выбрать необходимые данные нельзя заполним их при обходе.
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ВходящиеТочки)  Тогда
			
			// Инициализируем таблицу связанных точек
			ТаблицаСвязанных = СтрокаТаблицы.Точка.ВходящиеТочки.Выгрузить();
			ТаблицаСвязанных.Колонки.Добавить("ВидТочки", Новый ОписаниеТипов("ПеречислениеСсылка.бит_ВидыТочекАлгоритмов"));
			
			Для каждого СтрокаСвязи Из ТаблицаСвязанных Цикл
				СтрокаСвязи.ВидТочки = СтрокаСвязи.Точка.ВидТочки;
			КонецЦикла;	
			
			СтрокаТаблицы.ВходящиеТочки = ТаблицаСвязанных;
			
		КонецЕсли; 
		
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ИсходящиеТочки) Тогда
			
			// Инициализируем таблицу связанных точек
			ТаблицаСвязанных = СтрокаТаблицы.Точка.ИсходящиеТочки.Выгрузить();
			ТаблицаСвязанных.Колонки.Добавить("ВидТочки", Новый ОписаниеТипов("ПеречислениеСсылка.бит_ВидыТочекАлгоритмов"));
			
			Для каждого СтрокаСвязи Из ТаблицаСвязанных Цикл
				СтрокаСвязи.ВидТочки = СтрокаСвязи.Точка.ВидТочки;
			КонецЦикла;	
			
			СтрокаТаблицы.ИсходящиеТочки = ТаблицаСвязанных;
			
		КонецЕсли; 
		
	КонецЦикла; // По строкам таблицы 
	
	ТаблицаТочкиВизы.Индексы.Добавить("Точка");
	
	Возврат ТаблицаТочкиВизы;
	
КонецФункции

// Процедура определяет доступность точек визирования.
// 
// Параметры:
//  ТаблицаТочек      - ТаблицаЗначений.
//  ВыполнятьПоэтапно - Булево.
// 
Процедура ОпределитьДоступностьТочек(ТаблицаТочек, ВыполнятьПоэтапно, ДопПараметрыПроверкиУсловий) Экспорт
	
	ТекущаяТочка         = Неопределено;
	ТекущаяСтрокаПозиции = Неопределено;	
	Обработанные         = Новый Соответствие;
	СчетчикЗацикливания  = 1;
	
	КоличествоТочек             = ТаблицаТочек.Количество();
	КоличествоОбработанныхТочек = 0;
	
	СтрокаТаблицыТочек = Неопределено;
	КэшПроверки        = Новый Соответствие;
	Для каждого СтрокаАлгоритма Из ТаблицаТочек Цикл
		Если СтрокаАлгоритма.ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Старт Тогда
			СтрокаТаблицыТочек = СтрокаАлгоритма;
			ТекущаяТочка       = СтрокаТаблицыТочек.Точка;
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаАлгоритма.Решение) Тогда
			ДопПараметрыПроверкиУсловий.ТипыРешенийПоТочкам.Вставить(СтрокаАлгоритма.Точка, СтрокаАлгоритма.ТипРешения);
		КонецЕсли;
		СтрокаАлгоритма.ИсходящиеЗаполнены = УстановленоРешениеВИсходящихТочках(СтрокаАлгоритма.Точка,
																				ТаблицаТочек,
																				КэшПроверки);
	КонецЦикла;
	
	// Разместим точки алгоритма для отрисовки.
	Пока КоличествоТочек > КоличествоОбработанныхТочек Цикл
		Если СтрокаТаблицыТочек = Неопределено Тогда
			СтрокаТаблицыТочек = ТаблицаТочек.Найти(0, "Обработана");
			Если СтрокаТаблицыТочек = Неопределено Тогда
				ТекстСообщения = НСтр("ru='Ошибка при определении доступности точек алгоритма';
								      |en='Looping Algorithm in determining availability points'");
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
				Прервать;
			КонецЕсли;
			ТекущаяТочка = СтрокаТаблицыТочек.Точка;
		КонецЕсли;
		
		Если СтрокаТаблицыТочек.КоличествоВходящих = 0 Тогда
			СтрокаТаблицыТочек.Доступность       = СтрокаТаблицыТочек.ЕстьПраво;			
			СтрокаТаблицыТочек.ВходящиеЗаполнены = Истина;
		Иначе
			Если ВыполнятьПоэтапно Тогда
				ВидУсловия = "ЗаполненоРешениеВиза";
			Иначе
				ВидУсловия = "Согласовано";
			КонецЕсли;
			
			ВходящиеЗаполнены = ПринятыРешенияПоВышестоящимТочкам(ТаблицаТочек,
																	ТекущаяТочка,
																	ВидУсловия,
																	ДопПараметрыПроверкиУсловий);
			
			СтрокаТаблицыТочек.ВходящиеЗаполнены  = ВходящиеЗаполнены;
			СтрокаТаблицыТочек.Доступность = СтрокаТаблицыТочек.ЕстьПраво И ВходящиеЗаполнены;
		КонецЕсли; // По количеству входящих.
		
		Обработанные.Вставить(ТекущаяТочка, Истина);
		СтрокаТаблицыТочек.Обработана = 1;
		
		ТочкаИсходящая = Неопределено;
		Для каждого СтрокаИсходящие Из ТекущаяТочка.ИсходящиеТочки Цикл
			ТочкаИсходящая = СтрокаИсходящие.Точка;
			Если Обработанные.Получить(ТочкаИсходящая) = Неопределено Тогда
				Прервать;
			Иначе
				ТочкаИсходящая = Неопределено;
			КонецЕсли; 
		КонецЦикла; 
		ТекущаяТочка       = ТочкаИсходящая;
		СтрокаТаблицыТочек = ТаблицаТочек.Найти(ТекущаяТочка,"Точка");
		
		КоличествоОбработанныхТочек = ТаблицаТочек.Итог("Обработана");
		
		СчетчикЗацикливания = СчетчикЗацикливания + 1;
		Если СчетчикЗацикливания > 1000 Тогда
			ТекстСообщения = НСтр("ru='Зацикливание при определении доступности точек алгоритма';
								  |en='Looping Algorithm in determining availability points'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			Прервать;
		КонецЕсли;
		
	КонецЦикла;	// Размещение точек
	
	ЕстьОтклоняющиеРешения  = (ТаблицаТочек.Найти(Перечисления.бит_ТипыРешений.Отклоняющее, "ТипРешения") <> Неопределено);
	БлокироватьПоОтклонению = ЕстьОтклоняющиеРешения И НЕ ВыполнятьПоэтапно;
	
	Для каждого СтрокаТочки Из ТаблицаТочек Цикл
		СтрокаТочки.Доступность  = СтрокаТочки.ЕстьПраво
									И СтрокаТочки.ВходящиеЗаполнены
									И НЕ СтрокаТочки.ИсходящиеЗаполнены
									// Если есть отклоняющие решения, то новые решения не доступны.
									И (НЕ БлокироватьПоОтклонению ИЛИ ЗначениеЗаполнено(СтрокаТочки.Решение));
		СтрокаТочки.АктивнаяВиза = СтрокаТочки.ВходящиеЗаполнены
									И НЕ СтрокаТочки.ИсходящиеЗаполнены
									И НЕ ЗначениеЗаполнено(СтрокаТочки.Решение)
									И НЕ БлокироватьПоОтклонению;
	КонецЦикла; 

КонецПроцедуры

// Процедура проверяет выполнение условия по нижестоящим точкам.
// 
// Параметры:
//  ТаблицаТочек    - ТаблицаЗначений.
//  ТочкаНачальная  - СправочникСсылка.бит_ТочкиАлгоритмов.
//  Заполнены       - Булево.
//  Режим           - Строка.
//  УровеньРекурсии - Число.
// 
Процедура ПроверитьНижестоящиеТочки(ТаблицаТочек,ТочкаНачальная,УсловиеВыполнено,Режим,УровеньРекурсии) Экспорт
	
	УровеньРекурсии = УровеньРекурсии + 1;
	Если УровеньРекурсии > 1000 Тогда		
		ТекстСообщения = НСтр("ru='Превышен уровень рекурсии при проверке заполнения нижестоящих точек алгоритма.';
		      				  |en='The recursion level was exceeded when checking the filling of the lower points of the algorithm.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;		
	КонецЕсли;	
	
	СтрокаТаблицыНачальная = ТаблицаТочек.Найти(ТочкаНачальная,"Точка");
	Если СтрокаТаблицыНачальная = Неопределено Тогда		
		Возврат;		
	КонецЕсли; 
	ИсходящиеТочки = СтрокаТаблицыНачальная.ИсходящиеТочки;
	
	флЕстьНеЗаполненныеРешения = Ложь;
	КолТочДействия       = 0;
	КолТочДействияБезВиз = 0;
	
	Для каждого СтрокаИсходящие Из ИсходящиеТочки Цикл
		
		Если ЭтоДействие(СтрокаИсходящие.ВидТочки) Тогда
			
			// Проверим принято решение в данной точке или нет.
			СтрокаТаблицы = ТаблицаТочек.Найти(СтрокаИсходящие.Точка,"Точка");
			Если НЕ СтрокаТаблицы = Неопределено Тогда
				
				Если ВРег(Режим) = ВРег("ЗадачиВыполнены") Тогда
					
					Если Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(СтрокаТаблицы.Состояние,
							Перечисления.бит_ТипыСтатусовОбъектов.Исполнен) Тогда
						
						УсловиеВыполнено = Истина;
						Прервать;
						
					КонецЕсли; 
					
				КонецЕсли; 
				
			КонецЕсли;	  
			
		Иначе
			
			ПроверитьНижестоящиеТочки(ТаблицаТочек,СтрокаИсходящие.Точка,УсловиеВыполнено,Режим,УровеньРекурсии);
			
		КонецЕсли;	// Точка действия
		
	КонецЦикла;	// По входящим точкам
	
КонецПроцедуры	// ПроверитьНижестоящиеТочки

// Функция проверяет наличие веток без единого действия выше по дереву алгоритма.
// 
// Параметры:
//  ТочкаНачальная - СправочникСсылка.бит_ТочкиАлгоритмов.
//
// 
// Возвращаемое значение:
//   Булево.
// 
Функция ВышеНетТочекДействия(ТочкаНачальная, ДопПараметрыПроверкиУсловий) Экспорт
	
	КэшПроверок = ДопПараметрыПроверкиУсловий.КэшПроверок.ВышеНетТочекДействия;
	РезультатПроверки = КэшПроверок.Получить(ТочкаНачальная);
	Если РезультатПроверки <> Неопределено Тогда
		Возврат РезультатПроверки;
	КонецЕсли;
	
	РезультатПроверки = РезультатПроверкиВышеНетТочекДействия(ТочкаНачальная, ДопПараметрыПроверкиУсловий);
	КэшПроверок.Вставить(ТочкаНачальная, РезультатПроверки);	
	Возврат РезультатПроверки; 
	
КонецФункции

Функция ТочкиЗациклены(Точка1, Точка2, СтекПроверки = Неопределено) Экспорт
	
	Если СтекПроверки = Неопределено Тогда
		СтекПроверки = Новый Соответствие;
	КонецЕсли;
	Если СтекПроверки.Получить(Точка2) = Неопределено Тогда
		СтекПроверки.Вставить(Точка2, Ложь);
	Иначе
		// Внешний цикл не относящийся к проверяемым точкам.
		Возврат Ложь;
	КонецЕсли;
	
	Если Точка1 = Точка2 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Для каждого СтрокаИсходящейТочки Из Точка2.ИсходящиеТочки Цикл
		ИсходящаяТочка = СтрокаИсходящейТочки.Точка;
		Если ТочкиЗациклены(Точка1, ИсходящаяТочка, СтекПроверки) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

#КонецОбласти

#Область ВыполнениеАлгоритмов

// Выполнение алгоритма.
// 
// Параметры:
//  Алгоритм  - СправочникСсылка.бит_АлгоритмыПроцессов.
//  СтруктураКонтекст  - Структура.
//  РежимСообщений - Строка: "Нет","Все","Ошибки".
//                 
// 
Процедура ВыполнитьАлгоритм(Алгоритм, СтруктураКонтекст, РежимСообщений = "Ошибки") Экспорт

	ПараметрыШаблон = НовыеПараметрыВыполненияАлгоритма();
	Для каждого КлючЗначение Из ПараметрыШаблон Цикл
		Значение = Неопределено;
		Если СтруктураКонтекст.Свойство(КлючЗначение.Ключ, Значение) Тогда
			ПараметрыШаблон.Вставить(КлючЗначение.Ключ, Значение);
		КонецЕсли; 
	КонецЦикла;
	
	Визы 	  = ПараметрыШаблон.Визы;
	ТабЗадачи = ПараметрыШаблон.ТабЗадачи;
	
    Заголовок = НСтр("ru='Выполнение алгоритма ""%1""';en='Executing the ""%1"" algorithm'");
	Заголовок = СтрШаблон(Заголовок, Алгоритм);
	
	ВыводитьОшибки     = РежимСообщений = "Все" ИЛИ РежимСообщений = "Ошибки";
	ВыводитьИнформацию = РежимСообщений = "Все";	
	
	Если ВыводитьИнформацию Тогда
		ТекстСообщения = НСтр("ru='Начало выполнения: %1';en='Start of execution: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ТекущаяДатаСеанса());
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения); 
	КонецЕсли; 
	
	// Получим точки данного алгоритма
	Если Визы <> Неопределено Тогда
		ТаблицаВизы  = Визы.Выгрузить();
		ТаблицаВизы.Колонки.Добавить("ДоступностьВизы", Новый ОписаниеТипов("Булево"));
		ТаблицаТочек = ОписаниеТочекАлгоритма(Алгоритм, ТаблицаВизы);
	ИначеЕсли ТабЗадачи <> Неопределено Тогда
		ТаблицаТочек = ОписаниеТочекАлгоритма(Алгоритм,, ТабЗадачи);
	Иначе	
		ТаблицаТочек = ОписаниеТочекАлгоритма(Алгоритм);
	КонецЕсли; 
	
	ПараметрыШаблон.Алгоритм          = Алгоритм;
	ПараметрыШаблон.ВидАлгоритма      = Алгоритм.ВидАлгоритма;
	ПараметрыШаблон.ТаблицаТочек      = ТаблицаТочек;
	ПараметрыШаблон.СтруктураКонтекст = СтруктураКонтекст;
	ПараметрыШаблон.Заголовок         = Заголовок;
	ПараметрыШаблон.РежимСообщений    = РежимСообщений;
	ПараметрыШаблон.ВыводитьОшибки    = ВыводитьОшибки;
	ПараметрыШаблон.ВыполнятьПоэтапно = ВыполнятьАлгоритмПоэтапно(Алгоритм);   
	
	Отбор = Новый Структура("КоличествоВходящих", 0);
	ТочкиПервогоУровня = ТаблицаТочек.НайтиСтроки(Отбор);
	Для каждого СтрокаТаблицыТочек Из ТочкиПервогоУровня Цикл
		ОбработатьАлгоритмДляТочки(СтрокаТаблицыТочек.Точка, ПараметрыШаблон);
	КонецЦикла;
	Для каждого ЭлементСпискаОтложенныхТочек Из ПараметрыШаблон.ТочкиОтложеннойОбработки Цикл
		ОбработатьАлгоритмДляТочки(ЭлементСпискаОтложенныхТочек.Значение, ПараметрыШаблон);
	КонецЦикла;
	Если ПараметрыШаблон.ПользовательскиеДействия <> Неопределено Тогда
		СтруктураКонтекст.ПользовательскиеДействия = ПараметрыШаблон.ПользовательскиеДействия;
	КонецЕсли;
	
	ТекущийОбъект 		 = ПараметрыШаблон.ТекущийОбъект;
	ДатаИзмененияСтатуса = ТекущаяДатаСеанса();
	
	// Если в процессе выполнения алгоритма изменился статус - запишем новое значение.
	Если ПараметрыШаблон.ВидАлгоритма = Перечисления.бит_ВидыАлгоритмов.ИзменениеСтатусовОбъектов Тогда 
		
		Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ТекущийСтатус") Тогда
			ТекущийСтатус = ТекущийОбъект.ДополнительныеСвойства.ТекущийСтатус;
		Иначе
			ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(ТекущийОбъект.Ссылка);
		КонецЕсли; 

		НовыйСтатус = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
							ТекущийОбъект.ДополнительныеСвойства,
							"бит_НовыйСтатус", Неопределено);

		Если НовыйСтатус <> Неопределено И ТекущийСтатус <> НовыйСтатус  Тогда
			
			ПараметрыУстановкиСтатуса = бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса();
			ПараметрыУстановкиСтатуса.Объект               = ТекущийОбъект.Ссылка; 
			ПараметрыУстановкиСтатуса.Статус               = НовыйСтатус;
			ПараметрыУстановкиСтатуса.СтатусПредыдущий     = ТекущийСтатус;
			ПараметрыУстановкиСтатуса.ДатаИзмененияСтатуса = ДатаИзмененияСтатуса;
			ПараметрыУстановкиСтатуса.Алгоритм             = Алгоритм;
			
			ДействиеВыполнено = бит_ВизированиеСервер.УстановитьСтатусОбъекта(ПараметрыУстановкиСтатуса);
			
			Если ДействиеВыполнено Тогда
				ТекущийОбъект.ДополнительныеСвойства.Вставить("ТекущийСтатус", НовыйСтатус);
				ТекущийОбъект.ДополнительныеСвойства.Вставить("ДатаИзмененияСтатуса", ДатаИзмененияСтатуса);
			КонецЕсли; 	
		КонецЕсли;
	КонецЕсли;	
	
	Если ВыводитьИнформацию Тогда
		ЗаголовокСообщения = "";
		Если НЕ ПустаяСтрока(Заголовок) Тогда
			ЗаголовокСообщения = Заголовок + Символы.ПС;
			Заголовок = "";	
		КонецЕсли; 
		ТекстСообщения = НСтр("ru='%1Выполнение закончено: %2';en='%1Completion complete: %2'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ЗаголовокСообщения, Формат(ДатаИзмененияСтатуса, "ДЛФ=DT"));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения); 
	КонецЕсли;
	
КонецПроцедуры

// Функция определяет следует ли данный алгоритм выполнять поэтапно или нет.
// 
// Параметры:
//  Алгоритм  - СправочникСсылка.бит_АлгоритмыПроцессов.
// 
// Возвращаемое значение:
//  Булево.
// 
Функция ВыполнятьАлгоритмПоэтапно(Алгоритм) Экспорт
	
	ВыполнятьПоэтапно = Ложь;
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Алгоритм, "ВидАлгоритма, СпособВыполнения");
	
	Если Реквизиты.ВидАлгоритма = Перечисления.бит_ВидыАлгоритмов.Визирование Тогда
		
		Если Реквизиты.СпособВыполнения = Перечисления.бит_СпособыВыполненияАлгоритма.Поэтапно Тогда
			
			ВыполнятьПоэтапно = Истина;
			
		КонецЕсли; 
		
	ИначеЕсли Реквизиты.ВидАлгоритма = Перечисления.бит_ВидыАлгоритмов.Прочее Тогда
		
		ВыполнятьПоэтапно = Истина;
		
	КонецЕсли; 
	
	Возврат ВыполнятьПоэтапно;
	
КонецФункции

// Возвращает точки действия после текущей точки.
// 
// Параметры:
//  ТочкаАлгоритма - СправочникСсылка.бит_ТочкиАлгоритмов, Массив 
//	ПараметрыКонтекста - Структура
//  	* Алгоритм      - СправочникСсылка.бит_АлгоритмыПроцессов
//  	* ТекущийОбъект - ДокументОбъект
//  	* НаборВизы     - РегистрСведенийНаборЗаписей.бит_УстановленныеВизы
// 
// Возвращаемое значение:
//  Структура
//		* ТочкиДействия - Массив.
//
Функция ТочкиДействияПослеТекущей(ТочкаАлгоритма, ПараметрыКонтекста) Экспорт
	
	ПараметрыПоследующихТочек = Новый Структура;
	ПараметрыПоследующихТочек.Вставить("ТочкиДействия", Новый Массив);
	ПараметрыПоследующихТочек.Вставить("ТочкиОбработок", Новый Массив);
	
	Если ТипЗнч(ТочкаАлгоритма) = Тип("СправочникСсылка.бит_ТочкиАлгоритмов") Тогда
		ДобавитьТочкиДействияПослеТекущей(ПараметрыПоследующихТочек, ТочкаАлгоритма, ПараметрыКонтекста);
	Иначе
		СтекОбработанныхТочек = Новый СписокЗначений;
		Для каждого ТекущаяТочка Из ТочкаАлгоритма Цикл
			ДобавитьТочкиДействияПослеТекущей(ПараметрыПоследующихТочек, ТекущаяТочка, ПараметрыКонтекста, СтекОбработанныхТочек);
		КонецЦикла;
	КонецЕсли;
	
	Возврат ПараметрыПоследующихТочек;
	
КонецФункции

// Функция выполняет пользовательское действие.
// 
// Параметры:
//  ПользовательскоеДействие  - СправочникСсылка.бит_ПользовательскиеДействия.
//  СтруктураКонтекст  - Структура.
//  ЗначенияРеквизитов - Структура.
//  Заголовок      - Строка.
//  РежимСообщений - Строка: "Нет","Все","Ошибки".
// 
// Возвращаемое значение:
//   флДействиеВыполнено   - Булево.
// 
Функция ВыполнитьПользовательскоеДействие(ПользовательскоеДействие, СтруктураКонтекст, ТочкаАлгоритма = Неопределено, 
			Заголовок="",РежимСообщений="Ошибки") Экспорт
	
	Модуль 		= Справочники.бит_ПользовательскиеДействия;		
	флВыполнено = Модуль.ВыполнитьПользовательскоеДействие(ПользовательскоеДействие,
						СтруктураКонтекст, ТочкаАлгоритма, Заголовок, РежимСообщений);									   
	Возврат флВыполнено;
																				 
КонецФункции										   

// Функция вычисляет значение пользовательского условия.
// 
// Параметры:
//  ПользовательскоеУсловие  - СправочникСсылка.бит_ПользовательскиеУсловия.
//  СтруктураКонтекст        - Структура.
//  ВыражениеКорректно       - Булево - признак того, что выражения условия корректно.
//  Заголовок      - Строка.
//  РежимСообщений - Строка: "Нет","Все","Ошибки".
// 
// Возвращаемое значение:
//   флРезультат   - Булево.
// 
Функция ПроверитьПользовательскоеУсловие(ПользовательскоеУсловие
	                                      ,СтруктураКонтекст
										  ,ВыражениеКорректно = Истина
										  ,Заголовок = ""
										  ,РежимСообщений  = "Ошибки") Экспорт

	флРезультат = Справочники.бит_ПользовательскиеУсловия.ПроверитьПользовательскоеУсловие(ПользовательскоеУсловие
	                                                                                        , СтруктураКонтекст
																							, ВыражениеКорректно
																							, Заголовок
																							, РежимСообщений); 
	
	Возврат флРезультат;
	
КонецФункции // ПроверитьПользовательскоеУсловие()

// Вычисляет значение пользовательского варианта.
// 
// Параметры:
//  ПользовательскийВыборВарианта  - СправочникСсылка.бит_ПользовательскиеВыборыВарианта.
//  СтруктураКонтекст        - Структура.
// 
// Возвращаемое значение:
//  Значение - Произвольное.
//
Функция ЗначениеПользовательскогоВарианта(ПользовательскийВыборВарианта, СтруктураКонтекст) Экспорт
	
	МенеджерСправочника = Справочники.бит_ПользовательскиеВыборыВарианта;
	Результат = МенеджерСправочника.ЗначениеПользовательскогоВарианта(ПользовательскийВыборВарианта
																		, СтруктураКонтекст); 
	
	Возврат Результат;
	
КонецФункции

// Возвращает алгоритм визирования для данного объекта системы.
// 
// Параметры:
//  ТекущийОбъект  - ДокументОбъект,ДокументСсылка.
// 
Функция АлгоритмВизированияОбъекта(ТекущийОбъект) Экспорт

	АлгоритмыОбъекта    = АлгоритмыОбъектаСистемы(ТекущийОбъект,Перечисления.бит_ВидыАлгоритмов.Визирование); 
	АлгоритмВизирования = АлгоритмыОбъекта.Визирование;
	
	Возврат АлгоритмВизирования;

КонецФункции

// Возвращает алгоритм установки статуса для данного объекта системы.
// 
// Параметры:
//  ТекущийОбъект  - ДокументОбъект,ДокументСсылка.
// 
Функция АлгоритмУстановкиСтатусаОбъекта(ТекущийОбъект) Экспорт

	ОбъектДляПолученияСтатуса = ТекущийОбъект;
	
	Если бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
		ИмяМетаданных = ТекущийОбъект.Метаданные().ПолноеИмя();
		Если ИмяМетаданных = "Документ.бит_кзн_ПлатежнаяПозиция"
			ИЛИ ИмяМетаданных = "Документ.бит_кзн_ПлатежнаяПозиция"
			ИЛИ ИмяМетаданных = "Документ.бит_кзн_ПозицияПоступления"
			ИЛИ ИмяМетаданных = "Документ.бит_кзн_ПозицияПоступления" Тогда
			ОбъектДляПолученияСтатуса = ТекущийОбъект.ДокументПланирования;
		КонецЕсли;
	КонецЕсли;
	
	АлгоритмыОбъекта          = АлгоритмыОбъектаСистемы(ОбъектДляПолученияСтатуса,
									Перечисления.бит_ВидыАлгоритмов.ИзменениеСтатусовОбъектов); 
	АлгоритмУстановкиСтатусов = АлгоритмыОбъекта.ИзменениеСтатусовОбъектов;
	
	Возврат АлгоритмУстановкиСтатусов;

КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЭтоДействие(Значение)

	Возврат Значение = Перечисления.бит_ВидыТочекАлгоритмов.Действие
			ИЛИ Значение = Перечисления.бит_ВидыТочекАлгоритмов.ПодчиненныйПроцесс;

КонецФункции
		
Функция ЭтоПроверка(Значение)

	Возврат Значение = Перечисления.бит_ВидыТочекАлгоритмов.Условие
			ИЛИ Значение = Перечисления.бит_ВидыТочекАлгоритмов.ВыборВарианта;

КонецФункции		

// Проверяет выполняется ли условие связи точек алгоритма.
// 
// Параметры:
//  ТочкаАлгоритма    - СправочникСсылка.бит_ТочкиАлгоритмов
//  ЗначениеУсловия   - Произвольный - Значение условия связи
//  ПараметрыПроверки - Структура.
// 
// Возвращаемое значение:
// 	Булево.
//
Функция ВыполняетсяУловиеСвязиТочки(ТочкаАлгоритма, ЗначениеУсловия, ПараметрыПроверки)
	
	РеквизитыТочки = "ВидТочки, ПользовательскоеУсловие, ПользовательскийВыборВарианта, ВариантыВыбора";
	ДанныеТочки    = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТочкаАлгоритма, РеквизитыТочки);
	
	ВидТочки       = ДанныеТочки.ВидТочки;
	Если НЕ ЭтоПроверка(ВидТочки) Тогда
		Возврат Истина;
	КонецЕсли;
	
	ПользовательскоеУсловие       = ДанныеТочки.ПользовательскоеУсловие;
	ПользовательскийВыборВарианта = ДанныеТочки.ПользовательскийВыборВарианта;
	
	Если ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Условие Тогда
		Если НЕ ЗначениеЗаполнено(ПользовательскоеУсловие) Тогда
			Возврат Ложь;
		КонецЕсли;
		РезультатУсловия = ПроверитьПользовательскоеУсловие(ПользовательскоеУсловие, ПараметрыПроверки);
		Возврат (РезультатУсловия = ЗначениеУсловия);
	ИначеЕсли ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.ВыборВарианта Тогда
		Если НЕ ЗначениеЗаполнено(ПользовательскийВыборВарианта) Тогда
			Возврат Ложь;
		КонецЕсли;
		РасчетноеЗначение = ЗначениеПользовательскогоВарианта(ПользовательскийВыборВарианта, ПараметрыПроверки);
		Если РасчетноеЗначение = ЗначениеУсловия Тогда
			Возврат Истина;
		ИначеЕсли ЗначениеУсловия <> Неопределено Тогда
			Возврат Ложь;
		Иначе
			// В качестве связи указан вариант "Прочее" (ЗначениеУсловия = Неопределено).
			// Результат проверки будем вычислять методом исключения прочих вариантов.
			ВыборкаВариантов = ДанныеТочки.ВариантыВыбора.Выбрать();
			Пока ВыборкаВариантов.Следующий() Цикл
				Если ВыборкаВариантов.ЗначениеВыбора = РасчетноеЗначение Тогда
					// Рассчитанное значение соответсвует другому варианту
					Возврат Ложь;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция РезультатПроверкиВышеНетТочекДействия(ТочкаНачальная, ДопПараметрыПроверкиУсловий)
	
	Если ТочкаНачальная = Неопределено ИЛИ ТочкаНачальная.ВходящиеТочки.Количество() = 0 Тогда
		Возврат Истина;
	КонецЕсли;
		
	Для каждого СтрокаВходящейТочки Из ТочкаНачальная.ВходящиеТочки Цикл
			
		ТочкаВерхняя = СтрокаВходящейТочки.Точка;
		ВидТочки     = ТочкаВерхняя.ВидТочки;
		Если ЭтоДействие(ВидТочки) Тогда
			Продолжить;
		ИначеЕсли ЭтоПроверка(ВидТочки) Тогда
			Если НЕ ВыполняетсяУловиеСвязиТочки(ТочкаВерхняя,
												СтрокаВходящейТочки.ЗначениеУсловия,
												ДопПараметрыПроверкиУсловий) Тогда 
				// Условие не выполняется, по данной ветке не придет
				Продолжить;
			КонецЕсли;
			Если ВышеНетТочекДействия(ТочкаВерхняя, ДопПараметрыПроверкиУсловий) Тогда
				Возврат Истина;
			КонецЕсли;
		ИначеЕсли ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Слияние Тогда
			// При слиянии должна выполняться проверка отсутвия точек действия по всем вышестоящим точкам
			Если НЕ ВышеЕстьТочкиДействия(ТочкаВерхняя, ДопПараметрыПроверкиУсловий) Тогда
				Возврат Истина;
			КонецЕсли;
		ИначеЕсли ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Старт
			ИЛИ ВышеНетТочекДействия(ТочкаВерхняя, ДопПараметрыПроверкиУсловий) Тогда
				Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Функция проверяет наличие веток действия выше по дереву алгоритма.
// 
// Параметры:
//  ТочкаНачальная - СправочникСсылка.бит_ТочкиАлгоритмов.
//
// 
// Возвращаемое значение:
//   Булево.
// 
Функция ВышеЕстьТочкиДействия(ТочкаНачальная, ДопПараметрыПроверкиУсловий)
	
	КэшПроверок = ДопПараметрыПроверкиУсловий.КэшПроверок.ВышеЕстьТочкиДействия;
	РезультатПроверки = КэшПроверок.Получить(ТочкаНачальная);
	Если РезультатПроверки <> Неопределено Тогда
		Возврат РезультатПроверки;
	КонецЕсли;
	
	РезультатПроверки = РезультатПроверкиВышеЕстьТочкиДействия(ТочкаНачальная, ДопПараметрыПроверкиУсловий);
	КэшПроверок.Вставить(ТочкаНачальная, РезультатПроверки);	
	Возврат РезультатПроверки; 
	
КонецФункции

Функция РезультатПроверкиВышеЕстьТочкиДействия(ТочкаНачальная, ДопПараметрыПроверкиУсловий)
	
	Если ТочкаНачальная = Неопределено
		ИЛИ ТочкаНачальная.ВходящиеТочки.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
		
	Для каждого СтрокаВходящейТочки Из ТочкаНачальная.ВходящиеТочки Цикл
			
		ТочкаВерхняя = СтрокаВходящейТочки.Точка;
		ВидТочки     = ТочкаВерхняя.ВидТочки;
		
		Если ЭтоДействие(ВидТочки) И ВышеНетНевыполнимыхУсловий(ТочкаВерхняя, ДопПараметрыПроверкиУсловий) Тогда
			Возврат Истина;
		ИначеЕсли ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Старт Тогда
			Продолжить;
		ИначеЕсли ЭтоПроверка(ВидТочки) Тогда
			Если НЕ ВыполняетсяУловиеСвязиТочки(ТочкаВерхняя,
												СтрокаВходящейТочки.ЗначениеУсловия,
												ДопПараметрыПроверкиУсловий) Тогда
				// Условие не выполняется, по данной ветке не придет
				Продолжить;
			КонецЕсли;
			Если ВышеЕстьТочкиДействия(ТочкаВерхняя, ДопПараметрыПроверкиУсловий) Тогда
				Возврат Истина;
			КонецЕсли;
		ИначеЕсли ВышеЕстьТочкиДействия(ТочкаВерхняя, ДопПараметрыПроверкиУсловий) Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция ВышеНетНевыполнимыхУсловий(ТочкаНачальная, ДопПараметрыПроверкиУсловий, РекурсивныйВызов = Ложь)
	
	КэшПроверок = ДопПараметрыПроверкиУсловий.КэшПроверок.ВышеНетНевыполнимыхУсловий;
	РезультатПроверки = КэшПроверок.Получить(ТочкаНачальная);
	Если РезультатПроверки <> Неопределено Тогда
		Возврат РезультатПроверки;
	КонецЕсли;
	
	Если РекурсивныйВызов Тогда
		СтекВызова = ДопПараметрыПроверкиУсловий.КэшПроверок.СтекВызоваВышеНетНевыполнимыхУсловий;
		Если СтекВызова.НайтиПоЗначению(ТочкаНачальная) = Неопределено Тогда
			СтекВызова.Добавить(ТочкаНачальная);
		Иначе
			// Зацикленный участок алгоритма.
			Возврат Ложь;
		КонецЕсли;
	Иначе
		ДопПараметрыПроверкиУсловий.КэшПроверок.Вставить("СтекВызоваВышеНетНевыполнимыхУсловий", Новый СписокЗначений);	
	КонецЕсли;
	
	РезультатПроверки = РезультатПроверкиВышеНетНевыполнимыхУсловий(ТочкаНачальная, ДопПараметрыПроверкиУсловий);
	КэшПроверок.Вставить(ТочкаНачальная, РезультатПроверки);	
	Возврат РезультатПроверки;
	
КонецФункции

Функция РезультатПроверкиВышеНетНевыполнимыхУсловий(ТочкаНачальная, ДопПараметрыПроверкиУсловий)
	
	Если ТочкаНачальная = Неопределено
		ИЛИ ТочкаНачальная.ВходящиеТочки.Количество() = 0
		ИЛИ ДопПараметрыПроверкиУсловий.ТипыРешенийПоТочкам.Получить(ТочкаНачальная) = Перечисления.бит_ТипыРешений.Согласующее Тогда
		Возврат Истина;
	КонецЕсли;
	
	Для каждого СтрокаВходящейТочки Из ТочкаНачальная.ВходящиеТочки Цикл
		
		Если НЕ ВыполняетсяУловиеСвязиТочки(СтрокаВходящейТочки.Точка,
											СтрокаВходящейТочки.ЗначениеУсловия,
											ДопПараметрыПроверкиУсловий) Тогда
			// Условие не выполняется, по данной ветке не придет.
			Продолжить;
		КонецЕсли;
		
		Если ВышеНетНевыполнимыхУсловий(СтрокаВходящейТочки.Точка, ДопПараметрыПроверкиУсловий, Истина) Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции		

Процедура ОбработатьАлгоритмДляТочки(ТочкаАлгоритма, ПараметрыОбработкиАлгоритма)
	
	Если ПараметрыОбработкиАлгоритма.СтекОбработанныхТочек.НайтиПоЗначению(ТочкаАлгоритма) = Неопределено Тогда
		ПараметрыОбработкиАлгоритма.СтекОбработанныхТочек.Добавить(ТочкаАлгоритма);
	Иначе
		// Анализ данной точки уже выполнялся.
		Возврат;
	КонецЕсли;
	
	ТекущийОбъект     = ПараметрыОбработкиАлгоритма.ТекущийОбъект;
	Визы              = ПараметрыОбработкиАлгоритма.Визы;
	Алгоритм          = ПараметрыОбработкиАлгоритма.Алгоритм;
	ВидАлгоритма      = ПараметрыОбработкиАлгоритма.ВидАлгоритма;
	ТаблицаТочек      = ПараметрыОбработкиАлгоритма.ТаблицаТочек;
	СтруктураКонтекст = ПараметрыОбработкиАлгоритма.СтруктураКонтекст;
	Заголовок         = ПараметрыОбработкиАлгоритма.Заголовок;
	РежимСообщений    = ПараметрыОбработкиАлгоритма.РежимСообщений;
	ВыводитьОшибки    = ПараметрыОбработкиАлгоритма.ВыводитьОшибки;
	ОплатаЗаявки      = ПараметрыОбработкиАлгоритма.ОплатаЗаявки;
	ВыполнятьПоэтапно = ПараметрыОбработкиАлгоритма.ВыполнятьПоэтапно;
	
	Отбор = Новый Структура("Точка", ТочкаАлгоритма);
	СтрокаТаблицыТочек = ТаблицаТочек.Найти(ТочкаАлгоритма);
	Если СтрокаТаблицыТочек = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоПроверка(ТочкаАлгоритма.ВидТочки) Тогда
		
		ПараметрыПроверки = Новый Структура("ТекущийОбъект", ТекущийОбъект);
		Если ОплатаЗаявки <> Неопределено Тогда
			ПараметрыПроверки.Вставить("ОплатаЗаявки", ОплатаЗаявки);
		КонецЕсли; 
		Если Визы <> Неопределено Тогда
			ПараметрыПроверки.Вставить("НаборВизы", Визы);
		КонецЕсли; 
		
		Если ТочкаАлгоритма.ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Условие Тогда	
		
			УсловиеВыполнено = Ложь;
			
			// Вычисляем условие.
			Если ЗначениеЗаполнено(ТочкаАлгоритма.ПользовательскоеУсловие) Тогда
				
				УсловиеВыполнено = ПроверитьПользовательскоеУсловие(ТочкаАлгоритма.ПользовательскоеУсловие,
																	ПараметрыПроверки,,
																	Заголовок,
																	РежимСообщений);
			Иначе	
				Если ВыводитьОшибки Тогда
					ТекстСообщения = НСтр("ru='Не указано условие для точки ""%1"".';
											|en='The condition for the point ""%1"" is not specified.'");
					ТекстСообщения = СтрШаблон(ТекстСообщения, ТочкаАлгоритма);
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения); 
				КонецЕсли;
			КонецЕсли;
			
			СтрокаНаправленияУсловия = ТочкаАлгоритма.ИсходящиеТочки.Найти(УсловиеВыполнено, "ЗначениеУсловия");
			Если СтрокаНаправленияУсловия <> Неопределено Тогда
				ОбработатьАлгоритмДляТочки(СтрокаНаправленияУсловия.Точка, ПараметрыОбработкиАлгоритма);
			КонецЕсли;
			
		ИначеЕсли ТочкаАлгоритма.ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.ВыборВарианта Тогда
			
			ЗначениеВарианта = ЗначениеПользовательскогоВарианта(ТочкаАлгоритма.ПользовательскийВыборВарианта,
																	ПараметрыПроверки);
			СтрокаНаправленияВарианта = Неопределено;
			Для каждого ИсходящаяСтрока Из ТочкаАлгоритма.ИсходящиеТочки Цикл
				ЗначениеВариантаСтроки = ИсходящаяСтрока.ЗначениеУсловия;
				Если ЗначениеВариантаСтроки = ЗначениеВарианта Тогда
					СтрокаНаправленияВарианта = ИсходящаяСтрока;
					Прервать;
				ИначеЕсли ЗначениеВариантаСтроки = Неопределено Тогда
					// Вариант "Прочее" перейдет по методу исключения.
					СтрокаНаправленияВарианта = ИсходящаяСтрока;
				КонецЕсли;
			КонецЦикла;
			Если СтрокаНаправленияВарианта <> Неопределено Тогда
				ОбработатьАлгоритмДляТочки(СтрокаНаправленияВарианта.Точка, ПараметрыОбработкиАлгоритма);
			КонецЕсли;
				
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
		
	Если ЭтоДействие(ТочкаАлгоритма.ВидТочки) Тогда
		
		Если НЕ ЗначениеЗаполнено(ТочкаАлгоритма.ПользовательскоеДействие) Тогда
			Если ВыводитьОшибки Тогда
				ТекстСообщения = НСтр("ru='Не указано действие для точки ""%1"".'; 
									|en='No action was specified for the ""%1"" point.'");
				ТекстСообщения = СтрШаблон(ТекстСообщения, ТочкаАлгоритма);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			КонецЕсли;
			Возврат;
		КонецЕсли;
		
		// Определим необходимо ли выполнять текущее действие
		// Это зависит от способа выполнения алгоритма:
		// Сразу - выполняем все действия за один обход
		// Поэтапно - выполняем действия постепенно, если выполнены действия 
		// предыдущих уровней (используется при визировании).
		
		ДопПараметрыПроверкиУсловий = бит_ВизированиеСервер.НовыеПараметрыПроверкиУсловия();
		ДопПараметрыПроверкиУсловий.ТекущийОбъект = ПараметрыОбработкиАлгоритма.ТекущийОбъект;
		ДопПараметрыПроверкиУсловий.Визы          = ПараметрыОбработкиАлгоритма.Визы;
		ДопПараметрыПроверкиУсловий.Алгоритм      = ПараметрыОбработкиАлгоритма.Алгоритм;
		
		Если ВидАлгоритма = Перечисления.бит_ВидыАлгоритмов.Прочее Тогда
			
			Если ПараметрыОбработкиАлгоритма.ПользовательскиеДействия <> Неопределено
				И НЕ ЗначениеЗаполнено(СтрокаТаблицыТочек.Задача) Тогда
				
				Если ПринятыРешенияПоВышестоящимТочкам(ТаблицаТочек,
														ТочкаАлгоритма,
														"ЗадачиВыполнены",
														ДопПараметрыПроверкиУсловий) Тогда
					СвойстваТочки = Новый Структура;
					СвойстваТочки.Вставить("Точка", 	 ТочкаАлгоритма);
					СвойстваТочки.Вставить("Действие",   ТочкаАлгоритма.ПользовательскоеДействие);
					СвойстваТочки.Вставить("Назначение", ТочкаАлгоритма.ПользовательскоеДействие.Назначение);
					ПараметрыОбработкиАлгоритма.ПользовательскиеДействия.Добавить(СвойстваТочки);
				КонецЕсли; 
			
			КонецЕсли;
			
		Иначе	
			
			ВыполнятьДействие = Ложь;
			Если ВыполнятьПоэтапно Тогда
				ПринятоРешениеПоВышестоящим = ПринятыРешенияПоВышестоящимТочкам(ТаблицаТочек,
																				ТочкаАлгоритма,
																				"ЗаполненоРешение",
																				ДопПараметрыПроверкиУсловий);
				ВыполнятьДействие = ПринятоРешениеПоВышестоящим И НЕ ЗначениеЗаполнено(СтрокаТаблицыТочек.Виза);
			Иначе	
				ВыполнятьДействие = Истина;
			КонецЕсли; 
			
			Если ВыполнятьДействие Тогда
				ДействиеВыполнено = ВыполнитьПользовательскоеДействие(ТочкаАлгоритма.ПользовательскоеДействие,
																	СтруктураКонтекст,
																	ТочкаАлгоритма,
																	Заголовок,
																	РежимСообщений);
				Если ДействиеВыполнено
					И ТочкаАлгоритма.ПользовательскоеДействие.Назначение = Перечисления.бит_НазначенияПользовательскихДействий.Визирование Тогда
					СтрокаТаблицыТочек.Виза = ТочкаАлгоритма.ПользовательскоеДействие.Виза;
				КонецЕсли;
			КонецЕсли; 				
		КонецЕсли; 
		
	КонецЕсли;
	
	Для каждого СтрокаИсходящейТочки Из ТочкаАлгоритма.ИсходящиеТочки Цикл
		ИсходящаяТочка              = СтрокаИсходящейТочки.Точка;
		ОбработатьАлгоритмИсходящей = Истина;
		
		ПараметрыИсходящейТочки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ИсходящаяТочка, "ВидТочки, ВходящиеТочки");
		Если ПараметрыИсходящейТочки.ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Слияние Тогда
			// Для корректной сортировки виз обработка точек слияния выполняется после того,
			//	как обработаны все вышестоящие точки.
			ВыборкаВходящих = ПараметрыИсходящейТочки.ВходящиеТочки.Выбрать();
			Пока ВыборкаВходящих.Следующий() Цикл
				ТочкаВходящаяВСлияние = ВыборкаВходящих.Точка;
				Если ПараметрыОбработкиАлгоритма.СтекОбработанныхТочек.НайтиПоЗначению(ТочкаВходящаяВСлияние) = Неопределено Тогда 
					// Одна из входящих точек слияния еще не обработана.
					ОбработатьАлгоритмИсходящей = Ложь;
					Если ПараметрыОбработкиАлгоритма.ТочкиОтложеннойОбработки.НайтиПоЗначению(ИсходящаяТочка) = Неопределено Тогда
						ПараметрыОбработкиАлгоритма.ТочкиОтложеннойОбработки.Добавить(ИсходящаяТочка);
					КонецЕсли;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Если ОбработатьАлгоритмИсходящей Тогда
			ОбработатьАлгоритмДляТочки(ИсходящаяТочка, ПараметрыОбработкиАлгоритма);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьТочкиДействияПослеТекущей(ПараметрыПоследующихТочек, ТочкаАлгоритма, ПараметрыКонтекста, СтекОбработанныхТочек = Неопределено)
	
	Если СтекОбработанныхТочек = Неопределено Тогда
		СтекОбработанныхТочек = Новый СписокЗначений;
	КонецЕсли;
	
	Если СтекОбработанныхТочек.НайтиПоЗначению(ТочкаАлгоритма) = Неопределено Тогда
		СтекОбработанныхТочек.Добавить(ТочкаАлгоритма);
	Иначе
		// Анализ данной точки уже выполнялся.
		Возврат;
	КонецЕсли;
	
	Если ТочкаАлгоритма.ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Обработка Тогда
		ПараметрыПоследующихТочек.ТочкиОбработок.Добавить(ТочкаАлгоритма);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИсходящиеТочки.Точка КАК Точка,
	|	ИсходящиеТочки.Точка.ВидТочки КАК ВидТочки,
	|	ИсходящиеТочки.Точка.ПользовательскоеУсловие КАК ПользовательскоеУсловие,
	|	ИсходящиеТочки.Точка.ПользовательскийВыборВарианта КАК ПользовательскийВыборВарианта
	|ИЗ
	|	Справочник.бит_ТочкиАлгоритмов.ИсходящиеТочки КАК ИсходящиеТочки
	|ГДЕ
	|	ИсходящиеТочки.Ссылка = &ТочкаАлгоритма";
	Запрос.УстановитьПараметр("ТочкаАлгоритма", ТочкаАлгоритма);
	ВыборкаИсходящихТочек = Запрос.Выполнить().Выбрать();
	Пока ВыборкаИсходящихТочек.Следующий() Цикл
		ИсходящаяТочка = ВыборкаИсходящихТочек.Точка;
		ВидТочки       = ВыборкаИсходящихТочек.ВидТочки;
		Если ЭтоДействие(ВидТочки) Тогда
			ПараметрыПоследующихТочек.ТочкиДействия.Добавить(ИсходящаяТочка);
		ИначеЕсли ЭтоПроверка(ВидТочки) Тогда
			СтрокаНаправленияПроверки = Неопределено;
			Если ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Условие
				И ЗначениеЗаполнено(ВыборкаИсходящихТочек.ПользовательскоеУсловие) Тогда
				
				УсловиеВыполнено = ПроверитьПользовательскоеУсловие(ВыборкаИсходящихТочек.ПользовательскоеУсловие,
																	ПараметрыКонтекста);
				СтрокаНаправленияПроверки = ИсходящаяТочка.ИсходящиеТочки.Найти(УсловиеВыполнено, "ЗначениеУсловия");
				
			ИначеЕсли ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.ВыборВарианта
				И ЗначениеЗаполнено(ВыборкаИсходящихТочек.ПользовательскийВыборВарианта) Тогда
				
				ЗначениеВарианта = ЗначениеПользовательскогоВарианта(ВыборкаИсходящихТочек.ПользовательскийВыборВарианта,
																	ПараметрыКонтекста);
				Для каждого ИсходящаяСтрока Из ИсходящаяТочка.ИсходящиеТочки Цикл
					ЗначениеВариантаСтроки = ИсходящаяСтрока.ЗначениеУсловия;
					Если ЗначениеВариантаСтроки = ЗначениеВарианта Тогда
						СтрокаНаправленияПроверки = ИсходящаяСтрока;
						Прервать;
					ИначеЕсли ЗначениеВариантаСтроки = Неопределено Тогда
						// Вариант "Прочее" перейдет по методу исключения.
						СтрокаНаправленияПроверки = ИсходящаяСтрока;
					КонецЕсли;
				КонецЦикла;
				
			КонецЕсли;
			Если СтрокаНаправленияПроверки = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ТочкаНаправленияУсловия = СтрокаНаправленияПроверки.Точка;
			Если ЭтоДействие(ТочкаНаправленияУсловия.ВидТочки) Тогда
				ПараметрыПоследующихТочек.ТочкиДействия.Добавить(ТочкаНаправленияУсловия);	
			Иначе
				ДобавитьТочкиДействияПослеТекущей(ПараметрыПоследующихТочек, СтрокаНаправленияПроверки.Точка, ПараметрыКонтекста, СтекОбработанныхТочек);
			КонецЕсли;
		Иначе
			ДобавитьТочкиДействияПослеТекущей(ПараметрыПоследующихТочек, ИсходящаяТочка, ПараметрыКонтекста, СтекОбработанныхТочек);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Функция инициализирует таблицу виз. 
// Используется в процедуре ОписаниеТочекАлгоритма.
// 
// Возвращаемое значение:
//   ТаблицаВиз   - ТаблицаЗначений.
// 
Функция КонструкторТаблицыВиз()

	ТаблицаВизы = Новый ТаблицаЗначений;
	ТаблицаВизы.Колонки.Добавить("Виза"           ,Новый ОписаниеТипов("СправочникСсылка.бит_Визы"));
	ТаблицаВизы.Колонки.Добавить("ИД"             ,Новый ОписаниеТипов("Строка"));
	ТаблицаВизы.Колонки.Добавить("ТочкаАлгоритма" ,Новый ОписаниеТипов("СправочникСсылка.бит_ТочкиАлгоритмов"));
	ТаблицаВизы.Колонки.Добавить("Решение"        ,Новый ОписаниеТипов("СправочникСсылка.бит_ВидыРешенийСогласования"));
	ТаблицаВизы.Колонки.Добавить("АктивнаяВиза"   ,Новый ОписаниеТипов("Булево"));
	ТаблицаВизы.Колонки.Добавить("ДоступностьВизы",Новый ОписаниеТипов("Булево"));

	Возврат ТаблицаВизы;
	
КонецФункции // КонструкторТаблицыВиз()

// Функция инициализирует таблицу, содержащую информацию об точках алогоритма, визах и задачах.
// Используется в процедуре ОписаниеТочекАлгоритма.
// 
// Возвращаемое значение:
//   ТаблицаТочек   - ТаблицаЗначений.
// 
Функция КонструкторТаблицыТочкиВизы()
	
	ОписаниеЧисло = Новый ОписаниеТипов("Число");
	ОписаниеБулево = Новый ОписаниеТипов("Булево");
	
	ТаблицаТочкиВизы = Новый ТаблицаЗначений;
	ТаблицаТочкиВизы.Колонки.Добавить("Точка"                       ,Новый ОписаниеТипов("СправочникСсылка.бит_ТочкиАлгоритмов"));
	ТаблицаТочкиВизы.Колонки.Добавить("ВидТочки"                    ,Новый ОписаниеТипов("ПеречислениеСсылка.бит_ВидыТочекАлгоритмов"));
	ТаблицаТочкиВизы.Колонки.Добавить("Обработана"                  ,ОписаниеЧисло);
	ТаблицаТочкиВизы.Колонки.Добавить("СвязиОбработаны"             ,ОписаниеЧисло);
	ТаблицаТочкиВизы.Колонки.Добавить("КоличествоОбработанныхСвязей",ОписаниеЧисло);
	ТаблицаТочкиВизы.Колонки.Добавить("КоличествоВходящих"          ,ОписаниеЧисло);
	ТаблицаТочкиВизы.Колонки.Добавить("КоличествоИсходящих"         ,ОписаниеЧисло);
	ТаблицаТочкиВизы.Колонки.Добавить("ИдентификаторТочки",			 ОбщегоНазначения.ОписаниеТипаСтрока(10));
	ТаблицаТочкиВизы.Колонки.Добавить("КодТочки",					 ОбщегоНазначения.ОписаниеТипаСтрока(50));
	
	ТаблицаТочкиВизы.Колонки.Добавить("Виза"              ,Новый ОписаниеТипов("СправочникСсылка.бит_Визы"));
	ТаблицаТочкиВизы.Колонки.Добавить("ИД"                ,Новый ОписаниеТипов("Строка"));
	ТаблицаТочкиВизы.Колонки.Добавить("Решение"           ,Новый ОписаниеТипов("СправочникСсылка.бит_ВидыРешенийСогласования"));
	ТаблицаТочкиВизы.Колонки.Добавить("ТипРешения"        ,Новый ОписаниеТипов("ПеречислениеСсылка.бит_ТипыРешений"));
	ТаблицаТочкиВизы.Колонки.Добавить("ЕстьПраво"         ,ОписаниеБулево);
	ТаблицаТочкиВизы.Колонки.Добавить("ВходящиеЗаполнены" ,ОписаниеБулево);
	ТаблицаТочкиВизы.Колонки.Добавить("ИсходящиеЗаполнены",ОписаниеБулево);
	ТаблицаТочкиВизы.Колонки.Добавить("АктивнаяВиза"      ,ОписаниеБулево);
	ТаблицаТочкиВизы.Колонки.Добавить("Доступность"       ,ОписаниеБулево);
	
	НовОписание = бит_ОбщегоНазначенияКлиентСервер.ПолучитьОписаниеИзСтроки("ЗадачаСсылка.бит_Задача/БизнесПроцессСсылка.бит_Процесс");
	ТаблицаТочкиВизы.Колонки.Добавить("Задача"   , НовОписание);
	ТаблицаТочкиВизы.Колонки.Добавить("Состояние", Новый ОписаниеТипов("СправочникСсылка.бит_СтатусыОбъектов"));
	
	ТаблицаТочкиВизы.Колонки.Добавить("ДатаОкончания", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	
	Возврат ТаблицаТочкиВизы;
	
КонецФункции

// Процедура выполняет "Полное соединение" таблицы точек и таблицы виз. 
// Реализация посредством таблиц значений выполняется в несколько раз быстрее чем посредством запроса.
// 
// Параметры:
//  ТаблицаТочкиВизы - ТаблицаЗначений.
//  ТаблицаТочки     - ТаблицаЗначений.
//  ТаблицаВизы      - ТаблицаЗначений.
// 
Процедура ПолноеСоединениеТочкиВизы(ТаблицаТочкиВизы,ТаблицаТочки,ТаблицаВизы)

	ТаблицаВизы.Колонки.Добавить("Обработана",Новый ОписаниеТипов("Булево"));
	ТипыРешений = Новый Соответствие;
	
	Для каждого СтрокаТочки Из ТаблицаТочки Цикл
	
		НоваяСтрока = ТаблицаТочкиВизы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,СтрокаТочки);
		
		Для каждого СтрокаВизы Из ТаблицаВизы Цикл
		     // ++ NB Есть мнение, что строки нужно удалять, а не маркировать.
			 // 	  Тогда чисто строк во втором цикле уменьшится.
			 Если СтрокаВизы.ТочкаАлгоритма = СтрокаТочки.Точка И НЕ СтрокаВизы.Обработана Тогда
			 
			 	СтрокаВизы.Обработана    = Истина;
				НоваяСтрока.Виза         = СтрокаВизы.Виза;
				НоваяСтрока.ИД           = СтрокаВизы.ИД;
				НоваяСтрока.Решение      = СтрокаВизы.Решение;
				НоваяСтрока.ТипРешения   = Справочники.бит_ВидыРешенийСогласования.ТипРешенияСогласования(НоваяСтрока.Решение,
																											ТипыРешений);
				НоваяСтрока.ЕстьПраво    = СтрокаВизы.ДоступностьВизы;
				НоваяСтрока.АктивнаяВиза = СтрокаВизы.АктивнаяВиза;
			 
			 КонецЕсли; 
		
		КонецЦикла; 
	
	КонецЦикла; 

	Для каждого СтрокаВизы Из ТаблицаВизы Цикл
	
		Если НЕ СтрокаВизы.Обработана Тогда
		
			НоваяСтрока = ТаблицаТочкиВизы.Добавить();
			СтрокаВизы.Обработана    = Истина;
			НоваяСтрока.Виза         = СтрокаВизы.Виза;
			НоваяСтрока.ИД           = СтрокаВизы.ИД;
			НоваяСтрока.Решение      = СтрокаВизы.Решение;
			НоваяСтрока.ТипРешения   = Справочники.бит_ВидыРешенийСогласования.ТипРешенияСогласования(НоваяСтрока.Решение,
																										ТипыРешений);
			НоваяСтрока.ЕстьПраво    = СтрокаВизы.ДоступностьВизы;
			НоваяСтрока.ВидТочки     = Перечисления.бит_ВидыТочекАлгоритмов.Действие;
			НоваяСтрока.АктивнаяВиза = СтрокаВизы.АктивнаяВиза;
		
		КонецЕсли; 
	
	КонецЦикла; 

КонецПроцедуры

// Процедура заполняет в общей таблице ТаблицаТочкиВизы данные по задачам алгоритма. 
// 
// Параметры:
//  ТаблицаТочкиВизы - ТаблицаЗначений.
//  ТабЗадач         - ТаблицаЗначений.
// 
Процедура ЗаполнитьДанныеЗадач(ТаблицаТочкиВизы, ТабЗадач)
	
	Для каждого СтрокаЗадачи Из ТабЗадач Цикл
		
		СтрОтбор = Новый Структура;
		СтрОтбор.Вставить("Точка", СтрокаЗадачи.Точка);
		
		МассивСтрок = ТаблицаТочкиВизы.НайтиСтроки(СтрОтбор);
		
		Для каждого СтрокаТаблицы Из МассивСтрок Цикл
			
			СтрокаТаблицы.Задача        = СтрокаЗадачи.Задача;
			СтрокаТаблицы.Состояние     = СтрокаЗадачи.Состояние;
			СтрокаТаблицы.ДатаОкончания = СтрокаЗадачи.СрокИсполнения;
			
		КонецЦикла; 
		
	КонецЦикла; 	
	
КонецПроцедуры // ЗаполнитьДанныеЗадач() 

Функция УстановленоРешениеВИсходящихТочках(ТекущаяТочка, ТаблицаТочек, КэшПроверки)
	
	РезультатПроверки = КэшПроверки.Получить(ТекущаяТочка);
	Если РезультатПроверки <> Неопределено Тогда
		Возврат РезультатПроверки;
	КонецЕсли;
	
	РешениеУстановлено = Ложь;
	Для каждого СтрокаИсходящейТочки Из ТекущаяТочка.ИсходящиеТочки Цикл
		ИсходящаяТочка = СтрокаИсходящейТочки.Точка;
		
		Если ТочкиЗациклены(ТекущаяТочка, ИсходящаяТочка) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТаблицыТочек = ТаблицаТочек.Найти(ИсходящаяТочка, "Точка");
		Если ЗначениеЗаполнено(СтрокаТаблицыТочек.Решение) Тогда
			РешениеУстановлено = Истина;
			Прервать;
		КонецЕсли;
		
		Если УстановленоРешениеВИсходящихТочках(ИсходящаяТочка, ТаблицаТочек, КэшПроверки) Тогда
			РешениеУстановлено = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	КэшПроверки.Вставить(ТекущаяТочка, РешениеУстановлено);
	Возврат РешениеУстановлено;
	
КонецФункции

// Конструктор параметра СтруктураКонтекст функции "ВыполнитьАлгоритм".
// 
// Возвращаемое значение:
//  Параметры - Структрура.
//
Функция НовыеПараметрыВыполненияАлгоритма()

	Параметры = Новый Структура; 
	
	Параметры.Вставить("Визы");
	Параметры.Вставить("ТабЗадачи");
	Параметры.Вставить("ПользовательскиеДействия");
	Параметры.Вставить("ТекущийОбъект");
	Параметры.Вставить("ОплатаЗаявки");
	
	Параметры.Вставить("Алгоритм");
	Параметры.Вставить("ВидАлгоритма");
	Параметры.Вставить("ТаблицаТочек");
	Параметры.Вставить("СтруктураКонтекст");
	Параметры.Вставить("Заголовок");
	Параметры.Вставить("РежимСообщений");
	Параметры.Вставить("ВыводитьОшибки");
	Параметры.Вставить("ВыполнятьПоэтапно");
	
	Параметры.Вставить("СтекОбработанныхТочек",    Новый СписокЗначений);
	Параметры.Вставить("ТочкиОтложеннойОбработки", Новый СписокЗначений);
	
	Возврат Параметры;
	
КонецФункции

// Возвращает алгоритмы изменения статусов для текущего объекта.
// 
// Параметры:
//  ТекущийОбъект  - ДокументОбъект,ДокументСсылка.
//  ВидАлгоритма   - ПеречислениеСсылка.бит_ВидыАлгоритмов, СписокЗначений.
// 
// Возвращаемое значение:
// РезСтруктура - Структура - Ключ: имя вида алгоритма, Значение: Алгоритм.
// 
Функция АлгоритмыОбъектаСистемы(ТекущийОбъект,ВидАлгоритма = Неопределено)

	АлгоритмыОбъекта = Новый Структура;
	
	// Инициализируем результирующую структуру
	Для каждого ЗначениеПеречисления Из Метаданные.Перечисления.бит_ВидыАлгоритмов.ЗначенияПеречисления Цикл
		АлгоритмыОбъекта.Вставить(ЗначениеПеречисления.Имя,Справочники.бит_АлгоритмыПроцессов.ПустаяСсылка())
	КонецЦикла;
		
	МетаданныеОбъекта = ТекущийОбъект.Метаданные();
	
	ОбъектСистемы = бит_ПраваДоступа.ПолучитьОбъектДоступаПоМетаданным(МетаданныеОбъекта);
	
	ДатаСреза = ТекущийОбъект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаСреза) Тогда
		ДатаСреза = ТекущаяДатаСеанса();
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	НазначениеАлгоритмов.ОбъектСистемы КАК ОбъектСистемы,
	|	НазначениеАлгоритмов.ВидАлгоритма КАК ВидАлгоритма,
	|	НазначениеАлгоритмов.ПользовательскоеУсловие КАК ПользовательскоеУсловие,
	|	НазначениеАлгоритмов.Алгоритм КАК Алгоритм,
	|	ВЫБОР
	|		КОГДА НазначениеАлгоритмов.ПользовательскоеУсловие = ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеУсловия.ПустаяСсылка)
	|			ТОГДА 9999
	|		ИНАЧЕ НазначениеАлгоритмов.Приоритет
	|	КОНЕЦ КАК Приоритет
	|ИЗ
	|	РегистрСведений.бит_НазначениеАлгоритмов КАК НазначениеАлгоритмов
	|ГДЕ
	|	НазначениеАлгоритмов.ОбъектСистемы = &ОбъектСистемы
	|	И НазначениеАлгоритмов.Период <= &ДатаСреза
	|	И (НазначениеАлгоритмов.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ КОНЕЦПЕРИОДА(НазначениеАлгоритмов.ДатаОкончания, ДЕНЬ) >= &ДатаСреза)
	|	И &УсловиеВидАлгоритма
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет,
	|	НазначениеАлгоритмов.Период УБЫВ
	|ИТОГИ ПО
	|	ВидАлгоритма";
	ТекстУсловиеВидАлгоритма = "";
	Если ВидАлгоритма = Неопределено Тогда
		ТекстУсловиеВидАлгоритма = "ИСТИНА";
	Иначе
		ТекстУсловиеВидАлгоритма = "НазначениеАлгоритмов.ВидАлгоритма В (&ВидАлгоритма)";
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеВидАлгоритма", ТекстУсловиеВидАлгоритма);
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ОбъектСистемы", ОбъектСистемы);
	Запрос.УстановитьПараметр("ДатаСреза",     ДатаСреза);
	Запрос.УстановитьПараметр("ВидАлгоритма",  ВидАлгоритма);
	
	ВыборкаВидовАлгоритмов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаВидовАлгоритмов.Следующий() Цикл
		
		ВидАлгоритмаСтрока = бит_ОбщегоНазначения.ПолучитьИмяЗначенияПеречисления(Перечисления.бит_ВидыАлгоритмов,
																					ВыборкаВидовАлгоритмов.ВидАлгоритма);		
		ВыборкаАлгоритмов  = ВыборкаВидовАлгоритмов.Выбрать();
		Пока ВыборкаАлгоритмов.Следующий() Цикл
			Если ЗначениеЗаполнено(ВыборкаАлгоритмов.ПользовательскоеУсловие) Тогда
				ПараметрыУсловия   = Новый Структура("ТекущийОбъект", ТекущийОбъект);
				УсловиеВыполняется = ПроверитьПользовательскоеУсловие(ВыборкаАлгоритмов.ПользовательскоеУсловие,
																		ПараметрыУсловия,,"","Ошибки");
			Иначе
				УсловиеВыполняется = Истина;
			КонецЕсли;
			Если УсловиеВыполняется Тогда
				АлгоритмыОбъекта.Вставить(ВидАлгоритмаСтрока, ВыборкаАлгоритмов.Алгоритм);
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
					   
	Возврат АлгоритмыОбъекта;

КонецФункции

// Функция получает таблицу точек алгоритма с количествами входящих и исходящих точек.
// 
// Параметры:
//  Алгоритм  - СправочникСсылка.бит_АлгоритмыПроцессов.
// 
// Возвращаемое значение:
//   ТаблицаТочки   - ТаблицаЗначений.
// 
Функция ПолучитьТочкиАлгоритма(Алгоритм)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Алгоритм",Алгоритм);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВходящиеТочки.Ссылка КАК Точка,
	|	КОЛИЧЕСТВО(*) КАК Количество
	|ПОМЕСТИТЬ ВТ_ВхТочки
	|ИЗ
	|	Справочник.бит_ТочкиАлгоритмов.ВходящиеТочки КАК ВходящиеТочки
	|ГДЕ
	|	ВходящиеТочки.Ссылка.Владелец = &Алгоритм
	|
	|СГРУППИРОВАТЬ ПО
	|	ВходящиеТочки.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИсходящиеТочки.Ссылка КАК Точка,
	|	КОЛИЧЕСТВО(*) КАК Количество
	|ПОМЕСТИТЬ ВТ_ИсхТочки
	|ИЗ
	|	Справочник.бит_ТочкиАлгоритмов.ИсходящиеТочки КАК ИсходящиеТочки
	|ГДЕ
	|	ИсходящиеТочки.Ссылка.Владелец = &Алгоритм
	|
	|СГРУППИРОВАТЬ ПО
	|	ИсходящиеТочки.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТочкиАлгоритмов.ВидТочки, ЗНАЧЕНИЕ(Перечисление.бит_ВидыТочекАлгоритмов.Действие)) КАК ВидТочки,
	|	ЕСТЬNULL(ВТ_ВхТочки.Количество, 0) КАК КоличествоВходящих,
	|	ЕСТЬNULL(ВТ_ИсхТочки.Количество, 0) КАК КоличествоИсходящих,
	|	ТочкиАлгоритмов.ИдентификаторТочки КАК ИдентификаторТочки,
	|	ТочкиАлгоритмов.Ссылка КАК Точка,
	|	ТочкиАлгоритмов.КодТочки КАК КодТочки
	|ИЗ
	|	Справочник.бит_ТочкиАлгоритмов КАК ТочкиАлгоритмов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ВхТочки КАК ВТ_ВхТочки
	|		ПО ТочкиАлгоритмов.Ссылка = ВТ_ВхТочки.Точка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ИсхТочки КАК ВТ_ИсхТочки
	|		ПО ТочкиАлгоритмов.Ссылка = ВТ_ИсхТочки.Точка
	|ГДЕ
	|	ТочкиАлгоритмов.Владелец = &Алгоритм
	|	И НЕ ТочкиАлгоритмов.ПометкаУдаления";
	
	Результат = Запрос.Выполнить();
	
	ТаблицаТочки = Результат.Выгрузить();
	
	Возврат ТаблицаТочки;
	
КонецФункции

Функция ГрафическаяСхемаВXML(ГрафическаяСхема)
	
	Результат = "";
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку();
	
	Сериализатор = Новый СериализаторXDTO(ФабрикаXDTO);
	Сериализатор.ЗаписатьXML(ЗаписьXML, ГрафическаяСхема, НазначениеТипаXML.Явное);
	
	Результат = ЗаписьXML.Закрыть();
	
	Возврат Результат;
	
КонецФункции

// Проверяет приняты ли решения по вышестоящим точкам действия. Рекурсивный вызов.
// 
// Параметры:
//  ТаблицаТочек    - ТаблицаЗначений.
//  ТочкаНачальная  - СправочникСсылка.бит_ТочкиАлгоритмов.
//  Заполнены       - Булево.
//  Режим           - Строка.
// 
Функция ПринятыРешенияПоВышестоящимТочкам(ТаблицаТочек,ТочкаНачальная,Режим,ДопПараметрыПроверкиУсловий)
	
	УсловиеВыполнено = Истина;
	
	КэшПроверок = ДопПараметрыПроверкиУсловий.КэшПроверок.ПринятыРешенияПоВышестоящимТочкам;
	РезультатПроверки = КэшПроверок.Получить(ТочкаНачальная);
	Если РезультатПроверки <> Неопределено Тогда
		Возврат РезультатПроверки;
	КонецЕсли;
	
	СтрокаТаблицыНачальная = ТаблицаТочек.Найти(ТочкаНачальная,"Точка");
	Если СтрокаТаблицыНачальная = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	ВходящиеТочки = СтрокаТаблицыНачальная.ВходящиеТочки;
	
	КолТочДействия       = 0;
	КолТочДействияБезВиз = 0;
	ЕстьВыполнимыеВетки  = (ВходящиеТочки.Количество() = 0);
	ТочкаВСтартеПроцесса = Ложь;
	
	Для каждого СтрокаВходящие Из ВходящиеТочки Цикл
		
		Если ДопПараметрыПроверкиУсловий <> Неопределено
			И НЕ ВышеНетНевыполнимыхУсловий(СтрокаВходящие.Точка, ДопПараметрыПроверкиУсловий) Тогда
			Продолжить;
		КонецЕсли;
		
		ВыполненоУсловиеПоВетке = Истина;
			
		Если ЭтоДействие(СтрокаВходящие.ВидТочки) Тогда
			
			// Проверим принято решение в данной точке или нет.
			СтрокаТаблицы = ТаблицаТочек.Найти(СтрокаВходящие.Точка,"Точка");
			Если НЕ СтрокаТаблицы = Неопределено Тогда
				
				Если ВРег(Режим) = ВРег("ЗаполненоРешение") ИЛИ ВРег(Режим) = ВРег("ЗаполненоРешениеВиза") Тогда
					
					КолТочДействия = КолТочДействия + 1;
					
					Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Виза) Тогда
						
						КолТочДействияБезВиз = КолТочДействияБезВиз+1;
						
					КонецЕсли; 
					
					Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Решение)
						И (СтрокаТаблицы.ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Действие
							ИЛИ ЗначениеЗаполнено(СтрокаТаблицы.Виза)) Тогда
						ВыполненоУсловиеПоВетке = Ложь;
					КонецЕсли; 
					
				ИначеЕсли ВРег(Режим) = ВРег("Согласовано") Тогда	
					
					Если НЕ (СтрокаТаблицы.ТипРешения = Перечисления.бит_ТипыРешений.Согласующее)
							И ЗначениеЗаполнено(СтрокаТаблицы.Виза) Тогда
						ВыполненоУсловиеПоВетке = Ложь;
					КонецЕсли;
					
				ИначеЕсли ВРег(Режим) = ВРег("ЗадачиВыполнены") Тогда
					
					ТипСтатуса = Справочники.бит_СтатусыОбъектов.ТипСтатусаОбъкта(СтрокаТаблицы.Состояние);
					Если ТипСтатуса <> Перечисления.бит_ТипыСтатусовОбъектов.Исполнен
						И ТипСтатуса <> Перечисления.бит_ТипыСтатусовОбъектов.Отклонен Тогда
						ВыполненоУсловиеПоВетке = Ложь;
					КонецЕсли; 
				КонецЕсли; 
			КонецЕсли;	  
			
		ИначеЕсли СтрокаВходящие.ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Старт Тогда
			
			ВыполненоУсловиеПоВетке = Истина;
			ТочкаВСтартеПроцесса    = Истина;
		
		Иначе
			
			ТочкаПроверки = СтрокаВходящие.Точка;
			
			КлючПроверки  = "СтекПроверкиПринятыРешенияПоВышестоящимТочкам";
			Если НЕ ДопПараметрыПроверкиУсловий.Свойство(КлючПроверки) Тогда
				ДопПараметрыПроверкиУсловий.Вставить(КлючПроверки, Новый СписокЗначений);
			КонецЕсли;
			СтрекПроверки = ДопПараметрыПроверкиУсловий[КлючПроверки];
			Если СтрекПроверки.НайтиПоЗначению(ТочкаПроверки) = Неопределено Тогда
				СтрекПроверки.Добавить(ТочкаПроверки);
			Иначе
				ТекстСообщения = НСтр("ru='Ошибка рекурсии при проверке заполнения вышестоящих точек алгоритма.';
									|en='Recursion error while checking filling of higher points of the algorithm.'");
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
				ДопПараметрыПроверкиУсловий.Удалить(КлючПроверки);
				Возврат Ложь;
			КонецЕсли;
			
			Если НЕ ПринятыРешенияПоВышестоящимТочкам(ТаблицаТочек,
														ТочкаПроверки,
														Режим,
														ДопПараметрыПроверкиУсловий) Тогда
				ВыполненоУсловиеПоВетке = Ложь;
			КонецЕсли;
			
			Если ДопПараметрыПроверкиУсловий.Свойство(КлючПроверки) Тогда
				ДопПараметрыПроверкиУсловий.Удалить(КлючПроверки);
			КонецЕсли;
			
		КонецЕсли;	// Точка действия
		
		Если НЕ ВыполненоУсловиеПоВетке Тогда
			Если СтрокаТаблицыНачальная.ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Слияние Тогда
				// В случае слияния должны выполняться условия по всем входящим веткам.
				УсловиеВыполнено = Ложь;
				Прервать;
			Иначе
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		ЕстьВыполнимыеВетки = Истина;
		
	КонецЦикла;	// По входящим точкам
	
	Если УсловиеВыполнено Тогда
		
		Если НЕ ЕстьВыполнимыеВетки Тогда
			
			УсловиеВыполнено = Ложь;
			
		ИначеЕсли ВРег(Режим) = ВРег("ЗаполненоРешение") ИЛИ ВРег(Режим) = ВРег("ЗаполненоРешениеВиза") Тогда
			
			Если КолТочДействия > 0 И КолТочДействия = КолТочДействияБезВиз И НЕ ТочкаВСтартеПроцесса Тогда
				УсловиеВыполнено = Ложь;
			КонецЕсли; 
			
		КонецЕсли; 
	КонецЕсли;
	
	КэшПроверок.Вставить(ТочкаНачальная, УсловиеВыполнено);
	Возврат УсловиеВыполнено;
	
КонецФункции	

Процедура ДобавитьНижестоящиеЗадачи(ТекущаяТочка, ПараметрыДеактивации, НижестоящиеЗадачи, СтекПроверки = Неопределено)
	
	Если СтекПроверки = Неопределено Тогда
		СтекПроверки = Новый СписокЗначений;
	КонецЕсли;
	
	Если СтекПроверки.НайтиПоЗначению(ТекущаяТочка) <> Неопределено Тогда
		Возврат;
	Иначе
		СтекПроверки.Добавить(ТекущаяТочка);
	КонецЕсли;
	
	ТочкиАлгоритма = ПараметрыДеактивации.ТочкиАлгоритма;
	ИсходящиеТочки = ПараметрыДеактивации.ИсходящиеТочки;
	
	Отбор = Новый Структура("ТочкаАлгоритма", ТекущаяТочка);
	ТекущиеИсходящиеТочки = ИсходящиеТочки.НайтиСтроки(Отбор);
	
	ПараметрыТочки = ТочкиАлгоритма.Найти(ТекущаяТочка, "ТочкаАлгоритма");
	Если ПараметрыТочки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВидТочки = ПараметрыТочки.ВидТочки;
	
	Если ЭтоПроверка(ВидТочки) Тогда
		ПараметрыПроверки = Новый Структура;
		ПараметрыПроверки.Вставить("ТекущийОбъект", ПараметрыДеактивации.БизнесПроцесс);
		ПараметрыПроверки.Вставить("ТекущаяТочка",  ПараметрыДеактивации.ТекущаяТочка);
		ИсходящаяТочка    = Неопределено;
		Если ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Условие Тогда	
			ЗначениеУсловия = ПроверитьПользовательскоеУсловие(ПараметрыТочки.ПользовательскоеУсловие,
																ПараметрыПроверки);
			Для каждого СтрокаИсходящейСтроки Из ТекущиеИсходящиеТочки Цикл
				Если ЗначениеУсловия = СтрокаИсходящейСтроки.ЗначениеУсловия Тогда
					ИсходящаяТочка = СтрокаИсходящейСтроки.ИсходящаяТочка;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		ИначеЕсли ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.ВыборВарианта Тогда
			ЗначениеУсловия = ЗначениеПользовательскогоВарианта(ПараметрыТочки.ПользовательскийВыборВарианта,
																	ПараметрыПроверки);
			Для каждого СтрокаИсходящейСтроки Из ТекущиеИсходящиеТочки Цикл
				Если ЗначениеУсловия = СтрокаИсходящейСтроки.ЗначениеУсловия Тогда
					ИсходящаяТочка = СтрокаИсходящейСтроки.ИсходящаяТочка;
					Прервать;
				ИначеЕсли СтрокаИсходящейСтроки.ЗначениеУсловия = Неопределено Тогда
					// Вариант "Прочее" перейдет по методу исключения.
					ИсходящаяТочка = СтрокаИсходящейСтроки.ИсходящаяТочка;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если ИсходящаяТочка <> Неопределено Тогда
			ДобавитьНижестоящиеЗадачи(ИсходящаяТочка, ПараметрыДеактивации, НижестоящиеЗадачи, СтекПроверки);
		КонецЕсли;
		
		Возврат;
	ИначеЕсли ВидТочки = Перечисления.бит_ВидыТочекАлгоритмов.Действие Тогда
		Если НЕ ЗначениеЗаполнено(ПараметрыТочки.Задача) Тогда
			// Алгоритм еще не дошел до этой точки.
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Задача = ПараметрыТочки.Задача;
	Если ЗначениеЗаполнено(Задача) Тогда
		НижестоящиеЗадачи.Добавить(Задача);
	КонецЕсли;
	
	Для каждого СтрокаИсходящейСтроки Из ТекущиеИсходящиеТочки Цикл
		ИсходящаяТочка = СтрокаИсходящейСтроки.ИсходящаяТочка;
		ДобавитьНижестоящиеЗадачи(ИсходящаяТочка, ПараметрыДеактивации, НижестоящиеЗадачи, СтекПроверки);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
