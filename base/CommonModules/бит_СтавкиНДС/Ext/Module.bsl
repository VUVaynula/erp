#Область СлужебныйПрограммныйИнтерфейс

Функция ОписаниеТипаСтавкиНДС() Экспорт

	Возврат Метаданные.ОпределяемыеТипы.бит_СтавкаНДС.Тип;
	
КонецФункции

Функция СтавкаНДСПустая() Экспорт
	
	// ++ ЕРП 
	Возврат Справочники.СтавкиНДС.ПустаяСсылка();
	// -- ЕРП 
	
КонецФункции

Функция СтавкаНДСПоПеречислению(СтавкаНДСИзПеречисления) Экспорт

	// ++ ЕРП 
	Возврат УчетНДСЛокализация.СтавкаНДСПоПеречислению(СтавкаНДСИзПеречисления);
	// -- ЕРП 
	
КонецФункции

Функция СоответствуютСтавкиНДС(СтавкаТекущая, СтавкаЭталон) Экспорт

	// ++ ЕРП 
	СтавкиСоответствуют = Ложь;
	
	Если бит_ОбщегоНазначенияКлиентСерверПереопределяемый.ИспользоватьСправочникСтавкиНДС() Тогда
		Ставка10 	 = УчетНДСЛокализация.СтавкаНДСПоПеречислению(Перечисления.СтавкиНДС.НДС10);
		Ставка110 	 = УчетНДСЛокализация.СтавкаНДСПоПеречислению(Перечисления.СтавкиНДС.НДС10_110);
		Ставка18 	 = УчетНДСЛокализация.СтавкаНДСПоПеречислению(Перечисления.СтавкиНДС.НДС18);
		Ставка118 	 = УчетНДСЛокализация.СтавкаНДСПоПеречислению(Перечисления.СтавкиНДС.НДС18_118);
		Ставка20 	 = УчетНДСЛокализация.СтавкаНДСПоПеречислению(Перечисления.СтавкиНДС.НДС20);
		Ставка120 	 = УчетНДСЛокализация.СтавкаНДСПоПеречислению(Перечисления.СтавкиНДС.НДС20_120);
		СтавкаБезНДС = УчетНДСЛокализация.СтавкаНДСПоПеречислению(Перечисления.СтавкиНДС.БезНДС);
		СтавкаНДС0 	 = УчетНДСЛокализация.СтавкаНДСПоПеречислению(Перечисления.СтавкиНДС.НДС0);
	Иначе
		Ставка10 	 = Перечисления.СтавкиНДС.НДС10;
		Ставка110 	 = Перечисления.СтавкиНДС.НДС10_110;
		Ставка18 	 = Перечисления.СтавкиНДС.НДС18;
		Ставка118 	 = Перечисления.СтавкиНДС.НДС18_118;
		Ставка20 	 = Перечисления.СтавкиНДС.НДС20;
		Ставка120 	 = Перечисления.СтавкиНДС.НДС20_120;
		СтавкаБезНДС = Перечисления.СтавкиНДС.БезНДС;
		СтавкаНДС0 	 = Перечисления.СтавкиНДС.НДС0;
	КонецЕсли;
	
	Если СтавкаТекущая = СтавкаЭталон
		ИЛИ (СтавкаТекущая = Ставка10 И СтавкаЭталон = Ставка110)
		ИЛИ (СтавкаЭталон = Ставка10 И СтавкаТекущая = Ставка110)
		ИЛИ (СтавкаТекущая = Ставка18 И СтавкаЭталон = Ставка118)
		ИЛИ (СтавкаЭталон = Ставка18 И СтавкаТекущая = Ставка118)
		ИЛИ (СтавкаТекущая = Ставка20 И СтавкаЭталон = Ставка120)
		ИЛИ (СтавкаЭталон = Ставка20 И СтавкаТекущая = Ставка120)
		ИЛИ (СтавкаТекущая = СтавкаБезНДС И СтавкаЭталон = СтавкаНДС0)
		ИЛИ (СтавкаЭталон = СтавкаБезНДС И СтавкаТекущая = СтавкаНДС0) Тогда			
		СтавкиСоответствуют = Истина;	
	КонецЕсли;
	
	Возврат СтавкиСоответствуют;
	// -- ЕРП 
	
КонецФункции

// Функция возвращает процент ставки НДС.
//
// Параметры:
//  СтавкаНДС - СправочникСсылка.СтавкиНДС - Ставка НДС.
// 
// Возвращаемое значение:
//  Число.
//
Функция ЗначениеСтавкиНДС(СтавкаНДС) Экспорт

	// ++ ЕРП 
	Если ТипЗнч(СтавкаНДС) = Тип("ПеречислениеСсылка.СтавкиНДС") Тогда
		СтавкаНДССправочник = СтавкаНДСПоПеречислению(СтавкаНДС);
	Иначе
		СтавкаНДССправочник = СтавкаНДС;
	КонецЕсли;
	Возврат УчетНДСУПКлиентСервер.ЗначениеСтавкиНДС(СтавкаНДССправочник);
	// -- ЕРП 

КонецФункции

#КонецОбласти
