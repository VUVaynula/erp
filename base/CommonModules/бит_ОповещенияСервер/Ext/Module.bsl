КонецФункции // ПолучитьНастройкиКомпоновщика()

// Функция получает таблицу назначенных оповещений.
// 
// Возвращаемое значение:
//   ТаблицаЗначений.
// 
Функция ПолучитьАктивныеОповещения() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НазначениеОповещений.ВидСобытия КАК ВидСобытия,
	|	НазначениеОповещений.ОбъектСистемы КАК ОбъектСистемы,
	|	НазначениеОповещений.Оповещение КАК Оповещение,
	|	НазначениеОповещений.Оповещение.Статус КАК Статус,
	|	НазначениеОповещений.Оповещение.Виза КАК Виза,
	|	НазначениеОповещений.Оповещение.Решение КАК Решение,
	|	НазначениеОповещений.Оповещение.ПользовательскоеУсловие КАК ПользовательскоеУсловие,
	|	НазначениеОповещений.Оповещение.АлгоритмПроцесса КАК АлгоритмПроцесса,
	|	НазначениеОповещений.Оповещение.ТочкаАлгоритма КАК ТочкаАлгоритма,
	|	НазначениеОповещений.Оповещение.ФоновыйРежим КАК ФоновыйРежим
	|ИЗ
	|	РегистрСведений.бит_фн_НазначениеОповещений КАК НазначениеОповещений";
	
	Результат = Запрос.Выполнить().Выгрузить();			   
	
	Если Результат.Количество() > 1000 Тогда
		Результат.Индексы.Добавить("ВидСобытия,ОбъектСистемы");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Функция определяет получаетелей оповещений.
//
// Параметры:
//  СпособТранспорта - ПеречислениеСсылка.бит_фн_СпособыТранспортаОповещений.
//
// Возвращаемое значение:
//  СписокЗначений.
//
Функция ПолучателиОповещений(СпособТранспорта) Экспорт
	
	Получатели = Новый СписокЗначений;
	
	Если СпособТранспорта = Перечисления.бит_фн_СпособыТранспортаОповещений.Telegram Тогда
		НастройкаОповещения = ПланыВидовХарактеристик.бит_НастройкиПользователей.ОповещатьОНовыхВизахВТелеграм;
	ИначеЕсли СпособТранспорта = Перечисления.бит_фн_СпособыТранспортаОповещений.ЭлектроннаяПочта1С Тогда
		НастройкаОповещения = ПланыВидовХарактеристик.бит_НастройкиПользователей.ОповещатьОНовыхВизахПоПочте;
	Иначе
		Возврат Получатели;
	КонецЕсли;
	
	НастройкаОсновнаяГруппа = ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнаяГруппаПользователя;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НастройкиПользователей.Пользователь КАК Пользователь,
	|	НастройкиПользователей.Настройка КАК Настройка,
	|	НастройкиПользователей.ЗначениеНастройки КАК ЗначениеНастройки
	|ПОМЕСТИТЬ НастройкиПользователей
	|ИЗ
	|	РегистрСведений.бит_НастройкиПользователей КАК НастройкиПользователей
	|ГДЕ
	|	НастройкиПользователей.Настройка В (&НастройкаОповещения, &НастройкаОсновнаяГруппа)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеПользователи.Ссылка КАК Пользователь,
	|	ЕСТЬNULL(НастройкиОсновнаяГруппа.ЗначениеНастройки, ЗНАЧЕНИЕ(Справочник.ГруппыПользователей.ВсеПользователи)) КАК ОсновнаяГруппа
	|ПОМЕСТИТЬ ВсеПользователи
	|ИЗ
	|	Справочник.Пользователи КАК ВсеПользователи
	|		ЛЕВОЕ СОЕДИНЕНИЕ НастройкиПользователей КАК НастройкиОсновнаяГруппа
	|		ПО ВсеПользователи.Ссылка = НастройкиОсновнаяГруппа.Пользователь
	|			И (НастройкиОсновнаяГруппа.Настройка = &НастройкаОсновнаяГруппа)
	|ГДЕ
	|	НЕ ВсеПользователи.ПометкаУдаления
	|	И НЕ ВсеПользователи.Недействителен	
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеПользователи.Пользователь КАК Пользователь
	|ИЗ
	|	ВсеПользователи КАК ВсеПользователи
	|		ЛЕВОЕ СОЕДИНЕНИЕ НастройкиПользователей КАК НастройкиОповещенияПользователя
	|		ПО ВсеПользователи.Пользователь = НастройкиОповещенияПользователя.Пользователь
	|			И (НастройкиОповещенияПользователя.Настройка = &НастройкаОповещения)
	|		ЛЕВОЕ СОЕДИНЕНИЕ НастройкиПользователей КАК НастройкиОповещенияГруппы
	|		ПО ВсеПользователи.ОсновнаяГруппа = НастройкиОповещенияГруппы.Пользователь
	|			И (НастройкиОповещенияГруппы.Настройка = &НастройкаОповещения)
	|ГДЕ
	|	ЕСТЬNULL(НастройкиОповещенияПользователя.ЗначениеНастройки, НастройкиОповещенияГруппы.ЗначениеНастройки) = ИСТИНА";
	Запрос.УстановитьПараметр("НастройкаОповещения", НастройкаОповещения);
	Запрос.УстановитьПараметр("НастройкаОсновнаяГруппа", НастройкаОсновнаяГруппа);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Получатели;
	КонецЕсли;
	
	МассивПользователей = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Пользователь");	
	Получатели.ЗагрузитьЗначения(МассивПользователей);
	
	Возврат Получатели;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура НачатьСозданиеОбсуждения(Параметры)
	
	Если НЕ ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.Обсуждения") Тогда
		Возврат;	
	КонецЕсли; 
	
	Если НЕ Обсуждения.СистемаВзаимодействийПодключена() Тогда
		Возврат;
	КонецЕсли; 
	
	// ++ ЕРП
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	&Период КАК Период,
	|	&СтатусРегистрации КАК СтатусРегистрации,
	|	&ВидСобытия КАК ВидСобытия,
	|	&Оповещение КАК Оповещение,
	|	&Объект КАК Объект,
	|	&ИД КАК ИД,
	|	&Статус КАК Статус,
	|	&Виза КАК Виза,
	|	&Решение КАК Решение,
	|	&Пользователь КАК Пользователь,
	|	&Комментарий КАК Комментарий
	|ПОМЕСТИТЬ Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Таблица.Период КАК Период,
	|	Таблица.СтатусРегистрации КАК СтатусРегистрации,
	|	Таблица.ВидСобытия КАК ВидСобытия,
	|	Таблица.Оповещение КАК Оповещение,
	|	Таблица.Объект КАК Объект,
	|	Таблица.ИД КАК ИД,
	|	Таблица.Статус КАК Статус,
	|	Таблица.Виза КАК Виза,
	|	Таблица.Решение КАК Решение,
	|	Таблица.Пользователь КАК Пользователь,
	|	Таблица.Комментарий КАК Комментарий,
	|	СУММА(ЕСТЬNULL(ПлатежнаяПозиция.СуммаДокумента, 0)) КАК СуммаЗаявки
	|ИЗ
	|	Таблица КАК Таблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПозиция
	|		ПО Таблица.Объект = ПлатежнаяПозиция.ДокументПланирования
	|
	|СГРУППИРОВАТЬ ПО
	|	Таблица.Период,
	|	Таблица.Решение,
	|	Таблица.Объект,
	|	Таблица.СтатусРегистрации,
	|	Таблица.Статус,
	|	Таблица.Оповещение,
	|	Таблица.Виза,
	|	Таблица.ВидСобытия,
	|	Таблица.Пользователь,
	|	Таблица.Комментарий,
	|	Таблица.ИД
	|ИТОГИ ПО
	|	ВидСобытия,
	|	Оповещение,
	|	Пользователь";
	// -- ЕРП
	
	Запрос.УстановитьПараметр("Период",			  Параметры.Период);
	Запрос.УстановитьПараметр("СтатусРегистрации",Параметры.СтатусРегистрации);
	Запрос.УстановитьПараметр("ВидСобытия",		  Параметры.ВидСобытия);
	Запрос.УстановитьПараметр("Оповещение",		  Параметры.Оповещение);
	Запрос.УстановитьПараметр("Объект",			  Параметры.Объект);
	Запрос.УстановитьПараметр("ИД",				  Параметры.ИД);
	Запрос.УстановитьПараметр("Статус",			  Параметры.Статус);
	Запрос.УстановитьПараметр("Виза",			  Параметры.Виза);
	Запрос.УстановитьПараметр("Решение",		  Параметры.Решение);
	Запрос.УстановитьПараметр("Пользователь",	  Параметры.Пользователь);
	Запрос.УстановитьПараметр("Комментарий",	  Параметры.Комментарий);
	
	Результат = Запрос.Выполнить();
	
	ПараметрыОбработки = Обработки.бит_фн_ОбработкаЗаписейРегистрацииОповещений.НовыеПараметрыОбработкиСобытийОповещений();
	ПараметрыОбработки.ЗаписыватьОповещения = Ложь;
	ПараметрыОбработки.Результат            = Результат;
	ПараметрыОбработки.СоздаватьОбсуждения  = Истина;
	Обработки.бит_фн_ОбработкаЗаписейРегистрацииОповещений.ОбработатьСобытияОповещений(ПараметрыОбработки);
	
КонецПроцедуры

Функция ПодготовитьПараметрыСообщения(ПараметрыОповещения)

	Ключи = ""
		  + "Заголовок,"
		  + "Текст,"
		  + "Данные,"
		  + "Ссылки";
	
	ПараметрыСообщения = Новый Структура(Ключи); 	
	
	Ссылки 			  = Новый СписокЗначений(); 
	ТекущийОбъект 	  = Неопределено;
	Оповещение 		  = Неопределено;
	ВыборкаДокументов = Неопределено;
	Если ТипЗнч(ПараметрыОповещения.ДополнительныеСвойства) = Тип("Структура") Тогда 
		ПараметрыОповещения.ДополнительныеСвойства.Свойство("ТекущийОбъект"	   , ТекущийОбъект);
		ПараметрыОповещения.ДополнительныеСвойства.Свойство("Оповещение"	   , Оповещение);
		ПараметрыОповещения.ДополнительныеСвойства.Свойство("ВыборкаДокументов", ВыборкаДокументов);
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ПараметрыОповещения.Сообщение_Заголовок) Тогда
		Заголовок = ПараметрыОповещения.Сообщение_Заголовок;
	ИначеЕсли ЗначениеЗаполнено(Оповещение) Тогда
		Заголовок = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Оповещение, "ВидСобытия");
	Иначе	
		Заголовок = НСтр("ru='Новое обсуждение %1';en='New discussion %1'");
		Заголовок = СтрШаблон(Заголовок, ТекущаяДатаСеанса());
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ПараметрыОповещения.Сообщение_Текст) Тогда
		Текст = ПараметрыОповещения.Сообщение_Текст;
		Если СтрСравнить(ПараметрыОповещения.ТипТекстаСообщения, "HTML") = 0 Тогда
			Текст = Заголовок;
		КонецЕсли;
	Иначе	
		Текст = Заголовок;
	КонецЕсли;
	
	ДобавитьСсылкиДляСообщений(ТекущийОбъект, Ссылки);
	Если ТипЗнч(ВыборкаДокументов) = Тип("ВыборкаИзРезультатаЗапроса") Тогда
		ВыборкаДокументов.Сбросить();
		Пока ВыборкаДокументов.Следующий() Цикл
			ДобавитьСсылкиДляСообщений(ВыборкаДокументов.Объект, Ссылки);
		КонецЦикла;
	КонецЕсли; 
	
	ПараметрыСообщения.Заголовок = Заголовок;
	ПараметрыСообщения.Текст 	 = Текст;
	ПараметрыСообщения.Данные 	 = "ОткрытьНавигационнуюСсылку";
	ПараметрыСообщения.Ссылки 	 = Ссылки;
	
	Возврат ПараметрыСообщения;
	
КонецФункции

Процедура ДобавитьСсылкиДляСообщений(Ссылка, Ссылки)
	
	Если ЗначениеЗаполнено(Ссылка) И ОбщегоНазначения.ЭтоСсылка(ТипЗнч(Ссылка)) Тогда
		Ссылки.Добавить(Ссылка, Строка(Ссылка));
	КонецЕсли; 
	
КонецПроцедуры

// Функция определяет параметры, используемые в данном шаблоне.
// 
// Параметры:
//  ШаблонСообщения    - СправочникСсылка.бит_фн_ШаблоныСообщений.
//  ПараметрыТекста    - Соответствие.
// 
// Возвращаемое значение:
//  Соответствие.
// 
Процедура ОпределитьПараметрыТекста(ШаблонТекста, ПараметрыТекста = Неопределено)
	
	Если ПараметрыТекста = Неопределено Тогда		
		ПараметрыТекста = Новый Соответствие;		
	КонецЕсли; 
	
	СтрОткрытие = "/[";
	СтрЗакрытие = "/]";
	
	Стр = ШаблонТекста;	
	ЧислоШаблонов = СтрЧислоВхождений(Стр, СтрОткрытие);
	Для Сч = 1 По ЧислоШаблонов Цикл
		
		НомерСимволаОткрытие = Найти(Стр, СтрОткрытие);
		Если НомерСимволаОткрытие > 0 Тогда
			
			Стр = Сред(Стр, НомерСимволаОткрытие+2);
			НомерСимволаЗакрытие = Найти(Стр, СтрЗакрытие);
			Если НомерСимволаЗакрытие > 0 Тогда
				
				ИмяПараметра = СокрЛП(Лев(Стр, НомерСимволаЗакрытие-1));							
				Если ПараметрыТекста[ИмяПараметра] = Неопределено Тогда
					ПараметрыТекста.Вставить(ИмяПараметра);
				КонецЕсли; 
				Стр = Сред(Стр, НомерСимволаЗакрытие+2);
				
			КонецЕсли; // Нашли закрытие.
			
		КонецЕсли; // Нашли открытие.
		
	КонецЦикла; // По количеству параметров в тексте.
	
КонецПроцедуры // ОпределитьПараметрыТекста()

// Процедура выполняет регистрацию событий для оповещений.
// 
// Параметры:
//  Источник    - СправочникСсылка, ДокументСсылка.
//  Отказ       - Булево.
//  РежимЗаписи - РежимЗаписиДокумента.
// 
Процедура ВыполнитьРегистрациюСобытий(Источник, Отказ, РежимЗаписи = Неопределено)

	Если Отказ ИЛИ НЕ ПолучитьФункциональнуюОпцию("бит_ИспользоватьМеханизмОповещений") Тогда
		Возврат;
	КонецЕсли; 
	
	// Определим объект системы по метаданным.
	ОбъектСистемы = бит_ПраваДоступа.ПолучитьОбъектДоступаПоМетаданным(Источник.Метаданные());
	// Определим вид события в зависимости от режима записи.
	ВидСобытия = Новый Массив;
	Если РежимЗаписи = РежимЗаписиДокумента.Запись Тогда
		ВидСобытия.Добавить(Перечисления.бит_фн_ВидыСобытийОповещений.ЗаписанДокумент);
	ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		ВидСобытия.Добавить(Перечисления.бит_фн_ВидыСобытийОповещений.ПроведенДокумент);
	ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		ВидСобытия.Добавить(Перечисления.бит_фн_ВидыСобытийОповещений.ОтмененоПроведениеДокумента);
	ИначеЕсли РежимЗаписи = Неопределено Тогда	
		ВидСобытия.Добавить(Перечисления.бит_фн_ВидыСобытийОповещений.ЗаписанСправочник);
	КонецЕсли; 
	
	ИзмененаДатаПлатежа = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Источник.ДополнительныеСвойства,
	"ИзмененаДатаПлатежа", Ложь);
	Если ИзмененаДатаПлатежа Тогда
		ВидСобытия.Добавить(Перечисления.бит_фн_ВидыСобытийОповещений.ИзмененаДатаПлатежа);
	КонецЕсли;
	
	Если НЕ бит_ОповещенияПовтИсп.ЕстьНастройкаОповещения(ОбъектСистемы) Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаОповещений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_фн_АктивныеОповещения");
	// Обработаем события.
	Если ТаблицаОповещений <> Неопределено И НЕ Источник.ДополнительныеСвойства.Свойство("бит_ОтключитьРегистрациюОповещений") Тогда
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ТаблицаОповещений"  , ТаблицаОповещений);
		Запрос.УстановитьПараметр("ОбъектСистемы"	   , ОбъектСистемы);
		Запрос.УстановитьПараметр("ВидСобытия"		   , ВидСобытия);
		Запрос.УстановитьПараметр("Объект"			   , Источник.Ссылка);
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаОповещений.Оповещение КАК Оповещение,
		|	ТаблицаОповещений.ПользовательскоеУсловие КАК ПользовательскоеУсловие,
		|	ТаблицаОповещений.ВидСобытия КАК ВидСобытия,
		|	ТаблицаОповещений.ОбъектСистемы КАК ОбъектСистемы
		|ПОМЕСТИТЬ ТаблицаОповещений
		|ИЗ
		|	&ТаблицаОповещений КАК ТаблицаОповещений
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаОповещений.Оповещение КАК Оповещение,
		|	ТаблицаОповещений.ПользовательскоеУсловие КАК ПользовательскоеУсловие,
		|	ТаблицаОповещений.ВидСобытия КАК ВидСобытия,
		|	Оповещения.НеРегистрироватьПовторно КАК НеРегистрироватьПовторно
		|ПОМЕСТИТЬ ОповещенияПоОбъекту
		|ИЗ
		|	ТаблицаОповещений КАК ТаблицаОповещений
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_фн_Оповещения КАК Оповещения
		|		ПО ТаблицаОповещений.Оповещение = Оповещения.Ссылка
		|ГДЕ
		|	ТаблицаОповещений.ВидСобытия В(&ВидСобытия)
		|	И ТаблицаОповещений.ОбъектСистемы = &ОбъектСистемы
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Оповещение,
		|	ВидСобытия
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОповещенияПоОбъекту.Оповещение КАК Оповещение,
		|	ОповещенияПоОбъекту.ВидСобытия КАК ВидСобытия,
		|	ОповещенияПоОбъекту.ПользовательскоеУсловие КАК ПользовательскоеУсловие
		|ИЗ
		|	ОповещенияПоОбъекту КАК ОповещенияПоОбъекту
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_фн_РегистрацияСобытийОповещений КАК РегистрацияОповещений
		|		ПО ОповещенияПоОбъекту.Оповещение = РегистрацияОповещений.Оповещение
		|			И ОповещенияПоОбъекту.ВидСобытия = РегистрацияОповещений.ВидСобытия
		|			И (ОповещенияПоОбъекту.НеРегистрироватьПовторно)
		|			И (РегистрацияОповещений.Объект = &Объект)
		|ГДЕ
		|	РегистрацияОповещений.Оповещение ЕСТЬ NULL";
		
		РезультатЗапроса = Запрос.Выполнить();		
		Выборка = РезультатЗапроса.Выбрать();		
		Пока Выборка.Следующий() Цикл			
			
			Если ЗначениеЗаполнено(Выборка.ПользовательскоеУсловие) Тогда
				СтруктураКонтекст = Новый Структура("ТекущийОбъект, Статус", Источник, Справочники.бит_СтатусыОбъектов.ПустаяСсылка());
				УсловиеВыполнено = бит_УправлениеПроцессами.ПроверитьПользовательскоеУсловие(Выборка.ПользовательскоеУсловие, СтруктураКонтекст);
			Иначе
				УсловиеВыполнено = Истина;
			КонецЕсли; 
			
			Если УсловиеВыполнено Тогда
				ПараметрыСобытия			= НовыеПараметрыСобытия(); 
				ПараметрыСобытия.ВидСобытия	= Выборка.ВидСобытия;
				ПараметрыСобытия.Оповещение	= Выборка.Оповещение;
				ПараметрыСобытия.Объект		= Источник.Ссылка;
				ЗарегистрироватьСобытиеДляОповещений(ПараметрыСобытия);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли; // Есть оповещения, нужно выполнять регистрацию.

КонецПроцедуры

Процедура ВыполнитьРегистрациюСобытийПоГрафикуПлатежейНачислений(Оповещение, График)
	
	Если ВРег(График) = ВРег("ГрафикПлатежей") Тогда
		ТекстЗапроса = ТекстЗапросаПоГрафикуПлатежей();
	Иначе
		ТекстЗапроса = ТекстЗапросаПоГрафикуНачислений();
	КонецЕсли;
	
	СхемаКомпоновкиДанных = бит_МеханизмПолученияДанных.СоздатьСхемуКомпоновкиПоЗапросу(ТекстЗапроса);
	АдресКомпоновки = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных);
	Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
	
    ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресКомпоновки);
    Попытка
		Компоновщик.Инициализировать(ИсточникНастроек);
    Исключение
		ТекстСообщения = НСтр("ru='Не удалось инициализировать компоновщик для отбора. Попробуйте обновить текст запроса. Описание ошибки: %1.';
							  |en='Failed to initialize builder for selection. Try refreshing the query text. Description of error: %1.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;
	
    Компоновщик.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);
    
    // Выполняем компановку макета МакетСКД
    // (настройки берутся из схемы компановки данных и из пользовательских настроек).
    Настройки = бит_ОповещенияСервер.ПолучитьНастройкиКомпоновщика(Оповещение.НастройкиКомпоновщика);
    бит_МеханизмПолученияДанных.КопироватьКоллекциюЭлементовОтбора(Настройки.НастройкиКомпоновщика.Отбор.Элементы, Компоновщик.Настройки.Отбор.Элементы);

	// Выполняем компановку макета МакетСКД
	// (настройки берутся из схемы компановки данных и из пользовательских настроек).
	КомпоновщикМакетаКомпоновкиДанных = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетСКД = КомпоновщикМакетаКомпоновкиДанных.Выполнить(СхемаКомпоновкиДанных, Компоновщик.ПолучитьНастройки());
	
	// Получаем запрос макета компановки данных
	Запрос = Новый Запрос(МакетСКД.НаборыДанных.НаборДанныхОсновной.Запрос);
		
	// Устанавливаем параметры запроса
	ОписаниеПараметровЗапроса = Запрос.НайтиПараметры();
	Для каждого ОписаниеПараметраЗапроса Из ОписаниеПараметровЗапроса Цикл
		
		Если ВРег(ОписаниеПараметраЗапроса.Имя) = ВРег("ДнейДляПроверки") ИЛИ ВРег(ОписаниеПараметраЗапроса.Имя) = ВРег("ТекущаяДата") Тогда
			Продолжить;
		Иначе
			Запрос.УстановитьПараметр(ОписаниеПараметраЗапроса.Имя, МакетСКД.ЗначенияПараметров[ОписаниеПараметраЗапроса.Имя].Значение);
		КонецЕсли;
		
	КонецЦикла;

	Запрос.УстановитьПараметр("ДнейДляПроверки", Оповещение.КоличествоДнейДляПроверки);
	Запрос.УстановитьПараметр("ТекущаяДата",     ТекущаяДатаСеанса());

	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка= РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
	    ПараметрыСобытия				= НовыеПараметрыСобытия();
		ПараметрыСобытия.ВидСобытия		= Оповещение.ВидСобытия;
		ПараметрыСобытия.Оповещение		= Оповещение;
		ПараметрыСобытия.Объект			= Выборка.Ссылка;
		ПараметрыСобытия.Пользователь	= Справочники.Пользователи.ПустаяСсылка();
		ПараметрыСобытия.Виза			= Справочники.бит_Визы.ПустаяСсылка();
		ПараметрыСобытия.Статус			= Справочники.бит_СтатусыОбъектов.ПустаяСсылка();
		ЗарегистрироватьСобытиеДляОповещений(ПараметрыСобытия);
	КонецЦикла;
	
КонецПроцедуры

Процедура ВыполнитьРегистрациюСобытийПриОкончанииСрокаДействияДоговора(Оповещение)
	
	// ++ ЕРП.
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДоговорыКонтрагентов.Ссылка КАК ОбъектРегистрации,
	|	ДоговорыКонтрагентов.Менеджер КАК Ответственный
	|ПОМЕСТИТЬ ДанныеПоДоговорам
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	ДоговорыКонтрагентов.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыДоговоровКонтрагентов.Закрыт)
	|	И ДоговорыКонтрагентов.ДатаОкончанияДействия <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ДоговорыКонтрагентов.ДатаОкончанияДействия < &КрайняяДата
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДоговорыКредитовИДепозитов.Ссылка,
	|	ДоговорыКредитовИДепозитов.Ответственный
	|ИЗ
	|	Справочник.ДоговорыКредитовИДепозитов КАК ДоговорыКредитовИДепозитов
	|ГДЕ
	|	ДоговорыКредитовИДепозитов.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыДоговоровКонтрагентов.Закрыт)
	|	И ДоговорыКредитовИДепозитов.ДатаПоследнегоПлатежа <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ДоговорыКредитовИДепозитов.ДатаПоследнегоПлатежа < &КрайняяДата
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДоговорыАренды.Ссылка,
	|	ДоговорыАренды.Ответственный
	|ИЗ
	|	Справочник.ДоговорыАренды КАК ДоговорыАренды
	|ГДЕ
	|	ДоговорыАренды.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыДоговоровКонтрагентов.Закрыт)
	|	И ДоговорыАренды.ДатаОкончанияДействия <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ДоговорыАренды.ДатаОкончанияДействия < &КрайняяДата
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДоговорыМеждуОрганизациями.Ссылка,
	|	ДоговорыМеждуОрганизациями.Менеджер
	|ИЗ
	|	Справочник.ДоговорыМеждуОрганизациями КАК ДоговорыМеждуОрганизациями
	|ГДЕ
	|	ДоговорыМеждуОрганизациями.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыДоговоровКонтрагентов.Закрыт)
	|	И ДоговорыМеждуОрганизациями.ДатаОкончанияДействия <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ДоговорыМеждуОрганизациями.ДатаОкончанияДействия < &КрайняяДата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Оповещения.Ссылка КАК Оповещение
	|ПОМЕСТИТЬ ВТОповещения
	|ИЗ
	|	Справочник.бит_фн_Оповещения КАК Оповещения
	|ГДЕ
	|	Оповещения.НеРегистрироватьПовторно
	|	И Оповещения.ВидСобытия = ЗНАЧЕНИЕ(Перечисление.бит_фн_ВидыСобытийОповещений.ОкончаниеСрокаДействияДоговора)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	РегистрацияСобытийОповещений.Объект КАК Объект
	|ПОМЕСТИТЬ НеРегистрироватьПовторно
	|ИЗ
	|	РегистрСведений.бит_фн_РегистрацияСобытийОповещений КАК РегистрацияСобытийОповещений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОповещения КАК ВТОповещения
	|		ПО РегистрацияСобытийОповещений.Оповещение = ВТОповещения.Оповещение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеПоДоговорам КАК ДанныеПоДоговорам
	|		ПО РегистрацияСобытийОповещений.Объект = ДанныеПоДоговорам.ОбъектРегистрации
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Объект
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеПоДоговорам.ОбъектРегистрации КАК ОбъектРегистрации,
	|	ДанныеПоДоговорам.Ответственный КАК Ответственный
	|ИЗ
	|	ДанныеПоДоговорам КАК ДанныеПоДоговорам
	|		ЛЕВОЕ СОЕДИНЕНИЕ НеРегистрироватьПовторно КАК НеРегистрироватьПовторно
	|		ПО ДанныеПоДоговорам.ОбъектРегистрации = НеРегистрироватьПовторно.Объект
	|ГДЕ
	|	НеРегистрироватьПовторно.Объект ЕСТЬ NULL";
	
	СхемаКомпоновкиДанных = бит_МеханизмПолученияДанных.СоздатьСхемуКомпоновкиПоЗапросу(ТекстЗапроса);
	АдресКомпоновки = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных);
	Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
	
    ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресКомпоновки);
    Попытка
		Компоновщик.Инициализировать(ИсточникНастроек);
    Исключение
		ТекстСообщения = НСтр("ru='Не удалось инициализировать компоновщик для отбора. Попробуйте обновить текст запроса. Описание ошибки: %1.';
							  |en='Failed to initialize builder for selection. Try refreshing the query text. Description of error: %1.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;
	
    Компоновщик.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);
    
    // Выполняем компановку макета МакетСКД.
    // (настройки берутся из схемы компановки данных и из пользовательских настроек).
    Настройки = бит_ОповещенияСервер.ПолучитьНастройкиКомпоновщика(Оповещение.НастройкиКомпоновщика);
    
    бит_МеханизмПолученияДанных.КопироватьКоллекциюЭлементовОтбора(Настройки.НастройкиКомпоновщика.Отбор.Элементы, Компоновщик.Настройки.Отбор.Элементы);

	// Выполняем компановку макета МакетСКД.
	// (настройки берутся из схемы компановки данных и из пользовательских настроек).
	КомпоновщикМакетаКомпоновкиДанных = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетСКД = КомпоновщикМакетаКомпоновкиДанных.Выполнить(СхемаКомпоновкиДанных, Компоновщик.ПолучитьНастройки());
	
	// Получаем запрос макета компановки данных.
	Запрос = Новый Запрос(МакетСКД.НаборыДанных.НаборДанныхОсновной.Запрос);
	
	// Устанавливаем параметры запроса.
	ОписаниеПараметровЗапроса = Запрос.НайтиПараметры();
	Для каждого ОписаниеПараметраЗапроса Из ОписаниеПараметровЗапроса Цикл
		Если ВРег(ОписаниеПараметраЗапроса.Имя) = ВРег("КрайняяДата") Тогда
			Продолжить;
		Иначе
			Запрос.УстановитьПараметр(ОписаниеПараметраЗапроса.Имя, МакетСКД.ЗначенияПараметров[ОписаниеПараметраЗапроса.Имя].Значение);
		КонецЕсли;
	КонецЦикла;
	КрайняяДата = ТекущаяДатаСеанса() + Оповещение.КоличествоДнейДляПроверки * 3600 * 24;
    Запрос.УстановитьПараметр("КрайняяДата", КрайняяДата);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл
		ПараметрыСобытия				= НовыеПараметрыСобытия();
		ПараметрыСобытия.ВидСобытия		= Оповещение.ВидСобытия;
		ПараметрыСобытия.Оповещение		= Оповещение;
		ПараметрыСобытия.Объект			= Выборка.ОбъектРегистрации;
		ПараметрыСобытия.Пользователь	= Выборка.Ответственный;
		ПараметрыСобытия.Виза			= Справочники.бит_Визы.ПустаяСсылка();
		ПараметрыСобытия.Статус			= Справочники.бит_СтатусыОбъектов.ПустаяСсылка();
		ЗарегистрироватьСобытиеДляОповещений(ПараметрыСобытия);
	КонецЦикла;
	// -- ЕРП.
	
КонецПроцедуры

Процедура ВыполнитьРегистрациюСобытийНапоминанийОбОплате(Оповещение)
	
	// ++ ЕРП.
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПлатежныеПозиции.Ссылка КАК Ссылка,
	|	ПлатежныеПозиции.ДатаПлан КАК ДатаПлан,
	|	ПлатежныеПозиции.ДатаПланКрайняя КАК ДатаПланКрайняя
	|ПОМЕСТИТЬ ВТВсеПлатежныеПозиции
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|ГДЕ
	|	ПлатежныеПозиции.Проведен
	|	И ПлатежныеПозиции.ДатаПлан >= &ТекущаяДата
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПлатежныеПозиции.Ссылка,
	|	ПлатежныеПозиции.ДатаПлан,
	|	ПлатежныеПозиции.ДатаПланКрайняя
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|ГДЕ
	|	ПлатежныеПозиции.Проведен
	|	И ПлатежныеПозиции.ДатаПланКрайняя >= &ТекущаяДата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТВсеПлатежныеПозиции.Ссылка КАК Ссылка,
	|	ВТВсеПлатежныеПозиции.ДатаПлан КАК ДатаПлан,
	|	ВТВсеПлатежныеПозиции.ДатаПланКрайняя КАК ДатаПланКрайняя
	|ПОМЕСТИТЬ ВТПлатежныеПозицииРеквизиты
	|ИЗ
	|	ВТВсеПлатежныеПозиции КАК ВТВсеПлатежныеПозиции
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПлатежныеПозиции.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ПлатежныеПозиции.ДатаПлан = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ПлатежныеПозиции.ДатаПланКрайняя
	|		ИНАЧЕ ПлатежныеПозиции.ДатаПлан
	|	КОНЕЦ КАК ДатаПлатежа
	|ПОМЕСТИТЬ ВТПлатежныеПозиции
	|ИЗ
	|	ВТПлатежныеПозицииРеквизиты КАК ПлатежныеПозиции
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТПлатежныеПозиции.Ссылка КАК Ссылка,
	|	РАЗНОСТЬДАТ(&ТекущаяДата, ВТПлатежныеПозиции.ДатаПлатежа, ДЕНЬ) КАК ДнейДоОплаты
	|ПОМЕСТИТЬ ВТОстатокДней
	|ИЗ
	|	ВТПлатежныеПозиции КАК ВТПлатежныеПозиции
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТОстатокДней.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТПлатежныеПозицииИтог
	|ИЗ
	|	ВТОстатокДней КАК ВТОстатокДней
	|ГДЕ
	|	ВТОстатокДней.ДнейДоОплаты <= &ДнейДляПроверки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	РегистрацияСобытийОповещений.Объект КАК Объект
	|ПОМЕСТИТЬ НеРегистрироватьПовторно
	|ИЗ
	|	РегистрСведений.бит_фн_РегистрацияСобытийОповещений КАК РегистрацияСобытийОповещений
	|ГДЕ
	|	РегистрацияСобытийОповещений.Оповещение.НеРегистрироватьПовторно
	|	И РегистрацияСобытийОповещений.Оповещение.ВидСобытия = ЗНАЧЕНИЕ(Перечисление.бит_фн_ВидыСобытийОповещений.НапоминанияОбОплате)
	|	И РегистрацияСобытийОповещений.Объект В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				ВТПлатежныеПозицииИтог.Ссылка КАК ОбъектРегистрации
	|			ИЗ
	|				ВТПлатежныеПозицииИтог КАК ВТПлатежныеПозицииИтог)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТПлатежныеПозицииИтог.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(СтатусыОбъектов.Статус, ЗНАЧЕНИЕ(Справочник.бит_СтатусыОбъектов.ПустаяСсылка)) КАК Статус,
	|	ЕСТЬNULL(СостоянияОплаты.Статус, ЗНАЧЕНИЕ(Справочник.бит_СтатусыОбъектов.ПустаяСсылка)) КАК Оплата
	|ИЗ
	|	ВТПлатежныеПозицииИтог КАК ВТПлатежныеПозицииИтог
	|		ЛЕВОЕ СОЕДИНЕНИЕ НеРегистрироватьПовторно КАК НеРегистрироватьПовторно
	|		ПО ВТПлатежныеПозицииИтог.Ссылка = НеРегистрироватьПовторно.Объект
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_СтатусыОбъектов КАК СтатусыОбъектов
	|		ПО ВТПлатежныеПозицииИтог.Ссылка = СтатусыОбъектов.Объект
	|			И (СтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_СтатусыОбъектов КАК СостоянияОплаты
	|		ПО ВТПлатежныеПозицииИтог.Ссылка = СостоянияОплаты.Объект
	|			И (СостоянияОплаты.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.СостояниеОплаты))
	|ГДЕ
	|	НеРегистрироватьПовторно.Объект ЕСТЬ NULL";
		
	СхемаКомпоновкиДанных = бит_МеханизмПолученияДанных.СоздатьСхемуКомпоновкиПоЗапросу(ТекстЗапроса);
	АдресКомпоновки = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных);
	Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
	
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресКомпоновки);
	Попытка
		Компоновщик.Инициализировать(ИсточникНастроек);
	Исключение
		ТекстСообщения = НСтр("ru='Не удалось инициализировать компоновщик для отбора. Попробуйте обновить текст запроса. Описание ошибки: %1.';
							  |en='Failed to initialize builder for selection. Try refreshing the query text. Description of error: %1.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;
	
	Компоновщик.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);
	
	// Выполняем компановку макета МакетСКД
	// (настройки берутся из схемы компановки данных и из пользовательских настроек).
	Настройки = бит_ОповещенияСервер.ПолучитьНастройкиКомпоновщика(Оповещение.НастройкиКомпоновщика);
	бит_МеханизмПолученияДанных.КопироватьКоллекциюЭлементовОтбора(Настройки.НастройкиКомпоновщика.Отбор.Элементы, Компоновщик.Настройки.Отбор.Элементы);

	// Выполняем компановку макета МакетСКД
	// (настройки берутся из схемы компановки данных и из пользовательских настроек).
	КомпоновщикМакетаКомпоновкиДанных = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетСКД = КомпоновщикМакетаКомпоновкиДанных.Выполнить(СхемаКомпоновкиДанных, Компоновщик.ПолучитьНастройки());
	
	// Получаем запрос макета компановки данных
	Запрос = Новый Запрос(МакетСКД.НаборыДанных.НаборДанныхОсновной.Запрос);
	
	// Устанавливаем параметры запроса
	ОписаниеПараметровЗапроса = Запрос.НайтиПараметры();
	Для каждого ОписаниеПараметраЗапроса Из ОписаниеПараметровЗапроса Цикл
		Если ВРег(ОписаниеПараметраЗапроса.Имя) = ВРег("ДнейДляПроверки") ИЛИ ВРег(ОписаниеПараметраЗапроса.Имя) = ВРег("ТекущаяДата") Тогда
			Продолжить;
		Иначе
			Запрос.УстановитьПараметр(ОписаниеПараметраЗапроса.Имя, МакетСКД.ЗначенияПараметров[ОписаниеПараметраЗапроса.Имя].Значение);
		КонецЕсли;
	КонецЦикла;
    ТекущаяДата = НачалоДня(ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ДнейДляПроверки", Оповещение.КоличествоДнейДляПроверки);
	Запрос.УстановитьПараметр("ТекущаяДата",     ТекущаяДата);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл
		    ПараметрыСобытия				= НовыеПараметрыСобытия();
			ПараметрыСобытия.ВидСобытия		= Оповещение.ВидСобытия;
			ПараметрыСобытия.Оповещение		= Оповещение;
			ПараметрыСобытия.Объект			= Выборка.Ссылка;
			ПараметрыСобытия.Пользователь	= Справочники.Пользователи.ПустаяСсылка();
			ПараметрыСобытия.Виза			= Справочники.бит_Визы.ПустаяСсылка();
			ПараметрыСобытия.Статус			= Выборка.Статус;
			ЗарегистрироватьСобытиеДляОповещений(ПараметрыСобытия);
	КонецЦикла;
	// -- ЕРП.
	
КонецПроцедуры

Функция ТекстЗапросаПоГрафикуПлатежей()

	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	бит_ДополнительныеУсловияПоДоговоруГрафикПлатежей.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ТабДок
	|ИЗ
	|	Документ.бит_ДополнительныеУсловияПоДоговору.ГрафикПлатежей КАК бит_ДополнительныеУсловияПоДоговоруГрафикПлатежей
	|ГДЕ
	|	бит_ДополнительныеУсловияПоДоговоруГрафикПлатежей.Ссылка.Проведен = ИСТИНА
	|	И бит_ДополнительныеУсловияПоДоговоруГрафикПлатежей.Период < ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, &ДнейДляПроверки)
	|	И (бит_ДополнительныеУсловияПоДоговоруГрафикПлатежей.ДокументПланирования = ЗНАЧЕНИЕ(Документ.бит_ЗаявкаНаРасходованиеСредств.ПустаяСсылка)
	|			ИЛИ бит_ДополнительныеУсловияПоДоговоруГрафикПлатежей.ДокументПланирования = ЗНАЧЕНИЕ(Документ.бит_ЗаявкаНаРасходованиеСредствОбщая.ПустаяСсылка)
