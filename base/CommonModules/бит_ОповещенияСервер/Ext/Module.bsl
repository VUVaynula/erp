// Функция определяет способ транспорта в зависимости от имени обработки.
//
// Параметры:
//   ИмяОбработки - Строка.
//
// Возвращаемое значение:
//  СпособТранспорта - ПеречислениеСсылка.бит_фн_СпособыТранспортаОповещений.
//
Функция ОпределитьСпособТранспортаПоИмениОбработки(ИмяОбработки) Экспорт

	Если ИмяОбработки = "бит_ДоставкаОповещенийPush" Тогда
		
		СпособТранспорта = ПредопределенноеЗначение("Перечисление.бит_фн_СпособыТранспортаОповещений.PushNotification");
		
	ИначеЕсли ИмяОбработки = "бит_ДоставкаОповещенийTelegram" Тогда	
		
		СпособТранспорта = ПредопределенноеЗначение("Перечисление.бит_фн_СпособыТранспортаОповещений.Telegram");

	ИначеЕсли ИмяОбработки = "бит_ДоставкаОповещенийЭлектроннойПочтой1С" Тогда	
		
		СпособТранспорта = ПредопределенноеЗначение("Перечисление.бит_фн_СпособыТранспортаОповещений.ЭлектроннаяПочта1С");
	
	ИначеЕсли ИмяОбработки = "бит_ДоставкаОповещенийСистемаВзаимодействия" Тогда	
		
		СпособТранспорта = ПредопределенноеЗначение("Перечисление.бит_фн_СпособыТранспортаОповещений.СистемаВзаимодействия");
		
	Иначе	
		
		СпособТранспорта = ПредопределенноеЗначение("Перечисление.бит_фн_СпособыТранспортаОповещений.ЭлектроннаяПочта");
		
	КонецЕсли; 

	Возврат СпособТранспорта;
	
КонецФункции

// Функция получает настройки компоновщика.
// 
// Возвращаемое значение:
//  Структура.
// 
Функция ПолучитьНастройкиКомпоновщика(НастройкиКомпоновщика) Экспорт
	
	СтруктураНастроек = НастройкиКомпоновщика.Получить();
	
	Если ТипЗнч(СтруктураНастроек) <> Тип("Структура") Тогда	
