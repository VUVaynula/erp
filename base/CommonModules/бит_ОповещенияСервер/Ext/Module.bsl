#КонецОбласти

#Область СистемаВзаимодействия

Процедура СоздатьОбсуждения(ОповещенияПолучателям) Экспорт

	# Если НЕ ВнешнееСоединение Тогда 
		
		Если НЕ ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.Обсуждения") Тогда
			Возврат;	
		КонецЕсли; 
		
		Если НЕ Обсуждения.СистемаВзаимодействийПодключена() Тогда
			Возврат;
		КонецЕсли; 
		
		УстановитьПривилегированныйРежим(Истина);
		
		Для каждого ПараметрыОповещения Из ОповещенияПолучателям Цикл
			// Конструктор см. в Обработки.бит_фн_ОбработкаЗаписейРегистрацииОповещений.НовыеПараметрыОповещения();
			Если ТипЗнч(ПараметрыОповещения.Пользователь) = Тип("СправочникСсылка.Пользователи") 
				И ПараметрыОповещения.СоздаватьОбсуждение Тогда
				
				// Параметры сообщения формируем до отправки в фоновое задание,
				// для чтения ссылки текущего объекта в транзакции и получения ее представления.
				// Вне транзакции ссылка битая или происходит гонка (транзакция/фоновое задание).
				ПараметрыСообщения = ПодготовитьПараметрыСообщения(ПараметрыОповещения);
				
				// Удаляем, далее не используется, может не сериализоваться.
				ПараметрыОповещения.Удалить("ДополнительныеСвойства");
				
				// Работа с внешним сервисом службы взаимодействия непредсказуема по времени, выделяем ее в отдельный поток.
				ПараметрыЗаполнения = Новый Массив;
				ПараметрыЗаполнения.Добавить(ПараметрыОповещения);
				ПараметрыЗаполнения.Добавить(ПараметрыСообщения);
				ИмяФоновогоЗадания = НСтр("ru = 'Отправка сообщений в системе взаимодействия.';
											|en = 'Sending messages in the interaction system.'"); 
				ФоновыеЗадания.Выполнить("бит_ОповещенияСервер.СоздатьОбсужденияВФоне", ПараметрыЗаполнения,, ИмяФоновогоЗадания);
				
			КонецЕсли; 
		КонецЦикла; 

	# КонецЕсли 

КонецПроцедуры

Процедура СоздатьОбсужденияВФоне(ПараметрыОповещения, ПараметрыСообщения) Экспорт
	
		УстановитьПривилегированныйРежим(Истина);
				
		ПользовательСВ = Обсуждения.ПользовательСистемыВзаимодействия(ПараметрыОповещения.Пользователь);
		ИдентификаторПользователяСВ = ПользовательСВ.Идентификатор;
		
		// Обсуждение.
		КлючОбсуждения = XMLСтрока(ПараметрыОповещения.Оповещение) + Строка(ИдентификаторПользователяСВ);
		Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(КлючОбсуждения);
		Если Обсуждение = Неопределено Тогда
			Обсуждение = СистемаВзаимодействия.СоздатьОбсуждение();
			Обсуждение.Ключ			= КлючОбсуждения;
			Обсуждение.Участники.Добавить(ИдентификаторПользователяСВ);
		ИначеЕсли НЕ Обсуждение.Участники.Содержит(ИдентификаторПользователяСВ) Тогда	
			Обсуждение.Участники.Добавить(ИдентификаторПользователяСВ);
		КонецЕсли;
		Если ЗначениеЗаполнено(ПараметрыОповещения.Оповещение) Тогда
			Обсуждение.Заголовок = Строка(ПараметрыОповещения.Оповещение);			
		Иначе	
			Обсуждение.Заголовок = ПараметрыСообщения.Заголовок;			
		КонецЕсли;  
		Обсуждение.Записать();
		
		// Сообщение.
		СообщениеСВ = СистемаВзаимодействия.СоздатьСообщение(Обсуждение.Идентификатор);
		Если ЗначениеЗаполнено(ПараметрыОповещения.Оповещение)
			И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыОповещения.Оповещение, "ВидСобытия") = Перечисления.бит_фн_ВидыСобытийОповещений.ДокументыДляВизирования Тогда
			
			// Это РМВ.
			Если СтрСравнить(ПараметрыОповещения.ТипТекстаСообщения, "HTML") = 0 Тогда
				Текст = "";
				Если ЗначениеЗаполнено(ПараметрыСообщения.Ссылки) Тогда
					СтрокиСообщения = Новый Массив();
					Для Каждого Элемент Из ПараметрыСообщения.Ссылки Цикл
						СтрокиСообщения.Добавить(Элемент.Представление);	
					КонецЦикла;
					Текст = СтрСоединить(СтрокиСообщения, Символы.ПС);
				КонецЕсли;
			Иначе
				Текст = ПараметрыСообщения.Текст;
			КонецЕсли;
			СообщениеСВ.Текст = Текст;
			СообщениеСВ.Данные = "ОткрытьНавигационнуюСсылку";
			Представление = НСтр("ru = 'Рабочее место визирования'; en = 'Approval Workplace'");
			СообщениеСВ.Действия.Добавить("e1cib/app/Обработка.бит_КонсольОперативногоВизирования", Представление);
		Иначе
			Если ЗначениеЗаполнено(ПараметрыСообщения.Ссылки) Тогда
				Для Каждого Элемент Из ПараметрыСообщения.Ссылки Цикл
					СообщениеСВ.Действия.Добавить(ПолучитьНавигационнуюСсылку(Элемент.Значение), Элемент.Представление);
				КонецЦикла;
			КонецЕсли;
			СообщениеСВ.Текст = ПараметрыСообщения.Текст;
			СообщениеСВ.Данные = "ОткрытьНавигационнуюСсылку";
		КонецЕсли;
		СообщениеСВ.Записать();
		
КонецПроцедуры
 
