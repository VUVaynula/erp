		КонецПопытки;
		
		Попытка
			СоответствиеЗаписей.Записать(); 
		Исключение
			ЗаписьЖурналаРегистрации(НСтр("ru='Механизм трансляции';en='Механизм трансляции'", ОбщегоНазначения.КодОсновногоЯзыка()), 
