Функция ЗначениеДопРеквизитаОсновнойАглоритм(Источник, ВидРеквизита, ИмяРеквизита)
	
	ЗначениеДопРеквизита = Неопределено;
	
	СвойстваИсточника = УправлениеСвойствами.СвойстваОбъекта(Источник);
	Запрос            = Новый Запрос;
	Запрос.Текст      =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДополнительныеРеквизитыИСведения.Ссылка КАК Свойство
	|ИЗ
	|	ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
	|ГДЕ
	|	ДополнительныеРеквизитыИСведения.Ссылка В(&СвойстваИсточника)
	|	И ДополнительныеРеквизитыИСведения.Наименование = &Наименование
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДополнительныеРеквизитыИСведения.ПометкаУдаления";
	Запрос.УстановитьПараметр("СвойстваИсточника", СвойстваИсточника);
	Запрос.УстановитьПараметр("Наименование",      ИмяРеквизита);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Свойство = Выборка.Свойство;
	Иначе
		Возврат ЗначениеДопРеквизита;
	КонецЕсли;
	
	ЗначениеДопРеквизита = УправлениеСвойствами.ЗначениеСвойства(Источник, Свойство);	
	Если ЗначениеДопРеквизита = Неопределено
		И ЗначениеЗаполнено(Свойство) Тогда
		ТипСвойства          = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Свойство, "ТипЗначения");
		ЗначениеДопРеквизита = ТипСвойства.ПривестиЗначение(ЗначениеДопРеквизита);
	КонецЕсли; 
	
	Возврат ЗначениеДопРеквизита;	
	
КонецФункции

Функция ЗначениеДопРеквизитаСУканазиемКодаСвойства(Источник, ИмяРеквизита)
	
	ИмяРеквизитаБезДопРеквизита = СтрЗаменить(ИмяРеквизита, "ДополнительныйРеквизит_", "");
	ИмяРеквизитаБезДопСвойства  = СтрЗаменить(ИмяРеквизитаБезДопРеквизита, "ДополнительноеСвойство_", "");
	
	ИмяСвойства = ИмяРеквизитаБезДопСвойства;
	СвойствоОбъекта = СвойствоОбъектаПоИмени(ИмяСвойства);
	Если СвойствоОбъекта = Неопределено Тогда
		СвойствоОбъекта = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию(ИмяСвойства);
	КонецЕсли; 
	
	Возврат УправлениеСвойствами.ЗначениеСвойства(Источник, СвойствоОбъекта);
	
КонецФункции

