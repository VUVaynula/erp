Функция ДанныеДействующейУчетнойПолитики(ИмяРегистра, Подразделение, Период = Неопределено)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", ?(Период = Неопределено, ТекущаяДатаСеанса(), Период));
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	*
	|ИЗ
	|	РегистрСведений.бит_НастройкиБюджетирования.СрезПоследних(&Период, СтруктурноеПодразделение = &Подразделение) КАК Таблица";
	
	Если ИмяРегистра <> "бит_НастройкиБюджетирования" Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "бит_НастройкиБюджетирования", ИмяРегистра);
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	
	Возврат Запрос.Выполнить();

КонецФункции
 
// Вычисляет структурное подразделение, по которому определяются настройки программы,
// если настройки для переданного подразделения не были найдены.
// Аналог "ПараметрыФункциональнойОпцииНастроекПрограммы", но для других целей.
//
// Параметры:
//  Подразделение	 - СправочникСсылка.Организации, СправочникСсылка.Подразделения	 
//					 - подразделение, шаблон, для которого надо вычислить.
// 
// Возвращаемое значение:
//  Шаблон - неопределено, СправочникСсылка.бит_ГруппыСтруктурныхПодразделений. 
//
Функция ПодразделениеАдминистративныйШаблон(Подразделение)

	Шаблон = Неопределено; // Нет групп, значит для всего предприятия.
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Состав.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.бит_ГруппыСтруктурныхПодразделений.Состав КАК Состав
	|ГДЕ
	|	Состав.СтруктурноеПодразделение = &Подразделение";
	
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	
	РезультатЗапроса 	   = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Шаблон = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;

	Возврат Шаблон;
	
КонецФункции

Функция ПараметрыФункциональнойОпцииНастроекПрограммы(СтруктурноеПодразделение)

	Если ТипЗнч(СтруктурноеПодразделение) = Тип("Структура") Тогда
		Подразделение = ОбщегоНазначения.СкопироватьРекурсивно(СтруктурноеПодразделение);
	Иначе	
		Если ТипЗнч(СтруктурноеПодразделение) = Тип("СправочникСсылка.Организации") Тогда
			Подразделение = Новый Структура("Организация", СтруктурноеПодразделение);
		ИначеЕсли ТипЗнч(СтруктурноеПодразделение) = Тип("СправочникСсылка.Подразделения") Тогда	
			Подразделение = Новый Структура("ЦФО", СтруктурноеПодразделение);
		Иначе
			Подразделение = Новый Структура;
		КонецЕсли;
	КонецЕсли;

	Организация = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Подразделение, "Организация", Неопределено);
	ЦФО 	    = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Подразделение, "ЦФО", 		   Неопределено);
	
	// Параметры выстраиваются по приоритету настроек. 
	// Самая важная настройка по ЦФО, самая неважная по предприятию.
	Параметры = Новый Массив;
	Если ЗначениеЗаполнено(ЦФО) Тогда
		Параметры.Добавить(ЦФО);
	КонецЕсли;
	Если ЗначениеЗаполнено(Организация) Тогда
		Параметры.Добавить(Организация);
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Состав.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.бит_ГруппыСтруктурныхПодразделений.Состав КАК Состав
	|ГДЕ
	|	Состав.СтруктурноеПодразделение В (&Организация, &ЦФО)";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ЦФО", 		 ЦФО);
	
	РезультатЗапроса 	   = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Параметры.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
	
	Параметры.Добавить(Неопределено);
	
	Возврат Параметры;
	
КонецФункции
 
// Функция применяется при необходимости получить сведения об учетной политике организации
// или настройках налога
//
// Параметры: нет
//
// Возвращаемое значение - дерево значений.
//  На первом уровне дерева - список организаций, для которых задана учетная политика
//  На втором уровне дерева - записи учетной политики по организации, каждая запись хранится в дереве как структура
//
Функция ЗаполнениеНастройкиУчетнойПолитики(ИмяНастройки)

	Запрос = Новый Запрос();

	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	*
	|ИЗ
	|	РегистрСведений.бит_НастройкиБюджетирования КАК УчетнаяПолитика";
	
	Если ИмяНастройки <> "бит_НастройкиБюджетирования" Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "бит_НастройкиБюджетирования", ИмяНастройки);
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	Результат = Запрос.Выполнить().Выгрузить();
	Результат.Сортировать("Период");

	ДеревоУчетнойПолитики = Новый ДеревоЗначений;
	ДеревоУчетнойПолитики.Колонки.Добавить("СтруктурноеПодразделение");
	ДеревоУчетнойПолитики.Колонки.Добавить("Период");
	ДеревоУчетнойПолитики.Колонки.Добавить("УчетнаяПолитика");

	Для каждого Строка Из Результат Цикл
		УчетнаяПолитикаПодразделения = ДеревоУчетнойПолитики.Строки.Найти(Строка.СтруктурноеПодразделение, "СтруктурноеПодразделение");
		Если УчетнаяПолитикаПодразделения = Неопределено Тогда
			УчетнаяПолитикаПодразделения = ДеревоУчетнойПолитики.Строки.Добавить();
			УчетнаяПолитикаПодразделения.СтруктурноеПодразделение = Строка.СтруктурноеПодразделение;
		КонецЕсли;
		ПоПериоду = УчетнаяПолитикаПодразделения.Строки.Добавить();
		ПоПериоду.Период = Строка.Период;

		СтруктураУчетнойПолитики = Новый Структура;
		Для Каждого Колонка Из Результат.Колонки Цикл
			СтруктураУчетнойПолитики.Вставить(Колонка.Имя, Строка[Колонка.Имя]);
		КонецЦикла;

		ПоПериоду.УчетнаяПолитика = СтруктураУчетнойПолитики;

	КонецЦикла;

	Возврат ДеревоУчетнойПолитики;

КонецФункции

// Возвращает элемент пользовательского отбора динамического списка, 
// соответствующий отбору, заданному в конфигураторе с указанным именем.
// Соответствие определяется по совпадению идентификаторов настройки.
//
// Параметры
//  Список - ДинамическийСписок - динамический список, для которого ищется элемент отбора.
//  ИмяОтбора - Строка - имя отбора, заданное в конфигураторе для элемента настроек динамического списка.
//
// Возвращаемое значение:
//	ЭлементОтбораКомпоновкиДанных - найденный элемент пользовательского отбора.
//  Неопределено - если элемент пользовательского отбора не найден.
//
Функция ЭлементОтбораСпискаПоИмени(Список, ИмяОтбора)

	Отборы = ОбщегоНазначенияКлиентСервер.НайтиЭлементыИГруппыОтбора(
		Список.КомпоновщикНастроек.Настройки.Отбор, 
		ИмяОтбора);
	
	Если Отборы.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе
		Возврат Отборы[0];
	КонецЕсли;
	
КонецФункции

Процедура ЗаписатьМенеджерЗаписиНастроекПрограммы(ИмяРегистра, ДанныеЗаполнения)
	
	МенеджерЗаписи = РегистрыСведений[ИмяРегистра].СоздатьМенеджерЗаписи();
	РегистрыСведений[ИмяРегистра].УстановкаНастроекПоУмолчанию(МенеджерЗаписи, ДанныеЗаполнения);
	МенеджерЗаписи.Записать(Истина);
	
КонецПроцедуры

