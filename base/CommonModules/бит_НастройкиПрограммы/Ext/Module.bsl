// Присваивает ресурсу регистра значение по умолчанию, в случае,
// если в данных заполнения заполнение реквизита не предусмотрено
// 
// Параметры:
//  Запись              - запись регистра сведений.
//  ДанныеЗаполнения    - Структура - содержит данные для заполнения ресурсов регистра,
//                      где имя ключа соответствует имени ресурса.
//  ИмяРесурса          - Строка - имя ресурса, оторому присваивается значение.
//  ЗначениеПоУмолчанию - Произвольный - значение по умолчанию, соответствующее типу ресурса.
//
Процедура УстановитьЗначениеПоУмолчанию(Запись, ДанныеЗаполнения, ИмяРесурса, ЗначениеПоУмолчанию) Экспорт
	
	Если Не ДанныеЗаполнения.Свойство(ИмяРесурса, Запись[ИмяРесурса]) Тогда
		Запись[ИмяРесурса] = ЗначениеПоУмолчанию;
	КонецЕсли;
	
КонецПроцедуры

// Возвращает ключ действующей настройки учетной политики на заданную дату.
//
// Параметры:
//  ИмяРегистра		 - Строка - имя регистра, для которого требуется получить значения.
//  Подразделение	 - Произвольный - структурное подразделение,
//                  				  для которого требуется получить настройки.
//  Период			 - Дата, Неопределено - период действия настройки.
// 
// Возвращаемое значение:
//  - РегистрСведенийКлючЗаписи 
//	- Неопределено
//
Функция КлючЗаписиДействующейУчетнойПолитики(ИмяРегистра, Подразделение, Период = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Подразделение) И НЕ Подразделение = Неопределено Тогда
		// Ошибочная ситуация. В "настройках" может быть не заполнено подразделение,
		// но оно должно быть "НЕОПРЕДЕЛЕНО".
		Возврат Неопределено;
	КонецЕсли;
	
	Данные  = ДанныеДействующейУчетнойПолитики(ИмяРегистра, Подразделение, Период);
	Выборка = Данные.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗначенияКлюча = Новый Структура;
		ЗначенияКлюча.Вставить("СтруктурноеПодразделение", Подразделение);
		ЗначенияКлюча.Вставить("Период", Выборка.Период);
		
		Возврат РегистрыСведений[ИмяРегистра].СоздатьКлючЗаписи(ЗначенияКлюча);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Возвращает значения действующей настройки учетной политики на заданную дату.
//
// Параметры:
//  ИмяРегистра		 - Строка - имя регистра, для которого требуется получить значения.
//  Подразделение	 - Произвольный	 - структурное подразделение, для которого требуется получить настройки.
//  Период			 - Дата, Неопределено - период действия настройки.
// 
// Возвращаемое значение:
//   - Неопределено
//	 - Произвольный
//
Функция ЗначенияДействующейУчетнойПолитики(ИмяРегистра, Подразделение, Период = Неопределено) Экспорт

	Если Не ЗначениеЗаполнено(Подразделение) И НЕ Подразделение = Неопределено Тогда
		// Ошибочная ситуация. В "настройках" может быть не заполнено подразделение,
		// но оно должно быть "НЕОПРЕДЕЛЕНО".
		Возврат Неопределено;
	КонецЕсли;
	
	Данные = ДанныеДействующейУчетнойПолитики(ИмяРегистра, Подразделение, Период);
	Если Данные.Пустой() Тогда
		Возврат Неопределено;
	Иначе	
		Выгрузка = Данные.Выгрузить();
		Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Выгрузка[0]);
	КонецЕсли;

КонецФункции

// Функция определяет дату окончания действия записи настройки учета.
//
// Параметры:
//  Период			 - Дата - дата чтения настроек. 
//  Подразделение	 - Произвольный	 - структурное подразделение, для которого требуется получить настройки.
//  ИмяРегистра		 - Строка - имя регистра, для которого требуется получить значения. 
// 
// Возвращаемое значение:
//   - Дата - дата окончания действия записи.
//
Функция НайтиДатуОкончанияДействия(Знач Период, Знач Подразделение, ИмяРегистра) Экспорт

	ДатаОкончания = Период;

	НастройкаПрограммыВсехПодразделений = ЗаполнениеНастройкиУчетнойПолитики(ИмяРегистра);
	
	НастройкаПрограммыПодразделения = НастройкаПрограммыВсехПодразделений.Строки.Найти(Подразделение, "СтруктурноеПодразделение");
	Если НастройкаПрограммыПодразделения <> Неопределено Тогда
		Для каждого СтрокаНастройки Из НастройкаПрограммыПодразделения.Строки Цикл
			Если СтрокаНастройки.Период = Период Тогда
				Продолжить;
			КонецЕсли;
			Если СтрокаНастройки.Период > ДатаОкончания Тогда
				ДатаОкончания = СтрокаНастройки.Период - 1;
				Возврат ДатаОкончания;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Если Период > ТекущаяДата Тогда
		Возврат КонецДня(Период);
	Иначе
		Если ДатаОкончания = Период Тогда
			Возврат КонецДня(ТекущаяДата);
		Иначе
			Возврат КонецДня(ДатаОкончания);
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

// Заполняет регистры настроек подсистем значениями по умолчанию для всего предприятия.
//
Процедура ЗаполнитьНастройкиПрограммыПоУмолчанию() Экспорт
		
	ДанныеЗаполнения = Новый Структура();
	ДанныеЗаполнения.Вставить("Период", Дата('19800101'));

	ЗаписатьМенеджерЗаписиНастроекПрограммы("бит_НастройкиБюджетирования",ДанныеЗаполнения);
	ЗаписатьМенеджерЗаписиНастроекПрограммы("бит_НастройкиВизирования",ДанныеЗаполнения);
	ЗаписатьМенеджерЗаписиНастроекПрограммы("бит_НастройкиДоговоровИЗатрат",ДанныеЗаполнения);
	ЗаписатьМенеджерЗаписиНастроекПрограммы("бит_НастройкиЗакупок",ДанныеЗаполнения);
	ЗаписатьМенеджерЗаписиНастроекПрограммы("бит_НастройкиКазначейства",ДанныеЗаполнения);
	ЗаписатьМенеджерЗаписиНастроекПрограммы("бит_НастройкиПрограммыОбщие",ДанныеЗаполнения);
	
КонецПроцедуры

