// Функция определяет знак числа.
// 
// Параметры:
//  Значение  - Число.
// 
// Возвращаемое значение:
//   Число.
// 
Функция ЗнакЧисла(Значение) Экспорт

	Если Значение > 0 Тогда
		Результат = 1;
	ИначеЕсли Значение < 0 Тогда
		Результат = -1;
	Иначе
