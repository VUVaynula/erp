// Обработчик подписки "бит_КонтрольВложений".
// Выполняет контроль вложения при проверке заполнения.
//
Процедура КонтрольВложенийОбработчик(Источник, Отказ) Экспорт
	
	СсылкиПроверкиВложений = Новый Массив;
	ОбъектыПроверкиСтатей  = Новый Массив;
	
	СсылкиПроверкиВложений.Добавить(Источник.Ссылка);
	ОбъектыПроверкиСтатей.Добавить(Источник);
		
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ДокументПланирования", Источник.Метаданные()) Тогда
		Если Источник.ДокументПланирования = Неопределено Тогда
			ОбъектКонтроля = Источник	
		Иначе	
			ОбъектКонтроля = Источник.ДокументПланирования;
			СсылкиПроверкиВложений.Добавить(ОбъектКонтроля);
			ОбъектыПроверкиСтатей.Добавить(ОбъектКонтроля);
		КонецЕсли;
	Иначе
		ОбъектКонтроля = Источник;
	КонецЕсли;
	
	НастройкиКонтроля = бит_ВизированиеСервер.НастройкиОбъектаВизирования(ОбъектКонтроля);
	
	КонтрольВложений  = НастройкиКонтроля.РежимКонтроляВложений;
	Если КонтрольВложений = Перечисления.бит_ВидыКонтроля.НеКонтролировать Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого ОбъектПровеки Из ОбъектыПроверкиСтатей Цикл
		Если ОбщегоНазначения.ЕстьРеквизитОбъекта("СтатьяОборотов", ОбъектПровеки.Метаданные()) Тогда
			НеКонтролироватьВложения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектПровеки.СтатьяОборотов,
																				"РазрешитьЗаявкиБезВложений");
			Если НеКонтролироватьВложения = Истина Тогда
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НаличиеФайлов.ЕстьФайлы КАК ЕстьФайлы
	|ИЗ
	|	РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
	|ГДЕ
	|	НаличиеФайлов.ОбъектСФайлами В (&СсылкиПроверкиВложений)
	|	И НаличиеФайлов.ЕстьФайлы";
	Запрос.УстановитьПараметр("СсылкиПроверкиВложений", СсылкиПроверкиВложений);
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Если КонтрольВложений = Перечисления.бит_ВидыКонтроля.Предупреждать Тогда
		ТекстСообщения = НСтр("ru = 'У документа %1 отсутствуют присоединенные файлы.';
			|en = '%1 have not attachment files.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбъектКонтроля);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ОбъектКонтроля);
	ИначеЕсли КонтрольВложений = Перечисления.бит_ВидыКонтроля.Контролировать Тогда
		ТекстСообщения = НСтр("ru = 'Для проведения документа %1 необходимо прикрепить файлы вложений.';
			|en = 'To complete %1 you must add the attachment files.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбъектКонтроля);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,ОбъектКонтроля,,,Отказ);
	КонецЕсли;
	
КонецПроцедуры

