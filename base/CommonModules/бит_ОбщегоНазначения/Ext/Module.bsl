// Функция выполняет пропорциональное распределение суммы в соответствии
// с заданными коэффициентами распределения.
// 
// Параметры:
// 		ИсхСумма   	 - распределяемая сумма.
// 		Коэффициенты - массив коэффициентов распределения.
// 		Точность   	 - точность округления при распределении. Необязателен.
// 
// 	Возврат:
// 		МассивСумм - массив размерностью равный массиву коэффициентов, содержит
// 			суммы в соответствии с весом коэффициента (из массива коэффициентов)
//          В случае если распределить не удалось (сумма = 0, кол-во коэффициентов = 0,
//          или суммарный вес коэффициентов = 0), тогда возвращается значение Неопределено.
// 
Функция РаспределитьПропорционально(Знач ИсхСумма, Коэффициенты, Знач Точность = 2) Экспорт
	
	Если Коэффициенты.Количество() = 0 ИЛИ ИсхСумма = Неопределено ИЛИ ИсхСумма = Null Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИндексМакс = 0;
	МаксЗнач   = 0;
	РаспрСумма = 0;
	СуммаКоэф  = 0;
	
	Для Сч = 0 По Коэффициенты.Количество() - 1 Цикл
		
		МодульЧисла = ?(Коэффициенты[Сч] > 0, Коэффициенты[Сч], - Коэффициенты[Сч]);
		
		Если МаксЗнач < МодульЧисла Тогда
			МаксЗнач = МодульЧисла;
			ИндексМакс = Сч;
		КонецЕсли;
		
		СуммаКоэф = СуммаКоэф + Коэффициенты[Сч];
		
	КонецЦикла;
	
	Если СуммаКоэф = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МассивСумм = Новый Массив(Коэффициенты.Количество());
	
	Для Сч = 0 По Коэффициенты.Количество() - 1 Цикл
		МассивСумм[Сч] = Окр(ИсхСумма * Коэффициенты[Сч] / СуммаКоэф, Точность, 1);
		РаспрСумма = РаспрСумма + МассивСумм[Сч];
	КонецЦикла;
	
	// Погрешности округления отнесем на коэффициент с максимальным весом.
	Если Не РаспрСумма = ИсхСумма Тогда
		МассивСумм[ИндексМакс] = МассивСумм[ИндексМакс] + ИсхСумма - РаспрСумма;
	КонецЕсли;
	
	Возврат МассивСумм;
	
КонецФункции // РаспределитьПропорционально()

