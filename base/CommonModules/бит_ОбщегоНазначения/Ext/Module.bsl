		ПроцессОбъект.Записать();
		Выполнено = Истина;
		
		Если РежимыВывода.ВыводитьИнформацию Тогда			
			ТекстСообщения = НСтр("ru='Записан бизнес процесс ""%1"".';en='Business process ""%1"" saved.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, Строка(ПроцессОбъект));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);			
