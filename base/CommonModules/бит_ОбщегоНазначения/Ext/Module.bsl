// См. ОбщегоНазначенияПереопределяемый.ПриДобавленииПараметровРаботыКлиентаПриЗапуске
Процедура ПриДобавленииПараметровРаботыКлиентаПриЗапуске(Параметры) Экспорт
	// ++ ЕРП 
	ПарамСтарта = бит_ПолныеПраваВызовСервера.ПолучитьПараметрыДляСтартаСистемы("ДействияПриНачалеРаботыСистемы");
	
	УстановитьЗначенияПоУмолчанию(Параметры);
	
	Если ПарамСтарта.ЭтоЧужойПодчиненныйУзел Тогда	
		Возврат;	
	КонецЕсли; 

	Параметры.бит_ПоказатьФормуКонстант = ПоказатьФормуКонстант();	
	
	Параметры.бит_ПоказатьРабочееМестоВизирования             = ПарамСтарта.ОткрытьРабочееМестоВизирования;
	Параметры.бит_ПодключитьОжиданиеУведомленияОбУстановкеВиз = ПарамСтарта.ИнтервалУведомленияУстановкиВиз;
	Параметры.бит_ПоказатьДополнительнуюИнформацию            = ПарамСтарта.ОткрытьДополнительнуюИнформациюБИТ;
	// -- ЕРП 
	
	// ++ НЕ УТ
	// налоговый мониторинг
	Если ПравоДоступа("Просмотр", Метаданные.Обработки.бит_НалоговыйМониторинг)
		И Не Пользователи.ЭтоПолноправныйПользователь() Тогда
		НачальнаяСтраница = Новый НастройкиНачальнойСтраницы;
		СоставФорм = Новый СоставФормНачальнойСтраницы();
		СоставФорм.ЛеваяКолонка.Добавить("Обработка.бит_НалоговыйМониторинг.Форма.РегламентированнаяОтчетность");
		СоставФорм.ЛеваяКолонка.Добавить("Обработка.бит_НалоговыйМониторинг.Форма.РабочийСтолНалоговогоИнспектора");
		СоставФорм.ПраваяКолонка.Добавить("Обработка.бит_НалоговыйМониторинг.Форма.БухгалтерскиеОтчеты");
		
		НачальнаяСтраница.УстановитьСоставФорм(СоставФорм);
		ХранилищеСистемныхНастроек.Сохранить("Общее/НастройкиНачальнойСтраницы", "", НачальнаяСтраница);
		Параметры.Вставить("бит_ОбновитьИнтерфейс", Истина);
	КонецЕсли;
	// -- НЕ УТ
	
КонецПроцедуры

