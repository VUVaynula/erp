        КонецЕсли; 
        ТекстСообщения = НСтр("ru = 'БИТ.ОшибкаЗаписиБизнесПроцесса'", ОбщегоНазначения.КодОсновногоЯзыка());  
        ЗаписьЖурналаРегистрации(ТекстСообщения, УровеньЖурналаРегистрации.Ошибка,,,
							     ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));   				
            
	КонецПопытки;
	
	Возврат Выполнено;
	
КонецФункции // ЗаписатьБизнесПроцесс()

// Функция выполняет старт бизнес процесса.
// 
// Параметры:
//   ПроцессОбъект - БизнесПроцесс.Объект.
//	РежимСообщений - Строка.
// 
// Возвращаемое значение:
//  Булево.
// 
Функция СтартоватьБизнесПроцесс(ПроцессОбъект, РежимСообщений = "Все") Экспорт
	
	РежимыВывода = ОпределитьРежимыВывода(РежимСообщений);
	Выполнено  = Ложь;
	
	Попытка
		
		ПроцессОбъект.Старт();
		Выполнено = Истина;
		
		Если РежимыВывода.ВыводитьОшибки Тогда
			
			ТекстСообщения = НСтр("ru='Выполнен старт бизнес процесса ""%1"".';en='Business process ""%1"" started.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, Строка(ПроцессОбъект));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
		КонецЕсли; 
		
	Исключение
		
		Выполнено = Ложь;
		        
        Если РежимыВывода.ВыводитьОшибки Тогда
            ОбщегоНазначения.СообщитьПользователю(ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
        КонецЕсли; 
        ТекстСообщения = НСтр("ru = 'БИТ.ОшибкаСтартаБизнесПроцесса'", ОбщегоНазначения.КодОсновногоЯзыка()); 
        ЗаписьЖурналаРегистрации(ТекстСообщения, УровеньЖурналаРегистрации.Ошибка,,,
								  ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));   				
                  		
	КонецПопытки;
	
	Возврат Выполнено;
	
КонецФункции // СтартоватьБизнесПроцесс()

// Процедура выполняет изменение пометки на удаление у объекта.
// 
// Параметры:
//  ТекущийОбъект     - Ссылка, Объект.
//     При передачи объекта необходимо в параметр "СтруктураПараметров" добавить ключ "ОбъектПолучен".
// 
//  ПометкаНаУдаление   - Булево, Режимы: Истина - пометить на удаление
//                                        Ложь   - снять пометку на удаление.
//  Заголовок           - Строка.
//  РежимСообщений      - Строка: "Нет","Все","Ошибки".
//  СтруктураПараметров - Структура, дополнительные параметры.
// 
// Возвращаемое значение:
//   ДействиеВыполнено - Булево.
// 
Функция ИзменитьПометкуНаУдалениеУОбъекта(ТекущийОбъект, ПометкаНаУдаление, Заголовок = "", 
                                          РежимСообщений = "Все", СтруктураПараметров = Неопределено) Экспорт

	РежимыВывода      = ОпределитьРежимыВывода(РежимСообщений);
	ДействиеВыполнено = Ложь;
	
	УказанаСтруктураПараметров = (ТипЗнч(СтруктураПараметров) = Тип("Структура"));
	ОбъектПолучен   = УказанаСтруктураПараметров И СтруктураПараметров.Свойство("ОбъектПолучен");
	РежимТранзакции = УказанаСтруктураПараметров И ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураПараметров, "РежимТранзакции", Ложь);
		
	Попытка
		
		Если ОбъектПолучен Тогда
			ПометкаНаУдалениеУОбъекта = ТекущийОбъект.ПометкаУдаления;
		Иначе
			ПометкаНаУдалениеУОбъекта = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущийОбъект, "ПометкаУдаления");
		КонецЕсли;
		
		Если ПометкаНаУдалениеУОбъекта <> ПометкаНаУдаление Тогда
			
			Если УказанаСтруктураПараметров И СтруктураПараметров.Свойство("ОбъектПолучен") Тогда
				ПолученныйОбъект = ТекущийОбъект;
			Иначе
				ПолученныйОбъект = ТекущийОбъект.ПолучитьОбъект();
			КонецЕсли;
			
			Если УказанаСтруктураПараметров Тогда
				Если СтруктураПараметров.Свойство("ЭтоПометкаИзГрафикаПлатежей") Тогда
					ПолученныйОбъект.ДополнительныеСвойства.Вставить("ПометкаИзГрафикаПлатежей", Истина);
				ИначеЕсли СтруктураПараметров.Свойство("ЭтоПометкаИзГрафикаНачислений") Тогда
					ПолученныйОбъект.ДополнительныеСвойства.Вставить("ПометкаИзГрафикаНачислений", Истина);
				КонецЕсли;
			КонецЕсли;
			
			ПолученныйОбъект.УстановитьПометкуУдаления(ПометкаНаУдаление);
			
			Если РежимыВывода.ВыводитьИнформацию Тогда
				Если ПометкаНаУдаление Тогда
					ТекстСообщения = НСтр("ru='Пометка на удаление установлена. %1';en='Tagging removal installed. %1'") 
				Иначе
					ТекстСообщения = НСтр("ru='Пометка на удаление снята. %1';en='Mark removal is removed. %1'") 
				КонецЕсли;
				ТекстСообщения = СтрШаблон(ТекстСообщения, ПолученныйОбъект); 
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ПолученныйОбъект); 			
			КонецЕсли;
		КонецЕсли;
		
		ДействиеВыполнено = ТекущийОбъект.ПометкаУдаления = ПометкаНаУдаление;
		
	Исключение
        Если РежимыВывода.ВыводитьОшибки Тогда
			ОбщегоНазначения.СообщитьПользователю(ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), ПолученныйОбъект); 
		КонецЕсли; 
		ТекстСообщения = НСтр("ru = 'БИТ.ОшибкаИзмененияПометкиУдаления'", ОбщегоНазначения.КодОсновногоЯзыка()); 
        ЗаписьЖурналаРегистрации(ТекстСообщения, УровеньЖурналаРегистрации.Ошибка, , ,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Если РежимТранзакции Тогда
			ВызватьИсключение;
		КонецЕсли;
	КонецПопытки;
    
	Возврат ДействиеВыполнено;
    
КонецФункции

// Функция читает набор записей регистра сведений бит_УстановленныеВизы согласно установленного отбора.
// 
// Параметры:
//   СтруктураОтбор - Структура.
//   ИмяРегистра    - Строка.
// 
// Возвращаемое значение:
//   НаборЗаписей - РегистрСведенийНаборЗаписей.бит_УстановленныеВизы.
// 
Функция ПрочитатьНаборЗаписейРегистраСведений(СтруктураОтбор,ИмяРегистра) Экспорт
	
	НаборЗаписей = РегистрыСведений[ИмяРегистра].СоздатьНаборЗаписей();
	
	Для каждого КлючИЗначение Из СтруктураОтбор Цикл
	
		ИмяПоля = КлючИЗначение.Ключ;
		ЗначениеПоля = КлючИЗначение.Значение;
		
		НаборЗаписей.Отбор[ИмяПоля].Использование = Истина;
		НаборЗаписей.Отбор[ИмяПоля].ВидСравнения = ВидСравнения.Равно;
        НаборЗаписей.Отбор[ИмяПоля].Значение     = ЗначениеПоля;		
		
	КонецЦикла; 
	
	НаборЗаписей.Прочитать();
	
	Возврат НаборЗаписей;
	
КонецФункции // ПрочитатьНаборВиз()

// Функция записывает набор записей регистра сведений.
// 
// Параметры:
//  НаборЗаписей   - РегистрСведенийНаборЗаписей.
//  РежимСообщений - Строка: "Нет", "Все", "Ошибки".
// 
// Возвращаемое значение:
//  Булево - действие выполнено.
// 
Функция ЗаписатьНаборЗаписейРегистра(НаборЗаписей,РежимСообщений="Все") Экспорт

	ДействиеВыполнено  = Ложь;
	
	Попытка
        НаборЗаписей.Записать();
	    ДействиеВыполнено = Истина;
    Исключение
        бит_ОбщегоНазначенияКлиентСервер.ВывестиСообщение(ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
        ТекстСообщения = НСтр("ru = 'БИТ.ОшибкаЗаписиНабораЗаписейРегистра'", ОбщегоНазначения.КодОсновногоЯзыка());     
        ЗаписьЖурналаРегистрации(ТекстСообщения, УровеньЖурналаРегистрации.Ошибка, , ,ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));   				
       		         
		ДействиеВыполнено = Ложь;
	КонецПопытки;

	Возврат ДействиеВыполнено;
	
КонецФункции // ЗаписатьНаборЗаписейРегистра()

// Функция удаляет набор записей регистра сведений.
