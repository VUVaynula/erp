Функция ПараметрыОбъектаДляОчисткиНеиспользуемыхРеквизитов() Экспорт

	ПоляОбъекта = Новый Структура; 
	ПоляОбъекта.Вставить("Аналитика_1","Аналитика_1");
	ПоляОбъекта.Вставить("Аналитика_2","Аналитика_2");
	ПоляОбъекта.Вставить("Аналитика_3","Аналитика_3");
	ПоляОбъекта.Вставить("Аналитика_4","Аналитика_4");
	ПоляОбъекта.Вставить("Аналитика_5","Аналитика_5");
	ПоляОбъекта.Вставить("Аналитика_6","Аналитика_6");
	ПоляОбъекта.Вставить("Аналитика_7","Аналитика_7");
	// ++ ЕРП 	
	ПоляОбъекта.Вставить("Аналитика_8","Аналитика_8");
	ПоляОбъекта.Вставить("Аналитика_9","Аналитика_9");
	ПоляОбъекта.Вставить("Аналитика_10","Аналитика_10");
	ПоляОбъекта.Вставить("Аналитика_11","Аналитика_11");
	ПоляОбъекта.Вставить("Аналитика_12","Аналитика_12");
	// -- ЕРП 

	ПараметрыОбъекта = Новый Структура("ПоляОбъекта, СтатьяОборотов", 
						ПоляОбъекта, Справочники.бит_СтатьиОборотов.ПустаяСсылка()); 
	
	Возврат ПараметрыОбъекта;

КонецФункции

Функция ПараметрыОчисткиНеиспользуемыхРеквизитов(ПараметрыОбъекта) Экспорт

	ПоляОбъекта = ПараметрыОбъекта.ПоляОбъекта;
	
	Если ТипЗнч(ПараметрыОбъекта.СтатьяОборотов) = Тип("Массив") Тогда
		Статьи = ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыОбъекта.СтатьяОборотов);
	Иначе	
		Статьи = Новый Массив; 
		Статьи.Добавить(ПараметрыОбъекта.СтатьяОборотов);
	КонецЕсли; 
	
	Индекс = Статьи.ВГраница();
	Пока Индекс >= 0 Цикл
		Если НЕ ЗначениеЗаполнено(Статьи.Получить(Индекс)) Тогда
			Статьи.Удалить(Индекс);		
		КонецЕсли; 
		Индекс = Индекс - 1;
	КонецЦикла;  
	
	ПараметрыПоиска = НовыеПараметрыПоискаПолейОчисткиНеиспользуемыхРеквизитов();
	РеквизитыСтатьи = Новый Массив; 
	Для каждого КлючЗначение Из ПараметрыПоиска Цикл
		ПолеОбъекта = Неопределено;
		Если ПоляОбъекта.Свойство(КлючЗначение.Значение, ПолеОбъекта) Тогда
			Если ЗначениеЗаполнено(ПолеОбъекта) Тогда
				РеквизитыСтатьи.Добавить(КлючЗначение.Ключ);
			КонецЕсли;
		КонецЕсли; 
	КонецЦикла; 

	ДанныеПоУмолчанию = Новый Структура();
	Для каждого Ключ Из РеквизитыСтатьи Цикл
		ДанныеПоУмолчанию.Вставить(Ключ, Ложь);
	КонецЦикла; 

	Если Статьи.Количество() > 0 Тогда
		ПараметрыДанных = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Статьи, РеквизитыСтатьи);
	Иначе
		ПараметрыДанных = Новый Соответствие;
	КонецЕсли; 
	ПараметрыДанных.Вставить(Справочники.бит_СтатьиОборотов.ПустаяСсылка(), ДанныеПоУмолчанию);
	
	ПараметрыОчистки = Новый Структура("ПараметрыПоиска, ПараметрыДанных", 
							ПараметрыПоиска, ПараметрыДанных);
	
	Возврат ПараметрыОчистки;
	
КонецФункции

Процедура ОчиститьНеиспользуемыеРеквизитыНабора(НаборДанных, ПараметрыОчистки) Экспорт 
	
	Для каждого СтрокаТаблицы Из НаборДанных Цикл
		ОчиститьНеиспользуемыеРеквизитыДанных(СтрокаТаблицы, ПараметрыОчистки);
	КонецЦикла; 

КонецПроцедуры
 
Процедура ОчиститьНеиспользуемыеРеквизитыДанных(Данные, ПараметрыОчистки) Экспорт

	ПараметрыПоиска = ПараметрыОчистки.ПараметрыПоиска;
	ПараметрыДанных = ПараметрыОчистки.ПараметрыДанных;
	
	ДанныеСтатьи = ПараметрыДанных.Получить(Данные.СтатьяОборотов);
	Если ДанныеСтатьи = Неопределено Тогда
		Возврат;	
	КонецЕсли; 
	
	Для каждого КлючЗначение Из ДанныеСтатьи Цикл
		
		ПолеДанных = ПараметрыПоиска[КлючЗначение.Ключ];
		Если НЕ КлючЗначение.Значение Тогда
			Данные[ПолеДанных] = Неопределено;
		Иначе
			Если НЕ ЗначениеЗаполнено(Данные[ПолеДанных]) Тогда
				Данные[ПолеДанных] = Неопределено;
			КонецЕсли; 	
		КонецЕсли; 
	КонецЦикла; 
	
КонецПроцедуры

// Функция проверяет разрешено ли заполнение аналитик.
// 
// Параметры:
//  Источник - ДокументОбъект.
//  
// Возвращаемое значение:
//   Булево - разрешено.
// 
Функция РазрешеноПерезаполнениеАналитик(Источник)

	Разрешено = Истина;
	
	Если Источник.ДополнительныеСвойства.Свойство("бит_НеЗаполнятьАналитикиПоУмолчанию") 
		И Источник.ДополнительныеСвойства.бит_НеЗаполнятьАналитикиПоУмолчанию Тогда
	
		Разрешено = Ложь;
	Иначе		
		// ++ЕРП
		РежимЗаполнения     = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_РежимАвтоЗаполненияАналитик");
		ПеречисленияРежимов = Перечисления.бит_РежимыАвтоЗаполненияАналитик;
		Если РежимЗаполнения = ПеречисленияРежимов.НеЗаполнять Тогда
			// Заполнение запрещено, если режим автозаполнения аналитик установлен в значение "НеЗаполнять".
			Разрешено = Ложь; 		
		ИначеЕсли РежимЗаполнения = ПеречисленияРежимов.Заполнять Тогда
			// Заполнение запрещено, если режим = "ЗаполнятьВсегда" и для документа установлен запрет на перезаполнение аналитик.
			Разрешено = Не ПолучитьЗначениеДополнительногоПараметраОбъекта(Источник.Ссылка, "ЗапретитьПерезаполнениеАналитик");
		Иначе	
			Разрешено = Ложь;
		КонецЕсли;
		// --ЕРП
	КонецЕсли;
	
	Источник.ДополнительныеСвойства.Вставить("бит_НеЗаполнятьАналитикиПоУмолчанию", НЕ Разрешено);
	
	Возврат Разрешено;
	
КонецФункции

#Область УстановкаСвойствАналитик

// Процедура устанавливает начальные свойства аналитик шапки при изменении статьи оборотов.
//
// Параметры:
//  Форма.
//  Объект.
//  ПараметрыУстановки.
//
Процедура УстановитьСвойстваАналитикШапкиПриИзмененииСтатьиОборотов(Форма, Объект, ПараметрыУстановки) Экспорт
		
	ДанныеОбъекта = бит_МеханизмДопИзмеренийКлиентСервер.ДанныеУстановкиПараметровАналитик(Объект, ПараметрыУстановки);
	
	бит_МеханизмДопИзмеренийКлиентСервер.УстановитьПараметрыВыбораАналитик(Форма, Объект, ПараметрыУстановки, ДанныеОбъекта);
	
КонецПроцедуры

// Процедура устанавливает начальные свойства аналитик строки таблицы при изменении статьи оборотов.
//
// Параметры:
//  Форма.
//  СтрокаТаблицы.
//  ПараметрыУстановки.
//
Процедура УстановитьСвойстваАналитикСтрокиПриИзмененииСтатьиОборотов(Форма, СтрокаТаблицы, ПараметрыУстановки) Экспорт
			
