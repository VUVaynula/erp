КонецПроцедуры

Процедура ПодготовитьЗначенияАналитикПоДоговору(Аналитики, ТекущийОбъект)

	Если НЕ ЗначениеЗаполнено(Аналитики.ДоговорКонтрагента) Тогда
		Возврат;	
	КонецЕсли; 
	
	Договор = Аналитики.ДоговорКонтрагента;
	
	ИменаРеквизитов = Новый Массив; 
	ИменаРеквизитов.Добавить("бит_ЦФО");
	ИменаРеквизитов.Добавить("бит_Проект");
	ИменаРеквизитов.Добавить("бит_ВысокийПриоритетПриЗаполненииАналитик");
	
	ИмяСвойстваКонтрагент = бит_ОбщегоНазначенияКлиентСерверПереопределяемый.ИмяСвойстваКонтрагентДоговора();
	ЕстьКонтрагент		  = ОбщегоНазначения.ЕстьРеквизитОбъекта(ИмяСвойстваКонтрагент, Договор.Метаданные());
	Если ЕстьКонтрагент Тогда
		ИменаРеквизитов.Добавить(ИмяСвойстваКонтрагент);
	КонецЕсли;
		
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Аналитики.ДоговорКонтрагента, СтрСоединить(ИменаРеквизитов, ","));
	
	Аналитики.Вставить("ЦФО",	 		   Реквизиты.бит_ЦФО);
	Аналитики.Вставить("Проект", 		   Реквизиты.бит_Проект);
	Аналитики.Вставить("ВысокийПриоритет", Реквизиты.бит_ВысокийПриоритетПриЗаполненииАналитик);	
	Аналитики.Вставить("СтатьяОборотов",   ОсновнаяСтатьяПоДоговору(ТекущийОбъект, Аналитики.ДоговорКонтрагента));
	
	Если ЕстьКонтрагент Тогда
		Аналитики.Вставить("Контрагент",Реквизиты[ИмяСвойстваКонтрагент]);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПодготовитьЗначенияАналитикПоСоглашению(Аналитики, ТекущийОбъект)
	
	ЕстьРеквизитОбъекта = ОбщегоНазначения.ЕстьРеквизитОбъекта("Соглашение", ТекущийОбъект.Метаданные());
	Если НЕ ЕстьРеквизитОбъекта Тогда
		Возврат;
	КонецЕсли;  
	
	Если НЕ ЗначениеЗаполнено(ТекущийОбъект.Соглашение) Тогда
		Возврат;	
	КонецЕсли;  

	ИменаРеквизитов = Новый Массив; 
	ИменаРеквизитов.Добавить("бит_ЦФО");
	ИменаРеквизитов.Добавить("бит_Проект");
	ИменаРеквизитов.Добавить("бит_ВысокийПриоритетПриЗаполненииАналитик"); 
	ИменаРеквизитов.Добавить("Контрагент");
	
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТекущийОбъект.Соглашение, ИменаРеквизитов);
	
	Аналитики.Вставить("ЦФО",	 		   Реквизиты.бит_ЦФО);
	Аналитики.Вставить("Проект", 		   Реквизиты.бит_Проект);
	Аналитики.Вставить("ВысокийПриоритет", Реквизиты.бит_ВысокийПриоритетПриЗаполненииАналитик);	
	Аналитики.Вставить("СтатьяОборотов",   ОсновнаяСтатьяПоДоговору(ТекущийОбъект, ТекущийОбъект.Соглашение));
	Аналитики.Вставить("Контрагент",	   Реквизиты.Контрагент);
	
КонецПроцедуры

Функция ОсновнаяСтатьяПоДоговору(ДокументОбъект, ДоговорКонтрагента)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ОсновнаяСтатья = Неопределено;
	Если ТипЗнч(ДоговорКонтрагента) = Тип("Структура") Тогда
		Договор = ДоговорКонтрагента.Ссылка;
	Иначе	
		Договор = ДоговорКонтрагента;
	КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(Договор) Тогда
		Возврат ОсновнаяСтатья;
	КонецЕсли; 
	
	// Статья оборотов.
	СтруктураОтбораСтатьи = ОтборДляСтатьиОборотовПоДокументу(ДокументОбъект);
	Если СтруктураОтбораСтатьи.ЗаполнятьСтатью Тогда
		
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	&СтатьяОборотов КАК СтатьяОборотов,
		|	0 КАК ПорядокВыборки
		|ПОМЕСТИТЬ СтатьиОборотов
		|ИЗ
		|	#Реквизиты КАК ДоговорыКонтрагентов
		|ГДЕ
		|	ДоговорыКонтрагентов.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатьиОборотовДоговора.СтатьяОборотов,
		|	1
		|ИЗ
		|	#Реквизиты.бит_СтатьиОборотов КАК СтатьиОборотовДоговора
		|ГДЕ
		|	СтатьиОборотовДоговора.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СтатьиОборотов.СтатьяОборотов КАК СтатьяОборотов
		|ИЗ
		|	СтатьиОборотов КАК СтатьиОборотов
		|ГДЕ
		|	СтатьиОборотов.СтатьяОборотов.ТипСтатьи = &ТипСтатьи
		|	И СтатьиОборотов.СтатьяОборотов.РасходДоход = &РасходДоход
		|
		|УПОРЯДОЧИТЬ ПО
		|	СтатьиОборотов.ПорядокВыборки";
		
		// В различных локализациях БИТ.ФИНАНС имя таблицы меняется.
		// Поэтому используем универсальный текст запроса.
		ЧтоЗаменить = "#Реквизиты";
		НаЧтоЗаменить = Договор.Метаданные().ПолноеИмя();
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, ЧтоЗаменить, НаЧтоЗаменить);
		
		ЧтоЗаменить = "&СтатьяОборотов";
		Если СтруктураОтбораСтатьи.ТипСтатьи = Перечисления.бит_ТипыСтатейОборотов.БДР Тогда
			НаЧтоЗаменить = "бит_ОсновнаяСтатьяОборотовБДР";
		Иначе	
			НаЧтоЗаменить = "бит_ОсновнаяСтатьяОборотов";
		КонецЕсли; 
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, ЧтоЗаменить, НаЧтоЗаменить);
		
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапроса;
		Запрос.УстановитьПараметр("Ссылка", 	 Договор);
		Запрос.УстановитьПараметр("ТипСтатьи", 	 СтруктураОтбораСтатьи.ТипСтатьи);
		Запрос.УстановитьПараметр("РасходДоход", СтруктураОтбораСтатьи.РасходДоход);
		
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Следующий() Тогда
			ОсновнаяСтатья = Выборка.СтатьяОборотов;
		КонецЕсли; 
	КонецЕсли;
	
	Возврат ОсновнаяСтатья;
	
КонецФункции

Процедура ЗаполнитьДополнительныеАналитикиШапки(ТекущийОбъект, НаборЗаписей)
		
	ЗначенияПоУмолчанию		= ЗначенияАналитикПоУмолчанию(ТекущийОбъект, Истина);
	ДополнительныеАналитики = НазначенныеДополнительныеАналитики(ТекущийОбъект.Метаданные());
	
	Для каждого СтрокаТаблицы Из ДополнительныеАналитики Цикл
		УстановитьЗначениеАналитики(ТекущийОбъект, НаборЗаписей, СтрокаТаблицы.Аналитика, ЗначенияПоУмолчанию);	
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьДополнительныеАналитикиРаспределенияБюджета(НаборЗаписей, ТекущийОбъект)

	ТекПользователь     = Пользователи.ТекущийПользователь();
	ЗначенияПоУмолчанию = ЗначенияАналитикПоУмолчанию(ТекущийОбъект, Ложь);
	
	СоответствиеСтатейПоДоговорам = Новый Соответствие;
	СоответствиеСтатейПоСтатьямРг = Новый Соответствие;
	
	СтрокаСвойствПоДоговору = "бит_ЦФО, бит_Проект";
	
	// Заполним аналитики в табличной части.
	МетаданныеОбъекта  = ТекущийОбъект.Метаданные();
	ЕстьДоговорВТч	   = бит_РаботаСМетаданными.ЕстьРеквизитТабЧасти("ДоговорКонтрагента", 
							МетаданныеОбъекта, "РасшифровкаПлатежа");
	РасшифровкаПлатежа = ТекущийОбъект.РасшифровкаПлатежа;
	
	РеквизитыТабЧасти = Новый Структура;
	РеквизитыТабЧасти.Вставить("бит_ЦФО"		   		 , ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ЦФО);
	РеквизитыТабЧасти.Вставить("бит_СтатьяОборотов"		 , ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.СтатьяОборотов);
	РеквизитыТабЧасти.Вставить("бит_Проект"			   	 , ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.Проект);
	РеквизитыТабЧасти.Вставить("бит_НоменклатурнаяГруппа", ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.НоменклатурнаяГруппа);
	
	// Не заполнять аналитику (заполненную в шапке) в тч, если в тч одна строка(и в шапке заполнена).
	ОднострочныйДокумент = РасшифровкаПлатежа.Количество() = 1;
	МассивНезаполняемых = Новый Массив;
	Если ОднострочныйДокумент Тогда
		// Заполним массив имен аналитик, которые не надо заполнять в тч, так как они уже заполнены в шапке. 				
		Если НаборЗаписей <> Неопределено Тогда 
			Для каждого ТекЗап Из НаборЗаписей Цикл
				Если ЗначениеЗаполнено(ТекЗап.ЗначениеАналитики) Тогда
					МассивНезаполняемых.Добавить(ТекЗап.Аналитика);					
				КонецЕсли;				
			КонецЦикла;
		Иначе
			ЗначенияПоУмолчаниюДляШапки = ЗначенияАналитикПоУмолчанию(ТекущийОбъект, Истина);
			Для каждого КлЗнч Из ЗначенияПоУмолчаниюДляШапки Цикл
				Если ЗначениеЗаполнено(КлЗнч.Значение) Тогда
					МассивНезаполняемых.Добавить(КлЗнч.Ключ);					
				КонецЕсли;				
			КонецЦикла; 	
		КонецЕсли; 			
	КонецЕсли;
	
	Для каждого СтрокаРасшифровки Из РасшифровкаПлатежа Цикл
		
		// Очистка аналитик табличной части значениями по умолчанию.
		Для каждого КлючИЗначение Из РеквизитыТабЧасти Цикл
			ИмяРеквизита = КлючИЗначение.Ключ;
			СтрокаРасшифровки[ИмяРеквизита] = КлючИЗначение.Значение.ТипЗначения.ПривестиЗначение(Неопределено);
		КонецЦикла;
		
		// Заполнение аналитик табличной части по договору, если у него высокий приоритет.
		Если ЕстьДоговорВТч Тогда
			ТекущийДоговор = СтрокаРасшифровки.ДоговорКонтрагента;
			Если ТекущийДоговор.бит_ВысокийПриоритетПриЗаполненииАналитик 
				Или Не ЗначениеЗаполнено(СтрокаРасшифровки.СтатьяДвиженияДенежныхСредств) Тогда
				
				Если ТекущийДоговор.бит_ВысокийПриоритетПриЗаполненииАналитик Тогда
					// ЦФО, проект
					Если Не ОднострочныйДокумент ИЛИ МассивНезаполняемых.Найти(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ЦФО) = Неопределено Тогда
						СтрокаРасшифровки.бит_ЦФО = ТекущийДоговор.бит_ЦФО;
					КонецЕсли;
					Если Не ОднострочныйДокумент ИЛИ МассивНезаполняемых.Найти(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.Проект) = Неопределено Тогда
						СтрокаРасшифровки.бит_Проект = ТекущийДоговор.бит_Проект;
					КонецЕсли;
				КонецЕсли;
				
				// Статья оборотов
				Если Не ОднострочныйДокумент ИЛИ МассивНезаполняемых.Найти(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.СтатьяОборотов) = Неопределено Тогда
					СтатьяОборотовПоДог = СоответствиеСтатейПоДоговорам.Получить(СтрокаРасшифровки.ДоговорКонтрагента);
					Если СтатьяОборотовПоДог = Неопределено Тогда
						ОсновнаяСтатья = ПолучитьСтатьюПоДоговору(ТекущийОбъект, ТекущийДоговор);
						Если ОсновнаяСтатья <> Неопределено Тогда
							СтрокаРасшифровки.бит_СтатьяОборотов = ОсновнаяСтатья;
							СоответствиеСтатейПоДоговорам.Вставить(СтрокаРасшифровки.ДоговорКонтрагента, ОсновнаяСтатья);
						КонецЕсли;
					Иначе
						СтрокаРасшифровки.бит_СтатьяОборотов = СтатьяОборотовПоДог;	
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
		
		// Заполнение статью оборотов по соответсвию.
		Если Не ОднострочныйДокумент ИЛИ МассивНезаполняемых.Найти(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.СтатьяОборотов) = Неопределено Тогда
			Если Не ЗначениеЗаполнено(СтрокаРасшифровки.бит_СтатьяОборотов) Тогда
				СтатьяОборотовПоСоотв = СоответствиеСтатейПоСтатьямРг.Получить(СтрокаРасшифровки.СтатьяДвиженияДенежныхСредств);
				Если СтатьяОборотовПоСоотв = Неопределено Тогда
					РезМассив = бит_Бюджетирование.СвязанныеСтатьиОборотовИСтатьиРегл(СтрокаРасшифровки.СтатьяДвиженияДенежныхСредств);
					Если РезМассив.Количество() = 1 Тогда 	 							
						Если ТипЗнч(РезМассив[0]) = Тип("СправочникСсылка.бит_СтатьиОборотов") Тогда 					 
							СтрокаРасшифровки.бит_СтатьяОборотов = РезМассив[0];
							СоответствиеСтатейПоСтатьямРг.Вставить(СтрокаРасшифровки.СтатьяДвиженияДенежныхСредств, СтрокаРасшифровки.бит_СтатьяОборотов);
						КонецЕсли; // Значение типа СтатьяОборотов. 							  
					КонецЕсли;
				Иначе
					СтрокаРасшифровки.бит_СтатьяОборотов = СтатьяОборотовПоСоотв;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// Заполнение аналитик табличной части значениями по умолчанию.
		Для каждого КлючИЗначение Из РеквизитыТабЧасти Цикл
			ИмяРеквизита = КлючИЗначение.Ключ;
			ТекАналитика = КлючИЗначение.Значение;
			// Не заполнять в ТЧ аналитики, заполненные в шапке, если в тч одна строка.
			Если ОднострочныйДокумент И МассивНезаполняемых.Найти(ТекАналитика) <> Неопределено Тогда
				Продолжить;						
			КонецЕсли;
			ЗначениеАналитики = ЗначенияПоУмолчанию[КлючИЗначение.Значение];
			Если ЗначениеЗаполнено(ЗначениеАналитики) И Не ЗначениеЗаполнено(СтрокаРасшифровки[ИмяРеквизита]) Тогда
				СтрокаРасшифровки[ИмяРеквизита] = ЗначениеАналитики;													
			КонецЕсли;
		КонецЦикла; 				
		
		// Заполнение аналитик табличной части по договору, если у него низкий приоритет.
		Если ЕстьДоговорВТч И Не ТекущийДоговор.бит_ВысокийПриоритетПриЗаполненииАналитик Тогда					
			// ЦФО.
			Если Не ОднострочныйДокумент ИЛИ МассивНезаполняемых.Найти(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ЦФО) = Неопределено Тогда
				Если Не ЗначениеЗаполнено(СтрокаРасшифровки.бит_ЦФО) Тогда
					СтрокаРасшифровки.бит_ЦФО = ТекущийДоговор.бит_ЦФО;
				КонецЕсли;
			КонецЕсли;
			// Статья оборотов.
			Если Не ОднострочныйДокумент ИЛИ МассивНезаполняемых.Найти(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.СтатьяОборотов) = Неопределено Тогда
				Если Не ЗначениеЗаполнено(СтрокаРасшифровки.бит_СтатьяОборотов) Тогда
					ОсновнаяСтатья = ПолучитьСтатьюПоДоговору(ТекущийОбъект, ТекущийДоговор);
					Если ОсновнаяСтатья <> Неопределено Тогда
						СтрокаРасшифровки.бит_СтатьяОборотов = ОсновнаяСтатья;					
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			// Проект.
			Если Не ОднострочныйДокумент ИЛИ МассивНезаполняемых.Найти(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.Проект) = Неопределено Тогда
				Если ЗначениеЗаполнено(ТекущийДоговор.бит_Проект) Тогда
					СтрокаРасшифровки.бит_Проект = ТекущийДоговор.бит_Проект;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// Из настроек пользователя.
		Если Не ОднострочныйДокумент ИЛИ МассивНезаполняемых.Найти(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ЦФО) = Неопределено Тогда
			ЗаполнитьЗначениеДопАналитикиИзНастройкиПользователя(СтрокаРасшифровки.бит_ЦФО, "ОсновнойЦФО", ТекПользователь);
		КонецЕсли;
		Если Не ОднострочныйДокумент ИЛИ МассивНезаполняемых.Найти(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.Проект) = Неопределено Тогда
			ЗаполнитьЗначениеДопАналитикиИзНастройкиПользователя(СтрокаРасшифровки.бит_Проект, "ОсновнойПроект", ТекПользователь);
		КонецЕсли;
		Если Не ОднострочныйДокумент ИЛИ МассивНезаполняемых.Найти(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.НоменклатурнаяГруппа) = Неопределено Тогда
			ЗаполнитьЗначениеДопАналитикиИзНастройкиПользователя(СтрокаРасшифровки.бит_НоменклатурнаяГруппа, "ОсновнаяНоменклатурнаяГруппа", ТекПользователь);
		КонецЕсли;
	КонецЦикла;  			

КонецПроцедуры

// Процедура заполняет значение дополнительной аналитики по реквизиту объекта.
// 
// Параметры:
//  ДопАн_СтатьяОборотов  - Неопределено или СправочникСсылка.бит_СтатьиОборотов.
//  ИмяРеквизита  		  - Строка.
//  ТекущийОбъект         - ДокументОбъект.
//  МетаданныеОбъекта     - Коллекция метаданных объекта.
//  ТребуемыйТип 		  - Строка.
// 
Процедура ЗаполнитьЗначениеДопАналитикиСтатьиОборотовПоРеквизиту(ДопАн_СтатьяОборотов, ИмяРеквизита, ТекущийОбъект, МетаданныеОбъекта, ТребуемыйТип = Неопределено)

	Если Не ЗначениеЗаполнено(ДопАн_СтатьяОборотов) И бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита, МетаданныеОбъекта) Тогда
		
		Если ТребуемыйТип = Неопределено 
			ИЛИ ТипЗнч(ТекущийОбъект[ИмяРеквизита]) = ТребуемыйТип Тогда
			
			ЗначениеИсточник = ТекущийОбъект[ИмяРеквизита];
		
			Если бит_ОбщегоНазначенияКлиентСервер.ЭтоУказанныйТип(ТипЗнч(ЗначениеИсточник), бит_ОбщегоНазначения.ПолучитьИмяТипаНоменклатурныеГруппы()) Тогда
				РезМассив = бит_Бюджетирование.СвязанныеСтатьиОборотовИНоменклатурныеГруппы(ЗначениеИсточник);
			Иначе	
				РезМассив = бит_Бюджетирование.СвязанныеСтатьиОборотовИСтатьиРегл(ЗначениеИсточник);
			КонецЕсли;
		
			Если РезМассив.Количество() <> 0 Тогда  			
				Если ТипЗнч(РезМассив[0]) = Тип("СправочникСсылка.бит_СтатьиОборотов") Тогда				
					ДопАн_СтатьяОборотов = РезМассив[0];				
				КонецЕсли;  			
			КонецЕсли;			
		КонецЕсли;    		 
	КонецЕсли;
	
КонецПроцедуры

// Процедура заполняет значение дополнительной аналитики по набору реквизитов объекта
// типа: Субконто1, Субконто2, Субконто3 (ПрефиксРеквизитов = "Субконто").
// 
// Параметры:
//  ДопАн_СтатьяОборотов  - Неопределено или СправочникСсылка.бит_СтатьиОборотов.
//  ПрефиксРеквизитов	  - Строка.
//  ТекущийОбъект         - ДокументОбъект.
//  МетаданныеОбъекта     - Коллекция метаданных объекта.
//  ТребуемыйТип 		  - Строка.
// 
Процедура ЗаполнитьЗначениеДопАналитикиСтатьиОборотовПоНаборуРеквизитов(ДопАн_СтатьяОборотов, ПрефиксРеквизитов, ТекущийОбъект, МетаданныеОбъекта, ТребуемыйТип)

	Если Не ЗначениеЗаполнено(ДопАн_СтатьяОборотов) Тогда
		Для Сч = 1 По 3 Цикл
			ИмяРеквизита = ПрефиксРеквизитов + Сч;
			ЗаполнитьЗначениеДопАналитикиСтатьиОборотовПоРеквизиту(ДопАн_СтатьяОборотов, ИмяРеквизита, ТекущийОбъект, МетаданныеОбъекта, ТребуемыйТип);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Процедура заполняет значение дополнительной аналитики по значению пользователя.
// 
// Параметры:
//  ЗначениеДопАн   - Произвольное значение.
//  ИмяНастройки    - Строка.
//  ТекПользователь - СправочникСсылка.Пользователи.
// 
Процедура ЗаполнитьЗначениеДопАналитикиИзНастройкиПользователя(ЗначениеДопАн, ИмяНастройки, ТекПользователь)

	Если Не ЗначениеЗаполнено(ЗначениеДопАн) Тогда
		ТекЗначение = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(ИмяНастройки, ТекПользователь);
		Если ЗначениеЗаполнено(ТекЗначение) Тогда
			ЗначениеДопАн = ТекЗначение;
		КонецЕсли; 
	КонецЕсли;
	
КонецПроцедуры
              
// Функция заполняет структуру поиска статьи оборотов.
// 
// Параметры:
//  ТекущийОбъект  - ДокументОбъект, ДокументСсылка.
//  
// Возвращаемое значение:
//   Структура("ЗаполнятьСтатью, ТипСтатьи, РасходДоход").
// 
Функция ОтборДляСтатьиОборотовПоДокументу(ТекущийОбъект)

	// ++ ЕРП 
	БДРРасходование = Новый Массив;
	БДРРасходование.Добавить(Метаданные.Документы.ЗаказПоставщику); 
	БДРРасходование.Добавить(Метаданные.Документы.ПриобретениеТоваровУслуг);
	БДРРасходование.Добавить(Метаданные.Документы.ПриобретениеУслугПрочихАктивов);

	БДРПоступление = Новый Массив; 
	БДРПоступление.Добавить(Метаданные.Документы.ЗаказКлиента);
	БДРПоступление.Добавить(Метаданные.Документы.РеализацияТоваровУслуг);
	БДРПоступление.Добавить(Метаданные.Документы.РеализацияУслугПрочихАктивов);
	БДРПоступление.Добавить(Метаданные.Документы.АктВыполненныхРабот);
	
	БДДСРасходование = Новый Массив; 
	
	БДДСПоступление = Новый Массив; 
	БДДСПоступление.Добавить(Метаданные.Документы.СчетНаОплатуКлиенту);
	// -- ЕРП 
		
	МетаданныеОбъекта = ТекущийОбъект.Метаданные();
	
	Если БДРРасходование.Найти(МетаданныеОбъекта) <> Неопределено Тогда
		ТипСтатьи      	= Перечисления.бит_ТипыСтатейОборотов.БДР;
		РасходДоход    	= Перечисления.бит_РасходДоход.Расходование;
		ТипСтатьиСтр   	= "БДР";
		РасходДоходСтр 	= "Расходование"; 
		ЗаполнятьСтатью = Истина;
	ИначеЕсли БДРПоступление.Найти(МетаданныеОбъекта) <> Неопределено Тогда
		ТипСтатьи      	= Перечисления.бит_ТипыСтатейОборотов.БДР;
		РасходДоход    	= Перечисления.бит_РасходДоход.Поступление;
		ТипСтатьиСтр   	= "БДР";
		РасходДоходСтр 	= "Поступление";  
		ЗаполнятьСтатью = Истина;
	ИначеЕсли БДДСРасходование.Найти(МетаданныеОбъекта) <> Неопределено Тогда
		ТипСтатьи      	= Перечисления.бит_ТипыСтатейОборотов.БДДС;
		РасходДоход    	= Перечисления.бит_РасходДоход.Расходование;
		ТипСтатьиСтр   	= "БДДС";
		РасходДоходСтр 	= "Расходование"; 
		ЗаполнятьСтатью = Истина;	
	ИначеЕсли БДДСПоступление.Найти(МетаданныеОбъекта) <> Неопределено Тогда
		ТипСтатьи      	= Перечисления.бит_ТипыСтатейОборотов.БДДС;
		РасходДоход    	= Перечисления.бит_РасходДоход.Поступление;
		ТипСтатьиСтр   	= "БДДС";
		РасходДоходСтр 	= "Поступление"; 
		ЗаполнятьСтатью = Истина;
	Иначе
		ТипСтатьи      	= Перечисления.бит_ТипыСтатейОборотов.БДДС;
		РасходДоход    	= Перечисления.бит_РасходДоход.Расходование;
		ТипСтатьиСтр   	= "";
		РасходДоходСтр 	= "";
		ЗаполнятьСтатью = Ложь;
	КонецЕсли;
	
	НастройкиОтбора = Новый Структура;
	НастройкиОтбора.Вставить("ЗаполнятьСтатью",	ЗаполнятьСтатью);
	НастройкиОтбора.Вставить("ТипСтатьи",    	ТипСтатьи); 	
	НастройкиОтбора.Вставить("РасходДоход",    	РасходДоход);
	НастройкиОтбора.Вставить("ТипСтатьиСтр", 	ТипСтатьиСтр); 	
	НастройкиОтбора.Вставить("РасходДоходСтр", 	РасходДоходСтр);

	Возврат НастройкиОтбора;
	
КонецФункции

Процедура УстановитьЗапретитьПерезаполнениеАналитикНовому(Источник)

	ЭтоНовый = Ложь;
	Если НЕ Источник.ДополнительныеСвойства.Свойство("ЭтоНовый", ЭтоНовый) Тогда
		Возврат;	
	КонецЕсли; 
	
	Если НЕ ЭтоНовый Тогда
		Возврат;
	КонецЕсли; 
	
	РежимЗаполнения     = Константы.бит_РежимАвтоЗаполненияАналитик.Получить();
	ПеречисленияРежимов = Перечисления.бит_РежимыАвтоЗаполненияАналитик;
	// ++ ЕРП 
	Если РежимЗаполнения = ПеречисленияРежимов.НеЗаполнять Тогда
		Возврат;
	КонецЕсли; 	
	// -- ЕРП 	
	НаборЗаписей = РегистрыСведений.бит_ДополнительныеПараметрыОбъектов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Объект.Установить(Источник.Ссылка);
	
	Запись = НаборЗаписей.Добавить();
	Запись.Объект = Источник.Ссылка;
	Запись.ЗапретитьПерезаполнениеАналитик = Истина;
	
	НаборЗаписей.Записать();

КонецПроцедуры

// Функция получает результат запроса на данные из регистра бит_ДополнительныеПараметрыОбъектов.
// 
// Параметры:
//  СсылкаНаОбъект  - Любая ссылка.
//  
// Возвращаемое значение:
//   Результат выполнения запроса.
// 
Функция ПолучитьРезультатЗапросаНаДополнительныеПараметрыОбъекта(СсылкаНаОбъект)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СсылкаНаОбъект", СсылкаНаОбъект);
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	бит_ДополнительныеПараметрыОбъектов.Объект,
	|	бит_ДополнительныеПараметрыОбъектов.ЗапретитьПерезаполнениеАналитик
	|ИЗ
	|	РегистрСведений.бит_ДополнительныеПараметрыОбъектов КАК бит_ДополнительныеПараметрыОбъектов
	|ГДЕ
	|	бит_ДополнительныеПараметрыОбъектов.Объект = &СсылкаНаОбъект
	|";
	РезультатЗапроса = Запрос.Выполнить();

	Возврат РезультатЗапроса;
	
КонецФункции

// Функция получает значение дополнительного параметра объекта.
// 
// Параметры:
//  СсылкаНаОбъект - Любая ссылка.
//  ИмяПараметра   - Строка.
//  
// Возвращаемое значение:
//   Тип.Вид   - описание.
// 
Функция ПолучитьЗначениеДополнительногоПараметраОбъектаПоРезультатуЗапроса(РезультатЗапроса, ИмяПараметра, МетаПараметра)
	
	Если РезультатЗапроса.Пустой() Тогда
		ЗначениеПараметра = Неопределено;
		ЗначениеПараметра = МетаПараметра.Тип.ПривестиЗначение(ЗначениеПараметра);
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ЗначениеПараметра = Выборка[ИмяПараметра];
	КонецЕсли;

	Возврат ЗначениеПараметра;
	
КонецФункции

