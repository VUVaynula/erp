// Процедура заполняет ВидПлатежа в платежном поручении по платежной позиции.
// 
// Параметры:
//  ДокПлатежка - ДокументОбъект.ПлатежноеПоручение
//  ПлатежнаяПозиция - ДокументСсылка.бит_ПлатежнаяПозиция
// 
Процедура ЗаполнитьВидПлатежа(ДокПлатежка, ПлатежнаяПозиция)

	Если ВРег(ПлатежнаяПозиция.ВидПлатежа) = ВРег("Электронно") 
		И ПлатежнаяПозиция.ДатаРасхода >=  Дата('20120709') Тогда
		
		ДокПлатежка.ВидПлатежа 	= "";
		
	Иначе
		
		ДокПлатежка.ВидПлатежа 	= ПлатежнаяПозиция.ВидПлатежа;
		
	КонецЕсли; 
	

КонецПроцедуры // ЗаполнитьВидПлатежа()

Процедура ПрименитьОграниченияПоФункциональнымОпциям(ВидыОпераций)

	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьОбособленныеПодразделенияВыделенныеНаБаланс") Тогда
		УдалитьИзМассива(ВидыОпераций, Перечисления.бит_ВидыОперацийКазначейства.ВнутренняяПередачаДенежныхСредств);
	КонецЕсли;
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьПередачиТоваровМеждуОрганизациями") Тогда
		УдалитьИзМассива(ВидыОпераций, Перечисления.бит_ВидыОперацийКазначейства.ОплатаДенежныхСредствВДругуюОрганизацию);
		УдалитьИзМассива(ВидыОпераций, Перечисления.бит_ВидыОперацийКазначейства.ВозвратДенежныхСредствВДругуюОрганизацию);	
	КонецЕсли; 
	
	бит_КазначействоПереопределяемый.ПрименитьОграниченияВидовОперацийПоФункциональнымОпциям(ВидыОпераций);
	
КонецПроцедуры

Процедура УдалитьИзМассива(Массив, Значение)

	ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(Массив, Значение);

КонецПроцедуры

Функция ЭлементыМассиваВходятВМассив(КонтролируемыеТипыАналитик, ПроверяемыеТипы)

	ЭлементыМассиваВходятВМассив = Ложь;
	Для каждого Элемент Из ПроверяемыеТипы Цикл
		Если КонтролируемыеТипыАналитик.Найти(Элемент) <> Неопределено Тогда
			ЭлементыМассиваВходятВМассив = Истина;	
			Прервать;
		КонецЕсли;	
	КонецЦикла;

	Возврат ЭлементыМассиваВходятВМассив;
	
КонецФункции

// Функция выполняет поиск документа отражения.
//
// Параметры:
//   ДокументОснование - ДокументСсылка.
//
// Возвращаемое значение:
//  Результат - ДокументСсылка.бит_ОтражениеФактаДДС.
//
Функция НайтиДокументОтражения(ДокументОснование) Экспорт

    // ++ ЕРП 
	ДокументОтражение = Документы.бит_ОтражениеФактаДДС.НайтиДокументОтражение(ДокументОснование);	
	Возврат ДокументОтражение;
	// -- ЕРП
	
КонецФункции

Функция ЕстьРасшифровкаПлатежа(Объект, ВидОперации) Экспорт

	ЕстьРасшифровкаПлатежа = бит_РаботаСМетаданными.ЕстьТабЧасть("РасшифровкаПлатежа", Объект.Метаданные());
	
	// См. ФормаДокумента.ИнициализироватьРасшифровкуПлатежа()

	ДокументСсылка			 = Объект.Ссылка;
	МассивРеквизитовОперации = Новый Массив;
	МассивВсехРеквизитов	 = Новый Массив;

	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.СписаниеБезналичныхДенежныхСредств") Тогда
		
		Документы.СписаниеБезналичныхДенежныхСредств.ЗаполнитьИменаРеквизитовПоХозяйственнойОперации(
				Объект, МассивВсехРеквизитов, МассивРеквизитовОперации);
		
		Если МассивРеквизитовОперации.Найти("РасшифровкаПлатежа") = Неопределено
			ИЛИ Документы.СписаниеБезналичныхДенежныхСредств.МассивОперацийБезРасшифровкиПлатежа().Найти(Объект.ХозяйственнаяОперация) <> Неопределено
			И НЕ Объект.ОплатаПоЗаявкам Тогда
			ЕстьРасшифровкаПлатежа = Ложь;
		КонецЕсли;
	
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПоступлениеБезналичныхДенежныхСредств") Тогда
		
		Документы.ПоступлениеБезналичныхДенежныхСредств.ЗаполнитьИменаРеквизитовПоХозяйственнойОперации(
			Объект, МассивВсехРеквизитов, МассивРеквизитовОперации);
		
		Если МассивРеквизитовОперации.Найти("РасшифровкаПлатежа") = Неопределено Тогда
			ЕстьРасшифровкаПлатежа = Ложь;
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходныйКассовыйОрдер") Тогда

		Документы.ПриходныйКассовыйОрдер.ЗаполнитьИменаРеквизитовПоХозяйственнойОперации(
			Объект.ХозяйственнаяОперация, МассивВсехРеквизитов, МассивРеквизитовОперации);
		
		Если МассивРеквизитовОперации.Найти("РасшифровкаПлатежа") = Неопределено Тогда
			ЕстьРасшифровкаПлатежа = Ложь;
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходныйКассовыйОрдер") Тогда

		Документы.РасходныйКассовыйОрдер.ЗаполнитьИменаРеквизитовПоХозяйственнойОперации(
			Объект, МассивВсехРеквизитов, МассивРеквизитовОперации);
		
		Если МассивРеквизитовОперации.Найти("РасшифровкаПлатежа") = Неопределено
			ИЛИ Документы.РасходныйКассовыйОрдер.МассивОперацийБезРасшифровкиПлатежа().Найти(Объект.ХозяйственнаяОперация) <> Неопределено
			И НЕ Объект.ОплатаПоЗаявкам Тогда
			ЕстьРасшифровкаПлатежа = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЕстьРасшифровкаПлатежа;
	
КонецФункции

#КонецОбласти 
