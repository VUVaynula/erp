#Область ДополнительныеАналитикиВДокументахКазначейства

Процедура ЗаполнитьДопАналитикуПоДаннымДокумента(Объект, Реквизиты) Экспорт

	Перем Организация;
	
	Настройки 	= бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	ВГраница 	= бит_МеханизмДопИзмерений.ПолучитьМаксимальноеКоличествоДополнительныхИзмерений();
	
	Реквизиты.Свойство("Организация", Организация);
	
	Для Индекс = 1 По ВГраница Цикл
		
		Настройка = Настройки["Аналитика_" + Индекс];
		Если Настройка = Неопределено Тогда
			Продолжить;		
		КонецЕсли; 
		
		Если НЕ Настройка.ЭтоСоставнойТип Тогда
			Если Настройка.ТипЗначения.СодержитТип(Тип("СправочникСсылка.Организации")) Тогда
				Объект["Аналитика_" + Индекс] = Организация;
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла;
	
КонецПроцедуры

Процедура УстановитьВидимостьНазначенныхАналитик(Форма, ПараметрыУстановки) Экспорт

	Объект	  = Форма.Объект;
	Элементы  = Форма.Элементы;
	Настройки = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	
	ПоляОбъекта = ПараметрыУстановки.ПоляОбъекта;
	ПоляФормы	= ПараметрыУстановки.ПоляФормы;
	
	СтатьяОборотов	= Объект[ПоляОбъекта.СтатьяОборотов];
	РеквизитыСтатьи = Новый Структура;
	Для Номер = 1 По 12 Цикл
		РеквизитыСтатьи.Вставить("Учет_Аналитика_" + Номер, Ложь); 	
	КонецЦикла;
	
	Если ЗначениеЗаполнено(СтатьяОборотов) Тогда
		ИменаРеквизитов = ОбщегоНазначенияКлиентСервер.КлючиСтруктурыВСтроку(РеквизитыСтатьи, ",");	
		РеквизитыСтатьи = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтатьяОборотов, ИменаРеквизитов);
	КонецЕсли;
	
	Для Номер = 1 По 12 Цикл
		Настройка = Настройки["Аналитика_" + Номер];
		Показать  = РеквизитыСтатьи["Учет_Аналитика_" + Номер];
		
		ПолеФормы = "";
		Если ПоляФормы.Свойство("Аналитика_" + Номер, ПолеФормы) Тогда
			ЭлементФормы = Элементы.Найти(ПолеФормы);
			Если ЭлементФормы = Неопределено Тогда
				Продолжить;			
			КонецЕсли;
			Если Настройка = Неопределено Тогда
				Показать = Ложь;
			Иначе
				Если НЕ Настройка.ЭтоСоставнойТип
					И Настройка.ТипЗначения.СодержитТип(Тип("СправочникСсылка.Организации")) Тогда
					Показать = Ложь;
				КонецЕсли;
			КонецЕсли;
			Элементы[ПолеФормы].Видимость = Показать;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

