// Возвращает курс валюты на дату.
//
// Источник: см. РаботаСКурсамивалютУТ.ПолучитьКурсВалютыПоОбъектамРасчетов()
//
// Параметры:
//   Валюта    - Массив из СправочникСсылка.Валюты - валюты, для которых получается курс.
//   ДатаКурса - Дата - дата, на которую получается курс.
//   БазоваяВалюта - СправочникСсылка.Валюты - Валюта, относительно которой необходимо получить курс
//   ОбъектРасчетов - Массив из СправочникСсылка.ОбъектыРасчетов - Объекты расчетов, по которым определяется вариант курса договора
//   
// Возвращаемое значение: 
//   ТаблицаЗначений:
//    * КурсЧислитель    - Число - Числитель курса валюты на указанную дату.
//    * КурсЗнаменатель  - Число - Знаменатель курса валюты на указанную дату.
//    * Валюта           - СправочникСсылка.Валюты - ссылка валюты.
//    * ОбъектРасчетов   - СправочникСсылка.ОбъектыРасчетов - Объект расчетов, по которому определен курс
//    * ДатаКурса        - Дата - дата получения курса.
//    * БазоваяВалюта    - СправочникСсылка.Валюты - Валюта, относительно которой получены  курс.
//
Функция ПолучитьКурсВалютыПоОбъектамРасчетов(Валюты, ДатаКурса, Знач БазоваяВалюта = Неопределено, ОбъектыРасчетов) Экспорт
	
	Если Не ЗначениеЗаполнено(БазоваяВалюта) Тогда
		БазоваяВалюта = ЗначениеНастроекПовтИсп.БазоваяВалютаПоУмолчанию();
	КонецЕсли;
	
	ОбъектыТипаОбъектРасчетов = Новый Массив;
	ОбъектыТипаДоговор 		  = Новый Массив;
	
	РезультатОбъектыРасчетов  = Новый ТаблицаЗначений;
	РезультатОбъектыРасчетов.Колонки.Добавить("ОбъектРасчетов");
	РезультатОбъектыРасчетов.Колонки.Добавить("Валюта");
	РезультатОбъектыРасчетов.Колонки.Добавить("БазоваяВалюта");
	РезультатОбъектыРасчетов.Колонки.Добавить("ДатаКурса");
	РезультатОбъектыРасчетов.Колонки.Добавить("КурсЧислитель");
	РезультатОбъектыРасчетов.Колонки.Добавить("КурсЗнаменатель");

	РезультатДоговоры = РезультатОбъектыРасчетов.СкопироватьКолонки();
	
	Для каждого Элемент Из ОбъектыРасчетов Цикл
		Если ТипЗнч(Элемент) = Тип("СправочникСсылка.ОбъектыРасчетов") Тогда
			ОбъектыТипаОбъектРасчетов.Добавить(Элемент)
		Иначе	
			ОбъектыТипаДоговор.Добавить(Элемент);
		КонецЕсли;	
	КонецЦикла;
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("ВалютаУпр", ЗначениеНастроекПовтИсп.ВалютаУправленческогоУчета());
	Запрос.УстановитьПараметр("Период", ДатаКурса);
	Запрос.УстановитьПараметр("МассивВалют", Валюты);
	Запрос.УстановитьПараметр("ВалютаРегл", БазоваяВалюта);
	
	Если ЗначениеЗаполнено(ОбъектыТипаОбъектРасчетов) Тогда
		Запрос.УстановитьПараметр("ОбъектыРасчетов", ОбъектыТипаОбъектРасчетов);
		Запрос.Текст = ТекстЗапросаКурсовПоОбъектуРасчетов();
		РезультатОбъектыРасчетов = 	Запрос.Выполнить().Выгрузить();	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОбъектыТипаДоговор) Тогда
		Запрос.УстановитьПараметр("ОбъектыРасчетов", ОбъектыТипаДоговор);
		Запрос.Текст = ТекстЗапросаКурсовПоДоговору();
		РезультатДоговоры = Запрос.Выполнить().Выгрузить();
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РезультатДоговоры, РезультатОбъектыРасчетов);
	
	Возврат РезультатОбъектыРасчетов;
	
КонецФункции
	
#КонецОбласти

Функция НовыеПараметрыСозданияПлатежногоДокумента() Экспорт
	
	Параметры = Новый Структура;
	Параметры.Вставить("ДокументОснование");
	Параметры.Вставить("ДатаДокумента", ТекущаяДатаСеанса());
	Параметры.Вставить("ВызовИзРеестра", Ложь);
	Параметры.Вставить("БезПриходника", Ложь);
