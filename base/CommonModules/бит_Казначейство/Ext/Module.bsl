
#Область СлужебныйПрограммныйИнтерфейс

#Область ПодпискиНаСобытия

Процедура ОбработкаПроведенияПлатежногоДокумента(Источник, Отказ, РежимПроведения, ЗаписыватьДвижения = Ложь) Экспорт
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
	
	Если бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_ЭтоЧужойПодчиненныйУзел") = Истина Тогда
		Возврат;
	КонецЕсли; 			
	
	Если НЕ ПолучитьФункциональнуюОпцию("бит_СТ") Тогда
		Возврат;	
	КонецЕсли;  
	
	Документы.бит_ОтражениеФактаДДС.ДвиженияПоРегистрамОтраженияДДС(Источник, Отказ, Ложь);	
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведенияПлатежногоДокумента(Источник, Отказ) Экспорт

	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
	
	Если бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_ЭтоЧужойПодчиненныйУзел") = Истина Тогда
		Возврат;
	КонецЕсли; 			
	
	Если НЕ ПолучитьФункциональнуюОпцию("бит_СТ") Тогда
		Возврат;	
	КонецЕсли;
	
	ОчищаемыеДвижения = Новый Массив;
	ОчищаемыеДвижения.Добавить("бит_кзн_ПланируемыйРасходДенежныхСредств");
	ОчищаемыеДвижения.Добавить("бит_кзн_ПланируемоеПоступлениеДенежныхСредств");
	
	Для каждого ИмяНабора Из ОчищаемыеДвижения Цикл
		Движение = Источник.Движения.Найти(ИмяНабора);
		Если Движение = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Движение.Записать();
	КонецЦикла;
	Документы.бит_ОтражениеФактаДДС.ПриОтменеДвиженийПоРегистрам(Источник, Отказ);	
	
КонецПроцедуры

Процедура ПриЗаписиПлатежногоДокумента(Источник, Отказ) Экспорт
	
	Перем ОтражениеФакта;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
	
	Если бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_ЭтоЧужойПодчиненныйУзел") = Истина Тогда
		Возврат;
	КонецЕсли; 			
	
	Если НЕ ПолучитьФункциональнуюОпцию("бит_СТ") Тогда
		Возврат;	
	КонецЕсли;
	
	Если Источник.ДополнительныеСвойства.Свойство("бит_ЗаполнениеНаОснованииПлана") Тогда
		Возврат;
	КонецЕсли; 
	
	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	РезультатПоиска = Документы.бит_ОтражениеФактаДДС.НайтиДокументОтражение(Источник.Ссылка);
	Если НЕ ЗначениеЗаполнено(РезультатПоиска) Тогда
		// Первоначальное создание документа отражения факта.
		ОтражениеФакта = Документы.бит_ОтражениеФактаДДС.СоздатьДокумент();
		ОтражениеФакта.Заполнить(Источник.Ссылка);
		Документы.бит_ОтражениеФактаДДС.ОбработатьСобытиеПриЗаписиПлатежногоДокумента(ОтражениеФакта, Источник, Отказ);
	Иначе	
		ОтражениеФакта = РезультатПоиска.ПолучитьОбъект();
		Если НЕ ОтражениеФакта.НачатПереходНаНовуюАрхитектуру Тогда	
			Документы.бит_ОтражениеФактаДДС.ОбработатьСобытиеПриЗаписиПлатежногоДокумента(ОтражениеФакта, Источник, Отказ);	
		Иначе
			ОтражениеФакта.ОбработатьПриЗаписиДокументаДДС(Источник.Ссылка);
		КонецЕсли;
	КонецЕсли; 
	ОтражениеФакта.Записать(РежимЗаписиДокумента.Запись);
	
	Если ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.РасходныйКассовыйОрдер") 
	 ИЛИ ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.СписаниеБезналичныхДенежныхСредств") Тогда
		Документы.бит_кзн_РеестрПлатежей.ОбработатьПриЗаписиДокументаДДС(ОтражениеФакта.Ссылка);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

#КонецОбласти

#Область ОбщегоНазначения

Функция ПустоеЗначениеЗаявкаНаРасходованиеСредств() Экспорт

	Возврат Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.ПустаяСсылка();	

КонецФункции

// Функция выполняет валютные пересчеты из валюты ПлатежнойПозиции в валюту платежа. 
// Пересчеты выполняются с учетом условий расчета курсов в ПлатежнойПозиции. 
// Используется в процедуре заполнения платежного документа.
// 
// Параметры:
//  СуммаКОплате  - Сумма
//  ПлатежнаяПозиция  - ДокументСсылка.бит_ПлатежнаяПозиция
//  ДокПлатежка       - ДокументОбъект.ПлатежноеПоручениеИсходящее,ДокументОбъект.РасходныйКассовыйОрдер
// 
// Возвращаемое значение:
//  СуммаПлатежа  - Число
// 
Функция ПересчитатьСуммуПлатежаПоВалюте(СуммаКОплате,ПлатежнаяПозиция,СтруктураПараметров)  Экспорт
// -- NB Неактуально?
	СуммаПлатежа = СуммаКОплате;
	
	Если ПлатежнаяПозиция.ВалютаДокумента = СтруктураПараметров.ВалютаДокумента Тогда
	
		Если ПлатежнаяПозиция.УсловиеПоКурсу = Перечисления.бит_УсловияПоКурсу.ЦБпроц Тогда
			СуммаПлатежа  = СуммаКОплате*(100+ПлатежнаяПозиция.Процент)/100;
		Иначе	
			СуммаПлатежа  = СуммаКОплате;
		КонецЕсли; 
		
	Иначе // Нужен пересчет
		
		СтрКурсаПлатежка     = бит_КурсыВалют.ПолучитьКурсВалюты(СтруктураПараметров.ВалютаДокумента,СтруктураПараметров.Дата);
		// СтрКурсаПозиция      = бит_КурсыВалют.ПолучитьКурсВалюты(ПлатежнаяПозиция.ВалютаДокумента
		// 																,ПлатежнаяПозиция.Дата);
		СтрКурсаПозиция      = бит_КурсыВалют.ПолучитьКурсВалюты(ПлатежнаяПозиция.ВалютаДокумента,СтруктураПараметров.Дата);
		
		
		Если ПлатежнаяПозиция.УсловиеПоКурсу = Перечисления.бит_УсловияПоКурсу.ЦБ Тогда
			
			СуммаПлатежа = бит_КурсыВалютКлиентСервер.ПересчитатьИзВалютыВВалюту(СуммаКОплате
																			,ПлатежнаяПозиция.ВалютаДокумента
																			,СтруктураПараметров.ВалютаДокумента
																			,СтрКурсаПозиция.Курс
																			,СтрКурсаПлатежка.Курс
																			,СтрКурсаПозиция.Кратность
																			,СтрКурсаПлатежка.Кратность);
			
			
		ИначеЕсли ПлатежнаяПозиция.УсловиеПоКурсу = Перечисления.бит_УсловияПоКурсу.ЦБпроц Тогда
			
			СуммаПлатежа = бит_КурсыВалютКлиентСервер.ПересчитатьИзВалютыВВалюту(СуммаКОплате
																			,ПлатежнаяПозиция.ВалютаДокумента
																			,СтруктураПараметров.ВалютаДокумента
																			,СтрКурсаПозиция.Курс
																			,СтрКурсаПлатежка.Курс
																			,СтрКурсаПозиция.Кратность
																			,СтрКурсаПлатежка.Кратность);
			СуммаПлатежа = СуммаПлатежа*(100+ПлатежнаяПозиция.Процент)/100;																	
			
		ИначеЕсли ПлатежнаяПозиция.УсловиеПоКурсу = Перечисления.бит_УсловияПоКурсу.Оператор Тогда
			
			СуммаПлатежа  = бит_КурсыВалютКлиентСервер.ПересчитатьИзВалютыВВалюту(СуммаКОплате
																			,ПлатежнаяПозиция.ВалютаДокумента
																			,СтруктураПараметров.ВалютаДокумента
																			,ПлатежнаяПозиция.КурсДокумента
																			,СтрКурсаПлатежка.Курс
																			,ПлатежнаяПозиция.УдалитьКратностьДокумента
																			,СтрКурсаПлатежка.Кратность);
			
		КонецЕсли;	
		
	КонецЕсли; 
	
    Возврат СуммаПлатежа;
КонецФункции // ПересчитатьСуммуПлатежаПоВалюте()

// Функция выполняет поиск платежного(затратного) документа по платежной(расходной) позиции.
// 
// Параметры:
//  ПлатежнаяПозиция  - бит_ПлатежнаяПозиция, бит_РасходнаяПозиция
// 
// Возвращаемое значение:
// ПлатежныйДокумент   - ДокументСсылка.ПлатежноеПоручениеИсходящее, ДокументСсылка.РасходныйКассовыйОрдер,Неопределено
// 						ДокументСсылка.ПоступлениеТоваров, ДокументСсылка.ПоступлениеДопРасходов, ДокументСсылка.АвансовыйОтчет
// 
Функция НайтиПлатежныйДокументПоПлатежнойПозиции(ПлатежнаяПозиция) Экспорт

	ПлатежныйДокумент = Неопределено;
	
	// Для новой платежной позиции искать документ бессмысленно.
	Если НЕ ЗначениеЗаполнено(ПлатежнаяПозиция) Тогда
		Возврат ПлатежныйДокумент;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	бит_ДополнительныеАналитики.Объект КАК Объект,
	|	1 КАК Приоритет
	|ИЗ
	|	РегистрСведений.бит_ДополнительныеАналитики КАК бит_ДополнительныеАналитики
	|ГДЕ
	|	бит_ДополнительныеАналитики.ЗначениеАналитики = &ПлатежнаяПозиция
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	бит_ДокументыМножественнойОплаты.ДокументОплаты,
	|	2
	|ИЗ
	|	РегистрСведений.бит_ДокументыМножественнойОплаты КАК бит_ДокументыМножественнойОплаты
	|ГДЕ
	|	бит_ДокументыМножественнойОплаты.ПлатежнаяПозиция = &ПлатежнаяПозиция
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет";
				   
	Запрос.УстановитьПараметр("ПлатежнаяПозиция",ПлатежнаяПозиция);			   
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
	
		ПлатежныйДокумент = Выборка.Объект;
	
	КонецЕсли; 
	
    Возврат ПлатежныйДокумент;
КонецФункции // НайтиПлДокументПоПлПозиции()

// Функция находит документы оплаты по переданному массиву платежных позиций.
// 
// Параметры:
// 	ПлатежныеПозиции - Массив - элементы ДокументСсылка.бит_ПлатежнаяПозиция
// 
// Возвращаемое значение:
// 	СоответствиеДокументов - Соответствие - ключ - ДокументСсылка.бит_ПлатежнаяПозиция
// 											значение - произвольная ссылка на документ оплаты
// 
Функция ПолучитьСоответствиеПлатежныхПозицийИДокументовОплаты(ПлатежныеПозиции) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("ПлатежныеПозиции", ПлатежныеПозиции);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫРАЗИТЬ(бит_ДополнительныеАналитики.ЗначениеАналитики КАК Документ.бит_ПлатежнаяПозиция) КАК ПлатежнаяПозиция,
	|	бит_ДополнительныеАналитики.Объект КАК ПлатежныйДокумент
	|ПОМЕСТИТЬ ДокументыОплаты
	|ИЗ
	|	РегистрСведений.бит_ДополнительныеАналитики КАК бит_ДополнительныеАналитики
	|ГДЕ
	|	бит_ДополнительныеАналитики.Аналитика = ЗНАЧЕНИЕ(ПланВидовХарактеристик.бит_ВидыДополнительныхАналитик.ПлатежнаяПозиция)
	|	И бит_ДополнительныеАналитики.ЗначениеАналитики В(&ПлатежныеПозиции)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	бит_ДокументыМножественнойОплаты.ПлатежнаяПозиция,
	|	бит_ДокументыМножественнойОплаты.ДокументОплаты
	|ИЗ
	|	РегистрСведений.бит_ДокументыМножественнойОплаты КАК бит_ДокументыМножественнойОплаты
	|ГДЕ
	|	бит_ДокументыМножественнойОплаты.ПлатежнаяПозиция В(&ПлатежныеПозиции)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументыОплаты.ПлатежнаяПозиция,
	|	ДокументыОплаты.ПлатежныйДокумент
	|ИЗ
	|	ДокументыОплаты КАК ДокументыОплаты
	|
	|СГРУППИРОВАТЬ ПО
	|	ДокументыОплаты.ПлатежнаяПозиция,
	|	ДокументыОплаты.ПлатежныйДокумент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ДокументыОплаты";
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	СоответствиеДокументов = Новый Соответствие;
	
	Пока Выборка.Следующий() Цикл
		
		СоответствиеДокументов.Вставить(Выборка.ПлатежнаяПозиция, Выборка.ПлатежныйДокумент);
		
	КонецЦикла;
	
	Возврат СоответствиеДокументов;
	
КонецФункции

// Функция формирует список доступных для выбора валют в зависимости от валюты договора. 
// Используется в ЗаявкеНаРасходованиеСредств и ПланируемомПоступленииДенежныхСредств.
//
// Параметры:
//  ТекущийОбъект  - ДокументОбъект
//
// Возвращаемое значение:
//   СписокВалют   - СписокЗначений
//
Функция СформироватьСписокДоступныхВалют(ТекущийОбъект) Экспорт

	СписокВалют = Новый СписокЗначений;
	Договор 	= ТекущийОбъект.ДоговорКонтрагента;
	ВалютаРегл  = Константы.ВалютаРегламентированногоУчета.Получить();	
			
	Если ЗначениеЗаполнено(Договор) Тогда
		
		ВалютаВзаиморасчетов = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "ВалютаВзаиморасчетов");
		СписокВалют.Добавить(ВалютаВзаиморасчетов);
		
		Если бит_Договоры.РасчетыВУсловныхЕдиницах(Договор) Тогда
			СписокВалют.Добавить(ВалютаРегл);				
		КонецЕсли;
		
	Иначе
		
		ВыборкаВалюты = Справочники.Валюты.Выбрать();		
		Пока ВыборкаВалюты.Следующий() Цикл			
			СписокВалют.Добавить(ВыборкаВалюты.Ссылка);			
		КонецЦикла; 
		
	КонецЕсли; 	
	
	Возврат СписокВалют;

КонецФункции // СформироватьСписокДоступныхВалют()


// Функция проверяет наличие документов КорректировкаКонтрольныхЗначений 
// 	созданных на основании заявки
// 
// Параметры:
// 	ДокСсылка - ДокументСсылка
// 
// Возвращаемое значение:
// 	ЕстьКорректировка - булево
// 
Функция ЕстьКорректировкаКонтрольныхЗначений(ДокСсылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	бит_КорректировкаКонтрольныхЗначений.Ссылка
	|ИЗ
	|	Документ.бит_КорректировкаКонтрольныхЗначений КАК бит_КорректировкаКонтрольныхЗначений
	|ГДЕ
	|	бит_КорректировкаКонтрольныхЗначений.ДокументОснование = &ДокСсылка";
	
	Запрос.УстановитьПараметр("ДокСсылка", ДокСсылка);
	
	Результат = Запрос.Выполнить();
	
	ЕстьКорректировка = НЕ Результат.Пустой();
	
	Возврат ЕстьКорректировка;
	
КонецФункции

// Функция проверяет допустимость использования статьи оборотов 
// исходя из ТипаСтатьи и направления РасходДоход
// 
// Параметры:
//  СтруктураПараметров  - Структура
//                           СтатьяОборотов - СправочникСсылка.СтатьиОборотов - Обязательный ключ
//                           РасходДоход    - ПеречислениеСсылка.бит_РасходДоход
//                           ТипСтатьи      - ПеречислениеСсылка.бит_ТипыСтатейОборотов
//                           ВыводитьСообщения - Булево
// 
// Возвращаемое значение:
//   флСтатьяКорректна   - Булево
// 
Функция СтатьяОборотовКорректна(СтруктураПараметров)  Экспорт

	флСтатьяКорректна = Истина;	
	ТекстСообщения    = "";
	
	Если ЗначениеЗаполнено(СтруктураПараметров.СтатьяОборотов) Тогда
	
		Если СтруктураПараметров.Свойство("РасходДоход") Тогда		
			Если НЕ СтруктураПараметров.СтатьяОборотов.РасходДоход = СтруктураПараметров.РасходДоход Тогда
				ТекстПромежуточный = НСтр("ru='%1Направление ""%1"" недопустимо в данном контексте.';
							  			  |en='%1The direction ""%2"" is not allowed in this context.'");
				ТекстСообщения = СтрШаблон(ТекстПромежуточный, ТекстСообщения, СтруктураПараметров.РасходДоход) + Символы.ПС;	
				флСтатьяКорректна = Ложь;
			КонецЕсли; 
		КонецЕсли;
		
		Если СтруктураПараметров.Свойство("ТипСтатьи") Тогда		
			Если НЕ СтруктураПараметров.СтатьяОборотов.ТипСтатьи = СтруктураПараметров.ТипСтатьи Тогда
				ТекстПромежуточный = НСтр("ru='%1Тип статьи ""%2"" недопустим в данном контексте.';
							  			  |en='%1The article type ""%2"" is not valid in this context.'");
				ТекстСообщения = СтрШаблон(ТекстПромежуточный, ТекстСообщения, СтруктураПараметров.ТипСтатьи);
				флСтатьяКорректна = Ложь;
			КонецЕсли; 
		КонецЕсли;
		
		Если СтруктураПараметров.Свойство("ВыводитьСообщения") И СтруктураПараметров.ВыводитьСообщения Тогда
			Если НЕ ПустаяСтрока(ТекстСообщения) Тогда
			    ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,, "Объект.СтатьяОборотов"); 
			КонецЕсли; 
		КонецЕсли; // Нужно вывести сообщения пользователю
		
	КонецЕсли; // Заполнена СтатьяОборотов

	Возврат флСтатьяКорректна;
	
КонецФункции // СтатьяОборотовКорректна()

// Процедура проверяет возможность проведения позиций и заявок.
//
// Параметры:
//  Ссылка            - ДокументОбъект.бит_ПлатежнаяПозиция, ДокументОбъект.бит_ПозицияПоступления,
//                      ДокументОбъект.бит_ЗаявкаНаРасходованиеСредств.
//  Статус            - текущий статус объекта
//
Процедура ПроверитьВозможностьПроведения(Ссылка, Статус, Отказ) Экспорт
	
	Заголовок  = СтрШаблон(НСтр("ru='Отмена проведения документа: %1';en='Cancellation of document posting: %1'"),
						СокрЛП(Ссылка));
	ТипСтатуса = Справочники.бит_СтатусыОбъектов.ТипСтатусаОбъкта(Статус);
	
	Если ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.Закрыт Тогда

		Отказ = Истина;
		ТекстСообщения = СтрШаблон(НСтр("ru='Документу в статусе ""%1"" запрещено проведение(отмена проведения)';
								   		|en='Document in status ""%1"" is prohibited from posting (cancellation of posting)'"), 
								   СокрЛП(Статус));
		ОбщегоНазначения.СообщитьПользователю(Заголовок);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);

	КонецЕсли; 

	Если ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.Исполнен
		ИЛИ ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен Тогда   

		Отказ = Истина;
		ТекстСообщения = СтрШаблон(НСтр("ru='Документ в статусе ""%1"". Отмена проведения невозможна.';
								   		|en='Document in status ""%1"". Cancellation is not possible.'"), 
								   СокрЛП(Статус));
		ОбщегоНазначения.СообщитьПользователю(Заголовок);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);

	КонецЕсли; 
	
КонецПроцедуры

// Процедура заполняет ресурс "СуммаОплаты" в регистрах ДДС,
// с разворотом по аналитике.
//
Процедура ЗаполнитьРесурсСуммаОплаты( РегистрНакопления, РегистрНакопленияИмя) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ОборотыРегистра.Регистратор
			|ИЗ
			|	РегистрНакопления."+РегистрНакопленияИмя+" КАК ОборотыРегистра
			|ГДЕ
			|	ОборотыРегистра.СуммаОплаты = 0";
			
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Набор = РегистрНакопления.СоздатьНаборЗаписей();
		Набор.Отбор.Регистратор.Установить(Выборка.Регистратор);
		Набор.Прочитать();
		
		// изменение существующих записей
		Для Каждого Движение Из Набор Цикл
			
			Если ЗначениеЗаполнено(Движение.БанковскийСчет) Тогда
				
				СтруктураКурсыВалютДокумент = бит_КурсыВалют.ПолучитьКурсВалюты(Движение.Валюта, Движение.Период);
				СтрКурсаБанковскийСчетКасса = бит_КурсыВалют.ПолучитьКурсВалюты(Движение.БанковскийСчет.ВалютаДенежныхСредств, Движение.Период);
				
				Движение.СуммаОплаты = бит_КурсыВалют.ПересчитатьПоВалюте(Движение.Сумма, СтруктураКурсыВалютДокумент, СтрКурсаБанковскийСчетКасса);
				
			Иначе
				
				Движение.СуммаОплаты = Движение.Сумма;
				
			КонецЕсли;
			
	    КонецЦикла;
		
		Набор.Записать(Истина);
		
	КонецЦикла;
	
КонецПроцедуры  //ЗаполнитьРесурсСуммаОплаты()

// Функция возвращает договор объекта расчетов.
//
// Параметры: МетаОбъект - ОбъектМетаданных.
//
// Возвращаемое значение:
//  СправочникСсылка.ДоговорыКонтрагентов или СправочникСсылка.ДоговорыКредитовИДепозитов
//  или СправочникСсылка.ДоговорыАренды 
//  или СправочникСсылка.СоглашенияСКлиентами или СправочникСсылка.СоглашенияСПоставщиками.
//
Функция ДоговорОбъектаРассчетов(ОбъектРасчетов) Экспорт 
	
	Договор = Неопределено;
	
	Если ЗначениеЗаполнено(ОбъектРасчетов) Тогда
	
		Если ТипЗнч(ОбъектРасчетов) = Тип("СправочникСсылка.ДоговорыКонтрагентов") 
			ИЛИ ТипЗнч(ОбъектРасчетов) = Тип("СправочникСсылка.ДоговорыКредитовИДепозитов")
			ИЛИ (бит_ОбщегоНазначенияКлиентСерверПереопределяемый.ЕстьДоговорыАренды()
			 	 И ТипЗнч(ОбъектРасчетов) = Тип("СправочникСсылка.ДоговорыАренды"))
	        ИЛИ ТипЗнч(ОбъектРасчетов) = Тип("СправочникСсылка.СоглашенияСКлиентами")
			ИЛИ ТипЗнч(ОбъектРасчетов) = Тип("СправочникСсылка.СоглашенияСПоставщиками") Тогда			
			Договор = ОбъектРасчетов;
		Иначе
			Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектРасчетов, "Договор");
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Договор;
	
КонецФункции

Функция ВалютыРассчетов(ОбъектРасчетов, БанковскийСчетКасса, ВалютаДокумента) Экспорт
	
	//ВызватьИсключение "бит_Казначейство.ВалютыРассчетов() NB Устареет после внедрения валюты взаиморасчетов в позиции.";
	
	// -- NB Устареет после внедрения валюты взаиморасчетов в позиции.
	ВалютаОплаты		 = ВалютаДокумента;
	ОплатаВВалюте 		 = Ложь;
	ВалютаВзаиморасчетов = ВалютаОплаты;
	
	Если ЗначениеЗаполнено(БанковскийСчетКасса)
		И ЗначениеЗаполнено(ОбъектРасчетов) Тогда

		ВалютаОплаты = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БанковскийСчетКасса, "ВалютаДенежныхСредств");
		ДоговорОбъектаРассчетов = ДоговорОбъектаРассчетов(ОбъектРасчетов);
			
		Если ЗначениеЗаполнено(ДоговорОбъектаРассчетов) Тогда
			РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДоговорОбъектаРассчетов, 
									"ВалютаВзаиморасчетов, ОплатаВВалюте");
			ВалютаВзаиморасчетов = РеквизитыДоговора.ВалютаВзаиморасчетов;
			ОплатаВВалюте 		 = РеквизитыДоговора.ОплатаВВалюте;
		КонецЕсли;

	ИначеЕсли ЗначениеЗаполнено(БанковскийСчетКасса)
		И НЕ ЗначениеЗаполнено(ОбъектРасчетов) Тогда	
		
		ВалютаОплаты = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БанковскийСчетКасса, "ВалютаДенежныхСредств");
		ВалютаВзаиморасчетов = ВалютаДокумента;
		
	ИначеЕсли НЕ ЗначениеЗаполнено(БанковскийСчетКасса)
		И ЗначениеЗаполнено(ОбъектРасчетов) Тогда	
		
		ДоговорОбъектаРассчетов = ДоговорОбъектаРассчетов(ОбъектРасчетов);
		
		Если ЗначениеЗаполнено(ДоговорОбъектаРассчетов) Тогда
			РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДоговорОбъектаРассчетов, 
									"ВалютаВзаиморасчетов, ОплатаВВалюте");
			ВалютаВзаиморасчетов = РеквизитыДоговора.ВалютаВзаиморасчетов;
			ОплатаВВалюте 		 = РеквизитыДоговора.ОплатаВВалюте;
			Если ОплатаВВалюте Тогда
				ВалютаОплаты = РеквизитыДоговора.ВалютаВзаиморасчетов;	
			Иначе	
				ВалютаОплаты = Константы.ВалютаРегламентированногоУчета.Получить();
			КонецЕсли;
		КонецЕсли;
	Иначе
		ВалютаОплаты = ВалютаДокумента;	
	КонецЕсли; 
	
	ПорядокОплаты = Новый Структура;
	ПорядокОплаты.Вставить("ВалютаОплаты", 		   ВалютаОплаты);
	ПорядокОплаты.Вставить("ВалютаВзаиморасчетов", ВалютаВзаиморасчетов);
	ПорядокОплаты.Вставить("ОплатаВВалюте", 	   ОплатаВВалюте);
	
	Возврат ПорядокОплаты;
	
КонецФункции

//  Функция вызывает типовую проверку заполнения реквизитов
//  платежного документа, если требуется.
//
// Параметры:
// 	ДокОб - ДокументОбъект.
//  РежимЗаписи - РежимЗаписиДокумента.
//
// Возвращаемое значение:
//  ПроверкаУспешна - Булево.
//
Функция ПроверитьЗаполнениеПлатежногоДокумента(ДокОб, РежимЗаписи, ЗаписыватьПередПроведением = Истина) Экспорт

	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		Если ЗаписыватьПередПроведением Тогда		
			бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ДокОб, РежимЗаписиДокумента.Запись,, "Ошибки");		
		КонецЕсли; 
		
		ТекстСообщения = Нстр("ru='Выполнение проведения документа %1';en='Execution of document %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ДокОб.Ссылка);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);				  
		ПроверкаУспешна = ДокОб.ПроверитьЗаполнение();
		
		Если НЕ ПроверкаУспешна Тогда		
			ТекстСообщения = Нстр("ru='Не удалость провести документ %1';en='Do not remove document %1'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ДокОб.Ссылка);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		
		КонецЕсли;
		
	Иначе	
		ПроверкаУспешна = Истина;
	КонецЕсли; 

	Возврат ПроверкаУспешна;
	
КонецФункции // ПроверитьЗаполнениеПлатежногоДокумента()

//  Функция устанавливает отборы для банковских счетов и касс
//  из данных платежной позиции. 
//
// Параметры:
// 	Организация - СправочникСсылка.Организации.
//  Валюта - СправочникСсылка.Валюты.
//  ДокументПланирования - ДокументСсылка.
//  ВалютаРегл - СправочникСсылка.Валюты (валюта регламентированного учета).
//
// Возврат:
//  ПараметрВыбораИтог - ФиксированныйМассив.
//
Функция УстановитьОтборыДляБанковскихСчетовКасс(Организация, Валюта, ДокументПланирования, ВалютаРегл) Экспорт

	// Подготовка параметров выбора по валюте.
	ОтборВалюта = Новый Массив();
	Если ТипЗнч(ДокументПланирования) <> Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию")
		И ТипЗнч(ДокументПланирования) <> Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда

		ОтборВалюта.Добавить(ВалютаРегл);
	КонецЕсли;
	ОтборВалюта.Добавить(Валюта);
	ПараметрыОтбора = Новый ФиксированныйМассив(ОтборВалюта);
	ПараметрВыбораВалюта  = Новый ПараметрВыбора("Отбор.ВалютаДенежныхСредств", ПараметрыОтбора);

	// Подготовка параметров выбора по организации.
	ОтборОрганизация = Новый Массив();
	ОтборОрганизация.Добавить(Организация);
	Если Организация.ДопускаютсяВзаиморасчетыЧерезГоловнуюОрганизацию Тогда
		ОтборОрганизация.Добавить(Организация.ГоловнаяОрганизация);
	КонецЕсли; 
	ПараметрыОтбора = Новый ФиксированныйМассив(ОтборОрганизация);
	ПараметрВыбораОрганизация  = Новый ПараметрВыбора("Отбор.Владелец", ПараметрыОтбора);
	
	// Формирование итогового отбора.
	ОтборИтог = Новый Массив;
	ОтборИтог.Добавить(ПараметрВыбораОрганизация);
	ОтборИтог.Добавить(ПараметрВыбораВалюта);
	ПараметрВыбораИтог = Новый ФиксированныйМассив(ОтборИтог);
	
	Возврат ПараметрВыбораИтог;
	
КонецФункции // УстановитьОтборыДляБанковскихСчетовКасс()

Функция ЗаявкаПоДаннымОтраженияФакта(ДокументСписание) Экспорт
	
	ЗаявкаНаРасходДС = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументОснование", ДокументСписание);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ПлатежныеПозиции.ДокументПланирования КАК ДокументПланирования
	|ИЗ
	|	Документ.бит_ОтражениеФактаДДС.ФактическиеДанные КАК ФактическиеДанные
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|		ПО ФактическиеДанные.Позиция = ПлатежныеПозиции.Ссылка
	|ГДЕ
	|	ФактическиеДанные.Ссылка.ДокументОснование = &ДокументОснование";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка			 = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаявкаНаРасходДС = Выборка.ДокументПланирования;
	КонецЕсли;
	
	Возврат ЗаявкаНаРасходДС;
	
КонецФункции

#КонецОбласти

#Область РегламентныеЗадания

// Обработчик регламентного задания "бит_СоздатьДокументыПланированияИзДопУсловий".
// Создает документы плаинрования из доп. условий по договору.
// 
// Параметры:
//  СтруктураПараметров - Структура.
//
Процедура СоздатьДокументыПланированияИзДопУсловий(СтруктураПараметров = Неопределено) Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.бит_СоздатьДокументыПланированияИзДопУсловий);
	
	// Проверим корректность переданых параметров.
	Если НЕ ТипЗнч(СтруктураПараметров) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("СоздаватьЗаявкаНаРасходованиеДС") Тогда
		СоздаватьЗаявкиДС               = СтруктураПараметров.СоздаватьЗаявкаНаРасходованиеДС;
		ЗаявкаНаРасходованиеДСДни       = СтруктураПараметров.ЗаявкаДни;
	Иначе
		Возврат;
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("СоздаватьПланируемоеПоступлениеДС") Тогда
		СоздаватьПланируемоеПоступление = СтруктураПараметров.СоздаватьПланируемоеПоступлениеДС;
		ПланируемоеПоступлениеДни       = СтруктураПараметров.ПланируемоеПоступлениеДни;
	Иначе
		Возврат;
	КонецЕсли;
		
	Если СтруктураПараметров.Свойство("СоздаватьПрогнозПлатежа") Тогда
		СоздаватьПрогнозПлатежа         = СтруктураПараметров.СоздаватьПрогнозПлатежа;
		ПрогнозПлатежаДни               = СтруктураПараметров.ПрогнозПлатежаДни;
	Иначе
		Возврат;
	КонецЕсли;

	Если СтруктураПараметров.Свойство("РежимЗаписи") Тогда
		РежимЗаписи = СтруктураПараметров.РежимЗаписи;
	Иначе
		Возврат;
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("ДатаНачала") Тогда
		ДатаНачала = СтруктураПараметров.ДатаНачала;
	Иначе
		Возврат;
	КонецЕсли;
	
	ВидДокументаЗаявка = Перечисления.бит_кзн_ВидыПланов.ПустаяСсылка();

	Если СоздаватьЗаявкиДС Тогда
		ВидДокументаЗаявка =  Перечисления.бит_кзн_ВидыПланов.План; 
		КоличествоДней     = ЗаявкаНаРасходованиеДСДни;
	ИначеЕсли СоздаватьПрогнозПлатежа Тогда
		ВидДокументаЗаявка =  Перечисления.бит_кзн_ВидыПланов.Прогноз; 
		КоличествоДней     = ПрогнозПлатежаДни;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бит_ДополнительныеУсловияПоДоговору.Ссылка КАК ДокДУ
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК бит_СтатусыОбъектов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_ДополнительныеУсловияПоДоговору КАК бит_ДополнительныеУсловияПоДоговору
	|		ПО бит_СтатусыОбъектов.Объект = бит_ДополнительныеУсловияПоДоговору.Ссылка
	|			И (бит_ДополнительныеУсловияПоДоговору.Дата >= &ДатаНачала)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_СтатусыОбъектов КАК СтатусыОбъектов
	|		ПО бит_СтатусыОбъектов.Статус = СтатусыОбъектов.Ссылка
	|			И (СтатусыОбъектов.ТипСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ТипыСтатусовОбъектов.Утвержден))";
	
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	
	Результат = Запрос.Выполнить();
	
	ВыборкаДокументов = Результат.Выбрать();
	
	Пока ВыборкаДокументов.Следующий() Цикл
		
		ДокДопУсловие = ВыборкаДокументов.ДокДУ;
		
		ДокОбъект = ДокДопУсловие.ПолучитьОбъект();
				
		Если СоздаватьЗаявкиДС ИЛИ СоздаватьПрогнозПлатежа ИЛИ СоздаватьПланируемоеПоступление Тогда
	
	        СтруктураОтбора = Новый Структура;
			СтруктураОтбора.Вставить("ДокументПланирования", Неопределено);
			
			МассивСтроксОтбором = ДокДопУсловие.ГрафикПлатежей.НайтиСтроки(СтруктураОтбора);

			МассивСтрок = Новый Массив;
			
			Для Инд = 0 По МассивСтроксОтбором.ВГраница() Цикл
				Если МассивСтроксОтбором[Инд].РасходДоход = Перечисления.бит_РасходДоход.Расходование Тогда
					Если ТекущаяДатаСеанса() >= МассивСтроксОтбором[Инд].Период  - КоличествоДней *24*60*60 Тогда
						МассивСтрок.Добавить(МассивСтроксОтбором[Инд]);
					КонецЕсли;
				Иначе
					Если ТекущаяДатаСеанса() >= МассивСтроксОтбором[Инд].Период - ПланируемоеПоступлениеДни *24*60*60 Тогда
						МассивСтрок.Добавить(МассивСтроксОтбором[Инд]);
					КонецЕсли;
				КонецЕсли;
				Инл = Инд +1;
			КонецЦикла;
			
			// Проверим заполненность реквизитов шапки документа.
			Если ДокОбъект.РеквизитыЗаполненыДляСозданияДокументовПланирования("ГрафикПлатежей", МассивСтрок, "Ошибки") Тогда
				Если МассивСтрок.Количество() > 0  Тогда 
					ДокОбъект.СоздатьДокументыПланирования("ГрафикПлатежей", МассивСтрок, ВидДокументаЗаявка, РежимЗаписиДокумента[РежимЗаписи], "Ошибки");
				КонецЕсли;
			КонецЕсли;
				  
		КонецЕсли;
		
	КонецЦикла;
			
КонецПроцедуры
	
// Обработчик регламентного задания "бит_СозданиеДокументовПланирования". Создает документы планирования.
