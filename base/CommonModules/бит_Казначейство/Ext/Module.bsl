	Возврат ВидыОпераций;
	
КонецФункции

Функция ПодготовитьПараметрыВидимости(ВидОперации) Экспорт
	
	Возврат бит_КазначействоКлиентСервер.ПодготовитьПараметрыВидимости(ВидОперации);
	
КонецФункции

Процедура ДополнитьНазначениеПлатежаСуммой(ТекущийОбъект) Экспорт
	
	ТекстСумма	  = СтрШаблон(НСтр("en = 'Amount %1'; ru = 'Сумма %1'"), Формат(ТекущийОбъект.СуммаДокумента, "ЧДЦ=2; ЧРД=-; ЧН=0-00; ЧГ="));
	ТекстСуммаНДС = ДенежныеСредстваСервер.ТекстСуммаНДСПлатежа(ТекущийОбъект.Организация, ТекущийОбъект.Валюта, 
																ТекущийОбъект.РасшифровкаПлатежа, Истина);
	ТекущийОбъект.НазначениеПлатежа = ТекущийОбъект.НазначениеПлатежа + Символы.ПС + ТекстСумма + Символы.ПС + ТекстСуммаНДС;
	
КонецПроцедуры

// Заполняет реквизит объект расчетов типа СправочникСсылка.ОбъектыРасчетов
//  выполнив поиск элемента справочника соответствующего значению 
//  устаревшего реквизита УдалитьОбъектРасчетов или ОснованиеПлатежа.
//
Процедура ЗаполнитьОбъектыРасчетов(ДокументОбъект, ОбъектИзменен, ПутьКДанным = "") Экспорт 
	
	ПолноеИмя = ДокументОбъект.Метаданные().ПолноеИмя();
	ПутьСтарыйОбъектРасчетов = "Таблица.УдалитьОбъектРасчетов";
	
	Если НЕ ПустаяСтрока(ПутьКДанным) Тогда
		ЧастиПути = СтрРазделить(ПутьКДанным, ".");
		Если ЧастиПути.Количество() <> 2 Тогда
			ВызватьИсключение НСтр("ru='Ошибка описания реквизита при заполнении объект расчетов.;
								   |en='Error in the description of the variable when filling out the calculation object.'") ;
		Иначе
			ПутьСтарыйОбъектРасчетов = ЧастиПути[1];	
		КонецЕсли;
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОбъектыРасчетов.Ссылка КАК ОбъектРасчетов
	|ИЗ
	|	&Таблица КАК Таблица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
	|		ПО ОбъектыРасчетов.Объект = &СтарыйОбъектРасчетов
	|ГДЕ
	|	Таблица.Ссылка = &Ссылка";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Таблица", ПолноеИмя);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&СтарыйОбъектРасчетов", ПутьСтарыйОбъектРасчетов);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументОбъект.Ссылка);
	Запрос.Текст = ТекстЗапроса;
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ДокументОбъект.ОбъектРасчетов = ВыборкаДетальныеЗаписи.ОбъектРасчетов;
		ОбъектИзменен = Истина;
	КонецЦикла;
	
КонецПроцедуры

// Процедура управляет видимостью полей назначенных аналитик.
// 
Процедура ВидимостьНазначенныхАналитик(Форма) Экспорт 

	Объект	  = Форма.Объект;
	Элементы  = Форма.Элементы;
	Настройки = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	
	СкрываемыеТипыАналитик = Новый Массив;
	СкрываемыеТипыАналитик.Добавить(Тип("СправочникСсылка.ДоговорыКредитовИДепозитов"));
	Если бит_ОбщегоНазначенияКлиентСерверПереопределяемый.ЕстьДоговорыАренды() Тогда
		СкрываемыеТипыАналитик.Добавить(Тип("СправочникСсылка.ДоговорыАренды"));
	КонецЕсли;
	СкрываемыеТипыАналитик.Добавить(Тип("СправочникСсылка.ДоговорыКонтрагентов"));
	СкрываемыеТипыАналитик.Добавить(Тип("СправочникСсылка.ДоговорыМеждуОрганизациями"));
	СкрываемыеТипыАналитик.Добавить(Тип("СправочникСсылка.БанковскиеСчетаКонтрагентов"));
	СкрываемыеТипыАналитик.Добавить(Тип("СправочникСсылка.БанковскиеСчетаОрганизаций"));
	СкрываемыеТипыАналитик.Добавить(Тип("СправочникСсылка.Кассы"));
	СкрываемыеТипыАналитик.Добавить(Тип("СправочникСсылка.Контрагенты"));

	ОснованиеОбъектаРасчетов 	= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ОбъектРасчетов, "Объект");
	ТипОснованиеОбъектаРасчетов = ТипЗнч(ОснованиеОбъектаРасчетов);
	
	ИменаРеквизитов = Новый Массив;
	РеквизитыСтатьи = Новый Структура;
	Для каждого Настройка Из Настройки Цикл
		ИмяРеквизита = СтрШаблон("Учет_%1", Настройка.Ключ);
		ИменаРеквизитов.Добавить(ИмяРеквизита);
		РеквизитыСтатьи.Вставить(ИмяРеквизита, Ложь);
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Объект.СтатьяОборотов) Тогда
		РеквизитыСтатьи = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.СтатьяОборотов, ИменаРеквизитов); 
	КонецЕсли;
	
	Для каждого Настройка Из Настройки Цикл
		
		ИмяРеквизита = СтрШаблон("Учет_%1", Настройка.Ключ);
		Если Настройка.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.Организации")) Тогда 
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Элементы, Настройка.Ключ) Тогда
				Элементы[Настройка.Ключ].Видимость = Ложь;
			КонецЕсли;
			Если РеквизитыСтатьи[ИмяРеквизита] Тогда
				Объект[Настройка.Ключ] = Объект.Организация;
			Иначе	
				Объект[Настройка.Ключ] = Справочники.Организации.ПустаяСсылка();
			КонецЕсли; 
		КонецЕсли;	
		
		ПроверяемыеТипы = Настройка.Значение.ТипЗначения.Типы();
		Если ЭлементыМассиваВходятВМассив(СкрываемыеТипыАналитик, ПроверяемыеТипы) Тогда
			
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Элементы, Настройка.Ключ) Тогда
				Элементы[Настройка.Ключ].Видимость = Ложь;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ОснованиеОбъектаРасчетов)
				И ПроверяемыеТипы.Найти(ТипОснованиеОбъектаРасчетов) <> Неопределено Тогда
				РеквизитОбъекта = ОснованиеОбъектаРасчетов;
			ИначеЕсли Настройка.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.БанковскиеСчетаКонтрагентов")) Тогда
				РеквизитОбъекта = Объект.БанковскийСчетПолучателя;
			ИначеЕсли Настройка.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.БанковскиеСчетаОрганизаций")) Тогда
				РеквизитОбъекта = Объект.БанковскийСчет;
			ИначеЕсли Настройка.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.Кассы")) Тогда
				РеквизитОбъекта = Объект.Касса;
			ИначеЕсли Настройка.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.Контрагенты")) Тогда
				РеквизитОбъекта = Объект.Контрагент;
			Иначе
				РеквизитОбъекта = Настройка.Значение.ТипЗначения.ПривестиЗначение(Объект[Настройка.Ключ]);
			КонецЕсли;
			
			Если РеквизитыСтатьи[ИмяРеквизита] Тогда
				Объект[Настройка.Ключ] = РеквизитОбъекта;
			Иначе	
				Объект[Настройка.Ключ] = Настройка.Значение.ТипЗначения.ПривестиЗначение();
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;	
		
КонецПроцедуры

Процедура ПроверитьПлатежныеПозицииИзРеестраПоИсточникуВызова(ПлатежныеПозиции, Настройки, Отказ) Экспорт

	ТолькоИзРеестра = ПолучитьФункциональнуюОпцию("бит_ОплатаЗаявокНаРасходованиеДСТолькоИзРеестра");
	ВызовИзРеестра  = Настройки.ВызовИзРеестра;
	
	Если ТолькоИзРеестра И НЕ ВызовИзРеестра Тогда
		ТекстСообщения = НСтр("ru = 'Документы оплачиваются только из реестра.'; 
							|en = 'Documents are paid only from the registry.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , ,Отказ); 
	КонецЕсли;

КонецПроцедуры

// Функция получает плановую и фактическую сумму оплат по платежным позициям.
// 
// Параметры:
//  Заявка			  - ДокументСсылка.бит_ПлатежнаяПозиция, Массив.
//  ПлатежныйДокумент - Платежный документ ссылка. По умолчанию Неопределено.
// 
// Возвращаемое значение:
//   РезСтруктура - 1. Структура 	- Заявка - ДокументСсылка.бит_ПлатежнаяПозиция.
//                  2. Соответствие - Заявка - Массив.
// 
Функция ПолучитьОплатыПоПлатежнойПозиции(ПлатежнаяПозиция) Экспорт
	
	Если ТипЗнч(ПлатежнаяПозиция) = Тип("Массив") Тогда
		ПлатежныеПозиции = ПлатежнаяПозиция;
	Иначе
		ПлатежныеПозиции = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПлатежнаяПозиция);
	КонецЕсли;
	
	// Сформируем текст запроса по получению оплаты.
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПланируемыйРасход.Позиция КАК ПлатежнаяПозиция,
	|	СУММА(ПланируемыйРасход.СуммаПриход) КАК СуммаПлан,
	|	СУММА(ПланируемыйРасход.СуммаРасход) КАК СуммаОплата,
	|	СУММА(ПланируемыйРасход.СуммаКонечныйОстаток) КАК Разность
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.ОстаткиИОбороты(, , , , Позиция В (&ПлатежныеПозиции)) КАК ПланируемыйРасход
	|
	|СГРУППИРОВАТЬ ПО
	|	ПланируемыйРасход.Позиция
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПланируемоеПоступление.Позиция,
	|	СУММА(ЕСТЬNULL(ПланируемоеПоступление.СуммаПриход, 0)),
	|	СУММА(ЕСТЬNULL(ПланируемоеПоступление.СуммаРасход, 0)),
	|	СУММА(ЕСТЬNULL(ПланируемоеПоступление.СуммаКонечныйОстаток, 0))
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ОстаткиИОбороты(, , , , Позиция В (&ПлатежныеПозиции)) КАК ПланируемоеПоступление
	|
	|СГРУППИРОВАТЬ ПО
	|	ПланируемоеПоступление.Позиция";
	Запрос = Новый Запрос;
	Запрос.Текст 	 = ТекстЗапроса;
	Запрос.УстановитьПараметр("ПлатежныеПозиции", ПлатежныеПозиции);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	// Формирование результата по всем документам.
	ДокументыПланирования = Новый Соответствие;
	Для каждого Элемент Из ПлатежныеПозиции Цикл
		ОстаткиИОбороты = Новый Структура;
		ОстаткиИОбороты.Вставить("СуммаПлан",    0);
		ОстаткиИОбороты.Вставить("СуммаОплата",  0);
		ОстаткиИОбороты.Вставить("СуммаЗакрыта", 0);
		ОстаткиИОбороты.Вставить("Разность", 	 0);
		ДокументыПланирования.Вставить(Элемент, ОстаткиИОбороты);
	КонецЦикла; 
	
	ВыборкаИзЗапроса = РезультатЗапроса.Выбрать();
	Пока ВыборкаИзЗапроса.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДокументыПланирования[ВыборкаИзЗапроса.ПлатежнаяПозиция], ВыборкаИзЗапроса);
	КонецЦикла;
	
	Если ТипЗнч(ПлатежнаяПозиция) = Тип("Массив") Тогда
		ОплатыПоПозиции = ДокументыПланирования;
	Иначе
		ОплатыПоПозиции = ДокументыПланирования.Получить(ПлатежнаяПозиция);
	КонецЕсли;
	
	Возврат ОплатыПоПозиции;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПроцедурыИФункцииРаботыСВалютамиУТ

// Функция получает коэффициенты пересчета сумм из валюты документа в валюту взаиморасчетов,
// в валюты управленческого и регламентированного учета.
//
// Источник: см. РаботаСКурсамивалютУТ.ПолучитьКоэффициентыПересчетаВалюты()
//
// Параметры:
//	ВалютаДокумента - СправочникСсылка.Валюты - Валюта документа
//	ВалютаВзаиморасчетов - СправочникСсылка.Валюты - Валюта взаиморасчетов документа
//	Период - Дата - Дата документа
//	Организация - СправочникСсылка.Организации - Организация документа
//	КурсЧислительДокумента - Число - Необязательный, курс-числитель валюты документа
//	КурсЗнаменательДокумента - Число - Необязательный, курс-знаменатель валюты документа.
//	ОбъектРасчетов - СправочникСсылка.ОбъектыРасчетов - Необязательный,Объект расчетов для определения источника курса валюты.
//
// Возвращаемое значение:
//   Структура - Параметры курса валюты:
//	   * КоэффициентПересчетаВВалютуВзаиморасчетов 	- Число - Коэффициент пересчета в валюту взаиморасчетов.
//	   * КоэффициентПересчетаВВалютуУПР 			- Число - Коэффициент пересчета в валюту управленческого учета.
//	   * КоэффициентПересчетаВВалютуРегл 			- Число - Коэффициент пересчета в валюту регламентированного учета.
//
Функция ПолучитьКоэффициентыПересчетаВалюты(ВалютаДокумента, ВалютаВзаиморасчетов, Период, Организация, 
		КурсЧислительДокумента = Неопределено, КурсЗнаменательДокумента = Неопределено, ОбъектРасчетов = Неопределено) Экспорт

	ВалютаУпр  = Константы.бит_ВалютаУправленческогоУчета.Получить();
	ВалютаРегл = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Организация);
	
	Запрос = Новый Запрос;
	Если ЗначениеЗаполнено(ОбъектРасчетов) Тогда
		МассивВалют = Новый Массив;
		МассивВалют.Добавить(ВалютаДокумента);
		МассивВалют.Добавить(ВалютаВзаиморасчетов);
		МассивВалют.Добавить(ВалютаУпр);
		МассивВалют.Добавить(ВалютаРегл);
		ТаблицаКурсов = ПолучитьКурсВалютыПоОбъектамРасчетов(
			МассивВалют, 
			Период, 
			ВалютаРегл, 
			ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ОбъектРасчетов));
	Иначе
		ТекстЗапроса = "
			|ВЫБРАТЬ
			|	ОтносительныеКурсыВалют.Валюта КАК Валюта,
			|	ОтносительныеКурсыВалют.КурсЧислитель КАК КурсЧислитель,
			|	ОтносительныеКурсыВалют.КурсЗнаменатель КАК КурсЗнаменатель
			|ИЗ
			|	РегистрСведений.ОтносительныеКурсыВалют.СрезПоследних(&Период,
			|		(Валюта = &ВалютаУпр ИЛИ Валюта = &ВалютаРегл ИЛИ Валюта = &ВалютаВзаиморасчетов ИЛИ Валюта = &ВалютаДокумента) И БазоваяВалюта = &ВалютаРегл
			|	) КАК ОтносительныеКурсыВалют
			|";
		Запрос.УстановитьПараметр("ВалютаДокумента",      ВалютаДокумента);
		Запрос.УстановитьПараметр("ВалютаВзаиморасчетов", ВалютаВзаиморасчетов);
		Запрос.УстановитьПараметр("Период",     Период);
		Запрос.УстановитьПараметр("ВалютаУпр",  ВалютаУпр);
		Запрос.УстановитьПараметр("ВалютаРегл", ВалютаРегл);
		Запрос.Текст = ТекстЗапроса;
		ТаблицаКурсов = Запрос.Выполнить().Выгрузить();
	КонецЕсли;

	КурсЧислительВалютыУпр = 1;
	КурсЗнаменательВалютыУпр = 1;

	КурсЧислительВалютыРегл = 1;
	КурсЗнаменательВалютыРегл = 1;

	КурсЧислительВзаиморасчетов = 1;
	КурсЗнаменательВзаиморасчетов = 1;

	КурсЧислительВалютыДокумента = 1;
	КурсЗнаменательВалютыДокумента = 1;

	Для Каждого СтрокаКурса Из ТаблицаКурсов Цикл

		Если СтрокаКурса.Валюта = ВалютаУпр Тогда

			КурсЧислительВалютыУпр = СтрокаКурса.КурсЧислитель;
			КурсЗнаменательВалютыУпр = СтрокаКурса.КурсЗнаменатель;

		КонецЕсли;

		Если СтрокаКурса.Валюта = ВалютаРегл Тогда

			КурсЧислительВалютыРегл = СтрокаКурса.КурсЧислитель;
			КурсЗнаменательВалютыРегл = СтрокаКурса.КурсЗнаменатель;

		КонецЕсли;

		Если СтрокаКурса.Валюта = ВалютаВзаиморасчетов Тогда

			КурсЧислительВзаиморасчетов = СтрокаКурса.КурсЧислитель;
			КурсЗнаменательВзаиморасчетов = СтрокаКурса.КурсЗнаменатель;

		КонецЕсли;

		Если СтрокаКурса.Валюта = ВалютаДокумента Тогда

			КурсЧислительВалютыДокумента = СтрокаКурса.КурсЧислитель;
			КурсЗнаменательВалютыДокумента = СтрокаКурса.КурсЗнаменатель;

		КонецЕсли;
	КонецЦикла;

	Если ЗначениеЗаполнено(КурсЧислительДокумента) Тогда
		
		Если ВалютаДокумента = ВалютаРегл И НЕ ВалютаВзаиморасчетов = ВалютаРегл Тогда
			КурсЧислительВзаиморасчетов = КурсЧислительДокумента;
			КурсЗнаменательВзаиморасчетов = КурсЗнаменательДокумента;
			КурсЧислительВалютыДокумента = 1;
			КурсЗнаменательВалютыДокумента = 1;
		Иначе
			КурсЧислительВалютыДокумента = КурсЧислительДокумента;
			КурсЗнаменательВалютыДокумента = КурсЗнаменательДокумента;
			КурсЧислительВзаиморасчетов = 1;
			КурсЗнаменательВзаиморасчетов = 1;
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = Новый Структура("КоэффициентПересчетаВВалютуВзаиморасчетов, КоэффициентПересчетаВВалютуУПР, КоэффициентПересчетаВВалютуРегл");

	Результат.КоэффициентПересчетаВВалютуУпр  = КурсЧислительВалютыДокумента * КурсЗнаменательВалютыУпр / (КурсЗнаменательВалютыДокумента * КурсЧислительВалютыУпр); 
	Результат.КоэффициентПересчетаВВалютуРегл = КурсЧислительВалютыДокумента * КурсЗнаменательВалютыРегл / (КурсЗнаменательВалютыДокумента * КурсЧислительВалютыРегл);
	Результат.КоэффициентПересчетаВВалютуВзаиморасчетов = КурсЧислительВалютыДокумента * КурсЗнаменательВзаиморасчетов / (КурсЗнаменательВалютыДокумента * КурсЧислительВзаиморасчетов);

	Возврат Результат;

КонецФункции

Функция ТекстЗапросаКурсовПоОбъектуРасчетов()
	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	ОбъектыРасчетов.Ссылка                                                 КАК ОбъектРасчетов,
	|	ВЫБОР
	|		КОГДА ОбъектыРасчетов.ТипОбъектаРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыОбъектовРасчетов.Накладная)
	|				И ЕСТЬNULL(ОбъектыРасчетов.Договор.ВариантКурсаДоговора, ЗНАЧЕНИЕ(Перечисление.ВариантыКурсаДоговора.Переменный)) 
	|					= ЗНАЧЕНИЕ(Перечисление.ВариантыКурсаДоговора.ФиксированныйНаДатуОтгрузки)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВариантыКурсаДоговора.ФиксированныйНаДатуОтгрузки)
	|		ИНАЧЕ ЕСТЬNULL(ОбъектыРасчетов.Договор.ВариантКурсаДоговора, ЗНАЧЕНИЕ(Перечисление.ВариантыКурсаДоговора.Переменный))
	|	КОНЕЦ                                                                  КАК ВариантКурсаДоговора,
	|	ОбъектыРасчетов.ТипОбъектаРасчетов                                     КАК ТипОбъектаРасчетов,
	|	ЕСТЬNULL(КурсыДокументов.КурсЧислительВалютыВзаиморасчетов, 0)         КАК КурсЧислительВалютыВзаиморасчетов,
	|	ЕСТЬNULL(КурсыДокументов.КурсЗнаменательВалютыВзаиморасчетов, 0)       КАК КурсЗнаменательВалютыВзаиморасчетов,
	|	ЕСТЬNULL(КурсыДокументов.КурсЧислительВалютыУправленческогоУчета, 0)   КАК КурсЧислительВалютыУправленческогоУчета,
	|	ЕСТЬNULL(КурсыДокументов.КурсЗнаменательВалютыУправленческогоУчета, 0) КАК КурсЗнаменательВалютыУправленческогоУчета,
	|	ЕСТЬNULL(КурсыДокументов.КурсЧислительВалютыДокумента, 0)              КАК КурсЧислительВалютыДокумента,
	|	ЕСТЬNULL(КурсыДокументов.КурсЗнаменательВалютыДокумента, 0)            КАК КурсЗнаменательВалютыДокумента,
	|	ЕСТЬNULL(КурсыДокументов.ВалютаДокумента, 0)                           КАК ВалютаДокумента,
	|	ОбъектыРасчетов.ВалютаВзаиморасчетов                                   КАК ВалютаВзаиморасчетов,
	|	ОбъектыРасчетов.Организация.ВалютаРегламентированногоУчета             КАК ВалютаРегламентированногоУчета,
	|	ОбъектыРасчетов.Дата                                                   КАК Дата,
	|	ЕСТЬNULL(КурсыДоговоров.Период, ДАТАВРЕМЯ(1, 1, 1))                    КАК ПериодКурсаДоговора,
	|	ЕСТЬNULL(КурсыДоговоров.КурсЧислитель, 0)                              КАК КурсЧислительВалютыДоговора,
	|	ЕСТЬNULL(КурсыДоговоров.КурсЗнаменатель, 0)                            КАК КурсЗнаменательВалютыДоговора
	|ПОМЕСТИТЬ ДанныеОбъектаРасчетов
	|ИЗ
	|	Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВалютыИКурсыДокументов КАК КурсыДокументов
	|		ПО ОбъектыРасчетов.Объект = КурсыДокументов.Документ
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалютРасчетовПоДоговорам.СрезПоследних(&Период, ) КАК КурсыДоговоров
	|		ПО ОбъектыРасчетов.Договор = КурсыДоговоров.Договор
	|ГДЕ
	|	ОбъектыРасчетов.Ссылка В (&ОбъектыРасчетов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеОбъектаРасчетов.ОбъектРасчетов                 КАК ОбъектРасчетов,
	|	ДанныеОбъектаРасчетов.ВалютаДокумента                КАК Валюта,
	|	ДанныеОбъектаРасчетов.ВалютаРегламентированногоУчета КАК БазоваяВалюта,
	|	ДанныеОбъектаРасчетов.Дата                           КАК ДатаКурса,
	|	ДанныеОбъектаРасчетов.КурсЧислительВалютыДокумента   КАК КурсЧислитель,
	|	ДанныеОбъектаРасчетов.КурсЗнаменательВалютыДокумента КАК КурсЗнаменатель
	|ПОМЕСТИТЬ ВтКурсыПредварительно
	|ИЗ
	|	ДанныеОбъектаРасчетов КАК ДанныеОбъектаРасчетов
	|ГДЕ
	|	ДанныеОбъектаРасчетов.ВариантКурсаДоговора = ЗНАЧЕНИЕ(Перечисление.ВариантыКурсаДоговора.ФиксированныйНаДатуОтгрузки)
	|	И ДанныеОбъектаРасчетов.ТипОбъектаРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыОбъектовРасчетов.Накладная)
	|	И ДанныеОбъектаРасчетов.ВалютаДокумента В(&МассивВалют)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДанныеОбъектаРасчетов.ОбъектРасчетов                      КАК ОбъектРасчетов,
	|	ДанныеОбъектаРасчетов.ВалютаВзаиморасчетов                КАК Валюта,
	|	ДанныеОбъектаРасчетов.ВалютаРегламентированногоУчета      КАК БазоваяВалюта,
	|	ДанныеОбъектаРасчетов.Дата                                КАК ДатаКурса,
	|	ДанныеОбъектаРасчетов.КурсЧислительВалютыВзаиморасчетов   КАК КурсЧислитель,
	|	ДанныеОбъектаРасчетов.КурсЗнаменательВалютыВзаиморасчетов КАК КурсЗнаменатель
	|ИЗ
	|	ДанныеОбъектаРасчетов КАК ДанныеОбъектаРасчетов
	|ГДЕ
	|	ДанныеОбъектаРасчетов.ВариантКурсаДоговора = ЗНАЧЕНИЕ(Перечисление.ВариантыКурсаДоговора.ФиксированныйНаДатуОтгрузки)
	|	И ДанныеОбъектаРасчетов.ТипОбъектаРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыОбъектовРасчетов.Накладная)
	|	И ДанныеОбъектаРасчетов.ВалютаВзаиморасчетов В(&МассивВалют)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДанныеОбъектаРасчетов.ОбъектРасчетов                            КАК ОбъектРасчетов,
	|	&ВалютаУпр                                                      КАК Валюта,
	|	ДанныеОбъектаРасчетов.ВалютаРегламентированногоУчета            КАК БазоваяВалюта,
	|	ДанныеОбъектаРасчетов.Дата                                      КАК ДатаКурса,
	|	ДанныеОбъектаРасчетов.КурсЧислительВалютыУправленческогоУчета   КАК КурсЧислитель,
	|	ДанныеОбъектаРасчетов.КурсЗнаменательВалютыУправленческогоУчета КАК КурсЗнаменатель
	|ИЗ
	|	ДанныеОбъектаРасчетов КАК ДанныеОбъектаРасчетов
	|ГДЕ
	|	ДанныеОбъектаРасчетов.ВариантКурсаДоговора = ЗНАЧЕНИЕ(Перечисление.ВариантыКурсаДоговора.ФиксированныйНаДатуОтгрузки)
	|	И ДанныеОбъектаРасчетов.ТипОбъектаРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыОбъектовРасчетов.Накладная)
	|	И &ВалютаУпр В (&МассивВалют)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДанныеОбъектаРасчетов.ОбъектРасчетов                 КАК ОбъектРасчетов,
	|	ДанныеОбъектаРасчетов.ВалютаВзаиморасчетов           КАК Валюта,
	|	ДанныеОбъектаРасчетов.ВалютаРегламентированногоУчета КАК БазоваяВалюта,
	|	ДанныеОбъектаРасчетов.ПериодКурсаДоговора            КАК ДатаКурса,
	|	ДанныеОбъектаРасчетов.КурсЧислительВалютыДоговора    КАК КурсЧислитель,
	|	ДанныеОбъектаРасчетов.КурсЗнаменательВалютыДоговора  КАК КурсЗнаменатель
	|ИЗ
	|	ДанныеОбъектаРасчетов КАК ДанныеОбъектаРасчетов
	|ГДЕ
	|	ДанныеОбъектаРасчетов.ВариантКурсаДоговора = ЗНАЧЕНИЕ(Перечисление.ВариантыКурсаДоговора.УстановленныйВДоговоре)
	|	И ДанныеОбъектаРасчетов.ВалютаВзаиморасчетов В(&МассивВалют)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВтКурсыПредварительно.ОбъектРасчетов  КАК ОбъектРасчетов,
	|	ВтКурсыПредварительно.Валюта          КАК Валюта,
	|	ВтКурсыПредварительно.БазоваяВалюта   КАК БазоваяВалюта,
	|	ВтКурсыПредварительно.ДатаКурса       КАК ДатаКурса,
	|	ВтКурсыПредварительно.КурсЧислитель   КАК КурсЧислитель,
	|	ВтКурсыПредварительно.КурсЗнаменатель КАК КурсЗнаменатель
	|ИЗ
	|	ВтКурсыПредварительно КАК ВтКурсыПредварительно
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЕСТЬNULL(ДанныеОбъектаРасчетов.ОбъектРасчетов,
	|		ЗНАЧЕНИЕ(Справочник.ОбъектыРасчетов.ПустаяСсылка)) КАК ОбъектРасчетов,
	|	ОтносительныеКурсыВалютСрезПоследних.Валюта            КАК Валюта,
	|	ОтносительныеКурсыВалютСрезПоследних.БазоваяВалюта     КАК БазоваяВалюта,
	|	ОтносительныеКурсыВалютСрезПоследних.Период            КАК ДатаКурса,
	|	ОтносительныеКурсыВалютСрезПоследних.КурсЧислитель     КАК КурсЧислитель,
	|	ОтносительныеКурсыВалютСрезПоследних.КурсЗнаменатель   КАК КурсЗнаменатель
	|ИЗ
	|	РегистрСведений.ОтносительныеКурсыВалют.СрезПоследних(
	|			&Период,
	|			БазоваяВалюта = &ВалютаРегл
	|				И Валюта В (&МассивВалют)
	|				И НЕ Валюта В
	|						(ВЫБРАТЬ
	|							Т.Валюта
	|						ИЗ
	|							ВтКурсыПредварительно КАК Т)) КАК ОтносительныеКурсыВалютСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеОбъектаРасчетов КАК ДанныеОбъектаРасчетов
	|		ПО (ИСТИНА)
	|ГДЕ
	|	НЕ (ОтносительныеКурсыВалютСрезПоследних.Валюта, ДанныеОбъектаРасчетов.ОбъектРасчетов)
	|		В (ВЫБРАТЬ Т.Валюта, Т.ОбъектРасчетов ИЗ ВтКурсыПредварительно КАК Т)
	|";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаКурсовПоДоговору()
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	Договоры.Ссылка КАК ОбъектРасчетов,
	|	Договоры.ВариантКурсаДоговора КАК ВариантКурсаДоговора,
	|	Договоры.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	Договоры.Организация.ВалютаРегламентированногоУчета КАК ВалютаРегламентированногоУчета,
	|	ЕСТЬNULL(КурсыДоговоров.Период, ДАТАВРЕМЯ(1, 1, 1)) КАК ПериодКурсаДоговора,
	|	ЕСТЬNULL(КурсыДоговоров.КурсЧислитель, 0) КАК КурсЧислительВалютыДоговора,
	|	ЕСТЬNULL(КурсыДоговоров.КурсЗнаменатель, 0) КАК КурсЗнаменательВалютыДоговора
	|ПОМЕСТИТЬ ДанныеОбъектаРасчетов
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК Договоры
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалютРасчетовПоДоговорам.СрезПоследних(&Период, ) КАК КурсыДоговоров
	|		ПО (Договоры.Ссылка = КурсыДоговоров.Договор)
	|ГДЕ
	|	Договоры.Ссылка В(&ОбъектыРасчетов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеОбъектаРасчетов.ОбъектРасчетов КАК ОбъектРасчетов,
	|	ДанныеОбъектаРасчетов.ВалютаВзаиморасчетов КАК Валюта,
	|	ДанныеОбъектаРасчетов.ВалютаРегламентированногоУчета КАК БазоваяВалюта,
	|	ДанныеОбъектаРасчетов.ПериодКурсаДоговора КАК ДатаКурса,
	|	ДанныеОбъектаРасчетов.КурсЧислительВалютыДоговора КАК КурсЧислитель,
	|	ДанныеОбъектаРасчетов.КурсЗнаменательВалютыДоговора КАК КурсЗнаменатель
	|ПОМЕСТИТЬ ВтКурсыПредварительно
	|ИЗ
	|	ДанныеОбъектаРасчетов КАК ДанныеОбъектаРасчетов
	|ГДЕ
	|	ДанныеОбъектаРасчетов.ВариантКурсаДоговора = ЗНАЧЕНИЕ(Перечисление.ВариантыКурсаДоговора.УстановленныйВДоговоре)
	|	И ДанныеОбъектаРасчетов.ВалютаВзаиморасчетов В(&МассивВалют)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВтКурсыПредварительно.ОбъектРасчетов КАК ОбъектРасчетов,
	|	ВтКурсыПредварительно.Валюта КАК Валюта,
	|	ВтКурсыПредварительно.БазоваяВалюта КАК БазоваяВалюта,
	|	ВтКурсыПредварительно.ДатаКурса КАК ДатаКурса,
	|	ВтКурсыПредварительно.КурсЧислитель КАК КурсЧислитель,
	|	ВтКурсыПредварительно.КурсЗнаменатель КАК КурсЗнаменатель
	|ИЗ
	|	ВтКурсыПредварительно КАК ВтКурсыПредварительно
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЕСТЬNULL(ДанныеОбъектаРасчетов.ОбъектРасчетов, ЗНАЧЕНИЕ(Справочник.ОбъектыРасчетов.ПустаяСсылка)) ОбъектРасчетов,
	|	ОтносительныеКурсыВалютСрезПоследних.Валюта Валюта,
	|	ОтносительныеКурсыВалютСрезПоследних.БазоваяВалюта БазоваяВалюта,
	|	ОтносительныеКурсыВалютСрезПоследних.Период ДатаКурса,
	|	ОтносительныеКурсыВалютСрезПоследних.КурсЧислитель КурсЧислитель,
	|	ОтносительныеКурсыВалютСрезПоследних.КурсЗнаменатель КурсЗнаменатель
	|ИЗ
	|	РегистрСведений.ОтносительныеКурсыВалют.СрезПоследних(
	|			&Период,
	|			БазоваяВалюта = &ВалютаРегл
	|				И Валюта В (&МассивВалют)
	|				И НЕ Валюта В
	|						(ВЫБРАТЬ
	|							Т.Валюта
	|						ИЗ
	|							ВтКурсыПредварительно КАК Т)) КАК ОтносительныеКурсыВалютСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеОбъектаРасчетов КАК ДанныеОбъектаРасчетов
	|		ПО (ИСТИНА)
	|ГДЕ
	|	НЕ (ОтносительныеКурсыВалютСрезПоследних.Валюта, ДанныеОбъектаРасчетов.ОбъектРасчетов) В
	|				(ВЫБРАТЬ
	|					Т.Валюта,
	|					Т.ОбъектРасчетов
	|				ИЗ
	|					ВтКурсыПредварительно КАК Т)";
	
	Возврат ТекстЗапроса;
	
КонецФункции

