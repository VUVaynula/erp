Функция ВозможноВзысканиеСПеречисленияФизлицу(Дата, ВидОперации, КонтрагентЮрФизЛицо = Неопределено) Экспорт
	
	// См. ОМ.СписаниеБезналичныхДенежныхСредствЛокализация.ЗаполнитьНастройкиПолейФормы().
	// Область "Код вида дохода".
	
	Результат = Ложь;
	
	ПеречислениеСотруднику =
		ВидОперации = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета")
		ИЛИ ВидОперации = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВыплатаЗарплатыПоЗарплатномуПроекту");
		
	ПеречислениеПодотчетномуЛицу =
		ВидОперации = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВыдачаДенежныхСредствПодотчетнику");
		
	ВыплатыКонтрагентам =
		ВидОперации = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПрочаяВыдачаДенежныхСредств")
		ИЛИ ВидОперации = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ОплатаПоставщику");
		
	ДействуетУказание2019_5286У = ПлатежиВБюджетКлиентСервер.ДействуетУказание2019_5286У(Дата);
	
	Если (ПеречислениеСотруднику ИЛИ ПеречислениеПодотчетномуЛицу ИЛИ ВыплатыКонтрагентам) И ДействуетУказание2019_5286У Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура КодВидаДоходаПоУмолчанию(Объект, ВидОперации, КонтрагентЮрФизЛицо) Экспорт
		
	Если ВидОперации = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета")
		И Объект.КодВидаДохода = "" Тогда
		Объект.КодВидаДохода = "1";
	КонецЕсли;

КонецПроцедуры

Функция ЭтоДокументПоступленияДС(Данные) Экспорт
	
	ЭтоПоступлениеДС = Ложь;
	
	ДокументыПоступления = Новый Массив;
	ДокументыПоступления.Добавить(Тип("ДокументСсылка.ПриходныйКассовыйОрдер"));
	ДокументыПоступления.Добавить(Тип("ДокументСсылка.ПоступлениеБезналичныхДенежныхСредств"));
	
	Если НЕ ДокументыПоступления.Найти(ТипЗнч(Данные)) = Неопределено Тогда
		ЭтоПоступлениеДС = Истина;
	КонецЕсли; 
	
	Возврат ЭтоПоступлениеДС;
	
КонецФункции

Функция ЭтоДокументРасходованияДС(Данные) Экспорт
	
	ЭтоРасходованиеДС = Ложь;
	
	ДокументыРасходования = Новый Массив;
	ДокументыРасходования.Добавить(Тип("ДокументСсылка.РасходныйКассовыйОрдер"));
	ДокументыРасходования.Добавить(Тип("ДокументСсылка.СписаниеБезналичныхДенежныхСредств"));
	
	Если НЕ ДокументыРасходования.Найти(ТипЗнч(Данные)) = Неопределено Тогда
		ЭтоРасходованиеДС = Истина;
	КонецЕсли; 
	
	Возврат ЭтоРасходованиеДС;
	
КонецФункции

Функция ПериодЗаданКорректно(Объект, Параметры)  Экспорт

	ДатаКорректна = Истина;

	ДатаНачала 	  = Параметры.ПоляОбъекта.ДатаНачала;
	ДатаОкончания = Параметры.ПоляОбъекта.ДатаОкончания;
		
	ПолеДатаНачала 	  = Параметры.ПоляФормы.ДатаНачала;
	ПолеДатаОкончания = Параметры.ПоляФормы.ДатаОкончания;
	Префикс 		  = Параметры.ПоляФормы.Префикс;
	ИмяСписка		  = Параметры.ПоляФормы.ИмяСписка;
	НомерСтроки		  = Параметры.ПоляФормы.НомерСтроки;
	
	ВыводитьСообщения = Параметры.ВыводитьСообщения;

	Если НЕ ЗначениеЗаполнено(Объект[ДатаОкончания]) Тогда
		Возврат ДатаКорректна;	
	КонецЕсли;
	
	ЗначениеНачало 	  = НачалоДня(Объект[ДатаНачала]);
	ЗначениеОкончание = НачалоДня(Объект[ДатаОкончания]);
	
	ДатаКорректна = (ЗначениеНачало <= ЗначениеОкончание);
	
	Если НЕ ДатаКорректна И ВыводитьСообщения Тогда
		
		Дополнение = НСтр("ru = '""%1"" не может быть ранее ""%2"".'; en = '""%1"" cannot be earlier than ""%2""'");
		Дополнение = СтрШаблон(Дополнение, ПолеДатаОкончания, ПолеДатаНачала);
		
		Если ЗначениеЗаполнено(ИмяСписка) Тогда
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка","Корректность", ПолеДатаОкончания, 
								НомерСтроки, ИмяСписка, Дополнение);
		Иначе	
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,"Корректность", ПолеДатаОкончания,,,Дополнение);
		КонецЕсли;
		
		ПутьКДанным = "";
		Если ЗначениеЗаполнено(Префикс) И ЗначениеЗаполнено(НомерСтроки) Тогда
			ПутьКДанным = Префикс + "[%1].";
			ПутьКДанным = СтрШаблон(ПутьКДанным, Формат(НомерСтроки - 1, "ЧН=0; ЧГ="));
		ИначеЕсли ЗначениеЗаполнено(Префикс) Тогда
			ПутьКДанным = Префикс + ".";
		КонецЕсли;
		ПутьКДанным = ПутьКДанным + ДатаОкончания;
		
		#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , ПутьКДанным,);
		#Иначе
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , ПутьКДанным,);
		#КонецЕсли	
	КонецЕсли; 
	
	Возврат ДатаКорректна;

КонецФункции

Функция НовыеПараметрыПериодЗаданКорректно() Экспорт

	// Имена полей объета с данными.
	ПоляОбъекта = Новый Структура;	
	ПоляОбъекта.Вставить("ДатаНачала",	  "Дата");
	ПоляОбъекта.Вставить("ДатаОкончания", "ДатаПлан");
	
	// Представление полей объекта (колонок) и списка.
	ПоляФормы = Новый Структура;
	ПоляФормы.Вставить("ДатаНачала",	НСтр("ru = 'Дата документа'"));
	ПоляФормы.Вставить("ДатаОкончания", НСтр("ru = 'Дата расхода'"));
	ПоляФормы.Вставить("ИмяСписка",     "");
	
	// Элементы пути к данным, пригодные для формирования сообщения пользователю.
	ПоляФормы.Вставить("НомерСтроки", 	0);
	ПоляФормы.Вставить("Префикс",     	"Объект");
	
	Параметры = Новый Структура;
	Параметры.Вставить("ПоляОбъекта",	  	ПоляОбъекта);
	Параметры.Вставить("ПоляФормы", 		ПоляФормы);
	Параметры.Вставить("ВыводитьСообщения", Истина);
	
	Возврат Параметры;
	
КонецФункции

