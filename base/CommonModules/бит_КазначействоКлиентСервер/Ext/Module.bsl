Функция ПодготовитьПараметрыВидимости(ВидОперации) Экспорт

	ОперацииСКонтрагентами = ОперацииСКонтрагентами().Найти(ВидОперации) <> Неопределено;
	ОперацииСДоговорами	   = ОперацииСДоговорами().Найти(ВидОперации) <> Неопределено;
	ОперацииСФизЛицами	   = ОперацииСФизЛицами().Найти(ВидОперации) <> Неопределено;
	ОперацииПередачиДС 	   = ОперацииПередачиДС().Найти(ВидОперации) <> Неопределено;
	ЕстьОбъектРасчетов	   = ОперацииСОбъектомРасчетов().Найти(ВидОперации) <> Неопределено;
	ЕстьПартнер			   = ОперацииСПартнерами().Найти(ВидОперации) <> Неопределено;
	
	Результат = Новый Структура();
	Результат.Вставить("ЕстьКонтрагент",	 ОперацииСКонтрагентами ИЛИ ОперацииСДоговорами);
	Результат.Вставить("ЕстьДоговор",		 ОперацииСДоговорами);
	Результат.Вставить("ФизЛицо",			 ОперацииСФизЛицами);
	Результат.Вставить("ЕстьОбъектРасчетов", ЕстьОбъектРасчетов);
	Результат.Вставить("ЕстьПартнер",		 ЕстьПартнер);
	
	Возврат Результат;
	
КонецФункции

