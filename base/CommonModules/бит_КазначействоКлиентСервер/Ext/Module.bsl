Функция ОперацияБезРасшифровкиПлатежа()
	
	ВидыОпераций = Новый Массив;
	
	// См. Документы.СписаниеБезналичныхДенежныхСредств.МассивОперацийБезРасшифровкиПлатежа();
	// См. так же: бит_ОбщегоНазначенияПереопределяемый.ЕстьРасшифровкаПлатежа().
	
	ВидыОпераций.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ВнутренняяПередачаДенежныхСредств"));
	ВидыОпераций.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.КонвертацияВалюты"));
	ВидыОпераций.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ВозвратОплатыНаПлатежнуюКарту"));
	
	ИспользоватьКадровыйУчет = бит_КазначействоВызовСервера.ИспользоватьКадровыйУчет();
	Если НЕ ИспользоватьКадровыйУчет Тогда
		ВидыОпераций.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ВыплатаЗарплатыПоЗарплатномуПроекту"));
	КонецЕсли;

	Возврат ВидыОпераций;
	
КонецФункции
 
