// Возвращает специально подготовленную строку JSON с информацией об аналитиках.
//
// Параметры:
//  HTTPЗапрос	 - HTTPЗапрос	 - Содержит параметры запроса, в случае вызова из метода HTTP-сервиса бит_PowerBIAPI.
// 
// Возвращаемое значение:
//  Строка - Строка JSON,
//  Неопределено - Если отсутствует лицензия для Power BI.
//
Функция СинонимыАналитик(HTTPЗапрос = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИсточникНастроек.ИмяИзмерения КАК ИмяИзмерения,
	|	ИсточникНастроек.Синоним КАК Синоним
	|ИЗ
	|	РегистрСведений.бит_НазначениеДополнительныхИзмерений КАК ИсточникНастроек";
	
	Выборка = Запрос.Выполнить().Выбрать();
	ДопИзмерения = Новый Структура;
	Пока Выборка.Следующий() Цикл
		ДопИзмерения.Вставить(Выборка.ИмяИзмерения, Выборка.Синоним);
	КонецЦикла;
	
	ИменаКолонок = ИменаКолонокВнешнейСистемы();
	Колонки = Новый Структура();
	Колонки.Вставить("Аналитика_1",			ИменаКолонок.Аналитика_1);
	Колонки.Вставить("Аналитика_2",			ИменаКолонок.Аналитика_2);
	Колонки.Вставить("Аналитика_3",			ИменаКолонок.Аналитика_3);
	Колонки.Вставить("Аналитика_4",			ИменаКолонок.Аналитика_4);
	Колонки.Вставить("Аналитика_5",			ИменаКолонок.Аналитика_5);
	Колонки.Вставить("Аналитика_6",			ИменаКолонок.Аналитика_6);
	Колонки.Вставить("Аналитика_7",			ИменаКолонок.Аналитика_7);
	Колонки.Вставить("Аналитика_8",			ИменаКолонок.Аналитика_8);
	Колонки.Вставить("Аналитика_9",			ИменаКолонок.Аналитика_9);
	Колонки.Вставить("Аналитика_10",		ИменаКолонок.Аналитика_10);
	Колонки.Вставить("Аналитика_11",		ИменаКолонок.Аналитика_11);
	Колонки.Вставить("Аналитика_12",		ИменаКолонок.Аналитика_12);

	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыJSON = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, " ", Истина);
	ЗаписьJSON.УстановитьСтроку(ПараметрыJSON);
	ЗаписьJSON.ЗаписатьНачалоМассива();
	
	Для Каждого СвойствоКолонки Из Колонки Цикл
		ИмяКолонки = Неопределено;
		ДопИзмерения.Свойство(СвойствоКолонки.Ключ, ИмяКолонки);
		Если ИмяКолонки = Неопределено Тогда
			ИмяКолонки = СвойствоКолонки.Значение;
		КонецЕсли;
		ЗаписьJSON.ЗаписатьНачалоОбъекта();
		ЗаписьJSON.ЗаписатьИмяСвойства("Имя_аналиики");
		ЗаписьJSON.ЗаписатьЗначение(СвойствоКолонки.Ключ);
		ЗаписьJSON.ЗаписатьИмяСвойства("Синоним");
		ЗаписьJSON.ЗаписатьЗначение(ИмяКолонки);
		ЗаписьJSON.ЗаписатьКонецОбъекта();
		
		// Ключи доп. аналитик.
		ЗаписьJSON.ЗаписатьНачалоОбъекта();
		ЗаписьJSON.ЗаписатьИмяСвойства("Имя_аналиики");
		ЗаписьJSON.ЗаписатьЗначение(СвойствоКолонки.Ключ + "_Key");
		ЗаписьJSON.ЗаписатьИмяСвойства("Синоним");
		ЗаписьJSON.ЗаписатьЗначение(ИмяКолонки + "_Key");
		ЗаписьJSON.ЗаписатьКонецОбъекта();
	КонецЦикла; 
	
	ЗаписьJSON.ЗаписатьКонецМассива();
	СтрJSON = ЗаписьJSON.Закрыть();
	
	Возврат СтрJSON;
		
КонецФункции

// Возвращает специально подготовленную строку JSON с информацией о видах ЦФО.
//
// Параметры:
//  HTTPЗапрос	 - HTTPЗапрос	 - Содержит параметры запроса, в случае вызова из метода HTTP-сервиса бит_PowerBIAPI.
// 
// Возвращаемое значение:
//  Строка - Строка JSON,
//  Неопределено - Если отсутствует лицензия для Power BI.
//
Функция ВидыЦФО(HTTPЗапрос = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бит_ОборотыПоБюджетамОбороты.ЦФО КАК ЦФО
	|ПОМЕСТИТЬ ВТЦФООставить
	|ИЗ
	|	РегистрНакопления.бит_ОборотыПоБюджетам.Обороты(
	|			,
	|			,
	|			,
	|			ЦФО В
	|				(ВЫБРАТЬ
	|					Подразделения.Ссылка
	|				ИЗ
	|					Справочник.Подразделения КАК Подразделения)) КАК бит_ОборотыПоБюджетамОбороты
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ЦФО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Подразделения.ВидЦФО КАК ВидЦФО
	|ПОМЕСТИТЬ ВТВидЦФООставить
	|ИЗ
	|	Справочник.Подразделения КАК Подразделения
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЦФООставить КАК ВТЦФООставить
	|		ПО Подразделения.Ссылка = ВТЦФООставить.ЦФО
	|ГДЕ
	|	НЕ(Подразделения.ПометкаУдаления
	|				И ВТЦФООставить.ЦФО ЕСТЬ NULL)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ВидЦФО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыЦФО.Ссылка КАК Ссылка,
	|	ВидыЦФО.Код КАК Код,
	|	ВидыЦФО.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ВидыЦФО КАК ВидыЦФО
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВидЦФООставить КАК ВТВидЦФООставить
	|		ПО ВидыЦФО.Ссылка = ВТВидЦФООставить.ВидЦФО
	|ГДЕ
	|	НЕ(ВидыЦФО.ПометкаУдаления
	|				И ВТВидЦФООставить.ВидЦФО ЕСТЬ NULL)";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	"""" КАК Ссылка,
		|	"""" КАК Код,
		|	"""" КАК Наименование";
		РезультатЗапроса = Запрос.Выполнить();
	КонецЕсли;
	
	ИменаКолонок = ИменаКолонокВнешнейСистемы();
	Поля = Новый СписокЗначений(); // Пометка "Истина", устанавливается у элемента ссылочного типа для выгрузки УИД.  
	Поля.Добавить("Ссылка",			ИменаКолонок.Ref_Key, Истина);
	Поля.Добавить("Код",			ИменаКолонок.Код);
	Поля.Добавить("Наименование",	ИменаКолонок.ВидЦФО);
	
	ПараметрыПолучения = бит_PowerBIСлужебный.НовыеПараметрыПолучения();
	ПараметрыПолучения.Поля				= Поля;
	ПараметрыПолучения.РезультатЗапроса	= РезультатЗапроса;
	ПараметрыПолучения.HTTPЗапрос	    = HTTPЗапрос; 
	Возврат бит_PowerBIСлужебный.ПолучитьСтрокуJSON(ПараметрыПолучения); 
	
КонецФункции

