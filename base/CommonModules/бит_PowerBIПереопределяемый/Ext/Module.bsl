// Возвращает специально подготовленную строку JSON с информацией о ЦФО.
//
// Параметры:
//  HTTPЗапрос	 - HTTPЗапрос	 - Содержит параметры запроса, в случае вызова из метода HTTP-сервиса бит_PowerBIAPI.
// 
// Возвращаемое значение:
//  Строка - Строка JSON,
//  Неопределено - Если отсутствует лицензия для Power BI.
//
Функция ЦФО(HTTPЗапрос = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Подразделения.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Подразделения КАК Подразделения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бит_ОборотыПоБюджетамОбороты.ЦФО КАК ЦФО
	|ПОМЕСТИТЬ ВТЦФООставить
	|ИЗ
	|	РегистрНакопления.бит_ОборотыПоБюджетам.Обороты(
	|			,
	|			,
	|			,
	|			ЦФО В
	|				(ВЫБРАТЬ
	|					Подразделения.Ссылка
	|				ИЗ
	|					Справочник.Подразделения КАК Подразделения)) КАК бит_ОборотыПоБюджетамОбороты
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ЦФО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Подразделения.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА Подразделения.Родитель = ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка)
	|			ТОГДА Подразделения.Ссылка
	|		ИНАЧЕ Подразделения.Родитель
	|	КОНЕЦ КАК Родитель,
	|	Подразделения.Код КАК Код,
	|	Подразделения.Наименование КАК Наименование,
	|	Подразделения.Кодификатор КАК Кодификатор,
	|	Подразделения.ЯвляетсяЮрЛицом КАК ЯвляетсяЮрЛицом,
	|	Подразделения.ПризнакАктуальности КАК ПризнакАктуальности,
	|	Подразделения.ВидЦФО КАК ВидЦФО,
	|	Подразделения.Руководитель КАК Руководитель
	|ИЗ
	|	Справочник.Подразделения КАК Подразделения
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЦФООставить КАК ВТЦФООставить
	|		ПО Подразделения.Ссылка = ВТЦФООставить.ЦФО
	|ГДЕ
	|	НЕ(Подразделения.ПометкаУдаления
	|				И ВТЦФООставить.ЦФО ЕСТЬ NULL)";
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	ПоляДопРеквизитов = УправлениеСвойствами.СвойстваОбъекта(Справочники.Подразделения.ПустаяСсылка());
	ДопРеквизиты = Неопределено;
	Ссылки = ПакетЗапросов[0].Выгрузить().ВыгрузитьКолонку("Ссылка");
	Если Ссылки.Количество() > 0 Тогда
		ДопРеквизиты = УправлениеСвойствами.ЗначенияСвойств(Ссылки);
		ДопРеквизиты.Индексы.Добавить("ВладелецСвойств, Свойство");
	КонецЕсли;
	
	РезультатЗапроса = ПакетЗапросов[2];
	Если РезультатЗапроса.Пустой() Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	"""" КАК Ссылка,
		|	"""" КАК Родитель,
		|	"""" КАК Код,
		|	"""" КАК Наименование,
		|	"""" КАК Кодификатор,
		|	"""" КАК ЯвляетсяЮрЛицом,
		|	"""" КАК ПризнакАктуальности,
		|	"""" КАК ВидЦФО,
		|	"""" КАК Руководитель";
		РезультатЗапроса = Запрос.Выполнить();
	КонецЕсли;
	
	ИменаКолонок = ИменаКолонокВнешнейСистемы();
	Поля = Новый СписокЗначений(); // Пометка "Истина", устанавливается у элемента ссылочного типа для выгрузки УИД.  
	Поля.Добавить("Ссылка",				ИменаКолонок.Ref_Key,					Истина);
	Поля.Добавить("Родитель",			ИменаКолонок.Parent_Key,				Истина);
	Поля.Добавить("Код",				ИменаКолонок.Код);
	Поля.Добавить("Наименование",		ИменаКолонок.ЦФО);
	Поля.Добавить("Кодификатор",		ИменаКолонок.КодификаторЦФО);
	Поля.Добавить("ЯвляетсяЮрЛицом",	ИменаКолонок.ЯвляетсяЮрЛицом);
	Поля.Добавить("ПризнакАктуальности",ИменаКолонок.ПризнакАктуальности);
	Поля.Добавить("ВидЦФО",				ИменаКолонок.ВидЦФО_Key,				Истина);
	Поля.Добавить("Руководитель",		ИменаКолонок.Руководитель_Key,			Истина);
	
	ПараметрыПолучения = бит_PowerBIСлужебный.НовыеПараметрыПолучения();
	ПараметрыПолучения.Поля				= Поля;
	ПараметрыПолучения.РезультатЗапроса	= РезультатЗапроса;
	ПараметрыПолучения.HTTPЗапрос	    = HTTPЗапрос; 
	ПараметрыПолучения.ПоляДопРеквизитов= ПоляДопРеквизитов; 
	ПараметрыПолучения.ДопРеквизиты		= ДопРеквизиты; 
	Возврат бит_PowerBIСлужебный.ПолучитьСтрокуJSON(ПараметрыПолучения); 
	
КонецФункции

// Возвращает специально подготовленную строку JSON с информацией о статьях оборотов.
