	// ++ ЕРП 
	Коды = Новый Массив;
	Коды.Добавить("643");
	РаботаСКурсамиВалют.ДобавитьВалютыПоКоду(Коды);
	// -- ЕРП 
	
КонецПроцедуры

Процедура УстановитьВалютуУправленческогоУчета()
	
	ВалютаРегламентированногоУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	Если НЕ ЗначениеЗаполнено(ВалютаРегламентированногоУчета) Тогда
		
		Запрос = Новый Запрос(
			"ВЫБРАТЬ
			|	Валюты.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Валюты КАК Валюты
			|ГДЕ
			|	НЕ Валюты.ПометкаУдаления
			|	И Валюты.Код = ""643""");
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() Тогда
			Коды = Новый Массив;
			Коды.Добавить("643");
			РаботаСКурсамиВалют.ДобавитьВалютыПоКоду(Коды);
			УстановитьВалютуУправленческогоУчета();
		Иначе
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			
			Константы.бит_ВалютаУправленческогоУчета.Установить(Выборка.Ссылка);
		КонецЕсли;
	Иначе
		Константы.бит_ВалютаУправленческогоУчета.Установить(ВалютаРегламентированногоУчета);
	КонецЕсли;
	
КонецПроцедуры

