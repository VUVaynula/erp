Процедура НазначитьАналитику(Аналитики, ИмяОбъектаПолное)

	ТекущийОбъект  = Справочники.бит_ОбъектыСистемы.НайтиПоРеквизиту("ИмяОбъектаПолное", ИмяОбъектаПолное);	
	Если НЕ ЗначениеЗаполнено(ТекущийОбъект) Тогда		
		Возврат;		
	КонецЕсли;         	
	
	Для каждого Аналитика Из Аналитики Цикл
		Если НЕ ЗначениеЗаполнено(Аналитика) Тогда 			
			Продолжить; 			
		КонецЕсли;    		
		
		МенеджерЗаписи = РегистрыСведений.бит_НазначениеДополнительныхАналитик.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Объект    = ТекущийОбъект;
		МенеджерЗаписи.Аналитика = Аналитика;
		МенеджерЗаписи.Записать();
	КонецЦикла;     	
	
