	|			ИЛИ НаборыДополнительныхРеквизитовИСведений.ИмяПредопределенногоНабора = """")";
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	                                   	
	Пока Выборка.Следующий() Цикл
		
		НаборОбъект = Выборка.Ссылка.ПолучитьОбъект();
		НаборОбъект.ИмяПредопределенногоНабора = Выборка.ИмяПредопределенныхДанных;
		НаборОбъект.Используется               = Истина;
		НаборОбъект.Записать();
		
	КонецЦикла;
	
