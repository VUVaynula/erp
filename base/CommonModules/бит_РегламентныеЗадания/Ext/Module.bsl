// Обработчик регламентного задания "бит_РегистрацияОповещенийОВизировании".
// Записывает в регистр "Регистрация оповещений" документы подлежащие визированию.
// 
// Параметры:
//  СтруктураПараметров - Структура.
// 
Процедура РегистрацияОповещенийОВизировании(СтруктураПараметров) Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.бит_РегистрацияОповещенийОВизировании);
	
	// Проверим корректность переданых параметров.
	Если НЕ ТипЗнч(СтруктураПараметров) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Оповещение = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураПараметров, "Оповещение", Неопределено);
	СогласующиеЛица = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураПараметров, "СогласующиеЛица", Неопределено);
	Если Оповещение = Неопределено
		ИЛИ СогласующиеЛица = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НастройкаОбработкиВизирования = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураПараметров,
		"НастройкаОбработкиВизирования", Неопределено);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВсеПользователи", Справочники.ГруппыПользователей.ВсеПользователи);
	Запрос.УстановитьПараметр("СогласующиеЛица", СогласующиеЛица);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СогласующиеЛица.Пользователь,
	|	СогласующиеЛица.НастройкаОбработкиВизирования
	|ПОМЕСТИТЬ СогласующиеЛица
	|ИЗ
	|	&СогласующиеЛица КАК СогласующиеЛица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА СогласующиеЛица.Пользователь = &ВсеПользователи
	|			ТОГДА СпрПользователи.Ссылка
	|		КОГДА ТИПЗНАЧЕНИЯ(СогласующиеЛица.Пользователь) = ТИП(Справочник.ГруппыПользователей)
	|			ТОГДА ПользователиГруппы.Пользователь
	|		ИНАЧЕ СогласующиеЛица.Пользователь
	|	КОНЕЦ КАК Пользователь,
	|	СогласующиеЛица.НастройкаОбработкиВизирования
	|ИЗ
	|	СогласующиеЛица КАК СогласующиеЛица
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГруппыПользователей.%ИмяТабЧасти% КАК ПользователиГруппы
	|		ПО СогласующиеЛица.Пользователь = ПользователиГруппы.Ссылка,
	|	Справочник.Пользователи КАК СпрПользователи
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА СогласующиеЛица.Пользователь = &ВсеПользователи
	|			ТОГДА СпрПользователи.Ссылка
	|		КОГДА ТИПЗНАЧЕНИЯ(СогласующиеЛица.Пользователь) = ТИП(Справочник.ГруппыПользователей)
	|			ТОГДА ПользователиГруппы.Пользователь
	|		ИНАЧЕ СогласующиеЛица.Пользователь
	|	КОНЕЦ,
	|	СогласующиеЛица.НастройкаОбработкиВизирования";
	
	ИмяТабЧасти = бит_ОбщегоНазначения.ИмяТабЧастиГруппыПользователей();
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ИмяТабЧасти%", ИмяТабЧасти);	
	ТаблицаПользователей = Запрос.Выполнить().Выгрузить();
	// Для каждого пользователя укажем настройку обработки визирования.
	Для Каждого СтрокаПользователя Из ТаблицаПользователей Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаПользователя.НастройкаОбработкиВизирования) Тогда
			СтрокаПользователя.НастройкаОбработкиВизирования = НастройкаОбработкиВизирования;
		КонецЕсли;
	КонецЦикла;
	
	ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ДокументыДляВизирования;                  
	ПараметрыПолучения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
	ПараметрыПолучения.ВыводитьВТаблицуЗначений	= Истина;
	ПараметрыПолучения.РежимПроверкиОповещений	= Истина;
	ПараметрыПолучения.ЭтоОповещения			= Истина;
	Для каждого ТекущийПользователь Из ТаблицаПользователей Цикл
		Если НЕ ЗначениеЗаполнено(ТекущийПользователь.НастройкаОбработкиВизирования)
			ИЛИ НЕ ЗначениеЗаполнено(ТекущийПользователь.Пользователь) Тогда
			Продолжить;
		КонецЕсли;
		СтруктураНастроек = ТекущийПользователь.НастройкаОбработкиВизирования.ХранилищеНастроек.Получить();
		Если ТипЗнч(СтруктураНастроек) = Тип("Структура") Тогда
			ПараметрыПолучения.Ответственный			= ТекущийПользователь.Пользователь;
			ПараметрыПолучения.МатрицаДоступа			= Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа(
															ТекущийПользователь.Пользователь);
			ПараметрыПолучения.НастройкиКомпоновщика	= СтруктураНастроек.НастройкиКомпоновщика;
			ПараметрыПолучения.ВариантОтбораВиз			= СтруктураНастроек.ВариантОтбораВиз; 
			ПараметрыПолучения.Отбор.ТипОбъекта         = СтруктураНастроек.ТипыОбъектовВизирования;
			ПараметрыПолучения.Отбор.Виза				= СтруктураНастроек.ФильтрВизы; 
			АдресВХранилище = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор); 
			Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
			Результат = ПолучитьИзВременногоХранилища(АдресВХранилище);
			ДокументыПользователя = Результат.РезультатТаблицаЗначений;
			
			Для каждого Документ Из ДокументыПользователя Цикл
				ПараметрыСобытия				= бит_ОповещенияСервер.НовыеПараметрыСобытия();
				ПараметрыСобытия.ВидСобытия		= ВидСобытия;
				ПараметрыСобытия.Оповещение		= Оповещение;
				ПараметрыСобытия.Объект			= Документ.ОбъектВизирования;
				ПараметрыСобытия.Пользователь	= ТекущийПользователь.Пользователь;
				ПараметрыСобытия.Виза			= Документ.Виза;
				ПараметрыСобытия.Статус			= Документ.Статус;
				бит_ОповещенияСервер.ЗарегистрироватьСобытиеДляОповещений(ПараметрыСобытия);
			КонецЦикла;
			
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры

// Обработчик регламентного задания "бит_СоздатьДокументыПланированияИзДопУсловий".
// Создает документы плаинрования из доп. условий по договору.
// 
// Параметры:
