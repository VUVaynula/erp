// Обработчик регламентного задания "бит_ЗакрытиеДокументовПланирования". Закрывает документы планирования.
// 
// Параметры:
//  ПараметрыЗадания - Структура:
//		* НастройкаПодбораЗакрываемыхДокументов - СправочникСсылка.бит_СохраненныеНастройки.
// 
Процедура ЗакрытиеДокументовПланирования(ПараметрыЗадания) Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.бит_ЗакрытиеДокументовПланирования);
	
	НастройкаПодбораЗакрываемыхДокументов = Неопределено;
	Если ТипЗнч(ПараметрыЗадания) = Тип("Структура") Тогда
		ПараметрыЗадания.Свойство("НастройкаПодбораЗакрываемыхДокументов", НастройкаПодбораЗакрываемыхДокументов);
	КонецЕсли;
	
	ИмяСобытия = НСтр("ru='Начало закрытия документов планирования.';
					  |en='Start closing planning documents.'", ОбщегоНазначения.КодОсновногоЯзыка());
	ТекстСообщения = НСтр("ru='Начало закрытия документов планирования.';
						  |en='Start closing planning documents.'"); 
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);
    								
	Обработки.бит_ЗакрытиеДокументовПланирования.ВыполнитьРегламентнуюОперацию(НастройкаПодбораЗакрываемыхДокументов);
		
	ИмяСобытия = НСтр("ru='Закрытие документов планирования завершено.';
					  |en='Closing planning documents completed.'", ОбщегоНазначения.КодОсновногоЯзыка());
	ТекстСообщения = НСтр("ru='Закрытие документов планирования завершено.';
						  |en='Closing planning documents completed.'"); 
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);
    
КонецПроцедуры

