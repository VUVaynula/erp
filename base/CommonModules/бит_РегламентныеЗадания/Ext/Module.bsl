#Область МеханизмТрансляции

// Обработчик регламентного задания "бит_ОтложеннаяТрансляция". Выполняет отложенную трансляцию движений.
// 
// Параметры:
//	Нет.
//
Процедура ОтложеннаяТрансляция() Экспорт

	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.бит_ОтложеннаяТрансляция);

	Результат = Обработки.бит_ОбработкаЗаписейРегистраОчередьТрансляции.НачатьОтложеннуюТрансляцию();
	
	Если ЭтоАдресВременногоХранилища(Результат.АдресРезультата) Тогда
		РезультатыПакета = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Для каждого РезультатПакета Из РезультатыПакета Цикл
			Если РезультатПакета.Значение.Статус = "Ошибка" Тогда
				ВызватьИсключение РезультатПакета.Значение.ПодробноеПредставлениеОшибки;	
			КонецЕсли;                     	
		КонецЦикла;
	КонецЕсли;	  
	
КонецПроцедуры

// Обработчик регламентного задания "бит_ОчисткаОчередиТрансляции". Удаляет из очереди трансляции обработанные записи.
// 
// Параметры:
//	Нет.
//
Процедура ОчисткаОчередиТрансляции()  Экспорт

	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.бит_ОчисткаОчередиТрансляции);
	
	Результат = Обработки.бит_ОбработкаЗаписейРегистраОчередьТрансляции.НачатьОтложеннуюОчисткуОчереди();
	
	Если ЭтоАдресВременногоХранилища(Результат.АдресРезультата) Тогда
		РезультатыПакета = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Для каждого РезультатПакета Из РезультатыПакета Цикл
			Если РезультатПакета.Значение.Статус = "Ошибка" Тогда
				ВызватьИсключение РезультатПакета.Значение.ПодробноеПредставлениеОшибки;	
			КонецЕсли;                     	
		КонецЦикла;
	КонецЕсли;	  

КонецПроцедуры

#КонецОбласти

