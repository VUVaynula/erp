//
Процедура СоздатьДокументыПланированияИзДопУсловий(СтруктураПараметров = Неопределено) Экспорт
	
	бит_Казначейство.СоздатьДокументыПланированияИзДопУсловий(СтруктураПараметров);	
	
КонецПроцедуры

// Обработчик регламентного задания "бит_ОбработкаНазначенияЗаместителей".
// Выполняет назначение/удаление назначения заместителей в регистрах бит_ПраваУстановкиВиз и бит_ИсполнителиЗадач.
// 
// Параметры:
//  Нет.
// 
Процедура ОбработкаНазначенияЗаместителей() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.бит_ОбработкаНазначенияЗаместителей);
	
	ИмяСобытия = НСтр("ru='Начало выполнения обработки назначения заместителей.';
					  |en='Job Appointment of deputies started.'", ОбщегоНазначения.КодОсновногоЯзыка());
	ТекстСообщения = НСтр("ru='Начало выполнения обработки назначения заместителей.';
						  |en='Job Appointment of deputies started.'"); 
    ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);

	// Завершение замещения.
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущаяДата",       НачалоДня(ТекущаяДатаСеанса())); // Снимаем заместителей, которые вчера закончились.
	Запрос.УстановитьПараметр("СостояниеНазначен", Перечисления.бит_СостоянияЗаместителей.Назначен);
	Запрос.УстановитьПараметр("СостояниеОжидание", Перечисления.бит_СостоянияЗаместителей.Ожидание);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НазначенныеЗаместители.Пользователь КАК Пользователь,
	|	НазначенныеЗаместители.Состояние КАК Состояние,
	|	НазначенныеЗаместители.Виза КАК Виза,
	|	НазначенныеЗаместители.ПользовательскоеУсловие КАК ПользовательскоеУсловие,
	|	НазначенныеЗаместители.РольИсполнителя КАК РольИсполнителя,
	|	НазначенныеЗаместители.ОбъектАдресации_1 КАК ОбъектАдресации_1,
	|	НазначенныеЗаместители.ОбъектАдресации_2 КАК ОбъектАдресации_2,
	|	НазначенныеЗаместители.ОбъектАдресации_3 КАК ОбъектАдресации_3,
	|	НазначенныеЗаместители.Заместитель КАК Заместитель,
	|	НазначенныеЗаместители.ДатаНачала КАК ДатаНачала,
	|	НазначенныеЗаместители.ДатаОкончания КАК ДатаОкончания,
	|	НазначенныеЗаместители.ПередаватьПраваРЛС КАК ПередаватьПраваРЛС,
	|	0 КАК ВидЗамещения
	|ИЗ
	|	РегистрСведений.бит_НазначенныеЗаместители КАК НазначенныеЗаместители
	|ГДЕ
	|	НазначенныеЗаместители.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
	|	И НазначенныеЗаместители.ДатаОкончания < &ТекущаяДата
	|	И (НазначенныеЗаместители.Состояние = &СостояниеНазначен
	|			ИЛИ НазначенныеЗаместители.Состояние = &СостояниеОжидание)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаместителиПоЗадачам.Пользователь,
	|	ЗаместителиПоЗадачам.Состояние,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	ЗаместителиПоЗадачам.Заместитель,
	|	ЗаместителиПоЗадачам.ДатаНачала,
	|	ЗаместителиПоЗадачам.ДатаОкончания,
	|	NULL,
	|	1
	|ИЗ
	|	РегистрСведений.бит_ЗаместителиПоЗадачам КАК ЗаместителиПоЗадачам
	|ГДЕ
	|	ЗаместителиПоЗадачам.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ЗаместителиПоЗадачам.ДатаОкончания < &ТекущаяДата
	|	И (ЗаместителиПоЗадачам.Состояние = &СостояниеНазначен
	|			ИЛИ ЗаместителиПоЗадачам.Состояние = &СостояниеОжидание)";
				   
    Результат = Запрос.Выполнить();				   
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.ВидЗамещения = 0 Тогда
			МенеджерЗаписи = РегистрыСведений.бит_НазначенныеЗаместители.СоздатьМенеджерЗаписи();
		Иначе
			МенеджерЗаписи = РегистрыСведений.бит_ЗаместителиПоЗадачам.СоздатьМенеджерЗаписи();
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
		МенеджерЗаписи.Прочитать();
		МенеджерЗаписи.Состояние = Перечисления.бит_СостоянияЗаместителей.ЗамещениеЗавершено;
		
		Попытка		
			МенеджерЗаписи.Записать();		
		Исключение
			ИмяСобытия = НСтр("ru='Ошибка обработки назначения заместителей.';
							  |en='Error in job Appointment of deputies'", ОбщегоНазначения.КодОсновногоЯзыка());
			ТекстСообщения = НСтр("ru='Не удалось завершить замещение пользователя ""%1"" пользователем ""%2"". Описание ошибки: %3.';
								  |en='Unable to complete replacement of the user ""%1"" user ""%2"". description of the error: %3.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, Выборка.Пользователь, Выборка.Заместитель, 
									   ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	        ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
		КонецПопытки;
				
	КонецЦикла; // Завершение замещения.
	
	// Назначение заместителей.
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущаяДата",       ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("СостояниеОжидание", Перечисления.бит_СостоянияЗаместителей.Ожидание);

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НазначенныеЗаместители.Состояние КАК Состояние,
	|	НазначенныеЗаместители.Виза КАК Виза,
	|	НазначенныеЗаместители.ПользовательскоеУсловие КАК ПользовательскоеУсловие,
	|	НазначенныеЗаместители.РольИсполнителя КАК РольИсполнителя,
	|	НазначенныеЗаместители.ОбъектАдресации_1 КАК ОбъектАдресации_1,
	|	НазначенныеЗаместители.ОбъектАдресации_2 КАК ОбъектАдресации_2,
	|	НазначенныеЗаместители.ОбъектАдресации_3 КАК ОбъектАдресации_3,
	|	НазначенныеЗаместители.Заместитель КАК Заместитель,
	|	НазначенныеЗаместители.ДатаНачала КАК ДатаНачала,
	|	НазначенныеЗаместители.ДатаОкончания КАК ДатаОкончания,
	|	НазначенныеЗаместители.Пользователь КАК Пользователь,
	|	НазначенныеЗаместители.ПередаватьПраваРЛС КАК ПередаватьПраваРЛС,
	|	0 КАК ВидЗамещения
	|ИЗ
	|	РегистрСведений.бит_НазначенныеЗаместители КАК НазначенныеЗаместители
	|ГДЕ
	|	НазначенныеЗаместители.Состояние = &СостояниеОжидание
	|	И НазначенныеЗаместители.ДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
	|	И НазначенныеЗаместители.ДатаНачала <= &ТекущаяДата
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаместителиПоЗадачам.Состояние,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	ЗаместителиПоЗадачам.Заместитель,
	|	ЗаместителиПоЗадачам.ДатаНачала,
	|	ЗаместителиПоЗадачам.ДатаОкончания,
	|	ЗаместителиПоЗадачам.Пользователь,
	|	NULL,
	|	1
	|ИЗ
	|	РегистрСведений.бит_ЗаместителиПоЗадачам КАК ЗаместителиПоЗадачам
	|ГДЕ
	|	ЗаместителиПоЗадачам.Состояние = &СостояниеОжидание
	|	И ЗаместителиПоЗадачам.ДатаНачала <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ЗаместителиПоЗадачам.ДатаНачала <= &ТекущаяДата";
				   
    Результат = Запрос.Выполнить();				   
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл

		Если Выборка.ВидЗамещения = 0 Тогда
			МенеджерЗаписи = РегистрыСведений.бит_НазначенныеЗаместители.СоздатьМенеджерЗаписи();
		Иначе
			МенеджерЗаписи = РегистрыСведений.бит_ЗаместителиПоЗадачам.СоздатьМенеджерЗаписи();
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка);
		МенеджерЗаписи.Прочитать();		
		МенеджерЗаписи.Состояние = Перечисления.бит_СостоянияЗаместителей.Назначен;
		
		Попытка		
			МенеджерЗаписи.Записать();		
		Исключение
			ИмяСобытия = НСтр("ru='Ошибка обработки назначения заместителей.';
							  |en='Error in job Appointment of deputies'", ОбщегоНазначения.КодОсновногоЯзыка());
			ТекстСообщения = НСтр("ru='Не удалось назначить заместителя ""%1"" пользователю ""%2"". Описание ошибки: %3.';
								  |en='Failed to appoint a deputy to ""%1"" user ""%2"". Description of the error: %3.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, Выборка.Заместитель, Выборка.Пользователь, 
									   ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	        ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);			
		КонецПопытки;
							 		
	КонецЦикла; // Завершение замещения.
	
	
	ИмяСобытия = НСтр("ru='Завершено выполнение обработки назначения заместителей.';
					  |en='Job Appointment of deputies completed.'", ОбщегоНазначения.КодОсновногоЯзыка());
	ТекстСообщения = НСтр("ru='Завершено выполнение обработки назначения заместителей.';
						  |en='Job Appointment of deputies completed.'"); 
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);
	
КонецПроцедуры

// Обработчик регламентного задания "бит_УстановкаРешенийПоПросроченнымВизам".
// Устанавливает решения по визам, по которым прошли сроки установки решения.
// 
// Параметры:
//  СтруктураПараметров - Структура.
//
Процедура УстановкаРешенийПоПросроченнымВизам(СтруктураПараметров) Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.бит_УстановкаРешенийПоПросроченнымВизам);
	
	Отбор = Новый Структура();
	Отбор.Вставить("Метаданные", "бит_УстановкаРешенийПоПросроченнымВизам");
	Задания = РегламентныеЗаданияСервер.НайтиЗадания(Отбор);

	Если Задания.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	ЗаданиеУстановкиРешений = Задания[0]; 
	
	Если Не ЗначениеЗаполнено(ЗаданиеУстановкиРешений.ИмяПользователя) Тогда
		ИмяСобытия = НСтр("ru='Ошибка выполнения регламентного задания.';
						  |en='Error performing routine tasks.'",
						  ОбщегоНазначения.КодОсновногоЯзыка());
		ТекстСообщения = НСтр("ru='Не заполнен пользователь в настройках регламентного задания.';
							  |en='Do not fill the user in the settings of scheduled jobs.'");		
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
		ВызватьИсключение ТекстСообщения;		
	КонецЕсли;
	
	// Проверим корректность переданых параметров.
	Если НЕ ТипЗнч(СтруктураПараметров) = Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
		
	Если СтруктураПараметров.Свойство("Решение") Тогда
		
		Если ЗначениеЗаполнено(СтруктураПараметров.Решение) Тогда
			РешениеВизирования = СтруктураПараметров.Решение;			
		Иначе
			ИмяСобытия = НСтр("ru='Ошибка выполнения регламентного задания.';en='Error performing routine tasks.'",
							  ОбщегоНазначения.КодОсновногоЯзыка());
			ТекстСообщения = НСтр("ru='Не заполнено решения визирования в настройках регламентного задания.';
								  |en='Not filled solutions in sight settings routine tasks.'");		
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
			ВызватьИсключение ТекстСообщения;
		КонецЕсли;
		
	Иначе
		
		Возврат;
		
	КонецЕсли;

	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(ЗаданиеУстановкиРешений.ИмяПользователя);
	ПользовательВизирования = Справочники.Пользователи.НайтиПоРеквизиту("ИдентификаторПользователяИБ", ПользовательИБ.УникальныйИдентификатор);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бит_УстановленныеВизы.Объект,
	|	бит_УстановленныеВизы.Виза,
	|	бит_УстановленныеВизы.ИД,
	|	бит_УстановленныеВизы.Пользователь,
	|	бит_УстановленныеВизы.ФизическоеЛицо,
	|	бит_УстановленныеВизы.ДобавленаВручную,
	|	бит_УстановленныеВизы.ДатаУстановки,
	|	бит_УстановленныеВизы.КодСортировки,
	|	бит_УстановленныеВизы.Должность,
	|	бит_УстановленныеВизы.Комментарий,
	|	бит_УстановленныеВизы.Статус,
	|	бит_УстановленныеВизы.Решение,
	|	бит_УстановленныеВизы.Маршрут,
	|	бит_УстановленныеВизы.Алгоритм,
	|	бит_УстановленныеВизы.ТочкаАлгоритма,
	|	бит_УстановленныеВизы.ДатаКрайняя,
	|	бит_УстановленныеВизы.ВремяНаУстановку,
	|	бит_УстановленныеВизы.ПодписанЭП,
	|	бит_УстановленныеВизы.ЭПДействительна
	|ИЗ
	|	РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы
	|ГДЕ
	|	бит_УстановленныеВизы.Пользователь = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
	|	И бит_УстановленныеВизы.ДатаКрайняя < &ТекущаяДата
	|	И бит_УстановленныеВизы.ДатаКрайняя > ДАТАВРЕМЯ(1, 1, 1)
	|	И бит_УстановленныеВизы.Решение = ЗНАЧЕНИЕ(Справочник.бит_ВидыРешенийСогласования.ПустаяСсылка)";
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(Запрос.Текст);
	
	ИмяОбъектаПолное = "";
	Если СтруктураПараметров.Свойство("ОбъектСистемы") И ЗначениеЗаполнено(СтруктураПараметров.ОбъектСистемы) Тогда
		ИмяОбъектаПолное = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураПараметров.ОбъектСистемы, "ИмяОбъектаПолное");
		СхемаЗапроса.ПакетЗапросов[0].Операторы[0].Отбор.Добавить("бит_УстановленныеВизы.Объект Ссылка "+ ИмяОбъектаПолное);
	КонецЕсли;
	Если СтруктураПараметров.Свойство("Организация") И ЗначениеЗаполнено(СтруктураПараметров.Организация) Тогда
		Если ПустаяСтрока(ИмяОбъектаПолное) Тогда
			МетаданныеОбъекта = Метаданные.НайтиПоПолномуИмени(ИмяОбъектаПолное);
			Если бит_РаботаСМетаданными.ЕстьРеквизит("Организация",МетаданныеОбъекта) Тогда
				СхемаЗапроса.ПакетЗапросов[0].Операторы[0].Отбор.Добавить("бит_УстановленныеВизы.Объект.Организация = &Организация");
				Запрос.УстановитьПараметр("Организация", СтруктураПараметров.Организация);
			КонецЕсли;
		Иначе
			СхемаЗапроса.ПакетЗапросов[0].Операторы[0].Отбор.Добавить("бит_УстановленныеВизы.Объект.Организация = &Организация");
			Запрос.УстановитьПараметр("Организация", СтруктураПараметров.Организация);
		КонецЕсли;
	КонецЕсли;
	Если СтруктураПараметров.Свойство("Статус") И ЗначениеЗаполнено(СтруктураПараметров.Статус) Тогда
		СхемаЗапроса.ПакетЗапросов[0].Операторы[0].Отбор.Добавить("бит_УстановленныеВизы.Статус = &Статус");
		Запрос.УстановитьПараметр("Статус", СтруктураПараметров.Статус);
	КонецЕсли;
	
	Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Запись = РегистрыСведений.бит_УстановленныеВизы.СоздатьМенеджерЗаписи(); 

	Пока Выборка.Следующий() Цикл 
		
        Запись.Объект = Выборка.Объект; 
        Запись.Виза   = Выборка.Виза; 
        Запись.ИД     = Выборка.ИД;
        
        Запись.Прочитать(); 
		Если Запись.Выбран() Тогда 
			Запись.ДатаУстановки = ТекущаяДатаСеанса();
			Запись.Пользователь  = ПользовательВизирования;
            Запись.Решение       = РешениеВизирования;
			Запись.Комментарий   = НСтр("ru='Решение установлено с помощью регламентного задания ""Установить решения по просроченным визам"".';
										|en='The solution found by a routine job ""Set decisions on an expired visa.""'");
			Если Запись.ПроверитьЗаполнение() Тогда
				Запись.Записать(); 
			КонецЕсли;
		КонецЕсли; 
		
	КонецЦикла; 
			
КонецПроцедуры

// Обработчик регламентного задания "бит_АвтоСогласование".
// Автоматическая установка решений по визам.
// 
// Параметры:
//  Нет.
//
Процедура АвтоСогласование() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.бит_АвтоСогласование);
	Если НЕ ПолучитьФункциональнуюОпцию("бит_ИспользоватьАвтоСогласование") Тогда
		ВызватьИсключение НСтр("ru='Регламентное задание недоступно по функциональным опциям.';
		|en='Scheduled task is not available for functional options.'");
	КонецЕсли;
	
	Отбор = Новый Структура();
	Отбор.Вставить("Метаданные", "бит_АвтоСогласование");
	Задания = РегламентныеЗаданияСервер.НайтиЗадания(Отбор);

	Если Задания.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	ЗаданиеУстановкиРешений = Задания[0]; 
	
	Если НЕ ЗначениеЗаполнено(ЗаданиеУстановкиРешений.ИмяПользователя) Тогда
		ИмяСобытия = НСтр("ru='Ошибка выполнения регламентного задания.';
						  |en='Error performing routine tasks.'",
						  ОбщегоНазначения.КодОсновногоЯзыка());
		ТекстСообщения = НСтр("ru='Не заполнен пользователь в настройках регламентного задания.';
							  |en='Do not fill the user in the settings of scheduled jobs.'");		
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
		ВызватьИсключение ТекстСообщения;		
	КонецЕсли;
	
	ПользовательИБ          = ПользователиИнформационнойБазы.НайтиПоИмени(ЗаданиеУстановкиРешений.ИмяПользователя);
	ПользовательВизирования = Справочники.Пользователи.НайтиПоРеквизиту("ИдентификаторПользователяИБ",
								ПользовательИБ.УникальныйИдентификатор);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	УстановленныеВизы.Объект КАК Объект,
	|	УстановленныеВизы.Виза КАК Виза,
	|	УстановленныеВизы.ИД КАК ИД,
	|	УстановленныеВизы.Алгоритм КАК Алгоритм,
	|	УстановленныеВизы.ДатаКрайняя КАК ДатаКрайняя,
	|	УстановленныеВизы.АктивнаяВиза КАК АктивнаяВиза
	|ПОМЕСТИТЬ АктивныеВизы
	|ИЗ
	|	РегистрСведений.бит_УстановленныеВизы КАК УстановленныеВизы
	|ГДЕ
	|	УстановленныеВизы.АктивнаяВиза
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Виза
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АктивныеВизы.Объект КАК Объект,
	|	АктивныеВизы.Виза КАК Виза,
	|	АктивныеВизы.ИД КАК ИД,
	|	НастройкиАвтоСогласования.ПользовательскоеУсловие КАК ПользовательскоеУсловие,
	|	НастройкиАвтоСогласования.Решение КАК Решение,
	|	НастройкиАвтоСогласования.Комментарий КАК Комментарий
	|ИЗ
	|	АктивныеВизы КАК АктивныеВизы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_НастройкиАвтоСогласования КАК НастройкиАвтоСогласования
	|		ПО (НастройкиАвтоСогласования.Виза = ЗНАЧЕНИЕ(Справочник.бит_Визы.ПустаяСсылка)
	|				ИЛИ АктивныеВизы.Виза = НастройкиАвтоСогласования.Виза)
	|			И (НастройкиАвтоСогласования.Алгоритм = ЗНАЧЕНИЕ(Справочник.бит_АлгоритмыПроцессов.ПустаяСсылка)
	|				ИЛИ АктивныеВизы.Алгоритм = НастройкиАвтоСогласования.Алгоритм)
	|			И (НастройкиАвтоСогласования.Просрочка = 0
	|				ИЛИ АктивныеВизы.ДатаКрайняя > ДАТАВРЕМЯ(1, 1, 1)
	|					И ДОБАВИТЬКДАТЕ(АктивныеВизы.ДатаКрайняя, МИНУТА, НастройкиАвтоСогласования.Просрочка) < &ТекущаяДата)
	|
	|УПОРЯДОЧИТЬ ПО
	|	НастройкиАвтоСогласования.ПользовательскоеУсловие = ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеУсловия.ПустаяСсылка) УБЫВ
	|ИТОГИ ПО
	|	Объект,
	|	Виза,
	|	ИД";
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	ВыборкаОбъектов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОбъектов.Следующий() Цикл
		ВыборкаВиз = ВыборкаОбъектов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаВиз.Следующий() Цикл
			ВыборкаИдентификаторов = ВыборкаВиз.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаИдентификаторов.Следующий() Цикл
				ДетальныеЗаписи = ВыборкаИдентификаторов.Выбрать();
				Пока ДетальныеЗаписи.Следующий() Цикл
					Если НЕ ЗначениеЗаполнено(ДетальныеЗаписи.ПользовательскоеУсловие) Тогда
						УстановитьРешениеАвтоСогласования(ДетальныеЗаписи, ПользовательВизирования);
						Прервать;
					Иначе
						ПараметрыУсловия = Новый Структура;
						ПараметрыУсловия.Вставить("ТекущийОбъект", ДетальныеЗаписи.Объект);
						Если бит_УправлениеПроцессами.ПроверитьПользовательскоеУсловие(ДетальныеЗаписи.ПользовательскоеУсловие,
																							ПараметрыУсловия) Тогда
							УстановитьРешениеАвтоСогласования(ДетальныеЗаписи, ПользовательВизирования);
							Прервать;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла; 
			
КонецПроцедуры

// Обработчик регламентного задания "бит_УстановкаКонтрольныхЗначений".
// 
// Параметры:
//  ПараметрыЗадания - Структура.
//
Процедура УстановкаКонтрольныхЗначений(ПараметрыЗадания) Экспорт

	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.бит_УстановкаКонтрольныхЗначений);
	Если ТипЗнч(ПараметрыЗадания) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли; 
	
	Документы.бит_УстановкаКонтрольныхЗначений.ФоновоеПроведение(ПараметрыЗадания);
	
КонецПроцедуры

// Обработчик регламентного задания "бит_УдалениеИсторииТелеграм".
// Выполняет очистку истории в регистрах бит_ПараметрыСообщенийТелеграм и бит_РеестрОбменаСТелеграм.
// 
// Параметры:
//  Нет.
//
Процедура УдалениеИсторииТелеграм() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.бит_УдалениеИсторииТелеграм);
	
	Если НЕ ПолучитьФункциональнуюОпцию("бит_ПолучатьИнформациюОтБотаТелеграм") Тогда
		ВызватьИсключение НСтр("ru='Регламентное задание недоступно по функциональным опциям.';
		|en='Scheduled task is not available for functional options.'");
	КонецЕсли;
	
	РегистрыСведений.бит_ПараметрыСообщенийТелеграм.УдалитьИсториюЗаписей();
	РегистрыСведений.бит_РеестрОбменаСТелеграм.УдалитьИсториюЗаписей();
	
КонецПроцедуры

// Обработчик регламентного задания "бит_СтартПериодическихПроцессовБФ".
// Стартует произвольные процессы по рассписанию.
// 
// Параметры:
//  ПараметрыЗадания - Структура.
//
Процедура СтартоватьПроцесс(ПараметрыЗадания) Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(
		Метаданные.РегламентныеЗадания.бит_СтартПериодическихПроцессовБФ);
	
	Если ТипЗнч(ПараметрыЗадания) = Тип("Массив") Тогда
		МассивАлгоритмов = ПараметрыЗадания;
	ИначеЕсли ТипЗнч(ПараметрыЗадания) = Тип("СправочникСсылка.бит_АлгоритмыПроцессов") Тогда
		МассивАлгоритмов = Новый Массив;
		МассивАлгоритмов.Добавить(ПараметрыЗадания);
	Иначе
		Возврат;
	КонецЕсли; 
	
	Для каждого АлгоритмПроцесса Из МассивАлгоритмов Цикл
		НачатьТранзакцию();
		Попытка
			НовыйПроцесс = БизнесПроцессы.бит_Процесс.СоздатьБизнесПроцесс();
			НовыйПроцесс.Дата = ТекущаяДатаСеанса();
			НовыйПроцесс.Заполнить(АлгоритмПроцесса);
			НовыйПроцесс.Записать();
			НовыйПроцесс.Старт();
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ВызватьИсключение ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

// Обработчик регламентного задания "бит_СозданиеКлючейДоступаЦФОСтатьяОборотов".
// Создание ключей доступа для механизма RLS.
// 
// Параметры:
//  Нет.
//
Процедура СозданиеКлючейДоступаЦФОСтатьяОборотов() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(
		Метаданные.РегламентныеЗадания.бит_СозданиеКлючейДоступаЦФОСтатьяОборотов);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПустаяСтатья", Справочники.бит_СтатьиОборотов.ПустаяСсылка()); 
	Запрос.УстановитьПараметр("ПустоеЦФО", Справочники.Подразделения.ПустаяСсылка());
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Подразделения.Ссылка КАК ЦФО,
		|	&ПустаяСтатья КАК СтатьяОборотов
		|ИЗ
		|	Справочник.Подразделения КАК Подразделения
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_КлючиДоступаЦФОСтатьиОборотов КАК КлючиДоступа
		|		ПО (КлючиДоступа.ЦФО = Подразделения.Ссылка)
		|ГДЕ
		|	КлючиДоступа.Ссылка ЕСТЬ NULL
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	&ПустоеЦФО,
		|	СтатьиОборотов.Ссылка
		|ИЗ
		|	Справочник.бит_СтатьиОборотов КАК СтатьиОборотов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_КлючиДоступаЦФОСтатьиОборотов КАК КлючиДоступа
		|		ПО (КлючиДоступа.СтатьяОборотов = СтатьиОборотов.Ссылка)
		|ГДЕ
		|	КлючиДоступа.Ссылка ЕСТЬ NULL";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.КлючиЦФОСтатьяОборотовДокумента(Выборка.ЦФО, Выборка.СтатьяОборотов);
	КонецЦикла;
		
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область АвтоСогласование

Процедура УстановитьРешениеАвтоСогласования(ПараметрыУстановкиРешения, Пользователь)
	
	КомментарийРешения = НСтр("ru='Автосогласование';en='Auto-negotiation'");
	
	Если НЕ ПустаяСтрока(ПараметрыУстановкиРешения.Комментарий) Тогда
		КомментарийРешения = КомментарийРешения + ": " + ПараметрыУстановкиРешения.Комментарий;
	КонецЕсли;
	
	ПараметрыРешения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыПринятияРешения();
	ПараметрыРешения.ОбъектВизирования    = ПараметрыУстановкиРешения.Объект;
	ПараметрыРешения.ИДВизы               = ПараметрыУстановкиРешения.ИД;
	ПараметрыРешения.ТекущийПользователь  = Пользователь;
	ПараметрыРешения.Решение              = ПараметрыУстановкиРешения.Решение;
	ПараметрыРешения.Комментарий          = КомментарийРешения;
	ПараметрыРешения.ДатаУстановкиРешения = ТекущаяДатаСеанса();
	
	Обработки.бит_КонсольОперативногоВизирования.УстановитьРешениеПоВизе(ПараметрыРешения);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
