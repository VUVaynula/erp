#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// См. УправлениеДоступом.ЗаполнитьНаборыЗначенийДоступа.
//
Процедура ЗаполнитьНаборыЗначенийДоступа(Таблица) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	Если ФактическиеДанные.Количество() = 0 Тогда
	
		Строка = Таблица.Добавить();
		Строка.ЗначениеДоступа = Перечисления.ДополнительныеЗначенияДоступа.ДоступРазрешен;
		
	Иначе
		
		// Таблица "Фактические данные"
		Для каждого СтрокаТаблицы Из ФактическиеДанные Цикл
			КлючДоступаЦФОСтатьяОборотов = Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.КлючиЦФОСтатьяОборотовДокумента(
				СтрокаТаблицы.ЦФО, СтрокаТаблицы.СтатьяОборотов);
			ДобавитьСтрокуВНаборЗначенийДоступа(КлючДоступаЦФОСтатьяОборотов, Таблица);
		КонецЦикла; 
				
		// Удалим дубли
		ПоляГруппировки = "";
		Для каждого Колонка Из Таблица.Колонки Цикл
			ПоляГруппировки = "," + Колонка.Имя + ПоляГруппировки;
		КонецЦикла; 
		
		ПоляГруппировки = Сред(ПоляГруппировки, 2);
		Таблица.Свернуть(ПоляГруппировки);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Основание = Неопределено;
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		бит_ОбщегоНазначения.ЗаполнитьПоСтруктуре(ЭтотОбъект, ДанныеЗаполнения);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Сценарий) И ДанныеЗаполнения <> Неопределено Тогда
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеЗаполнения, "Дата") Тогда
			ДатаЗаполнения = ДанныеЗаполнения.Дата;
			Если НЕ ЗначениеЗаполнено(ДатаЗаполнения) Тогда
				ДатаЗаполнения = ТекущаяДатаСеанса();	
			КонецЕсли;
		КонецЕсли;
		
		Параметры = Новый Структура;
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеЗаполнения, "Организация") Тогда
			Параметры.Вставить("Организация", ДанныеЗаполнения.Организация);	
		КонецЕсли;
		
		СценарийКандидат = бит_НастройкиПрограммы.СценарийОтраженияФактаБДДС(Параметры, ДатаЗаполнения);	
		Если НЕ ЗначениеЗаполнено(СценарийКандидат) Тогда
			СценарийКандидат = Справочники.СценарииПланирования.ФАКТ;		
		КонецЕсли;
		Сценарий = СценарийКандидат;
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Дата) Тогда
		Дата = ТекущаяДатаСеанса();	
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДатаЗаполнения) Тогда
		ДатаЗаполнения = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Сценарий) Тогда
		Сценарий = Справочники.СценарииПланирования.ФАКТ;
	КонецЕсли;
	
	Ответственный = Пользователи.ТекущийПользователь();
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)

	НепроверяемыеРеквизиты = Новый Массив();
	Если НЕ НачатПереходНаНовуюАрхитектуру Тогда
		НепроверяемыеРеквизиты.Добавить("УдалитьКурсДокумента");
		НепроверяемыеРеквизиты.Добавить("УдалитьКратностьДокумента");	
	КонецЕсли;
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли; 
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	бит_ОбщегоНазначенияПереопределяемый.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ЗавершитьПереходНаНовуюАрхитектуру();

	
	Для каждого СтрокаТаблицы Из ФактическиеДанные Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Позиция) Тогда
			СтрокаТаблицы.Позиция = Неопределено;
		КонецЕсли;
	КонецЦикла;
		
	СуммаДокумента = ФактическиеДанные.Итог("СуммаОплаты");
	
	бит_Бюджетирование.ОчиститьНеИспользуемыеАналитикиСтатейОборотов(ФактическиеДанные);
	
	// Очищаем не заполненные данные составного типа.
	КонтролируемыеКолонки = Новый Массив;
	КонтролируемыеКолонки.Добавить("Позиция");
	
	ВсегоКолонок = 12;
	Для НомерКолонки = 1 По ВсегоКолонок Цикл
		КонтролируемыеКолонки.Добавить("Аналитика_" + НомерКолонки);
	КонецЦикла;
	
	Для каждого СтрокаТаблицы Из ФактическиеДанные Цикл
		Для каждого Колонка Из КонтролируемыеКолонки Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТаблицы[Колонка]) Тогда
				СтрокаТаблицы[Колонка] = Неопределено;			
			КонецЕсли;	
		КонецЦикла;
	КонецЦикла;
	
	Для каждого СтрокаТаблицы Из Аналитики Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ЗначениеАналитики) Тогда
			СтрокаТаблицы.ЗначениеАналитики = Неопределено;			
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли; 
	
	Если Отказ Тогда
		 Возврат;
	КонецЕсли; 
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.бит_ДополнительныеАналитики");
	ЭлементБлокировки.УстановитьЗначение("Объект", ДокументОснование);
	Блокировка.Заблокировать();

	// Запишем аналитики в РС.бит_ДополнительныеАналитики, 
	// т.к. именно он используется в МХО и МеханизмеТрансляции.
	НаборАналитики = РегистрыСведений.бит_ДополнительныеАналитики.СоздатьНаборЗаписей();
	НаборАналитики.Отбор.Объект.Установить(ДокументОснование);
	НаборАналитики.Прочитать();
	
	НаборАналитики.Очистить();
	
	Если НЕ ПометкаУдаления Тогда
		Для каждого СтрокаТаблицы Из Аналитики Цикл
			Запись = НаборАналитики.Добавить();
			Запись.Объект = ДокументОснование;
			Запись.Аналитика = СтрокаТаблицы.Аналитика;
			Запись.ЗначениеАналитики = СтрокаТаблицы.ЗначениеАналитики
		КонецЦикла; 
	КонецЕсли; 
	
	НаборАналитики.Записать();
		
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Процедура проводит отражение движений денежных средств. 
//
// Параметры:
//  Отражение - ДокументСсылка.бит_ОтражениеДДС.
//  Отказ     - Булево.
//
Процедура ПровестиОтражениеДДС(Отражение, Отказ) Экспорт

	Если Отказ Тогда
		Возврат;
	КонецЕсли; 

	Если НЕ ЗначениеЗаполнено(Отражение.ДокументОснование) Тогда
		Возврат;
	КонецЕсли; 
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Регистратором является типовой первичный документ.
	Источник = Отражение.ДокументОснование.ПолучитьОбъект();
	
	бит_ОбщегоНазначенияПереопределяемый.ПередЗаписьюДокумента(Источник, РежимЗаписиДокумента.Запись, 
		РежимПроведенияДокумента.Неоперативный);
		
	// Автоматический сбор факта по бюджету.
	Документы.бит_ОтражениеФактаДДС.ДвиженияПоРегистрамОтраженияДДС(Источник, Отказ, Истина);

	// Механизм трансляции
	бит_МеханизмТрансляции.ВыполнитьТрансляцию(Источник, , , Истина);
	
	// Мезанизм хозяйственных операций.
	бит_МеханизмХозяйственныхОперацийСервер.бит_мхо_НастраиваемыеДвиженияДокументовОбработкаПроведения(Источник, Отказ, РежимПроведенияДокумента.Неоперативный);
		
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры // ПровестиОтражениеДДС()

Процедура ОбработатьПриЗаписиДокументаДДС(Источник) Экспорт
	
	РеквизитыОснования = Документы.бит_ОтражениеФактаДДС.РеквизитыОснования(Источник);
	РасшифровкаПлатежа = РеквизитыОснования.РасшифровкаПлатежа;	
	
	Если РеквизитыОснования.ПометкаУдаления <> ПометкаУдаления Тогда
		УстановитьПометкуУдаления(РеквизитыОснования.ПометкаУдаления);
	КонецЕсли; 
		
	ЗаполнитьПоОснованию(Источник);

	Если НеСинхронизироватьСумму = Ложь И ФактическиеДанные.Количество() = 1 Тогда
		СтрокаТаблицы = ФактическиеДанные[0];
		СтрокаТаблицы.СуммаОплаты = РеквизитыОснования.СуммаДокумента;
							
		Если НЕ ЗначениеЗаполнено(РасшифровкаПлатежа) Тогда
			СтрокаТаблицы.Сумма = Источник.СуммаДокумента;	
		Иначе
			ИтогоСуммаВзаиморасчетов = РасшифровкаПлатежа.Итог("СуммаВзаиморасчетов");
			ИтогоСумма				 = РасшифровкаПлатежа.Итог("СуммаОплаты");
			СтрокаТаблицы.Сумма		 = ИтогоСумма;
		КонецЕсли;
		Если СтрокаТаблицы.СуммаОплаты <> СтрокаТаблицы.Сумма И СтрокаТаблицы.СуммаОплаты <> 0 И СтрокаТаблицы.Сумма <> 0  Тогда
			// Рассчеты в у.е.
			УдалитьКурсДокумента = ОКР(СтрокаТаблицы.СуммаОплаты / СтрокаТаблицы.Сумма, 4);  
		КонецЕсли;
	КонецЕсли; 
	
	Если НЕ НеСинхронизироватьПериод Тогда
		РеквизитыОснования = Документы.бит_ОтражениеФактаДДС.РеквизитыОснования(Источник.Ссылка);
	   	Период = РеквизитыОснования.Период;
		Для каждого СтрокаТаблицы Из ФактическиеДанные Цикл
			СтрокаТаблицы.Период = Период;
		КонецЦикла; 
	КонецЕсли;
	
КонецПроцедуры
 
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьПоОснованию(Основание)

	Если НЕ Метаданные().Реквизиты.ДокументОснование.Тип.СодержитТип(ТипЗнч(Основание)) Тогда
		ТекстСообщения = НСтр("ru = 'Ввод на основании %1 не поддерживается.'; en = 'Input based on %1 is not supported.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, Основание);
		ВызватьИсключение ТекстСообщения;
	КонецЕсли;
	
	РеквизитыОснования = Документы.бит_ОтражениеФактаДДС.РеквизитыОснования(Основание);
	ДокументОснование  = РеквизитыОснования.Ссылка;
	ВалютаДокумента    = РеквизитыОснования.Валюта;

	УстановитьДатуДокумента(РеквизитыОснования);
	
	Если НЕ НеСинхронизировать Тогда
		Документы.бит_ОтражениеФактаДДС.ЗаполнитьАналитикиФактическихДанных(ЭтотОбъект, РеквизитыОснования);
		Документы.бит_ОтражениеФактаДДС.ЗаполнитьАналитикиШапкиПоФактическимДанным(Основание.Метаданные(), ФактическиеДанные, Аналитики);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьСтрокуВНаборЗначенийДоступа(ЗначениеДоступа, Таблица)
	
	СтрокаТаб = Таблица.Добавить();
	Если ЗначениеЗаполнено(ЗначениеДоступа) Тогда			
		СтрокаТаб.ЗначениеДоступа = ЗначениеДоступа;
	Иначе
		СтрокаТаб.ЗначениеДоступа = Перечисления.ДополнительныеЗначенияДоступа.ДоступРазрешен;
	КонецЕсли; 

КонецПроцедуры

Процедура УстановитьДатуДокумента(РеквизитыОснования)
	
	ТекущаяДата = Дата;
	Дата		= РеквизитыОснования.Период;
	
	Если НачалоГода(ТекущаяДата) <> НачалоГода(Дата) Тогда
		УстановитьНовыйНомер();	
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗавершитьПереходНаНовуюАрхитектуру()
	
	Перем ВсеСтрокиПривязаны, РеквизитыОснования, СтрокаТаблицы;
	
	Если НЕ НачатПереходНаНовуюАрхитектуру Тогда
		Возврат;
	КонецЕсли;
	
	ВсеСтрокиПривязаны = Истина;
	РеквизитыОснования = Документы.бит_ОтражениеФактаДДС.РеквизитыОснования(ДокументОснование);
	Для каждого СтрокаТаблицы Из ФактическиеДанные Цикл
		ПараметрыПоиска = Новый Структура("ИдентификаторСтроки", СтрокаТаблицы.ИдентификаторСтроки);
		РезультатПоиска = РеквизитыОснования.РасшифровкаПлатежа.НайтиСтроки(ПараметрыПоиска);
		Если НЕ ЗначениеЗаполнено(РезультатПоиска) Тогда
			ВсеСтрокиПривязаны = Ложь;			
		КонецЕсли;
	КонецЦикла;

	Если НЕ ВсеСтрокиПривязаны Тогда
		НачатПереходНаНовуюАрхитектуру = Ложь;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли