#Область ОбновлениеИнформационнойБазы

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьКОбработкеДокументыДляПереходаКНовойАрхитектуре(Параметры) Экспорт 

	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ОтраженияФактаДДС.Ссылка КАК ОтражениеФакта,
	|	ОтраженияФактаДДС.ДокументОснование КАК ДокументРеглУчета,
	|	РапределениеФакта.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	РапределениеФакта.НомерСтроки КАК НомерСтроки,
	|	ОтраженияФактаДДС.Дата КАК Дата,
	|	РапределениеФакта.СуммаВзаиморасчетов КАК СуммаВзаиморасчетов,
	|	РапределениеФакта.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	РапределениеФакта.СуммаОплаты КАК СуммаОплаты,
	|	ОтраженияФактаДДС.ВалютаДокумента КАК ВалютаДокумента
	|ПОМЕСТИТЬ ВТ_ДанныеОтраженияФакта
	|ИЗ
	|	Документ.бит_ОтражениеФактаДДС КАК ОтраженияФактаДДС
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_ОтражениеФактаДДС.ФактическиеДанные КАК РапределениеФакта
	|		ПО ОтраженияФактаДДС.Ссылка = РапределениеФакта.Ссылка
	|ГДЕ
	|	ОтраженияФактаДДС.ДокументОснование <> НЕОПРЕДЕЛЕНО
	|	И НЕ ОтраженияФактаДДС.НачатПереходНаНовуюАрхитектуру
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументРеглУчета,
	|	ОтражениеФакта
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК ДокументРеглУчета,
	|	ЕСТЬNULL(РасшифровкиПлатежа.НомерСтроки, 0) КАК НомерСтроки,
	|	ЕСТЬNULL(РасшифровкиПлатежа.ИдентификаторСтроки, """") КАК ИдентификаторСтроки
	|ПОМЕСТИТЬ ВТ_ДанныеДокументовРеглУчета
	|ИЗ
	|	Документ.СписаниеБезналичныхДенежныхСредств КАК Реквизиты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СписаниеБезналичныхДенежныхСредств.РасшифровкаПлатежа КАК РасшифровкиПлатежа
	|		ПО Реквизиты.Ссылка = РасшифровкиПлатежа.Ссылка
	|ГДЕ
	|	Реквизиты.Ссылка В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				ДанныеОтраженияФакта.ДокументРеглУчета
	|			ИЗ
	|				ВТ_ДанныеОтраженияФакта КАК ДанныеОтраженияФакта)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Реквизиты.Ссылка,
	|	ЕСТЬNULL(РасшифровкиПлатежа.НомерСтроки, 0),
	|	ЕСТЬNULL(РасшифровкиПлатежа.ИдентификаторСтроки, """")
	|ИЗ
	|	Документ.РасходныйКассовыйОрдер КАК Реквизиты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходныйКассовыйОрдер.РасшифровкаПлатежа КАК РасшифровкиПлатежа
	|		ПО Реквизиты.Ссылка = РасшифровкиПлатежа.Ссылка
	|ГДЕ
	|	Реквизиты.Ссылка В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				ДанныеОтраженияФакта.ДокументРеглУчета
	|			ИЗ
	|				ВТ_ДанныеОтраженияФакта КАК ДанныеОтраженияФакта)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Реквизиты.Ссылка,
	|	ЕСТЬNULL(РасшифровкиПлатежа.НомерСтроки, 0),
	|	ЕСТЬNULL(РасшифровкиПлатежа.ИдентификаторСтроки, """")
	|ИЗ
	|	Документ.ПриходныйКассовыйОрдер КАК Реквизиты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходныйКассовыйОрдер.РасшифровкаПлатежа КАК РасшифровкиПлатежа
	|		ПО Реквизиты.Ссылка = РасшифровкиПлатежа.Ссылка
	|ГДЕ
	|	Реквизиты.Ссылка В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				ДанныеОтраженияФакта.ДокументРеглУчета
	|			ИЗ
	|				ВТ_ДанныеОтраженияФакта КАК ДанныеОтраженияФакта)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Реквизиты.Ссылка,
	|	ЕСТЬNULL(РасшифровкиПлатежа.НомерСтроки, 0),
	|	ЕСТЬNULL(РасшифровкиПлатежа.ИдентификаторСтроки, """")
	|ИЗ
	|	Документ.ПоступлениеБезналичныхДенежныхСредств КАК Реквизиты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПоступлениеБезналичныхДенежныхСредств.РасшифровкаПлатежа КАК РасшифровкиПлатежа
	|		ПО Реквизиты.Ссылка = РасшифровкиПлатежа.Ссылка
	|ГДЕ
	|	Реквизиты.Ссылка В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				ДанныеОтраженияФакта.ДокументРеглУчета
	|			ИЗ
	|				ВТ_ДанныеОтраженияФакта КАК ДанныеОтраженияФакта)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Реквизиты.Ссылка,
	|	0,
	|	""""
	|ИЗ
	|	Документ.ОтчетБанкаПоОперациямЭквайринга КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				ДанныеОтраженияФакта.ДокументРеглУчета
	|			ИЗ
	|				ВТ_ДанныеОтраженияФакта КАК ДанныеОтраженияФакта)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументРеглУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_ДанныеДокументовРеглУчета.ДокументРеглУчета КАК ДокументРеглУчета,
	|	ВТ_ДанныеДокументовРеглУчета.НомерСтроки КАК НомерСтроки,
	|	ВТ_ДанныеДокументовРеглУчета.ИдентификаторСтроки КАК ИдентификаторСтроки
	|ПОМЕСТИТЬ ВТ_БезРашифровкиПлатежа
	|ИЗ
	|	ВТ_ДанныеДокументовРеглУчета КАК ВТ_ДанныеДокументовРеглУчета
	|ГДЕ
	|	ВТ_ДанныеДокументовРеглУчета.НомерСтроки = 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументРеглУчета,
	|	ИдентификаторСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_ДанныеДокументовРеглУчета.ДокументРеглУчета КАК ДокументРеглУчета,
	|	ВТ_ДанныеДокументовРеглУчета.НомерСтроки КАК НомерСтроки,
	|	ВТ_ДанныеДокументовРеглУчета.ИдентификаторСтроки КАК ИдентификаторСтроки
	|ПОМЕСТИТЬ ВТ_CРашифровкойПлатежа
	|ИЗ
	|	ВТ_ДанныеДокументовРеглУчета КАК ВТ_ДанныеДокументовРеглУчета
	|ГДЕ
	|	ВТ_ДанныеДокументовРеглУчета.НомерСтроки > 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ИдентификаторСтроки,
	|	ДокументРеглУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОтраженияФакта.ОтражениеФакта КАК ОтражениеФакта,
	|	ОтраженияФакта.ДокументРеглУчета КАК ДокументРеглУчета
	|ПОМЕСТИТЬ ВТ_ПроблемныеДокументы
	|ИЗ
	|	ВТ_ДанныеОтраженияФакта КАК ОтраженияФакта
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_БезРашифровкиПлатежа КАК РасшифровкиПлатежа
	|		ПО ОтраженияФакта.ДокументРеглУчета = РасшифровкиПлатежа.ДокументРеглУчета
	|			И ОтраженияФакта.ИдентификаторСтроки = РасшифровкиПлатежа.ИдентификаторСтроки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_БезРашифровкиПлатежа КАК ВТ_БезРашифровкиПлатежа
	|		ПО ОтраженияФакта.ДокументРеглУчета = ВТ_БезРашифровкиПлатежа.ДокументРеглУчета
	|ГДЕ
	|	РасшифровкиПлатежа.ДокументРеглУчета ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОтраженияФакта.ОтражениеФакта,
	|	ОтраженияФакта.ДокументРеглУчета
	|ИЗ
	|	ВТ_ДанныеОтраженияФакта КАК ОтраженияФакта
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_CРашифровкойПлатежа КАК РасшифровкиПлатежа
	|		ПО ОтраженияФакта.ДокументРеглУчета = РасшифровкиПлатежа.ДокументРеглУчета
	|			И ОтраженияФакта.ИдентификаторСтроки = РасшифровкиПлатежа.ИдентификаторСтроки
	|			И (РасшифровкиПлатежа.ИдентификаторСтроки <> """")
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_CРашифровкойПлатежа КАК ВТ_CРашифровкойПлатежа
	|		ПО ОтраженияФакта.ДокументРеглУчета = ВТ_CРашифровкойПлатежа.ДокументРеглУчета
	|ГДЕ
	|	РасшифровкиПлатежа.ДокументРеглУчета ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1000
	|	ВТ_ДанныеОтраженияФакта.ОтражениеФакта КАК ОтражениеФакта
	|ИЗ
	|	ВТ_ДанныеОтраженияФакта КАК ВТ_ДанныеОтраженияФакта
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПроблемныеДокументы КАК ПроблемныеДокументы
	|		ПО ВТ_ДанныеОтраженияФакта.ОтражениеФакта = ПроблемныеДокументы.ОтражениеФакта
	|ГДЕ
	|	ВТ_ДанныеОтраженияФакта.ОтражениеФакта > &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1000
	|	ВТ_ДанныеОтраженияФакта.ОтражениеФакта
	|ИЗ
	|	ВТ_ДанныеОтраженияФакта КАК ВТ_ДанныеОтраженияФакта
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПроблемныеДокументы КАК ВТ_ПроблемныеДокументы
	|		ПО ВТ_ДанныеОтраженияФакта.ОтражениеФакта = ВТ_ПроблемныеДокументы.ОтражениеФакта
	|ГДЕ
	|	ВТ_ПроблемныеДокументы.ОтражениеФакта ЕСТЬ NULL
	|	И ВТ_ДанныеОтраженияФакта.ОтражениеФакта > &Ссылка
	|	И (ВТ_ДанныеОтраженияФакта.СуммаВзаиморасчетов = 0
	|				И ВТ_ДанныеОтраженияФакта.СуммаОплаты <> 0
	|			ИЛИ ВТ_ДанныеОтраженияФакта.ВалютаВзаиморасчетов = ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)
	|				И ВТ_ДанныеОтраженияФакта.ВалютаДокумента <> ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка))
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОтражениеФакта";
	
	ОтработаныВсеДокументы = Ложь;
	Ссылка 				   = "";
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Дата УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Дата УБЫВ");
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	
	Пока НЕ ОтработаныВсеДокументы Цикл
		
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапроса;
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		ДокументыДляОбработки = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ОтражениеФакта");
		
		ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, ДокументыДляОбработки);
		
		КоличествоСсылок = ДокументыДляОбработки.Количество();
		Если КоличествоСсылок < 1000 Тогда
			ОтработаныВсеДокументы = Истина;
		КонецЕсли;
		
		Если КоличествоСсылок > 0 Тогда
			Ссылка = ДокументыДляОбработки[КоличествоСсылок - 1];
		КонецЕсли;
	КонецЦикла;	

КонецПроцедуры

Процедура ОбработатьДокументыДляПереходаКНовойАрхитектуреОтложенно(Параметры) Экспорт
	
	ОбработкаЗавершена = Истина;
	
	МетаданныеОбъекта = ПустаяСсылка().Метаданные();
	ПолноеИмяОбъекта  = МетаданныеОбъекта.ПолноеИмя();
	
	ИменаОбъектов = Новый Массив; 
	ИменаОбъектов.Добавить(Метаданные.Документы.СписаниеБезналичныхДенежныхСредств.ПолноеИмя());
	ИменаОбъектов.Добавить(Метаданные.Документы.РасходныйКассовыйОрдер.ПолноеИмя());
	ИменаОбъектов.Добавить(Метаданные.Документы.ПриходныйКассовыйОрдер.ПолноеИмя());
	ИменаОбъектов.Добавить(Метаданные.Документы.ПоступлениеБезналичныхДенежныхСредств.ПолноеИмя());
	ИменаОбъектов.Добавить(Метаданные.Документы.ОтчетБанкаПоОперациямЭквайринга.ПолноеИмя());
	
	ЕстьЗаблокированные = Ложь;
	Для каждого ИмяОбъекта Из ИменаОбъектов Цикл
		Если ОбновлениеИнформационнойБазы.ЕстьЗаблокированныеПредыдущимиОчередямиДанные(Параметры.Очередь, ИмяОбъекта) Тогда
			ЕстьЗаблокированные = Истина;
		КонецЕсли;	
	КонецЦикла;
	
	Если ЕстьЗаблокированные Тогда
		Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
										Параметры.Очередь, ПолноеИмяОбъекта);  
		Возврат;
	КонецЕсли;  	

	ВыбранныеДанные   = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;
	
	Для Каждого Строка Из ВыбранныеДанные Цикл
		
		НачатьТранзакцию();
		Попытка
			
			БлокировкаДанных = Новый БлокировкаДанных;
			ЭлементБлокировкиДанных = БлокировкаДанных.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", Строка.Ссылка);
			
			ДокументОснование		= Строка.Ссылка.ДокументОснование;
			ПространствоБлокировок 	= ДокументОснование.Метаданные().ПолноеИмя();
			ЭлементБлокировкиДанных = БлокировкаДанных.Добавить(ПространствоБлокировок);
			ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", Строка.Ссылка.ДокументОснование);
			ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Разделяемый;
			
			БлокировкаДанных.Заблокировать();
			
			ДокументОбъект = Строка.Ссылка.ПолучитьОбъект(); // Документ.бит_ОтражениеФактаДДС
			ОбъектИзменен  = Ложь;
							
			Если ДокументОснование.Метаданные() = Метаданные.Документы.ОтчетБанкаПоОперациямЭквайринга Тогда
				РасшифровкаПлатежа = Новый ТаблицаЗначений; 
			Иначе	
				РасшифровкаПлатежа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОснование, "РасшифровкаПлатежа").Выгрузить();
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(РасшифровкаПлатежа) Тогда
				// 1. ДокументОснование без ТЧ "Расшифровка платежа", 
				// в "ФактическиеДанные" заполнены идентификаторы.
				Для каждого СтрокаФактическиеДанные  Из ДокументОбъект.ФактическиеДанные Цикл
					Если СтрокаФактическиеДанные.СуммаОплаты = 0 Тогда
						СтрокаФактическиеДанные.СуммаОплаты = СтрокаФактическиеДанные.Сумма;
					КонецЕсли;
					СтрокаФактическиеДанные.ИдентификаторСтроки 			= "";	
					СтрокаФактическиеДанные.ВалютаВзаиморасчетов 			= ДокументОбъект.ВалютаДокумента;
					СтрокаФактическиеДанные.КурсЧислительВзаиморасчетов 	= 1;
					СтрокаФактическиеДанные.КурсЗнаменательВзаиморасчетов	= 1;
					СтрокаФактическиеДанные.СуммаВзаиморасчетов				= СтрокаФактическиеДанные.СуммаОплаты;
				КонецЦикла;	
				ОбъектИзменен = Истина;
			Иначе
				// 2. В ТЧ "Расшифровка платежа" не установлены идентификаторы строки.
				ДокументОснованиеИзменен = Ложь;
				
				// Обработка ошибочной ситуации, когда ТЧ есть, но в дальнейшем будет игнорироваться.
				ЕстьРасшифровкаПлатежа = бит_ОбщегоНазначенияПереопределяемый.ЕстьРасшифровкаПлатежа(
											ДокументОснование, Неопределено);
											
				Если ЕстьРасшифровкаПлатежа Тогда
					Для каждого СтрокаРасшифровкаПлатежа Из РасшифровкаПлатежа Цикл
						Если НЕ ЗначениеЗаполнено(СтрокаРасшифровкаПлатежа.ИдентификаторСтроки) Тогда
							СтрокаРасшифровкаПлатежа.ИдентификаторСтроки = Новый УникальныйИдентификатор();							
							ДокументОснованиеИзменен 		 			 = Истина;
						КонецЕсли;	
					КонецЦикла;
					Если ДокументОснованиеИзменен Тогда
						ДокументОснованиеОбъект = ДокументОснование.ПолучитьОбъект(); 
						ДокументОснованиеОбъект.РасшифровкаПлатежа.Загрузить(РасшифровкаПлатежа);
						ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОснованиеОбъект);
					КонецЕсли;
				КонецЕсли;	
				
				// Иногда "Сумма оплаты" не заполнялась.
				Для каждого СтрокаТаблицы  Из ДокументОбъект.ФактическиеДанные Цикл
					Если СтрокаТаблицы.СуммаОплаты = 0 Тогда
						СтрокаТаблицы.СуммаОплаты = СтрокаТаблицы.Сумма;
						ОбъектИзменен = Истина;
					КонецЕсли;							
				КонецЦикла;

				Если РасшифровкаПлатежа.Количество() = 1 Тогда
					// 3. ДокументОснование однострочный, но не совпадают идентификаторы.
					Для каждого СтрокаФактическиеДанные Из ДокументОбъект.ФактическиеДанные Цикл
													
						ЗаполнитьСтрокуФактическихДанныхПриПереходеНаНовуюАрхитетктуру(СтрокаФактическиеДанные,
							РасшифровкаПлатежа[0], ДокументОбъект.ВалютаДокумента, ВалютаРеглУчета, ОбъектИзменен);
							
					КонецЦикла;	
				Иначе
					// 4. ДокументОснование многострочный, но тут что-то ни так.
					РасшифровкаПлатежаБезСвязей = Новый Массив;
					Коэффициенты 				= Новый Массив;
					
					Для каждого СтрокаРасшифровкаПлатежа  Из РасшифровкаПлатежа Цикл
						ПараметрыПоиска = Новый Структура("ИдентификаторСтроки", СтрокаРасшифровкаПлатежа.ИдентификаторСтроки);
						РезультатПоиска = ДокументОбъект.ФактическиеДанные.НайтиСтроки(ПараметрыПоиска);	
						
						Если НЕ ЗначениеЗаполнено(РезультатПоиска)  Тогда
							ПараметрыПоискаПоСумме = Новый Структура("СуммаОплаты", СтрокаРасшифровкаПлатежа.Сумма);
							РезультатПоискаПоСумме = ДокументОбъект.ФактическиеДанные.НайтиСтроки(ПараметрыПоискаПоСумме);	
							Для каждого СтрокаФактическиеДанные Из РезультатПоискаПоСумме Цикл
								Если СтрокаФактическиеДанные.ИдентификаторСтроки = "" Тогда
									СтрокаФактическиеДанные.ИдентификаторСтроки = СтрокаРасшифровкаПлатежа.ИдентификаторСтроки;
									РезультатПоиска = Новый Массив; 
									РезультатПоиска.Добавить(СтрокаФактическиеДанные);
									ОбъектИзменен = Истина;
									Прервать;
								КонецЕсли;							
							КонецЦикла;
						КонецЕсли;
						
						Если ЗначениеЗаполнено(РезультатПоиска) Тогда
							Для каждого СтрокаФактическиеДанные Из РезультатПоиска Цикл
								ЗаполнитьСтрокуФактическихДанныхПриПереходеНаНовуюАрхитетктуру(СтрокаФактическиеДанные,
									СтрокаРасшифровкаПлатежа, ДокументОбъект.ВалютаДокумента, ВалютаРеглУчета, ОбъектИзменен);
							КонецЦикла;
						Иначе
							РасшифровкаПлатежаБезСвязей.Добавить(СтрокаРасшифровкаПлатежа);	
							Коэффициенты.Добавить(СтрокаРасшифровкаПлатежа.Сумма);
						КонецЕсли;
					КонецЦикла;
					
					// 5. Неск. строк "Расшифровки" с любым числом строк "Фактические данные". 
					// При этом связь по идентификатору не установлена, сумма не совпадает.
					// Как сделать: продублировать строки Фактические данные для каждой строки Расшифровки. 
					// Сумму старой строки, распределить пропорционально суммам строк Расшифровки.
											
					ФактическиеданныеБезСвязей  = Новый Массив;
					Для каждого СтрокаФактическиеДанные Из ДокументОбъект.ФактическиеДанные Цикл
						Если СтрокаФактическиеДанные.ИдентификаторСтроки = "" Тогда
							ФактическиеданныеБезСвязей.Добавить(СтрокаФактическиеДанные);	
						КонецЕсли;	
					КонецЦикла;
					
					Для каждого СтрокаФактическиеДанные Из ФактическиеданныеБезСвязей Цикл
						НовыеСтроки = Новый Массив;
						Для каждого СтрокаРасшифровкаПлатежа Из РасшифровкаПлатежаБезСвязей Цикл
							НоваяСтрока = ДокументОбъект.ФактическиеДанные.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаФактическиеДанные);
							
							ЗаполнитьСтрокуФактическихДанныхПриПереходеНаНовуюАрхитетктуру(НоваяСтрока,
								СтрокаРасшифровкаПлатежа, ДокументОбъект.ВалютаДокумента, ВалютаРеглУчета, ОбъектИзменен);
							
							НоваяСтрока.ИдентификаторСтроки = СтрокаРасшифровкаПлатежа.ИдентификаторСтроки;
							НовыеСтроки.Добавить(НоваяСтрока);
						КонецЦикла;
						
						РаспределитьСуммуПропорциональноКоэффициентам(НовыеСтроки, "СуммаОплаты", 
							Коэффициенты, СтрокаФактическиеДанные.СуммаОплаты);
						
						ДокументОбъект.ФактическиеДанные.Удалить(СтрокаФактическиеДанные);
					КонецЦикла;
					
					Для каждого СтрокаФактическиеДанные Из ДокументОбъект.ФактическиеДанные Цикл
						Если СтрокаФактическиеДанные.ИдентификаторСтроки = "" Тогда
							ДокументОбъект.НачатПереходНаНовуюАрхитектуру = Истина;
							ОбъектИзменен = Истина;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(РасшифровкаПлатежа) Тогда
				СуммаДокумента = РасшифровкаПлатежа.Итог("Сумма");
			Иначе
				СуммаДокумента = ДокументОснование.СуммаДокумента;
			КонецЕсли;
			ИтогоФактическиеДанные = ДокументОбъект.ФактическиеДанные.Итог("СуммаОплаты");
			Если ИтогоФактическиеДанные <> СуммаДокумента Тогда
				ДокументОбъект.НеСинхронизироватьСумму = Истина;
				ОбъектИзменен = Истина;
			КонецЕсли;
			
			Если ОбъектИзменен Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
			КонецЕсли;
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Строка.Ссылка);
			
			ОбъектовОбработано = ОбъектовОбработано + 1;
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			// Если не удалось обработать какой-либо документ, повторяем попытку снова.
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			
			бит_ОбновлениеИнформационнойБазыБФ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Строка.Ссылка);
		КонецПопытки;
		
	КонецЦикла;
	
	Если НЕ ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта) Тогда
		ОбработкаЗавершена = Ложь;
	КонецЕсли;
	
	Если ОбъектовОбработано = 0 И ПроблемныхОбъектов <> 0 Тогда
		ШаблонСообщения = НСтр("ru = 'Не удалось обработать некоторые документы ""Отражение факта ДДС"" (пропущены): %1'; 
								|en = 'Some documents ""Reflection of the fact DDS"" could not be processed (skipped): %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ПроблемныхОбъектов);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация, МетаданныеОбъекта,, ТекстСообщения);
	Иначе
		ШаблонСообщения = НСтр("ru = 'Обработана очередная порция документов ""Отражение факта ДДС"": %1';
								|en = 'The next batch of documents ""Reflection of the fact DDS"" has been processed: %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ОбъектовОбработано);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация,
			МетаданныеОбъекта,, ТекстСообщения);
	КонецЕсли;
	
	Параметры.ОбработкаЗавершена = ОбработкаЗавершена;
	
КонецПроцедуры

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьКОбработкеДокументыВПоставкеМСФО(Параметры) Экспорт

	ТекстЗапроса = 
	"ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Таблица.Ссылка КАК ОтражениеФакта
	|ИЗ
	|	Документ.бит_ОтражениеФактаДДС КАК Таблица
	|ГДЕ
	|	Таблица.Ссылка > &Ссылка";
	
	ЭтоПоставкаМСФО		   = НЕ ПолучитьФункциональнуюОпцию("бит_СТ"); 
	ОтработаныВсеДокументы = Ложь;
	Ссылка 				   = "";
	
	ПараметрыВыборки 					 = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.СпособВыборки		 = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Дата УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Дата УБЫВ");  
	
	Если ЭтоПоставкаМСФО Тогда
		Пока НЕ ОтработаныВсеДокументы Цикл
			
			Запрос = Новый Запрос;
			Запрос.Текст = ТекстЗапроса;
			Запрос.УстановитьПараметр("Ссылка", Ссылка);
			ДокументыДляОбработки = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ОтражениеФакта");
			
			ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, ДокументыДляОбработки);
			
			КоличествоСсылок = ДокументыДляОбработки.Количество();
			Если КоличествоСсылок < 1000 Тогда
				ОтработаныВсеДокументы = Истина;
			КонецЕсли;
			
			Если КоличествоСсылок > 0 Тогда
				Ссылка = ДокументыДляОбработки[КоличествоСсылок - 1];
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;

КонецПроцедуры 

Процедура ОбработатьДокументыПоставкиМСФО(Параметры) Экспорт

	ОбработкаЗавершена = Истина;
	
	ИмяПроцедуры	  = "ОбработатьДокументыПоставкиМСФО";
	МетаданныеОбъекта = ПустаяСсылка().Метаданные();
	ПолноеИмяОбъекта  = МетаданныеОбъекта.ПолноеИмя();
	ВыбранныеДанные   = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;   
	
	ОчищаемыеДвижения = Новый Массив;
	ОчищаемыеДвижения.Добавить(Метаданные.РегистрыНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств);
	ОчищаемыеДвижения.Добавить(Метаданные.РегистрыНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств);
	ОчищаемыеДвижения.Добавить(Метаданные.РегистрыНакопления.бит_ОборотыПоБюджетам);
	ОчищаемыеДвижения.Добавить(Метаданные.РегистрыНакопления.бит_кзн_ДвиженияДенежныхСредств);
	ОчищаемыеДвижения.Добавить(Метаданные.РегистрыБухгалтерии.бит_Бюджетирование);    
	
	Для Каждого Строка Из ВыбранныеДанные Цикл
		
		НачатьТранзакцию();
		Попытка
			
			БлокировкаДанных = Новый БлокировкаДанных;
			ЭлементБлокировкиДанных = БлокировкаДанных.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", Строка.Ссылка);
			ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Разделяемый;
			
			БлокировкаДанных.Заблокировать();
			
			ДокументОбъект		= Строка.Ссылка.ПолучитьОбъект(); // Документ.бит_ОтражениеФактаДДС
			ДокументОснование	= ДокументОбъект.ДокументОснование;
			ПредставлениеСсылка = Строка(Строка.Ссылка);
			ОбъектИзменен  		= Ложь;
			
			Если НЕ ДокументОбъект.ПометкаУдаления Тогда 	
				ДокументОбъект.ПометкаУдаления = Истина;
				ОбъектИзменен 				   = Истина;
			КонецЕсли;
							
			Если ОбъектИзменен Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ДокументОснование) Тогда
				МетаданныеДокумента = ДокументОснование.Метаданные();
				Движения			= МетаданныеДокумента.Движения;
				
				Для каждого МетаданныеНабора Из ОчищаемыеДвижения Цикл 
					Если НЕ Движения.Содержит(МетаданныеНабора) Тогда
						Продолжить;					
					КонецЕсли;     
					
					НаборЗаписей = Неопределено;
					Если ОбщегоНазначения.ЭтоРегистрБухгалтерии(МетаданныеНабора) Тогда
						НаборЗаписей = РегистрыБухгалтерии[МетаданныеНабора.Имя].СоздатьНаборЗаписей();
					ИначеЕсли ОбщегоНазначения.ЭтоРегистрНакопления(МетаданныеНабора) Тогда	
					    НаборЗаписей = РегистрыНакопления[МетаданныеНабора.Имя].СоздатьНаборЗаписей();
					КонецЕсли;
					
					Если НаборЗаписей = Неопределено Тогда
						Продолжить;				
					КонецЕсли;     
					
					НаборЗаписей.Отбор.Регистратор.Установить(ДокументОснование, Истина);
					НаборЗаписей.Прочитать();
					Если ЗначениеЗаполнено(НаборЗаписей) Тогда
						НаборЗаписей.Очистить();                        	
						ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
					КонецЕсли;					
				КонецЦикла;
			КонецЕсли;

			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Строка.Ссылка);
			
			ОбъектовОбработано = ОбъектовОбработано + 1;
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			// Если не удалось обработать какой-либо документ, повторяем попытку снова.
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			
			ОбновлениеИнформационнойБазы.ЗаписатьОшибкуВЖурналРегистрации(Строка.Ссылка, ПредставлениеСсылка, ИнформацияОбОшибке());
		КонецПопытки;
		
	КонецЦикла;
	
	Если НЕ ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта) Тогда
		ОбработкаЗавершена = Ложь;
	КонецЕсли;
	
	Если ОбъектовОбработано = 0 И ПроблемныхОбъектов <> 0 Тогда
		ШаблонСообщения = НСтр("ru = 'Процедуре ""%1"" не удалось обработать некоторые документы ""Отражение факта ДДС"" (пропущены): %2'; 
								|en = 'Some documents ""Reflection of the fact DDS"" could not be processed (skipped): %2'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ИмяПроцедуры, ПроблемныхОбъектов);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация, МетаданныеОбъекта,, ТекстСообщения);
	Иначе
		ШаблонСообщения = НСтр("ru = 'Обработана очередная порция документов ""Отражение факта ДДС"": %1';
								|en = 'The next batch of documents ""Reflection of the fact DDS"" has been processed: %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ОбъектовОбработано);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация,
			МетаданныеОбъекта,, ТекстСообщения);
	КонецЕсли;
	
	Параметры.ОбработкаЗавершена = ОбработкаЗавершена; 

КонецПроцедуры 

#КонецОбласти

// Функция выполняет поиск документа ОтражениеФакта по документу основанию.
//
// Параметры:
//  ДокументОснование - ДокументСсылка.
//
// Возвращаемое значение:
//  ДокументСсылка.бит_ОтражениеФактаДДС.
//
Функция НайтиДокументОтражение(ДокументОснование) Экспорт

	Режим = ПривилегированныйРежим();
	
	Если Не Режим Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ДокументОтражение = Документы.бит_ОтражениеФактаДДС.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	бит_ОтражениеФактаДДС.Ссылка
	|ИЗ
	|	Документ.бит_ОтражениеФактаДДС КАК бит_ОтражениеФактаДДС
	|ГДЕ
	|	бит_ОтражениеФактаДДС.ДокументОснование = &ДокументОснование";
				   
	Результат = Запрос.Выполнить();	
	Выборка = Результат.Выбрать();	
	Если Выборка.Следующий() Тогда	
		ДокументОтражение = Выборка.Ссылка;	
	КонецЕсли; 

	Если Не Режим Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат ДокументОтражение;
	
КонецФункции // НайтиДокументОтражение()

// Процедура формирует движения документа ОтражениеДДС.
//
// Параметры:
//  Источник 		   - ДокументОбъект.
//  Отказ 			   - Булево.
//  ЗаписыватьДвижения - Булево.
//
Процедура ДвиженияПоРегистрамОтраженияДДС(Источник, Отказ, ЗаписыватьДвижения) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	ОтражениеФактаДДС = НайтиДокументОтражение(Источник.Ссылка);
	
	МетаИсточник = Источник.Метаданные();
	
	ЕстьОрганизация 	= ОбщегоНазначения.ЕстьРеквизитОбъекта("Организация", МетаИсточник);
	ЕстьПроведеноБанком = ОбщегоНазначения.ЕстьРеквизитОбъекта("ПроведеноБанком", МетаИсточник);
	
	Реквизиты = Новый Структура("Дата");
	Если ЕстьОрганизация Тогда
		Реквизиты.Вставить("Организация");
	КонецЕсли;
	Если ЕстьПроведеноБанком Тогда
		Реквизиты.Вставить("ПроведеноБанком");
	КонецЕсли;
	
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Источник.Ссылка, Реквизиты);
	
	// Проверяем сначала из настроек программы БИТ.
	Параметры = Новый Структура;
	Если ЕстьОрганизация Тогда
	 	Параметры.Вставить("Организация", Реквизиты.Организация);
	КонецЕсли;		
	
	ЗапретитьБезЗаявки = бит_НастройкиПрограммы.ЗапретитьПлатежиБезЗаявки(Параметры, Реквизиты.Дата);
	ОтражатьФактБДДС   = бит_НастройкиПрограммы.ОтражатьФактБДДСНаОснованииОперУчета(Параметры, Реквизиты.Дата);
	
	Если МетаИсточник = Метаданные.Документы.РасходныйКассовыйОрдер
	 ИЛИ МетаИсточник = Метаданные.Документы.СписаниеБезналичныхДенежныхСредств Тогда		
		ПроверитьПравоПроведенияБезЗаявки(ОтражениеФактаДДС, Отказ, ЗапретитьБезЗаявки);	
	КонецЕсли; 
	
	Если Отказ Тогда	
		Возврат;	
	КонецЕсли; 
	
	Измерения 		   = бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Произвольные", "Синоним");	
    НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");	
	
	// Подготовка данных для проведения.
	ПараметрыПроведения = ПодготовитьТаблицуФактическиеДанные(Источник, НастройкиИзмерений);

	ФактическиеДанные		 = ПараметрыПроведения.ТаблицаФактическиеДанные;
	ДвиженияДенежныхСредств	 = ПараметрыПроведения.ДвиженияДенежныхСредств;
	ОстаткиПозиций			 = ПараметрыПроведения.ОстаткиПозиций;
	
	Если МетаИсточник = Метаданные.Документы.ПоступлениеБезналичныхДенежныхСредств
	 ИЛИ МетаИсточник = Метаданные.Документы.СписаниеБезналичныхДенежныхСредств Тогда		
		Если НЕ ОтражатьФактБДДС И ЕстьПроведеноБанком И НЕ Реквизиты.ПроведеноБанком Тогда		
			ОчиститьДвиженияДокумента(Источник);
			УстановитьСтатусыСвязанныхДокументов(ДвиженияДенежныхСредств);
			Возврат;		
		КонецЕсли;	
	КонецЕсли; 
	
	// Проверяем наличие в шапке аналитики "Не отражать в факте бюджета".
	Если ОтражатьВФакте(ОтражениеФактаДДС) Тогда	
		// Движения по РН.бит_ОборотыПоБюджетам
		СформироватьДвиженияОборотыПоБюджетам(Источник, ФактическиеДанные, Измерения, ЗаписыватьДвижения);	
	КонецЕсли; 
	
	// Движения по РН.бит_ДвиженияДенежныхСредств.
	СформироватьДвиженияДвиженияДенежныхСредств(Источник, ДвиженияДенежныхСредств, ЗаписыватьДвижения);
	
	// Движения по РН.бит_кзн_ПланируемыйРасходДенежныхСредств.
	СформироватьДвижениеПланируемыйРасходДС(Источник, ОстаткиПозиций, ЗаписыватьДвижения);
		
	// Движения по РН.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.
	СформироватьДвижениеПланируемыйПриходДС(Источник, ОстаткиПозиций, ЗаписыватьДвижения);
	
	УстановитьСтатусыСвязанныхДокументов(ДвиженияДенежныхСредств);
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры // ДвиженияПоРегистрамОтраженияДДС()

// Процедура производит необходимые действия при отмене проведения типовых документов.
//
// Параметры:
//  Источник - ДокументОбъект.
//  Отказ 	 - Булево.
//
Процедура ПриОтменеДвиженийПоРегистрам(Источник, Отказ) Экспорт 

	Если Отказ Тогда	
		Возврат;	
	КонецЕсли; 
	
    НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");	
	
	// Подготовка данных для проведения.
	ПараметрыПроведения		 = ПодготовитьТаблицуФактическиеДанные(Источник, НастройкиИзмерений);
	ТаблицаФактическиеДанные = ПараметрыПроведения.ТаблицаФактическиеДанные;

	УстановитьСтатусыСвязанныхДокументов(ТаблицаФактическиеДанные);

КонецПроцедуры // ПриОтменеДвиженийПоРегистрам()

Процедура ОбновитьСтатусыПлатежныхПозиций(ПлатежныеПозиции, КэшОпераций) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ПлатежныеПозиции) Тогда
		Возврат;
	КонецЕсли;
	
	ОплатыПозиций  = бит_Казначейство.ПолучитьОплатыПоПлатежнойПозиции(ПлатежныеПозиции);
	ТекущиеСтатусы = бит_ВизированиеСервер.ТекущиеСтатусы(ПлатежныеПозиции, Перечисления.бит_ВидыСтатусовОбъектов.Статус);
	
	Для каждого ПлатежнаяПозиция Из ПлатежныеПозиции Цикл
	    Если НЕ ЗначениеЗаполнено(ПлатежнаяПозиция) Тогда
	        Продолжить;
		КонецЕсли;
		
		ПараметрыУстановкиСтатуса = бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса();
		ПараметрыУстановкиСтатуса.ТекущийСтатус        = ТекущиеСтатусы.Получить(ПлатежнаяПозиция);
		ПараметрыУстановкиСтатуса.ДатаИзмененияСтатуса = ТекущаяДатаСеанса();
		
		ПараметрыОплатыЕРП = ОплатыПозиций.Получить(ПлатежнаяПозиция);
		ПараметрыОплатыЕРП.Вставить("План",    ПараметрыОплатыЕРП.СуммаПлан);
		ПараметрыОплатыЕРП.Вставить("Факт",    ПараметрыОплатыЕРП.СуммаОплата);
		ПараметрыОплатыЕРП.Вставить("Остаток", ПараметрыОплатыЕРП.Разность);
		ПараметрыУстановкиСтатуса.ПараметрыОплаты = ПараметрыОплатыЕРП;
		
		ОбъектПозиция = ПлатежнаяПозиция.ПолучитьОбъект();
		бит_ВизированиеСервер.УстановитьСтатус(ОбъектПозиция, ПараметрыУстановкиСтатуса, КэшОпераций);
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьСтатусыЗаявокПоПлатежнымПозициям(ПлатежныеПозиции, КэшОпераций) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ПлатежныеПозиции) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаявкиПлатежныхПозиций = ЗаявкиПлатежныхПозиций(ПлатежныеПозиции);
	ТекущиеСтатусы         = бит_ВизированиеСервер.ТекущиеСтатусы(ЗаявкиПлатежныхПозиций,
																Перечисления.бит_ВидыСтатусовОбъектов.Статус);
																
	Для каждого Заявка Из ЗаявкиПлатежныхПозиций Цикл
		ПараметрыУстановкиСтатуса = бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса();
		ПараметрыУстановкиСтатуса.ТекущийСтатус        = ТекущиеСтатусы.Получить(Заявка);
		ПараметрыУстановкиСтатуса.ДатаИзмененияСтатуса = ТекущаяДатаСеанса();
		
		ОбъектЗаявка = Заявка.ПолучитьОбъект();
		бит_ВизированиеСервер.УстановитьСтатус(ОбъектЗаявка, ПараметрыУстановкиСтатуса, КэшОпераций);
	КонецЦикла;
	
КонецПроцедуры

#Область Заполнение

Процедура ОбработатьСобытиеПриЗаписиПлатежногоДокумента(ОтражениеФакта, Источник, Отказ) Экспорт
	
	Основание		   = Источник.Ссылка;
	РеквизитыОснования = РеквизитыОснования(Основание);
	
	Если РеквизитыОснования.ПометкаУдаления <> ОтражениеФакта.ПометкаУдаления Тогда
		ОтражениеФакта.УстановитьПометкуУдаления(РеквизитыОснования.ПометкаУдаления);
	КонецЕсли;
	
	Если НачалоГода(ОтражениеФакта.Дата) <> НачалоГода(РеквизитыОснования.Период) Тогда
		ОтражениеФакта.УстановитьНовыйНомер();	
	КонецЕсли;

	ОтражениеФакта.ДокументОснование = РеквизитыОснования.Ссылка;
	ОтражениеФакта.ВалютаДокумента	 = РеквизитыОснования.Валюта;

	ФактическиеДанные  = ОтражениеФакта.ФактическиеДанные.Выгрузить();
	РасшифровкаПлатежа = РеквизитыОснования.РасшифровкаПлатежа;
	
	ИнициироватьФактическиеДанные(РасшифровкаПлатежа, ФактическиеДанные, ОтражениеФакта);	
	
	ОтражениеФакта.ФактическиеДанные.Загрузить(ФактическиеДанные);
	
	РеквизитыОснования.РасшифровкаПлатежа = РасшифровкаПлатежа;
	
	ЗаполнитьАналитикиФактическихДанных(ОтражениеФакта, РеквизитыОснования);  

	ЗапретитьЗаполнениеАналитик = ОтражениеФакта.НеСинхронизировать;
	Если НЕ ЗапретитьЗаполнениеАналитик Тогда
		ЗаполнитьАналитикиШапкиПоФактическимДанным(Основание.Метаданные(), ОтражениеФакта.ФактическиеДанные, ОтражениеФакта.Аналитики);
	КонецЕсли;

КонецПроцедуры
Процедура ИнициироватьФактическиеДанные(РасшифровкаПлатежа, ФактическиеДанные, ОтражениеФакта) Экспорт

	Если РасшифровкаПлатежа.Количество() = 0 Тогда
		Возврат;	
	КонецЕсли; 
	
	РаспределениеПозиций = ФактическиеДанные.Скопировать();
	
	// Удаление строк, связанных с отсутствующими строками "Расшифровки".
	Индекс = ФактическиеДанные.Количество() - 1;
	Пока Индекс >= 0 Цикл
		СтрокаТаблицы = ФактическиеДанные.Получить(Индекс);
		НайденнаяСтрока = РасшифровкаПлатежа.Найти(СтрокаТаблицы.ИдентификаторСтроки, "ИдентификаторСтроки"); 
		Если НайденнаяСтрока = Неопределено Тогда
			ФактическиеДанные.Удалить(СтрокаТаблицы);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла; 
	
	СноваРаспределятьПоПозициям = (ЗначениеЗаполнено(РаспределениеПозиций) 
									И НЕ ЗначениеЗаполнено(ФактическиеДанные));
	Если СноваРаспределятьПоПозициям Тогда
		Группировки = Новый Массив;
		Группировки.Добавить("Период");
		Группировки.Добавить("ЦФО");
		Группировки.Добавить("СтатьяОборотов");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Аналитика_1");
		Группировки.Добавить("Позиция");
		Группировки.Добавить("Заблокировать");
		
		Рессурсы = Новый Массив;
		Рессурсы.Добавить("СуммаОплаты");
		Рессурсы.Добавить("СуммаВзаиморасчетов");
		
		РаспределениеПозиций.Свернуть(СтрСоединить(Группировки, ","), СтрСоединить(Рессурсы, ","));
	КонецЕсли;
	
	ЗапретитьЗаполнениеАналитик = ОтражениеФакта.НеСинхронизировать;
	ЗапретитьЗаполнениеСумм		= ОтражениеФакта.НеСинхронизироватьСумму;
	ЗапретитьЗаполнениеПериода	= ОтражениеФакта.НеСинхронизироватьПериод;
	
	// Формирование и модификация "распределения бюджета".
	Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл
		
		Ресурсы = Новый Структура;
		Ресурсы.Вставить("СуммаОплаты", СтрокаТаблицы.СуммаОплаты);
		Ресурсы.Вставить("СуммаВзаиморасчетов", СтрокаТаблицы.СуммаВзаиморасчетов);

		РезультатПоиска = ФактическиеДанные.НайтиСтроки(Новый Структура("ИдентификаторСтроки", 
								СтрокаТаблицы.ИдентификаторСтроки));

		Если РезультатПоиска.Количество() = 0 Тогда
			СтрокаТаблицы.ЭтоНоваяСтрока = Истина;
			РезультатПоиска 			 = Новый Массив();
			
			Если СноваРаспределятьПоПозициям Тогда
				// Если до записи "Расшифровка платежа" была изменена полностью, 
				// нужно восстановить позиции в Фактических данных.
				// Для этого заполняем Фактические данные по образу версии документа,
				// а потом Расшифровку платежа распределем по таким данным.
				Для каждого РаспределениеПозиции Из РаспределениеПозиций Цикл
					СтрокаРаспределения = ФактическиеДанные.Добавить();
					
					ЗаполнитьЗначенияСвойств(СтрокаРаспределения, РаспределениеПозиции);
					РезультатПоиска.Добавить(СтрокаРаспределения);
					
					ИсключаемыеСвойства = Новый Массив;
					ИсключаемыеСвойства.Добавить("СуммаОплаты");
					ИсключаемыеСвойства.Добавить("СуммаВзаиморасчетов");
					
					ЗаполнитьЗначенияСвойств(СтрокаРаспределения, СтрокаТаблицы,, СтрСоединить(ИсключаемыеСвойства, ","));
				КонецЦикла;
			Иначе	
				СтрокаРаспределения = ФактическиеДанные.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаРаспределения, СтрокаТаблицы);
				РезультатПоиска.Добавить(СтрокаРаспределения);
			КонецЕсли;
			
		Иначе
			Если НЕ ЗапретитьЗаполнениеСумм ИЛИ НЕ ЗапретитьЗаполнениеПериода Тогда
				// Наследуем "ВалютаВзаиморасчетов, КурсЧислительВзаиморасчетов, КурсЗнаменательВзаиморасчетов",
				// если пользователь не использует свои курсы.
				Для каждого СтрокаРаспределения Из РезультатПоиска Цикл
					Если НЕ ЗапретитьЗаполнениеСумм Тогда
						ЗаполнитьЗначенияСвойств(СтрокаРаспределения, СтрокаТаблицы,
							"ВалютаВзаиморасчетов, КурсЧислительВзаиморасчетов, КурсЗнаменательВзаиморасчетов");
					КонецЕсли;
					Если НЕ ЗапретитьЗаполнениеПериода Тогда
						ЗаполнитьЗначенияСвойств(СтрокаРаспределения, СтрокаТаблицы, "Период");
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли; 
		
		Коэффициенты = Новый Массив(); 
		Для каждого СтрокаРаспределения Из РезультатПоиска Цикл
			Коэффициенты.Добавить(СтрокаРаспределения.СуммаОплаты);
		КонецЦикла;
		
		// Распределяем данные строки "расшифровки платежа" по сумме платежа в "распределении".
		// Это нужно делать и для "СуммаОплаты", потому что могла измениться сумма документа,
		// а этот факт нужно отразить в распределении.		
		
		НужноРаспределить = (СтрокаТаблицы.ЭтоНоваяСтрока 
						 ИЛИ НЕ СтрокаТаблицы.ЭтоНоваяСтрока И НЕ ЗапретитьЗаполнениеСумм);

		Если НужноРаспределить Тогда
			Для каждого Ресурс Из Ресурсы Цикл
				
				Поле  = Ресурс.Ключ;
				Сумма = Ресурс.Значение;
				
				Если РезультатПоиска.Количество() = 1 Тогда
					РезультатПоиска[0][Поле] = Сумма;
				Иначе					
					РаспределитьСуммуПропорциональноКоэффициентам(РезультатПоиска, Поле, 
						Коэффициенты, СтрокаТаблицы[Поле]);
				КонецЕсли; 					
			КонецЦикла;  
		КонецЕсли;	
		
		Если СноваРаспределятьПоПозициям Тогда
			// Все строки получили аналитики из исторических данных,
			// далее заполнять аналитики ненужно 
			СтрокаТаблицы.ЭтоНоваяСтрока = Ложь;		
		КонецЕсли;
	КонецЦикла; 
	
КонецПроцедуры

Процедура ЗаполнитьАналитикиФактическихДанных(ОтражениеФакта, РеквизитыОснования) Экспорт 
	
	НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");	
	Автозаполнение 	   = (бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_РежимАвтоЗаполненияАналитик") 
							= Перечисления.бит_РежимыАвтоЗаполненияАналитик.Заполнять);

	РазрезыБюджетирования = РазрезыБюджетирования(НастройкиИзмерений, Автозаполнение);
	Период			   	  = РеквизитыОснования.Период;
	ЗначенияПоУмолчанию	  = АналитикиИзОснования(РеквизитыОснования);
	
	ПараметрыЗаполнения = НовыеПараметрыЗаполненияПоРасшифровке();
	ПараметрыЗаполнения.Автозаполнение 		  	= Автозаполнение;
	ПараметрыЗаполнения.ЗапретитьПерезаполнение	= ОтражениеФакта.НеСинхронизировать;
	ПараметрыЗаполнения.РазрезыБюджетирования	= РазрезыБюджетирования;
	ПараметрыЗаполнения.ЗначенияПоУмолчанию		= ЗначенияПоУмолчанию;
	ПараметрыЗаполнения.СтатьиОборотов			= СтатьиОборотовПоВидуОперации(РеквизитыОснования);
	
	ФактическиеДанные = ОтражениеФакта.ФактическиеДанные.Выгрузить();
	
	ЗаполнитьПоРасшифровке(ОтражениеФакта.ФактическиеДанные, РеквизитыОснования, ПараметрыЗаполнения);
		
КонецПроцедуры

Процедура ЗаполнитьАналитикиШапкиПоФактическимДанным(МетаданныеОснования, ФактическиеДанные, Аналитики) Экспорт

	Аналитики.Очистить();
	
	Если НЕ ЗначениеЗаполнено(ФактическиеДанные) Тогда
		Возврат;	
	КонецЕсли;
	
	КонтролируемыеКолонки = Новый Массив;
	КонтролируемыеКолонки.Добавить("Позиция");
	
	ВсегоКолонок = 12;
	Для Номер = 1 По ВсегоКолонок Цикл
		КонтролируемыеКолонки.Добавить("Аналитика_" + Номер);
	КонецЦикла;
	
	Для каждого СтрокаТаблицы Из ФактическиеДанные Цикл
		Для каждого Колонка Из КонтролируемыеКолонки Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаТаблицы[Колонка]) Тогда
				СтрокаТаблицы[Колонка] = Неопределено;			
			КонецЕсли;	
		КонецЦикла;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ФактическиеДанные", ФактическиеДанные.Выгрузить());
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ФактическиеДанные.ЦФО КАК ЦФО,
	|	ФактическиеДанные.СтатьяОборотов КАК СтатьяОборотов,
	|	ФактическиеДанные.Аналитика_1 КАК Аналитика_1,
	|	ФактическиеДанные.Аналитика_2 КАК Аналитика_2,
	|	ФактическиеДанные.Аналитика_3 КАК Аналитика_3,
	|	ФактическиеДанные.Аналитика_4 КАК Аналитика_4,
	|	ФактическиеДанные.Аналитика_5 КАК Аналитика_5,
	|	ФактическиеДанные.Аналитика_6 КАК Аналитика_6,
	|	ФактическиеДанные.Аналитика_7 КАК Аналитика_7,
	|	ФактическиеДанные.Аналитика_8 КАК Аналитика_8,
	|	ФактическиеДанные.Аналитика_9 КАК Аналитика_9,
	|	ФактическиеДанные.Аналитика_10 КАК Аналитика_10,
	|	ФактическиеДанные.Аналитика_11 КАК Аналитика_11,
	|	ФактическиеДанные.Аналитика_12 КАК Аналитика_12,
	|	ФактическиеДанные.Позиция КАК Позиция
	|ПОМЕСТИТЬ ВТ_ФактическиеДанные
	|ИЗ
	|	&ФактическиеДанные КАК ФактическиеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.ЦФО) КАК СелективностьЦФО,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.СтатьяОборотов) КАК СелективностьСтатьяОборотов,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Позиция) КАК СелективностьПозиция,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_1) КАК СелективностьАналитика_1,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_2) КАК СелективностьАналитика_2,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_3) КАК СелективностьАналитика_3,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_4) КАК СелективностьАналитика_4,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_5) КАК СелективностьАналитика_5,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_6) КАК СелективностьАналитика_6,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_7) КАК СелективностьАналитика_7,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_8) КАК СелективностьАналитика_8,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_9) КАК СелективностьАналитика_9,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_10) КАК СелективностьАналитика_10,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_11) КАК СелективностьАналитика_11,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ФактическиеДанные.Аналитика_12) КАК СелективностьАналитика_12
	|ПОМЕСТИТЬ ВТ_СелективностьФактическиеДанные
	|ИЗ
	|	ВТ_ФактическиеДанные КАК ВТ_ФактическиеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьЦФО > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.ЦФО
	|	КОНЕЦ КАК ЦФО,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьСтатьяОборотов > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.СтатьяОборотов
	|	КОНЕЦ КАК СтатьяОборотов,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьПозиция > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Позиция
	|	КОНЕЦ КАК Позиция,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_1 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_1
	|	КОНЕЦ КАК Аналитика_1,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_2 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_2
	|	КОНЕЦ КАК Аналитика_2,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_3 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_3
	|	КОНЕЦ КАК Аналитика_3,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_4 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_4
	|	КОНЕЦ КАК Аналитика_4,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_5 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_5
	|	КОНЕЦ КАК Аналитика_5,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_6 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_6
	|	КОНЕЦ КАК Аналитика_6,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_7 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_7
	|	КОНЕЦ КАК Аналитика_7,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_8 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_8
	|	КОНЕЦ КАК Аналитика_8,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_9 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_9
	|	КОНЕЦ КАК Аналитика_9,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_10 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_10
	|	КОНЕЦ КАК Аналитика_10,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_11 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_11
	|	КОНЕЦ КАК Аналитика_11,
	|	ВЫБОР
	|		КОГДА ВТ_СелективностьФактическиеДанные.СелективностьАналитика_12 > 1
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ВТ_ФактическиеДанные.Аналитика_12
	|	КОНЕЦ КАК Аналитика_12
	|ИЗ
	|	ВТ_ФактическиеДанные КАК ВТ_ФактическиеДанные
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СелективностьФактическиеДанные КАК ВТ_СелективностьФактическиеДанные
	|		ПО (ИСТИНА)";
	
	РезультатЗапроса	  = Запрос.Выполнить();
	ВыборкаАналитикиШапки = РезультатЗапроса.Выбрать();

	ДополнительныеАналитики = бит_МеханизмДопИзмерений.НазначенныеДополнительныеАналитики(МетаданныеОснования);

	Если ВыборкаАналитикиШапки.Следующий() Тогда
		Для каждого СтрокаТаблицы Из ДополнительныеАналитики Цикл
			НоваяСтрока = Аналитики.Добавить();
			НоваяСтрока.Аналитика = СтрокаТаблицы.Аналитика;
								
			Если НоваяСтрока.Аналитика = ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.СтатьяОборотов Тогда
				НоваяСтрока.ЗначениеАналитики = ВыборкаАналитикиШапки.СтатьяОборотов;
			ИначеЕсли НоваяСтрока.Аналитика = ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ЦФО Тогда
				НоваяСтрока.ЗначениеАналитики = ВыборкаАналитикиШапки.ЦФО;
			Иначе
				ИмяКолонки = СокрЛП(СтрокаТаблицы.ИмяКолонки);
				Свойство   = Новый Структура(ИмяКолонки);
				ЗаполнитьЗначенияСвойств(Свойство, ВыборкаАналитикиШапки);
				
				Если ЗначениеЗаполнено(Свойство[ИмяКолонки]) Тогда
					НоваяСтрока.ЗначениеАналитики = Свойство[ИмяКолонки];
				КонецЕсли;					
			КонецЕсли;
			
			НоваяСтрока.ЗначениеАналитики = СтрокаТаблицы.Аналитика.ТипЗначения.ПривестиЗначение(НоваяСтрока.ЗначениеАналитики);
		КонецЦикла;
	КонецЕсли;
		
КонецПроцедуры

Процедура ЗаполнитьАналитикиШапкиПоДаннымОснования(ДокументОбъект, РеквизитыОснования) Экспорт
	
	Если ДокументОбъект.НеСинхронизировать Тогда	
		Возврат;	
	КонецЕсли;
	
	МетаданныеОбъекта  = РеквизитыОснования.Ссылка.Метаданные();
	НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");	
	Автозаполнение 	   = (бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_РежимАвтоЗаполненияАналитик") 
							= Перечисления.бит_РежимыАвтоЗаполненияАналитик.Заполнять);

	РазрезыБюджетирования = РазрезыБюджетирования(НастройкиИзмерений, Автозаполнение);
	ЗначенияПоУмолчанию   = АналитикиИзОснования(РеквизитыОснования);
	
	ВидыДопАналитик		 = ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик;
	АналитикиПоУмолчанию = Новый Соответствие;
	
	Для каждого КлючЗначение Из РазрезыБюджетирования Цикл
		Если ЗначениеЗаполнено(КлючЗначение.Значение) Тогда
			Настройка = НастройкиИзмерений.Получить(КлючЗначение.Значение);
			Если ЗначениеЗаполнено(Настройка) Тогда
				ВидАналитики = Настройка.Аналитика;
				АналитикиПоУмолчанию.Вставить(ВидАналитики, ЗначенияПоУмолчанию[КлючЗначение.Ключ]);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	АналитикиПоУмолчанию.Вставить(ВидыДопАналитик.СтатьяОборотов, ЗначенияПоУмолчанию.СтатьяОборотов);
	АналитикиПоУмолчанию.Вставить(ВидыДопАналитик.ЦФО,			  ЗначенияПоУмолчанию.ЦФО);
			
	ДокументОбъект.Аналитики.Очистить();
	
	ДополнительныеАналитики = бит_МеханизмДопИзмерений.НазначенныеДополнительныеАналитики(МетаданныеОбъекта);
	
	Для каждого СтрокаТаблицы Из ДополнительныеАналитики Цикл
		НоваяСтрока = ДокументОбъект.Аналитики.Добавить();
		НоваяСтрока.Аналитика = СтрокаТаблицы.Аналитика;
		
		Если Автозаполнение Тогда
			
			Значение = Неопределено;
			Если НоваяСтрока.Аналитика = ВидыДопАналитик.СтатьяОборотов Тогда 
				ЗначенияПоУмолчанию.Свойство("СтатьяОборотов", Значение);
			ИначеЕсли НоваяСтрока.Аналитика = ВидыДопАналитик.ЦФО Тогда
				ЗначенияПоУмолчанию.Свойство("ЦФО", Значение);
			ИначеЕсли НоваяСтрока.Аналитика = ВидыДопАналитик.Проект Тогда
				ЗначенияПоУмолчанию.Свойство("Проект", Значение);
			ИначеЕсли НоваяСтрока.Аналитика = ВидыДопАналитик.НаправлениеДеятельности Тогда
				ЗначенияПоУмолчанию.Свойство("НаправлениеДеятельности", Значение);
			Иначе
				Значение = АналитикиПоУмолчанию.Получить(НоваяСтрока.Аналитика);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Значение) Тогда
				НоваяСтрока.ЗначениеАналитики = Значение;			
			КонецЕсли;
		КонецЕсли; 
	КонецЦикла;
	
КонецПроцедуры

Функция РеквизитыОснования(ДокументОснование) Экспорт
	
	РеквизитыОснования = Новый Структура;
	РеквизитыОснования.Вставить("Ссылка",		 		 		 ДокументОснование);
	РеквизитыОснования.Вставить("СуммаДокумента",		 		 0);
	РеквизитыОснования.Вставить("ХозяйственнаяОперация", 		 Неопределено);
	РеквизитыОснования.Вставить("Организация",			 		 Неопределено);
	РеквизитыОснования.Вставить("РасшифровкаПлатежа",			 Новый ТаблицаЗначений);
	РеквизитыОснования.Вставить("БанковскийСчет", 		 		 Неопределено);
	РеквизитыОснования.Вставить("Касса", 				 		 Неопределено);
	РеквизитыОснования.Вставить("Контрагент", 			 		 Неопределено);
	РеквизитыОснования.Вставить("Подразделение", 		 		 Неопределено);
	РеквизитыОснования.Вставить("СтатьяДвиженияДенежныхСредств", Неопределено);
	РеквизитыОснования.Вставить("ДатаПроведенияБанком", 		 '0001-01-01');
	РеквизитыОснования.Вставить("Валюта", 						 Неопределено);
	РеквизитыОснования.Вставить("НаправлениеДеятельности", 		 Неопределено);
	
	РеквизитыОснования.Вставить("ПометкаУдаления", 				 Ложь);
	РеквизитыОснования.Вставить("Дата", 						 '0001-01-01');
	
	МетаОбъект = ДокументОснование.Метаданные();
	
	ИменаРеквизитов = Новый Массив;
	ИменаРеквизитов.Добавить("ПометкаУдаления");
	ИменаРеквизитов.Добавить("Дата");

	Для каждого КлючЗначение Из РеквизитыОснования Цикл
		ЕстьРеквизитОбъекта	= ОбщегоНазначения.ЕстьРеквизитОбъекта(КлючЗначение.Ключ, МетаОбъект);
		Если ЕстьРеквизитОбъекта Тогда
			ИменаРеквизитов.Добавить(КлючЗначение.Ключ);
		КонецЕсли;
	КонецЦикла;

	ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОснование, СтрСоединить(ИменаРеквизитов, ","));
	ЗаполнитьЗначенияСвойств(РеквизитыОснования, ЗначенияРеквизитов);
		
	Если ЗначениеЗаполнено(РеквизитыОснования.ДатаПроведенияБанком) Тогда
		РеквизитыОснования.Вставить("Период", РеквизитыОснования.ДатаПроведенияБанком);
	Иначе	
		РеквизитыОснования.Вставить("Период", РеквизитыОснования.Дата);
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаРасшифровкаПлатежа(МетаОбъект);
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	Запрос.УстановитьПараметр("Период", РеквизитыОснования.Период);

	РезультатЗапроса   = Запрос.Выполнить();
	РасшифровкаПлатежа = РезультатЗапроса.Выгрузить();
	РасшифровкаПлатежа.Колонки.Добавить("ЭтоНоваяСтрока", Новый ОписаниеТипов("Булево"));
	
	РеквизитыОснования.РасшифровкаПлатежа = РасшифровкаПлатежа;
	
	Возврат РеквизитыОснования;

КонецФункции

Процедура ЗаполнитьОтражениеФактаПоДокументамПланирования(ДокументОплаты, ДокументыПланирования, СценарийФакт) Экспорт
	
	РезультатПоиска = Документы.бит_ОтражениеФактаДДС.НайтиДокументОтражение(ДокументОплаты.Ссылка);
	ОтражениеФакта 	= РезультатПоиска.ПолучитьОбъект();
	
	// Когда в распределении фактических данных встречаются платежные позиции и позиции поступления, контроль суммы выключается.
	// В этом случае сумма позиций не может быть равна сумме платежа, т.к. позиции отражают движения + и - в бюджете.
	ЕстьПоступление = Ложь;
	ЕстьСписание    = Ложь;	
	Для Каждого СтрокаТаблицы Из ДокументыПланирования Цикл
		Если ТипЗнч(СтрокаТаблицы.Позиция) = Тип("ДокументСсылка.бит_кзн_ПозицияПоступления") Тогда
			ЕстьПоступление = Истина;		
		КонецЕсли;
		Если ТипЗнч(СтрокаТаблицы.Позиция) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция") Тогда
			ЕстьСписание = Истина;		
		КонецЕсли;	
	КонецЦикла;
	
	ОтражениеФакта.Сценарий			  	   = СценарийФакт;
	ОтражениеФакта.НеСинхронизировать	   = Истина;
	ОтражениеФакта.НеСинхронизироватьСумму = ЕстьПоступление И ЕстьСписание;	

	УстановитьДокументыПланированияВФактическиеДанные(ОтражениеФакта, ДокументОплаты, ДокументыПланирования);
	
	ЗаполнитьАналитикиШапкиПоФактическимДанным(ДокументОплаты.Метаданные(), 
		ОтражениеФакта.ФактическиеДанные, ОтражениеФакта.Аналитики);		
	
	Попытка			
		ОтражениеФакта.Записать(РежимЗаписиДокумента.Запись);			
	Исключение
		ТекстСообщения = НСтр("ru='Не удалось записать документ отражение ДДС. По причине: %1';
								|en='Could not write the document reflected the SDS: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Функция готовит таблицу для проведения документа.
//
// Параметры:
//  Источник 		   - ДокументОбъект.бит_ОтражениеДДС
//  НастройкиИзмерений - Соответствие.
//
// Возвращаемое значение:
//  Строка.
//
Функция ПодготовитьТаблицуФактическиеДанные(Источник, НастройкиИзмерений)

	ХозяйственнаяОперацияБФ = бит_КазначействоКлиентСервер.ХозяйственнаяОперацияБФ(Источник.ХозяйственнаяОперация);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументОснование", 		 Источник.Ссылка);
	Запрос.УстановитьПараметр("ХозяйственнаяОперацияБФ", ХозяйственнаяОперацияБФ);	
	
	НомераТаблиц = Новый Структура;
	Запрос.Текст = ТекстЗапросаВременныеТаблицыОтраженияФакта(НомераТаблиц)
				 + ТекстЗапросаРеквизитыСтатейОтраженияФакта(НомераТаблиц)
				 + ТекстЗапросаДополнительныеАналитикиОтраженияФакта(НомераТаблиц)
				 + ТекстЗапросаФактическиеДанныеОтраженияФакта(НомераТаблиц)
				 + ТекстЗапросаСелективностьАналитикСпискаОтраженияФакта(НомераТаблиц);
				 
	Результат 			  = Запрос.ВыполнитьПакет();
	ТаблицыОтраженияФакта = Новый Структура;
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ТаблицыОтраженияФакта.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла;
		
	РеквизитыСтатей			 = ТаблицыОтраженияФакта.РеквизитыСтатей;
	ДополнительныеАналитики  = ТаблицыОтраженияФакта.ДополнительныеАналитики;
	ФактическиеДанные 		 = ТаблицыОтраженияФакта.ФактическиеДанные;
	ТаблицаСелективности	 = ТаблицыОтраженияФакта.СелективностьАналитикСписка;
	
	Если ЗначениеЗаполнено(ТаблицаСелективности) Тогда
		СелективностьАналитикСписка = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ТаблицаСелективности[0]);
	Иначе
		СелективностьАналитикСписка = Новый Структура;
	КонецЕсли;
	  
	АналитикиШапки = Новый Соответствие;
	Для каждого СтрокаТаблицы  Из ДополнительныеАналитики Цикл
		АналитикиШапки.Вставить(СтрокаТаблицы.Аналитика, СтрокаТаблицы.ЗначениеАналитики);	
	КонецЦикла;
		
	Для каждого СтрокаТаблицы Из ФактическиеДанные Цикл
		
		Для каждого КиЗ Из НастройкиИзмерений Цикл			
			ИмяИзмерения = КиЗ.Ключ;
			ТекНастройка = КиЗ.Значение;				
			Если НЕ ЗначениеЗаполнено(СтрокаТаблицы[ИмяИзмерения]) 
			   И СелективностьАналитикСписка[ИмяИзмерения] = 1 Тогда					
				// Если не заполнено значение аналитики в таб. части - возьмем из аналитик шапки.
				СтрокаТаблицы[ИмяИзмерения] = АналитикиШапки[ТекНастройка.Аналитика];				
			КонецЕсли; 			
		КонецЦикла; 
		
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ЦФО) И СелективностьАналитикСписка.ЦФО = 1 Тогда
			СтрокаТаблицы.ЦФО = АналитикиШапки[ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ЦФО];
		КонецЕсли; 
		
		Если ЗначениеЗаполнено(СтрокаТаблицы.СтатьяОборотов) Тогда
			СтатьяОборотов = СтрокаТаблицы.СтатьяОборотов;
		Иначе	
			СтатьяОборотов = АналитикиШапки[ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.СтатьяОборотов];
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтатьяОборотов) Тогда
			РеквизитыСтатьи = РеквизитыСтатей.Найти(СтатьяОборотов, "СтатьяОборотов");
			Если ЗначениеЗаполнено(РеквизитыСтатьи) Тогда
				ЗаполнитьЗначенияСвойств(СтрокаТаблицы, РеквизитыСтатьи);	
			КонецЕсли;
		КонецЕсли;
	КонецЦикла; 
	
	КопируемыеКолонки = "Период, Позиция, Сумма, СуммаВзаиморасчетов,"
						"Валюта, ВалютаВзаиморасчетов, ВалютаПланирования,"
						"КурсЧислительВзаиморасчетов, КурсЗнаменательВзаиморасчетов,"
						"ОбъектРасчетов, Договор, Организация";
	ОстаткиПозиций = ФактическиеДанные.Скопировать(, КопируемыеКолонки);
	Для каждого СтрокаТаблицы Из ОстаткиПозиций Цикл
		Если СтрокаТаблицы.ВалютаВзаиморасчетов = СтрокаТаблицы.ВалютаПланирования Тогда
			СтрокаТаблицы.Сумма = СтрокаТаблицы.СуммаВзаиморасчетов;
			
		ИначеЕсли СтрокаТаблицы.Валюта <> СтрокаТаблицы.ВалютаПланирования Тогда
									
			ОбъектРасчетов = ?(ЗначениеЗаполнено(СтрокаТаблицы.ОбъектРасчетов), СтрокаТаблицы.ОбъектРасчетов, СтрокаТаблицы.Договор);
			
			Коэффициенты = бит_Казначейство.ПолучитьКоэффициентыПересчетаВалюты(СтрокаТаблицы.Валюта,
					СтрокаТаблицы.ВалютаПланирования, СтрокаТаблицы.Период, СтрокаТаблицы.Организация,,, 
					ОбъектРасчетов);
					
			СтрокаТаблицы.Сумма = СтрокаТаблицы.Сумма * Коэффициенты.КоэффициентПересчетаВВалютуВзаиморасчетов
		КонецЕсли;
	КонецЦикла;
	
	// Валютные перерасчеты.
	Если ЗначениеЗаполнено(ФактическиеДанные) Тогда		
		СтрокаТаблицы 	= ФактическиеДанные[0];
		Сценарий		= СтрокаТаблицы.Сценарий;
		ОтражениеСсылка = СтрокаТаблицы.ОтражениеСсылка;
		Период 			= СтрокаТаблицы.Период;
		КурсыВалют		= бит_Бюджетирование.КурсыВалютСценария(ОтражениеСсылка, Период,
									Новый Структура("Документ, Регл, Упр, Сценарий"));
									
		КурсВалютыДокумента = РаботаСКурсамиВалют.ПолучитьКурсВалюты(СтрокаТаблицы.Валюта, Период);							
		КурсыВалют.Вставить("Документ", КурсВалютыДокумента);
		
		бит_Бюджетирование.ВыполнитьПересчетыВТаблицеОборотов(ФактическиеДанные, Неопределено, КурсыВалют);
	КонецЕсли; 

	ДвиженияДенежныхСредств = ФактическиеДанные.Скопировать(Новый Структура("ОтражатьКомиссию", Ложь));
	
	Результат = Новый Структура;
	Результат.Вставить("ДвиженияДенежныхСредств",  ДвиженияДенежныхСредств);
	Результат.Вставить("ТаблицаФактическиеДанные", ФактическиеДанные);
	Результат.Вставить("ОстаткиПозиций",		   ОстаткиПозиций);
	
	Возврат Результат;
	
КонецФункции

Функция ТекстЗапросаВременныеТаблицыОтраженияФакта(НомераТаблиц)

	НомераТаблиц.Вставить("ВТ_ДополнительныеАналитики", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ВТ_ФактическиеДанные", 		НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ВТ_ДокументыПланирования", 	НомераТаблиц.Количество());
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ОбщиеАналитики.Аналитика КАК Аналитика,
	|	ОбщиеАналитики.ЗначениеАналитики КАК ЗначениеАналитики
	|ПОМЕСТИТЬ ВТ_ДополнительныеАналитики
	|ИЗ
