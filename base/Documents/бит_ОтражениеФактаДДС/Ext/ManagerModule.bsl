Функция РазрезыБюджетирования(НастройкиИзмерений, Автозаполнение)
	
	Результат = Новый Структура();
	Результат.Вставить("БанковскийСчет",		  Неопределено);
	Результат.Вставить("Касса", 				  Неопределено);
	Результат.Вставить("Организация", 			  Неопределено);
	Результат.Вставить("Контрагент", 			  Неопределено);
	Результат.Вставить("ДоговорКонтрагента",	  Неопределено);
	Результат.Вставить("ДоговорКредитаИДепозита", Неопределено);
	Результат.Вставить("Подразделение", 		  Неопределено);
	Результат.Вставить("НаправлениеДеятельности", Неопределено);
	Результат.Вставить("Проект", 				  Неопределено);
									 
	Для каждого Аналитика Из НастройкиИзмерений Цикл
		
		Если Аналитика.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.БанковскиеСчетаОрганизаций")) Тогда 
			Результат.Вставить("БанковскийСчет", Аналитика.Ключ);
		КонецЕсли;	
			
		Если Аналитика.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.Кассы")) Тогда 
			Результат.Вставить("Касса", Аналитика.Ключ);
		КонецЕсли;
		
		Если Аналитика.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.Организации")) Тогда 
			Результат.Вставить("Организация", Аналитика.Ключ);
		КонецЕсли;
		
		Если Аналитика.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.Контрагенты")) Тогда 
			Результат.Вставить("Контрагент", Аналитика.Ключ);
		КонецЕсли;
		
		Если Аналитика.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.ДоговорыКонтрагентов")) Тогда 
			Результат.Вставить("ДоговорКонтрагента", Аналитика.Ключ);
		КонецЕсли;
		
		Если Аналитика.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.ДоговорыКредитовИДепозитов")) Тогда 
			Результат.Вставить("ДоговорКредитаИДепозита", Аналитика.Ключ);
		КонецЕсли;
		
		Если Аналитика.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.СтруктураПредприятия")) Тогда 
			Результат.Вставить("Подразделение", Аналитика.Ключ);
		КонецЕсли;
		
		Если Аналитика.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.НаправленияДеятельности")) Тогда 
			Результат.Вставить("НаправлениеДеятельности", Аналитика.Ключ);
		КонецЕсли;
		
		Если Аналитика.Значение.ТипЗначения.СодержитТип(Тип("СправочникСсылка.Проекты")) Тогда 
			Результат.Вставить("Проект", Аналитика.Ключ);
		КонецЕсли;				
	КонецЦикла; 

	Возврат Результат;
	
КонецФункции

Процедура УстановитьДокументыПланированияВФактическиеДанные(ОтражениеФакта, ДокументОплаты, ДокументыПланирования) 
			
	ПлатежныеПозиции   = Новый Массив;
	ПозицииПоступления = Новый Массив;
		
	Для каждого Элемент Из ДокументыПланирования Цикл
		Если ТипЗнч(Элемент.Позиция) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция") Тогда
			ПлатежныеПозиции.Добавить(Элемент.Позиция);
		КонецЕсли;
		Если ТипЗнч(Элемент.Позиция) = Тип("ДокументСсылка.бит_кзн_ПозицияПоступления") Тогда
			ПозицииПоступления.Добавить(Элемент.Позиция);
		КонецЕсли;
	КонецЦикла;
	
	ДанныеДокументовПланирования = Новый ТаблицаЗначений;
	
	Если ЗначениеЗаполнено(ПлатежныеПозиции) Тогда
		ДанныеДокументов = Документы.бит_кзн_ПлатежнаяПозиция.РеквизитыДокумента(ПлатежныеПозиции);
		
		СкопироватьКолонкиТаблицы(ДанныеДокументов, ДанныеДокументовПланирования);
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДанныеДокументов, ДанныеДокументовПланирования);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПозицииПоступления) Тогда
		ДанныеДокументов = Документы.бит_кзн_ПозицияПоступления.РеквизитыДокумента(ПозицииПоступления);
		
		СкопироватьКолонкиТаблицы(ДанныеДокументов, ДанныеДокументовПланирования);
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДанныеДокументов, ДанныеДокументовПланирования);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДанныеДокументовПланирования) Тогда
		Возврат;
	КонецЕсли;

	ФактическиеДанные = ОтражениеФакта.ФактическиеДанные.Выгрузить();
	ФактическиеДанные.Очистить();
	ФактическиеДанные.Колонки.Добавить("СуммаПозиции", ОбщегоНазначения.ОписаниеТипаЧисло(15, 2));

	АналитикаДляДоговораЛизинг 	= Новый Массив;
	АналитикаДляДоговораКредДеп = Новый Массив;
	АналитикаДляДоговора 		= Новый Массив;
	
	НастройкиДопИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	Для каждого Настройка Из НастройкиДопИзмерений Цикл
		Для каждого ТипЗначения Из Настройка.Значение.ТипЗначения.Типы() Цикл
			Если бит_ОбщегоНазначенияКлиентСерверПереопределяемый.ЕстьДоговорыАренды()
				 И ТипЗначения = Тип("СправочникСсылка.ДоговорыАренды") Тогда
				АналитикаДляДоговораЛизинг.Добавить(Настройка.Ключ);
			КонецЕсли;	
			Если ТипЗначения = Тип("СправочникСсылка.ДоговорыКредитовИДепозитов") Тогда
				АналитикаДляДоговораКредДеп.Добавить(Настройка.Ключ);
			КонецЕсли; 
			Если ТипЗначения = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
				АналитикаДляДоговора.Добавить(Настройка.Ключ);
			КонецЕсли; 
		КонецЦикла; 
	КонецЦикла; 	
	
	ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОплаты.Ссылка, 
							"РасшифровкаПлатежа, СуммаДокумента, Дата, Валюта");	
	РасшифровкаПлатежа = ЗначенияРеквизитов.РасшифровкаПлатежа.Выгрузить();	
	
	Для каждого Элемент Из ДокументыПланирования Цикл
		
		СтрокаТаблицы = ДанныеДокументовПланирования.Найти(Элемент.Позиция, "Ссылка"); 
		Если СтрокаТаблицы = Неопределено  Тогда
			Продолжить;		
		КонецЕсли;
		
		ДокументПозиции = СтрокаТаблицы.Ссылка;

		ЗначенияЗаполнения = Новый Структура;
		ЗначенияЗаполнения.Вставить("ОбъектРасчетов");
		ЗначенияЗаполнения.Вставить("ДоговорКредитаДепозита");
		ЗначенияЗаполнения.Вставить("ДоговорАренды");
		ЗначенияЗаполнения.Вставить("Договор");
		ЗаполнитьЗначенияСвойств(ЗначенияЗаполнения, СтрокаТаблицы);
				
		НоваяСтрока = ФактическиеДанные.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы.Ссылка);
					
		НоваяСтрока.Период  = ЗначенияРеквизитов.Дата;
		НоваяСтрока.Позиция = СтрокаТаблицы.Ссылка;
		Если ЗначениеЗаполнено(РасшифровкаПлатежа) Тогда
			СтрокаРасшифровки = РасшифровкаПлатежа.Найти(Элемент.ИдентификаторСтроки, "ИдентификаторСтроки");
			Если СтрокаРасшифровки = Неопределено Тогда
				Продолжить;			
			КонецЕсли;
			
			НоваяСтрока.СуммаПозиции		= СтрокаТаблицы.СуммаДокумента;
			НоваяСтрока.СуммаОплаты 		= СтрокаРасшифровки.Сумма;
			НоваяСтрока.СуммаВзаиморасчетов = СтрокаРасшифровки.СуммаВзаиморасчетов;
				
			НоваяСтрока.ВалютаВзаиморасчетов 		  = СтрокаРасшифровки.ВалютаВзаиморасчетов;
			НоваяСтрока.КурсЧислительВзаиморасчетов   = СтрокаРасшифровки.КурсЧислительВзаиморасчетов;
			НоваяСтрока.КурсЗнаменательВзаиморасчетов = СтрокаРасшифровки.КурсЗнаменательВзаиморасчетов;
			НоваяСтрока.ИдентификаторСтроки			  = СтрокаРасшифровки.ИдентификаторСтроки;
		Иначе
			
			НоваяСтрока.СуммаПозиции		= СтрокаТаблицы.СуммаДокумента;
			НоваяСтрока.СуммаОплаты			= ЗначенияРеквизитов.СуммаДокумента;
			НоваяСтрока.СуммаВзаиморасчетов = ЗначенияРеквизитов.СуммаДокумента;
			
			НоваяСтрока.ВалютаВзаиморасчетов 		  = ЗначенияРеквизитов.Валюта;
			НоваяСтрока.КурсЧислительВзаиморасчетов   = 1;
			НоваяСтрока.КурсЗнаменательВзаиморасчетов = 1;
		КонецЕсли;
		
		Если АналитикаДляДоговораЛизинг.Количество()>0 Тогда
			Для каждого АнДогЛиз Из АналитикаДляДоговораЛизинг Цикл
				Если ЗначениеЗаполнено(ЗначенияЗаполнения.ДоговорАренды) Тогда
					НоваяСтрока[АнДогЛиз] = ЗначенияЗаполнения.ДоговорАренды;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;	
		
		Если АналитикаДляДоговораКредДеп.Количество()>0 Тогда
			Для каждого АнДогКредДеп Из АналитикаДляДоговораКредДеп Цикл
				Если ЗначениеЗаполнено(ЗначенияЗаполнения.ДоговорКредитаДепозита) Тогда
					НоваяСтрока[АнДогКредДеп] = ЗначенияЗаполнения.ДоговорКредитаДепозита;
				КонецЕсли;				
			КонецЦикла;
		КонецЕсли;
		
		Если АналитикаДляДоговора.Количество()>0 Тогда
			Для каждого АнДог Из АналитикаДляДоговора Цикл
				Если ЗначениеЗаполнено(ЗначенияЗаполнения.Договор) Тогда
					НоваяСтрока[АнДог] = ЗначенияЗаполнения.Договор;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Для каждого Колонка Из ФактическиеДанные.Колонки Цикл
			Если НЕ ЗначениеЗаполнено(НоваяСтрока[Колонка.Имя]) Тогда
				НоваяСтрока[Колонка.Имя] = Неопределено;			
			КонецЕсли;
		КонецЦикла;
	КонецЦикла; 

	// Тот случай, когда позиций несколько (список или гр. оплата).
	РаспределитьСуммуПоПозициям = Ложь;
	ЗапретитьЗаполнениеСумм		= ОтражениеФакта.НеСинхронизироватьСумму;

	Если НЕ ЗапретитьЗаполнениеСумм Тогда
		РаспределитьСуммуПоПозициям = (ДанныеДокументовПланирования.Количество() > 1);
	КонецЕсли;
	
	Если РаспределитьСуммуПоПозициям Тогда
		Если ЗначениеЗаполнено(РасшифровкаПлатежа) Тогда
			Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл
				ПараметрыОтбра = Новый Структура("ИдентификаторСтроки", СтрокаТаблицы.ИдентификаторСтроки);
				СтрокиРаспределения = ФактическиеДанные.НайтиСтроки(ПараметрыОтбра);
				
				Если СтрокиРаспределения.Количество() > 1 Тогда
					Коэффициенты = Новый Массив;
					Для каждого СтрокаРаспределения Из СтрокиРаспределения Цикл
						Коэффициенты.Добавить(СтрокаРаспределения.СуммаПозиции);					
					КонецЦикла;					
					
					РаспределитьСуммуПропорциональноКоэффициентам(СтрокиРаспределения, "СуммаОплаты", 
						Коэффициенты, СтрокаТаблицы.Сумма);
						
					РаспределитьСуммуПропорциональноКоэффициентам(СтрокиРаспределения, "СуммаВзаиморасчетов", 
						Коэффициенты, СтрокаТаблицы.СуммаВзаиморасчетов);
						
				КонецЕсли;
			КонецЦикла;
		Иначе	
			Коэффициенты = ФактическиеДанные.ВыгрузитьКолонку("СуммаПозиции");
			
			РаспределитьСуммуПропорциональноКоэффициентам(ФактическиеДанные, "СуммаОплаты", 
						Коэффициенты, ЗначенияРеквизитов.СуммаДокумента);
						
			РаспределитьСуммуПропорциональноКоэффициентам(ФактическиеДанные, "СуммаВзаиморасчетов", 
						Коэффициенты, ЗначенияРеквизитов.СуммаДокумента);			
		КонецЕсли;
	КонецЕсли;
	
	ОтражениеФакта.ФактическиеДанные.Загрузить(ФактическиеДанные);
	
КонецПроцедуры

Процедура СкопироватьКолонкиТаблицы(ТаблицаИсточник, ТаблицаПриемник)

	Для каждого Колонка Из ТаблицаИсточник.Колонки Цикл
		КолонкаПриемник = ТаблицаПриемник.Колонки.Найти(Колонка.Имя);
		Если КолонкаПриемник = Неопределено Тогда
			ТаблицаПриемник.Колонки.Добавить(Колонка.Имя);	//Колонка.ТипЗначения
		//Иначе
		//	ИсходныеТипы 	   = КолонкаПриемник.ТипЗначения;
		//	ДобавляемыеТипы	   = Колонка.ТипЗначения.Типы();
		//	
		//	КолонкаПриемник.ТипЗначения = Новый ОписаниеТипов(ИсходныеТипы, ДобавляемыеТипы);
		КонецЕсли;					
	КонецЦикла;
	
КонецПроцедуры

Процедура РаспределитьСуммуПропорциональноКоэффициентам(СтрокиРаспределения, ИмяКолонки, Коэффициенты, РаспределяемаяСумма)

	РезультатРаспределения = ОбщегоНазначенияКлиентСервер.РаспределитьСуммуПропорциональноКоэффициентам(
								РаспределяемаяСумма, Коэффициенты, 2);
								
	Если НЕ ЗначениеЗаполнено(РезультатРаспределения) Тогда
		Если ЗначениеЗаполнено(Коэффициенты) Тогда
			РезультатРаспределения = Новый Массив(Коэффициенты.Количество());
		Иначе	
			РезультатРаспределения = Новый Массив;
		КонецЕсли;							
	КонецЕсли;
	
	Индекс = 0;
	Для каждого СтрокаРаспределения Из СтрокиРаспределения Цикл
		СтрокаРаспределения[ИмяКолонки] = РезультатРаспределения.Получить(Индекс);
		Индекс = Индекс + 1;
	КонецЦикла;

КонецПроцедуры

Процедура ЗаполнитьСтрокуФактическихДанныхПриПереходеНаНовуюАрхитетктуру(Приемник, Источник, Валюта, ВалютаРеглУчета, ОбъектИзменен)

	Если НЕ ЗначениеЗаполнено(Приемник.ВалютаВзаиморасчетов) Тогда
		ВалютаВзаиморасчетов = ?(ЗначениеЗаполнено(Источник.ВалютаВзаиморасчетов), 
									Источник.ВалютаВзаиморасчетов, Валюта);
		
		Приемник.ВалютаВзаиморасчетов = ВалютаВзаиморасчетов;
		ОбъектИзменен = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Приемник.КурсЧислительВзаиморасчетов) Тогда
		КурсЧислительВзаиморасчетов = ?(ЗначениеЗаполнено(Источник.КурсЧислительВзаиморасчетов), 
											Источник.КурсЧислительВзаиморасчетов, 1);
		Приемник.КурсЧислительВзаиморасчетов = КурсЧислительВзаиморасчетов;
		ОбъектИзменен = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Приемник.КурсЗнаменательВзаиморасчетов) Тогда
		КурсЗнаменательВзаиморасчетов = ?(ЗначениеЗаполнено(Источник.КурсЗнаменательВзаиморасчетов), 
											Источник.КурсЗнаменательВзаиморасчетов, 1);
		Приемник.КурсЗнаменательВзаиморасчетов = КурсЗнаменательВзаиморасчетов;
		ОбъектИзменен = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Приемник.СуммаВзаиморасчетов) Тогда
		
		ПараметрыПередачи = Новый Структура;
		ПараметрыПередачи.Вставить("КурсЧислительВзаиморасчетов", 	Приемник.КурсЧислительВзаиморасчетов);
		ПараметрыПередачи.Вставить("КурсЗнаменательВзаиморасчетов", Приемник.КурсЗнаменательВзаиморасчетов);
		ПараметрыПередачи.Вставить("СуммаВзаиморасчетов", 			Приемник.СуммаВзаиморасчетов);
		ПараметрыПередачи.Вставить("Сумма", 						Приемник.СуммаОплаты);
		
		ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
			ПараметрыПередачи, Валюта, ВалютаРеглУчета);
		
		Приемник.СуммаВзаиморасчетов = ПараметрыПередачи.СуммаВзаиморасчетов; 
		ОбъектИзменен = Истина;	
	КонецЕсли;
	
	Приемник.ИдентификаторСтроки = Источник.ИдентификаторСтроки;

КонецПроцедуры

#КонецОбласти

#КонецЕсли
