// Процедура формирует движение по регистру Планируемый расход ДС.
//
// Параметры:
//  Источник 				 - ДокументОбъект.
//  ТаблицаФактическиеДанные - ТаблицаЗначений.
//  ЗаписыватьДвижения		 - Булево.
//
Процедура СформироватьДвижениеПланируемыйРасходДС(Источник, ТаблицаФактическиеДанные, ЗаписыватьДвижения)

	СтрОтбор = Новый Структура();
	СтрОтбор.Вставить("Регистратор", Источник.Ссылка);
	
	// Выполнение движений.
	Если ЗаписыватьДвижения Тогда
		НаборЗаписей = бит_ОбщегоНазначения.ПолучитьНаборЗаписейСОтбором(РегистрыНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств, 
																		 СтрОтбор, 
																		 Истина);
	Иначе	
		НаборЗаписей = Источник.Движения.бит_кзн_ПланируемыйРасходДенежныхСредств;
	КонецЕсли;
	
	НаборЗаписей.Записывать = Истина;
	
	ТаблицаДвижений = НаборЗаписей.Выгрузить();
	ТаблицаДвижений.Очистить();
	
	Для каждого Стр Из ТаблицаФактическиеДанные Цикл
		
		Если ЗначениеЗаполнено(Стр.Позиция) И ТипЗнч(Стр.Позиция) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция") Тогда		
			НоваяСтрока = ТаблицаДвижений.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Стр);
			НоваяСтрока.ВидДвижения 		 = ВидДвиженияНакопления.Расход;
			НоваяСтрока.Организация 		 = Источник.Организация;
			НоваяСтрока.Регистратор 		 = Источник;
			НоваяСтрока.ДокументПланирования = Стр.Позиция.ДокументПланирования;
			НоваяСтрока.ВидПлана 			 = Перечисления.бит_кзн_ВидыПланов.План;			
		КонецЕсли;
		
	КонецЦикла; 
	
	Если ТаблицаДвижений.Количество() > 0 Тогда	
		НаборЗаписей.мТаблицаДвижений = ТаблицаДвижений;
		НаборЗаписей.Очистить();
		НаборЗаписей.ДобавитьДвижение();		
		// Запись выполняем безусловно, т.к. это необходимо для установки статусов.
		НаборЗаписей.Записать();
	Иначе
		НаборЗаписей.Очистить();
		НаборЗаписей.Записать();
	КонецЕсли;	
	
КонецПроцедуры

// Процедура формирует движение по регистру бит_кзн_ПланируемоеПоступлениеДенежныхСредств.
//
// Параметры:
//  Источник 				 - ДокументОбъект.
//  ТаблицаФактическиеДанные - ТаблицаЗначений.
//  ЗаписыватьДвижения 		 - Булево.
//
Процедура СформироватьДвижениеПланируемыйПриходДС(Источник, ТаблицаФактическиеДанные, ЗаписыватьДвижения)

	СтрОтбор = Новый Структура();
	СтрОтбор.Вставить("Регистратор", Источник.Ссылка);
	
	// Выполнение движений.
	Если ЗаписыватьДвижения Тогда
		НаборЗаписей = бит_ОбщегоНазначения.ПолучитьНаборЗаписейСОтбором(РегистрыНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств, СтрОтбор, Истина);
	Иначе	
		НаборЗаписей = Источник.Движения.бит_кзн_ПланируемоеПоступлениеДенежныхСредств;
	КонецЕсли;
	
	НаборЗаписей.Записывать = Истина;
	
	ТаблицаДвижений = НаборЗаписей.Выгрузить();
	ТаблицаДвижений.Очистить();
	
	Для каждого Стр Из ТаблицаФактическиеДанные Цикл
		
		Если ЗначениеЗаполнено(Стр.Позиция) И ТипЗнч(Стр.Позиция) = Тип("ДокументСсылка.бит_кзн_ПозицияПоступления") Тогда 			
			НоваяСтрока = ТаблицаДвижений.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Стр);		
			НоваяСтрока.ВидДвижения          = ВидДвиженияНакопления.Расход;
			НоваяСтрока.Организация          = Источник.Организация;
			// Для хоз операций бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию, организацию для поступления вытаскиваем 
			// из банковского счета получателя
			Если ТипЗнч(Источник) = Тип("ДокументОбъект.СписаниеБезналичныхДенежныхСредств") Тогда
				ИмяХозОпер = бит_РаботаСМетаданными.ПолучитьИмяЗначенияПеречисления(Перечисления.ХозяйственныеОперации,Источник.ХозяйственнаяОперация);
				Если ИмяХозОпер = "ВнутренняяПередачаДенежныхСредств" ИЛИ ИмяХозОпер = "ОплатаДенежныхСредствВДругуюОрганизацию" 
					ИЛИ ИмяХозОпер = "ВозвратДенежныхСредствВДругуюОрганизацию" Тогда				
					НоваяСтрока.Организация = Источник.БанковскийСчетПолучатель.Владелец;				
				КонецЕсли;			
			КонецЕсли; 
			НоваяСтрока.Регистратор          = Источник;
			НоваяСтрока.ДокументПланирования = Стр.Позиция.ДокументПланирования;
			НоваяСтрока.ВидПлана             = Стр.Позиция.ВидПлана;			
		КонецЕсли; 
		
	КонецЦикла; 
	
	Если ТаблицаДвижений.Количество() > 0 Тогда	
		НаборЗаписей.мТаблицаДвижений = ТаблицаДвижений;
		НаборЗаписей.ДобавитьДвижение();		
		// Запись выполняем безусловно, т.к. это необходимо для установки статусов.
		НаборЗаписей.Записать();
	Иначе
		НаборЗаписей.Очистить();
		НаборЗаписей.Записать();
	КонецЕсли; 
	
КонецПроцедуры // СформироватьДвижениеПланируемыйПриходДС()

// Процедура формируем движения по оборотам по бюджетам. 
//
// Параметры:
//  Источник 				 - ДокументОбъект.
//  ТаблицаФактическиеДанные - ТаблицаЗначений.
//  ЗаписыватьДвижения 		 - Булево.
//
Процедура СформироватьДвиженияОборотыПоБюджетам(Источник, ТаблицаФактическиеДанные, Измерения, ЗаписыватьДвижения)

	// Проверим необходимость формирования факта.
	СтруктураПараметров = Новый Структура;
	МетаИсточник = Источник.Метаданные();
	Если бит_РаботаСМетаданными.ЕстьРеквизит("Организация", МетаИсточник)  Тогда
	 	СтруктураПараметров.Вставить("Организация", Источник.Организация);
	КонецЕсли;		
	
	ФормироватьФактАвтоматически = НЕ бит_НастройкиПрограммы.НеФормироватьДвиженияПоФактуАвтоматически(СтруктураПараметров, 
											Источник.Дата);
	
	Если НЕ ФормироватьФактАвтоматически Тогда	
		Возврат;	
	КонецЕсли; 
	
	// Подготовка данных для проведения.
	ФормироватьЗависимыеОбороты  = бит_НастройкиПрограммы.ФормироватьЗависимыеОборотыПриАвтоматическомСбореФакта(
										СтруктураПараметров, Источник.Дата);
										
	ФормироватьПроводки = НЕ бит_НастройкиПрограммы.НеФормироватьПроводкиБюджетированияПриАвтоматическомСбореФакта(
										СтруктураПараметров, Источник.Дата);									
		
	// Выполнение движений.
	Если ЗаписыватьДвижения Тогда
		НаборЗаписей = бит_ОбщегоНазначения.ПолучитьНаборЗаписейСОтбором(РегистрыНакопления.бит_ОборотыПоБюджетам, 
							Новый Структура("Регистратор", Источник.Ссылка));
	Иначе	
		НаборЗаписей = Источник.Движения.бит_ОборотыПоБюджетам;
	КонецЕсли;
	
	НаборЗаписей.Записывать = Истина;
	
	ТаблицаДвижений = НаборЗаписей.Выгрузить();
	ТаблицаДвижений.Очистить();
		
	Для каждого СтрокаТаблицы Из ТаблицаФактическиеДанные Цикл
		
		СтрокаДвижений = ТаблицаДвижений.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДвижений,СтрокаТаблицы);
		
		УчитыватьНаправление = СтрокаТаблицы.ХозяйственнаяОперация <> Перечисления.бит_ВидыОперацийКазначейства.СдачаДенежныхСредствВБанк
						     И СтрокаТаблицы.ХозяйственнаяОперация <> Перечисления.бит_ВидыОперацийКазначейства.ПоступлениеДенежныхСредствИзБанка
							 И ЗначениеЗаполнено(СтрокаТаблицы.СтатьяОборотовРасходДоход);
		
		Если УчитыватьНаправление И НЕ СтрокаТаблицы.ОтражатьКомиссию Тогда 
			Коэффициент = 1;
			Если ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.СписаниеБезналичныхДенежныхСредств") 
				И СтрокаТаблицы.СтатьяОборотовРасходДоход = Перечисления.бит_РасходДоход.Поступление Тогда
				Коэффициент = - 1;
			ИначеЕсли ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.РасходныйКассовыйОрдер") 
				И СтрокаТаблицы.СтатьяОборотовРасходДоход = Перечисления.бит_РасходДоход.Поступление Тогда
				Коэффициент = - 1;
			ИначеЕсли ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.ПоступлениеБезналичныхДенежныхСредств")  
				И СтрокаТаблицы.СтатьяОборотовРасходДоход = Перечисления.бит_РасходДоход.Расходование Тогда
				Коэффициент = - 1;
			ИначеЕсли ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.ПриходныйКассовыйОрдер") 
				И СтрокаТаблицы.СтатьяОборотовРасходДоход = Перечисления.бит_РасходДоход.Расходование Тогда
				Коэффициент = - 1;
			КонецЕсли; 
			СтрокаДвижений.Сумма 	 	 = СтрокаДвижений.Сумма * Коэффициент;
			СтрокаДвижений.СуммаРегл 	 = СтрокаДвижений.СуммаРегл * Коэффициент;
			СтрокаДвижений.СуммаСценарий = СтрокаДвижений.СуммаСценарий * Коэффициент;
			СтрокаДвижений.СуммаУпр 	 = СтрокаДвижений.СуммаУпр * Коэффициент;
		КонецЕсли;
		
		// Проверка допустимости ввода аналитик.
		Для каждого КлючИЗначение Из Измерения Цикл
			ИмяИзмерения     = КлючИЗначение.Ключ;
			ИмяРеквизитаУчет = "Учет_" + КлючИЗначение.Ключ;
			Если НЕ СтрокаТаблицы[ИмяРеквизитаУчет] Тогда					
				СтрокаДвижений[ИмяИзмерения] = Неопределено;					
			КонецЕсли; 
		КонецЦикла; // Измерения.
	КонецЦикла; 
	
	НаборЗаписей.мТаблицаДвижений = ТаблицаДвижений;
	НаборЗаписей.ДобавитьДвижение();
	
	Если ФормироватьЗависимыеОбороты Тогда		
		бит_Бюджетирование.СформироватьЗависимыеОборотыПоНаборуЗаписей(Источник, НаборЗаписей);		
	КонецЕсли; 
		
	Если ФормироватьПроводки Тогда
		СформироватьПроводкиБюджетирования(Источник, НаборЗаписей, ТаблицаФактическиеДанные, 
			ЗаписыватьДвижения, ФормироватьЗависимыеОбороты);
	КонецЕсли; 	
	
	Если ЗаписыватьДвижения Тогда
		НаборЗаписей.Записать();
	КонецЕсли;	

КонецПроцедуры

Процедура СформироватьПроводкиБюджетирования(Источник, НаборЗаписей, ТаблицаФактическиеДанные, 
				ЗаписыватьДвижения, ФормироватьЗависимыеОбороты)
	
	Если ЗаписыватьДвижения Тогда
		Проводки = бит_ОбщегоНазначения.ПолучитьНаборЗаписейСОтбором(РегистрыБухгалтерии.бит_Бюджетирование, 
						Новый Структура("Регистратор", Источник.Ссылка));
	Иначе	
		Проводки = Источник.Движения.бит_Бюджетирование;
	КонецЕсли;
	
	ФактическиеДанные = ТаблицаФактическиеДанные.Скопировать();
	Если ФормироватьЗависимыеОбороты Тогда
		ФактическиеДанные.Очистить();
		Для каждого Элемент Из НаборЗаписей Цикл			
			НоваяСтрока = ФактическиеДанные.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Элемент);			
		КонецЦикла;			
	КонецЕсли;	
	
	бит_Бюджетирование.СформироватьПроводкиБюджетирования(ФактическиеДанные, Проводки);
	
	Если ЗаписыватьДвижения Тогда
		Проводки.Записать();	
	КонецЕсли;	

КонецПроцедуры

// Процедура формирует движения по РН.бит_ДвиженияДенежныхСредств.
//
// Параметры:
//  Источник 				 - ДокументОбъект.
//  ТаблицаФактическиеДанные - ТаблицаЗначений.
//  ЗаписыватьДвижения 		 - Булево.
//
Процедура СформироватьДвиженияДвиженияДенежныхСредств(Источник, ТаблицаФактическиеДанные, ЗаписыватьДвижения)
	
	СтрОтбор = Новый Структура();
	СтрОтбор.Вставить("Регистратор", Источник.Ссылка);
	
	// опредеяем вид денежных средств
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ПриходныйКассовыйОрдер") 
		ИЛИ ТипЗнч(Источник) = Тип("ДокументОбъект.РасходныйКассовыйОрдер") Тогда
		ВидДенежныхСредств = Перечисления.бит_ВидыДенежныхСредств.Наличные;
		БанковскийСчет     = Источник.Касса;
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПоступлениеБезналичныхДенежныхСредств") 
		ИЛИ ТипЗнч(Источник) = Тип("ДокументОбъект.СписаниеБезналичныхДенежныхСредств") Тогда
		ВидДенежныхСредств = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
		БанковскийСчет     = Источник.БанковскийСчет;
	КонецЕсли;
	
	// определяем вид движения денежных средств
	Если бит_КазначействоКлиентСервер.ЭтоДокументПоступленияДС(Источник.Ссылка) Тогда
		РасходДоход = Перечисления.бит_РасходДоход.Поступление;
	Иначе
		РасходДоход = Перечисления.бит_РасходДоход.Расходование;
	КонецЕсли;
	
	// выполнение движений
	Если ЗаписыватьДвижения Тогда
		НаборЗаписей = бит_ОбщегоНазначения.ПолучитьНаборЗаписейСОтбором(РегистрыНакопления.бит_кзн_ДвиженияДенежныхСредств, СтрОтбор);
	Иначе	
		НаборЗаписей = Источник.Движения.бит_кзн_ДвиженияДенежныхСредств;
	КонецЕсли;
	
	НаборЗаписей.Записывать = Истина;
	
	ТаблицаДвижений = НаборЗаписей.Выгрузить();
	ТаблицаДвижений.Очистить();
	
	Для каждого СтрокаТаблицы Из ТаблицаФактическиеДанные Цикл
		
		НоваяСтрока = ТаблицаДвижений.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);		
		
		// Для хоз операций бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию, организацию 
		// для поступления вытаскиваем из банковского счета получателя.
		Если Источник.Метаданные() = Метаданные.Документы.СписаниеБезналичныхДенежныхСредств Тогда
			ХозОперация = Источник.ХозяйственнаяОперация;
			Если ХозОперация = Перечисления.ХозяйственныеОперации.ВнутренняяПередачаДенежныхСредств
			 ИЛИ ХозОперация = Перечисления.ХозяйственныеОперации.ОплатаДенежныхСредствВДругуюОрганизацию 
			 ИЛИ ХозОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствВДругуюОрганизацию Тогда					
				НоваяСтрока.Организация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.БанковскийСчетПолучатель, "Владелец");
			Иначе
				НоваяСтрока.Организация = Источник.Организация;
			КонецЕсли;
		Иначе
			НоваяСтрока.Организация = Источник.Организация;
		КонецЕсли; 
		
		НоваяСтрока.РасходДоход 		 = РасходДоход;
		НоваяСтрока.Регистратор          = Источник;
		НоваяСтрока.ВидДенежныхСредств   = ВидДенежныхСредств;
		НоваяСтрока.БанковскийСчет       = БанковскийСчет;
		Если ЗначениеЗаполнено(СтрокаТаблицы.Позиция) Тогда
			НоваяСтрока.ДокументПланирования = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТаблицы.Позиция, "ДокументПланирования");
		КонецЕсли;
	КонецЦикла; 
	
	НаборЗаписей.мТаблицаДвижений = ТаблицаДвижений;
	НаборЗаписей.ДобавитьДвижение();
	
	// Запись выполняем безусловно, т.к. это необходимо для установки статусов.
	НаборЗаписей.Записать();
	
КонецПроцедуры

Функция ОтражатьВФакте(ОтражениеФактаДДС)

	ОтражатьВФакте = Истина;
	
	Для каждого Аналитика Из ОтражениеФактаДДС.Аналитики Цикл	
		Если Аналитика.Аналитика = ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.НеОтражатьВФакте
			И Аналитика.ЗначениеАналитики = Истина Тогда		
			ОтражатьВФакте = Ложь;
			Прервать;		
		КонецЕсли;		
	КонецЦикла; 

	Возврат ОтражатьВФакте;
	
КонецФункции

// Процедура проверяет право проведения документа без заявки.
//
// Параметры:
//  ДокДДС - ДокуменСсылка.бит_ОтражениеФактаДДС.
//  Отказ  - Булево.
//
Процедура ПроверитьПравоПроведенияБезЗаявки(Документ, Отказ, ЗапретитьБезЗаявки)

	Если НЕ ЗапретитьБезЗаявки Тогда		
		Возврат;	
	КонецЕсли; 								
	
	ОтсутствуетПозиция = Ложь;
	Для каждого Стр Из Документ.ФактическиеДанные Цикл	
		Если НЕ ЗначениеЗаполнено(Стр.Позиция) Тогда		
			ОтсутствуетПозиция = Истина;
			Прервать;		
		КонецЕсли;	
	КонецЦикла;
	
	Если ОтсутствуетПозиция Тогда
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Аналитика", ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.СтатьяОборотов);
		НайденныеСтроки = Документ.Аналитики.НайтиСтроки(ПараметрыОтбора);
		Если НайденныеСтроки.Количество() > 0 Тогда		
			СтатьяИзШапки = НайденныеСтроки[0].ЗначениеАналитики;
			
		Иначе	
			СтатьяИзШапки = Справочники.бит_СтатьиОборотов.ПустаяСсылка();
		КонецЕсли; 
		
		Для каждого Стр Из Документ.ФактическиеДанные Цикл
		
			Если ЗначениеЗаполнено(Стр.СтатьяОборотов) Тогда
			
				РазрешитьПроведение = Стр.СтатьяОборотов.РазрешитьПроводитьБезЗаявки;
				Если НЕ РазрешитьПроведение Тогда					
					ТекстСообщения = НСтр("ru='Для статьи оборотов ""%1"" запрещено проводить документ без заявки.';
										  |en='For speed article ""%1"" not allowed to carry out the document without the application.'");
					ТекстСообщения = СтрШаблон(ТекстСообщения, Стр.СтатьяОборотов.НаименованиеПолное);
					Прервать;					
				КонецЕсли; 
			
			Иначе 
				
				Если ЗначениеЗаполнено(СтатьяИзШапки) Тогда				
					РазрешитьПроведение = СтатьяИзШапки.РазрешитьПроводитьБезЗаявки;
					Если НЕ РазрешитьПроведение Тогда						
						ТекстСообщения = НСтр("ru='Для статьи оборотов ""%1"" запрещено проводить документ без заявки.';
											  |en='For speed article ""%1"" not allowed to carry out the document without the application.'");
						ТекстСообщения = СтрШаблон(ТекстСообщения, СтатьяИзШапки.НаименованиеПолное);
						Прервать;						
					КонецЕсли;			
				Иначе			
					ТекстСообщения = НСтр("ru='Для пустой статьи оборотов запрещено проводить документ без заявки.';
										  |en='To empty revolutions articles prohibited from the document without the application.'");
					РазрешитьПроведение = Ложь;
					Прервать;					
				КонецЕсли;	
					
			КонецЕсли; 
		
		КонецЦикла; 
		
		Если НЕ РазрешитьПроведение Тогда		
			Отказ = Истина;
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		
		КонецЕсли; 
		
	КонецЕсли; 

КонецПроцедуры // ПроверитьПравоПроведенияБезЗаявки()

Процедура ОчиститьДвиженияДокумента(Источник)
	
	Перем Регистры;
	
	Регистры = Новый Массив; 
	Регистры.Добавить("бит_ОборотыПоБюджетам");
	Регистры.Добавить("бит_кзн_ДвиженияДенежныхСредств");
	Регистры.Добавить("бит_кзн_ПланируемыйРасходДенежныхСредств");
	Регистры.Добавить("бит_кзн_ПланируемоеПоступлениеДенежныхСредств");
	
	ПроведениеДокументов.ОчиститьДвиженияДокумента(Источник, СтрСоединить(Регистры, ","));

КонецПроцедуры

Процедура УстановитьСтатусыСвязанныхДокументов(ТаблицаФактическиеДанные)
	
	Если ТаблицаФактическиеДанные.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПлатежныеПозиции = ТаблицаФактическиеДанные.ВыгрузитьКолонку("Позиция");
	бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(ПлатежныеПозиции);
	
	КэшОпераций = бит_ВизированиеСервер.НовыйКэшОперацийУстановкиСтатусов();
	ОбновитьСтатусыПлатежныхПозиций(ПлатежныеПозиции, КэшОпераций);
	ОбновитьСтатусыЗаявокПоПлатежнымПозициям(ПлатежныеПозиции, КэшОпераций);
	
КонецПроцедуры

Функция ЗаявкиПлатежныхПозиций(ПлатежныеПозиции)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПлатежныеПозиции.ДокументПланирования КАК Заявка
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|ГДЕ
	|	ПлатежныеПозиции.Ссылка В(&ПлатежныеПозиции)
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ПозицииПоступления.ДокументПланирования
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК ПозицииПоступления
	|ГДЕ
	|	ПозицииПоступления.Ссылка В(&ПлатежныеПозиции)";
	Запрос.УстановитьПараметр("ПлатежныеПозиции", ПлатежныеПозиции);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Заявка");
	
КонецФункции

Функция АналитикиПоНастройкамПользователя(Основание)
	
	МетаОбъект = Основание.Метаданные();
	
	ЦФО = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
				ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнойЦФО);
				
	Проект = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
				ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнойПроект);	
				
	НаправлениеДеятельности = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
								ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнаяНоменклатурнаяГруппа);		
				
	Если МетаОбъект = Метаданные.Документы.РасходныйКассовыйОрдер 
	 ИЛИ МетаОбъект = Метаданные.Документы.СписаниеБезналичныхДенежныхСредств Тогда		
		СтатьяКандидат = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
							ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнаяСтатьяРасходованиеБДДС);
	ИначеЕсли МетаОбъект = Метаданные.Документы.ПриходныйКассовыйОрдер 
		  ИЛИ МетаОбъект = Метаданные.Документы.ПоступлениеБезналичныхДенежныхСредств Тогда
			СтатьяКандидат = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
									ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнаяСтатьяПоступлениеБДДС);
		
	ИначеЕсли МетаОбъект = Метаданные.Документы.ОтчетБанкаПоОперациямЭквайринга Тогда											
		СтатьяКандидат = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
							ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнаяСтатьяПоступлениеБДДС);											
	КонецЕсли; 
	
	СтатьяОборотов = Неопределено;
	Если ЗначениеЗаполнено(СтатьяКандидат) Тогда
		ТипСтатьи = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтатьяКандидат, "ТипСтатьи");	
		Если СтатьяКандидат.ТипСтатьи = Перечисления.бит_ТипыСтатейОборотов.БДДС Тогда 
			СтатьяОборотов = СтатьяКандидат;
		КонецЕсли;
	КонецЕсли;

	АналитикиПоНастройкам = Новый Структура;	
	АналитикиПоНастройкам.Вставить("СтатьяОборотов", 		  СтатьяОборотов);
	АналитикиПоНастройкам.Вставить("ЦФО",			 		  ЦФО);
	АналитикиПоНастройкам.Вставить("Проект",		 		  Проект);
	АналитикиПоНастройкам.Вставить("НаправлениеДеятельности", НаправлениеДеятельности);
	
	Возврат АналитикиПоНастройкам;
	
КонецФункции

Функция ЗначениеАналитикиНаправлениеДеятельности(Данные)

	НаправлениеДеятельности = Неопределено;
	
	СвойстваДанных = Новый Структура;
	СвойстваДанных.Вставить("НаправлениеДеятельности", Неопределено);
	СвойстваДанных.Вставить("РасшифровкаПлатежа", Неопределено);
	ЗаполнитьЗначенияСвойств(СвойстваДанных, Данные);
	
	Если ЗначениеЗаполнено(СвойстваДанных.НаправлениеДеятельности) Тогда
		НаправлениеДеятельности = СвойстваДанных.НаправлениеДеятельности;
	ИначеЕсли ЗначениеЗаполнено(СвойстваДанных.РасшифровкаПлатежа) Тогда	
		ДанныеСтроки = Новый Структура("НаправлениеДеятельности, АналитикаРасходов");
		ЗаполнитьЗначенияСвойств(ДанныеСтроки, СвойстваДанных.РасшифровкаПлатежа[0]);
		
		Если ЗначениеЗаполнено(ДанныеСтроки.НаправлениеДеятельности) Тогда
			НаправлениеДеятельности = ДанныеСтроки.НаправлениеДеятельности;					
		ИначеЕсли ТипЗнч(ДанныеСтроки.АналитикаРасходов) = Тип("СправочникСсылка.НаправленияДеятельности") Тогда	
			НаправлениеДеятельности = ДанныеСтроки.АналитикаРасходов;
		КонецЕсли;
	КонецЕсли;
	
	Возврат НаправлениеДеятельности;
	
КонецФункции

Функция НовыеПараметрыЗаполненияПоРасшифровке()

	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("Автозаполнение", 			  Ложь);
	ПараметрыЗаполнения.Вставить("ЗапретитьПерезаполнение",   Ложь); 			// См. ДокументОбъект.НеСинхронизировать
	ПараметрыЗаполнения.Вставить("РазрезыБюджетирования", 	  Новый Структура); // См. РазрезыБюджетирования()
	ПараметрыЗаполнения.Вставить("ЗначенияПоУмолчанию", 	  Новый Структура); // См. АналитикиПоОснованию() 
	ПараметрыЗаполнения.Вставить("СтатьиОборотов", 	  		  Новый Массив);	// См. СтатьяОборотовПоВидуОперации()
	
	Возврат ПараметрыЗаполнения;
	
КонецФункции

Функция НоваяТаблицаРаспределенияБюджета()

	РаспределениеБюджета = Новый ТаблицаЗначений;
	
	Таблицы = Новый Массив;
	Таблицы.Добавить(Метаданные.Документы.бит_ОтражениеФактаДДС.ТабличныеЧасти.ФактическиеДанные);
	Таблицы.Добавить(Метаданные.Документы.ПоступлениеБезналичныхДенежныхСредств.ТабличныеЧасти.РасшифровкаПлатежа);
	Таблицы.Добавить(Метаданные.Документы.СписаниеБезналичныхДенежныхСредств.ТабличныеЧасти.РасшифровкаПлатежа);
	Таблицы.Добавить(Метаданные.Документы.ПриходныйКассовыйОрдер.ТабличныеЧасти.РасшифровкаПлатежа);
	Таблицы.Добавить(Метаданные.Документы.РасходныйКассовыйОрдер.ТабличныеЧасти.РасшифровкаПлатежа);

	Для каждого Таблица Из Таблицы Цикл
		Колонки = Таблица.Реквизиты;
		Для каждого Колонка Из Колонки Цикл
			Если РаспределениеБюджета.Колонки.Найти(Колонка.Имя) = Неопределено Тогда
				РаспределениеБюджета.Колонки.Добавить(Колонка.Имя, Колонка.Тип);			
			КонецЕсли;		
		КонецЦикла;
	КонецЦикла;
	
	// Дополняю реквизитами шапки документа.
	РаспределениеБюджета.Колонки.Добавить("БанковскийСчет");
	РаспределениеБюджета.Колонки.Добавить("Касса");
	
	Возврат РаспределениеБюджета;
	
КонецФункции

Процедура ЗаполнитьПоРасшифровке(ФактическиеДанные, РеквизитыОснования, ПараметрыЗаполнения)
	
	Период			   = РеквизитыОснования.Период;
	РасшифровкаПлатежа = РеквизитыОснования.РасшифровкаПлатежа;
	СтатьяОборотов	   = ПараметрыЗаполнения.СтатьиОборотов[0];
	
	Автозаполнение			= ПараметрыЗаполнения.Автозаполнение;
	ЗапретитьПерезаполнение = ПараметрыЗаполнения.ЗапретитьПерезаполнение;
	
	Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл
	
		МожноЗаполнять = (СтрокаТаблицы.ЭтоНоваяСтрока  
					 ИЛИ НЕ СтрокаТаблицы.ЭтоНоваяСтрока И НЕ ЗапретитьПерезаполнение);
					 
		 Если МожноЗаполнять И Автозаполнение Тогда
			 ОтборСтрок		 = Новый Структура("ИдентификаторСтроки", СтрокаТаблицы.ИдентификаторСтроки);
			 РезультатПоиска = ФактическиеДанные.НайтиСтроки(ОтборСтрок);
			 
			 Для каждого ЭлементРезультата Из РезультатПоиска Цикл
				 ЭлементРезультата.СтатьяОборотов = СтатьяОборотов;
				 ЗаполнитьАналитикиСтрокиРаспределенияБюджета(ЭлементРезультата, СтрокаТаблицы, ПараметрыЗаполнения);
			 КонецЦикла;	
		 КонецЕсли;
	КонецЦикла;
			
КонецПроцедуры

Процедура ЗаполнитьАналитикиСтрокиРаспределенияБюджета(СтрокаТаблицы, ДанныеРасшифровки, ПараметрыЗаполнения)
	
	РазрезыБюджетирования = ПараметрыЗаполнения.РазрезыБюджетирования;
	ЗначенияПоУмолчанию	  = ПараметрыЗаполнения.ЗначенияПоУмолчанию;
		
	АналитикаДоговор	  = ЗначениеАналитикиДоговор(ДанныеРасшифровки);
	АналитикиПоДоговору   = АналитикиПоДоговору(АналитикаДоговор);

	Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.СтатьяОборотов) Тогда			
		Если АналитикиПоДоговору.ВысокийПриоритет И ЗначениеЗаполнено(АналитикиПоДоговору.СтатьяОборотов) Тогда
			СтатьяОборотов = АналитикиПоДоговору.СтатьяОборотов;
		Иначе
			СтатьяОборотов = ЗначениеАналитикиСтатьяОборотов(ДанныеРасшифровки);	
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(СтатьяОборотов) Тогда
			Если ЗначениеЗаполнено(АналитикиПоДоговору.СтатьяОборотов) Тогда
				СтатьяОборотов = АналитикиПоДоговору.СтатьяОборотов;
			Иначе	
				СтатьяОборотов = ЗначенияПоУмолчанию.СтатьяОборотов;
			КонецЕсли;
		КонецЕсли;
		СтрокаТаблицы.СтатьяОборотов = СтатьяОборотов;	
	КонецЕсли; 
	
	Если АналитикиПоДоговору.ВысокийПриоритет И ЗначениеЗаполнено(АналитикиПоДоговору.ЦФО) Тогда
		ЦФО = АналитикиПоДоговору.ЦФО;
	Иначе	
		ЦФО = ЗначениеАналитикиЦФО(СтрокаТаблицы);
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ЦФО) Тогда
		Если ЗначениеЗаполнено(АналитикиПоДоговору.ЦФО) Тогда
			ЦФО = АналитикиПоДоговору.ЦФО;
		Иначе	
			ЦФО = ЗначенияПоУмолчанию.ЦФО;
		КонецЕсли;
	КонецЕсли;
	СтрокаТаблицы.ЦФО = ЦФО;			
	
	Если ЗначениеЗаполнено(РазрезыБюджетирования.Проект) Тогда
		Если АналитикиПоДоговору.ВысокийПриоритет И ЗначениеЗаполнено(АналитикиПоДоговору.Проект) Тогда
			Проект = АналитикиПоДоговору.Проект;
		Иначе	
			Проект = ЗначенияПоУмолчанию.Проект;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Проект) Тогда
			Если ЗначениеЗаполнено(АналитикиПоДоговору.Проект) Тогда
				Проект = АналитикиПоДоговору.Проект;
			Иначе	
				Проект = ЗначенияПоУмолчанию.Проект;
			КонецЕсли;
		КонецЕсли;
		СтрокаТаблицы[РазрезыБюджетирования.Проект] = Проект;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РазрезыБюджетирования.Организация) 
		И ЗначениеЗаполнено(ЗначенияПоУмолчанию.Организация) Тогда
		СтрокаТаблицы[РазрезыБюджетирования.Организация] = ЗначенияПоУмолчанию.Организация;
	КонецЕсли;
			
	Если ЗначениеЗаполнено(РазрезыБюджетирования.БанковскийСчет) 
		И ЗначениеЗаполнено(ЗначенияПоУмолчанию.БанковскийСчет) Тогда						
		СтрокаТаблицы[РазрезыБюджетирования.БанковскийСчет] = ЗначенияПоУмолчанию.БанковскийСчет;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РазрезыБюджетирования.Касса) 
		И ЗначениеЗаполнено(ЗначенияПоУмолчанию.Касса) Тогда						
		СтрокаТаблицы[РазрезыБюджетирования.Касса] = ЗначенияПоУмолчанию.Касса;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РазрезыБюджетирования.Контрагент) 
		И ЗначениеЗаполнено(ЗначенияПоУмолчанию.Контрагент) Тогда						
		СтрокаТаблицы[РазрезыБюджетирования.Контрагент] = ЗначенияПоУмолчанию.Контрагент;
	КонецЕсли;
				
	Если ЗначениеЗаполнено(РазрезыБюджетирования.Подразделение) 
		И ЗначениеЗаполнено(ДанныеРасшифровки.Подразделение) Тогда
		СтрокаТаблицы[РазрезыБюджетирования.Подразделение] = ЗначенияПоУмолчанию.Подразделение;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РазрезыБюджетирования.ДоговорКонтрагента) 
	   И ТипЗнч(АналитикаДоговор) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		СтрокаТаблицы[РазрезыБюджетирования.ДоговорКонтрагента] = АналитикаДоговор;							
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РазрезыБюджетирования.ДоговорКредитаИДепозита)
		И ТипЗнч(АналитикаДоговор) = Тип("СправочникСсылка.ДоговорыКредитовИДепозитов") Тогда
		СтрокаТаблицы[РазрезыБюджетирования.ДоговорКредитаИДепозита] = АналитикаДоговор;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РазрезыБюджетирования.НаправлениеДеятельности) Тогда
		Если ЗначениеЗаполнено(ДанныеРасшифровки.НаправлениеДеятельности) Тогда
			НаправлениеДеятельности = ДанныеРасшифровки.НаправлениеДеятельности;					
		ИначеЕсли ТипЗнч(ДанныеРасшифровки.АналитикаРасходов) = Тип("СправочникСсылка.НаправленияДеятельности") Тогда	
			НаправлениеДеятельности = ДанныеРасшифровки.АналитикаРасходов;
		Иначе
			НаправлениеДеятельности = ЗначенияПоУмолчанию.НаправлениеДеятельности;
		КонецЕсли;
		СтрокаТаблицы[РазрезыБюджетирования.НаправлениеДеятельности] = НаправлениеДеятельности;
	КонецЕсли;
	
КонецПроцедуры

Функция АналитикиИзОснования(РеквизитыОснования)

	НастройкиИзмерений	= бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");	
	Автозаполнение 		= (бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_РежимАвтоЗаполненияАналитик") 
							= Перечисления.бит_РежимыАвтоЗаполненияАналитик.Заполнять);
						
	РазрезыБюджетирования = РазрезыБюджетирования(НастройкиИзмерений, Автозаполнение);
	РазрезыСтрокой 		  = ОбщегоНазначенияКлиентСервер.КлючиСтруктурыВСтроку(РазрезыБюджетирования, ",");
	
	СтатьяОборотовПоВидуОперации = СтатьиОборотовПоВидуОперации(РеквизитыОснования);
	
	ЗначенияПоУмолчанию   = Новый Структура(РазрезыСтрокой);
	ЗначенияПоУмолчанию.Вставить("СтатьяОборотов", СтатьяОборотовПоВидуОперации[0]);
	ЗначенияПоУмолчанию.Вставить("ЦФО", 		   Неопределено);
	
	ЗначенияПоУмолчанию.Организация	   = РеквизитыОснования.Организация;
	ЗначенияПоУмолчанию.Касса		   = РеквизитыОснования.Касса;
	ЗначенияПоУмолчанию.БанковскийСчет = РеквизитыОснования.БанковскийСчет;
	ЗначенияПоУмолчанию.Контрагент 	   = РеквизитыОснования.Контрагент;
	ЗначенияПоУмолчанию.Подразделение  = РеквизитыОснования.Подразделение;

	АналитикиПоНастройкам  = АналитикиПоНастройкамПользователя(РеквизитыОснования.Ссылка);
	
	РасшифровкаПлатежа = РеквизитыОснования.РасшифровкаПлатежа;
	АналитикаДоговор   = Неопределено;

	Если ЗначениеЗаполнено(РасшифровкаПлатежа) Тогда
		АналитикаДоговор = ЗначениеАналитикиДоговор(РасшифровкаПлатежа[0]);
	КонецЕсли;
	
	Если ТипЗнч(АналитикаДоговор) = Тип("СправочникСсылка.ДоговорыКредитовИДепозитов") Тогда
		ЗначенияПоУмолчанию.ДоговорКредитаИДепозита = АналитикаДоговор;
	ИначеЕсли ТипЗнч(АналитикаДоговор) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда	
		ЗначенияПоУмолчанию.ДоговорКонтрагента = АналитикаДоговор;
	КонецЕсли;
	
	АналитикиПоДоговору = АналитикиПоДоговору(АналитикаДоговор);

	Если НЕ ЗначениеЗаполнено(ЗначенияПоУмолчанию.СтатьяОборотов) Тогда
		Если АналитикиПоДоговору.ВысокийПриоритет И ЗначениеЗаполнено(АналитикиПоДоговору.СтатьяОборотов) Тогда
			ЗначенияПоУмолчанию.СтатьяОборотов = АналитикиПоДоговору.СтатьяОборотов
		Иначе	
			ЗначенияПоУмолчанию.СтатьяОборотов = ЗначениеАналитикиСтатьяОборотов(РеквизитыОснования);
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ЗначенияПоУмолчанию.СтатьяОборотов) Тогда
			ЗначенияПоУмолчанию.СтатьяОборотов = АналитикиПоДоговору.СтатьяОборотов;
		КонецЕсли;
	КонецЕсли;
	
	Если АналитикиПоДоговору.ВысокийПриоритет И ЗначениеЗаполнено(АналитикиПоДоговору.ЦФО) Тогда
		ЗначенияПоУмолчанию.ЦФО = АналитикиПоДоговору.ЦФО;
	Иначе
		ЗначенияПоУмолчанию.ЦФО = ЗначениеАналитикиЦФО(РеквизитыОснования);
		Если НЕ ЗначениеЗаполнено(ЗначенияПоУмолчанию.ЦФО) Тогда
			ЗначенияПоУмолчанию.ЦФО = АналитикиПоДоговору.ЦФО;
		КонецЕсли;
	КонецЕсли; 
	
	Если АналитикиПоДоговору.ВысокийПриоритет И ЗначениеЗаполнено(АналитикиПоДоговору.Проект) Тогда
		ЗначенияПоУмолчанию.Проект = АналитикиПоДоговору.Проект;
	КонецЕсли;
	
	ЗначенияПоУмолчанию.НаправлениеДеятельности = ЗначениеАналитикиНаправлениеДеятельности(РеквизитыОснования);
	
	// Заполняем из настроек, что не удалось заполнить.
	Если НЕ ЗначениеЗаполнено(ЗначенияПоУмолчанию.СтатьяОборотов) Тогда
		ЗначенияПоУмолчанию.СтатьяОборотов = АналитикиПоНастройкам.СтатьяОборотов; 
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЗначенияПоУмолчанию.ЦФО) Тогда
		ЗначенияПоУмолчанию.ЦФО = АналитикиПоНастройкам.ЦФО; 
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЗначенияПоУмолчанию.Проект) Тогда
		ЗначенияПоУмолчанию.Проект = АналитикиПоНастройкам.Проект; 
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЗначенияПоУмолчанию.НаправлениеДеятельности) Тогда
		ЗначенияПоУмолчанию.НаправлениеДеятельности = АналитикиПоНастройкам.НаправлениеДеятельности; 
	КонецЕсли;
	
	Возврат ЗначенияПоУмолчанию;

КонецФункции

Функция ЗначениеАналитикиЦФО(Данные)

	ЦФО = Справочники.Подразделения.ПустаяСсылка();
	
	СвойстваДанных = Новый Структура;
	СвойстваДанных.Вставить("Подразделение",  	  Неопределено);
	СвойстваДанных.Вставить("БанковскийСчет", 	  Неопределено);
	СвойстваДанных.Вставить("Касса", 		  	  Неопределено);
	СвойстваДанных.Вставить("Организация", 	  	  Неопределено);
	СвойстваДанных.Вставить("РасшифровкаПлатежа", Неопределено);
	
	ЗаполнитьЗначенияСвойств(СвойстваДанных, Данные);
	
	Подразделение = Неопределено;
	Если ЗначениеЗаполнено(СвойстваДанных.Подразделение) Тогда		
		Подразделение = СвойстваДанных.Подразделение;
	ИначеЕсли ЗначениеЗаполнено(СвойстваДанных.РасшифровкаПлатежа) Тогда
		Подразделение = СвойстваДанных.РасшифровкаПлатежа[0].Подразделение;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Подразделение) Тогда
		ЦФО = РегистрыСведений.бит_СоответствияАналитик.ПолучитьПравуюАналитику(
				Справочники.бит_ВидыСоответствийАналитик.СтруктураПредприятия_ЦФО, 
				Подразделение, ТекущаяДатаСеанса());
	КонецЕсли;
						
	Если ЗначениеЗаполнено(ЦФО) Тогда
		Возврат ЦФО;	
	КонецЕсли;
	
	МестоХранения = Неопределено;
	Если ЗначениеЗаполнено(СвойстваДанных.БанковскийСчет) Тогда
		МестоХранения = СвойстваДанных.БанковскийСчет;
	ИначеЕсли ЗначениеЗаполнено(СвойстваДанных.Касса) Тогда
		МестоХранения = СвойстваДанных.Касса;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МестоХранения) Тогда
		ВладелецСчета = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(МестоХранения, "Владелец");
		ЦФО 		  = РегистрыСведений.бит_СоответствияАналитик.ПолучитьПравуюАналитику(
								Справочники.бит_ВидыСоответствийАналитик.Организации_ЦФО, 
								ВладелецСчета, ТекущаяДатаСеанса());
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЦФО) Тогда
		Возврат ЦФО;	
	КонецЕсли;

	Если ЗначениеЗаполнено(СвойстваДанных.Организация) Тогда		
		ЦФО = РегистрыСведений.бит_СоответствияАналитик.ПолучитьПравуюАналитику(
					Справочники.бит_ВидыСоответствийАналитик.Организации_ЦФО, 
					СвойстваДанных.Организация, ТекущаяДатаСеанса());
		
	КонецЕсли; 
		
	Возврат ЦФО;
	
КонецФункции

Функция ЗначениеАналитикиСтатьяОборотов(Данные)

	// ++ NB Дополняет с СтатьиОборотовПоВидуОперации() , собрать все в кучу?
	
	СтатьяОборотов = Справочники.бит_СтатьиОборотов.ПустаяСсылка();
	СтатьяДДС	   = Неопределено;
	
	СвойстваДанных = Новый Структура;
	СвойстваДанных.Вставить("СтатьяДвиженияДенежныхСредств", Неопределено);
	СвойстваДанных.Вставить("РасшифровкаПлатежа", 			 Неопределено);
	
	ЗаполнитьЗначенияСвойств(СвойстваДанных, Данные);
	
	Если ЗначениеЗаполнено(СвойстваДанных.СтатьяДвиженияДенежныхСредств) Тогда
		СтатьяДДС = СвойстваДанных.СтатьяДвиженияДенежныхСредств;
	ИначеЕсли ЗначениеЗаполнено(СвойстваДанных.РасшифровкаПлатежа) Тогда	
		СтатьяДДС = СвойстваДанных.РасшифровкаПлатежа[0].СтатьяДвиженияДенежныхСредств;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтатьяДДС) Тогда			
		СтатьяОборотов = РегистрыСведений.бит_СоответствияАналитик.ПолучитьПравуюАналитику(
							Справочники.бит_ВидыСоответствийАналитик.СтатьиДДС_СтатьиОборотов, 
							СтатьяДДС, Данные.Период);																
	КонецЕсли;													
		
	Возврат СтатьяОборотов;
	
КонецФункции

Функция АналитикиПоДоговору(ДоговорКонтрагента)

	АналитикиПоДоговору = Новый Структура;	
	АналитикиПоДоговору.Вставить("СтатьяОборотов", 	   Неопределено);
	АналитикиПоДоговору.Вставить("ЦФО", 			   Неопределено);
	АналитикиПоДоговору.Вставить("Проект",			   Неопределено);
	АналитикиПоДоговору.Вставить("ВысокийПриоритет",   Ложь);
	АналитикиПоДоговору.Вставить("ДоговорКонтрагента", ДоговорКонтрагента);
	АналитикиПоДоговору.Вставить("Контрагент",		   Неопределено);

	Если НЕ ЗначениеЗаполнено(ДоговорКонтрагента) Тогда
		Возврат АналитикиПоДоговору;
	КонецЕсли;
	
	МетаданныеДоговора = ДоговорКонтрагента.Метаданные();
	Если МетаданныеДоговора.Реквизиты.Найти("Контрагент") = Неопределено Тогда
		ИменаРеквизитов = "бит_ВысокийПриоритетПриЗаполненииАналитик, бит_Проект, бит_ЦФО, бит_ОсновнаяСтатьяОборотов";
		РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДоговорКонтрагента, ИменаРеквизитов);		
	Иначе
		ИменаРеквизитов = "Контрагент, бит_ВысокийПриоритетПриЗаполненииАналитик, "
	                     + "бит_Проект, бит_ЦФО, бит_ОсновнаяСтатьяОборотов";
		РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДоговорКонтрагента, ИменаРеквизитов);
		АналитикиПоДоговору.Контрагент = РеквизитыДоговора.Контрагент;	
	КонецЕсли;
	АналитикиПоДоговору.ВысокийПриоритет = РеквизитыДоговора.бит_ВысокийПриоритетПриЗаполненииАналитик;
	АналитикиПоДоговору.ЦФО 			 = РеквизитыДоговора.бит_ЦФО;
	АналитикиПоДоговору.Проект			 = РеквизитыДоговора.бит_Проект;
	
	Если ЗначениеЗаполнено(РеквизитыДоговора.бит_ОсновнаяСтатьяОборотов) Тогда		
		ТипСтатьи = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РеквизитыДоговора.бит_ОсновнаяСтатьяОборотов, 
						"ТипСтатьи"); 
		Если ТипСтатьи = Перечисления.бит_ТипыСтатейОборотов.БДДС Тогда		
			АналитикиПоДоговору.СтатьяОборотов = РеквизитыДоговора.бит_ОсновнаяСтатьяОборотов;
		КонецЕсли; 
	КонецЕсли;
	
	Возврат АналитикиПоДоговору;
	
КонецФункции

Функция ЗначениеАналитикиДоговор(Данные)

	АналитикаДоговор = Неопределено;
	
	СвойстваДанных = Новый Структура("ДоговорАренды, ДоговорКредитаДепозита, ОбъектРасчетов");
	ЗаполнитьЗначенияСвойств(СвойстваДанных, Данные);
	
	Если ЗначениеЗаполнено(СвойстваДанных.ДоговорАренды) Тогда
		АналитикаДоговор = Данные.ДоговорАренды;
	ИначеЕсли ЗначениеЗаполнено(СвойстваДанных.ДоговорКредитаДепозита) Тогда	
		АналитикаДоговор = СвойстваДанных.ДоговорКредитаДепозита;
	ИначеЕсли ЗначениеЗаполнено(СвойстваДанных.ОбъектРасчетов) Тогда
		АналитикаДоговор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СвойстваДанных.ОбъектРасчетов, "Договор");
	КонецЕсли;	
	
	Возврат АналитикаДоговор;
	
КонецФункции

Функция СтатьиОборотовПоВидуОперации(РеквизитыОснования)

	ОснованиеМетаданные   = РеквизитыОснования.Ссылка.Метаданные();
	ХозяйственнаяОперация = РеквизитыОснования.ХозяйственнаяОперация;
	
	СтатьиОборотов = Новый Массив;
	
	Если ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПеречислениеДенежныхСредствНаДругойСчет Тогда
						
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ПеречислениеДенежныхСредствНаДругойСчет_расходование);

	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеДенежныхСредствСДругогоСчета Тогда
				
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ПеречислениеДенежныхСредствНаДругойСчет_поступление);
		
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствВДругуюКассу Тогда
						
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ВыдачаДенежныхСредствВДругуюКассу);
		
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзДругойКассы Тогда
						
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ПоступлениеДенежныхСредствИзДругойКассы);
		
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.СдачаДенежныхСредствВБанк Тогда
				
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.СдачаДенежныхСредствВБанк_РасходованиеПоКассе);
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.СдачаДенежныхСредствВБанк_ПоступлениеВБанк);
		
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзБанка Тогда
				
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ПоступлениеДенежныхСредствИзБанка_ПоступлениеВКассу);
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ПоступлениеДенежныхСредствИзБанка_РасходПоБанку);
		
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.КонвертацияВалюты Тогда
		
		Если ОснованиеМетаданные = Метаданные.Документы.РасходныйКассовыйОрдер
		 ИЛИ ОснованиеМетаданные = Метаданные.Документы.СписаниеБезналичныхДенежныхСредств Тогда
			СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.КонвертацияВалюты_Списание);
		Иначе	
			СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.КонвертацияВалюты_Поступление);
		КонецЕсли;
				
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВнутренняяПередачаДенежныхСредств Тогда
					
		Если ОснованиеМетаданные = Метаданные.Документы.РасходныйКассовыйОрдер
		 ИЛИ ОснованиеМетаданные = Метаданные.Документы.СписаниеБезналичныхДенежныхСредств Тогда
			СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ВнутренняяПередачаДС_расходование);
		Иначе	
			СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ВнутренняяПередачаДС_поступление);
		КонецЕсли;
				
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствВДругуюОрганизацию
		  ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаДенежныхСредствВДругуюОрганизацию Тогда
						
		Если ОснованиеМетаданные = Метаданные.Документы.РасходныйКассовыйОрдер
		 ИЛИ ОснованиеМетаданные = Метаданные.Документы.СписаниеБезналичныхДенежныхСредств Тогда
			СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ОплатаВДругуюОрганизацию_Расходование);
		Иначе	
			СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ОплатаВДругуюОрганизацию_Поступление);
		КонецЕсли;
		
	ИначеЕсли ОснованиеМетаданные = Метаданные.Документы.ОтчетБанкаПоОперациямЭквайринга	 Тогда
						
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ПолучениеОплатыПоДоговорамЭквайринга);

	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.СнятиеНаличныхДенежныхСредств Тогда
		
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ПоступлениеДенежныхСредствИзБанка_РасходПоБанку);
		
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзКассыНаРасчетныйСчет Тогда
		
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.СдачаДенежныхСредствВБанк_ПоступлениеВБанк);
		
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ИнкассацияДенежныхСредствВБанк Тогда
		
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.СдачаДенежныхСредствВБанк_РасходованиеПоКассе);
		
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ИнкассацияДенежныхСредствИзБанка Тогда
		
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ПоступлениеДенежныхСредствИзБанка_ПоступлениеВКассу);
		
	КонецЕсли; 

	Если НЕ ЗначениеЗаполнено(СтатьиОборотов) Тогда
		СтатьиОборотов.Добавить(Справочники.бит_СтатьиОборотов.ПустаяСсылка());
	КонецЕсли;
	
	Возврат СтатьиОборотов;
	
КонецФункции

Функция ТекстЗапросаРасшифровкаПлатежа(ОснованиеМетаданные)
	
	Если ОснованиеМетаданные = Метаданные.Документы.ПоступлениеБезналичныхДенежныхСредств Тогда
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ПоступлениеБезналичныхДенежныхСредств.Ссылка КАК Ссылка,
		|	ПоступлениеБезналичныхДенежныхСредств.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
		|	ПоступлениеБезналичныхДенежныхСредств.СуммаДокумента КАК СуммаОплаты,
		|	"""" КАК ИдентификаторСтроки,
		|	НЕОПРЕДЕЛЕНО КАК ДоговорКредитаДепозита,
		|	ПоступлениеБезналичныхДенежныхСредств.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	ПоступлениеБезналичныхДенежныхСредств.ОбъектРасчетов КАК ОбъектРасчетов,
		|	НЕОПРЕДЕЛЕНО КАК ДоговорАренды,
		|	1 КАК КурсЧислительВзаиморасчетов,
		|	1 КАК КурсЗнаменательВзаиморасчетов,
		|	&Период КАК Период,
		|	ПоступлениеБезналичныхДенежныхСредств.Подразделение КАК Подразделение,
		|	ПоступлениеБезналичныхДенежныхСредств.АналитикаАктивовПассивов КАК АналитикаРасходов,
		|	ПоступлениеБезналичныхДенежныхСредств.Валюта КАК ВалютаВзаиморасчетов,
		|	ПоступлениеБезналичныхДенежныхСредств.СуммаДокумента КАК СуммаВзаиморасчетов
		|ИЗ
		|	Документ.ПоступлениеБезналичныхДенежныхСредств КАК ПоступлениеБезналичныхДенежныхСредств
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПоступлениеБезналичныхДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа
		|		ПО ПоступлениеБезналичныхДенежныхСредств.Ссылка = ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка
		|ГДЕ
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка ЕСТЬ NULL
		|	И ПоступлениеБезналичныхДенежныхСредств.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.СтатьяДвиженияДенежныхСредств,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Сумма,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.ИдентификаторСтроки,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.ДоговорКредитаДепозита,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.НаправлениеДеятельности,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.ОбъектРасчетов,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.ДоговорАренды,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.КурсЧислительВзаиморасчетов,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.КурсЗнаменательВзаиморасчетов,
		|	&Период,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Подразделение,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.АналитикаДоходов,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.ВалютаВзаиморасчетов,
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.СуммаВзаиморасчетов
		|ИЗ
		|	Документ.ПоступлениеБезналичныхДенежныхСредств.РасшифровкаПлатежа КАК ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа
		|ГДЕ
		|	ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка = &Ссылка";
		
	ИначеЕсли ОснованиеМетаданные = Метаданные.Документы.ПриходныйКассовыйОрдер Тогда
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ПриходныйКассовыйОрдер.Ссылка КАК Ссылка,
		|	ПриходныйКассовыйОрдер.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
		|	ПриходныйКассовыйОрдер.СуммаДокумента КАК СуммаОплаты,
		|	"""" КАК ИдентификаторСтроки,
