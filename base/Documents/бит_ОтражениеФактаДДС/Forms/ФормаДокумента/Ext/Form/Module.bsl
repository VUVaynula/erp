КонецПроцедуры

&НаСервере
Процедура ПрочитатьРасшифровкуПлатежа()
	
	РасшифровкаПлатежа.Очистить();
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	РасшифровкаПлатежа.НомерСтроки КАК ИДСтроки,
	|	РасшифровкаПлатежа.НомерСтроки КАК НомерСтрокиДокумента,
	|	РасшифровкаПлатежа.Сумма КАК Сумма,
	|	РасшифровкаПлатежа.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	РасшифровкаПлатежа.Ссылка КАК Документ,
	|	РасшифровкаПлатежа.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	НЕОПРЕДЕЛЕНО КАК ДоговорКредитаДепозита,
	|	НЕОПРЕДЕЛЕНО КАК ОбъектРасчетов,
	|	НЕОПРЕДЕЛЕНО КАК ДоговорАренды,
	|	НЕОПРЕДЕЛЕНО КАК ДоговорСЗаказчиком,
	|	НЕОПРЕДЕЛЕНО КАК Договор,
	|	РасшифровкаПлатежа.СтавкаНДС КАК СтавкаНДС,
	|	РасшифровкаПлатежа.СуммаНДС КАК СуммаНДС,
	|	РасшифровкаПлатежа.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	РасшифровкаПлатежа.СуммаВзаиморасчетов КАК СуммаВзаиморасчетов,
	|	РасшифровкаПлатежа.КурсЧислительВзаиморасчетов КАК КурсЧислительВзаиморасчетов,
	|	РасшифровкаПлатежа.КурсЗнаменательВзаиморасчетов КАК КурсЗнаменательВзаиморасчетов
	|ИЗ
	|	#РасшифровкаПлатежа КАК РасшифровкаПлатежа
	|ГДЕ
	|	РасшифровкаПлатежа.Ссылка = &ТекущийОбъект
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтрокиДокумента";
	
	ОбъектСсылка	 = Объект.ДокументОснование;
	МетаданныеСсылки = ОбъектСсылка.Метаданные().ТабличныеЧасти.РасшифровкаПлатежа;
	
	ЕстьДоговорКредитаДепозита = ОбщегоНазначения.ЕстьРеквизитОбъекта("ДоговорКредитаДепозита", МетаданныеСсылки);
	Если ЕстьДоговорКредитаДепозита Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "НЕОПРЕДЕЛЕНО КАК ДоговорКредитаДепозита",
			"ДоговорКредитаДепозита КАК ДоговорКредитаДепозита");
	КонецЕсли; 
	
	ЕстьОбъектРасчетов = ОбщегоНазначения.ЕстьРеквизитОбъекта("ОбъектРасчетов", МетаданныеСсылки);
	Если ЕстьОбъектРасчетов Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "НЕОПРЕДЕЛЕНО КАК ОбъектРасчетов",
			"ОбъектРасчетов КАК ОбъектРасчетов");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "НЕОПРЕДЕЛЕНО КАК Договор",
			"ОбъектРасчетов.Договор КАК Договор");
	КонецЕсли;
	
	ЕстьДоговорАренды = ОбщегоНазначения.ЕстьРеквизитОбъекта("ДоговорАренды", МетаданныеСсылки);
	Если ЕстьДоговорАренды Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "НЕОПРЕДЕЛЕНО КАК ДоговорАренды",
			"ДоговорАренды КАК ДоговорАренды");
	КонецЕсли;
	
	ЕстьДоговорСЗаказчиком = ОбщегоНазначения.ЕстьРеквизитОбъекта("ДоговорСЗаказчиком", МетаданныеСсылки);
	Если ЕстьДоговорСЗаказчиком Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "НЕОПРЕДЕЛЕНО КАК ДоговорСЗаказчиком",
			"ДоговорСЗаказчиком КАК ДоговорСЗаказчиком");
	КонецЕсли;
		
	Путь = ОбъектСсылка.Метаданные().ПолноеИмя();
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#РасшифровкаПлатежа", Путь + ".РасшифровкаПлатежа");			   
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущийОбъект", ОбъектСсылка);
	Запрос.Текст = ТекстЗапроса;
	Результат 	 = Запрос.Выполнить();
	Выборка   	 = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(РасшифровкаПлатежа.Добавить(), Выборка);	
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКурсКратностьТекстом()
	
	Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл
		ДенежныеСредстваКлиентСервер.СформироватьКурсЗнаменательТекстом(СтрокаТаблицы, Объект.ВалютаДокумента, ВалютаРеглУчета);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура РасшифровкаПлатежаКурсЧислительВзаиморасчетовПриИзмененииНаСервере()

	ТекущаяСтрокаРасшифровки = РасшифровкаПлатежа.НайтиПоИдентификатору(Элементы.РасшифровкаПлатежа.ТекущаяСтрока);
	
	ПараметрыОтборы = Новый Структура("ИдентификаторСтроки", ТекущаяСтрокаРасшифровки.ИдентификаторСтроки);
	
	СтрокиФактическихДанных = Объект.ФактическиеДанные.НайтиСтроки(ПараметрыОтборы);
	
	Для каждого СтрокаТаблицы Из СтрокиФактическихДанных Цикл
		
		СтрокаТаблицы.КурсЧислительВзаиморасчетов = ТекущаяСтрокаРасшифровки.КурсЧислительВзаиморасчетов;

		ПараметрыПередачи = Новый Структура;
		ПараметрыПередачи.Вставить("КурсЧислительВзаиморасчетов", 	СтрокаТаблицы.КурсЧислительВзаиморасчетов);
		ПараметрыПередачи.Вставить("КурсЗнаменательВзаиморасчетов", СтрокаТаблицы.КурсЗнаменательВзаиморасчетов);
		ПараметрыПередачи.Вставить("СуммаВзаиморасчетов", 			СтрокаТаблицы.СуммаВзаиморасчетов);
		ПараметрыПередачи.Вставить("Сумма", 						СтрокаТаблицы.СуммаОплаты);
		
		ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
			ПараметрыПередачи, Объект.ВалютаДокумента, ВалютаРеглУчета);
			
		СтрокаТаблицы.СуммаВзаиморасчетов = ПараметрыПередачи.СуммаВзаиморасчетов; 	
	КонецЦикла;
	
	ДенежныеСредстваКлиентСервер.СформироватьКурсЗнаменательТекстом(ТекущаяСтрокаРасшифровки, 
		Объект.ВалютаДокумента, ВалютаРеглУчета);

КонецПроцедуры

&НаСервере
Процедура ОбработатьИзменнениеНеСинхронизироватьСумму()

	РеквизитыДокументаОснования = Документы.бит_ОтражениеФактаДДС.РеквизитыОснования(Объект.ДокументОснование);
	
	ФактическиеДанные = Объект.ФактическиеДанные.Выгрузить();
	Документы.бит_ОтражениеФактаДДС.ИнициироватьФактическиеДанные(
		РеквизитыДокументаОснования.РасшифровкаПлатежа, ФактическиеДанные, Объект);
		
	Объект.ФактическиеДанные.Загрузить(ФактическиеДанные);
	
	Если ЕстьРасшифровкаПлатежа Тогда
		Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл
			ПараметрыОтбора	  = Новый Структура("ИдентификаторСтроки", СтрокаТаблицы.ИдентификаторСтроки);
			РезультатПоиска = Объект.ФактическиеДанные.НайтиСтроки(ПараметрыОтбора);
			Если ЗначениеЗаполнено(РезультатПоиска) Тогда
				Запись = РезультатПоиска[0];	
				СтрокаТаблицы.КурсЧислительВзаиморасчетов	= Запись.КурсЧислительВзаиморасчетов;
				СтрокаТаблицы.КурсЗнаменательВзаиморасчетов = Запись.КурсЗнаменательВзаиморасчетов;
			КонецЕсли;
			ОбновитьИтоги(СтрокаТаблицы.ИдентификаторСтроки, ЭтотОбъект);
		КонецЦикла;
		ЗаполнитьКурсКратностьТекстом();
	Иначе
		ОбновитьИтоги("", ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
