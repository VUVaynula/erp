КонецПроцедуры

&НаКлиенте
Процедура ФактическиеДанныеСуммаВзаиморасчетовПриИзменении(Элемент)
	
	ТекущиеДанные 	= Элементы.ФактическиеДанные.ТекущиеДанные;
	ТекущееЗначение = ТекущиеДанные.СуммаОплаты;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.СуммаВзаиморасчетов)
		И ТекущиеДанные.ВалютаВзаиморасчетов = Объект.ВалютаДокумента
		И ТекущиеДанные.СуммаВзаиморасчетов <> ТекущиеДанные.СуммаОплаты Тогда
		ТекущиеДанные.СуммаВзаиморасчетов = ТекущиеДанные.СуммаОплаты;
	Иначе
		ПараметрыПередачи = Новый Структура;
		ПараметрыПередачи.Вставить("КурсЧислительВзаиморасчетов", 	ТекущиеДанные.КурсЧислительВзаиморасчетов);
		ПараметрыПередачи.Вставить("КурсЗнаменательВзаиморасчетов", ТекущиеДанные.КурсЗнаменательВзаиморасчетов);
		ПараметрыПередачи.Вставить("СуммаВзаиморасчетов", 			ТекущиеДанные.СуммаВзаиморасчетов);
		ПараметрыПередачи.Вставить("Сумма", 						ТекущиеДанные.СуммаОплаты);
		
		ДенежныеСредстваКлиентСервер.РассчитатьСуммуВСтрокеРасшифровки(
			ПараметрыПередачи, Объект.ВалютаДокумента, ВалютаРеглУчета);
		
		ТекущиеДанные.СуммаОплаты = ПараметрыПередачи.Сумма; 	
	КонецЕсли;
	
	Если ТекущиеДанные.СуммаОплаты <> ТекущиеДанные.СуммаОплаты Тогда
		Если ЕстьРасшифровкаПлатежа Тогда
			ДанныеРасшифровки 	= Элементы.РасшифровкаПлатежа.ТекущиеДанные;
			ИдентификаторСтроки	= Элементы.ФактическиеДанные.ОтборСтрок.ИдентификаторСтроки;
		Иначе
			ИдентификаторСтроки = "";
		КонецЕсли;	
		ОбновитьИтоги(ИдентификаторСтроки, ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

