
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
    // СтандартныеПодсистемы.ПодключаемыеКоманды
    ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
    // Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	Если НЕ ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		ТекстСообщения = НСтр("ru = 'Непосредственное открытие этой формы не предусмотрено.';
							 | en = 'This form cannot be opened directly.'") + Символы.ПС 
					   + НСтр("ru = 'Для открытия формы можно воспользоваться командой ""Аналитики (БИТ)"" в формах документов.';
						 	  |en = 'To open the form, you can use the ""Analytics (bit)"" command in document forms.'");
		ВызватьИсключение ТекстСообщения;
	КонецЕсли;

	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);
	
	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаОбъектаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	
	Если Отказ Тогда
		Возврат;	
	КонецЕсли; 	
	
	Если Параметры.Ключ.Пустая() Тогда
		ПодготовитьФормуНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ОтобразитьРаспределениеБюджета();
	ПодключитьОбработчикОжидания("ПроверитьМодификациюВладельцаФормы", 0.5, Истина);
		
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ПодготовитьФормуНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ОпределитьПереченьПозиций(ТекущийОбъект);
	
	МетаданныеДокумента = Метаданные.Документы.бит_ОтражениеФактаДДС;
	Если бит_ДатыЗапретаРедактирования.ПропуститьПроверкуДатыЗапрета(МетаданныеДокумента, ТекущийОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	МетаданныеДокумента = Объект.ДокументОснование.Метаданные();
	РедактированиеЗапрещено = бит_ДатыЗапретаРедактирования.ВыполнитьПроверкуДатыЗапретаРедактирования(
									МетаданныеДокумента, Объект.ДокументОснование);
	Если РедактированиеЗапрещено Тогда
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если Отказ Тогда
		Возврат;	
	КонецЕсли;
	
	ФормироватьДвижения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущийОбъект.ДокументОснование, "Проведен");
	Если ФормироватьДвижения Тогда
		ВыполнитьПроведениеБитНаСервере(ТекущийОбъект, Отказ);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ДоработатьТаблицуАналитик();
	ЗаполнитьДобавленныеКолонкиТаблиц();
	ЗаполнитьКурсКратностьТекстом();

	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ЗаписатьИЗакрыть = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыЗаписи, "ЗаписатьИЗакрыть", Ложь);
	
	Если ВладелецФормы <> Неопределено Тогда
		Если ЗаписатьИЗакрыть Тогда
			// АПК:534-выкл Безопасное открытие формы документа.
			ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(Объект.ДокументОснование));
			// АПК:534-вкл
		КонецЕсли;
	Иначе
		Если ЗаписатьИЗакрыть И Открыта() Тогда
		     Закрыть();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НеСинхронизироватьПриИзменении(Элемент)
	
	Если Объект.НеСинхронизировать Тогда
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("НеСинхронизироватьПриИзмененииЗавершение", ЭтотОбъект); 

	Если ЕстьСсылкиНаПлатежныеПозиции() Тогда
		ТекстВопроса = НСтр("ru='Документ заполнен на основании данных документа планирования ДДС. 
							|При снятии флага ""Не синхронизировать"" документ при проведении будет перезаполнен без учета этих данных. Продолжить?';
							|en='The document is filled on the basis of the document data DDS planning. 
							|When removing the flag ""out of sync"" the document will be refilled during excluding those data. Proceed?'");
		
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет); 
	Иначе
		ВыполнитьОбработкуОповещения(Оповещение, КодВозвратаДиалога.Да);
	КонецЕсли; 
			
КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура НеСинхронизироватьПриИзмененииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда			
		Объект.НеСинхронизировать = Истина;			
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура НеСинхронизироватьПериодПриИзменении(Элемент)
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура НеСинхронизироватьСуммуПриИзменении(Элемент)
	
	Если НЕ Объект.НеСинхронизироватьСумму Тогда
		ОбработатьИзменнениеНеСинхронизироватьСумму();
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура СтраницыФормыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	ИмяТекущейСтраницы = Элементы.СтраницыФормы.ТекущаяСтраница.Имя;
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументОснованиеНажатие(Элемент, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(Объект.ДокументОснование));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыАналитики

&НаКлиенте
Процедура АналитикиАналитикаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Аналитики.ТекущиеДанные;
	ИзменениеАналитики(ТекущиеДанные.ПолучитьИдентификатор());
	
КонецПроцедуры

&НаКлиенте
Процедура НачалоВыбораЗначениеАналитикиШапки(Элемент, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.Аналитики.ТекущиеДанные;
    Если ТекущиеДанные = Неопределено Тогда
    	Возврат;
    КонецЕсли;
		
    бит_МеханизмДопИзмеренийКлиент.ВыбратьТипСоставнойАналитики(ЭтотОбъект, Элемент, ТекущиеДанные, 
		ТекущиеДанные.ИмяАналитики, СтандартнаяОбработка, КэшЗначений.НастройкиАналитик,  "ЗначениеАналитики");
															   
КонецПроцедуры // НачалоВыбораЗначениеАналитикиШапки()

&НаКлиенте
Процедура АналитикиЗначениеАналитикиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	НачалоВыбораЗначениеАналитикиШапки(Элемент, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура АналитикиЗначениеАналитикиАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	НачалоВыбораЗначениеАналитикиШапки(Элемент, СтандартнаяОбработка);
	
КонецПроцедуры // АналитикиЗначениеАналитикиАвтоПодбор()

&НаКлиенте
Процедура АналитикиЗначениеАналитикиОчистка(Элемент, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.Аналитики.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Контейнер = Новый Структура;
	Контейнер.Вставить(ТекущиеДанные.ИмяАналитики, ТекущиеДанные.ЗначениеАналитики);	

	бит_МеханизмДопИзмеренийКлиент.ОбработкаОчисткиДополнительногоИзмерения(Элемент,
																			Контейнер,
																		   	ТекущиеДанные.ИмяАналитики,
																		   	СтандартнаяОбработка,
																		   	КэшЗначений.НастройкиАналитик);
																		
	ТекущиеДанные.ЗначениеАналитики = Контейнер[ТекущиеДанные.ИмяАналитики];
	
КонецПроцедуры

&НаКлиенте
Процедура АналитикиПриИзменении(Элемент)
	
	Объект.НеСинхронизировать = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыФактическиеДанные

&НаКлиенте
Процедура ФактическиеДанныеПередНачаломИзменения(Элемент, Отказ)
	
	ТекущиеДанные = Элементы.ФактическиеДанные.ТекущиеДанные;
	
	бит_МеханизмДопИзмеренийКлиент.УстановитьНачальныеСвойстваАналитикСтроки(
		ЭтотОбъект, ТекущиеДанные, ПараметрыУстановкиСвойствАналитик(ЭтотОбъект, "ФактическиеДанные"));

КонецПроцедуры

&НаКлиенте
Процедура ФактическиеДанныеПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТекущиеДанные = Элементы.ФактическиеДанные.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НоваяСтрока Тогда
		Если ЕстьРасшифровкаПлатежа Тогда
			ИдентификаторСтроки 		  = Элементы.ФактическиеДанные.ОтборСтрок.ИдентификаторСтроки;
			ДанныеСтрокиРасшифровки 	  = Элементы.РасшифровкаПлатежа.ТекущиеДанные; 
			СуммаОплаты 				  = ДанныеСтрокиРасшифровки.Сумма;
			ВалютаВзаиморасчетов		  = ДанныеСтрокиРасшифровки.ВалютаВзаиморасчетов;
			КурсЧислительВзаиморасчетов   = ДанныеСтрокиРасшифровки.КурсЧислительВзаиморасчетов;
			КурсЗнаменательВзаиморасчетов = ДанныеСтрокиРасшифровки.КурсЗнаменательВзаиморасчетов;
		Иначе	
			ИдентификаторСтроки 		  = "";
			СуммаОплаты					  = СуммаДокумента;
			ВалютаВзаиморасчетов		  = Объект.ВалютаДокумента;
			КурсЧислительВзаиморасчетов   = 1;
			КурсЗнаменательВзаиморасчетов = 1;
		КонецЕсли; 
		
		ТекущиеДанные.ИдентификаторСтроки 			= ИдентификаторСтроки;
		ТекущиеДанные.ВалютаВзаиморасчетов 			= ВалютаВзаиморасчетов;
		ТекущиеДанные.КурсЧислительВзаиморасчетов	= КурсЧислительВзаиморасчетов;
		ТекущиеДанные.КурсЗнаменательВзаиморасчетов = КурсЗнаменательВзаиморасчетов;
		
		Если Объект.ФактическиеДанные.Количество() = 1 Тогда
			ТекущиеДанные.СуммаОплаты = СуммаОплаты;
		КонецЕсли; 
	КонецЕсли; 

	Если НоваяСтрока Тогда
		ПриИзмененииСуммыПлатежаРаспределенияБюджета(Копирование);
	КонецЕсли; 

КонецПроцедуры

&НаКлиенте
Процедура ФактическиеДанныеПриИзменении(Элемент)
	
	// Любой элемент таблицы, кроме "суммы платежа", взводит флаг "НеСинхронизировать".
	Колонка = Элементы.ФактическиеДанные.ТекущийЭлемент;
	Если Колонка = Элементы.ФактическиеДанныеНомерСтрокиДокумента Тогда
		Возврат;
	КонецЕсли;
	
	Если Колонка <> Элементы.ФактическиеДанныеСуммаОплаты Тогда
		Объект.НеСинхронизировать = Истина;
	КонецЕсли; 	
	
	УправлениеФормой(ЭтотОбъект);
	
	КлючСтроки = "";
	Если ЕстьРасшифровкаПлатежа Тогда
		КлючСтроки = Элементы.ФактическиеДанные.ОтборСтрок.ИдентификаторСтроки;
	КонецЕсли; 
	
	ОбновитьИтоги(КлючСтроки, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ФактическиеДанныеПозицияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	Перем ДокументПланирования;
	
	ТекущиеДанные = Элементы.ФактическиеДанные.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		ДокументПланирования = ТекущиеДанные.Позиция;
	КонецЕсли;
	
	Если ИспользуетсяПланируемоеПоступление Тогда
		ОткрытьПодборПланируемогоПоступленияДС(ДокументПланирования, Элемент, СтандартнаяОбработка);
	Иначе	
		ОткрытьПодборПлатежнойПозиции(ДокументПланирования, Элемент, СтандартнаяОбработка);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ФактическиеДанныеПозицияПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ФактическиеДанные.ТекущиеДанные;
	Если ЗначениеЗаполнено(ТекущиеДанные.Позиция) Тогда	
		ТекущаяСтатьяОборотов = ТекущиеДанные.СтатьяОборотов;
		НоваяСтрока = ДанныеЗаполненияИзПозиции(ТекущиеДанные.Позиция, ТекущиеДанные.ПолучитьИдентификатор());
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, НоваяСтрока);
		Если ТекущиеДанные.СтатьяОборотов <> ТекущаяСтатьяОборотов Тогда
			ИзменениеСтатьиОборотовНаСервере(ТекущиеДанные.ПолучитьИдентификатор());
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ФактическиеДанныеВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущаяСтрока = Объект.ФактическиеДанные.НайтиПоИдентификатору(ВыбраннаяСтрока);
	
	ИмяРеквизита = СтрЗаменить(Поле.Имя, "ФактическиеДанные", "");
	
	Если ТекущаяСтрока <> Неопределено И ТекущаяСтрока.Заблокировать = 2 И ИмяРеквизита = "Позиция" Тогда
	
		ТекЗнч = ТекущаяСтрока[ИмяРеквизита];		
		Если ЗначениеЗаполнено(ТекЗнч) Тогда
			ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(ТекЗнч));		
		КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ФактическиеДанныеАналитика_НачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ФактическиеДанные.ТекущиеДанные;
	ИмяАналитики  = СтрЗаменить(Элемент.Имя, "ФактическиеДанные", "");
	
	бит_МеханизмДопИзмеренийКлиент.ВыбратьТипСоставнойАналитики(ЭтотОбъект, Элемент, ТекущиеДанные,
		ИмяАналитики, СтандартнаяОбработка, КэшЗначений.НастройкиИзмерений);
	
КонецПроцедуры

&НаКлиенте
Процедура ФактическиеДанныеАналитика_АвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
    
	ТекущиеДанные = Элементы.ФактическиеДанные.ТекущиеДанные;
	ИмяАналитики  = СтрЗаменить(Элемент.Имя, "ФактическиеДанные", "");
	
	бит_МеханизмДопИзмеренийКлиент.ВыбратьТипСоставнойАналитики(ЭтотОбъект, Элемент, ТекущиеДанные,
		ИмяАналитики, СтандартнаяОбработка, КэшЗначений.НастройкиИзмерений);
                                                               
КонецПроцедуры

