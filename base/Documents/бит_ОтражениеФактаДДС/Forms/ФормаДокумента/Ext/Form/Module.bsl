&НаКлиентеНаСервереБезКонтекста 
Процедура ОбновитьИтоги(КлючСтроки, Форма)

	Объект = Форма.Объект;
	
	Распределено 			   = 0;
	Разница					   = 0;
	РаспределеноВзаиморасчетов = 0;
	
	Для каждого СтрокаТаблицы Из Объект.ФактическиеДанные Цикл
		Если СтрокаТаблицы.ИдентификаторСтроки = КлючСтроки Тогда
			Распределено			   = Распределено + СтрокаТаблицы.СуммаОплаты;
			РаспределеноВзаиморасчетов = РаспределеноВзаиморасчетов + СтрокаТаблицы.СуммаВзаиморасчетов;
		КонецЕсли; 
	КонецЦикла; 

	Если Форма.ЕстьРасшифровкаПлатежа Тогда
		Для каждого СтрокаТаблицы Из Форма.РасшифровкаПлатежа Цикл
			Если СтрокаТаблицы.ИдентификаторСтроки = КлючСтроки Тогда
				СтрокаТаблицы.Распределено 				 = Распределено;
				СтрокаТаблицы.РаспределеноВзаиморасчетов = РаспределеноВзаиморасчетов;
				СтрокаТаблицы.Разница 	 				 = СтрокаТаблицы.Сумма - Распределено;
			КонецЕсли; 
		КонецЦикла; 
	КонецЕсли; 
	
	Форма.Распределено = Распределено;
	Форма.Разница      = Форма.СуммаДокумента - Распределено;
	
КонецПроцедуры

&НаСервере
Функция АналитическиеРазрезы()

	Разрезы = Новый Массив();
	Для Индекс = 1 По 12 Цикл
		Разрезы.Добавить("Аналитика_" + Индекс);
	КонецЦикла; 
	
	Возврат Разрезы;
	
КонецФункции

&НаКлиенте
Процедура ПроверитьМодификациюВладельцаФормы()
		
	Если ТипЗнч(ВладелецФормы) = Тип("ФормаКлиентскогоПриложения") Тогда
		Если НЕ ВладелецМодифицирован = ВладелецФормы.Модифицированность Тогда
			ТолькоПросмотр 		  = ВладелецФормы.Модифицированность;
			ВладелецМодифицирован = ВладелецФормы.Модифицированность;
			Если ТолькоПросмотр Тогда
				Модифицированность = Ложь;
			КонецЕсли; 
			ПодготовитьФормуНаСервере();
		КонецЕсли; 
		ПодключитьОбработчикОжидания("ПроверитьМодификациюВладельцаФормы", 0.5, Истина);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПараметрыУстановкиСвойствАналитик(Форма, Префикс = "")

	Результат = бит_МеханизмДопИзмеренийКлиентСервер.ПараметрыУстановкиСвойствАналитикПоШаблону(
		Префикс + "Аналитика_", "Аналитика_", "СтатьяОборотов");
		
	Результат.ДопРеквизиты.Вставить("Организация", Форма.Организация);
	
	Возврат Результат;

КонецФункции

&НаКлиенте
Процедура ПриИзмененииСуммыПлатежаРаспределенияБюджета(Копирование = Ложь)
	
	ТекущиеДанные = Элементы.ФактическиеДанные.ТекущиеДанные;
	
	Если ЕстьРасшифровкаПлатежа Тогда
		ДанныеРасшифровки 	= Элементы.РасшифровкаПлатежа.ТекущиеДанные;
		СуммаОплаты 	  	= ДанныеРасшифровки.Сумма;
		ИдентификаторСтроки	= Элементы.ФактическиеДанные.ОтборСтрок.ИдентификаторСтроки;
	Иначе
		СуммаОплаты			= СуммаДокумента;
		ИдентификаторСтроки = "";
	КонецЕсли; 
	
	Итого = 0;
	Для каждого СтрокаТаблицы Из Объект.ФактическиеДанные Цикл
		Если СтрокаТаблицы.ИдентификаторСтроки = ИдентификаторСтроки Тогда
			Итого = СтрокаТаблицы.СуммаОплаты + Итого;
		КонецЕсли; 
	КонецЦикла; 
	
	Остаток = СуммаОплаты - Итого + ТекущиеДанные.СуммаОплаты;
	
	КонтролироватьПревышение = НЕ Объект.НеСинхронизироватьСумму;
	Если КонтролироватьПревышение Тогда
		Остаток = Макс(Остаток, 0);
		Если НЕ Копирование И Итого > СуммаОплаты Тогда
			Если ЕстьРасшифровкаПлатежа Тогда
				ТекстСообщения = НСтр("ru='Сумма распределенных платежей превышает сумму платежа. Остаток от распределения: %1.';
									  |en='The amount of distributed payment exceeds the amount of the payment. The residue from the distribution: %1.'");
			Иначе
				ТекстСообщения = НСтр("ru='Сумма распределенных платежей превышает сумму документа. Сумма документа: %1.';
									  |en='The amount of payments exceeds the amount distributed document. The amount of the document: %1.'"); 
			КонецЕсли;
			ТекстСообщения = СтрШаблон(ТекстСообщения, Формат(Остаток, "ЧДЦ=2; ЧН=")); 
			Индекс		   = Объект.ФактическиеДанные.Индекс(ТекущиеДанные);		
			Поле  		   = СтрШаблон("Объект.ФактическиеДанные[%1].СуммаОплаты", Формат(Индекс, "ЧН=0; ЧГ="));
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , Поле, ); 
		КонецЕсли;
		Если ТекущиеДанные.СуммаОплаты <> 0 Тогда
			Остаток = Мин(ТекущиеДанные.СуммаОплаты, Остаток);
		КонецЕсли;
		ТекущиеДанные.СуммаОплаты = Остаток;
	КонецЕсли; 
	
	ПараметрыПередачи = Новый Структура;
	ПараметрыПередачи.Вставить("КурсЧислительВзаиморасчетов", 	ТекущиеДанные.КурсЧислительВзаиморасчетов);
	ПараметрыПередачи.Вставить("КурсЗнаменательВзаиморасчетов", ТекущиеДанные.КурсЗнаменательВзаиморасчетов);
	ПараметрыПередачи.Вставить("СуммаВзаиморасчетов", 			ТекущиеДанные.СуммаВзаиморасчетов);
	ПараметрыПередачи.Вставить("Сумма", 						ТекущиеДанные.СуммаОплаты);
	
	ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
		ПараметрыПередачи, Объект.ВалютаДокумента, ВалютаРеглУчета);
		
	ТекущиеДанные.СуммаВзаиморасчетов = ПараметрыПередачи.СуммаВзаиморасчетов; 	

	ОбновитьИтоги(ТекущиеДанные.ИдентификаторСтроки, ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДобавленныеКолонкиТаблиц()
	
	Для каждого СтрокаТаблицы Из Объект.ФактическиеДанные Цикл
		ЗаполнитьДобавленныеКолонкиСтроки(СтрокаТаблицы); 
	КонецЦикла; 
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДобавленныеКолонкиСтроки(СтрокаТаблицы)
	
	СтатьяОборотов = Справочники.бит_СтатьиОборотов.ПустаяСсылка();
	
	// Если в "аналитиках шапки" выбрана статья оборотов, но не выбрана в "распределении",
	// наследуем ее настройки.
	Если ЗначениеЗаполнено(СтрокаТаблицы.СтатьяОборотов) Тогда
		СтатьяОборотов = СтрокаТаблицы.СтатьяОборотов;
	Иначе	
	//	СтатьяОборотов = ОсновнаяСтатьяОборотов;
		Возврат;
	КонецЕсли; 
	
	СвойстваСтатьи = бит_БюджетированиеПовтИспСервер.ПолучитьСвойстваСтатьи(СтатьяОборотов);
	Разрезы = АналитическиеРазрезы(); 
	
	Для каждого Разрез Из Разрезы Цикл
		СтрокаТаблицы[Разрез + "Доступность"] = СвойстваСтатьи[Разрез];
	КонецЦикла; 

КонецПроцедуры

&НаСервере
Процедура ИзменениеСтатьиОборотовНаСервере(ИД)

	СтрокаТаблицы = Объект.ФактическиеДанные.НайтиПоИдентификатору(ИД); 
	
	бит_МеханизмДопИзмерений.УстановитьСвойстваАналитикСтрокиПриИзмененииСтатьиОборотов(
				ЭтотОбъект, СтрокаТаблицы, ПараметрыУстановкиСвойствАналитик(ЭтотОбъект, "ФактическиеДанные"));
	ЗаполнитьДобавленныеКолонкиСтроки(СтрокаТаблицы);

КонецПроцедуры

