КонецПроцедуры

&НаКлиенте
Процедура ПривязатьТаблицы(Команда)
	
	ТекстСообщения = НСтр("ru = 'Проверьте правильность заполнения номеров строк. После записи документа изменить связи таблиц будет невозможно. Продолжить?'; 
							|en = 'Check that the line numbers are filled in correctly. After writing the document, it will be impossible to change the table relationships. Continue?'");
	
	Оповещение = Новый ОписаниеОповещения("ПривязатьТаблицыЗавершение", ЭтотОбъект);
	ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура ПривязатьТаблицыЗавершение(Результат, Дополнительно) Экспорт

	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	ВсеСтрокиПривязаны = Истина;
	
	Для каждого СтрокаТаблицы Из Объект.ФактическиеДанные Цикл
		// Метод НайтиСтроки() на клиенте выполняет неявный вызов сервера. Скнируем таблицу.
		СтрокаПривязана = Ложь;
		Для каждого ДанныеСтрокиРасшифровки Из РасшифровкаПлатежа Цикл
			Если СтрокаТаблицы.НомерСтрокиДокумента = ДанныеСтрокиРасшифровки.НомерСтрокиДокумента Тогда
				СтрокаТаблицы.ИдентификаторСтроки 			= ДанныеСтрокиРасшифровки.ИдентификаторСтроки;
				СтрокаТаблицы.ВалютаВзаиморасчетов		    = ДанныеСтрокиРасшифровки.ВалютаВзаиморасчетов;
				СтрокаТаблицы.КурсЧислительВзаиморасчетов   = ДанныеСтрокиРасшифровки.КурсЧислительВзаиморасчетов;
				СтрокаТаблицы.КурсЗнаменательВзаиморасчетов = ДанныеСтрокиРасшифровки.КурсЗнаменательВзаиморасчетов;
				
				ПараметрыПередачи = Новый Структура;
				ПараметрыПередачи.Вставить("КурсЧислительВзаиморасчетов", 	СтрокаТаблицы.КурсЧислительВзаиморасчетов);
				ПараметрыПередачи.Вставить("КурсЗнаменательВзаиморасчетов", СтрокаТаблицы.КурсЗнаменательВзаиморасчетов);
				ПараметрыПередачи.Вставить("СуммаВзаиморасчетов", 			СтрокаТаблицы.СуммаВзаиморасчетов);
				ПараметрыПередачи.Вставить("Сумма", 						СтрокаТаблицы.СуммаОплаты);
				
				ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
					ПараметрыПередачи, Объект.ВалютаДокумента, ВалютаРеглУчета);
				
				СтрокаТаблицы.СуммаВзаиморасчетов = ПараметрыПередачи.СуммаВзаиморасчетов; 	

				СтрокаПривязана = Истина;
			КонецЕсли;	
			ОбновитьИтоги(СтрокаТаблицы.ИдентификаторСтроки, ЭтотОбъект);
		КонецЦикла;
		Если НЕ СтрокаПривязана Тогда
			ВсеСтрокиПривязаны = Ложь;	
		КонецЕсли;
	КонецЦикла;
	
	Если ВсеСтрокиПривязаны Тогда
		Объект.НачатПереходНаНовуюАрхитектуру = Ложь;
		УправлениеФормой(ЭтотОбъект);
		ОтобразитьРаспределениеБюджета();
	Иначе
		ТекстСообщения = НСтр("ru = 'Найдены непривязанные строки. Уточните привязку.'; 
								|en = 'Unbound strings were found. Specify the binding.'");
		ПоказатьПредупреждение(, ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	ЗаполнитьКэшЗначений();
	ПрочитатьРеквизитыВладельцаАналитик();
	
	ПараметрыВидимости = бит_КазначействоКлиентСервер.ПодготовитьПараметрыВидимости(ХозяйственнаяОперацияБФ);
	ВалютаРеглУчета	   = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Организация);
	
	ЗаполнитьФлаги();
	
	ДоработатьТаблицуАналитик();
	
	// Управляем видимостью колонок дополнительных измерений.
	бит_МеханизмДопИзмерений.ПоказатьДополнительныеИзмеренияВТабличномПоле(ЭтотОбъект, "ФактическиеДанные",
		КэшЗначений.ИзмеренияДоп, КэшЗначений.НастройкиИзмерений);
			
	Если ЕстьРасшифровкаПлатежа Тогда
		
		ПрочитатьРасшифровкуПлатежа();
		
		Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл
			ПараметрыОтбора	  = Новый Структура("ИдентификаторСтроки", СтрокаТаблицы.ИдентификаторСтроки);
			РезультатПоиска = Объект.ФактическиеДанные.НайтиСтроки(ПараметрыОтбора);
			Если ЗначениеЗаполнено(РезультатПоиска) Тогда
				Запись = РезультатПоиска[0];	
				СтрокаТаблицы.КурсЧислительВзаиморасчетов	= Запись.КурсЧислительВзаиморасчетов;
				СтрокаТаблицы.КурсЗнаменательВзаиморасчетов = Запись.КурсЗнаменательВзаиморасчетов;
			КонецЕсли;
			ОбновитьИтоги(СтрокаТаблицы.ИдентификаторСтроки, ЭтотОбъект);
		КонецЦикла;
		Элементы.ФактическиеДанныеСуммаОплаты.ПутьКДаннымПодвала = "Элементы.РасшифровкаПлатежа.ТекущиеДанные.Распределено";
		
		// Переход на новую архитектуру.
		Если Объект.НачатПереходНаНовуюАрхитектуру Тогда
			НомерСтроки = 0;
			ВГраница 	= РасшифровкаПлатежа.Количество();
			Пока НомерСтроки <= ВГраница Цикл
				Элементы.ФактическиеДанныеНомерСтрокиДокумента.СписокВыбора.Добавить(НомерСтроки);
				НомерСтроки = НомерСтроки + 1;
			КонецЦикла;
			Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл
				ПараметрыОтбора	  = Новый Структура("ИдентификаторСтроки", СтрокаТаблицы.ИдентификаторСтроки);
				РезультатПоиска = Объект.ФактическиеДанные.НайтиСтроки(ПараметрыОтбора);
				Для каждого Элемент Из РезультатПоиска Цикл
					Элемент.НомерСтрокиДокумента = СтрокаТаблицы.НомерСтрокиДокумента;
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
	Иначе
		ОбновитьИтоги("", ЭтотОбъект);	
		Элементы.ФактическиеДанныеСуммаОплаты.ПутьКДаннымПодвала = "Распределено";
	КонецЕсли; 	

	ВладелецМодифицирован = ТолькоПросмотр;	
	
	Элементы.РасшифровкаПлатежаСумма.Заголовок	  	= СтрШаблон(НСтр("ru = 'Сумма (%1)'; en = 'Amount (%1)'"), Объект.ВалютаДокумента);
	Элементы.РасшифровкаПлатежаСуммаНДС.Заголовок 	= СтрШаблон(НСтр("ru = 'Сумма НДС (%1)'; en = 'VAT amount (%1)'"), Объект.ВалютаДокумента);
	Элементы.ФактическиеДанныеСуммаОплаты.Заголовок	= СтрШаблон(НСтр("ru = 'Сумма (%1)'; en = 'Amount (%1)'"), Объект.ВалютаДокумента);
	
	ЗаполнитьКурсКратностьТекстом();
	ЗаполнитьДобавленныеКолонкиТаблиц();
	УправлениеФормой(ЭтотОбъект);
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКэшЗначений()

	КэшЗначений = Новый Структура;
	КэшЗначений.Вставить("ИзмеренияДоп", бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Дополнительные", "Синоним"));
	// Настройки дополнительных измерений.
	КэшЗначений.Вставить("НастройкиИзмерений", бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений"));
	// Настройки всех дополнительных аналитик.
	КэшЗначений.Вставить("НастройкиАналитик", бит_МеханизмДопИзмерений.ПолучитьНастройкиДополнительныхАналитик());
			
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьФлаги()

	// ++ NB При перемещении денег используется 2 вида документов.
	
	ЕстьРасшифровкаПлатежа = бит_ОбщегоНазначенияПереопределяемый.ЕстьРасшифровкаПлатежа(
								Объект.ДокументОснование, Неопределено);
								
	Если ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.ПриходныйКассовыйОрдер") 
		ИЛИ ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.ПоступлениеБезналичныхДенежныхСредств") Тогда
		ОграничениеТипаПозиции = Новый ОписаниеТипов("ДокументСсылка.бит_кзн_ПозицияПоступления");
		ИспользуетсяПланируемоеПоступление = Истина;
	Иначе	
		ОграничениеТипаПозиции = Новый ОписаниеТипов("ДокументСсылка.бит_кзн_ПлатежнаяПозиция");
		ИспользуетсяПлатежнаяПозиция = Истина;
	КонецЕсли;
	
	Элементы.ФактическиеДанныеПозиция.ОграничениеТипа = ОграничениеТипаПозиции;					

	ИспользоватьДоговорыСПоставщиками	   = ПолучитьФункциональнуюОпцию("ИспользоватьДоговорыСПоставщиками");
	ИспользоватьДоговорыМеждуОрганизациями = ПолучитьФункциональнуюОпцию("ИспользоватьДоговорыМеждуОрганизациями");
	ИспользоватьДоговорыСКлиентами		   = ПолучитьФункциональнуюОпцию("ИспользоватьДоговорыСКлиентами");

КонецПроцедуры

&НаСервере
Процедура ПрочитатьРеквизитыВладельцаАналитик()

	ИменаРеквизитов = Новый Структура;
	ИменаРеквизитов.Вставить("Валюта");
	ИменаРеквизитов.Вставить("Организация");
	ИменаРеквизитов.Вставить("СуммаДокумента");
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ХозяйственнаяОперация", Объект.ДокументОснование.Метаданные()) Тогда
		ИменаРеквизитов.Вставить("ХозяйственнаяОперацияУП", "ХозяйственнаяОперация");	
	КонецЕсли;
	
	РеквизитыВладельца = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.ДокументОснование, 
							Новый ФиксированнаяСтруктура(ИменаРеквизитов));
							
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, РеквизитыВладельца);
	
	ХозяйственнаяОперацияБФ = бит_КазначействоКлиентСервер.ХозяйственнаяОперацияБФ(ХозяйственнаяОперацияУП);
	
КонецПроцедуры

// Процедура дозаполняет строку аналитик. 
//
&НаСервере
Процедура ДозаполнитьСтрокуАналитик(ТекущаяСтрока)

	Если ТекущаяСтрока <> Неопределено Тогда
		
		Если ЗначениеЗаполнено(ТекущаяСтрока.Аналитика) Тогда
			
			ОписаниеТиповАналитики = ТекущаяСтрока.Аналитика.ТипЗначения;
			ТекущаяСтрока.ЗначениеАналитики = ОписаниеТиповАналитики.ПривестиЗначение(ТекущаяСтрока.ЗначениеАналитики);
			
			// Для дополнительных значений аналитик необходимо проверить владельца.
			Если ТипЗнч(ТекущаяСтрока.ЗначениеАналитики) = Тип("СправочникСсылка.бит_ДополнительныеЗначенияАналитик") 
				 И ЗначениеЗаполнено(ТекущаяСтрока.ЗначениеАналитики) Тогда
			
				Если ТекущаяСтрока.ЗначениеАналитики.Владелец <> ТекущаяСтрока.Аналитика Тогда				
					ТекущаяСтрока.ЗначениеАналитики = Справочники.бит_ДополнительныеЗначенияАналитик.ПустаяСсылка();				
				КонецЕсли; 
			
			КонецЕсли; 
			
			ТекущаяСтрока.ИмяАналитики = СокрЛП(ТекущаяСтрока.Аналитика.Код);
			
		КонецЕсли;
		
	КонецЕсли; 

КонецПроцедуры // ДозаполнитьСтрокуАналитик()

// Процедура дополняет НаборДопАналитики необходимыми данными.
//
&НаСервере
Процедура ДоработатьТаблицуАналитик()

	Для каждого СтрокаТаблицы Из Объект.Аналитики Цикл	
		ДозаполнитьСтрокуАналитик(СтрокаТаблицы);	
	КонецЦикла; 

КонецПроцедуры // ДоработатьТаблицуАналитик()

// Обрабатывает изменение аналитики в строке таблицы НаборДопАналитики. 
//
// Параметры:
//  ИдСтроки - Число.
//
&НаСервере
Процедура ИзменениеАналитики(ИдСтроки)
	
	ТекущаяСтрока = Объект.Аналитики.НайтиПоИдентификатору(ИдСтроки);
	ДозаполнитьСтрокуАналитик(ТекущаяСтрока);
	
КонецПроцедуры // ИзменениеАналитики()

&НаКлиентеНаСервереБезКонтекста 
Процедура УправлениеФормой(Форма)
	
	Объект	 = Форма.Объект;
	Элементы = Форма.Элементы;
												 
	Элементы.ФормаЗаписатьЗакрыть.Доступность	   = НЕ Форма.ВладелецМодифицирован;
	Элементы.ПерезаполнитьПоОснованию.Доступность  = НЕ Форма.ВладелецМодифицирован;
	Элементы.АналитикиПодменюЗаполнить.Доступность = НЕ Форма.ВладелецМодифицирован;
		
	Элементы.ПредупреждениеОНезаписанномДокументе.Видимость	= Форма.ВладелецМодифицирован;
	Элементы.ЗаполнитьАналитикиТабличнойЧасти.Доступность   = НЕ Форма.ВладелецМодифицирован;
	
	Элементы.РасшифровкаПлатежа.Видимость 	  				= Форма.ЕстьРасшифровкаПлатежа;
	Элементы.ГруппаСуммаПлатежа.Видимость 	 				= НЕ Форма.ЕстьРасшифровкаПлатежа;
	Элементы.ФактическиеДанныеСуммаВзаиморасчетов.Видимость = Форма.ЕстьРасшифровкаПлатежа;
	
	Если ПустаяСтрока(Форма.ИмяТекущейСтраницы) Тогда
		Если Объект.ФактическиеДанные.Количество() <= 1 Тогда
			Элементы.СтраницыФормы.ТекущаяСтраница = Элементы.СтраницаАналитикиШапки;
		Иначе	
			Элементы.СтраницыФормы.ТекущаяСтраница = Элементы.СтраницаАналитикиТабличнойЧасти;
		КонецЕсли;
		Форма.ИмяТекущейСтраницы = Элементы.СтраницыФормы.ТекущаяСтраница.Имя;
	Иначе	
		// При обновлении формы-владельца происходит повторное открытие формы.
		// Это приводит к переключению закладок.
		Элементы.СтраницыФормы.ТекущаяСтраница = Элементы[Форма.ИмяТекущейСтраницы];
	КонецЕсли;

	ПараметрыВидимости 		= Форма.ПараметрыВидимости;
	ХозяйственнаяОперацияБФ = Форма.ХозяйственнаяОперацияБФ;
	
	Элементы.РасшифровкаПлатежаОбъектРасчетов.Видимость = ПараметрыВидимости.ЕстьОбъектРасчетов;
	
	Если Объект.НеСинхронизироватьСумму Тогда
		ЗаголовокКурсЧислительВзаиморасчетов = НСтр("ru = 'Факт по курсу'; en = 'Fact by rate'");
	Иначе	
		ЗаголовокКурсЧислительВзаиморасчетов = НСтр("ru = 'По курсу'; en = 'By rate'");
	КонецЕсли;
	Элементы.РасшифровкаПлатежаКурсЧислительВзаиморасчетов.Заголовок = ЗаголовокКурсЧислительВзаиморасчетов;
	
	Элементы.ФактическиеДанныеСуммаВзаиморасчетов.ТолькоПросмотр = НЕ Объект.НеСинхронизироватьСумму;
	
	Если ХозяйственнаяОперацияБФ = ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ПеречислениеНаДепозиты")
		ИЛИ ХозяйственнаяОперацияБФ = ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ОплатаПоКредитам")
		ИЛИ ХозяйственнаяОперацияБФ = ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ПеречислениеНаДепозиты") 
		ИЛИ ХозяйственнаяОперацияБФ = ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ВыдачаЗаймов") Тогда 			
		Элементы.РасшифровкаПлатежаДоговорКредитаДепозита.Видимость = Истина;
		Элементы.РасшифровкаПлатежаДоговорАренды.Видимость 	 	   = Ложь;	
	ИначеЕсли ХозяйственнаяОперацияБФ = ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ОплатаАрендодателю") Тогда			
		Элементы.РасшифровкаПлатежаДоговорКредитаДепозита.Видимость = Ложь;
		Элементы.РасшифровкаПлатежаДоговорАренды.Видимость		   = Истина;
	ИначеЕсли ХозяйственнаяОперацияБФ = ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ВозвратОплатыНаПлатежнуюКарту") Тогда
		Элементы.РасшифровкаПлатежаДоговорКредитаДепозита.Видимость = Ложь;
		Элементы.РасшифровкаПлатежаДоговорАренды.Видимость		   = Ложь;
	Иначе	
		Элементы.РасшифровкаПлатежаДоговорКредитаДепозита.Видимость = Ложь;
		Элементы.РасшифровкаПлатежаДоговорАренды.Видимость 		   = Ложь;
	КонецЕсли; 

	Если (ХозяйственнаяОперацияБФ = ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ВозвратДенежныхСредствВДругуюОрганизацию")
		И Форма.ИспользоватьДоговорыМеждуОрганизациями 
	  ИЛИ ХозяйственнаяОперацияБФ = ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ВозвратОплатыКлиенту") 
		И Форма.ИспользоватьДоговорыСКлиентами 
  	  ИЛИ ХозяйственнаяОперацияБФ = ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ОплатаПоставщику")
		И Форма.ИспользоватьДоговорыСПоставщиками
	  ИЛИ ХозяйственнаяОперацияБФ = ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ОплатаДенежныхСредствВДругуюОрганизацию")
		И Форма.ИспользоватьДоговорыМеждуОрганизациями
	  ИЛИ ХозяйственнаяОперацияБФ = ПредопределенноеЗначение("Перечисление.бит_ВидыОперацийКазначейства.ПеречислениеТаможне")
		И Форма.ИспользоватьДоговорыСПоставщиками) Тогда
		
		Элементы.РасшифровкаПлатежаДоговор.Видимость = Истина;
	Иначе
		Элементы.РасшифровкаПлатежаДоговор.Видимость = Ложь;
	КонецЕсли;

	Элементы.ПредупреждениеОНезавершенномПереходеНаНовуюАрхитектуру.Видимость = Объект.НачатПереходНаНовуюАрхитектуру;
	Элементы.ФактическиеДанныеПривязатьТаблицы.Видимость					  = Объект.НачатПереходНаНовуюАрхитектуру;
	Элементы.ФактическиеДанныеНомерСтрокиДокумента.Видимость				  = Объект.НачатПереходНаНовуюАрхитектуру;
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьПроведениеБитНаСервере(ТекущийОбъект, Отказ)

	ТекущийОбъект.ПровестиОтражениеДДС(ТекущийОбъект, Отказ);
	
	ПлатежныеПозиции = РазличныеПозиции.ВыгрузитьЗначения();
	КэшОпераций      = бит_ВизированиеСервер.НовыйКэшОперацийУстановкиСтатусов();
	Документы.бит_ОтражениеФактаДДС.ОбновитьСтатусыПлатежныхПозиций(ПлатежныеПозиции, КэшОпераций);
	Документы.бит_ОтражениеФактаДДС.ОбновитьСтатусыЗаявокПоПлатежнымПозициям(ПлатежныеПозиции, КэшОпераций);
	
КонецПроцедуры

&НаСервере
Процедура ОпределитьПереченьПозиций(ТекущийОбъект)
	
	РазличныеПозиции.Очистить();
	
	ТекущиеПозиции = ТекущийОбъект.ФактическиеДанные.ВыгрузитьКолонку("Позиция");
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ФактическиеДанные.Позиция КАК Позиция
	|ПОМЕСТИТЬ ПозицииДоИзменения
	|ИЗ
	|	Документ.бит_ОтражениеФактаДДС.ФактическиеДанные КАК ФактическиеДанные
	|ГДЕ
	|	ФактическиеДанные.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПлатежныеПозиции.Ссылка КАК Позиция
	|ПОМЕСТИТЬ ВсеПозиции
	|ИЗ
	|	ПозицииДоИзменения КАК ПозицииДоИзменения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|		ПО ПозицииДоИзменения.Позиция = ПлатежныеПозиции.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПлатежныеПозиции.Ссылка
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|ГДЕ
	|	ПлатежныеПозиции.Ссылка В(&ТекущиеПозиции)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПозицииПоступления.Ссылка
	|ИЗ
	|	ПозицииДоИзменения КАК ПозицииДоИзменения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПозицияПоступления КАК ПозицииПоступления
	|		ПО ПозицииДоИзменения.Позиция = ПозицииПоступления.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПозицииПоступления.Ссылка
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК ПозицииПоступления
	|ГДЕ
	|	ПозицииПоступления.Ссылка В(&ТекущиеПозиции)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВсеПозиции.Позиция КАК Позиция
	|ИЗ
	|	ВсеПозиции КАК ВсеПозиции";
	Запрос.УстановитьПараметр("Ссылка", ТекущийОбъект.Ссылка);
	Запрос.УстановитьПараметр("ТекущиеПозиции", ТекущиеПозиции);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	РазличныеПозиции.ЗагрузитьЗначения(РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Позиция"));
	
КонецПроцедуры

// Процедура заполняет аналитики шапки 
//
&НаСервере
Процедура ЗаполнитьШапкуПоОснованиюНаСервере()

	НеСинхронизировать		 = Объект.НеСинхронизировать;
	НеСинхронизироватьПериод = Объект.НеСинхронизироватьПериод;
	
	Объект.НеСинхронизировать		= Ложь;
	Объект.НеСинхронизироватьПериод = Ложь;
	
	РеквизитыОснования = Документы.бит_ОтражениеФактаДДС.РеквизитыОснования(Объект.ДокументОснование);

	Документы.бит_ОтражениеФактаДДС.ЗаполнитьАналитикиШапкиПоДаннымОснования(Объект, РеквизитыОснования);
	
	Объект.НеСинхронизировать		= НеСинхронизировать;
	Объект.НеСинхронизироватьПериод = НеСинхронизироватьПериод;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьФактическиеДанныеНаСервере()

	НеСинхронизировать		 = Объект.НеСинхронизировать;
	НеСинхронизироватьПериод = Объект.НеСинхронизироватьПериод;
	
	Объект.НеСинхронизировать		= Ложь;
	Объект.НеСинхронизироватьПериод = Ложь;
	
	РеквизитыОснования = Документы.бит_ОтражениеФактаДДС.РеквизитыОснования(Объект.ДокументОснование);
	
	Документы.бит_ОтражениеФактаДДС.ЗаполнитьАналитикиФактическихДанных(Объект, РеквизитыОснования);
	
	Объект.НеСинхронизировать		= НеСинхронизировать;
	Объект.НеСинхронизироватьПериод = НеСинхронизироватьПериод;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоОснованию()

	НеСинхронизировать		 = Объект.НеСинхронизировать;
	НеСинхронизироватьПериод = Объект.НеСинхронизироватьПериод;
	
	Объект.НеСинхронизировать		= Ложь;
	Объект.НеСинхронизироватьПериод = Ложь;

	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	ДокументОбъект.Заполнить(Объект.ДокументОснование);
	ЗначениеВДанныеФормы(ДокументОбъект, Объект);
	
	Объект.НеСинхронизировать		= НеСинхронизировать;
	Объект.НеСинхронизироватьПериод = НеСинхронизироватьПериод;
	
	ПодготовитьФормуНаСервере();

КонецПроцедуры

//  Функция проверяет наличие позиций в табл части ФактическиеДанные 
 //
&НаСервере
Функция ЕстьСсылкиНаПлатежныеПозиции()
	
	ЕстьСсылки = Ложь;
	
	Для каждого Стр Из Объект.ФактическиеДанные Цикл
		Если ЗначениеЗаполнено(Стр.Позиция) Тогда		
			ЕстьСсылки = Истина;
			Прервать;		
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЕстьСсылки;
	
КонецФункции

&НаСервере
Функция ДанныеЗаполненияИзПозиции(Позиция, ТекущаяСтрока)

	НоваяСтрока = Новый Структура;
	НоваяСтрока.Вставить("Аналитика_1");
	НоваяСтрока.Вставить("Аналитика_2");
	НоваяСтрока.Вставить("Аналитика_3");
	НоваяСтрока.Вставить("Аналитика_4");
	НоваяСтрока.Вставить("Аналитика_5");
	НоваяСтрока.Вставить("Аналитика_6");
	НоваяСтрока.Вставить("Аналитика_7");
	НоваяСтрока.Вставить("Аналитика_8");
	НоваяСтрока.Вставить("Аналитика_9");
	НоваяСтрока.Вставить("Аналитика_10");
	НоваяСтрока.Вставить("Аналитика_11");
	НоваяСтрока.Вставить("Аналитика_12");
	НоваяСтрока.Вставить("ЦФО");
	НоваяСтрока.Вставить("СтатьяОборотов");
	НоваяСтрока.Вставить("Период");

	ЗаполнитьЗначенияСвойств(НоваяСтрока, Позиция);

	Если ИспользуетсяПлатежнаяПозиция Тогда		
		ОстатокПланирования = ОстатокПлатежнойПозиции(Позиция);		
	Иначе		
		ОстатокПланирования = ОстатокПозицииПоступления(Позиция);
	КонецЕсли;
	
	СтрокаРаспределения = Объект.ФактическиеДанные.НайтиПоИдентификатору(ТекущаяСтрока);
	Если ЕстьРасшифровкаПлатежа Тогда
		РезультатПоиска  = РасшифровкаПлатежа.НайтиСтроки(Новый Структура("ИдентификаторСтроки", СтрокаРаспределения.ИдентификаторСтроки));
		СтрокаРасшифровки = РезультатПоиска[0];
		
		ВалютаВзаиморасчетов		  = СтрокаРасшифровки.ВалютаВзаиморасчетов;
		КурсЧислительВзаиморасчетов	  = СтрокаРасшифровки.КурсЧислительВзаиморасчетов;
		КурсЗнаменательВзаиморасчетов = СтрокаРасшифровки.КурсЗнаменательВзаиморасчетов;
	Иначе	
		
	КонецЕсли;
	
	Сумма = 0;
	Если ОстатокПланирования.Сумма <> 0 Тогда
		Коэффициенты = бит_Казначейство.ПолучитьКоэффициентыПересчетаВалюты(ВалютаВзаиморасчетов,
					Объект.ВалютаДокумента, Объект.Дата, Организация, КурсЧислительВзаиморасчетов, КурсЗнаменательВзаиморасчетов);
		
		Сумма = Коэффициенты.КоэффициентПересчетаВВалютуВзаиморасчетов * ОстатокПланирования.Сумма;
	КонецЕсли;
	
	НоваяСтрока.Вставить("СуммаОплаты", Сумма); 
	НоваяСтрока.Вставить("Период", 		Позиция.ДатаПлан); 
	
	Возврат НоваяСтрока;
									
КонецФункции

&НаСервере
Функция ОстатокПлатежнойПозиции(Позиция)

	Данные = Новый Структура("Валюта, Сумма", Объект.ВалютаДокумента, 0);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Позиция", Позиция);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПланируемыйРасходДенежныхСредств.Позиция КАК Позиция,
	|	ПланируемыйРасходДенежныхСредств.СуммаОстаток КАК Сумма,
	|	ВЫБОР
	|		КОГДА ПлатежныеПозиции.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа)
	|			ТОГДА ПлатежныеПозиции.ВалютаДокумента
	|		ИНАЧЕ ПлатежныеПозиции.ВалютаВзаиморасчетов
	|	КОНЕЦ КАК Валюта
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.Остатки(, Позиция = &Позиция) КАК ПланируемыйРасходДенежныхСредств
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|		ПО ПланируемыйРасходДенежныхСредств.Позиция = ПлатежныеПозиции.Ссылка";
					   
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Данные, Выборка);
	КонецЦикла;
	
	Возврат Данные;
	
КонецФункции

&НаСервере
Функция ОстатокПозицииПоступления(Позиция)
	
	Данные = Новый Структура("Валюта, Сумма", Объект.ВалютаДокумента, 0);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Позиция", Позиция);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПланируемоеПоступлениеДенежныхСредств.Позиция КАК Позиция,
	|	ПланируемоеПоступлениеДенежныхСредств.СуммаОстаток КАК Сумма,
	|	ВЫБОР
	|		КОГДА ПозицииПоступления.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа)
	|			ТОГДА ПозицииПоступления.ВалютаДокумента
	|		ИНАЧЕ ПозицииПоступления.ВалютаВзаиморасчетов
	|	КОНЕЦ КАК Валюта
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Остатки(, Позиция = &Позиция) КАК ПланируемоеПоступлениеДенежныхСредств
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПозицияПоступления КАК ПозицииПоступления
	|		ПО ПланируемоеПоступлениеДенежныхСредств.Позиция = ПозицииПоступления.Ссылка";
					   
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(Данные, Выборка);
	КонецЦикла;
	
	Возврат Данные;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьШапкуПоФактическимДаннымНаСервере()
	
	Если Объект.ФактическиеДанные.Количество() = 0 Тогда
		Возврат;	
	КонецЕсли; 	
	
	Документы.бит_ОтражениеФактаДДС.ЗаполнитьАналитикиШапкиПоФактическимДанным(
		Объект.ДокументОснование.Метаданные(), Объект.ФактическиеДанные, Объект.Аналитики);
						
КонецПроцедуры

// Процедура вызывается по кнопке при изменении активной строки в таблице расшифровки платежа.
//
&НаКлиенте
Процедура ОтобразитьРаспределениеБюджета()
	
	Если Объект.НачатПереходНаНовуюАрхитектуру Тогда
		Возврат;
	КонецЕсли;
	
	Если ЕстьРасшифровкаПлатежа Тогда
		СтрокаТаблицы =  Элементы.РасшифровкаПлатежа.ТекущиеДанные;
		
		Если СтрокаТаблицы <> Неопределено Тогда
			// Включаем отбор по ключу из текущей строки табличной части "РасшифровкаПлатежа".
			ОтборСтрок = Новый ФиксированнаяСтруктура("ИдентификаторСтроки", СтрокаТаблицы.ИдентификаторСтроки); 
			
			Элементы.ФактическиеДанные.ТолькоПросмотр = Ложь;
			Элементы.ФактическиеДанные.ОтборСтрок 	  = ОтборСтрок;
		Иначе
			// Текущая строка в таблице распределения платежа не установлена.
			Элементы.ФактическиеДанные.ТолькоПросмотр = Истина;
		КонецЕсли;
	КонецЕсли; 

КонецПроцедуры

