// Параметры:
//   Реквизиты - Массив - список имен реквизитов объекта.
//
Процедура ПриПолученииСлужебныхРеквизитов(Реквизиты) Экспорт
	
	Реквизиты.Добавить("НастройкиПостроителя");
	Реквизиты.Добавить("ХранилищеДерева");
	Реквизиты.Добавить("Удалить_ТекстЗапроса");

	Реквизиты.Добавить("БДДС.ИД");
	
	Реквизиты.Добавить("ЗависимыеОбороты.ИД");
	Реквизиты.Добавить("ЗависимыеОбороты.ИД_Родитель");
	Реквизиты.Добавить("ЗависимыеОбороты.КомментарийРасчета");
	
	Реквизиты.Добавить("НаборыЗначенийДоступа.*");
	
КонецПроцедуры

