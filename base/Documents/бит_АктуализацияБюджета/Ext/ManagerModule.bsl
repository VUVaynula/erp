// Функция подготавливает параметры проведения.
// 
// Параметры:
//  ДокументСсылка - ДокументСсылка.бит_НазначениеСоответствияАналитик - ссылка на документ.
//  Отказ          - Булево - признак обнаружения ошибки и отказа от дальнейших действий.
//
// Возвращаемое значение:
//  Структура - структура параметров проведения.
//
Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт
	
	ПараметрыПроведения = Новый Структура(); 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Дата КАК Дата,
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.Сценарий КАК Сценарий,
	|	Реквизиты.ЦФО КАК ЦФО,
	|	Реквизиты.ВалютаДокумента КАК ВалютаДокумента,
	|	Реквизиты.КурсДокумента КАК КурсДокумента,
	|	Реквизиты.КратностьДокумента КАК КратностьДокумента,
	|	Реквизиты.СторнироватьЗависимыеОбороты КАК СторнироватьЗависимыеОбороты,
	|	Реквизиты.СверхБюджета КАК СверхБюджета,
	|	Реквизиты.Сценарий.ИспользоватьКурсыСценария КАК ИспользоватьКурсыСценария,
	|	Реквизиты.Сценарий.Валюта КАК ВалютаСценария,
	|	Реквизиты.СценарийЭталон КАК СценарийЭталон,
	|	Реквизиты.РежимПринятияКУчету КАК РежимПринятияКУчету,
	|	Реквизиты.СписатьЛимиты КАК СписатьЛимиты
	|ИЗ
	|	Документ.бит_АктуализацияБюджета КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";
	Результат = Запрос.Выполнить().Выгрузить();
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Результат[0]);
	
	Если НЕ бит_ОбщегоНазначения.ВалютаУпрУчетаУстановлена(Истина, ДокументСсылка) Тогда
		Отказ = Истина;
		Возврат ПараметрыПроведения;
	КонецЕсли;

	КурсыВалют = бит_Бюджетирование.КурсыВалютСценария(Реквизиты.Регистратор, 
											Реквизиты.Дата, Новый Структура("Документ, Регл, Упр, Сценарий"));
	
	Реквизиты.Вставить("КурсыВалют", КурсыВалют);
	
	ПриниматьКУчету = Истина;
	ПроводитьПослеУтверждения = ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения");
	Если ПроводитьПослеУтверждения И Реквизиты.РежимПринятияКУчету = 1 Тогда
		ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(ДокументСсылка);
		Если НЕ Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ТекущийСтатус,
					Перечисления.бит_ТипыСтатусовОбъектов.Утвержден) Тогда
			ПриниматьКУчету = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыПроведения.Вставить("ТаблицаСторноДоИзменения", Новый ТаблицаЗначений);
	ПараметрыПроведения.Вставить("ТаблицаОборотыПоБюджетам", Новый ТаблицаЗначений);
	ПараметрыПроведения.Вставить("ВозвратЛимита", Новый ТаблицаЗначений);
	
	ПараметрыНастройки 		= Новый Структура("ЦФО", Реквизиты.ЦФО);
	НеУчитыватьСверхБюджета = бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеОперацииПриКонтролеПоБюджету(ПараметрыНастройки,Реквизиты.Дата);
		
	Запрос.УстановитьПараметр("НеУчитыватьСверхБюджета", НеУчитыватьСверхБюджета);
	Запрос.УстановитьПараметр("СинонимБДДС", 			 НСтр("ru='Данные бюджета';en='Budget Data'"));
	Запрос.УстановитьПараметр("СинонимЗависимыеОбороты", НСтр("ru='Зависимые обороты';en='Dependent Line-Items'"));
	Запрос.УстановитьПараметр("СинонимДоИзменения", 	 НСтр("ru='До изменения';en='before the change'"));
	Запрос.УстановитьПараметр("Сценарий", 				 Реквизиты.Сценарий);
	Запрос.УстановитьПараметр("СценарийЭталон", 		 Реквизиты.СценарийЭталон);
	Запрос.УстановитьПараметр("Валюта", 				 Реквизиты.ВалютаДокумента);
	
	Если Реквизиты.СценарийЭталон = Реквизиты.Сценарий Тогда
		СценарииСовпадают = Истина;
	Иначе	
		СценарииСовпадают = Ложь;
	КонецЕсли;
	
	ИнициализироватьКлючиАналитик(Реквизиты);
	
	НомераТаблиц = Новый Структура(); 
	ТекстЗапроса = ТекстЗапросаВременнаяТаблицаДокумента(НомераТаблиц)
				 + ТекстЗапросаТаблицыВалютногоПерерасчета(НомераТаблиц)
				 + ТекстЗапросаКонтрольИсполненияБюджета(НомераТаблиц, СценарииСовпадают)
				 + ТекстЗапросаТаблицаОборотыПоБюджетам(НомераТаблиц, ПриниматьКУчету)
				 + ТекстЗапросаТаблицаСторноДоИзменения(НомераТаблиц, ПриниматьКУчету, СценарииСовпадают);
				 
	Запрос.Текст = ТекстЗапроса;
	Результат = Запрос.ВыполнитьПакет();
	
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла; 	
	ПараметрыПроведения.Вставить("Реквизиты", Реквизиты);
	
	Если Реквизиты.СторнироватьЗависимыеОбороты И ЗначениеЗаполнено(ПараметрыПроведения.ТаблицаСторноДоИзменения) Тогда
		НаборОбороты = РегистрыНакопления.бит_ОборотыПоБюджетам.СоздатьНаборЗаписей();
		НаборОбороты.Загрузить(ПараметрыПроведения.ТаблицаСторноДоИзменения);
		бит_Бюджетирование.СформироватьЗависимыеОборотыПоНаборуЗаписей(ДокументСсылка, НаборОбороты);
		ПараметрыПроведения.ТаблицаСторноДоИзменения = НаборОбороты.Выгрузить();
	КонецЕсли; 
	
	ПодготовитьТаблицыДокументаРасчетыВВалюте(ПараметрыПроведения, Реквизиты);	
	
	ПодготовитьТаблицуИсполнениеБюджетаРасчетыВВалюте(ПараметрыПроведения.ИсполнениеБюджета, 
		ПараметрыПроведения.ИсполнениеБюджетаРеквизиты);
		
	ПодготовитьТаблицуИсполнениеБюджетаРасчетыВВалюте(ПараметрыПроведения.ВозвратЛимита, 
		ПараметрыПроведения.ИсполнениеБюджетаРеквизиты);	
		
	Возврат ПараметрыПроведения;
	
КонецФункции 

