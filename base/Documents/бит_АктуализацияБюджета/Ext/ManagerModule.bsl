		бит_Бюджетирование.СформироватьПроводкиБюджетирования(ДанныеБюджета,
			Движения.бит_Бюджетирование, Ложь);
	КонецЕсли;
	Движения.бит_Бюджетирование.Записывать = Истина;
	
КонецПроцедуры

// Инициализирует компоновщик, используемый для фильтрации структуры дерева.
// 
Функция ИнициализироватьКомпоновщикСтруктура(Знач ТекстЗапроса, КомпоновщикСтруктура, УникальныйИдентификатор) Экспорт
	
	АдресКомпоновкиСтруктура = "";
	
	ТекстЗапроса = бит_МеханизмПолученияДанных.АдаптироватьТекстПостроителяДляКомпоновки(ТекстЗапроса);
	
	Если НЕ ПустаяСтрока(ТекстЗапроса) Тогда
		
		// Создаем СКД по запросу
		СКД = бит_МеханизмПолученияДанных.СоздатьСхемуКомпоновкиПоЗапросу(ТекстЗапроса);
		// Параметр Бюджет не должен быть доступен в настройках СКД.
		Если Найти(ТекстЗапроса, "&Бюджет") > 0 Тогда
			ПараметрСКД = СКД.Параметры.Добавить();
			ПараметрСКД.Имя						= "Бюджет";
			ПараметрСКД.Заголовок				= НСтр("ru = 'Бюджет'");
			ПараметрСКД.ТипЗначения				= Новый ОписаниеТипов("СправочникСсылка.бит_Бюджеты");
			ПараметрСКД.ВключатьВДоступныеПоля	= Ложь;
			ПараметрСКД.ОграничениеИспользования= Ложь;
			ПараметрСКД.Значение				= Справочники.бит_Бюджеты.ПустаяСсылка();
		КонецЕсли; 

		АдресКомпоновкиСтруктура = ПоместитьВоВременноеХранилище(СКД, УникальныйИдентификатор);
		
		// Инициализируем компоновщик
		ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресКомпоновкиСтруктура);
		Попытка			
			КомпоновщикСтруктура.Инициализировать(ИсточникНастроек);			
		Исключение			
			ТекстСообщения = НСтр("ru='Не удалось инициализировать компоновщик для отбора структуры. Попробуйте обновить текст запроса в настройке формы ввода бюджета.';
								  |en='Failed to initialize builder for the selection of the structure. Try to update the text of the query to set the budget entry form.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);			
		КонецПопытки;
		КомпоновщикСтруктура.ЗагрузитьНастройки(СКД.НастройкиПоУмолчанию);
		
	КонецЕсли; 
	
	Возврат АдресКомпоновкиСтруктура;
	
КонецФункции // ИнициализироватьКомпоновщикСтруктура()

// Функция определяет новый статус объекта.
// Механизм определения статусов может быть переопределен алгоритмами.
//
// Параметры:
//  ТекущийОбъект - ДокументОбъект.бит_ФормаВводаБюджета.
//  ПараметрыУстановкиСтатуса - Структура - состав полей см. в функции бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса.
//
// Возвращаемое значение:
//   СправочникСсылка.бит_СтатусыОбъектов - новый статус объекта.
//
Функция НовыйСтатусОбъекта(ТекущийОбъект, ПараметрыУстановкиСтатуса) Экспорт
	
	Возврат бит_ВизированиеСервер.НовыйСтатусПоСтандартномуАлгоритму(ТекущийОбъект, ПараметрыУстановкиСтатуса);
	
КонецФункции

Функция ДанныеХранилищДокумента(СсылкаНаДокумент) Экспорт
	
	ДанныеХранилищ = Новый Структура;
	ДанныеХранилищ.Вставить("ТабличныйДокумент");
	ДанныеХранилищ.Вставить("НастройкиПостроителя");
	
	РеквизитыОбъекта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДокумент,
						"ХранилищеДерева, НастройкиПостроителя");
	
	ТабличныйДокумент = Неопределено;
	Если РеквизитыОбъекта.ХранилищеДерева <> Неопределено Тогда
		ТабличныйДокумент = РеквизитыОбъекта.ХранилищеДерева.Получить();
	КонецЕсли;
	Если ТипЗнч(ТабличныйДокумент) <> Тип("ТабличныйДокумент") Тогда
		ТабличныйДокумент = Новый ТабличныйДокумент;
	КонецЕсли; 
	ДанныеХранилищ.ТабличныйДокумент = ТабличныйДокумент;
	
	НастройкиПостроителя = Неопределено;
	Если РеквизитыОбъекта.НастройкиПостроителя <> Неопределено Тогда
		НастройкиПостроителя = РеквизитыОбъекта.НастройкиПостроителя.Получить();
	КонецЕсли;
	Если ТипЗнч(НастройкиПостроителя) <> Тип("Структура") Тогда
		НастройкиПостроителя = Новый Структура;
	КонецЕсли; 
	ДанныеХранилищ.НастройкиПостроителя = НастройкиПостроителя;
	
	Возврат ДанныеХранилищ;
	
КонецФункции

// Функция получает текст запроса для получения плановых данных.
// 
// Параметры:
//  ИмяИзмерения - Строка.
// 
// Возвращаемое значение:
//  Строка.
// 
Функция ТекстЗапросаПлановыеДанные(ИмяИзмерения) Экспорт

	ТекстПолей = "";
	Для каждого ТекИзмерение Из Метаданные.РегистрыНакопления.бит_ОборотыПоБюджетам.Измерения Цикл		
		
		ИмяИзмеренияПоле = ТекИзмерение.Имя;
		Если ИмяИзмеренияПоле = "Валюта" Или ИмяИзмеренияПоле = "Сценарий" Или ИмяИзмеренияПоле = "ЦФО" Или ИмяИзмеренияПоле = "СтатьяОборотов"  Тогда
			Продолжить;		
		КонецЕсли;
		
		// Поля запроса
		ТекстПолей = ТекстПолей + Символы.ПС + "	бит_ОборотыПоБюджетамОбороты." + ИмяИзмеренияПоле + ",";
				
	КонецЦикла;
	
	ТекстЗапроса = "
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	бит_ОборотыПоБюджетамОбороты.ПериодМесяц КАК Период,
	|	бит_ОборотыПоБюджетамОбороты." + ИмяИзмерения + " КАК Измерение,
	|	&СценарийАктуализация КАК Сценарий,
	|" + ТекстПолей + "
	|	бит_ОборотыПоБюджетамОбороты.ЦФО,
	|	бит_ОборотыПоБюджетамОбороты.СтатьяОборотов,
	|	бит_ОборотыПоБюджетамОбороты.Валюта,
	|	СУММА(бит_ОборотыПоБюджетамОбороты.КоличествоОборот) КАК Количество,
	|	СУММА(бит_ОборотыПоБюджетамОбороты.КоличествоОборот) КАК КоличествоДоИзменения,
	|	СУММА(бит_ОборотыПоБюджетамОбороты.СуммаОборот) КАК СуммаДоИзменения,
	|	СУММА(бит_ОборотыПоБюджетамОбороты.СуммаРеглОборот) КАК СуммаРеглДоИзменения,
	|	СУММА(бит_ОборотыПоБюджетамОбороты.СуммаУпрОборот) КАК СуммаУпрДоИзменения,
	|	СУММА(бит_ОборотыПоБюджетамОбороты.СуммаСценарийОборот) КАК СуммаСценарийДоИзменения,
	|	СУММА(ВЫБОР
	|			КОГДА бит_ОборотыПоБюджетамОбороты.Сценарий.Валюта <> &ВалютаДокумента
	|				ТОГДА ВЫБОР
	|						КОГДА ЕСТЬNULL(КурсыВалютСрезПоследних.Курс, 0) <> 0
	|							ТОГДА бит_ОборотыПоБюджетамОбороты.СуммаРеглОборот * ЕСТЬNULL(КурсыВалютСрезПоследних.Кратность, 0) / ЕСТЬNULL(КурсыВалютСрезПоследних.Курс, 0)
	|						ИНАЧЕ 0
	|					КОНЕЦ
	|			ИНАЧЕ бит_ОборотыПоБюджетамОбороты.СуммаСценарийОборот
	|		КОНЕЦ) КАК Сумма,
	|	бит_ОборотыПоБюджетамОбороты.СтатьяОборотов.СтавкаНДС КАК СтавкаНДС,
	|	0 КАК НДС
	|ИЗ
	|	РегистрНакопления.бит_ОборотыПоБюджетам.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			Авто,
	|			Сценарий = &Сценарий
	|				И " + ИмяИзмерения + " В (&МассивСсылок)) КАК бит_ОборотыПоБюджетамОбороты,
	|	РегистрСведений.КурсыВалют.СрезПоследних(&ДатаЗапроса, Валюта = &ВалютаДокумента) КАК КурсыВалютСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	бит_ОборотыПоБюджетамОбороты.ПериодМесяц,
	|	бит_ОборотыПоБюджетамОбороты.СтатьяОборотов,
	|	бит_ОборотыПоБюджетамОбороты.Сценарий,
	|	бит_ОборотыПоБюджетамОбороты.ЦФО,
	|" + ТекстПолей + "
	|	бит_ОборотыПоБюджетамОбороты.СтатьяОборотов.СтавкаНДС,
	|	бит_ОборотыПоБюджетамОбороты.СтатьяОборотов,
	|	бит_ОборотыПоБюджетамОбороты.Валюта
	|";
	
	Возврат ТекстЗапроса;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ФормированиеДереваСлужебные

// Функция формирует таблицу с сеткой дат, исходя из даты начала и периодичности.
// 
// Параметры:
//  ДатаНачала     - Дата.
//  Периодичность  - ПеречислениеСсылка.бит_ПериодичностьПланирования.
// 
// Возвращаемое значение:
//   ТаблицаПериоды - ТаблицаЗначений.
// 
Функция СформироватьТаблицуПериодов(ДатаНачала,Периодичность,КоличествоИнтервалов)

	ТаблицаПериоды = Новый ТаблицаЗначений;
	ТаблицаПериоды.Колонки.Добавить("Период", Новый ОписаниеТипов("Дата"));
	Для Сч = 1 По КоличествоИнтервалов Цикл
		ТекущаяДата = бит_ОбщегоНазначенияКлиентСервер.ПолучитьПериодПоСдвигу(ДатаНачала, Сч-1, Периодичность);
		НоваяСтрока = ТаблицаПериоды.Добавить();
		НоваяСтрока.Период = ТекущаяДата;
	КонецЦикла;	

    Возврат ТаблицаПериоды;
	
КонецФункции

// Функция получает фактические данные.
// 
// Параметры:
//  МассивСсылок  - Массив ссылок измерения для фильтрации.
//  ИмяИзмерения  - Строка.
// 
// Возвращаемое значение:
//   Результат   - РезультатЗапроса.
// 
Функция ПолучитьФактическиеДанные(МассивСсылок, ИмяИзмерения, Параметры)

	Периодичность				= Параметры.Периодичность;
	Дата						= Параметры.Дата;
	ДатаАктуализации			= Параметры.ДатаАктуализации;
	ДатаНачалаПланирования		= Параметры.ДатаНачалаПланирования;
	ВалютаДокумента				= Параметры.ВалютаДокумента;
	СценарийФакт				= Параметры.СценарийФакт;
	НастройкиКомпоновщикаДанные = Параметры.НастройкиКомпоновщикаДанные;
	
	ТекстПериодичность = бит_РаботаСМетаданными.ПолучитьИмяЗначенияПеречисления(Перечисления.бит_ПериодичностьПланирования,Периодичность, "Месяц");
	
	// Получаем имя справочника Сценарии бюджетирования в зависимости от текущего решения.
	ИмяСправочникаСценарии = бит_ОбщегоНазначения.ПолучитьИмяСправочникаСценарииБюджетирования();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОборотыПоБюджетам.Период,
	|	ОборотыПоБюджетам."+ИмяИзмерения+" КАК Измерение,
	|	СУММА(ОборотыПоБюджетам.КоличествоОборот) КАК Количество,
	|    СУММА(ВЫБОР
	|		КОГДА ОборотыПоБюджетам.Сценарий.Валюта <> &ВалютаДокумента
	|			ТОГДА ВЫБОР
	|					КОГДА ЕСТЬNULL(КурсыВалютСрезПоследних.Курс, 0) <> 0
	|						ТОГДА ОборотыПоБюджетам.СуммаРеглОборот * ЕСТЬNULL(КурсыВалютСрезПоследних.Кратность, 0) / ЕСТЬNULL(КурсыВалютСрезПоследних.Курс, 0)
	|					ИНАЧЕ 0
	|				КОНЕЦ
	|		ИНАЧЕ ОборотыПоБюджетам.СуммаСценарийОборот
	|	 КОНЕЦ) КАК Сумма
	|    ИЗ
	|	РегистрНакопления.бит_ОборотыПоБюджетам.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			" + ТекстПериодичность + ",
	|			Сценарий = &СценарийФакт
	|				И " + ИмяИзмерения + " В (&МассивСсылок)) КАК ОборотыПоБюджетам,
	|	РегистрСведений.КурсыВалют.СрезПоследних(&ДатаЗапроса, Валюта = &ВалютаДокумента) КАК КурсыВалютСрезПоследних
	|
	|СГРУППИРОВАТЬ ПО
	|	ОборотыПоБюджетам.Период,
	|	ОборотыПоБюджетам." + ИмяИзмерения;
				   
	
	КонецПериода = бит_ОбщегоНазначенияКлиентСервер.ПолучитьКонецПериода(бит_ОбщегоНазначенияКлиентСервер.ПолучитьНачалоПериода(ДатаАктуализации,Периодичность)-1,Периодичность);
	
	Запрос.УстановитьПараметр("МассивСсылок"   , МассивСсылок);		
	Запрос.УстановитьПараметр("НачалоПериода"  , ДатаНачалаПланирования);
	Запрос.УстановитьПараметр("КонецПериода"   , КонецПериода);
	Запрос.УстановитьПараметр("ДатаЗапроса"    , Дата);
	Запрос.УстановитьПараметр("ВалютаДокумента", ВалютаДокумента);
	
	Если ЗначениеЗаполнено(СценарийФакт) Тогда
		Запрос.УстановитьПараметр("СценарийФакт", СценарийФакт);
		
	Иначе
		ИмяСправочникаСценарии = бит_ОбщегоНазначения.ПолучитьИмяСправочникаСценарииБюджетирования();
		Запрос.УстановитьПараметр("СценарийФакт", Справочники[ИмяСправочникаСценарии].ФАКТ);
	КонецЕсли; 
	
	// Применение отбора, настроенного с использованием компоновщика.
	// Отбор устанавливается для запроса на получение плановых данных, 
	// поэтому создадим СКД по запросу для фактических данных.
	// и попробуем скопировать отбор из компоновщика для плановых данных.
	СКД = бит_МеханизмПолученияДанных.СоздатьСхемуКомпоновкиПоЗапросу(Запрос.Текст);
	АдресСКД = ПоместитьВоВременноеХранилище(СКД);
	
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСКД);
	Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
	Компоновщик.Инициализировать(ИсточникНастроек);
	Компоновщик.ЗагрузитьНастройки(СКД.НастройкиПоУмолчанию);
	
	// Копирование отбора.
	Для каждого эоИсточник Из НастройкиКомпоновщикаДанные.Отбор.Элементы Цикл
		ЭлементОтбора = Компоновщик.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЗаполнитьЗначенияСвойств(ЭлементОтбора, эоИсточник);
	КонецЦикла; 
	
	КомпоновщикМакетаКомпоновкиДанных = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетСКД = КомпоновщикМакетаКомпоновкиДанных.Выполнить(СКД, Компоновщик.ПолучитьНастройки());
	
	// Получаем запрос макета компоновки данных.
	Попытка			
		Запрос.Текст = МакетСКД.НаборыДанных.НаборДанныхОсновной.Запрос;			
	Исключение			
		ТекстСообщения = НСтр("ru='Не удалось установить отбор для получения фактических данных.';
								|en='Failed to set the selection for the actual data.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);			
	КонецПопытки;
	
	// Устанавливаем параметры запроса.
	ОписаниеПараметровЗапроса = Запрос.НайтиПараметры();
	Для каждого ОписаниеПараметраЗапроса Из ОписаниеПараметровЗапроса Цикл
		Если НЕ МакетСКД.ЗначенияПараметров.Найти(ОписаниеПараметраЗапроса.Имя) = Неопределено Тогда
			
			Запрос.УстановитьПараметр(ОписаниеПараметраЗапроса.Имя, МакетСКД.ЗначенияПараметров[ОписаниеПараметраЗапроса.Имя].Значение);
			
		КонецЕсли; 
	КонецЦикла;
	
	Результат = Запрос.Выполнить();
	
    Возврат Результат;
	
КонецФункции

// Функция получает плановые данные по бюджету.
// 
// Параметры:
//  МассивСсылок  - Массив ссылок измерения для фильтрации.
//  ИмяИзмерения  - Строка.
// 
// Возвращаемое значение:
//   Результат   - РезультатЗапроса.
// 
Функция ПолучитьПлановыеДанные(МассивСсылок, ИмяИзмерения, Параметры)
	
	Периодичность				= Параметры.Периодичность;
	Дата						= Параметры.Дата;
	ДатаАктуализации			= Параметры.ДатаАктуализации;
	ДатаНачалаПланирования		= Параметры.ДатаНачалаПланирования;
	ДатаОкончанияПланирования	= Параметры.ДатаОкончанияПланирования;
	ВалютаДокумента				= Параметры.ВалютаДокумента;
	СценарийЭталон				= Параметры.СценарийЭталон;
	Сценарий					= Параметры.Сценарий;
	СхемаКомпоновкиДанные		= Параметры.СхемаКомпоновкиДанные;
	НастройкиКомпоновщикаДанные = Параметры.НастройкиКомпоновщикаДанные;
	
	Запрос = Новый Запрос;
	Запрос.Текст = Документы.бит_АктуализацияБюджета.ТекстЗапросаПлановыеДанные(ИмяИзмерения);
	
	ПараметрыСценария		= ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Сценарий, "бит_Периодичность, ПродолжительностьИнтервала");
	Периодичность			= ПараметрыСценария.бит_Периодичность;
	КоличествоИнтервалов	= ПараметрыСценария.ПродолжительностьИнтервала;
	Если ЗначениеЗаполнено(ДатаОкончанияПланирования) Тогда
		ДатаОкончания = ДатаОкончанияПланирования;
	Иначе	
		ДатаОкончания = бит_ОбщегоНазначенияКлиентСервер.ПолучитьПериодПоСдвигу(ДатаНачалаПланирования,КоличествоИнтервалов-1,Периодичность);
	КонецЕсли; 
	
	Запрос.УстановитьПараметр("МассивСсылок",			МассивСсылок);		
	Запрос.УстановитьПараметр("НачалоПериода",			ДатаНачалаПланирования);
	Запрос.УстановитьПараметр("КонецПериода",			ДатаОкончания);
	Запрос.УстановитьПараметр("ДатаЗапроса",			Дата);
	Запрос.УстановитьПараметр("ВалютаДокумента",		ВалютаДокумента);
	Запрос.УстановитьПараметр("Сценарий",				СценарийЭталон);
	Запрос.УстановитьПараметр("СценарийАктуализация",	Сценарий);
	
	// Применение отбора, настроенного с использованием компоновщика.
	КомпоновщикМакетаКомпоновкиДанных = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетСКД = КомпоновщикМакетаКомпоновкиДанных.Выполнить(СхемаКомпоновкиДанные, НастройкиКомпоновщикаДанные);
	
	// Получаем запрос макета компоновки данных.
	Попытка
		Запрос.Текст = МакетСКД.НаборыДанных.НаборДанныхОсновной.Запрос;
	Исключение
		ТекстСообщения = НСтр("ru='Не удалось установить отбор для получения плановых данных.';
								|en='Failed to set the selection for plan data.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;
	
	// Устанавливаем параметры запроса.
	ОписаниеПараметровЗапроса = Запрос.НайтиПараметры();
	Для каждого ОписаниеПараметраЗапроса Из ОписаниеПараметровЗапроса Цикл
		Если НЕ МакетСКД.ЗначенияПараметров.Найти(ОписаниеПараметраЗапроса.Имя) = Неопределено Тогда
			Запрос.УстановитьПараметр(ОписаниеПараметраЗапроса.Имя, МакетСКД.ЗначенияПараметров[ОписаниеПараметраЗапроса.Имя].Значение);
		КонецЕсли; 
	КонецЦикла;
	
	ТекстПериодичность = бит_ОбщегоНазначения.ПолучитьИмяЗначенияПеречисления(Перечисления.бит_ПериодичностьПланирования, Периодичность);
	Если Периодичность <> Перечисления.бит_ПериодичностьПланирования.Месяц Тогда
		ТекстПериодичность = "бит_ОборотыПоБюджетамОбороты.Период" + ТекстПериодичность;
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "бит_ОборотыПоБюджетамОбороты.ПериодМесяц", ТекстПериодичность); 
	КонецЕсли;
	Результат = Запрос.Выполнить();
	
    Возврат Результат;
	
КонецФункции

Функция ВывестиДеревоДанных(Параметры)
	
	ТабДок							= Параметры.ТабДок;
	НастройкаФормы					= Параметры.НастройкаФормы;
	Настройки						= Параметры.Настройки;
	ТекстЗапроса					= Параметры.ТекстЗапроса;
	СхемаКомпоновкиСтруктура		= Параметры.СхемаКомпоновкиСтруктура;
	НастройкиКомпоновщикаСтруктура	= Параметры.НастройкиКомпоновщикаСтруктура;
	
	СтрокаСортировки = "";	
	
	МассивОтбор = Новый Массив;
	
	// Инициализация построителя.
	Запрос = Новый Запрос;
	Запрос.Параметры.Вставить("Бюджет", Настройки.Бюджет);
	Попытка		
		Запрос.Текст = ТекстЗапроса;		
	Исключение		
		ТекстСообщения = НСтр("ru='Неверный текст запроса. Описание ошибки: %1.';
							  |en='Invalid query text. Description of error: %1.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		
	КонецПопытки;
	
	Если НЕ Настройки.ВыводитьКодификатор Тогда
		бит_ОтчетыБФСервер.УдалитьВыбранноеПолеИзВсехНастроекОтчета(НастройкиКомпоновщикаСтруктура, "Кодификатор");
	КонецЕсли;

	Если СхемаКомпоновкиСтруктура.НаборыДанных.Количество() <> 0 Тогда
		
		КомпоновщикМакетаКомпоновкиДанных = Новый КомпоновщикМакетаКомпоновкиДанных;
		МакетСКД = КомпоновщикМакетаКомпоновкиДанных.Выполнить(СхемаКомпоновкиСтруктура, НастройкиКомпоновщикаСтруктура);
		
		// Получаем запрос макета компоновки данных.
		Попытка				
			Запрос.Текст = МакетСКД.НаборыДанных.НаборДанныхОсновной.Запрос;				
		Исключение				
			ТекстСообщения = НСтр("ru='Не удалось установить отбор для получения структуры.';
									|en='Failed to set the selection for the structure.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);				
		КонецПопытки;
		
		// Устанавливаем параметры запроса.
		ОписаниеПараметровЗапроса = Запрос.НайтиПараметры();
		Для каждого ОписаниеПараметраЗапроса Из ОписаниеПараметровЗапроса Цикл				
			Если МакетСКД.ЗначенияПараметров.Найти(ОписаниеПараметраЗапроса.Имя) <> Неопределено Тогда					
				Запрос.УстановитьПараметр(ОписаниеПараметраЗапроса.Имя, МакетСКД.ЗначенияПараметров[ОписаниеПараметраЗапроса.Имя].Значение);					
			КонецЕсли;				
		КонецЦикла;			
		
	КонецЕсли; 
	
	
	// Формируем строку сортировки.
	СохраненнаяНастройка = Справочники.бит_ЭлементыДанных.ПолучитьНастройкиПостроителя(НастройкаФормы);
	Если СохраненнаяНастройка.Свойство("НастройкиКомпоновщика") 
		И ТипЗнч(СохраненнаяНастройка.НастройкиКомпоновщика) = Тип("НастройкиКомпоновкиДанных")  Тогда
		
		Для каждого ЭлПорядка Из СохраненнаяНастройка.НастройкиКомпоновщика.Порядок.Элементы Цикл
			
			Если ЭлПорядка.Использование = Истина И НЕ Строка(ЭлПорядка.Поле) = "" Тогда
				
				НаправлениеСтр = ?(ЭлПорядка.ТипУпорядочивания = НаправлениеСортировкиКомпоновкиДанных.Убыв, "УБЫВ", "ВОЗР"); 
				СтрокаСортировки = СтрокаСортировки+?(ПустаяСтрока(СтрокаСортировки),"",",")+Строка(ЭлПорядка.Поле)+" "+НаправлениеСтр;
				
			КонецЕсли; 
			
		КонецЦикла; 
		
	КонецЕсли; 
	
	// Установка отбора под владельцу дополнительных аналитик при необходимости.
	НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");	
	ИзмеренияРазворачивать = Настройки.СпособыЗаполнения[Перечисления.бит_СпособыЗаполненияИзмеренийВФормахВвода.Разворачивать];
	Для каждого Имя Из ИзмеренияРазворачивать Цикл
	
		ТекущаяНастройка = НастройкиИзмерений[Имя];
		
		Если НЕ ТекущаяНастройка = Неопределено 
			 И ТекущаяНастройка.ТипЗначения.СодержитТип(Тип("СправочникСсылка.бит_ДополнительныеЗначенияАналитик")) Тогда
		
			 Запрос.УстановитьПараметр(Имя, ТекущаяНастройка.Аналитика);
		
		КонецЕсли; 
	
	КонецЦикла; 	
	
	Попытка		
		Результат = Запрос.Выполнить();		
	Исключение		
		ТекстСообщения = НСтр("ru='Не удалось заполнить дерево данных. Описание ошибки: %1.';
							  |en='Unable to complete the data tree. Description of error: %1.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат МассивОтбор;		
	КонецПопытки;
	
	РезДерево = Результат.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	ЭтоНовыйЗапрос = ?(РезДерево.Колонки.Найти("Ссылка") = Неопределено, Истина, Ложь);
	
	// Получение областей, необходимых для вывода.
	Макет = Документы.бит_АктуализацияБюджета.ПолучитьМакет("Макет");	
	Области = Новый Структура;
	Области.Вставить("Заголовок_Кодификатор",Макет.ПолучитьОбласть("Заголовок|Кодификатор"));
	Области.Вставить("Заголовок_Измерение"  ,Макет.ПолучитьОбласть("Заголовок|Измерение"));
	Области.Вставить("Заголовок_Поле"       ,Макет.ПолучитьОбласть("Заголовок|Поле"));
	Области.Вставить("Заголовок_ПолеДубль"  ,Макет.ПолучитьОбласть("Заголовок|ПолеДубль"));
	Области.Вставить("Строка_Кодификатор"   ,Макет.ПолучитьОбласть("Строка|Кодификатор"));
	Области.Вставить("Строка_Измерение"     ,Макет.ПолучитьОбласть("Строка|Измерение"));
	Области.Вставить("Строка_ПолеКоличество",Макет.ПолучитьОбласть("Строка|ПолеКоличество"));
	Области.Вставить("Строка_ПолеСумма"     ,Макет.ПолучитьОбласть("Строка|ПолеСумма"));
	Области.Вставить("Строка_ПолеДубль"     ,Макет.ПолучитьОбласть("Строка|ПолеДубль"));
	Области.Вставить("СтрокаРасчетная_ПолеКоличество", Макет.ПолучитьОбласть("СтрокаРасчетная|ПолеКоличество"));
	Области.Вставить("СтрокаРасчетная_ПолеСумма"     , Макет.ПолучитьОбласть("СтрокаРасчетная|ПолеСумма"));
	Области.Вставить("СтрокаРасчетная_ПолеДубль", Макет.ПолучитьОбласть("СтрокаРасчетная|ПолеДубль"));
	
	ЭтоНастройкаПоБюджету   = ?(ЗначениеЗаполнено(Настройки.Бюджет), Истина, Ложь);
	ИспользоватьКоэффициенты = ?(ЭтоНастройкаПоБюджету И Настройки.ИспользоватьКоэффициентыСтатейБюджета, Истина, Ложь);
	
	Если ИспользоватьКоэффициенты Тогда
		
		// Если используются коэффициенты статей бюджета необходимо установить специальный формат.
		Область = Области.Строка_ПолеСумма.Область(1,1,1,1);
		бит_Бюджетирование.УстановитьФорматОтрицательныхЧисел(Область);
		Область = Области.Строка_ПолеКоличество.Область(1,1,1,1);
		бит_Бюджетирование.УстановитьФорматОтрицательныхЧисел(Область);
		Область = Области.Строка_ПолеДубль.Область(1,1,1,1);
		бит_Бюджетирование.УстановитьФорматОтрицательныхЧисел(Область);
		Область = Области.Строка_ПолеДубль.Область(1,2,1,2);
		бит_Бюджетирование.УстановитьФорматОтрицательныхЧисел(Область);
		
		Область = Области.СтрокаРасчетная_ПолеСумма.Область(1,1,1,1);
		бит_Бюджетирование.УстановитьФорматОтрицательныхЧисел(Область);
		Область = Области.СтрокаРасчетная_ПолеКоличество.Область(1,1,1,1);
		бит_Бюджетирование.УстановитьФорматОтрицательныхЧисел(Область);
		Область = Области.СтрокаРасчетная_ПолеДубль.Область(1,1,1,1);
		бит_Бюджетирование.УстановитьФорматОтрицательныхЧисел(Область);
		Область = Области.СтрокаРасчетная_ПолеДубль.Область(1,2,1,2);
		бит_Бюджетирование.УстановитьФорматОтрицательныхЧисел(Область);
		
	КонецЕсли; 
	
	// Вывод дерева данных.
	Периоды = ВывестиШапку(Области, Параметры);
	
	ТабДок.НачатьАвтогруппировкуСтрок();

	// Сортировка по кодификатору.
	Если ПустаяСтрока(СтрокаСортировки) Тогда
		
		ИзмеренияРазворачивать  = Настройки.СпособыЗаполнения[Перечисления.бит_СпособыЗаполненияИзмеренийВФормахВвода.Разворачивать];
		Если ИзмеренияРазворачивать.Количество() > 1 Тогда
			
			ИмяПервого = ИзмеренияРазворачивать[0];
			ИмяКодификатор = СтрШаблон("%1_Кодификатор", ИмяПервого);
			
			Если РезДерево.Колонки.Найти(ИмяКодификатор) <> Неопределено Тогда				
				СтрокаСортировки = СтрШаблон("%1,%2", ИмяКодификатор, ИмяПервого);				
			КонецЕсли; 
			
		КонецЕсли; 	
		
	КонецЕсли; 
	
	Если НЕ ПустаяСтрока(СтрокаСортировки) Тогда
		
		Попытка			
			РезДерево.Строки.Сортировать(СтрокаСортировки, Истина);			
		Исключение			
			ТекстСообщения = НСтр("ru='Не удалось выполнить сортировку по настройке: %1. Описание ошибки: %2.';
							 	  |en='Unable to sort by setting: %1. Description of the error: %2.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, СтрокаСортировки, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);			
		КонецПопытки;
		
	КонецЕсли; 

	СтатьиБезИтогов = бит_Бюджетирование.СтатьиБезИтогов(Настройки.Бюджет);
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ЭтоНовыйЗапрос",	ЭтоНовыйЗапрос);
	ДопПараметры.Вставить("СтатьиБезИтогов",СтатьиБезИтогов);
	
	ОбойтиДерево(РезДерево, Области, Периоды, 1, Параметры, ДопПараметры);
	ТабДок.ЗакончитьАвтогруппировкуСтрок();
	
	ТабДок.ТолькоПросмотр = Ложь;
	ТабДок.НаправлениеПерехода = ТипНаправленияПереходаТабличногоДокумента.БезПерехода;
	
	ИмяИзмеренияРазворачивать = Настройки.ИмяРазворачивать;
	Если ЭтоНовыйЗапрос Тогда
	   МассивОтбор = Результат.Выгрузить().ВыгрузитьКолонку(ИмяИзмеренияРазворачивать);
	Иначе	
	   МассивОтбор = Результат.Выгрузить().ВыгрузитьКолонку("Ссылка");
    КонецЕсли; 
    бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(МассивОтбор);	
	
	Возврат МассивОтбор;
	
КонецФункции

// Устанавливает значения в дерево из табличных частей БДДС и Фактические данные. 
// 
Процедура УстановитьЗначенияВДерево(ИмяИзмеренияРазворачивать, БДДС, ФактическиеДанные, Параметры)
	
	ТабДок = Параметры.ТабДок;
	
	ОписаниеБулево = Новый ОписаниеТипов("Булево");
	ТабФакт = ФактическиеДанные.Скопировать();
	ТабФакт.Колонки.Добавить("Обработана", ОписаниеБулево);
	ТабДанные = БДДС.Скопировать();
	ТабДанные.Колонки.Добавить("Обработана", ОписаниеБулево);
	
	// Восстанавливаем значения областей по значениям табличной части БДДС.
	Для каждого Обл Из ТабДок.Области Цикл
		
		Если бит_ОбщегоНазначенияКлиентСервер.ПроверитьИмяКласса(Обл.Расшифровка,"РасшифровкаЯчейкиФормыВвода") Тогда
			
			Расшифровка = Обл.Расшифровка;
			Если Расшифровка.Вид = "Значение" Тогда
				
				Если Расшифровка.ПланФакт = "Ф" Тогда
					
					// Факт.
					СтрОтбор = Новый Структура;
					СтрОтбор.Вставить("Период", Расшифровка.Период);
					СтрОтбор.Вставить("Измерение", Расшифровка.Измерения[ИмяИзмеренияРазворачивать]);
					
					МассивСтрок = ТабФакт.НайтиСтроки(СтрОтбор);
					
				Иначе	
					
					// План.
					СтрОтбор = Новый Структура;
					СтрОтбор.Вставить("Период", Расшифровка.Период);
					Для каждого КиЗ Из Расшифровка.Измерения Цикл
						
						СтрОтбор.Вставить(КиЗ.Ключ, КиЗ.Значение);
						
					КонецЦикла; // Обл.Расшифровка.Измерения.
					
					МассивСтрок = ТабДанные.НайтиСтроки(СтрОтбор);
					
				КонецЕсли; // ПланФакт
				
					ИтСумма      = 0;				 
					ИтКоличество = 0;
					Для каждого СтрокаТаблицы Из МассивСтрок Цикл
						
						СтрокаТаблицы.Обработана = Истина;
						ИтСумма      = ИтСумма + СтрокаТаблицы.Сумма;
						ИтКоличество = ИтКоличество + СтрокаТаблицы.Количество;
						
					КонецЦикла; // МассивСтрок
					
					Если Лев(Обл.Имя,1) = "С" Тогда
						
						Обл.Значение = ИтСумма;
						
					КонецЕсли; 
					
					Если Лев(Обл.Имя,1) = "К" Тогда
						
						Обл.Значение = ИтКоличество;
						
					КонецЕсли; 
				
				
			КонецЕсли; // Р.Вид = Значение.
			
		КонецЕсли; // ИмяКласса.
		
	КонецЦикла; // ТабДок.Области.
	
	// Выполнение расчетов по формулам в табличном документе.
	бит_Бюджетирование.ВыполнитьРасчеты(ТабДок);	

КонецПроцедуры

// Осуществляет вывод шапки дерева данных. 
// 
// Параметры:
//  ТабДок - ТабличныйДокумент.
//  Области - Структура - Области макета.
//  НастрФормы - Структура - Настройки формы ввода.
// 
Функция ВывестиШапку(Области, Параметры)
	
	ТабДок						= Параметры.ТабДок;
	Настройки					= Параметры.Настройки;
	Периодичность				= Параметры.Периодичность;
	ПродолжительностьИнтервала	= Параметры.ПродолжительностьИнтервала;
	ДатаНачалаПланирования		= Параметры.ДатаНачалаПланирования;
    ДатаОкончанияПланирования	= Параметры.ДатаОкончанияПланирования;
	
	ВыведеноОбластей = 0;
	// Колонка кодификатор. 
	Если Настройки.ВыводитьКодификатор Тогда
		ТабДок.Вывести(Области.Заголовок_Кодификатор); 
		ВыведеноОбластей = ВыведеноОбластей + 1;
	КонецЕсли;
	
	// Имена измерений.
	Для каждого Имя Из Настройки.СпособыЗаполнения[Перечисления.бит_СпособыЗаполненияИзмеренийВФормахВвода.Разворачивать] Цикл
		
		Если Настройки.ИспользоватьНаименованияСтатейБюджета И Настройки.Измерения[Имя].Имя = "СтатьяОборотов" Тогда
			Области.Заголовок_Измерение.Параметры.ИмяИзмерения = НСтр("ru = 'Статьи бюджета'");
		Иначе	
			Области.Заголовок_Измерение.Параметры.ИмяИзмерения = Настройки.Измерения[Имя].Синоним;
		КонецЕсли;
		
		Если ВыведеноОбластей = 0 Тогда
			ТабДок.Вывести(Области.Заголовок_Измерение); 
			ВыведеноОбластей = ВыведеноОбластей + 1;
		Иначе	
			ТабДок.Присоединить(Области.Заголовок_Измерение);
		КонецЕсли;
	
	КонецЦикла; 
	
	// Фиксация области измерений.
	ТабДок.ФиксацияСверху = 2;
	ТабДок.ФиксацияСлева  = Настройки.КоличествоРазворачивать+1;
	
	// Вывод заголовка периодов
	Если НЕ ЗначениеЗаполнено(ДатаОкончанияПланирования) Тогда
		КоличествоИнтервалов = ПродолжительностьИнтервала;
	Иначе
		КоличествоИнтервалов = бит_ОбщегоНазначенияКлиентСервер.РазностьДат(ДатаНачалаПланирования, ДатаОкончанияПланирования, Периодичность)+1;
	КонецЕсли; 
	
	ИмяОбластиПериод = ?(Настройки.УчетКоличество И Настройки.УчетСумма, "Заголовок_ПолеДубль","Заголовок_Поле");
	
	// Проверим, следует ли создавать дополнительные итоговые колонки.
	ПериодыИтогов = Новый Массив;
	Для каждого СтрНастройки Из Настройки.ДополнительныеИтоги Цикл
		Если Перечисления.бит_ПериодичностьПланирования.Индекс(СтрНастройки.Периодичность) > Перечисления.бит_ПериодичностьПланирования.Индекс(Периодичность) Тогда
			  ПериодыИтогов.Добавить(СтрНастройки);
		КонецЕсли; 
	КонецЦикла; 
	
	// Признак того, что нужно обработать выходные дни.
	НужноОбработатьВыходные = ?(Периодичность = Перечисления.бит_ПериодичностьПланирования.День 
	                          И НЕ Настройки.ОтображениеВыходных = Перечисления.бит_РежимыОтображенияВыходныхДнейФормыВвода.Обычный, Истина, Ложь);
	
							  
    ВыходныеДни = Новый Соответствие;
	Если НужноОбработатьВыходные Тогда
		
		// Получим календарь по которому будем проверять выходные.
		Календарь = бит_НастройкиПрограммы.Календарь(Неопределено, ДатаНачалаПланирования);
		
		Если ЗначениеЗаполнено(Календарь) Тогда
			
			МассивВидов = Новый Массив;
			МассивВидов.Добавить(Перечисления.ВидыДнейПроизводственногоКалендаря.Суббота);
			МассивВидов.Добавить(Перечисления.ВидыДнейПроизводственногоКалендаря.Воскресенье);
			МассивВидов.Добавить(Перечисления.ВидыДнейПроизводственногоКалендаря.Праздник);
			
			ДатаОкончанияКалендаря = бит_ОбщегоНазначенияКлиентСервер.ПолучитьПериодПоСдвигу(ДатаНачалаПланирования,КоличествоИнтервалов,Периодичность);
			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("ПроизводственныйКалендарь",	Календарь);
			Запрос.УстановитьПараметр("ДатаНачала",					ДатаНачалаПланирования);
			Запрос.УстановитьПараметр("ДатаОкончания",				ДатаОкончанияКалендаря);
			Запрос.УстановитьПараметр("МассивВидов",				МассивВидов);
			
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ТабКалендарь.Дата КАК Дата
			|ИЗ
			|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ТабКалендарь
			|ГДЕ
			|	ТабКалендарь.ПроизводственныйКалендарь = &ПроизводственныйКалендарь
			|	И ТабКалендарь.ВидДня В(&МассивВидов)
			|	И ТабКалендарь.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания";
						   
			Результат = Запрос.Выполнить();
			Выборка = Результат.Выбрать();
			
			Пока Выборка.Следующий() Цикл			
				ВыходныеДни.Вставить(Выборка.Дата, Истина);			
			КонецЦикла; 			
			
		Иначе	
			
			НужноОбработатьВыходные = Ложь;
			ТекстСообщения = НСтр("ru='Невозможно определить выходные дни, т.к. не установлен Календарь в настройках программы (БИТ).';
								  |en='It is impossible to define the weekend as Calendar is not set in the program settings (BIT).'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
		КонецЕсли; 
		
	КонецЕсли;// Обработать выходные.						  
							  
	Периоды = Новый Массив;
	НомИт = 1;
	Для й=1 По КоличествоИнтервалов Цикл
	
		ТекущийПериод = бит_ОбщегоНазначенияКлиентСервер.ПолучитьПериодПоСдвигу(ДатаНачалаПланирования,й-1,Периодичность);
		Синоним 	  = бит_ОбщегоНазначения.СформироватьПредставлениеПериода(ТекущийПериод,Периодичность);		
		
		ПараметрыОписанияПериода = бит_Бюджетирование.НовыеПараметрыОписаниеПериода();
		ПараметрыОписанияПериода.Период  = ТекущийПериод;
		ПараметрыОписанияПериода.Синоним = Синоним;
		ТекОписаниеПериода = бит_Бюджетирование.ОписаниеПериода(ПараметрыОписанияПериода);
		
		Если НужноОбработатьВыходные Тогда
			Если ВыходныеДни[ТекущийПериод] = Истина Тогда
				Если Настройки.ОтображениеВыходных = Перечисления.бит_РежимыОтображенияВыходныхДнейФормыВвода.НеОтображать Тогда
					Продолжить;
				КонецЕсли; 
				ТекОписаниеПериода.ЭтоВыходной = Истина;
			КонецЕсли; 
		КонецЕсли; 
		
		
		Периоды.Добавить(ТекОписаниеПериода);
		
		// Добавление дополнительных итоговых колонок по периодам.
		КонецТекПериода = бит_ОбщегоНазначенияКлиентСервер.ПолучитьКонецПериода(ТекущийПериод, Периодичность);		
		Для каждого СтрНастройки Из ПериодыИтогов Цикл
			КонецИтПериода = бит_ОбщегоНазначенияКлиентСервер.ПолучитьКонецПериода(ТекущийПериод, СтрНастройки.Периодичность);
			Если КонецТекПериода = КонецИтПериода Тогда
			
				Синоним = бит_ОбщегоНазначения.СформироватьПредставлениеПериода(ТекущийПериод, СтрНастройки.Периодичность);
				НачалоИтПериода = бит_ОбщегоНазначенияКлиентСервер.ПолучитьНачалоПериода(ТекущийПериод, СтрНастройки.Периодичность);
				
				ПараметрыОписанияПериода = бит_Бюджетирование.НовыеПараметрыОписаниеПериода();
				ПараметрыОписанияПериода.Период  			= НачалоИтПериода;
				ПараметрыОписанияПериода.Синоним 			= Синоним;
				ПараметрыОписанияПериода.Имя 	 			= "Ит_"+Формат(НомИт,"ЧГ=");
				ПараметрыОписанияПериода.ЭтоИтог 			= Истина;
				ПараметрыОписанияПериода.ЭтоНарастающийИтог = СтрНастройки.НарастающийИтог;
				ПараметрыОписанияПериода.КонецПериода 		= КонецИтПериода;
				
				ТекОписаниеПериода = бит_Бюджетирование.ОписаниеПериода(ПараметрыОписанияПериода);
		        Периоды.Добавить(ТекОписаниеПериода);				
				
				НомИт = НомИт + 1;
			КонецЕсли; 
		
		КонецЦикла; // ПериодыИтогов.
		
	КонецЦикла; // По интервалам.

	// Колонки итогов
	Если Настройки.ВыводитьОбщиеИтоги Тогда
		ПараметрыОписанияПериода = бит_Бюджетирование.НовыеПараметрыОписаниеПериода();
		ПараметрыОписанияПериода.Период  			= Дата('00010101');
		ПараметрыОписанияПериода.Синоним 			= НСтр("ru='Итого';en='Total'");
		ПараметрыОписанияПериода.Имя 	 			= "Итог";
		ПараметрыОписанияПериода.ЭтоИтог 			= Истина;

		ТекОписаниеПериода = бит_Бюджетирование.ОписаниеПериода(ПараметрыОписанияПериода);
		Периоды.Добавить(ТекОписаниеПериода);
	КонецЕсли;
	
	Для каждого ТекОписание Из Периоды Цикл
		
		ОбластьПериод = Области[ИмяОбластиПериод];
		
		ОбластьПериод.Параметры.ИмяПоля = ТекОписание.Синоним;
		
		Область = ОбластьПериод.Область(1,1,1,1);
		
		Если ТекОписание.ЭтоВыходной 
			 И Настройки.ОтображениеВыходных = Перечисления.бит_РежимыОтображенияВыходныхДнейФормыВвода.Выделять Тогда
			 Область.ЦветТекста = WebЦвета.Красный;
		Иначе
			 Область.ЦветТекста = WebЦвета.Черный;
		КонецЕсли; 
		
		ТабДок.Присоединить(Области[ИмяОбластиПериод]);
		
	КонецЦикла; 
	
	Возврат Периоды;
	
КонецФункции

// Выводит группировки в дерево данных. 
// 
// Параметры:
//  СтрокаВерх - СтрокаДереваЗначений.
//  Области - Структура.
//  Периоды - Массив.
//  Ном - Число.
//  Параметры - Структура.
//  ДопПараметры - Структура.
// 
Функция ОбойтиДерево(СтрокаВерх, Области, Периоды, Ном, Параметры, ДопПараметры)
	
	ТабДок				= Параметры.ТабДок;
	Настройки			= Параметры.Настройки;
	ДатаАктуализации	= Параметры.ДатаАктуализации;
	
	ИменаЯчеек = Новый Соответствие;
	ИзмеренияРазворачивать  = Настройки.СпособыЗаполнения[Перечисления.бит_СпособыЗаполненияИзмеренийВФормахВвода.Разворачивать];
	КоличествоРазворачивать = Настройки.КоличествоРазворачивать;
	ЭтоНастройкаПоБюджету   = ?(ЗначениеЗаполнено(Настройки.Бюджет), Истина, Ложь);
	ИспользоватьКоэффициенты = ?(ЭтоНастройкаПоБюджету И Настройки.ИспользоватьКоэффициентыСтатейБюджета, Истина, Ложь);
	
	ЦветФактПрошлый = WebЦвета.Белый;
	ЦветНедоступный = WebЦвета.Лимонный;
	
	// Структура для хранения данных, используемых при анализе необходимости объединения ячеек.
	ДанныеВрем = бит_Бюджетирование.КонструкторСтруктурыПроверкиОбъединения(ИзмеренияРазворачивать, Настройки.ВыводитьКодификатор);
	
	Для каждого СтрокаДерева Из СтрокаВерх.Строки Цикл
		
		Уровень = СтрокаДерева.Уровень();
		ЕстьПодчиненныеСтроки = ?(СтрокаДерева.Строки.Количество() > 0, Истина, Ложь);
		// Если настройка не по бюджету, коэффициент всегда 1.
		// Для настройки по бюджету, для групп коэффициент 1, для статей берем указанный в статье.
		Коэффициент = ?(ИспользоватьКоэффициенты, ?(СтрокаДерева.СтатьяБюджета.ЭтоГруппа, 1, СтрокаДерева.СтатьяБюджета.Коэффициент), 1);
		
		// Если нет подчиненных строк - строку, содержащую группы выводить не нужно.
		ЕстьГруппы = Ложь;
		Для каждого Имя Из ИзмеренияРазворачивать Цикл
			Если ДопПараметры.ЭтоНовыйЗапрос Тогда
				// Новый формат запроса может содержать несколько измерений.
				ТекЗначение = СтрокаДерева[Имя];
				Если ЭтоНастройкаПоБюджету И ВРег(Имя) = ВРег("СтатьяОборотов") И НЕ ЗначениеЗаполнено(ТекЗначение) Тогда					
					Если СтрокаДерева.СтатьяБюджета.ЭтоГруппа Тогда
						Если Настройки.ИспользоватьНаименованияСтатейБюджета Тогда
							ТекЗначение = СтрокаДерева.СтатьяБюджета;
						Иначе
							ТекЗначение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаДерева.СтатьяБюджета, "СтатьяОборотов");
							Если НЕ ЗначениеЗаполнено(ТекЗначение) Тогда
								ТекЗначение = СтрокаДерева.СтатьяБюджета;
							КонецЕсли;
						КонецЕсли;
					Иначе	
						ТекЗначение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаДерева.СтатьяБюджета, "СтатьяОборотов");
					КонецЕсли; 
				КонецЕсли; 
			Иначе
				// Формат запроса редакции 2.8 содержал, только одно измерение с именем Ссылка.
				ТекЗначение = СтрокаДерева.Ссылка; 
			КонецЕсли; 
			Если ЗначениеЗаполнено(ТекЗначение) И ТекЗначение.ЭтоГруппа Тогда
				ЕстьГруппы = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;  // По именам измерений.
		
		Если ЕстьГруппы И НЕ ЕстьПодчиненныеСтроки Тогда
			Продолжить;
		КонецЕсли; 
		
		// Если в подчиненных строках только группы - выводить не нужно.
		ТолькоГруппы = Истина;
		бит_Бюджетирование.ПроверитьНаличиеПодчиненныхЭлементов(СтрокаДерева, ИзмеренияРазворачивать, ДопПараметры.ЭтоНовыйЗапрос, ТолькоГруппы); 			
        Если ТолькоГруппы Тогда
			Продолжить;
		КонецЕсли; 
		
		// Измерения.
		ЗначенияИзмерений = Новый Структура;
		ИдИзмерений = "";
		ЕстьГруппа = Ложь;
		Сч = 1;
		Для каждого Имя Из ИзмеренияРазворачивать Цикл
			
			Если Сч = 1 И Настройки.ВыводитьКодификатор Тогда
				// Вывод кодификатора для первого измерения.
				Если ДопПараметры.ЭтоНовыйЗапрос Тогда
					Области.Строка_Кодификатор.Параметры.Кодификатор = СтрокаДерева[Имя+"_Кодификатор"];
				Иначе	
					Области.Строка_Кодификатор.Параметры.Кодификатор = СтрокаДерева.Кодификатор;
				КонецЕсли; 
				ТабДок.Вывести(Области.Строка_Кодификатор, Уровень);
			КонецЕсли; 
			
			// Вывод измерений в макет.
			Если ДопПараметры.ЭтоНовыйЗапрос Тогда
				ТекЗначение = СтрокаДерева[Имя];
				Если НЕ ЗначениеЗаполнено(ТекЗначение) И СтрСравнить(Имя, "СтатьяОборотов") = 0 И ЭтоНастройкаПоБюджету Тогда
					Если СтрокаДерева.СтатьяБюджета.ЭтоГруппа Тогда
						Если Настройки.ИспользоватьНаименованияСтатейБюджета Тогда
							ТекЗначение = СтрокаДерева.СтатьяБюджета;
						Иначе
							ТекЗначение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаДерева.СтатьяБюджета, "СтатьяОборотов");
							Если НЕ ЗначениеЗаполнено(ТекЗначение) Тогда
								ТекЗначение = СтрокаДерева.СтатьяБюджета;
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли; 
			Иначе	
				// Формат запроса редакции 2.8 содержал, только одно измерение с именем Ссылка.
				ТекЗначение = СтрокаДерева.Ссылка; 
			КонецЕсли; 
			
			Если ЗначениеЗаполнено(ТекЗначение) И ТекЗначение.ЭтоГруппа Тогда
				ЕстьГруппа = Истина;
			КонецЕсли;
			
			Если ЭтоНастройкаПоБюджету И Настройки.ИспользоватьНаименованияСтатейБюджета И СтрСравнить(Имя, "СтатьяОборотов") = 0 Тогда
				Области.Строка_Измерение.Параметры.ЗначениеИзмерения = СтрокаДерева.СтатьяБюджета;
			Иначе
				Области.Строка_Измерение.Параметры.ЗначениеИзмерения = ТекЗначение;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ТекЗначение) Тогда
			    ЗначенияИзмерений.Вставить(Имя, ТекЗначение);
				ИдИзмерений = ИдИзмерений+?(ПустаяСтрока(ИдИзмерений),"","_")+СтрЗаменить(Строка(ТекЗначение.УникальныйИдентификатор()),"-","");
			КонецЕсли; 
			
			ИмяЯчейки = Имя+"_"+Формат(Ном,"ЧГ=");
			Обл = Области.Строка_Измерение.Область(1,1,1,1);
			Обл.Имя = Имя+"_"+Формат(Ном,"ЧГ=");
			Области.Строка_Измерение.Параметры.р = бит_Бюджетирование.РасшифровкаЯчейки(ИмяЯчейки, 
														Неопределено, '0001-01-01', "Измерение", "", ТекЗначение); 
														
			Если Сч = 1 И НЕ Настройки.ВыводитьКодификатор Тогда
				ТабДок.Вывести(Области.Строка_Измерение, Уровень);
           	Иначе
				ТабДок.Присоединить(Области.Строка_Измерение, Уровень);			
			КонецЕсли;                                                 
			
			// Объединение ограничено 1 разворотом, чтобы избежать смещения в сетке табличного документа.
			Если Настройки.ОбъединятьЯчейки И Сч = 1 И КоличествоРазворачивать > 1 Тогда
				// Объединяем ячейки с повторяющимися значениями аналитик.
				бит_Бюджетирование.ПроверитьВыполнитьОбъединениеЯчеек(ТабДок, ДанныеВрем, Имя, ТекЗначение, ЕстьПодчиненныеСтроки);
			КонецЕсли; 
			Сч = Сч +1;
		КонецЦикла;  // По именам измерений.
		
		// Ячейки данных.
		ИспользуемДваРесурса = (Настройки.УчетСумма И Настройки.УчетКоличество);
		ИмяСтроки  			 = ?(НЕ ЕстьПодчиненныеСтроки И НЕ ЕстьГруппа , "Строка", "СтрокаРасчетная");
		ИмяКолонки 			 = ?(ИспользуемДваРесурса, "ПолеДубль", ?(Настройки.УчетКоличество,"ПолеКоличество","ПолеСумма"));
		ИмяОбласти 			 = ИмяСтроки+"_"+ИмяКолонки;
		ИмяОбластиИтог 		 = "СтрокаРасчетная_"+ИмяКолонки;
		ВидЯчейки  			 = ?(НЕ ЕстьПодчиненныеСтроки И НЕ ЕстьГруппа , "Значение", "Формула");
		
	    Префиксы = Новый Структура;
		Префиксы.Вставить("ИмяСумма","СП");
		Префиксы.Вставить("ИмяСуммаФакт","СФ");
		Префиксы.Вставить("ИмяКоличество","КП");
		Префиксы.Вставить("ИмяКоличествоФакт","КФ");
		
		Аргументы	= Новый Структура;  // Хранит аргументы для формул.
		Имена		= Новый Структура;  // Хранит имена различных типов ячеек.
		Для каждого КиЗ Из Префиксы Цикл
			Аргументы.Вставить(КиЗ.Значение, Новый Массив);
			Имена.Вставить(КиЗ.Значение, "");
		КонецЦикла; 
		
		Для каждого ТекОписание Из Периоды Цикл
			
			// Определение цвета ячейка фактических данных.
			Если НЕ ТекОписание.ЭтоИтог Тогда
				ЦветЯчейкиФакт = ?(ТекОписание.Период < ДатаАктуализации, ЦветФактПрошлый, ЦветНедоступный);
			Иначе	
				ЦветЯчейкиФакт = ?(ТекОписание.КонецПериода < ДатаАктуализации И ЗначениеЗаполнено(ТекОписание.Период), ЦветФактПрошлый, ЦветНедоступный);
			КонецЕсли; 
			
			// Подготовка имен.
			Для каждого КиЗ Из Префиксы Цикл
				
				ТипИмени = КиЗ.Ключ;
				Префикс  = КиЗ.Значение;
				
				ТекИмяБезАналитики = ТекОписание[ТипИмени];
				ТекИмяЯчейки = ТекОписание[ТипИмени]+"_"+ИдИзмерений;
				Имена[Префикс] = ТекИмяЯчейки;
				Если ИменаЯчеек[ТекИмяБезАналитики] = Неопределено Тогда
					ИменаЯчеек[ТекИмяБезАналитики] = Новый Массив;
				КонецЕсли; 
				
				// Проверка статьи бюджета на флаг "НеВключатьВИтоги".
				Если НЕ ЗначениеЗаполнено(Настройки.Бюджет)
					ИЛИ (ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаДерева, "СтатьяБюджета")
					И ДопПараметры.СтатьиБезИтогов[СтрокаДерева.СтатьяБюджета] = Неопределено) Тогда
					ИменаЯчеек[ТекИмяБезАналитики].Добавить(Новый Структура("Имя, Коэф", Имена[Префикс], Коэффициент));
				КонецЕсли;
				Если НЕ ТекОписание.ЭтоИтог Тогда
					Аргументы[Префикс].Добавить(Имена[Префикс]);
				КонецЕсли;
			
			КонецЦикла; // Префиксы.
			
			Если ИспользуемДваРесурса Тогда
				
				// Форма с двумя ресурсами.
				
				Если ТекОписание.ЭтоИтог Тогда
					
					// Итоговые колонки.
					Обл = Области[ИмяОбластиИтог];
					ПараметрыДоработки = бит_Бюджетирование.НовыеПараметрыДоработкиЯчейки();
					ПараметрыДоработки.ТД 			   = Обл;
