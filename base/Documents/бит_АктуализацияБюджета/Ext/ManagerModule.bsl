		|	ТаблицаДокумента.Количество КАК Количество,
		|	ТаблицаДокумента.Сумма КАК Сумма,
		|	НЕ ТаблицаДокумента.СтатьяОборотов.НеКонтролировать_Сумма КАК КонтролироватьСумму,
		|	НЕ ТаблицаДокумента.СтатьяОборотов.НеКонтролировать_Количество КАК КонтролироватьКоличество,
		|	НЕ ТаблицаДокумента.СтатьяОборотов.НеКонтролировать_Бюджеты КАК КонтролироватьПоСтатье,
		|	ТаблицаДокумента.Аналитика_1 КАК Аналитика_1,
		|	ТаблицаДокумента.Аналитика_2 КАК Аналитика_2,
		|	ТаблицаДокумента.Аналитика_3 КАК Аналитика_3,
		|	ТаблицаДокумента.Аналитика_4 КАК Аналитика_4,
		|	ТаблицаДокумента.Аналитика_5 КАК Аналитика_5,
		|	ТаблицаДокумента.Аналитика_6 КАК Аналитика_6,
		|	ТаблицаДокумента.Аналитика_7 КАК Аналитика_7,
		|	ТаблицаДокумента.Аналитика_8 КАК Аналитика_8,
		|	ТаблицаДокумента.Аналитика_9 КАК Аналитика_9,
		|	ТаблицаДокумента.Аналитика_10 КАК Аналитика_10,
		|	ТаблицаДокумента.Аналитика_11 КАК Аналитика_11,
		|	ТаблицаДокумента.Аналитика_12 КАК Аналитика_12
		|ИЗ
		|	ВременнаяТаблицаДоИзменения КАК ТаблицаДокумента
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_НастройкаКонтроляПоСценариям КАК НастройкаКонтроляПоСценариям
		|		ПО (НастройкаКонтроляПоСценариям.Сценарий = &Сценарий)
		|			И ТаблицаДокумента.Период >= НастройкаКонтроляПоСценариям.Период
		|			И (ТаблицаДокумента.Период <= НастройкаКонтроляПоСценариям.ДатаОкончания
		|				ИЛИ НастройкаКонтроляПоСценариям.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1))
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки";
		
	КонецЕсли;
	
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции

Процедура ПодготовитьТаблицуИсполнениеБюджетаРасчетыВВалюте(ИсполнениеБюджета, ИсполнениеБюджетаРеквизиты)

	Если НЕ ЗначениеЗаполнено(ИсполнениеБюджета) ИЛИ НЕ ЗначениеЗаполнено(ИсполнениеБюджетаРеквизиты) Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты = ИсполнениеБюджетаРеквизиты[0];
	
	КурсВалютыДокумента = Новый Структура;
	КурсВалютыДокумента.Вставить("Валюта", 	  Реквизиты.Валюта);
	КурсВалютыДокумента.Вставить("Курс", 	  Реквизиты.Курс);
	КурсВалютыДокумента.Вставить("Кратность", Реквизиты.Кратность);
	
	КурсВалютыСценария = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Реквизиты.ВалютаСценария, Реквизиты.Дата);
	
	Для каждого СтрокаТаблицы Из ИсполнениеБюджета Цикл
		СтрокаТаблицы.Сумма = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(
								СтрокаТаблицы.Сумма, КурсВалютыДокумента, КурсВалютыСценария);
	КонецЦикла;																	

КонецПроцедуры
 
Процедура ПодготовитьТаблицыДокументаРасчетыВВалюте(ПараметрыПроведения, Реквизиты)

	Если ПараметрыПроведения.ТаблицаОборотыПоБюджетам.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Сценарии		  = ПараметрыПроведения.Сценарии;
	ТаблицаПериодов	  = ПараметрыПроведения.ТаблицаПериодов;
	ОборотыПоБюджетам = ПараметрыПроведения.ТаблицаОборотыПоБюджетам;
	КурсыПоПериодам	  = Неопределено;
	
	Если ТаблицаПериодов.Количество() >= 1000 Тогда
		ТаблицаПериодов.Индексы.Добавить("Сценарий");
	КонецЕсли; 
	
	Если ОборотыПоБюджетам.Количество() >= 1000 Тогда
		ОборотыПоБюджетам.Индексы.Добавить("Сценарий");
	КонецЕсли;

	Если Реквизиты.ИспользоватьКурсыСценария Тогда
		Для каждого СтрокаТаблицы Из Сценарии Цикл
			
			Отбор	= Новый Структура("Сценарий", СтрокаТаблицы.Сценарий);
			Периоды = ТаблицаПериодов.Скопировать(Отбор);
			Валюты  =  бит_Бюджетирование.ЗаполнитьСтруктуруПараметровПолученияКурсовПоПериодам(СтрокаТаблицы.Сценарий, Реквизиты.ВалютаДокумента);
		
			КурсыПоПериодам = бит_КурсыВалют.ПолучитьКурсыВалютПоПериодам(Периоды, Валюты, СтрокаТаблицы.Сценарий);
			
			НайденныеСтроки = ОборотыПоБюджетам.НайтиСтроки(Отбор);
			бит_Бюджетирование.ВыполнитьПересчетыВТаблицеОборотов(НайденныеСтроки, 
								КурсыПоПериодам, Реквизиты.КурсыВалют);

		КонецЦикла; 
	Иначе
		
		бит_Бюджетирование.ВыполнитьПересчетыВТаблицеОборотов(ОборотыПоБюджетам, 
								Неопределено, Реквизиты.КурсыВалют);
	КонецЕсли;
							
КонецПроцедуры

Процедура ИнициализироватьКлючиАналитик(Реквизиты)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Регистратор", Реквизиты.Регистратор);
	Запрос.УстановитьПараметр("Сценарий", 	 Реквизиты.Сценарий);

	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДанныеБюджета.ЦФО КАК ЦФО,
	|	&Сценарий КАК Сценарий
	|ПОМЕСТИТЬ ДанныеБюджета
	|ИЗ
	|	Документ.бит_АктуализацияБюджета.БДДС КАК ДанныеБюджета
	|ГДЕ
	|	ДанныеБюджета.Ссылка = &Регистратор
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗависимыеОбороты.ЦФО,
	|	&Сценарий
	|ИЗ
	|	Документ.бит_АктуализацияБюджета.ЗависимыеОбороты КАК ЗависимыеОбороты
	|ГДЕ
	|	ЗависимыеОбороты.Ссылка = &Регистратор
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДоИзменения.ЦФО,
	|	&Сценарий
	|ИЗ
	|	Документ.бит_АктуализацияБюджета.ДоИзменения КАК ДоИзменения
	|ГДЕ
	|	ДоИзменения.Ссылка = &Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДанныеБюджета.Сценарий КАК Сценарий,
	|	ДанныеБюджета.ЦФО КАК ЦФО
