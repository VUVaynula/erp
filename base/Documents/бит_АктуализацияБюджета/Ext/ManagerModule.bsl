		ИменаПодчиненныхЯчеек = ОбойтиДерево(СтрокаДерева, Области, Периоды, Ном, Параметры, ДопПараметры);
		
		// Установим формулы для вычисления итогов по группам.
		Если ИменаПодчиненныхЯчеек.Количество() > 0 Тогда
