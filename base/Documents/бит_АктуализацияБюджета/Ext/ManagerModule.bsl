// Параметры для функций актуализации данных.
//
// Параметры:
//  АктуализацияБюджета	 - ДокументСсылка, ДокументОбъект	 - Ссылка или объект документа Актуализация бюджета.
//  Настройки			 - Структура						 - Свойства настройки формы ввода бюджета.
// 
// Возвращаемое значение:
//  Структура - Структура аналитик для подстановки в строки БДДС.
//
Функция АналитикиБДДСДляПодстановки(АктуализацияБюджета, Настройки) Экспорт
	
	Результат  = Новый Структура;
	МетаОбъект = Документы.бит_АктуализацияБюджета.ПустаяСсылка().Метаданные();
	ИменаПоУмолчанию = Настройки.СпособыЗаполнения[Перечисления.бит_СпособыЗаполненияИзмеренийВФормахВвода.ПоУмолчанию];
	Для каждого ИмяИзмерения Из Настройки.СпособыЗаполнения[Перечисления.бит_СпособыЗаполненияИзмеренийВФормахВвода.ПоУмолчаниюРедактирование] Цикл
		ИменаПоУмолчанию.Добавить(ИмяИзмерения);
	КонецЦикла;
	
	Если ОбщегоНазначения.ЗначениеСсылочногоТипа(АктуализацияБюджета) Тогда
		Индекс = ИменаПоУмолчанию.ВГраница();
		Пока Индекс >= 0 Цикл
			ТекЗначение = ИменаПоУмолчанию[Индекс];
			Если НЕ бит_РаботаСМетаданными.ЕстьРеквизит(ТекЗначение, МетаОбъект) 
				ИЛИ НЕ бит_РаботаСМетаданными.ЕстьРеквизитТабЧасти(ТекЗначение, МетаОбъект, "БДДС") Тогда
				ИменаПоУмолчанию.Удалить(Индекс);
			КонецЕсли;
			Индекс = Индекс - 1;
		КонецЦикла;
		
		РеквизитыАктуализации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(АктуализацияБюджета, ИменаПоУмолчанию);
		Для каждого Измерение Из РеквизитыАктуализации Цикл
			Если ЗначениеЗаполнено(Измерение.Значение) Тогда
				Результат.Вставить(Измерение.Ключ, Измерение.Значение);
			КонецЕсли;
		КонецЦикла;
	Иначе
		Для каждого ТекЗначение Из ИменаПоУмолчанию Цикл
			Если бит_РаботаСМетаданными.ЕстьРеквизит(ТекЗначение, МетаОбъект) 
				И бит_РаботаСМетаданными.ЕстьРеквизитТабЧасти(ТекЗначение, МетаОбъект,"БДДС") 
				И ЗначениеЗаполнено(АктуализацияБюджета[ТекЗначение]) Тогда
				
				Результат.Вставить(ТекЗначение, АктуализацияБюджета[ТекЗначение]);
			КонецЕсли; 
		КонецЦикла; 	
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

#КонецОбласти

Процедура СформироватьДвиженияОборотыПоБюджетам(ДанныеБюджета, Реквизиты, Движения, Отказ) Экспорт 
	
	Для каждого СтрокаТаблицы Из ДанныеБюджета Цикл
		Движение = Движения.бит_ОборотыПоБюджетам.Добавить();
		ЗаполнитьЗначенияСвойств(Движение, СтрокаТаблицы);
	КонецЦикла; 
	Движения.бит_ОборотыПоБюджетам.Записывать = Истина;
	
КонецПроцедуры

Процедура СформироватьДвиженияБюджетирование(ДанныеБюджета, Реквизиты, Движения, Отказ) Экспорт 
	
