	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаДокумента.ИмяСписка КАК ИмяСписка,
	|	ТаблицаДокумента.СинонимСписка КАК СинонимСписка,
	|	ТаблицаДокумента.НомерТаблицы КАК НомерТаблицы,
