	Если Настройки.ОбъединятьЯчейки Тогда
		// Вызова процедуры объединения для объединения ячеек в случае завершения группировки.
		Сч = 1;
		Для каждого Имя Из ИзмеренияРазворачивать Цикл
			// Объединение ограничено 1 разворотом, чтобы избежать смещения в сетке табличного документа.
			Если Сч = 1 И КоличествоРазворачивать > 1 Тогда
				// Объединяем ячейки с повторяющимися значениями аналитик.
				ЕстьПодчиненныеСтроки = ?(ТипЗнч(СтрокаВерх) = Тип("ДеревоЗначений"), Истина, Ложь);
