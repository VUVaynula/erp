КонецПроцедуры

#КонецОбласти

#Область ОбновленияДерева

// Выполняет обновление дерева данных. 
// 
&НаКлиенте
Процедура ОбновитьДеревоВФоне()
	
	ОчиститьВсе(ЭтотОбъект);
	ДлительнаяОперация = НачатьОбновлениеДерева();
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ОбновитьДеревоЗавершение", ЭтотОбъект);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьСообщения = Истина;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция НачатьОбновлениеДерева()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.ОжидатьЗавершение = 0;

	РеквизитыСценария = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Сценарий, "бит_Периодичность, ПродолжительностьИнтервала");
	Настройки = Справочники.бит_НастройкиФормВводаБюджета.ПодготовитьНастройки(Объект.НастройкаФормы);
	
	НовыеПараметрыДерева = Документы.бит_АктуализацияБюджета.НовыеПараметрыОбновеления();
	ЗаполнитьЗначенияСвойств(НовыеПараметрыДерева, Объект);
	НовыеПараметрыДерева.ТабДок						= Новый ТабличныйДокумент;
	НовыеПараметрыДерева.Настройки					= Настройки;
	НовыеПараметрыДерева.ТекстЗапроса				= ТекстЗапроса;
	
	НовыеПараметрыДерева.СхемаКомпоновкиСтруктура		= ПолучитьИзВременногоХранилища(АдресКомпоновкиСтруктура);
	НовыеПараметрыДерева.НастройкиКомпоновщикаСтруктура	= КомпоновщикСтруктура.ПолучитьНастройки();
	НовыеПараметрыДерева.СхемаКомпоновкиДанные			= ПолучитьИзВременногоХранилища(АдресКомпоновкиДанные);
	НовыеПараметрыДерева.НастройкиКомпоновщикаДанные	= КомпоновщикДанные.ПолучитьНастройки();
	
	НовыеПараметрыДерева.Периодичность				= РеквизитыСценария.бит_Периодичность;
	НовыеПараметрыДерева.ПродолжительностьИнтервала	= РеквизитыСценария.ПродолжительностьИнтервала;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
				"Документы.бит_АктуализацияБюджета.ОбновитьДеревоДанных", НовыеПараметрыДерева);
	
КонецФункции

&НаКлиенте
Процедура ОбновитьДеревоЗавершение(Результат, Контекст) Экспорт
	
	Если Результат = Неопределено Тогда  // Отменено пользователем.
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		ОбновитьДеревоЗавершениеНаСервере(Результат);
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(,Результат.КраткоеПредставлениеОшибки);
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура ОбновитьДеревоЗавершениеНаСервере(Результат)
	
	Если Результат.Свойство("АдресРезультата") И ЗначениеЗаполнено(Результат.АдресРезультата) Тогда
		РезультатВыполнения = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Если РезультатВыполнения = Неопределено Тогда
			ТекстОшибки = НСтр("ru = 'Из временного хранилища не получен результат (получено Неопределено)';
								|en = 'No result received from temporary storage (Received Undefined)'");
			ВызватьИсключение ТекстОшибки;
		КонецЕсли;
		Объект.ФактическиеДанные.Загрузить(РезультатВыполнения.ФактическиеДанные);
		Объект.БДДС.Загрузить(РезультатВыполнения.БДДС);
		Объект.ДоИзменения.Загрузить(РезультатВыполнения.ДоИзменения);
		ТабДокДанные = РезультатВыполнения.ТабДок;
		Объект.АктуализацияВыполнена = Ложь;
		ПослеИзмененияМакета();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ВосстановленияДерева

// Восстанавливает дерево данных по табличным частям. 
// 
&НаКлиенте
Процедура ВосстановитьДеревоВФоне()
	
	ТабДокДанные = Новый ТабличныйДокумент;
	ДлительнаяОперация = НачатьВосстановлениеДерева();
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ВосстановитьДеревоВФонеЗавершение", ЭтотОбъект);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьСообщения = Истина;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция НачатьВосстановлениеДерева()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	РеквизитыСценария = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Сценарий, "бит_Периодичность, ПродолжительностьИнтервала");
	Настройки = Справочники.бит_НастройкиФормВводаБюджета.ПодготовитьНастройки(Объект.НастройкаФормы);
	
	НовыеПараметрыДерева = Документы.бит_АктуализацияБюджета.НовыеПараметрыВосстановления();
	ЗаполнитьЗначенияСвойств(НовыеПараметрыДерева, Объект);
	НовыеПараметрыДерева.ТабДок						= Новый ТабличныйДокумент;
	НовыеПараметрыДерева.Настройки					= Настройки;
	НовыеПараметрыДерева.ТекстЗапроса				= ТекстЗапроса;

	НовыеПараметрыДерева.СхемаКомпоновкиСтруктура		= ПолучитьИзВременногоХранилища(АдресКомпоновкиСтруктура);
	НовыеПараметрыДерева.НастройкиКомпоновщикаСтруктура	= КомпоновщикСтруктура.ПолучитьНастройки();
	
	НовыеПараметрыДерева.Периодичность				= РеквизитыСценария.бит_Периодичность;
	НовыеПараметрыДерева.ПродолжительностьИнтервала	= РеквизитыСценария.ПродолжительностьИнтервала;
	НовыеПараметрыДерева.БДДС						= Объект.БДДС.Выгрузить();
	НовыеПараметрыДерева.ФактическиеДанные			= Объект.ФактическиеДанные.Выгрузить();
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
				"Документы.бит_АктуализацияБюджета.ВосстановитьДеревоПоДанным", НовыеПараметрыДерева);
	
КонецФункции

&НаКлиенте
Процедура ВосстановитьДеревоВФонеЗавершение(Результат, Контекст) Экспорт
	
	Если Результат = Неопределено Тогда  // Отменено пользователем.
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		ВосстановитьДеревоВФонеЗавершениеНаСервере(Результат);
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(,Результат.КраткоеПредставлениеОшибки);
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура ВосстановитьДеревоВФонеЗавершениеНаСервере(Результат)
	
	Если Результат.Свойство("АдресРезультата") И ЗначениеЗаполнено(Результат.АдресРезультата) Тогда
		РезультатВыполнения = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Если РезультатВыполнения = Неопределено Тогда
			ТекстОшибки = НСтр("ru = 'Из временного хранилища не получен результат (получено Неопределено)';
								|en = 'No result received from temporary storage (Received Undefined)'");
			ВызватьИсключение ТекстОшибки;
		КонецЕсли;
		ТабДокДанные = РезультатВыполнения.ТабДок;
		ПослеИзмененияМакета();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьДерево()

	РеквизитыСценария = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Сценарий, "бит_Периодичность, ПродолжительностьИнтервала");
	Настройки = Справочники.бит_НастройкиФормВводаБюджета.ПодготовитьНастройки(Объект.НастройкаФормы);
	
	НовыеПараметрыДерева = Документы.бит_АктуализацияБюджета.НовыеПараметрыВосстановления();
	ЗаполнитьЗначенияСвойств(НовыеПараметрыДерева, Объект);
	НовыеПараметрыДерева.ТабДок						= Новый ТабличныйДокумент;
	НовыеПараметрыДерева.Настройки					= Настройки;
	НовыеПараметрыДерева.ТекстЗапроса				= ТекстЗапроса;

	НовыеПараметрыДерева.СхемаКомпоновкиСтруктура		= ПолучитьИзВременногоХранилища(АдресКомпоновкиСтруктура);
	НовыеПараметрыДерева.НастройкиКомпоновщикаСтруктура	= КомпоновщикСтруктура.ПолучитьНастройки();
	
	НовыеПараметрыДерева.Периодичность				= РеквизитыСценария.бит_Периодичность;
	НовыеПараметрыДерева.ПродолжительностьИнтервала	= РеквизитыСценария.ПродолжительностьИнтервала;
	НовыеПараметрыДерева.БДДС						= Объект.БДДС.Выгрузить();
	НовыеПараметрыДерева.ФактическиеДанные			= Объект.ФактическиеДанные.Выгрузить();
	
	РезультатВыполнения = Документы.бит_АктуализацияБюджета.ВосстановитьДеревоПоДанным(НовыеПараметрыДерева);
	ТабДокДанные = РезультатВыполнения.ТабДок;
	ПослеИзмененияМакета();
	
КонецПроцедуры

#КонецОбласти

#Область Актуализация

&НаКлиенте
Процедура АктуализацияВФоне()
	
	ДлительнаяОперация = НачатьАктуализацию();
	ОповещениеОЗавершении = Новый ОписаниеОповещения("АктуализацияЗавершение", ЭтотОбъект);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьСообщения = Истина;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция НачатьАктуализацию()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.ОжидатьЗавершение = 0;

	РеквизитыСценария = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Сценарий, "бит_Периодичность, ПродолжительностьИнтервала");
	Настройки = Справочники.бит_НастройкиФормВводаБюджета.ПодготовитьНастройки(Объект.НастройкаФормы);
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	ПараметрыАктуализации = Документы.бит_АктуализацияБюджета.НовыеПараметрыАктуализации();
 	ЗаполнитьЗначенияСвойств(ПараметрыАктуализации, Объект, ,"БДДС,ФактическиеДанные");
	АналитикиБДДСДляПодстановки = Документы.бит_АктуализацияБюджета.АналитикиБДДСДляПодстановки(ДокументОбъект, Настройки);
	
	ПараметрыАктуализации.АналитикиБДДСДляПодстановки	= АналитикиБДДСДляПодстановки;
	ПараметрыАктуализации.Настройки						= Настройки;
	ПараметрыАктуализации.Периодичность					= РеквизитыСценария.бит_Периодичность;
	ПараметрыАктуализации.ПродолжительностьИнтервала	= РеквизитыСценария.ПродолжительностьИнтервала;
	ПараметрыАктуализации.БДДС							= Объект.БДДС.Выгрузить();
	ПараметрыАктуализации.ФактическиеДанные				= Объект.ФактическиеДанные.Выгрузить();

	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
				"Документы.бит_АктуализацияБюджета.ВыполнитьАктуализацию", ПараметрыАктуализации);
	
КонецФункции

&НаКлиенте
Процедура АктуализацияЗавершение(Результат, Контекст) Экспорт
	
	Если Результат = Неопределено Тогда  // Отменено пользователем.
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		АктуализацияВФонеЗавершениеНаСервере(Результат);
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(,Результат.КраткоеПредставлениеОшибки);
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура АктуализацияВФонеЗавершениеНаСервере(Результат)
	
	Если Результат.Свойство("АдресРезультата") И ЗначениеЗаполнено(Результат.АдресРезультата) Тогда
		РезультатВыполнения = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Если РезультатВыполнения = Неопределено Тогда
			ТекстОшибки = НСтр("ru = 'Из временного хранилища не получен результат (получено Неопределено)';
								|en = 'No result received from temporary storage (Received Undefined)'");
			ВызватьИсключение ТекстОшибки;
		КонецЕсли;
		Объект.БДДС.Загрузить(РезультатВыполнения.БДДС);
		Объект.АктуализацияВыполнена = Истина;
		Модифицированность = Истина;
		ВосстановитьДерево();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ПослеИзмененияМакета()
	
	Статьи = ИзвлечьСтатьиИзДерева(ТабДокДанные);	
	КэшЗначений.НастройкиСтатей = Новый Соответствие;
	бит_Бюджетирование.ПолучитьНастройкиСтатейОборотов(Статьи, КэшЗначений.НастройкиСтатей);
	ЗависимостиЯчеек = бит_Бюджетирование.ПолучитьЗависимостиЯчеек(ТабДокДанные);	
	УправлениеВидимостьюКолонокТаблиц();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСостояниеДокумента()
	
	СостояниеДокумента = бит_ОбщегоНазначения.СостояниеДокумента(Объект);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ЗависимыеОборотыКомментарийРасчета");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Объект.КурсДокумента", ВидСравненияКомпоновкиДанных.Больше, -1);
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.бит_ЦветГиперссылки);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru='Комментарий расчета';en='Calculation Comments'"));

КонецПроцедуры

&НаСервере
Процедура ОбработкаОповещенияИзмененияСтатуса()
	
	Прочитать();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НеУчитыватьСверхБюджета(ЦФО, Период)

	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("ЦФО", ЦФО);
								
	НеУчитыватьСверхБюджета = бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеОперацииПриКонтролеПоБюджету(
								ПараметрыНастройки, Период);
								
	Возврат НеУчитыватьСверхБюджета;							

КонецФункции

&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	ЗаполнитьКэшЗначений();
	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.ЦФО, Объект.Дата);
	
	ПериодПланирования.ДатаНачала    = Объект.ДатаНачалаПланирования;
	ПериодПланирования.ДатаОкончания = Объект.ДатаОкончанияПланирования;

	ИнициализироватьФорму();

	УстановитьСостояниеДокумента();
	
КонецПроцедуры

&НаСервере
Процедура ЦФОПриИзмененииНаСервере()

	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.ЦФО, Объект.Дата);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ДатаПриИзмененииНаСервере()

	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.ЦФО, Объект.Дата);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры 

// Функция - Реквизиты сценариев
//
// Параметры:
//  Сценарии	 - Массив - Массив из ссылок на сценарии.
//  Реквизиты	 - Массив - Массив из имен реквизитов.
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение - список объектов и значений их реквизитов:
//   * Ключ - ЛюбаяСсылка - ссылка на объект;
//   * Значение - Структура:
//    ** Ключ - Строка - имя реквизита;
//    ** Значение - Произвольный - значение реквизита.
//
&НаСервереБезКонтекста
Функция РеквизитыСценариев(Сценарии, Реквизиты)
	
	Если НЕ ЗначениеЗаполнено(Сценарии) ИЛИ Реквизиты.Количество() = 0 Тогда
		Возврат Новый Соответствие;
	КонецЕсли;
	
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Сценарии, Реквизиты);
	
КонецФункции

#КонецОбласти