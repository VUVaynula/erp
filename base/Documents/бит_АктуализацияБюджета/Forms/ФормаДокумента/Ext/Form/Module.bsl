	Если НЕ ОтменаРедактирования И АктивнаРедактируемаяЯчейка() Тогда
		
		Обл = Элементы.ТабДокДанные.ТекущаяОбласть;
		ОбластьР   = Обл.Расшифровка;
		
		ОбновитьЗначениеЯчейкиДерева(Обл, ОбластьР);
		ОбновитьПарнуюЯчейки(Обл);		
		
	КонецЕсли; 
	
