	КэшЗначений = Новый Структура;
	КэшЗначений.Вставить("ИзмеренияДоп", бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Дополнительные","Синоним"));
	КэшЗначений.Вставить("ИзмеренияВсе", бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("все","синоним"));
	КэшЗначений.Вставить("НастройкиИзмерений" , бит_Бюджетирование.НастройкиИзмеренийБюджетирования()); 
	КэшЗначений.Вставить("НастройкиФормы"     , Справочники.бит_НастройкиФормВводаБюджета.ПодготовитьНастройки(Объект.НастройкаФормы));
	КэшЗначений.Вставить("ТекущийПользователь", Пользователи.ТекущийПользователь());	
	КэшЗначений.Вставить("ВидСравненияРавно"  , ВидСравнения.Равно);
	КэшЗначений.Вставить("ПроводитьПослеУтверждения", ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения"));	
		
	// Параметры, используемые для управления автовидимостью колонок.
	КэшЗначений.Вставить("НастройкаВидимостиКолонок"	 , Новый Структура);
	КэшЗначений.Вставить("МассивСтатей_БДДС"			 , Новый Массив);
	КэшЗначений.Вставить("МассивСтатей_ЗависимыеОбороты", Новый Массив);
	
	КэшЗначений.Вставить("СтруктураДопПолей", Новый Структура("Учет_Сумма, Учет_Количество", "Норма","Норма"));
	
	КэшЗначений.Вставить("НастройкиСтатей", Новый Соответствие);
	
	// Запишем параметр для формирования заголовка.
	КэшЗначений.Вставить("ПредставлениеОбъекта", Объект.Ссылка.Метаданные().ПредставлениеОбъекта);

	КэшЗначений.Вставить("СценарийЭталон", Объект.СценарийЭталон);
	КэшЗначений.Вставить("Сценарий",		Объект.Сценарий);
	
