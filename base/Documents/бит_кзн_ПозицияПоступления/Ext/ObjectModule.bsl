Процедура ЗаполнитьПоОснованию(Основание, ДанныеЗаполнения)

	ИсключаемыеСвойства = "Дата,Номер,Проведен,ПометкаУдаления,ДокументОснование,ДокументПланирования,ВидПлана, ОтправленНаСогласование";
	ЗначенияИсключаемыхСвойств = Новый Структура(ИсключаемыеСвойства);
	ЗаполнитьЗначенияСвойств(ЗначенияИсключаемыхСвойств, ЭтотОбъект);
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Основание);
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения);
	КонецЕсли;
	
	// Восстановим незаполняемые реквизиты.
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ЗначенияИсключаемыхСвойств);
	
	Если ВидПлана = Перечисления.бит_кзн_ВидыПланов.Прогноз Тогда
		ДокументОснование = Основание;
	КонецЕсли;
	
	ТипОснования = ТипЗнч(Основание);
	Если ТипОснования = Тип("ДокументСсылка.бит_кзн_ПозицияПоступления") Тогда
		СтрОплата = Документы.бит_кзн_ПозицияПоступления.ПолучитьОстаток(Основание);		
		СуммаДокумента = СтрОплата.Остаток;
	КонецЕсли; 
	
	ЗначениеСтавки = бит_БухгалтерскийУчет.ПолучитьСтавкуНДС(СтавкаНДС);
	СуммаНДС  	   = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(СуммаДокумента, Истина, Истина, ЗначениеСтавки);
		 
КонецПроцедуры
	
Процедура ЗаполнитьНаОснованииПланируемогоПоступленияДенежныхСредств()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументПланирования);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПланируемыеПоступления.ФормаОплаты КАК ФормаОплаты,
	|	ПланируемыеПоступления.Организация КАК Организация,
	|	ПланируемыеПоступления.Контрагент КАК Контрагент,
	|	ПланируемыеПоступления.ВалютаДокумента КАК ВалютаДокумента,
	|	ПланируемыеПоступления.ДокументОснование КАК ДокументОснование,
	|	ПланируемыеПоступления.ПометкаУдаления КАК ПометкаУдаления
	|ИЗ
	|	Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств КАК ПланируемыеПоступления
	|ГДЕ
	|	ПланируемыеПоступления.Ссылка = &ДокументПланирования";	
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаРеквизиты = РезультатЗапроса.Выбрать();
	ВыборкаРеквизиты.Следующий();
	
	Если ВыборкаРеквизиты.ПометкаУдаления Тогда
		ТекстСообщения = НСтр("ru = 'Выполнить не могу. По причине: Планируемое поступление помеченно на удаление.';
								|en = 'I can''t do it. For the reason: The Planned income is marked for deletion.'");
		ВызватьИсключение ТекстСообщения;	
	КонецЕсли;	
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ВыборкаРеквизиты);
	
	ОснованиеДокументаПланирования = ВыборкаРеквизиты.ДокументОснование;
	Если ТипЗнч(ОснованиеДокументаПланирования) = Тип("ДокументСсылка.СчетНаОплатуКлиенту") Тогда
		ЗначенияРеквизитовЗаполнения = бит_МеханизмДопИзмерений.ЗначенияДополнительныхАналитик(ОснованиеДокументаПланирования,
										"ЦФО, СтатьяОборотов");
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ЗначенияРеквизитовЗаполнения);
	КонецЕсли;

КонецПроцедуры

