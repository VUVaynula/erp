Процедура ИнициализироватьДокумент(ДанныеЗаполнения)
	
	Перем Соглашение;
	
	Если НЕ ЗначениеЗаполнено(Дата) Тогда
		Дата = ТекущаяДатаСеанса();
	КонецЕсли;
	
	ТекущаяДатаПлан = ДатаПлан;
	
	Если НЕ ЗначениеЗаполнено(ДатаПлан) Тогда
		ДатаПлан = Макс(Дата, ТекущаяДатаСеанса());
	Иначе
		ДатаПлан = Макс(ДатаПлан, ТекущаяДатаСеанса());
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВидПлана) Тогда
		ВидПлана = Перечисления.бит_кзн_ВидыПланов.План;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ФормаОплаты) Тогда
		ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(Важность) Тогда
		Важность  = Перечисления.бит_Важность.Средняя;
	КонецЕсли;
	
	Ответственный = Пользователи.ТекущийПользователь();
	
	Инициатор = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
					ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнойИнициаторКазначейства);
	
	Если НЕ ЗначениеЗаполнено(Инициатор) Тогда
		Инициатор = Ответственный;
	КонецЕсли;
	
	РеквизитыДоговора = Новый Структура;
	РеквизитыДоговора.Вставить("БанковскийСчет");
	РеквизитыДоговора.Вставить("БанковскийСчетКонтрагента");
	РеквизитыДоговора.Вставить("бит_ЦФО");
	РеквизитыДоговора.Вставить("бит_ОсновнаяСтатьяОборотов");

	Если ЗначениеЗаполнено(Договор) Тогда
		РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Договор, Новый ФиксированнаяСтруктура(РеквизитыДоговора));	
	КонецЕсли;                                                                                
			
	Если ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
		Если НЕ ЗначениеЗаполнено(БанковскийСчет) Тогда
			Если ЗначениеЗаполнено(Договор) Тогда
				БанковскийСчет = РеквизитыДоговора.БанковскийСчет;
			Иначе	
				БанковскийСчет = Справочники.БанковскиеСчетаОрганизаций.ПолучитьБанковскийСчетОрганизацииПоУмолчанию(
									Организация, ВалютаДокумента);
			КонецЕсли;
		КонецЕсли;	

		Если ЗначениеЗаполнено(БанковскийСчет) Тогда
			РеквизитыБанковскогоСчета = Справочники.БанковскиеСчетаОрганизаций.ПолучитьРеквизитыБанковскогоСчетаОрганизации(БанковскийСчет);
			Если Организация <> РеквизитыБанковскогоСчета.Организация Тогда
				БанковскийСчет = Неопределено;
			Иначе
				Организация 	= РеквизитыБанковскогоСчета.Организация;
				Если ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
					ВалютаДокумента = РеквизитыБанковскогоСчета.Валюта;				
				КонецЕсли;				
			КонецЕсли;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(БанковскийСчетПолучателя) Тогда
			БанковскийСчетПолучателя = РеквизитыДоговора.БанковскийСчетКонтрагента;		
		КонецЕсли;
	Иначе	
		Если НЕ ЗначениеЗаполнено(Касса) Тогда
			Касса = Справочники.Кассы.ПолучитьКассуПоУмолчанию(Организация, ВалютаДокумента);
		КонецЕсли;
		Если ЗначениеЗаполнено(Касса) Тогда
			РеквизитыКассы = Справочники.Кассы.ПолучитьРеквизитыКассы(Касса);
			Если Организация <> РеквизитыКассы.Организация Тогда
				Касса = Неопределено;
			Иначе
				Организация = РеквизитыКассы.Организация;
				Если ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
					ВалютаДокумента = РеквизитыКассы.Валюта;				
				КонецЕсли;				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		Организация = ЗначениеНастроекПовтИсп.ПолучитьОрганизациюПоУмолчанию(Организация);
	КонецЕсли;
			
	Если НЕ ЗначениеЗаполнено(ВалютаДокумента) Тогда
		ВалютаДокумента = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Организация);
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ВалютаВзаиморасчетов) Тогда
		ВалютаВзаиморасчетов = ВалютаДокумента;
		КурсЗнаменательВзаиморасчетов = 1;
		КурсЗнаменательВзаиморасчетов = 1;
		СуммаВзаиморасчетов 		  = СуммаДокумента;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПланированиеСуммы) Тогда		
		ВалютаДенежныхСредств = ВалютаДокумента;
		Если ЗначениеЗаполнено(Касса) Тогда
			ВалютаДенежныхСредств = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Касса, "ВалютаДенежныхСредств");	
		ИначеЕсли ЗначениеЗаполнено(БанковскийСчет) Тогда 	
			ВалютаДенежныхСредств = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БанковскийСчет, "ВалютаДенежныхСредств");	
		КонецЕсли;
		
		Если ВалютаДокумента = ВалютаДенежныхСредств Тогда
			ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа;	
		Иначе
			ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов;	
		КонецЕсли;		
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(СтавкаНДС) И ЗначениеЗаполнено(СтатьяОборотов) Тогда
		СтавкаНДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтатьяОборотов, "СтавкаНДС");	
		Если ЗначениеЗаполнено(СтавкаНДС) И СуммаДокумента <> 0 Тогда
			ЗначениеСтавки = бит_БухгалтерскийУчет.ПолучитьСтавкуНДС(СтавкаНДС);
			СуммаНДС       = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(СуммаДокумента, Истина,
									Истина, ЗначениеСтавки);
		КонецЕсли;
	КонецЕсли; 

	Если ДатаПлан <> ТекущаяДатаПлан ИЛИ ВалютаДокумента <> ВалютаВзаиморасчетов Тогда
		ЗаполнитьКурсВзаиморасчетов(ДатаПлан);
		РассчитатьСуммуВзаиморасчетов();
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДокументПланирования) Тогда
		ДокументПланирования = Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ПустаяСсылка();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтатьяОборотов) Тогда
		ТипСтатьи = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтатьяОборотов, "ТипСтатьи");
	    Если ТипСтатьи <> Перечисления.бит_ТипыСтатейОборотов.БДДС Тогда
			Модуль		    = РегистрыСведений.бит_СоответствияАналитик;
			ВидСоответствия = Справочники.бит_ВидыСоответствийАналитик.СтатьиОборотовБДР_СтатьиОборотовБДДС;
			СтатьяОборотов	= Модуль.ПолучитьПравуюАналитику(ВидСоответствия, СтатьяОборотов, ТекущаяДатаСеанса());
		КонецЕсли;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Договор) 
		И (НЕ ЗначениеЗаполнено(ЦФО) ИЛИ НЕ ЗначениеЗаполнено(СтатьяОборотов)) Тогда		
		Если НЕ ЗначениеЗаполнено(ЦФО) Тогда
			ЦФО = РеквизитыДоговора.бит_ЦФО;	
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(СтатьяОборотов) Тогда
			СтатьяОборотов = РеквизитыДоговора.бит_ОсновнаяСтатьяОборотов;	
		КонецЕсли;		
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ЦФО) ИЛИ НЕ ЗначениеЗаполнено(СтатьяОборотов) Тогда
		Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
			Соглашение = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеЗаполнения, "Соглашение", Неопределено);
		КонецЕсли;                                                 
		
		РеквизитыСоглашения = Новый Структура;
		РеквизитыСоглашения.Вставить("бит_ЦФО");
		РеквизитыСоглашения.Вставить("бит_ОсновнаяСтатьяОборотов");		
		Если ЗначениеЗаполнено(Соглашение) Тогда
			РеквизитыСоглашения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Соглашение, 
									Новый ФиксированнаяСтруктура(РеквизитыСоглашения));				
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ЦФО) Тогда
			ЦФО = РеквизитыСоглашения.бит_ЦФО;	
		КонецЕсли;	
		Если НЕ ЗначениеЗаполнено(СтатьяОборотов) Тогда
			СтатьяОборотов = РеквизитыСоглашения.бит_ОсновнаяСтатьяОборотов;	
		КонецЕсли;								
	КонецЕсли;                                                             
	
	Если НЕ ЗначениеЗаполнено(ЦФО) Тогда
		РезультатПодбора = Новый Массив;
		Если ЗначениеЗаполнено(Подразделение) Тогда
			РезультатПодбора = бит_Бюджетирование.СвязанныеЦФОИПодразделения(Подразделение, 
									ТекущаяДатаСеанса());
		ИначеЕсли ЗначениеЗаполнено(Организация) Тогда
			РезультатПодбора = бит_Бюджетирование.СвязанныеЦФОИПодразделения(Организация, 
									ТекущаяДатаСеанса());
		КонецЕсли;
		Если ЗначениеЗаполнено(РезультатПодбора) Тогда
			ЦФО = РезультатПодбора[0];
		КонецЕсли;								
	КонецЕсли; 

	Если НЕ ЗначениеЗаполнено(ЦФО) Тогда
		ЦФО = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
										ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнойЦФО);	
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СтатьяОборотов) Тогда
		СтатьяОборотов = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
										ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнаяСтатьяПоступлениеБДДС);		
	КонецЕсли; 

	
	// Заполнение реквизитов "Аналитика_n".
	ПараметрыУстановки = бит_МеханизмДопИзмеренийКлиентСервер.ПараметрыУстановкиСвойствАналитикПоШаблону("", 
							"Аналитика_", "СтатьяОборотов");		
	ПараметрыУстановки.ДопРеквизиты.Вставить("Организация", Организация);
	
	РеквизитыОбъекта = Документы.бит_кзн_ПозицияПоступления.РеквизитыОбъектаДляПодстановкиВАналитики(ЭтотОбъект);
	
	Для каждого Значение Из РеквизитыОбъекта Цикл 
		Если ЗначениеЗаполнено(Значение) Тогда
			бит_МеханизмДопИзмерений.ЗаполнитьДопАналитикуПоДаннымДокумента(ЭтотОбъект, Значение, ПараметрыУстановки);	
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

Процедура ОчиститьНеиспользуемыеРеквизиты()
	
	ОплатаЧерезБанк = (ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные);
	Если ОплатаЧерезБанк Тогда
	   	Касса = Справочники.Кассы.ПустаяСсылка();
	Иначе	
	    БанковскийСчет = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Договор) Тогда
		Договор = Неопределено;
	КонецЕсли;
	
	// Очистка разрезов бюджетирования, по которым не ведется учет.
	ПараметрыОбъекта = бит_МеханизмДопИзмерений.ПараметрыОбъектаДляОчисткиНеиспользуемыхРеквизитов();
	ПараметрыОбъекта.СтатьяОборотов = СтатьяОборотов;
	
	ПараметрыОчистки = бит_МеханизмДопИзмерений.ПараметрыОчисткиНеиспользуемыхРеквизитов(ПараметрыОбъекта);
	
	бит_МеханизмДопИзмерений.ОчиститьНеиспользуемыеРеквизитыДанных(ЭтотОбъект, ПараметрыОчистки);
			
КонецПроцедуры

// Процедура выполняет синхронизацию позиции и планируемого поступления, если позиция одна. 
//
Процедура ВыполнитьСинхронизацию(РежимЗаписи)
	
	НеСинхронизировать = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства, "НеСинхронизировать", Ложь);
	
	Если НеСинхронизировать Тогда
		Возврат;
	КонецЕсли;  
	
	РезультатПоиска = Документы.бит_кзн_ПозицияПоступления.НайтиПозициюПоОснованию(ДокументПланирования);
	// Теперь платежные позиции не удаляются непосредственно. Поэтому возникла необходимость
	// анализировать состав и реквизиты свящанных с заявкой документов.
	// Синхронизация выполняется у единственного документа или у последнего непомеченного на удаление,
	// или последнего помечаемого на удаление.
	Если РезультатПоиска.КоличествоПозиций > 1 Тогда
		КоличествоПозиций = 0;
		РеквизитыОбъектов = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(РезультатПоиска.МассивПозиций, "ПометкаУдаления");
		Для каждого КлючЗначение Из РеквизитыОбъектов Цикл
			Если КлючЗначение.Ключ = Ссылка Тогда
				КоличествоПозиций = КоличествоПозиций + 1;
			ИначеЕсли НЕ КлючЗначение.Значение.ПометкаУдаления Тогда 
				КоличествоПозиций = КоличествоПозиций + 1;
			КонецЕсли; 
		КонецЦикла; 
	Иначе
		КоличествоПозиций = 1;
	КонецЕсли;
	
	Если РезультатПоиска.КоличествоПозиций = 1 
		И ТипЗнч(ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств") Тогда
		
		ИменаСинхр = Документы.бит_кзн_ПозицияПоступления.СинхронизируемыйРеквизиты();
		
		ЗаявкаОбъект = ДокументПланирования.ПолучитьОбъект();
		
		// Признак того, что дальнейшая синхронизация не нужна, необходимо, чтобы не было циклических синхронизаций.
		ЗаявкаОбъект.ДополнительныеСвойства.Вставить("НеСинхронизировать", Истина);
		
		// синхронизация пометки удаления
		Если ПометкаУдаления <> ЗаявкаОбъект.ПометкаУдаления Тогда			
			ЗаявкаОбъект.УстановитьПометкуУдаления(ПометкаУдаления);			
		КонецЕсли; 
		
		ЕстьИзменения = Ложь;
		
		// Синхронизация реквизитов.
		Для каждого Имя Из ИменаСинхр Цикл			
			Если ЭтотОбъект[Имя] <> ЗаявкаОбъект[Имя] Тогда				
				ЗаявкаОбъект[Имя] = ЭтотОбъект[Имя];			
				ЕстьИзменения = Истина;				
			КонецЕсли;			
		КонецЦикла; 
		
		// Синхронизируем дату, если ее изменили с помощью механизма изменения доступности элементов.
		Если Дата <> ЗаявкаОбъект.Дата Тогда		
			ЗаявкаОбъект.Дата = Дата;
			ЕстьИзменения = Истина;		
		КонецЕсли; 
		
		ЗаявкаОбъект.ДополнительныеСвойства.Вставить("НеУстанавливатьСтатусПриЗаписи",
													(РежимЗаписи = РежимЗаписиДокумента.Проведение));
													
		НадоЗаписатьВРежиме = Неопределено;
		Если (Проведен И НЕ ЗаявкаОбъект.Проведен) 
			  ИЛИ РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
			НадоЗаписатьВРежиме = РежимЗаписиДокумента.Проведение;
		ИначеЕсли (НЕ Проведен И ЗаявкаОбъект.Проведен) 
			  ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда	
			НадоЗаписатьВРежиме = РежимЗаписиДокумента.ОтменаПроведения;
		ИначеЕсли ЕстьИзменения Тогда
			НадоЗаписатьВРежиме = РежимЗаписиДокумента.Запись;	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НадоЗаписатьВРежиме) Тогда
			ПредставлениеЗаявки = Строка(ДокументПланирования);
			Попытка
				ЗаявкаОбъект.Записать(НадоЗаписатьВРежиме);

				ДополнительныеСвойства.Вставить("УстановитьСтатусДокументаПланированияПриПроведении",
													(РежимЗаписи = РежимЗаписиДокумента.Проведение));
				ДополнительныеСвойства.Вставить("ДополнительныеСвойстваДокументаПланирования",
											ЗаявкаОбъект.ДополнительныеСвойства);
				
			Исключение	
				ТекстСообщения = НСтр("ru = 'Ошибка при записи документа планирования ""%1"" по причине: %2.'; 
										|en = 'Error when writing the planning document ""%1"" for the reason: %2.'");
				ТекстСообщения = СтрШаблон(ТекстСообщения, ПредставлениеЗаявки, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));

				ВызватьИсключение ТекстСообщения;
			КонецПопытки;	
		КонецЕсли;		
	КонецЕсли; 
	
КонецПроцедуры // ВыполнитьСинхронизацию()

// Процедура проверяет наличие у пользователя права проводить заявки
//
// Параметры:
//  Отказ - Булево.
//
Процедура ПроверитьПравоПроведения(Отказ)
	
	Если ТипЗнч(ДокументПланирования) <> Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств")
		И ТипЗнч(ДокументПланирования) <> Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда
	
		ТекПользователь = Пользователи.ТекущийПользователь();
		флРазрешеноПроводить = бит_ПраваДоступа.ПолучитьЗначениеДопПраваПользователя(ТекПользователь, 
			ПланыВидовХарактеристик.бит_ДополнительныеПраваПользователей.РазрешеноПроводитьПланируемыеПоступленияДС);
		
		Если НЕ флРазрешеноПроводить Тогда			
			ТекстСообщения = НСтр("ru='У пользователя отсутствует дополнительное право на проведение планируемых поступлений ДС.';
								  |en='The user has no right to conduct additional DS planned revenues.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);			
		КонецЕсли; 
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура выполняет контроль остатка по прогнозу. 
//
// Параметры:
//  Шапка 			 	- Структура.
//  ШапкаОснование 		- Структура.
//  НастройкиПрограммы  - Соответствие.
//  СтруктураКурсыВалют - Структура.
//
Процедура КонтрольОстатковПоПрогнозу(Шапка, ШапкаОснование, КакКонтролироватьОстатки, Отказ)
	
	// получение остатка по прогнозу
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидПланаПрогноз" , Перечисления.бит_кзн_ВидыПланов.Прогноз);
	Запрос.УстановитьПараметр("Организация"     , ШапкаОснование.Организация);
	Запрос.УстановитьПараметр("ПозицияОснование", ШапкаОснование.Ссылка);
	Запрос.УстановитьПараметр("ДокументПланированияОснование", ШапкаОснование.ДокументПланирования);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОстаткиПрогноз.СуммаОстаток
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Остатки(
	|			,
	|			ВидПлана = &ВидПланаПрогноз
	|				И Организация = &Организация
	|				И Позиция = &ПозицияОснование
	|				И ДокументПланирования = &ДокументПланированияОснование) КАК ОстаткиПрогноз";
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	СуммаОстаток = 0;
	Если Выборка.Следующий() Тогда		
		СуммаОстаток = Выборка.СуммаОстаток;		
	КонецЕсли; 
	
	Если Шапка.ВалютаДокумента = ШапкаОснование.ВалютаДокумента Тогда		
		ТекСумма = Шапка.СуммаДокумента;		
	Иначе		
		// Пересчет суммы текущего документа в валюту прогноза.
		
		// По данным основания.
		БазоваяВалюта   = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(ШапкаОснование.Организация);
		ВалютыДокумента = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ШапкаОснование.Валюта); 

		Если ЗначениеЗаполнено(ШапкаОснование.ОбъектРасчетов) Тогда
			ОбъектыРасчетов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ШапкаОснование.ОбъектРасчетов); 
		Иначе	
			ОбъектыРасчетов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ШапкаОснование.Договор); 
		КонецЕсли;
		
		
		КурсыВалютПрогноза = бит_Казначейство.ПолучитьКурсВалютыПоОбъектамРасчетов(ВалютыДокумента, 
									Шапка.Дата, БазоваяВалюта, ОбъектыРасчетов);
									
		Если НЕ ЗначениеЗаполнено(КурсыВалютПрогноза) Тогда
			ТекстСообщения = НСтр("ru = 'Не удалось получить курс валюты документа ""%1"".';
								|en= 'It was not possible to get the currency exchange rate of the document ""%1""'.");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ШапкаОснование.Позиция);
		    ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ШапкаОснование.Позиция, , ,Отказ);   
			Возврат;
		КонецЕсли;	
		
		// По данным документа.							
		БазоваяВалюта   = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Шапка.Организация);
		ВалютыДокумента = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Шапка.Валюта); 

		Если ЗначениеЗаполнено(Шапка.ОбъектРасчетов) Тогда
			ОбъектыРасчетов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Шапка.ОбъектРасчетов); 
		Иначе	
			ОбъектыРасчетов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Шапка.Договор); 
		КонецЕсли;
		
		КурсыВалютДокумента = бит_Казначейство.ПолучитьКурсВалютыПоОбъектамРасчетов(ВалютыДокумента, 
									Шапка.Дата, БазоваяВалюта, ОбъектыРасчетов);
									
		ТекСумма = РаботаСКурсамивалютУТ.ПересчитатьПоКурсу(Шапка.СуммаДокумента, КурсыВалютДокумента[0], КурсыВалютПрогноза[0]);							

	КонецЕсли; 
	
	// Выполнение контроля.
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Организация", Шапка.Организация);
	СтруктураПараметров.Вставить("ЦФО"		  , Шапка.ЦФО);
	ПроцентПревышения = бит_НастройкиПрограммы.ДопустимыйПроцентПревышенияСуммыПрогнозаПоступления(
							СтруктураПараметров, Шапка.Дата);
							
	СуммаКонтроль = СуммаОстаток*(1+ПроцентПревышения/100) - ТекСумма;
	
	Если СуммаКонтроль < 0 Тогда		
		Отказ = Истина;
		ТекстСообщения = НСтр("ru='Превышена сумма прогноза %1. Остаток по прогнозу: %2, сумма документа %3, не достаточно: %4.';
							  |en='Exceed the sum of the forecast of %1. The residue forecast %2, document amount %3, isn’t sufficient: %4.'");
		ТекстПроцент = ?(ПроцентПревышения = 0, 
						 "", СтрШаблон(НСтр("ru = 'более чем на %1%%'; en = 'more than %1%%'"), Формат(ПроцентПревышения,"ЧЦ=10; ЧДЦ=4")));
		ТекстСообщения = СтрШаблон(ТекстСообщения, ТекстПроцент, 
								   бит_ОбщегоНазначения.ФорматСумм(СуммаОстаток, ШапкаОснование.ВалютаДокумента), 
								   бит_ОбщегоНазначения.ФорматСумм(ТекСумма, ШапкаОснование.ВалютаДокумента), 
								   бит_ОбщегоНазначения.ФорматСумм(-СуммаКонтроль, ШапкаОснование.ВалютаДокумента));		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);	
	КонецЕсли; 
	
КонецПроцедуры

Процедура ЗаполнитьКурсВзаиморасчетов(ДатаЗаполнения)

	// См. форму документа.
	
	ПараметрыЗаполнения = ДенежныеСредстваСервер.ПараметрыЗаполненияКурсаИКратности();

	ПараметрыЗаполнения.Валюта 				 		   = ВалютаДокумента;
	ПараметрыЗаполнения.ВалютаВзаиморасчетов 		   = ВалютаВзаиморасчетов;
	ПараметрыЗаполнения.ОбъектРасчетов		 		   = ОбъектРасчетов;
	ПараметрыЗаполнения.ВалютаРегламентированногоУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	ПараметрыЗаполнения.Дата						   = ДатаЗаполнения;
	
	Если НЕ ЗначениеЗаполнено(ОбъектРасчетов) Тогда
		ПараметрыЗаполнения.Договор = Договор;
	КонецЕсли;	
	
	Данные = Новый Структура;
	Данные.Вставить("КурсЧислительВзаиморасчетов",  0);
	Данные.Вставить("КурсЗнаменательВзаиморасчетов",0);
	Данные.Вставить("ВариантКурсаДоговора", 		Перечисления.ВариантыКурсаДоговора.ПустаяСсылка());
	Данные.Вставить("ТипОбъектаРасчетов", 			Перечисления.ТипыОбъектовРасчетов.ПустаяСсылка());
	
	ЗаполнитьЗначенияСвойств(Данные, ЭтотОбъект);
	
	ДенежныеСредстваСервер.ЗаполнитьКурсИКратностьВСтрокеРасшифровки(Данные, ПараметрыЗаполнения);
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Данные);
	
КонецПроцедуры

Процедура РассчитатьСуммуВзаиморасчетов()
	
	Данные = Новый Структура;
	Данные.Вставить("Сумма", 						 СуммаДокумента);
	Данные.Вставить("КурсЧислительВзаиморасчетов",	 КурсЧислительВзаиморасчетов);
	Данные.Вставить("КурсЗнаменательВзаиморасчетов", КурсЗнаменательВзаиморасчетов);
	Данные.Вставить("СуммаВзаиморасчетов",			 СуммаВзаиморасчетов);
	
	ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
			Данные, ВалютаДокумента, Константы.ВалютаРегламентированногоУчета.Получить());
			
	СуммаВзаиморасчетов = Данные.СуммаВзаиморасчетов; 		
		
КонецПроцедуры

