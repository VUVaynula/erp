// Переопределяет настройки печати для объекта.
//
// Параметры:
//  Настройки - см. УправлениеПечатью.НастройкиПечатиОбъекта.
//
Процедура ПриОпределенииНастроекПечати(Настройки) Экспорт
		
КонецПроцедуры

// Заполняет список команд печати.
//
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.Печать

// Добавляет команду создания документа "Планируемое поступление денежных средств (БИТ)".
//
// Параметры:
//   КомандыСозданияНаОсновании - ТаблицаЗначений - Таблица с командами создания на основании. Для изменения.
//       См. описание 1 параметра процедуры СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании().
//
Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании) Экспорт
	
	Если ПравоДоступа("Добавление", Метаданные.Документы.бит_кзн_ПозицияПоступления) Тогда
		
		КомандаСоздатьНаОсновании = КомандыСозданияНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Менеджер = Метаданные.Документы.бит_кзн_ПозицияПоступления.ПолноеИмя();
		КомандаСоздатьНаОсновании.Представление = ОбщегоНазначенияУТ.ПредставлениеОбъекта(Метаданные.Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств);
		КомандаСоздатьНаОсновании.РежимЗаписи = "Проводить";
		КомандаСоздатьНаОсновании.ФункциональныеОпции = "ИспользоватьОплатуПлатежнымиКартами";

		Возврат КомандаСоздатьНаОсновании;
	КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция ПараметрыВзаиморасчеты(ДанныеЗаполнения = Неопределено) Экспорт
		
	Если ДанныеЗаполнения = Неопределено Тогда
		ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
	Иначе	
		ФормаОплаты = ДанныеЗаполнения.ФормаОплаты;
	КонецЕсли;

	ОплатаЧерезБанк = (ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные);

	Если ДанныеЗаполнения = Неопределено Тогда
		ХозяйственнаяОперация = Неопределено;
		Контрагент			  = Неопределено;
	Иначе
		Если ОбщегоНазначения.ЗначениеСсылочногоТипа(ДанныеЗаполнения) Тогда
			РеквизитыОбъекта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеЗаполнения, 
									"Контрагент"); 
		Иначе
			РеквизитыОбъекта = Новый Структура("Контрагент");
			ЗаполнитьЗначенияСвойств(РеквизитыОбъекта, ДанныеЗаполнения);
		КонецЕсли;
		
		// ++ NB Допущение, что 1 ХО. 
		РеквизитыОбъекта.Вставить("ХозяйственнаяОперация", Перечисления.бит_ВидыОперацийКазначейства.ПоступлениеОплатыОтКлиента);
		
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияУП(РеквизитыОбъекта.ХозяйственнаяОперация);
		Контрагент			  = РеквизитыОбъекта.Контрагент;
	КонецЕсли;

	СтруктураПараметров = ВзаиморасчетыСервер.ПараметрыМеханизма();
	
	Если ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента
		ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзДругойОрганизации Тогда
		СтруктураПараметров.ТипРасчетов                      = Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом;
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствОтПоставщика
		ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствОтДругойОрганизации Тогда
		СтруктураПараметров.ТипРасчетов                      = Перечисления.ТипыРасчетовСПартнерами.РасчетыСПоставщиком;
	КонецЕсли;
	
	СтруктураПараметров.ИзменяетПланОплаты = ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента
										 ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзДругойОрганизации
										 ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствОтПоставщика
										 ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствОтДругойОрганизации;
		
	СтруктураПараметров.ИзменяетПланОтгрузкиПоставки = Ложь;
	
	Если Контрагент = Неопределено Тогда
		СтруктураПараметров.Партнер = "";
	Иначе	
		СтруктураПараметров.Партнер = ДенежныеСредстваСервер.ПолучитьПартнераПоКонтрагенту(
										Контрагент, ХозяйственнаяОперация);
	КонецЕсли;
									
	СтруктураПараметров.ВалютаДокумента			  = "Объект.ВалютаДокумента";
	СтруктураПараметров.ВалютаВзаиморасчетов      = "Объект.ВалютаВзаиморасчетов";
	СтруктураПараметров.КурсЧислитель             = "";
	СтруктураПараметров.КурсЗнаменатель           = "";
	СтруктураПараметров.ПорядокРасчетов           = "";
	СтруктураПараметров.ФормаОплаты               = ?(ОплатаЧерезБанк, Перечисления.ФормыОплаты.Безналичная, Перечисления.ФормыОплаты.Наличная);
	СтруктураПараметров.ОплатаВВалюте             = "";
	СтруктураПараметров.Организация               = "Объект.Организация";
	СтруктураПараметров.Соглашение                = "";
	СтруктураПараметров.Договор                   = "Объект.Договор";
	СтруктураПараметров.БанковскийСчетОрганизации = ?(ОплатаЧерезБанк, "Объект.БанковскийСчет", "");
	СтруктураПараметров.Касса                     = ?(ОплатаЧерезБанк, "", "Объект.Касса");
	СтруктураПараметров.Дата                      = "Объект.Дата";
	
	// Инициализация своего ключа.
	СтруктураПараметров.ЭлементыФормы.Вставить("ОбъектРасчетов", "ОбъектРасчетов");
	
	СтруктураПараметров.ПодборДебиторскойЗадолженности    = Истина;
	СтруктураПараметров.ПодборТолькоБезусловнойЗадолженности = ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствОтПоставщика
									ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствОтДругойОрганизации;

	Возврат СтруктураПараметров;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область ОбновлениеИнформационнойБазы

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьКОбработкеДокументыБезПланированияСуммы(Параметры) Экспорт

	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Дата УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Дата УБЫВ");
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК Реквизиты
	|ГДЕ
	|	Реквизиты.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ПустаяСсылка)";
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));	

КонецПроцедуры

// Обработчик обновления.
// 
// Параметры:
//  Параметры - Структура - параметры.
//
Процедура ОбработатьДокументыБезПланированияСуммыОтложенно(Параметры) Экспорт
	
	МетаданныеОбъекта = ПустаяСсылка().Метаданные();
	ПолноеИмяОбъекта  = МетаданныеОбъекта.ПолноеИмя();
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если НЕ ЗначениеЗаполнено(ОбновляемыеДанные) Тогда
		Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
											Параметры.Очередь, ПолноеИмяОбъекта);
		Возврат;
	КонецЕсли;
	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылки", ОбновляемыеДанные.ВыгрузитьКолонку("Ссылка"));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка,
	|	Реквизиты.ВалютаДокумента КАК ВалютаДокумента,
	|	Реквизиты.УдалитьКратностьДокумента КАК УдалитьКратностьДокумента,
	|	Реквизиты.УдалитьКурсДокумента КАК УдалитьКурсДокумента,
	|	Реквизиты.СуммаДокумента КАК СуммаДокумента,
	|	Реквизиты.ФормаОплаты КАК ФормаОплаты,
	|	ВЫБОР
	|		КОГДА Реквизиты.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа)
	|			ТОГДА Реквизиты.ВалютаДокумента
	|		ИНАЧЕ ВЫБОР
	|				КОГДА Реквизиты.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|					ТОГДА Реквизиты.БанковскийСчет.ВалютаДенежныхСредств
	|				ИНАЧЕ Реквизиты.БанковскийСчет.ВалютаДенежныхСредств
	|			КОНЕЦ
	|	КОНЕЦ КАК ВалютаДенежныхСредств,
	|	ВЫБОР
	|		КОГДА НЕ ОбъектыРасчетов.Ссылка ЕСТЬ NULL
	|			ТОГДА ОбъектыРасчетов.ВалютаВзаиморасчетов
	|		КОГДА НЕ ДоговорыКонтрагентов.Ссылка ЕСТЬ NULL
	|			ТОГДА ДоговорыКонтрагентов.ВалютаВзаиморасчетов
	|		ИНАЧЕ Реквизиты.ВалютаДокумента
	|	КОНЕЦ КАК ВалютаВзаиморасчетов,
	|	Реквизиты.ДатаПлан КАК Период,
	|	Реквизиты.ОбъектРасчетов КАК ОбъектРасчетов,
	|	Реквизиты.Договор КАК Договор
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК Реквизиты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
	|		ПО Реквизиты.ОбъектРасчетов = ОбъектыРасчетов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО Реквизиты.Договор = ДоговорыКонтрагентов.Ссылка
	|ГДЕ
	|	Реквизиты.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ПустаяСсылка)
	|	И Реквизиты.Ссылка В(&Ссылки)";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка 		 = РезультатЗапроса.Выбрать();
	
	ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();

	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			Блокировка.Заблокировать();
			
			ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			Если Выборка.ВалютаДокумента = Выборка.ВалютаВзаиморасчетов Тогда
				ДокументОбъект.ПланированиеСуммы 	= Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов;
				ДокументОбъект.ВалютаВзаиморасчетов = Выборка.ВалютаВзаиморасчетов;
				ДокументОбъект.КурсЧислительВзаиморасчетов   = 1;
				ДокументОбъект.КурсЗнаменательВзаиморасчетов = 1;
				ДокументОбъект.СуммаВзаиморасчетов		   	 = Выборка.СуммаДокумента;
			Иначе
				ДокументОбъект.ПланированиеСуммы 	= Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа;
				ДокументОбъект.ВалютаВзаиморасчетов = Выборка.ВалютаВзаиморасчетов;
				
				// Заполним курс взаиморасчетов.
				ПараметрыЗаполнения = ДенежныеСредстваСервер.ПараметрыЗаполненияКурсаИКратности();
				
				ПараметрыЗаполнения.Валюта 				 = Выборка.ВалютаДокумента;
				ПараметрыЗаполнения.ОбъектРасчетов		 = Выборка.ОбъектРасчетов;
				ПараметрыЗаполнения.Договор				 = Выборка.Договор;
				ПараметрыЗаполнения.ВалютаВзаиморасчетов = Выборка.ВалютаВзаиморасчетов;
				
				ПараметрыЗаполнения.ВалютаРегламентированногоУчета = ВалютаРеглУчета;
				ПараметрыЗаполнения.Дата						   = Выборка.Период;
				
				Данные = Новый Структура;
				Данные.Вставить("КурсЧислительВзаиморасчетов",  0);
				Данные.Вставить("КурсЗнаменательВзаиморасчетов",0);
				Данные.Вставить("ВариантКурсаДоговора", 		Перечисления.ВариантыКурсаДоговора.ПустаяСсылка());
				Данные.Вставить("ТипОбъектаРасчетов", 			Перечисления.ТипыОбъектовРасчетов.ПустаяСсылка());
				
				ДенежныеСредстваСервер.ЗаполнитьКурсИКратностьВСтрокеРасшифровки(Данные, ПараметрыЗаполнения);
				
				ЗаполнитьЗначенияСвойств(ДокументОбъект, Данные);

				// Рассчитаем Сумму взаиморасчетов.
				Данные = Новый Структура;
				Данные.Вставить("Сумма", 						 ДокументОбъект.СуммаДокумента);
				Данные.Вставить("КурсЧислительВзаиморасчетов",	 ДокументОбъект.КурсЧислительВзаиморасчетов);
				Данные.Вставить("КурсЗнаменательВзаиморасчетов", ДокументОбъект.КурсЗнаменательВзаиморасчетов);
				Данные.Вставить("СуммаВзаиморасчетов",			 ДокументОбъект.СуммаВзаиморасчетов);
				
				ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
					Данные, ДокументОбъект.ВалютаДокумента, Константы.ВалютаРегламентированногоУчета.Получить());
				
				ДокументОбъект.СуммаВзаиморасчетов = Данные.СуммаВзаиморасчетов; 		

			КонецЕсли;
			
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			
			ОбъектовОбработано = ОбъектовОбработано + 1;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			бит_ОбновлениеИнформационнойБазыБФ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Выборка.Ссылка);
		КонецПопытки;		
	КонецЦикла;
	
	Если ОбъектовОбработано = 0 И ПроблемныхОбъектов <> 0 Тогда
		ШаблонСообщения = НСтр("ru = 'Не удалось обработать некоторые документы ""Позиция поступления"" (пропущены): %1'; 
								|en = 'Some documents ""Receipt position"" could not be processed (skipped): %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ПроблемныхОбъектов);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация, МетаданныеОбъекта,, ТекстСообщения);
	Иначе
		ШаблонСообщения = НСтр("ru = 'Обработана очередная порция документов ""Позиция поступления"": %1';
								|en = 'The next batch of documents ""Receipt position"" has been processed: %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ОбъектовОбработано);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация,
			МетаданныеОбъекта,, ТекстСообщения);
	КонецЕсли;
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
		Параметры.Очередь, ПолноеИмяОбъекта);

КонецПроцедуры

#КонецОбласти

#Область ВводНаОсновании

Функция ДанныеЗаполненияИзОснования(Основание) Экспорт
	
	// См. бит_КазначействоКлиент.СоздатьПланируемоеПоступлениеСредств().
	
	Если ТипЗнч(Основание) = Тип("Структура") Тогда
		ДокументОснование = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Основание, "Основание",);
		ДопАналитики 	  = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Основание, "ДопАналитики", Новый Структура); 
	Иначе	
		ДокументОснование = Основание;
		ДопАналитики 	  = Новый Структура;
	КонецЕсли;
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		Результат = ДанныеЗаполненияПоЗаказуКлиента(ДокументОснование, ДопАналитики);
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда	
		Результат = ДанныеЗаполненияПоРеализацииТоваровУслуг(ДокументОснование, ДопАналитики);
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.СчетНаОплатуКлиенту") Тогда
		Результат = ДанныеЗаполненияПоСчетуНаОплатуКлиенту(ДокументОснование, ДопАналитики);
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.РеализацияУслугПрочихАктивов") Тогда
		Результат = ДанныеЗаполненияПоРеализацииУслугПрочихАктивов(ДокументОснование, ДопАналитики);
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
		Результат = ДанныеЗаполненияПоАктуВыполненныхРабот(ДокументОснование, ДопАналитики);	
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств") Тогда
		Результат = ДанныеЗаполненияИзПланируемогоПоступления(ДокументОснование);
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда	
		Результат = ДанныеЗаполненияПоЗаявкеНаПеремещение(Основание);	
	Иначе
		Результат = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДокументОснование);
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Функция РеквизитыОбъектаДляПодстановкиВАналитики(Объект) Экспорт
	
	Результат = Новый Массив;
	Результат.Добавить(Объект.Подразделение);
	Результат.Добавить(Объект.Касса);
	Результат.Добавить(Объект.БанковскийСчет);
	Результат.Добавить(Объект.БанковскийСчетПолучателя);
	Результат.Добавить(Объект.ОбъектРасчетов);
	Результат.Добавить(Объект.Контрагент);
	Результат.Добавить(Объект.Договор);
	Результат.Добавить(Объект.Организация);
	Результат.Добавить(Объект.СтатьяОборотов);
		
	Если ЗначениеЗаполнено(Объект.Договор) Тогда
		Проект = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "бит_Проект");
		Результат.Добавить(Проект);
	КонецЕсли;
	
	Возврат Результат;	

КонецФункции

#КонецОбласти

#Область Проведение

Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт

	ПараметрыПроведения = Новый Структура;
	ПараметрыПроведения.Вставить("ПланируемоеПоступлениеСписаниеРеквизиты",	  Новый ТаблицаЗначений);
	ПараметрыПроведения.Вставить("ПланируемоеПоступлениеСписание",			  Новый ТаблицаЗначений);
	ПараметрыПроведения.Вставить("ПланируемоеПоступлениеСписаниеСАналитиками",Новый ТаблицаЗначений);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.ДатаПлан КАК Период,
	|	Реквизиты.Ссылка КАК Ссылка,
	|	Реквизиты.Дата КАК Дата,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.ЦФО КАК ЦФО,
	|	Реквизиты.ДокументОснование КАК ДокументОснование,
	|	Реквизиты.ДокументОснование КАК Прогноз,
	|	Реквизиты.ФормаОплаты КАК ФормаОплаты,
	|	Реквизиты.БанковскийСчет КАК БанковскийСчет,
	|	Реквизиты.ВидПлана КАК ВидПлана,
	|	Реквизиты.ОбъектРасчетов КАК ОбъектРасчетов,
	|	Реквизиты.ВалютаДокумента КАК Валюта,
	|	Реквизиты.СуммаДокумента КАК СуммаДокумента,
	|	Реквизиты.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	Реквизиты.СуммаВзаиморасчетов КАК СуммаВзаиморасчетов,
	|	Реквизиты.КурсЧислительВзаиморасчетов КАК КурсЧислительВзаиморасчетов,
	|	Реквизиты.КурсЗнаменательВзаиморасчетов КАК КурсЗнаменательВзаиморасчетов,
	|	ВЫБОР
	|		КОГДА Реквизиты.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа)
	|			ТОГДА Реквизиты.ВалютаДокумента
	|		ИНАЧЕ ВЫБОР
	|				КОГДА Реквизиты.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|					ТОГДА Реквизиты.БанковскийСчет.ВалютаДенежныхСредств
	|				ИНАЧЕ Реквизиты.Касса.ВалютаДенежныхСредств
	|			КОНЕЦ
	|	КОНЕЦ КАК ВалютаДенежныхСредств,
	|	Реквизиты.Договор КАК Договор
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";
	
	Результат    	 = Запрос.Выполнить();
	ТаблицаРеквизиты = Результат.Выгрузить();
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ТаблицаРеквизиты[0]);
		
	Если НЕ бит_ОбщегоНазначения.ВалютаУпрУчетаУстановлена(Истина, ДокументСсылка) Тогда
		Отказ = Истина;
		Возврат ПараметрыПроведения;
	КонецЕсли;
	
	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("Организация", Реквизиты.Организация);
	ПараметрыНастройки.Вставить("ЦФО",		   Реквизиты.ЦФО);
									
	СписатьПрогноз = ЗначениеЗаполнено(Реквизиты.Прогноз) 
	   			   И ТипЗнч(Реквизиты.ДокументОснование) = Тип("ДокументСсылка.бит_кзн_ПозицияПоступления");

	Реквизиты.Вставить("СписатьПрогноз", СписатьПрогноз);
	Реквизиты.Вставить("ВалютаРегламентированногоУчета", Константы.ВалютаРегламентированногоУчета.Получить());	
	
	ОбъектРасчетов = ?(ЗначениеЗаполнено(Реквизиты.ОбъектРасчетов), Реквизиты.ОбъектРасчетов, Реквизиты.Договор);
	
	Коэффициенты = бит_Казначейство.ПолучитьКоэффициентыПересчетаВалюты(Реквизиты.Валюта,
					Реквизиты.ВалютаДенежныхСредств, Реквизиты.Период, Реквизиты.Организация,,, 
					ОбъектРасчетов);

	Реквизиты.Вставить("КоэффициентПересчетаВВалютуУпр",             Коэффициенты.КоэффициентПересчетаВВалютуУпр);
	Реквизиты.Вставить("КоэффициентПересчетаВВалютуРегл",            Коэффициенты.КоэффициентПересчетаВВалютуРегл);
	Реквизиты.Вставить("КоэффициентПересчетаВВалютуДенежныхСредств", Коэффициенты.КоэффициентПересчетаВВалютуВзаиморасчетов);
			
	ПараметрыПроведения.Вставить("Реквизиты", Реквизиты);
			
	Запрос.УстановитьПараметр("Прогноз", 		Реквизиты.Прогноз);
	Запрос.УстановитьПараметр("СуммаДокумента", Реквизиты.СуммаДокумента);

	НомераТаблиц = Новый Структура;
	Запрос.Текст = ТекстЗапросаПланируемоеПоступлениеСписание(НомераТаблиц, СписатьПрогноз)
				 + ТекстЗапросаПланируемоеПоступлениеПоступление(НомераТаблиц);

	Результат = Запрос.ВыполнитьПакет();
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла;
	
	ПодготовитьРеквизитыПрогноза(ПараметрыПроведения, Реквизиты, Отказ);
	ПодготовитьТаблицыРасчетыВВалюте(ПараметрыПроведения, Реквизиты);
	
	Возврат ПараметрыПроведения;
	
КонецФункции

Процедура СформироватьПланируемоеПоступлениеДенежныхСредств(ТаблицаПланируемоеПоступление, Движения, Отказ) Экспорт

	Если НЕ ЗначениеЗаполнено(ТаблицаПланируемоеПоступление) Тогда
		Возврат;
	КонецЕсли; 	

	НаборЗаписей = Движения.бит_кзн_ПланируемоеПоступлениеДенежныхСредств;
	НаборЗаписей.Записывать = Истина;
	
	Для каждого СтрокаТаблицы Из ТаблицаПланируемоеПоступление Цикл
		Проводка = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(Проводка, СтрокаТаблицы);
	КонецЦикла;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

Процедура СформироватьПланируемоеПоступлениеДенежныхСредствАналитиками(ТаблицаПланируемоеПоступление, Движения, Отказ) Экспорт

	Если НЕ ЗначениеЗаполнено(ТаблицаПланируемоеПоступление) Тогда
		Возврат;
	КонецЕсли; 	

	НаборЗаписей = Движения.бит_кзн_ПланируемоеПоступлениеДенежныхСредствАналитика;
	НаборЗаписей.Записывать = Истина;
	
	Для каждого СтрокаТаблицы Из ТаблицаПланируемоеПоступление Цикл
		Проводка = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(Проводка, СтрокаТаблицы);
	КонецЦикла;
	
КонецПроцедуры
	
#КонецОбласти

Функция НайтиПозициюПоОснованию(ДокументПланирования, БезПомеченныхНаУдаление = Истина) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументПланирования);
	Запрос.УстановитьПараметр("ВсеДокументы", 		  Истина);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	бит_кзн_ПозицияПоступления.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК бит_кзн_ПозицияПоступления
	|ГДЕ
	|	бит_кзн_ПозицияПоступления.ДокументПланирования = &ДокументПланирования
	|	И &ВсеДокументы";
	
	Если БезПомеченныхНаУдаление Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ВсеДокументы", "НЕ ПометкаУдаления");	
	КонецЕсли; 

	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	СвязанныеДокументы = Новый Массив;
	Пока Выборка.Следующий() Цикл
		СвязанныеДокументы.Добавить(Выборка.Ссылка);
	КонецЦикла; 
	
	РезультатПоиска = Новый Структура;
	РезультатПоиска.Вставить("КоличествоПозиций", СвязанныеДокументы.Количество());
	РезультатПоиска.Вставить("МассивПозиций", 	  СвязанныеДокументы);
	РезультатПоиска.Вставить("Позиция", 	  	  Документы.бит_кзн_ПлатежнаяПозиция.ПустаяСсылка());
	
	Если ЗначениеЗаполнено(СвязанныеДокументы) Тогда
		РезультатПоиска.Позиция = СвязанныеДокументы[0];
	КонецЕсли;
	
	Возврат РезультатПоиска;
	
КонецФункции

// Функция возвращает перечень синхронизируемых реквизитов позиции и заявки.
//
// Возвращаемое значение:
//  Массив.
//
Функция СинхронизируемыйРеквизиты() Экспорт

	Имена = Новый Массив;
	
	Имена.Добавить("ВидПлана");
	Имена.Добавить("Организация");
	Имена.Добавить("Контрагент");
	Имена.Добавить("ФормаОплаты");
	Имена.Добавить("ОтправленНаСогласование");	
    Имена.Добавить("НазначениеПлатежа");
	Имена.Добавить("НазначениеПлатежаУпр");
	Имена.Добавить("Инициатор");
	Имена.Добавить("Ответственный");
	Имена.Добавить("ПланированиеСуммы");
	Имена.Добавить("ВалютаДокумента");
	
	Возврат Имена;
	
КонецФункции // СинхронизируемыйРеквизиты()

// Функция получает неоплаченный остаток по позиции поступления.
//
// Параметры:
//  Позиция - ДокументСсылка.бит_кзн_ПозицияПоступления.
//
// Возвращаемое значение:
//  Структура.
//
Функция ПолучитьОстаток(Позиция) Экспорт

	СтрОплата = Новый Структура("План, Факт, Остаток",Позиция.СуммаДокумента, 0, Позиция.СуммаДокумента);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидПлана"            , Позиция.ВидПлана);
	Запрос.УстановитьПараметр("ДокументПланирования", Позиция.ДокументПланирования);
	Запрос.УстановитьПараметр("Организация"         , Позиция.Организация);
	Запрос.УстановитьПараметр("Позиция"             , Позиция);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ЕСТЬNULL(ПлПоступлениеОстаткиОбороты.СуммаКонечныйОстаток, 0)) КАК СуммаОстаток,
	|	СУММА(ЕСТЬNULL(ПлПоступлениеОстаткиОбороты.СуммаПриход, 0)) КАК СуммаПлан,
	|	СУММА(ЕСТЬNULL(ПлПоступлениеОстаткиОбороты.СуммаРасход, 0)) КАК СуммаФакт
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ОстаткиИОбороты(
	|			,
	|			,
	|			,
	|			,
	|			ВидПлана = &ВидПлана
	|				И ДокументПланирования = &ДокументПланирования
	|				И Организация = &Организация
	|				И Позиция = &Позиция) КАК ПлПоступлениеОстаткиОбороты";
				   
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда	
		СтрОплата.План    = Выборка.СуммаПлан;
		СтрОплата.Факт    = Выборка.СуммаФакт;
		СтрОплата.Остаток = Выборка.СуммаОстаток;	
	КонецЕсли; 

	Возврат СтрОплата;
	
КонецФункции // ПолучитьОстаток()

// Функция возвращает массив документ оплаты по позиции.
//
Функция НайтиДокументыОплатыПоПозиции(Позиция) Экспорт
	
	ДокументыОплаты = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	бит_ОтражениеФактаДДС.ДокументОснование КАК ДокументОплаты
	|ИЗ
	|	Документ.бит_ОтражениеФактаДДС КАК бит_ОтражениеФактаДДС
	|ГДЕ
	|	бит_ОтражениеФактаДДС.ФактическиеДанные.Позиция = &Позиция
	|	И бит_ОтражениеФактаДДС.ФактическиеДанные.Позиция <> ЗНАЧЕНИЕ(Документ.бит_кзн_ПозицияПоступления.ПустаяСсылка)";
	Запрос.УстановитьПараметр("Позиция", Позиция);
	Результат = Запрос.Выполнить();

	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		ДокументыОплаты.Добавить(Выборка.ДокументОплаты);
	КонецЦикла;

	Возврат ДокументыОплаты;
	
КонецФункции	

// Функция находит аналитики тип которых совпадает с типом реквизитов позиции.
//
// Параметры: МетаОбъект - ОбъектМетаданных.
//
// Возвращаемое значение:
//  Соответствие.
//
Функция НайтиАналитикиСовпадающиеСРеквизитами(МетаОбъект) Экспорт 

	СовпадающиеАналитики = Новый Соответствие;
	
	МассивТипов = Новый Массив;
	
	Для каждого Реквизит Из МетаОбъект.Реквизиты Цикл	
		Если Найти(Реквизит.Имя, "Аналитика") = 0 Тогда		
			Для каждого ТипРек Из Реквизит.Тип.Типы() Цикл			
				Если НЕ ТипРек = Тип("Булево") И НЕ ТипРек = Тип("Дата") 
				   И НЕ ТипРек = Тип("Строка") И НЕ ТипРек = Тип("Число") Тогда					
					СтрРекв = Новый Структура("Имя, Тип", Реквизит.Имя, ТипРек);
					МассивТипов.Добавить(СтрРекв);				
				КонецЕсли; 			
			КонецЦикла;		
		КонецЕсли;	
	КонецЦикла; 
	
	Настр = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	
	Для каждого Аналит Из Настр Цикл		
		Если НЕ Аналит.Значение.ЭтоСоставнойТип Тогда 		
			Для каждого СтрРекв Из МассивТипов Цикл				
				ТипРек = СтрРекв.Тип;
				Если Аналит.Значение.ТипЗначения.СодержитТип(ТипРек) Тогда 
					СовпадающиеАналитики.Вставить(Аналит.Ключ, СтрРекв.Имя);
					Прервать;
				КонецЕсли;			
			КонецЦикла; 			
		КонецЕсли;				
	КонецЦикла; 
	
	Возврат СовпадающиеАналитики;
	
КонецФункции // НайтиАналитикиСовпадающиеСРеквизитами()

// Функция получает плановую и фактическую сумму оплат по позиции.
//
// Параметры:
//  Позиция	- ДокументСсылка.бит_кзн_ПозицияПоступления - позиция поступления.
// 
// Возвращаемое значение:
//  Структура.
//
Функция СтруктураОплатыПоПозиции(Позиция) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	СтруктураРезультат = Новый Структура;
	СтруктураРезультат.Вставить("СуммаПлан"	 , 0);
	СтруктураРезультат.Вставить("СуммаОплата", 0);
	СтруктураРезультат.Вставить("Разность"	 , 0);
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Позиция", Позиция);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПланируемоеПоступление.СуммаКонечныйОстаток КАК СуммаОстаток,
	|	ПланируемоеПоступление.СуммаПриход КАК СуммаПлан,
	|	ПланируемоеПоступление.СуммаРасход КАК СуммаФакт
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ОстаткиИОбороты(, , , , Позиция = &Позиция) КАК ПланируемоеПоступление";
	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();	
	Если Выборка.Следующий() Тогда		
		СтруктураРезультат.СуммаПлан   = Выборка.СуммаПлан;
		СтруктураРезультат.СуммаОплата = Выборка.СуммаФакт;
		СтруктураРезультат.Разность    = Выборка.СуммаОстаток;		
	КонецЕсли; 

	Возврат СтруктураРезультат;
	
КонецФункции

// Функция определяет новый статус объекта в зависимости от режима записи документа
//и предыдущего статуса. Механизм определения статусов может быть переопределен алгоритмами.
//
// Параметры:
//  ТекущийОбъект - ДокументОбъект.бит_кзн_ПозицияПоступления.
//  ПараметрыУстановкиСтатуса - Структура - состав полей см. в функции бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса.
//
// Возвращаемое значение:
//   НовыйСтатус - СправочникСсылка.бит_СтатусыОбъектов.
//
Функция НовыйСтатусОбъекта(ТекущийОбъект, ПараметрыУстановкиСтатуса) Экспорт
	
	Если ПараметрыУстановкиСтатуса.ПараметрыОплаты = Неопределено Тогда
		СтруктураОплаты = Документы.бит_кзн_ПозицияПоступления.ПолучитьОстаток(ТекущийОбъект.Ссылка);
	Иначе	
		СтруктураОплаты = ПараметрыУстановкиСтатуса.ПараметрыОплаты;
	КонецЕсли;
	
	СсылкаНаОбъект       = ТекущийОбъект.Ссылка;
	ДокументПланирования = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаОбъект, "ДокументПланирования");
	ВизированиеОтключено = бит_ВизированиеСервер.МеханизмВизированияОтключен(ДокументПланирования);
	
	ПроводитьПослеУтверждения = ОбщегоНазначения.ЕстьРеквизитОбъекта("ОтправленНаСогласование", ТекущийОбъект.Метаданные())
									И ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения")
									И НЕ ВизированиеОтключено;
									
	РежимЗаписи = ПараметрыУстановкиСтатуса.РежимЗаписи;
									
	Если ПроводитьПослеУтверждения Тогда
		Если НЕ ТекущийОбъект.ОтправленНаСогласование Тогда
			Возврат Справочники.бит_СтатусыОбъектов.Черновик;
		КонецЕсли;
	ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
		ИЛИ (РежимЗаписи = РежимЗаписиДокумента.Запись И НЕ ТекущийОбъект.Проведен И НЕ ТекущийОбъект.ОтправленНаСогласование) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Черновик;
	КонецЕсли;
	
	Если бит_ВизированиеСервер.ЕстьБлокирующиеРешения(ДокументПланирования) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Отклонен;
	ИначеЕсли СтруктураОплаты.Остаток <= 0.01 И СтруктураОплаты.Факт > 0 Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Оплачен;
	ИначеЕсли СтруктураОплаты.Факт > 0 Тогда
		Возврат Справочники.бит_СтатусыОбъектов.ЧастичноОплачен;
	ИначеЕсли РегистрыСведений.бит_РеестрыПлатежей.ПозицияВключенаВРеестр(СсылкаНаОбъект) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Заявка_ВРеестре;
	ИначеЕсли ВизированиеОтключено Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Рабочий;
	ИначеЕсли бит_ВизированиеСервер.ВсеВизыСогласованы(ДокументПланирования) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Утвержден;
	КонецЕсли;
	
	Возврат Справочники.бит_СтатусыОбъектов.НаСогласовании;
	
КонецФункции

// Фукнция выполняет поиск значения Подразденеия из доступных дополнительных измерений с соответствующим типом.
//
// Параметры:
