	ДанныеЗаполнения.Вставить("НазначениеПлатежа");
	ДанныеЗаполнения.Вставить("НазначениеПлатежаУпр");
	ДанныеЗаполнения.Вставить("ФормаОплаты");
	ДанныеЗаполнения.Вставить("ДатаПлан");
	ДанныеЗаполнения.Вставить("ВидПлана");
	ДанныеЗаполнения.Вставить("БанковскийСчет");
	ДанныеЗаполнения.Вставить("БанковскийСчетПолучателя");
