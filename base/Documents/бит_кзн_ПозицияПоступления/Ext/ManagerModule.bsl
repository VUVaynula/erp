	Подразделение = Справочники.СтруктураПредприятия.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПозицияПоступления.Аналитика_1 КАК Аналитика_1,
	|	ПозицияПоступления.Аналитика_2 КАК Аналитика_2,
	|	ПозицияПоступления.Аналитика_3 КАК Аналитика_3,
	|	ПозицияПоступления.Аналитика_4 КАК Аналитика_4,
