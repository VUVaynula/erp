	ДанныеЗаполнения.Вставить("СуммаДокумента");
	ДанныеЗаполнения.Вставить("ЦФО");
	ДанныеЗаполнения.Вставить("СтатьяОборотов"); 
	ДанныеЗаполнения.Вставить("ОбъектРасчетов");
	ДанныеЗаполнения.Вставить("ОснованиеПлатежа");
	ДанныеЗаполнения.Вставить("БанковскийСчетПолучателя");
	ДанныеЗаполнения.Вставить("Соглашение");
	
	ДанныеЗаполнения.Вставить("ВалютаВзаиморасчетов");
