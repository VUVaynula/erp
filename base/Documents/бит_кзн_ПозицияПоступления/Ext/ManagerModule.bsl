Функция ПараметрыФормыПриКопировании(ДокументПланирования) Экспорт

	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения, КоличествоПозиций", Новый Структура, 0);

	РезультатПоиска = НайтиПозициюПоОснованию(ДокументПланирования);	
	Если РезультатПоиска.КоличествоПозиций = 1 Тогда
		РеквизитыДокумента = РеквизитыДокумента(РезультатПоиска.МассивПозиций[0]);
		ЗначенияЗаполнения = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(РеквизитыДокумента[0]);

		Исключения = Новый Структура;
		Исключения.Вставить("Cсылка", 				   Неопределено);
		Исключения.Вставить("Дата", 				   '0001-01-01');
		Исключения.Вставить("Номер", 				   "");
		Исключения.Вставить("Проведен", 			   Ложь);
		Исключения.Вставить("ПометкаУдаления", 		   Ложь);
		Исключения.Вставить("ДокументОснование", 	   Неопределено);
		Исключения.Вставить("ДокументПланирования",    Неопределено);
		Исключения.Вставить("ОтправленНаСогласование", Ложь);
		ЗаполнитьЗначенияСвойств(ЗначенияЗаполнения, Исключения);
		
		ПараметрыФормы.ЗначенияЗаполнения = ЗначенияЗаполнения;
	КонецЕсли;
	
	ПараметрыФормы.КоличествоПозиций = РезультатПоиска.КоличествоПозиций;
	
	Возврат ПараметрыФормы;
	
