Функция ОбъектРасчетовПоИсточнику(ИсточникОбъектаРасчетов)
	
	Если НЕ ЗначениеЗаполнено(ИсточникОбъектаРасчетов) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоСсылке(ИсточникОбъектаРасчетов);
		ПараметрыВзаиморасчеты = МенеджерОбъекта.ПараметрыВзаиморасчеты();
		Если ТипЗнч(ПараметрыВзаиморасчеты) = Тип("Массив") Тогда
			СтруктураВзаиморасчетов = ПараметрыВзаиморасчеты[0];
		Иначе
			СтруктураВзаиморасчетов = ПараметрыВзаиморасчеты;
		КонецЕсли;
		РеквизитыОбъекта       = ОбъектыРасчетовСервер.РеквизитыОбъектаРасчетовПоСтруктуре(
									ИсточникОбъектаРасчетов.ПолучитьОбъект(),
									ИсточникОбъектаРасчетов,
									СтруктураВзаиморасчетов,
									РежимЗаписиДокумента.Запись);

		Если ЗначениеЗаполнено(РеквизитыОбъекта.Организация)
			И ТипЗнч(РеквизитыОбъекта.Организация) <> Тип("СправочникСсылка.Организации") Тогда
			РеквизитыОбъекта.Организация = Справочники.Организации.ПустаяСсылка();
		КонецЕсли;
		Если ЗначениеЗаполнено(РеквизитыОбъекта.Контрагент)
			И ТипЗнч(РеквизитыОбъекта.Контрагент) <> Тип("СправочникСсылка.Организации")
			И ТипЗнч(РеквизитыОбъекта.Контрагент) <> Тип("СправочникСсылка.Контрагенты") Тогда
			РеквизитыОбъекта.Контрагент = Неопределено;
		КонецЕсли;
		Если ЗначениеЗаполнено(РеквизитыОбъекта.Партнер)
			И ТипЗнч(РеквизитыОбъекта.Партнер) <> Тип("СправочникСсылка.Партнеры") Тогда
			РеквизитыОбъекта.Партнер = Справочники.Партнеры.ПустаяСсылка();
		КонецЕсли;									
									
		ОбъектРасчетов = ОбъектыРасчетовСервер.ПроверитьСоздатьОбъектРасчетов(РеквизитыОбъекта);
	Исключение
		ОбъектРасчетов = Неопределено;
	КонецПопытки;
	
	Возврат ОбъектРасчетов;
	
