		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка);                             
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, АналитикиДляЗаполнения);
		
		ДенежныеСредстваСервер.ЗаполнитьРеквизитыДокументаПоФормеОплаты(Перечисления.ФормыОплаты.Безналичная, ДанныеЗаполнения);
		
		Если ДанныеЗаполнения.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
			ДанныеЗаполнения.БанковскийСчетПолучателя = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьБанковскийСчетПоУмолчанию(
															ДанныеЗаполнения.Контрагент, ДанныеЗаполнения.ВалютаДокумента);
		КонецЕсли;
		
		РасшифровкаПлатежа = НоваяРасшифровкаПлатежа();
		
		Если Выборка.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоНакладным
			Или Выборка.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказамНакладным
			Или Выборка.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамНакладным Тогда
			
			СтрокиГрафика = ДенежныеСредстваСервер.СтрокиГрафикаКОплате(Выборка.ДокументОснование);
			Если СтрокиГрафика.Количество() Тогда
				
				Результат  = ДенежныеСредстваСервер.ОплатитьСтрокиГрафика(СтрокиГрафика, "ПоступлениеБезналичныхДенежныхСредств");
				
				Если Результат.Свойство("ДокументКСозданию") И ЗначениеЗаполнено(Результат.ДокументКСозданию) Тогда
					ЗаполнитьПоМассивуОснований(ДанныеЗаполнения, 
						Результат.ДокументКСозданию.ДанныеЗаполнения.Основание, РасшифровкаПлатежа);
				КонецЕсли;
			КонецЕсли;
		Иначе
		
			Запрос = Новый Запрос("
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ТаблицаУслуги.ЗаказКлиента КАК ЗаказКлиента
			|ИЗ
			|	Документ.АктВыполненныхРабот.Услуги КАК ТаблицаУслуги
			|ГДЕ
			|	ТаблицаУслуги.Ссылка = &Ссылка
			|	И ТаблицаУслуги.Ссылка.АктПоЗаказам
			|");
			Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
			
			РезультатЗапросаПоЗаказам = Запрос.Выполнить();
			Если НЕ РезультатЗапросаПоЗаказам.Пустой() Тогда
				ЗаказыКлиента = РезультатЗапросаПоЗаказам.Выгрузить().ВыгрузитьКолонку("ЗаказКлиента");
				ЗаказыКлиента.Добавить(ДокументОснование);
			Иначе
				ЗаказыКлиента = ДокументОснование;
			КонецЕсли;
			
			ПараметрыЗаполненияРасшифровки = ВзаиморасчетыСервер.ПараметрыЗаполненияРасшифровкиПлатежаПоЗаказу();
			ПараметрыЗаполненияРасшифровки.ЗаказКлиента     = ЗаказыКлиента;
			ПараметрыЗаполненияРасшифровки.Договор          = Выборка.Договор;
			ПараметрыЗаполненияРасшифровки.ВалютаДокумента  = ДанныеЗаполнения.ВалютаДокумента;
			ПараметрыЗаполненияРасшифровки.Партнер          = Выборка.Партнер;
			ПараметрыЗаполненияРасшифровки.ОснованиеПлатежа = ДокументОснование;
			
			СуммаКОплате 	   = Выборка.Сумма;
			
			ВзаиморасчетыСервер.ЗаполнитьРасшифровкуПлатежаПоЗаказуКлиента(
				ПараметрыЗаполненияРасшифровки,  РасшифровкаПлатежа, СуммаКОплате);
		КонецЕсли;  
		Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл
			Экземпляр = ОбщегоНазначенияКлиентСервер.СкопироватьРекурсивно(ДанныеЗаполнения);
			Исключения = Новый Массив;
			Если ЗначениеЗаполнено(Экземпляр.Организация) Тогда
				Исключения.Добавить("Организация");		
			КонецЕсли;
			Если ЗначениеЗаполнено(Экземпляр.Партнер) Тогда
				Исключения.Добавить("Партнер");		
			КонецЕсли;    
			Если ЗначениеЗаполнено(Экземпляр.Подразделение) Тогда
				Исключения.Добавить("Подразделение");		
			КонецЕсли;
			Если ЗначениеЗаполнено(Исключения) Тогда
				ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТаблицы,, СтрСоединить(Исключения, ","));
			Иначе
				ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТаблицы);
			КонецЕсли;	  				
			
			Экземпляр.СуммаДокумента = СтрокаТаблицы.Сумма;
			ПозицииПоступления.Добавить(Экземпляр);
		КонецЦикла;	
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ПозицииПоступления) Тогда
		Возврат ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДанныеЗаполнения);
	КонецЕсли;
	
	Возврат ПозицииПоступления;   
	
КонецФункции

Функция ДанныеЗаполненияИзПланируемогоПоступления(ДокументОснование)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументОснование);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Позиции.Ссылка КАК Позиция,
	|	Позиции.ВидПлана КАК ВидПлана
	|ПОМЕСТИТЬ ВТ_Позиции
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК Позиции
	|ГДЕ
	|	Позиции.ДокументПланирования = &ДокументПланирования
	|	И Позиции.ВидПлана = ЗНАЧЕНИЕ(Перечисление.бит_кзн_ВидыПланов.Прогноз)
	|	И НЕ Позиции.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиПрогноза.Позиция КАК Позиция,
	|	ОстаткиПрогноза.СуммаОстаток КАК Сумма
	|ПОМЕСТИТЬ ВТ_ОстаткиПрогноза
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Остатки(
	|			,
	|			Позиция В
	|				(ВЫБРАТЬ
	|					ВТ_Позиции.Позиция КАК Позиция
	|				ИЗ
	|					ВТ_Позиции КАК ВТ_Позиции)) КАК ОстаткиПрогноза
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Позиции.Позиция КАК Позиция,
	|	ЕСТЬNULL(ВТ_ОстаткиПрогноза.Сумма, 0) КАК Сумма
	|ИЗ
	|	ВТ_Позиции КАК ВТ_Позиции
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОстаткиПрогноза КАК ВТ_ОстаткиПрогноза
	|		ПО ВТ_Позиции.Позиция = ВТ_ОстаткиПрогноза.Позиция
	|ГДЕ
	|	ЕСТЬNULL(ВТ_ОстаткиПрогноза.Сумма, 0) > 0";
	
	РезультатЗапроса = Запрос.Выполнить();  
	
	Если РезультатЗапроса.Пустой() Тогда
		Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не требуется вводить Планируемое поступление на основании документа %1.'; 
					|en = 'You do not need to enter the Planned receipt based on the document %1.'"), ДокументОснование);
		ВызватьИсключение Текст;
	КонецЕсли;
	
	ДанныеЗаполнения = НовыеДанныеЗаполнения();
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		ДанныеЗаполнения.Вставить(Колонка.Имя);
	КонецЦикла;

	Выборка	   = РезультатЗапроса.Выбрать();
	ВсеПозиции = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Позиция");
	
	ПозицииПоступления = Новый Массив;
	РеквизитыПозиций = РеквизитыДокумента(ВсеПозиции);
	
	Исключения = Новый Структура;
	Исключения.Вставить("Cсылка", 				   Неопределено);
	Исключения.Вставить("Дата", 				   '0001-01-01');
	Исключения.Вставить("Номер", 				   "");
	Исключения.Вставить("Проведен", 			   Ложь);
	Исключения.Вставить("ПометкаУдаления", 		   Ложь);
	Исключения.Вставить("ОтправленНаСогласование", Ложь);
	
	Пока Выборка.Следующий() Цикл
		СтрокаТаблицы 	   = РеквизитыПозиций.Найти(Выборка.Позиция, "Позиция"); 
		Экземпляр = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(СтрокаТаблицы);
		
		Экземпляр.ВидПлана			 	= Перечисления.бит_кзн_ВидыПланов.План;
		Экземпляр.СуммаДокумента	 	= Выборка.Сумма;
		Экземпляр.ДокументОснование	= Выборка.Позиция;
		Экземпляр.ДокументПланирования = Неопределено;
		ЗаполнитьЗначенияСвойств(Экземпляр, Исключения);

		ПозицииПоступления.Добавить(Экземпляр);
	КонецЦикла;
	
	Возврат ПозицииПоступления;
	
КонецФункции

Функция ДанныеЗаполненияПоЗаявкеНаПеремещение(ДокументОснование)
	
	ОперацииСНаличными = Новый Массив;
	ОперацииСНаличными.Добавить(Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствВДругуюКассу);
	ОперацииСНаличными.Добавить(Перечисления.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствИзБанка);
	ОперацииСНаличными.Добавить(Перечисления.бит_ВидыОперацийКазначейства.ПоступлениеДенежныхСредствИзБанка);
	
	ОперацииЧерезБанк = Новый Массив;
	ОперацииЧерезБанк.Добавить(Перечисления.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствВБанк);
	ОперацииЧерезБанк.Добавить(Перечисления.бит_ВидыОперацийКазначейства.СдачаДенежныхСредствВБанк);
	ОперацииЧерезБанк.Добавить(Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеДенежныхСредствНаДругойСчет);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	Запрос.УстановитьПараметр("ОперацииСНаличными", ОперацииСНаличными);
	Запрос.УстановитьПараметр("ОперацииЧерезБанк", ОперацииЧерезБанк);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК ДокументПланирования,
	|	Реквизиты.Дата КАК ДатаПлан,
	|	Реквизиты.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.ЦФО КАК ЦФО,
	|	Реквизиты.СуммаДокумента КАК СуммаДокумента,
	|	Реквизиты.СуммаДокумента КАК СуммаВзаиморасчетов,
	|	Реквизиты.ВалютаДокумента КАК ВалютаДокумента,
	|	Реквизиты.ВалютаДокумента КАК ВалютаВзаиморасчетов,
	|	Реквизиты.НазначениеПлатежа КАК НазначениеПлатежа,
	|	Реквизиты.НазначениеПлатежаУпр КАК НазначениеПлатежаУпр,
	|	Реквизиты.Комментарий КАК Комментарий,
	|	Реквизиты.Сценарий КАК Сценарий,
	|	Реквизиты.СверхБюджета КАК СверхБюджета,
	|	Реквизиты.СписатьЛимиты КАК СписатьЛимиты,
	|	Реквизиты.Важность КАК Важность,
	|	Реквизиты.Ответственный КАК Ответственный,
	|	1 КАК КурсЧислительВзаиморасчетов,
	|	1 КАК КурсЗнаменательВзаиморасчетов,
	|	Реквизиты.БанковскийСчетПолучатель КАК БанковскийСчет,
	|	Реквизиты.КассаПолучатель КАК Касса,
	|	Реквизиты.Инициатор КАК Инициатор,
	|	ВЫБОР
	|		КОГДА Реквизиты.ХозяйственнаяОперация В (&ОперацииСНаличными)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Наличные)
	|		КОГДА Реквизиты.ХозяйственнаяОперация В (&ОперацииЧерезБанк)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|	КОНЕЦ КАК ФормаОплаты,
	|	ВЫБОР
	|		КОГДА Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.СдачаДенежныхСредствВБанк)
	|				ИЛИ Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствВБанк)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.СдачаДенежныхСредствВБанк_ПоступлениеВБанк)
	|		КОГДА Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствВДругуюКассу)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.ПоступлениеДенежныхСредствИзДругойКассы)
	|		КОГДА Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ПеречислениеДенежныхСредствНаДругойСчет)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.ПеречислениеДенежныхСредствНаДругойСчет_поступление)
	|		КОГДА Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ПоступлениеДенежныхСредствИзБанка)
	|				ИЛИ Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствИзБанка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.ПоступлениеДенежныхСредствИзБанка_ПоступлениеВКассу)
	|	КОНЕЦ КАК СтатьяОборотов
	|ИЗ
	|	Документ.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";	
	
	Результат = Запрос.Выполнить();
	Выборка	  = Результат.Выгрузить();
	
	Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Выборка[0]);
	
КонецФункции

Функция НоваяРасшифровкаПлатежа()

	УстановитьПривилегированныйРежим(Истина);
	
	// В алгоритмах общих модулей ЕРП выполняется группировка таблицы по некоторым колонкам.
	// Если использовать ТЗ, изменяется состав колонок. Поэтому используем объектную модель.
	
	ДокументОбъект	   = Документы.ПоступлениеБезналичныхДенежныхСредств.СоздатьДокумент();
	РасшифровкаПлатежа = ДокументОбъект.РасшифровкаПлатежа;
		
	Возврат РасшифровкаПлатежа;	
	
КонецФункции

