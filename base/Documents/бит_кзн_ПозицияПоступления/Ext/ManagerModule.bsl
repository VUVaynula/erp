	|			ТОГДА Реквизиты.Касса
	|		ИНАЧЕ Реквизиты.БанковскийСчет
	|	КОНЕЦ КАК МестоХраненияДенежныхСредств,
	|	Реквизиты.Подразделение КАК Подразделение
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка
	|	И ТИПЗНАЧЕНИЯ(Реквизиты.ДокументПланирования) = ТИП(Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств)";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Если НЕ ЗначениеЗаполнено(РезультатЗапроса) Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты = РезультатЗапроса[0];
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", Реквизиты.ДокументПланирования);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.ДокументПланирования КАК ДокументПланирования,
	|	СУММА(Реквизиты.СуммаНДС) КАК НДС,
	|	СУММА(Реквизиты.СуммаДокумента) КАК Сумма
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК Реквизиты
	|ГДЕ
	|	Реквизиты.ДокументПланирования = &ДокументПланирования
	|	И НЕ Реквизиты.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	Реквизиты.ДокументПланирования";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Если ЗначениеЗаполнено(РезультатЗапроса) Тогда
		// Если запрос пустой, значит все документы помечены на удаление.
		Реквизиты.Сумма = РезультатЗапроса[0].Сумма;
		Реквизиты.НДС   = РезультатЗапроса[0].НДС;
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.бит_ДанныеДокументовКазначейства.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Документ.Установить(Реквизиты.ДокументПланирования);
	ЗаполнитьЗначенияСвойств(НаборЗаписей.Добавить(), Реквизиты);
	НаборЗаписей.Записать();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ВводНаОсновании

Функция ДанныеЗаполненияПоЗаказуКлиента(ДокументОснование, ДопАналитики)

	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.БанковскийСчет <> ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.БанковскийСчет.Владелец
	|		КОГДА ДанныеДокумента.Касса <> ЗНАЧЕНИЕ(Справочник.Кассы.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.Касса.Владелец
	|		ИНАЧЕ ДанныеДокумента.Организация
	|	КОНЕЦ КАК Организация,
	|	ДанныеДокумента.Подразделение КАК Подразделение,
	|	ДанныеДокумента.БанковскийСчет КАК БанковскийСчет,
	|	ДанныеДокумента.Касса КАК Касса,
	|	ДанныеДокумента.Партнер КАК Партнер,
	|	ДанныеДокумента.Контрагент КАК Контрагент,
	|	ДанныеДокумента.Договор КАК Договор,
	|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента) КАК ХозяйственнаяОперация,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.БанковскийСчет <> ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.БанковскийСчет.ВалютаДенежныхСредств
	|		КОГДА ДанныеДокумента.Касса <> ЗНАЧЕНИЕ(Справочник.Кассы.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.Касса.ВалютаДенежныхСредств
	|		ИНАЧЕ ДанныеДокумента.Валюта
	|	КОНЕЦ КАК ВалютаДокумента,
	|	ДанныеДокумента.Ссылка КАК ОснованиеПлатежа,
	|	ДанныеДокумента.Ссылка КАК ДокументОснование,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.ФормыОплаты.Наличная)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Наличные)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|	КОНЕЦ КАК ФормаОплаты,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.ФормыОплаты.Безналичная)
	|			ТОГДА ВЫБОР
	|					КОГДА ДанныеДокумента.БанковскийСчетКонтрагента = ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|						ТОГДА ДанныеДокумента.Договор.БанковскийСчетКонтрагента
	|					ИНАЧЕ ДанныеДокумента.БанковскийСчетКонтрагента
	|				КОНЕЦ
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК БанковскийСчетПолучателя,
	|	ДанныеДокумента.Соглашение КАК Соглашение
	|ИЗ
	|	Документ.ЗаказКлиента КАК ДанныеДокумента
	|ГДЕ
	|	ДанныеДокумента.Ссылка = &Ссылка
	|	И ДанныеДокумента.ХозяйственнаяОперация <> ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПередачаНаКомиссию)
	|	И ДанныеДокумента.ПорядокРасчетов <> ЗНАЧЕНИЕ(Перечисление.ПорядокРасчетов.ПоНакладным)";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не требуется вводить Планируемое поступление на основании документа %1.'; 
					|en = 'You do not need to enter the Planned receipt based on the document %1.'"), ДокументОснование);
		ВызватьИсключение Текст;
	КонецЕсли;
	
	Выборка			   = РезультатЗапроса.Выбрать();
	ПозицииПоступления = Новый Массив;
	
	ДанныеЗаполнения = НовыеДанныеЗаполнения();
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		ДанныеЗаполнения.Вставить(Колонка.Имя);
	КонецЦикла;
	
	Если Выборка.Следующий() Тогда
		
		АналитикиДляЗаполнения = АналитикиДляЗаполнения(ДокументОснование, ДопАналитики);
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка);
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, АналитикиДляЗаполнения);
		
		Если ДанныеЗаполнения.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
			ДанныеЗаполнения.БанковскийСчетПолучателя = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьБанковскийСчетПоУмолчанию(
															ДанныеЗаполнения.Контрагент, ДанныеЗаполнения.ВалютаДокумента);
		КонецЕсли;
		
		Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			ПараметрыЗаполненияРасшифровки = ВзаиморасчетыСервер.ПараметрыЗаполненияРасшифровкиПлатежаПоЗаказу();
			ПараметрыЗаполненияРасшифровки.ЗаказКлиента     = ДокументОснование;
			ПараметрыЗаполненияРасшифровки.Договор          = Выборка.Договор;
			ПараметрыЗаполненияРасшифровки.ВалютаДокумента  = ДанныеЗаполнения.ВалютаДокумента;
			ПараметрыЗаполненияРасшифровки.Партнер          = Выборка.Партнер;
			ПараметрыЗаполненияРасшифровки.ОснованиеПлатежа = ДокументОснование;
			
			РасшифровкаПлатежа = НоваяРасшифровкаПлатежа();
			СуммаКОплате 	   = 0;
			
			ВзаиморасчетыСервер.ЗаполнитьРасшифровкуПлатежаПоЗаказуКлиента(ПараметрыЗаполненияРасшифровки, РасшифровкаПлатежа, СуммаКОплате);
			
			Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл
				Экземпляр = ОбщегоНазначенияКлиентСервер.СкопироватьРекурсивно(ДанныеЗаполнения);
				Исключения = Новый Массив;
				Если ЗначениеЗаполнено(Экземпляр.Организация) Тогда
					Исключения.Добавить("Организация");		
				КонецЕсли;
				Если ЗначениеЗаполнено(Экземпляр.Подразделение) Тогда
					Исключения.Добавить("Подразделение");		
				КонецЕсли;
				Если ЗначениеЗаполнено(Экземпляр.Партнер) Тогда
					Исключения.Добавить("Партнер");		
				КонецЕсли;    
				
				Если ЗначениеЗаполнено(Исключения) Тогда
					ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТаблицы,, СтрСоединить(Исключения, ","));
				Иначе
					ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТаблицы);
				КонецЕсли;	  				
				
				Экземпляр.СуммаДокумента = СтрокаТаблицы.Сумма;
				
				ПозицииПоступления.Добавить(Экземпляр);
			КонецЦикла;
		КонецЕсли;	
	КонецЕсли;    
	
	Возврат ПозицииПоступления;
	
КонецФункции

Функция ДанныеЗаполненияПоРеализацииТоваровУслуг(ДокументОснование, ДопАналитики)

	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.БанковскийСчетОрганизации <> ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.БанковскийСчетОрганизации.Владелец
	|		КОГДА ДанныеДокумента.Касса <> ЗНАЧЕНИЕ(Справочник.Кассы.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.Касса.Владелец
	|		ИНАЧЕ ДанныеДокумента.Организация
	|	КОНЕЦ КАК Организация,
	|	ДанныеДокумента.Подразделение КАК Подразделение,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.Касса <> ЗНАЧЕНИЕ(Справочник.Кассы.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Наличные)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|	КОНЕЦ КАК ФормаОплаты,
	|	ДанныеДокумента.БанковскийСчетОрганизации КАК БанковскийСчет,
	|	ДанныеДокумента.Касса КАК Касса,
	|	ДанныеДокумента.Партнер КАК Партнер,
	|	ДанныеДокумента.Контрагент КАК Контрагент,
	|	ДанныеДокумента.Договор КАК Договор,
	|	ДанныеДокумента.ПорядокРасчетов КАК ПорядокРасчетов,
	|	ДанныеДокумента.РеализацияПоЗаказам КАК РеализацияПоЗаказам,
	|	ДанныеДокумента.Валюта КАК ВалютаДокумента,
	|	ДанныеДокумента.Ссылка КАК ОснованиеПлатежа,
	|	ДанныеДокумента.Ссылка КАК ДокументОснование,
	|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента) КАК ХозяйственнаяОперация,
	|	ДанныеДокумента.СуммаДокумента КАК Сумма,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.БанковскийСчетКонтрагента = ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.Договор.БанковскийСчетКонтрагента
	|		ИНАЧЕ ДанныеДокумента.БанковскийСчетКонтрагента
	|	КОНЕЦ КАК БанковскийСчетПолучателя,
	|	ДанныеДокумента.Соглашение КАК Соглашение
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК ДанныеДокумента
	|ГДЕ
	|	ДанныеДокумента.Ссылка = &Ссылка";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не требуется вводить Планируемое поступление на основании документа %1.'; 
					|en = 'You do not need to enter the Planned receipt based on the document %1.'"), ДокументОснование);
		ВызватьИсключение Текст;
	КонецЕсли;
		
	ДанныеЗаполнения = НовыеДанныеЗаполнения();
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		ДанныеЗаполнения.Вставить(Колонка.Имя);
	КонецЦикла;
	
	Выборка			   = РезультатЗапроса.Выбрать();
	ПозицииПоступления = Новый Массив;
	
	Если Выборка.Следующий() Тогда
		
		АналитикиДляЗаполнения = АналитикиДляЗаполнения(ДокументОснование, ДопАналитики);
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка);
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, АналитикиДляЗаполнения);
				
		Если ДанныеЗаполнения.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
			ДанныеЗаполнения.БанковскийСчетПолучателя = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьБанковскийСчетПоУмолчанию(
															ДанныеЗаполнения.Контрагент, ДанныеЗаполнения.ВалютаДокумента);
		КонецЕсли;
		
		РасшифровкаПлатежа = НоваяРасшифровкаПлатежа();
		
		Если ((Выборка.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоНакладным
			ИЛИ Выборка.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказам)
			И НЕ Выборка.РеализацияПоЗаказам) 
			ИЛИ Выборка.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказамНакладным
			ИЛИ Выборка.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамНакладным Тогда
			
			СтрокиГрафика = ДенежныеСредстваСервер.СтрокиГрафикаКОплате(Выборка.ДокументОснование);
			Если СтрокиГрафика.Количество() Тогда
				
				Результат = ДенежныеСредстваСервер.ОплатитьСтрокиГрафика(СтрокиГрафика, "ПоступлениеБезналичныхДенежныхСредств");
				
				Если Результат.Свойство("ДокументКСозданию") И ЗначениеЗаполнено(Результат.ДокументКСозданию) Тогда
					ЗаполнитьПоМассивуОснований(ДанныеЗаполнения, 
							Результат.ДокументКСозданию.ДанныеЗаполнения.Основание, РасшифровкаПлатежа);
				КонецЕсли;
				
			КонецЕсли;
		Иначе
			
			Запрос = Новый Запрос("
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ТаблицаТовары.ЗаказКлиента КАК ЗаказКлиента
			|ИЗ
			|	Документ.РеализацияТоваровУслуг.Товары КАК ТаблицаТовары
			|ГДЕ
			|	ТаблицаТовары.Ссылка = &Ссылка
			|	И ТаблицаТовары.Ссылка.РеализацияПоЗаказам
			|");
			Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
			
			РезультатЗапросаПоЗаказам = Запрос.Выполнить();
			Если НЕ РезультатЗапросаПоЗаказам.Пустой() Тогда
				ЗаказыКлиента = РезультатЗапросаПоЗаказам.Выгрузить().ВыгрузитьКолонку("ЗаказКлиента");
				ЗаказыКлиента.Добавить(ДокументОснование);
			Иначе
				ЗаказыКлиента = ДокументОснование;
			КонецЕсли;
			
			ПараметрыЗаполненияРасшифровки = ВзаиморасчетыСервер.ПараметрыЗаполненияРасшифровкиПлатежаПоЗаказу();
			ПараметрыЗаполненияРасшифровки.ЗаказКлиента     = ЗаказыКлиента;
			ПараметрыЗаполненияРасшифровки.Договор          = Выборка.Договор;
			ПараметрыЗаполненияРасшифровки.ВалютаДокумента  = ДанныеЗаполнения.ВалютаДокумента;
			ПараметрыЗаполненияРасшифровки.Партнер          = Выборка.Партнер;
			ПараметрыЗаполненияРасшифровки.ОснованиеПлатежа = ДокументОснование;
						
			СуммаКОплате = Выборка.Сумма;
			
			ВзаиморасчетыСервер.ЗаполнитьРасшифровкуПлатежаПоЗаказуКлиента(
				ПараметрыЗаполненияРасшифровки, РасшифровкаПлатежа, СуммаКОплате);
				
		КонецЕсли;
		Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл
			Экземпляр = ОбщегоНазначенияКлиентСервер.СкопироватьРекурсивно(ДанныеЗаполнения);
			Исключения = Новый Массив;
			Если ЗначениеЗаполнено(Экземпляр.Организация) Тогда
				Исключения.Добавить("Организация");		
			КонецЕсли;
			Если ЗначениеЗаполнено(Экземпляр.Подразделение) Тогда
				Исключения.Добавить("Подразделение");		
			КонецЕсли;
			Если ЗначениеЗаполнено(Экземпляр.Партнер) Тогда
				Исключения.Добавить("Партнер");		
			КонецЕсли;    
			
			Если ЗначениеЗаполнено(Исключения) Тогда
				ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТаблицы,, СтрСоединить(Исключения, ","));
			Иначе
				ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТаблицы);
			КонецЕсли;	  				
			
			Экземпляр.СуммаДокумента = СтрокаТаблицы.Сумма;
			
			ПозицииПоступления.Добавить(Экземпляр);
		КонецЦикла;	
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПозицииПоступления) Тогда
		Возврат ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДанныеЗаполнения);
	КонецЕсли;
	
	Возврат ПозицииПоступления;
	
КонецФункции

Функция ДанныеЗаполненияПоСчетуНаОплатуКлиенту(ДокументОснование, ДопАналитики)
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.БанковскийСчет <> ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.БанковскийСчет.Владелец
	|		КОГДА ДанныеДокумента.Касса <> ЗНАЧЕНИЕ(Справочник.Кассы.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.Касса.Владелец
	|		ИНАЧЕ ДанныеДокумента.Организация
	|	КОНЕЦ КАК Организация,
	|	ДанныеДокумента.ДокументОснование.Контрагент КАК Контрагент,
	|	ДанныеДокумента.ДокументОснование КАК ЗаказКлиента,
	|	ДанныеДокумента.БанковскийСчет КАК БанковскийСчет,
	|	ДанныеДокумента.Касса КАК Касса,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.БанковскийСчет <> ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.БанковскийСчет.ВалютаДенежныхСредств
	|		КОГДА ДанныеДокумента.Касса <> ЗНАЧЕНИЕ(Справочник.Кассы.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.Касса.ВалютаДенежныхСредств
	|		ИНАЧЕ ДанныеДокумента.Валюта
	|	КОНЕЦ КАК ВалютаДокумента,
	|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента) КАК ХозяйственнаяОперация,
	|	ДанныеДокумента.Ссылка КАК ДокументОснование,
	|	ДанныеДокумента.НазначениеПлатежа КАК НазначениеПлатежа,
	|	ДанныеДокумента.НазначениеПлатежа КАК НазначениеПлатежаУпр,
	|	ДанныеДокумента.ДокументОснование КАК ОснованиеПлатежа,
	|	ДанныеДокумента.Договор КАК Договор,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.ФормыОплаты.Наличная)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Наличные)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|	КОНЕЦ КАК ФормаОплаты,
	|	ДанныеДокумента.Партнер КАК Партнер,
	|	ДанныеДокумента.Договор.БанковскийСчетКонтрагента КАК БанковскийСчетПолучателя
	|ИЗ
	|	Документ.СчетНаОплатуКлиенту КАК ДанныеДокумента
	|ГДЕ
	|	ДанныеДокумента.Ссылка = &Ссылка";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не требуется вводить Планируемое поступление на основании документа %1.'; 
					|en = 'You do not need to enter the Planned receipt based on the document %1.'"), ДокументОснование);
		ВызватьИсключение Текст;
	КонецЕсли;
	
	ДанныеЗаполнения = НовыеДанныеЗаполнения();
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		ДанныеЗаполнения.Вставить(Колонка.Имя);
	КонецЦикла;
		
	Выборка			   = РезультатЗапроса.Выбрать();
	ПозицииПоступления = Новый Массив;

	Если Выборка.Следующий() Тогда
		
		АналитикиДляЗаполнения = АналитикиДляЗаполнения(ДокументОснование, ДопАналитики);
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка);
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, АналитикиДляЗаполнения);
		
		Если ДанныеЗаполнения.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
			ДанныеЗаполнения.БанковскийСчетПолучателя = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьБанковскийСчетПоУмолчанию(
															ДанныеЗаполнения.Контрагент, ДанныеЗаполнения.ВалютаДокумента);
		КонецЕсли;
		
		РасшифровкаПлатежа = НоваяРасшифровкаПлатежа();
		
		ВзаиморасчетыСервер.ЗаполнитьРасшифровкуПлатежаПоСчетуНаОплату(ДокументОснование, Выборка.Организация,
			Выборка.ЗаказКлиента, ДанныеЗаполнения.ВалютаДокумента, РасшифровкаПлатежа);
			
		Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл
			Экземпляр = ОбщегоНазначенияКлиентСервер.СкопироватьРекурсивно(ДанныеЗаполнения);
			Исключения = Новый Массив;
			Если ЗначениеЗаполнено(Экземпляр.Организация) Тогда
				Исключения.Добавить("Организация");		
			КонецЕсли;
			Если ЗначениеЗаполнено(Экземпляр.Подразделение) Тогда
				Исключения.Добавить("Подразделение");		
			КонецЕсли;
			Если ЗначениеЗаполнено(Экземпляр.Партнер) Тогда
				Исключения.Добавить("Партнер");		
			КонецЕсли;    
			
			Если ЗначениеЗаполнено(Исключения) Тогда
				ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТаблицы,, СтрСоединить(Исключения, ","));
			Иначе
				ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТаблицы);
			КонецЕсли;	  				
			
			Экземпляр.СуммаДокумента = СтрокаТаблицы.Сумма;
			
			ПозицииПоступления.Добавить(Экземпляр);
		КонецЦикла;

	КонецЕсли;
	
	Возврат ПозицииПоступления;
	
КонецФункции

