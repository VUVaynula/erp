&НаКлиенте
Процедура ОбработатьИзменениеПериодаРассчетов()
	
	ТекущаяДатаПлан = Объект.ДатаПлан;
	
	Если ЗначениеЗаполнено(Объект.ДатаПлан) Тогда		
		ПараметрыПроверки = бит_КазначействоКлиентСервер.НовыеПараметрыПериодЗаданКорректно();
		ПараметрыПроверки.ПоляОбъекта.ДатаНачала	= "Дата";
		ПараметрыПроверки.ПоляОбъекта.ДатаОкончания = "ДатаПлан";
		
		ПараметрыПроверки.ПоляФормы.ДатаНачала	  = НСтр("ru = 'Дата'; en = 'Date'");
		ПараметрыПроверки.ПоляФормы.ДатаОкончания = НСтр("ru = 'Дата платежа'; en = 'Payment Date'");
		
		ПериодЗаданКорректно = бит_КазначействоКлиентСервер.ПериодЗаданКорректно(Объект, ПараметрыПроверки);
		Если НЕ ПериодЗаданКорректно Тогда
			Объект.ДатаПлан = Объект.Дата;
		КонецЕсли;
	КонецЕсли;

	Если ЗначениеЗаполнено(Объект.ДатаПлан) И КонтролируемыеРеквизиты.ДатаПлан <> Объект.ДатаПлан Тогда
		ПараметрыПроверки = бит_КазначействоКлиентСервер.НовыеПараметрыПериодЗаданКорректно();
		ПараметрыПроверки.ПоляОбъекта.ДатаНачала	= "Дата";
		ПараметрыПроверки.ПоляОбъекта.ДатаОкончания = "ДатаПлан";
		
		ПараметрыПроверки.ПоляФормы.ДатаНачала	  = НСтр("ru = 'Дата'; en = 'Date'");
		ПараметрыПроверки.ПоляФормы.ДатаОкончания = НСтр("ru = 'Дата платежа'; en = 'Payment Date'");
		
		ПериодЗаданКорректно = бит_КазначействоКлиентСервер.ПериодЗаданКорректно(Объект, ПараметрыПроверки);
		Если НЕ ПериодЗаданКорректно Тогда
			Объект.ДатаПлан = Объект.Дата;
		КонецЕсли;

		Если ЗначениеЗаполнено(Объект.ДатаПланКрайняя) Тогда
			РазностьДат = бит_ОбщегоНазначенияКлиентСервер.РазностьДат(КонтролируемыеРеквизиты.ДатаПлан, Объект.ДатаПлан, "День");
			Объект.ДатаПланКрайняя = бит_ОбщегоНазначенияКлиентСервер.ПолучитьПериодПоСдвигу(
										КонтролируемыеРеквизиты.ДатаПланКрайняя, РазностьДат, "День");
			ОбновитьКонтролируемыеРеквизиты("ДатаПланКрайняя", ЭтотОбъект);							
		КонецЕсли;

		Если КонтролируемыеРеквизиты.ДатаПлан <> Объект.ДатаПлан Тогда
			УправлениеФормой();
		КонецЕсли;

		ОбновитьКонтролируемыеРеквизиты("ДатаПлан", ЭтотОбъект);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ДатаПланКрайняя) И КонтролируемыеРеквизиты.ДатаПланКрайняя <> Объект.ДатаПланКрайняя Тогда
		
		ПараметрыПроверки = бит_КазначействоКлиентСервер.НовыеПараметрыПериодЗаданКорректно();
		ПараметрыПроверки.ПоляОбъекта.ДатаНачала	= "ДатаПлан";
		ПараметрыПроверки.ПоляОбъекта.ДатаОкончания = "ДатаПланКрайняя";
		
		ПараметрыПроверки.ПоляФормы.ДатаНачала	  = НСтр("ru = 'Дата платежа'; en = 'Payment Date'");
		ПараметрыПроверки.ПоляФормы.ДатаОкончания = НСтр("ru = 'Не позднее'; en = 'on or before'");
		
		ПериодЗаданКорректно = бит_КазначействоКлиентСервер.ПериодЗаданКорректно(Объект, ПараметрыПроверки);
		Если НЕ ПериодЗаданКорректно Тогда
			Объект.ДатаПланКрайняя = КонтролируемыеРеквизиты.ДатаПланКрайняя;
		КонецЕсли;

		ОбновитьКонтролируемыеРеквизиты("ДатаПланКрайняя", ЭтотОбъект);
	КонецЕсли;	
		
	Если Объект.ДатаПлан <> ТекущаяДатаПлан Тогда
		ЗаполнитьКурсВзаиморасчетов();
		РассчитатьСуммуВзаиморасчетов();
		ЗаполнитьВалютуВзаиморасчетовДокумента();
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораБанковскогоСчетаКассыПолучателя()

	ДанныеОбъекта = Новый Структура;
	ДанныеОбъекта.Вставить("ХозяйственнаяОперация", ХозОперацияУП);
	ДанныеОбъекта.Вставить("ОрганизацияПолучатель", Объект.ОрганизацияПолучатель);
	ДанныеОбъекта.Вставить("Организация", 			Объект.Организация);
	ДанныеОбъекта.Вставить("ПланированиеСуммы", 	Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов);

	ДенежныеСредстваСервер.УстановитьПараметрыВыбораБанковскогоСчетаКассыПолучателя(ДанныеОбъекта, Элементы.БанковскийСчетПолучатель);
	ДенежныеСредстваСервер.УстановитьПараметрыВыбораБанковскогоСчетаКассыПолучателя(ДанныеОбъекта, Элементы.КассаПолучатель);

КонецПроцедуры

&НаСервере
Процедура ОбработатьИзмененииВалюты()

	ИзмениласьВалюта = КонтролируемыеРеквизиты.ВалютаДокумента <> Объект.ВалютаДокумента;
	Если НЕ ИзмениласьВалюта Тогда
		Возврат;	
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Объект.ВалютаДокумента) Тогда
		Если Объект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов Тогда
			Объект.ВалютаВзаиморасчетов = Объект.ВалютаДокумента;
			Объект.КурсЧислительВзаиморасчетов = 1;
			Объект.КурсЗнаменательВзаиморасчетов = 1;
			Объект.СуммаДокумента = Объект.СуммаВзаиморасчетов;
		Иначе
			Если НЕ ЗначениеЗаполнено(Объект.ОбъектРасчетов) И НЕ ЗначениеЗаполнено(Объект.Договор) Тогда
				Объект.ВалютаВзаиморасчетов			 = Объект.ВалютаДокумента;
				Объект.КурсЧислительВзаиморасчетов	 = 1;
				Объект.КурсЗнаменательВзаиморасчетов = 1;
				Объект.СуммаДокумента				 = Объект.СуммаВзаиморасчетов;
			Иначе	
				РасшифровкаПлатежа.Очистить();
				НоваяСтрока = РасшифровкаПлатежа.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Объект);
				НоваяСтрока.Сумма = Объект.СуммаДокумента;
				
				Контекст = Новый Структура;
				Контекст.Вставить("РасшифровкаПлатежа", РасшифровкаПлатежа);
				Контекст.Вставить("СуммаДокумента", 	Объект.СуммаДокумента);
				Контекст.Вставить("Дата",				Объект.ДатаРасхода);
				
				ДенежныеСредстваСервер.ПересчетСуммДокументаВВалюту(Контекст, КонтролируемыеРеквизиты.ВалютаДокумента, 
					Объект.ВалютаДокумента);
					
				Объект.СуммаДокумента = Контекст.СуммаДокумента;
				
				ЗаполнитьКурсВзаиморасчетов();
				ЗаполнитьКурсКратностьТекстом();
				ЗаполнитьВалютуВзаиморасчетовДокумента();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ОбработатьИзмененииСуммыДокумента(Истина);
	
	ОбновитьКонтролируемыеРеквизиты("ВалютаДокумента", ЭтотОбъект);
	УстановитьПараметрыВыбораБанковскийСчетКасса();
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьИзмененииСуммыДокумента(ИзмененаВалюта = Ложь)
	
	Если НЕ ОперацияБезНДС Тогда
		РассчитатьСуммуНДС();
	КонецЕсли;
	
	Если НЕ ИзмененаВалюта Тогда
		ЗаполнитьКурсВзаиморасчетов();
		РассчитатьСуммуВзаиморасчетов();
		ЗаполнитьВалютуВзаиморасчетовДокумента();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКурсВзаиморасчетов(ТолькоДанныеФормы = Ложь)

	ПараметрыЗаполнения = ДенежныеСредстваСервер.ПараметрыЗаполненияКурсаИКратности();

	ПараметрыЗаполнения.Валюта 				 = Объект.ВалютаДокумента;
	ПараметрыЗаполнения.Договор				 = Объект.Договор;
	ПараметрыЗаполнения.ВалютаВзаиморасчетов = Объект.ВалютаВзаиморасчетов;
	
	ПараметрыЗаполнения.ВалютаРегламентированногоУчета = ВалютаРеглУчета;
	ПараметрыЗаполнения.Дата						   = Объект.ДатаПлан;
	
	Данные = Новый Структура;
	Данные.Вставить("КурсЧислительВзаиморасчетов",  0);
	Данные.Вставить("КурсЗнаменательВзаиморасчетов",0);
	Данные.Вставить("ВариантКурсаДоговора", 		Перечисления.ВариантыКурсаДоговора.ПустаяСсылка());
	Данные.Вставить("ТипОбъектаРасчетов", 			Перечисления.ТипыОбъектовРасчетов.ПустаяСсылка());
	
	ЗаполнитьЗначенияСвойств(Данные, Объект);
	ЗаполнитьЗначенияСвойств(Данные, ЭтотОбъект);
	
	ДенежныеСредстваСервер.ЗаполнитьКурсИКратностьВСтрокеРасшифровки(Данные, ПараметрыЗаполнения);
	
	Если ТолькоДанныеФормы Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Данные, "ВариантКурсаДоговора");
	Иначе	
		ЗаполнитьЗначенияСвойств(Объект, Данные);
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Данные);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РассчитатьСуммуВзаиморасчетов()
	
	Данные = Новый Структура;
	Данные.Вставить("Сумма", 						 Объект.СуммаДокумента);
	Данные.Вставить("КурсЧислительВзаиморасчетов",	 Объект.КурсЧислительВзаиморасчетов);
	Данные.Вставить("КурсЗнаменательВзаиморасчетов", Объект.КурсЗнаменательВзаиморасчетов);
	Данные.Вставить("СуммаВзаиморасчетов",			 Объект.СуммаВзаиморасчетов);
	
	ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
			Данные, Объект.ВалютаДокумента, ВалютаРеглУчета);
			
	Объект.СуммаВзаиморасчетов = Данные.СуммаВзаиморасчетов; 		
		
КонецПроцедуры
		
&НаСервере
Процедура ЗаполнитьВалютуВзаиморасчетовДокумента()
		
	Элементы.ДекорацияВалютыИКурсПлатежа.Заголовок = НадписьВалютыИКурсПлатежа();
	
КонецПроцедуры

&НаСервере
Процедура ПланированиеСуммыПриИзмененииНаСервере()
	
	Объект.ВалютаДокумента = ВалютаПланированияДенежныхСредств();
	ОбработатьИзмененииВалюты();
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Функция ВалютаПланированияДенежныхСредств()

	Если Объект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
		ВалютаПланирования = Объект.ВалютаДокумента;
		Если Объект.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Наличные Тогда
			Если ЗначениеЗаполнено(Объект.Касса) Тогда
				ВалютаПланирования = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Касса, "ВалютаДенежныхСредств");
			КонецЕсли;
		Иначе
			Если ЗначениеЗаполнено(Объект.БанковскийСчет) Тогда
				ВалютаПланирования = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.БанковскийСчет, "ВалютаДенежныхСредств");
			КонецЕсли;
		КонецЕсли;
	Иначе
		ВалютаПланирования = Объект.ВалютаВзаиморасчетов;
	КонецЕсли;

	Возврат ВалютаПланирования;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьКурсКратностьТекстом()
	
	СформироватьКурсЗнаменательТекстом();
		
КонецПроцедуры

&НаСервере
Процедура ДекорацияВалютыИКурсПлатежаНажатиеЗавершениеНаСервере(Знач ИзмененаСумма)
	
	ЗаполнитьКурсКратностьТекстом();
	ЗаполнитьВалютуВзаиморасчетовДокумента();
	
	Если ИзмененаСумма Тогда
		ОбработатьИзмененииСуммыДокумента(Истина);
		ОбновитьКонтролируемыеРеквизиты("СуммаДокумента", ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СуммаВзаиморасчетовПриИзмененииНаСервере()
	
	ТекущаяСуммаДокумента = Объект.СуммаДокумента;
	
	Если Объект.СуммаДокумента = 0 Тогда
		Если Объект.ВалютаДокумента = ВалютаРеглУчета Тогда
			Если Объект.КурсЗнаменательВзаиморасчетов <> 0 Тогда
				Объект.СуммаДокумента = Объект.СуммаВзаиморасчетов * Объект.КурсЧислительВзаиморасчетов / Объект.КурсЗнаменательВзаиморасчетов;
			Иначе
				Объект.СуммаДокумента = 0;
			КонецЕсли;
		Иначе
			Если Объект.КурсЧислительВзаиморасчетов <> 0 Тогда
				Объект.СуммаДокумента = Объект.СуммаВзаиморасчетов / Объект.КурсЧислительВзаиморасчетов * Объект.КурсЗнаменательВзаиморасчетов;
			Иначе
				Объект.СуммаДокумента = 0;
			КонецЕсли;
		КонецЕсли;
	Иначе
		Если Объект.ВалютаВзаиморасчетов = Объект.ВалютаДокумента Тогда
			
			Объект.КурсЧислительВзаиморасчетов = 1;
			
		ИначеЕсли Объект.ВалютаДокумента = ВалютаРеглУчета Тогда
			Если Объект.СуммаВзаиморасчетов <> 0 Тогда
				Объект.КурсЧислительВзаиморасчетов = Объект.СуммаДокумента / Объект.СуммаВзаиморасчетов * Объект.КурсЗнаменательВзаиморасчетов;
			Иначе
				Объект.КурсЧислительВзаиморасчетов = 1;
			КонецЕсли;
		Иначе
			Если Объект.СуммаДокумента <> 0 Тогда
				Объект.КурсЧислительВзаиморасчетов = Объект.СуммаВзаиморасчетов / Объект.СуммаДокумента * Объект.КурсЗнаменательВзаиморасчетов;
			Иначе
				Объект.КурсЧислительВзаиморасчетов = 0;
			КонецЕсли;
		КонецЕсли;
		СформироватьКурсЗнаменательТекстом();
	КонецЕсли;
	
	Если Объект.СуммаДокумента <> ТекущаяСуммаДокумента Тогда
		ОбработатьИзмененииСуммыДокумента(Истина);	
	КонецЕсли;
	
	ЗаполнитьВалютуВзаиморасчетовДокумента();
		
КонецПроцедуры

&НаСервере
Процедура ОбработатьИзменениеВалютыВзаиморасчетов()

	Объект.ВалютаДокумента = ВалютаПланированияДенежныхСредств();
	
	ЗаполнитьКурсВзаиморасчетов();
	
	РассчитатьСуммуВзаиморасчетов();
	СформироватьКурсЗнаменательТекстом();
	ЗаполнитьВалютуВзаиморасчетовДокумента();

	ОбновитьКонтролируемыеРеквизиты("ВалютаДокумента", ЭтотОбъект);
	УправлениеФормой();

КонецПроцедуры

&НаСервере
Процедура КурсЧислительВзаиморасчетовПриИзмененииНаСервере()
	
	РассчитатьСуммуВзаиморасчетов();
	СформироватьКурсЗнаменательТекстом();
	ЗаполнитьВалютуВзаиморасчетовДокумента();
	
КонецПроцедуры

// См. ДенежныеСредстваСервер.НадписьВалютыИКурсПлатежа().
//
&НаСервере
Функция НадписьВалютыИКурсПлатежа()
		
	ШаблонКурса = "(%1 %2 = %3 %4)";
	СтрокиНадписи = Новый Массив;
	СтрокиНадписи.Добавить(НСтр("ru = 'Расчеты';
								|en = 'AR/AP accounting'"));

	СтрокиНадписи.Добавить(Строка(Объект.СуммаВзаиморасчетов));
	СтрокиНадписи.Добавить(Строка(Объект.ВалютаВзаиморасчетов));
		
	Если Объект.КурсЧислительВзаиморасчетов <> 0 Тогда
		Если Объект.ВалютаДокумента = ВалютаРеглУчета Тогда
			
			СтрокиНадписи.Добавить(СтрШаблон(ШаблонКурса,
				Объект.КурсЗнаменательВзаиморасчетов,
				Объект.ВалютаВзаиморасчетов,
				Строка(Формат(Объект.КурсЧислительВзаиморасчетов, "ЧДЦ=4")),
				Объект.ВалютаДокумента));
		Иначе
			СтрокиНадписи.Добавить(СтрШаблон(ШаблонКурса,
				Объект.КурсЗнаменательВзаиморасчетов,
				Объект.ВалютаДокумента,
				Строка(Формат(Объект.КурсЧислительВзаиморасчетов, "ЧДЦ=4")),
				Объект.ВалютаВзаиморасчетов));
		КонецЕсли;
	КонецЕсли;

	Возврат СтрСоединить(СтрокиНадписи, " ");
	
КонецФункции

&НаСервере
Процедура СформироватьКурсЗнаменательТекстом()

	Данные = Новый Структура;
	Данные.Вставить("КурсЗнаменательВзаиморасчетовНадпись", КурсЗнаменательВзаиморасчетовНадпись);
	Данные.Вставить("КурсЧислительВзаиморасчетов", 			Объект.КурсЧислительВзаиморасчетов);
	Данные.Вставить("КурсЗнаменательВзаиморасчетов", 		Объект.КурсЗнаменательВзаиморасчетов);
	Данные.Вставить("ВалютаВзаиморасчетов",					Объект.ВалютаВзаиморасчетов);
	Данные.Вставить("КурсЧислительВзаиморасчетовТекст",		"");
	
	ДенежныеСредстваКлиентСервер.СформироватьКурсЗнаменательТекстом(Данные, Объект.ВалютаДокумента, ВалютаРеглУчета);

	КурсЗнаменательВзаиморасчетовНадпись = Данные.КурсЗнаменательВзаиморасчетовНадпись;
	
КонецПроцедуры

&НаСервере
Процедура УправлениеФормой()

	бит_НастройкиДоступностиЭлементовФорм.РазблокироватьЭлементы(ЭтотОбъект);
	
	ДокументВВалюте = Объект.ВалютаДокумента <> ВалютаРеглУчета;
	ОплатаЧерезБанк = (Объект.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные);
	ЭтоОперацияБезВалютыВзаиморасчетов = бит_КазначействоКлиентСервер.ЭтоОперацияБезВалютыВзаиморасчетов(ХозяйственнаяОперация);
	
	#Область НДС
	Если ЗначениеЗаполнено(ХозяйственнаяОперация) Тогда
		ОперацияБезНДС = бит_Казначейство.ОперацияБезНДС(ХозяйственнаяОперация);
	Иначе
		ОперацияБезНДС = Ложь;
	КонецЕсли;
	
	Элементы.СтавкаНДС.Видимость = НЕ ОперацияБезНДС;
	Элементы.СуммаНДС.Видимость	 = НЕ ОперацияБезНДС;
	Элементы.ВалютаНДС.Видимость = НЕ ОперацияБезНДС;
	
	Если НЕ ОперацияБезНДС Тогда
		Элементы.СтавкаНДС.Доступность = ЭтоПланируемоеПоступление;
		Элементы.СуммаНДС.Доступность  = ЭтоПланируемоеПоступление;
	КонецЕсли;
	#КонецОбласти 
	
	Если ЭтоПланируемоеПоступление Тогда
	
		ЕстьОснование  = ЗначениеЗаполнено(Объект.ДокументПланирования);
		ЭтоПрогноз     = Объект.ВидПлана = Перечисления.бит_кзн_ВидыПланов.Прогноз;
		
		// Если ввод не списком, показываем номер заявки, а не позиции.
		Элементы.Номер.Видимость 	   = НЕ ЭтоРежимЗаявки;
		Элементы.НомерЗаявки.Видимость = ЭтоРежимЗаявки;
		
		// Устанавливаем видимость команд группы СоздатьНаОсновании.
		Элементы.ФормаВвестиПланируемоеПоступленияДС.Видимость = ЭтоПрогноз;
		Элементы.ФормаВвестиДокументПоступленияДС.Видимость = Не ЭтоПрогноз;
		
		// Не даем возможность выбирать документ планирования.
		Элементы.ДокументПланирования.Видимость = НЕ ЭтоРежимЗаявки;

		// Реквизиты, заполняемые в документе-основании.
		Элементы.Организация.ТолькоПросмотр       = НЕ ЭтоРежимЗаявки;
		Элементы.Контрагент.ТолькоПросмотр        = НЕ ЭтоРежимЗаявки;
		Элементы.ФормаОплаты.ТолькоПросмотр       = НЕ ЭтоРежимЗаявки;
		Элементы.Ответственный.ТолькоПросмотр     = НЕ ЭтоРежимЗаявки;
		Элементы.Инициатор.ТолькоПросмотр         = НЕ ЭтоРежимЗаявки;
		
		#Область Валюты
		ВалютыСовпадают 				   = Объект.ВалютаДокумента = Объект.ВалютаВзаиморасчетов;
		ЗаблокироватьВалюту 			   = Истина;
		ЗаблокироватьВалютуВзаиморасчетов  = Ложь;
		ИсточникВалютыВзаиморасчетовВыбран = ЗначениеЗаполнено(Объект.ОбъектРасчетов) 
										 ИЛИ ЗначениеЗаполнено(Объект.Договор);										 
		
		Если Объект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
			ЗаблокироватьВалюту = Истина;
		Иначе	
			Если НЕ ЭтоРежимЗаявки Тогда
				ЗаблокироватьВалюту = Истина;
			Иначе	
				ЗаблокироватьВалюту = ИсточникВалютыВзаиморасчетовВыбран;
			КонецЕсли;
		КонецЕсли;	
		
		Если Объект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов Тогда
			ЗаблокироватьВалютуВзаиморасчетов = Истина;	
		Иначе	
			ЗаблокироватьВалютуВзаиморасчетов = ИсточникВалютыВзаиморасчетовВыбран;
		КонецЕсли;		
		
		Элементы.СуммаВзаиморасчетов.ТолькоПросмотр    			= ВалютыСовпадают;
		Элементы.СуммаВзаиморасчетов.Видимость					= НЕ ЭтоОперацияБезВалютыВзаиморасчетов; 
		Элементы.Валюта.ТолькоПросмотр 							= ЗаблокироватьВалюту;
		Элементы.ВариантКурсаДоговора.Видимость 	   			= НЕ ВалютыСовпадают;
		Элементы.КурсЧислительВзаиморасчетов.Видимость 			= НЕ ВалютыСовпадают;
		Элементы.КурсЗнаменательВзаиморасчетовНадпись.Видимость = НЕ ВалютыСовпадают;
		Элементы.ДекорацияВалютыИКурсПлатежа.Видимость 			= НЕ ВалютыСовпадают;
		Элементы.ВалютаВзаиморасчетов.ТолькоПросмотр 			= ЗаблокироватьВалютуВзаиморасчетов;
		Элементы.ВалютаВзаиморасчетов.Видимость		 			= НЕ ЭтоОперацияБезВалютыВзаиморасчетов;
		Элементы.ПланированиеСуммы.ТолькоПросмотр	 			= ЭтоОперацияБезВалютыВзаиморасчетов ИЛИ НЕ ЭтоРежимЗаявки;
		#КонецОбласти
		
		// Переход в список имеет смысл только если позиция открыта как псевдо-заявка.
		Элементы.ФормаКомандаСписок.Видимость = ЭтоРежимЗаявки;
		
		// Видимость Назначения платежа если позиция открыта как псевдо-заявка.
		Элементы.НазначениеПлатежа.Видимость = ЭтоРежимЗаявки;
		Элементы.НазначениеПлатежаУпр.Видимость = ЭтоРежимЗаявки;
		
		// Видимость Банк/Касса.
		Элементы.БанковскийСчет.Видимость = ОплатаЧерезБанк;
		Элементы.Касса.Видимость 		  = НЕ ОплатаЧерезБанк;
		
		// Видимость Контрагент/Договор.
		Элементы.Контрагент.Видимость = Истина;
				
		Элементы.ФормаПровестиИЗакрыть.Видимость         = РазрешеноПроводить И ЭтоРежимЗаявки;
		Элементы.ФормаПровести.Видимость                 = РазрешеноПроводить И ЭтоРежимЗаявки;
		Элементы.ФормаПровестиИЗакрыть.КнопкаПоУмолчанию = РазрешеноПроводить И ЭтоРежимЗаявки;
		
		ТекстЗаголовка = ?(Объект.ОтправленНаСогласование, 
							НСтр("ru='Отозвать';en='Revoke'"), НСтр("ru='На согласование';en='For Approval'"));
							
		Элементы.ФормаКомандаНаСогласование.Видимость         = НЕ РазрешеноПроводить И ЭтоРежимЗаявки;
		Элементы.ФормаКомандаНаСогласование.КнопкаПоУмолчанию = НЕ РазрешеноПроводить И ЭтоРежимЗаявки;		
		Элементы.ФормаКомандаНаСогласование.Заголовок         = ТекстЗаголовка;
		Элементы.ФормаКомандаНаСогласование.Доступность       = НЕ Объект.Проведен;	
		
		Если ТипСтатуса <> Перечисления.бит_ТипыСтатусовОбъектов.Утвержден
			И ТипСтатуса <> Перечисления.бит_ТипыСтатусовОбъектов.НаСогласовании
			И ТипСтатуса <> Перечисления.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен Тогда
			Элементы.ФормаВвестиДокументПоступленияДС.Доступность = Ложь;
		Иначе
			Элементы.ФормаВвестиДокументПоступленияДС.Доступность = Истина;
		КонецЕсли;
		
		Элементы.Подразделение.Видимость = ИспользоватьПодразделения;
		
		// Проверка заполнения Банковского счета.
		ДоговорОбъектаРасчетов = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ОбъектРасчетов, "Договор");
		Элементы.БанковскийСчет.АвтоОтметкаНезаполненного = НЕ ЗначениеЗаполнено(ДоговорОбъектаРасчетов);
		Элементы.БанковскийСчет.ОтметкаНезаполненного     = НЕ ЗначениеЗаполнено(ДоговорОбъектаРасчетов);
		
	Иначе
		
		Элементы.БанковскийСчет.ТолькоПросмотр  =  Истина;
		Элементы.Касса.ТолькоПросмотр 			=  Истина;
	
		Элементы.БанковскийСчет.Видимость = ОплатаЧерезБанк;
		Элементы.БанковскийСчет.Заголовок = НСтр("ru = 'Получатель'");
		Элементы.Касса.Видимость		  = НЕ ОплатаЧерезБанк;
		Элементы.Касса.Заголовок		  = НСтр("ru = 'Получатель'");
		
		Элементы.БанковскийСчет.АвтоОтметкаНезаполненного = Истина;
		Элементы.Касса.АвтоОтметкаНезаполненного		  = Истина;
		
		Элементы.ДокументПланирования.ТолькоПросмотр  =  Истина;
		Элементы.Организация.ТолькоПросмотр			  =  Истина;
		Элементы.ЦФО.ТолькоПросмотр					  =  НЕ ЭтоЗаявкаНаПереводСредств;
		Элементы.СуммаДокумента.ТолькоПросмотр		  =  Истина;
		Элементы.Подразделение.Видимость 			  = Ложь;
		
		#Область Валюты
		Элементы.СуммаВзаиморасчетов.Видимость    				= Ложь;
		Элементы.ВариантКурсаДоговора.Видимость 	   			= Ложь;
		Элементы.КурсЧислительВзаиморасчетов.Видимость 			= Ложь;
		Элементы.КурсЗнаменательВзаиморасчетовНадпись.Видимость = Ложь;
		Элементы.ДекорацияВалютыИКурсПлатежа.Видимость 			= Ложь;
		Элементы.ВалютаВзаиморасчетов.Видимость		 			= Ложь;
		Элементы.ПланированиеСуммы.Видимость	 				= Ложь;		
		Элементы.Валюта.ТолькоПросмотр	 						= Истина;		
		#КонецОбласти
		
		Элементы.ФормаОплаты.ТолькоПросмотр			= Истина;
		Элементы.Контрагент.Видимость				= Ложь;
		Элементы.ОбъектРасчетов.Видимость 			= Ложь;
		Элементы.Договор.Видимость 					= Ложь;
		Элементы.ОснованиеПлатежа.Видимость 		= Ложь;
		Элементы.ТипПлатежа.Видимость 				= Ложь;
		Элементы.ДоговорКредитаДепозита.Видимость	= Ложь;
		Элементы.БанковскийСчетПолучателя.Видимость	= Ложь;

		Элементы.ФормаКомандаСписок.Видимость = Ложь;
		Элементы.ФормаОбработкабит_РезультатПроведенияРезультатПроведенияКнопка.Видимость = Ложь;
		Элементы.ФормаКомандаНаСогласование.Видимость = Ложь;
		Элементы.ФормаВвестиПланируемоеПоступленияДС.Видимость = Ложь;
		Элементы.ФормаВвестиДокументПоступленияДС.Видимость = Ложь;
		
		Элементы.ФормаПровестиИЗакрыть.Видимость         = Ложь;
		Элементы.ФормаПровести.Видимость                 = Ложь;
		Элементы.ФормаПровестиИЗакрыть.КнопкаПоУмолчанию = Ложь;
		
		Счетчик 		  = 12;
		ПоказатьАналитики = Ложь;
		Пока Счетчик >= 1 Цикл
			ИмяЭлемента = "Аналитика_" + Счетчик;
			ПоказатьАналитики = Макс(Элементы[ИмяЭлемента].Видимость, ПоказатьАналитики);	
			Счетчик = Счетчик - 1;
		КонецЦикла;
		Если ПоказатьАналитики Тогда
			Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.ЗакладкиСверху;
		Иначе	
			Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;
		КонецЕсли;
	КонецЕсли;	

	Если (ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВозвратДенежныхСредствВДругуюОрганизацию
		И ИспользоватьДоговорыМеждуОрганизациями 
	  ИЛИ ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ОплатаДенежныхСредствВДругуюОрганизацию
		И ИспользоватьДоговорыМеждуОрганизациями
	ИЛИ (ИспользоватьДоговорыСКлиентами ИЛИ ИспользоватьДоговорыСПоставщиками)) Тогда
		
		Элементы.Договор.ТолькоПросмотр = ЗначениеЗаполнено(Объект.ОбъектРасчетов);	
	Иначе
		Элементы.Договор.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.ДокументОснование.Видимость = ЗначениеЗаполнено(Объект.ДокументОснование);
	
	Элементы.ГруппаДокументыПоступления.Видимость = ПравоДоступа("Просмотр", Метаданные.Документы.ПоступлениеБезналичныхДенежныхСредств)
		ИЛИ ПравоДоступа("Просмотр", Метаданные.Документы.ПриходныйКассовыйОрдер);
		
	бит_НастройкиДоступностиЭлементовФорм.ЗаблокироватьЭлементы(ЭтотОбъект);
	
КонецПроцедуры // УправлениеЭлементамиФормы()

&НаСервере
Процедура ОснованиеПлатежаОбработкаВыбораНаСервере(ВыбранноеЗначение)

	ДополнитьВыбранноеЗначение(ВыбранноеЗначение);
	
	ИсключаемыеСвойства = Новый Массив;
	Если ВыбранноеЗначение.Свойство("Дата") Тогда
		ИсключаемыеСвойства.Добавить("Дата");	
	КонецЕсли;
	Если ВыбранноеЗначение.Свойство("Номер") Тогда
		ИсключаемыеСвойства.Добавить("Номер");	
	КонецЕсли;
	
	ТекущийДоговор = Объект.Договор;
	ТекущаяВалюта  = Объект.ВалютаДокумента;
	
	ЗаполнитьЗначенияСвойств(Объект, ВыбранноеЗначение, , СтрСоединить(ИсключаемыеСвойства, ","));
	
	Модифицированность = Истина;
	
	Если ТекущийДоговор <> Объект.Договор Тогда
		ДоговорПриИзмененииНаСервере();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение.ВалютаВзаиморасчетов) 
	   И ТекущаяВалюта <> ВыбранноеЗначение.ВалютаВзаиморасчетов Тогда
		Объект.ВалютаДокумента = ВыбранноеЗначение.ВалютаВзаиморасчетов;
		ОбработатьИзмененииВалюты();
	КонецЕсли;
	
	РассчитатьСуммуНДС();
	ПриИзмененииПоставляемыхРеквизитов(Объект.ОбъектРасчетов);

КонецПроцедуры

&НаКлиенте
Процедура ДокументОплатыНажатие(Элемент)

	ДокументыОплаты = НайтиДокументыОплаты();

    Для Каждого Документ Из ДокументыОплаты Цикл
		Если Строка(Документ) = Элемент.Заголовок Тогда
			ОткрытьЗначение(Документ);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры // ДокументОплатыНажатие() 

