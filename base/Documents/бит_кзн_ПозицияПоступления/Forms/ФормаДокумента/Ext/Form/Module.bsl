&НаКлиенте
Процедура КомандаСписок(Команда)
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) ИЛИ Модифицированность Тогда
		ПредложитьЗаписатьДокумент();
	Иначе
		ОткрытьФормуПланируемоеПоступлениеДС();
	КонецЕсли; 
	
КонецПроцедуры
 
&НаКлиенте
Процедура КомандаНаСогласование(Команда)
	
	Если НЕ ЭтоРежимЗаявки И НЕ Элементы.ФормаКомандаНаСогласование.Заголовок = НСтр("ru='Отозвать';en='Revoke'") Тогда
		ТекстСообщения = НСтр("ru='В режиме списка платежную позицию запрещено отправлять на согласование.';
						  	  |en='In list mode, the position of payment allowed to send for approval.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Отказ = Истина;
	Иначе 
		
		Объект.ОтправленНаСогласование = НЕ Объект.ОтправленНаСогласование;
		Попытка			
			Записано = Записать();			
		Исключение			
			Записано = Ложь;			
		КонецПопытки;
		
		Если Записано Тогда			
			Если НЕ Объект.ОтправленНаСогласование Тогда				
				ОчиститьВсеВизы();				
			КонецЕсли;			
		Иначе			
		 	// Объект не удалось записать - возвращаем признак в исходное состояние.
		 	Объект.ОтправленНаСогласование = НЕ Объект.ОтправленНаСогласование;			
		КонецЕсли; 
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаСкопировать(Команда)
	
	Если Модифицированность ИЛИ НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда		
		ТекстСообщения =  НСтр("ru='Объект не записан.';en='The object is not recorded.'");
		Предупреждение(ТекстСообщения, 15);	
	Иначе		
		ПараметрыФормы = Новый Структура;
		Если ЭтоРежимЗаявки Тогда
			ПараметрыФормыПозиции = ПараметрыФормыПриКопировании(Объект.ДокументПланирования);
			ПараметрыФормы.Вставить("ЗначенияЗаполнения", ПараметрыФормыПозиции.ЗначенияЗаполнения);
		Иначе	
			ПараметрыФормы.Вставить("ЗначениеКопирования", Объект.Ссылка);
		КонецЕсли;
		ОткрытьФорму("Документ.бит_кзн_ПозицияПоступления.ФормаОбъекта", ПараметрыФормы);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВвестиДокументПоступленияДС(Команда)
	
	Если Модифицированность Тогда
		ТекстСообщения = НСтр("ru = 'Данные были изменены. Сохраните изменения.'"); 
		ПоказатьПредупреждение(,ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	НовыеДокументы = СоздатьДокументПоступления();
	
	Для каждого Документ Из НовыеДокументы Цикл
		НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(Документ);
		ПерейтиПоНавигационнойСсылке(НавигационнаяСсылка);
	КонецЦикла;
	
КонецПроцедуры

