	Документ.МоментВремени КАК МоментВремени,
	ВЫБОР
		КОГДА НаличиеПрисоединенныхФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА 0
		КОГДА НаличиеПрисоединенныхФайлов.ЕстьФайлы
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЕстьФайлы,
	ВЫБОР
		КОГДА Документ.РучнаяКорректировка = ИСТИНА
			ТОГДА ВЫБОР
					КОГДА Документ.ПометкаУдаления = ИСТИНА
