
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
		
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
	НаименованиеТаблицы = НСтр("ru = 'Увеличение лимита'; en = 'Increasing the limit'");
	бит_УправлениеДоступомБФ.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект.УвеличениеЛимита, НаименованиеТаблицы);
	
	НаименованиеТаблицы = НСтр("ru = 'Уменьшение лимита'; en = 'Limit reduction'");
	бит_УправлениеДоступомБФ.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект.УменьшениеЛимита, НаименованиеТаблицы);
	
	ПодготовитьФормуНаСервере();
	
	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект);
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	бит_УправлениеДоступомБФ.ПриСозданииНаСервере(ЭтотОбъект);
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	ДополнительныеПараметры.Вставить("ОтложеннаяИнициализация", Истина);
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства
	
	// СтандартныеПодсистемы.ОбновлениеВерсииИБ
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ОбновлениеВерсииИБ
	
	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаОбъектаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);

	Если Отказ Тогда
		Возврат;
	КонецЕсли;
				
		
	Если Объект.УвеличениеЛимита.Количество() > 0 ИЛИ Объект.УменьшениеЛимита.Количество() > 0 Тогда
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаЛимиты;
	КонецЕсли;
	
	Если Параметры.Ключ.Пустая() Тогда
		ПодготовитьФормуНаСервере();
	КонецЕсли;
	
	// Восстановим настройки формы.
	ВосстановитьНастройки();
	
	Элементы.ФормаКомандаАвтовидимостьКолонок.Пометка = АвтовидимостьКолонок;
	
	УстановитьАвтовидимостьКолонок();

	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект, СтандартнаяОбработка);
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если НЕ ЗавершениеРаботы И СохранитьНастройкиФормы Тогда
		СохранитьНастройкиНаСервере();
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	Если СохранитьНастройкиФормы Тогда
		СохранитьНастройкиНаСервере();
	КонецЕсли;
	
	ПодготовитьФормуНаСервере();
	
	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект);
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ИсточникВыбора.ВладелецФормы = ЭтотОбъект Тогда
		ТекущиеДанные = Элементы.УвеличениеЛимита.ТекущиеДанные;
		Если ТекущиеДанные <> Неопределено Тогда
			КлючСтроки = ТекущиеДанные.КлючСтроки;
		Иначе
			КлючСтроки = "";
		КонецЕсли;
		Результат = Ложь;
		ОбработкаВыбораПодборНаСервере(ВыбранноеЗначение, КлючСтроки, Результат);
		
		Если Результат = Истина Тогда
			// Обновление отбора и итогов.
			УстановитьОтборСтрок(ЭтотОбъект, ТекущиеДанные);
			ЗаполнитьИтогиСвязанныхСтрок();
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
		
	Если ПараметрыЗаписи.РежимЗаписи = ПредопределенноеЗначение("РежимЗаписиДокумента.Проведение") Тогда
		КлючеваяОперация = "Проведениебит_КорректировкаКонтрольныхЗначений";
		ОценкаПроизводительностиКлиент.ЗамерВремени(КлючеваяОперация);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если Источник = УникальныйИдентификатор Тогда
		Если ИмяСобытия = "ИзмененСтатус" Тогда	
			ОбработкаОповещенияИзмененияСтатуса();
		КонецЕсли; 
	КонецЕсли; 
	
	// СтандартныеПодсистемы.Свойства 
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтотОбъект, ИмяСобытия, Параметр) Тогда
		ОбновитьЭлементыДополнительныхРеквизитов();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры	

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ИнформацияСтатусНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Фильтр 		   = Новый Структура("Объект", Объект.Ссылка);
	ПараметрыФормы = Новый Структура("Отбор", Фильтр);
	ОткрытьФорму("РегистрСведений.бит_ИсторияИзмененияСтатусовОбъектов.ФормаСписка", 
		ПараметрыФормы, ЭтотОбъект, ЭтотОбъект,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура СценарийПриИзменении(Элемент)
	
	Если Объект.Сценарий <> ТекущийСценарий Тогда 
		
		// Очищать таблицу Увеличение большого смысла нет
		// , т.к. эту таблицу можно заполнить руками как угодно, поэтому очищаем только Уменьшение.		
		Если Объект.УменьшениеЛимита.Количество() <> 0 Тогда
			Если Объект.ВидКорректировки = ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет") Тогда
				НазваниеТаблицы = НСтр("ru='За счет';en='At the expense of'");
			Иначе
				НазваниеТаблицы = НСтр("ru = 'Уменьшение лимита'; en = 'Limit reduction'");
			КонецЕсли;
			ОповещениеВопрос = Новый ОписаниеОповещения("СценарийПриИзмененииЗавершение", ЭтотОбъект);
			
			ТекстСообщения = НСтр("ru='Таблица ""%1"" будет очищена. Продолжить?';
									|en='Table ""%1"" is cleared. Proceed?'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, НазваниеТаблицы);
			ПоказатьВопрос(ОповещениеВопрос, ТекстСообщения, РежимДиалогаВопрос.ДаНет, 15, КодВозвратаДиалога.Нет)
		Иначе
			ПрочитатьРеквизитыСценария(Объект.Сценарий);
			УстановитьКонтролируемыйСценарий();
		КонецЕсли;
		
	Иначе
		ПрочитатьРеквизитыСценария(Объект.Сценарий);
		УстановитьКонтролируемыйСценарий();
	КонецЕсли;
	
КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура СценарийПриИзмененииЗавершение(Ответ, Дополнительно) Экспорт

	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Объект.Сценарий = ТекущийСценарий;
	Иначе
		Объект.УменьшениеЛимита.Очистить();
		
		ЗаполнитьИтогиСвязанныхСтрок();
		УстановитьКонтролируемыйСценарий();
		ПрочитатьРеквизитыСценария(Объект.Сценарий);
	КонецЕсли;
	
	ТекущийСценарий = Объект.Сценарий;
	
КонецПроцедуры

&НаКлиенте
Процедура ВидКорректировкиПриИзменении(Элемент)
	
	Если Объект.ВидКорректировки = ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет")
		И Объект.ВидКорректировки <> ТекущийВидКорректировки Тогда		
		
		Если ЗначениеЗаполнено(Объект.УменьшениеЛимита) Тогда
			Дополнительно = Новый Структура; 
			Дополнительно.Вставить("ТекущийВидКорректировки", ТекущийВидКорректировки);
			ОповещениеВопрос = Новый ОписаниеОповещения("ВопросВидКорректировкиПриИзменении", ЭтотОбъект, Дополнительно);
			ТекстВопроса = НСтр("ru = 'Таблица ""Уменьшение лимита"" будет очищена. Продолжить?'");
			ПоказатьВопрос(ОповещениеВопрос, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		Иначе
			УправлениеФормой(ЭтотОбъект);
			ТекущийВидКорректировки = Объект.ВидКорректировки;
		КонецЕсли;
	Иначе
		УправлениеФормой(ЭтотОбъект);
		ТекущийВидКорректировки = Объект.ВидКорректировки;
	КонецЕсли;
	
КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
// 
&НаКлиенте
Процедура ВопросВидКорректировкиПриИзменении(Ответ, Дополнительно) Экспорт
			
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Объект.ВидКорректировки = Дополнительно.ТекущийВидКорректировки;
	Иначе
		Объект.УменьшениеЛимита.Очистить();
		УправлениеФормой(ЭтотОбъект);
		ТекущийВидКорректировки = Объект.ВидКорректировки;
		ЗаполнитьИтогиСвязанныхСтрок();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ДокументОснованиеНажатие(Элемент, СтандартнаяОбработка)
	
	ПоказатьЗначение(, Объект.ДокументОснование);
	
КонецПроцедуры

&НаКлиенте 
Процедура ВидКонтроляПриИзменении(Элемент)
	
	Если ТекущийВидКонтроля = Объект.ВидКонтроля Тогда
		Возврат;
	КонецЕсли;
	   	
	УстановитьКонтролируемыйСценарий();

	Объект.УвеличениеЛимита.Очистить();
	Объект.УменьшениеЛимита.Очистить();
	
	Объект.ВидКорректировки  = ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет");
	Объект.НастройкаКонтроля = ПредопределенноеЗначение("Документ.бит_УстановкаКонтрольныхЗначений.ПустаяСсылка");
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "КонтрольБанковскийСчет") Тогда
		КонтрольБюджета = ПредопределенноеЗначение("Перечисление.бит_РежимыКонтроляПоБюджету.Бюджет");
		Если Объект.ВидКонтроля <> КонтрольБюджета Тогда
			Объект["КонтрольБанковскийСчет"] = Ложь;
			РезультатПоиска = НастройкаЗаполнения.НайтиСтроки(Новый Структура("ИмяРеквизита", "КонтрольБанковскийСчет"));
			Для каждого СтрокаТаблицы Из НастройкаЗаполнения Цикл
				Если СтрокаТаблицы.ИмяРеквизита = "КонтрольБанковскийСчет" Тогда
					СтрокаТаблицы.ИспользоватьРазрез = Ложь;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);
	
	ТекущийВидКонтроля		= Объект.ВидКонтроля;
	ТекущийВидКорректировки = Объект.ВидКорректировки;
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппаСтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	// СтандартныеПодсистемы.Свойства
	Если ЭтотОбъект.ПараметрыСвойств.Свойство(ТекущаяСтраница.Имя)
		И Не ЭтотОбъект.ПараметрыСвойств.ВыполненаОтложеннаяИнициализация Тогда
		СвойстваВыполнитьОтложеннуюИнициализацию();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
		УправлениеФормой(ЭтотОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаКлиенте
Процедура ПроизвольнаяПериодичностьКонтроляПриИзменении(Элемент)
	
	Если Объект.ПроизвольнаяПериодичностьКонтроля Тогда
		Объект.ДатаНачалаКонтроля	 = Объект.Дата;
		Объект.ДатаОкончанияКонтроля = Объект.Дата;		
		Объект.ПериодичностьКонтроля = ПредопределенноеЗначение("Перечисление.бит_ПериодичностьПланирования.ПустаяСсылка");
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодичностьКонтроляПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(Объект.ДатаНачалаКонтроля) Тогда
		Объект.ДатаНачалаКонтроля 	 = Объект.Дата;
		Объект.ДатаОкончанияКонтроля = Объект.Дата;
	КонецЕсли;
	УстановитьГраницыКонтроля();
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаКонтроляПриИзменении(Элемент)
	
	Если Объект.ДатаНачалаКонтроля > Объект.ДатаОкончанияКонтроля Тогда
		Объект.ДатаОкончанияКонтроля = Объект.ДатаНачалаКонтроля;
	КонецЕсли;
	УстановитьГраницыКонтроля();
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаОкончанияКонтроляПриИзменении(Элемент)
	
	Если Объект.ДатаНачалаКонтроля > Объект.ДатаОкончанияКонтроля Тогда
		Объект.ДатаНачалаКонтроля = Объект.ДатаОкончанияКонтроля;
	КонецЕсли;
	УстановитьГраницыКонтроля();
	
КонецПроцедуры

&НаКлиенте
Процедура СпособУстановкиРазрезовКонтроляПриИзменении(Элемент)
	
	УправлениеФормой(ЭтотОбъект);
	
	Для каждого СтрокаТаблицы Из Объект.УвеличениеЛимита Цикл
		Для каждого Запись Из КолонкиКонтроля Цикл
			СтрокаТаблицы[Запись.Значение] = Ложь;		
		КонецЦикла;	
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаКонтроляНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Отбор 		   = Новый Структура("ВидКонтроля", Объект.ВидКонтроля);
	ПараметрыФормы = Новый Структура("Отбор, ТекущаяСтрока", Отбор, Объект.НастройкаКонтроля);

	ОткрытьФорму("Документ.бит_УстановкаКонтрольныхЗначений.ФормаВыбора", ПараметрыФормы, Элемент, ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыУвеличениеЛимита

#Область ПодключаемыеКоманды

&НаКлиенте
Процедура Подключаемый_АналитикаСтрокиПриходПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.УвеличениеЛимита.ТекущиеДанные;
	ИмяПоля 	  = СтрЗаменить(Элемент.Имя, "УвеличениеЛимита", "");
	ИмяФлажка 	  = "УвеличениеЛимитаКонтроль" + ИмяПоля;
	ЭлементФормы  = Элементы.Найти(ИмяФлажка); 
	Если ЭлементФормы <>  Неопределено И НЕ ЭлементФормы.ТолькоПросмотр Тогда
		ТекущиеДанные["Контроль" + ИмяПоля] = Истина;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_АналитикаСтрокиПриходНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.УвеличениеЛимита.ТекущиеДанные;
	ИмяПоля 	  = СтрЗаменить(Элемент.Имя, "УвеличениеЛимита", "");
	Если бит_МеханизмДопИзмеренийКлиент.ЭтоАналитикаБанковскийСчет(ИмяПоля, КэшЗначений.НастройкиИзмерений) Тогда
	  	бит_РаботаСДиалогамиКлиент.ВыбратьБанковскийСчетБезВладельца(ТекущиеДанные, СтандартнаяОбработка, ИмяПоля);	
	Иначе	
		бит_МеханизмДопИзмеренийКлиент.ВыбратьТипСоставнойАналитики(ЭтотОбъект, Элемент, ТекущиеДанные, ИмяПоля,
			СтандартнаяОбработка, КэшЗначений.НастройкиИзмерений);
	КонецЕсли;
	
КонецПроцедуры

