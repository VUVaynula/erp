		"НастройкаЗаполнения.ИспользоватьРазрез", ВидСравненияКомпоновкиДанных.Равно, Истина);

	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.бит_ФонПодписьВерна);
	
	// НастройкаЗаполнения.Измерение
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	бит_ОтчетыБФКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НастройкаЗаполненияИзмерение");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"НастройкаЗаполнения.ИмяРеквизита", ВидСравненияКомпоновкиДанных.Равно, "КонтрольБанковскийСчет");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.ВидКонтроля", ВидСравненияКомпоновкиДанных.НеРавно, 
		Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет);

	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", 	ЦветаСтиля.бит_ЦветНедоступногоПоля);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);

	// УвеличениеЛимитаСуммаУменьшение: цвет текста зеленый.
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	бит_ОтчетыБФКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "УвеличениеЛимитаСуммаУменьшение");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.УвеличениеЛимита.Сумма", ВидСравненияКомпоновкиДанных.Равно, 
		Новый ПолеКомпоновкиДанных("Объект.УвеличениеЛимита.СуммаУменьшение"));
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", 	WebЦвета.ЗеленыйЛес);
	
	// УвеличениеЛимитаСуммаУменьшение: цвет текста красный.
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	бит_ОтчетыБФКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "УвеличениеЛимитаСуммаУменьшение");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.УвеличениеЛимита.Сумма", ВидСравненияКомпоновкиДанных.НеРавно, 
		Новый ПолеКомпоновкиДанных("Объект.УвеличениеЛимита.СуммаУменьшение"));
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", 	ЦветаСтиля.ЦветОтрицательногоЧисла);
	
	// УвеличениеЛимитаСуммаУменьшение: по необходимости.
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "УвеличениеЛимитаСуммаУменьшение");
	// АПК:277-вкл
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.УвеличениеЛимита.СтатьяОборотов_Учет_Сумма", ВидСравненияКомпоновкиДанных.Равно, Ложь);

	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.бит_ТекстНедоступнойНадписи);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<не требуется>'; en = '<not required>'"));

	// УвеличениеЛимитаКоличествоУменьшение: цвет текста зеленый.
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	бит_ОтчетыБФКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "УвеличениеЛимитаКоличествоУменьшение");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.УвеличениеЛимита.Количество", ВидСравненияКомпоновкиДанных.Равно, 
		Новый ПолеКомпоновкиДанных("Объект.УвеличениеЛимита.КоличествоУменьшение"));
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", 	WebЦвета.ЗеленыйЛес);
	
	// УвеличениеЛимитаКоличествоУменьшение: цвет текста красный.
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	бит_ОтчетыБФКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "УвеличениеЛимитаКоличествоУменьшение");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.УвеличениеЛимита.Количество", ВидСравненияКомпоновкиДанных.НеРавно, 
		Новый ПолеКомпоновкиДанных("Объект.УвеличениеЛимита.КоличествоУменьшение"));
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", 	ЦветаСтиля.ЦветОтрицательногоЧисла);
	
	// УвеличениеЛимитаКоличествоУменьшение: по необходимости.
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "УвеличениеЛимитаКоличествоУменьшение");
	// АПК:277-вкл
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.УвеличениеЛимита.СтатьяОборотов_Учет_Количество", ВидСравненияКомпоновкиДанных.Равно, Ложь);

	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.бит_ТекстНедоступнойНадписи);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<не требуется>'; en = '<not required>'"));

КонецПроцедуры

&НаСервере
Процедура ДобавитьРеквизитыФормы()
	
	МетаСтатьиОборотов = Метаданные.Справочники.бит_СтатьиОборотов;
	Измерения = бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("произвольные","синоним");
	ОписаниеТипаБулево = Новый ОписаниеТипов("Булево");
	МассивРеквизитов = Новый Массив;
	
	Для Каждого КлючИЗначение Из Измерения Цикл
		ИмяРеквизита = "Учет_"+КлючИЗначение.Ключ;
		Если бит_РаботаСМетаданными.ЕстьРеквизит(ИмяРеквизита,МетаСтатьиОборотов) Тогда  
			ТекущаяНастройка = КэшЗначений.НастройкиИзмерений[КлючИЗначение.Ключ];
			Если Найти(ВРег(КлючИЗначение.Ключ), "АНАЛИТИКА") > 0 Тогда
				Если НЕ ТекущаяНастройка = Неопределено Тогда
					НовыйРеквизит = Новый РеквизитФормы("СтатьяОборотов_"+ИмяРеквизита, ОписаниеТипаБулево, "Объект.УвеличениеЛимита", ТекущаяНастройка.Синоним);
					МассивРеквизитов.Добавить(НовыйРеквизит);
					НовыйРеквизит = Новый РеквизитФормы("СтатьяОборотов_"+ИмяРеквизита, ОписаниеТипаБулево, "Объект.УменьшениеЛимита", ТекущаяНастройка.Синоним);
					МассивРеквизитов.Добавить(НовыйРеквизит);
				КонецЕсли;
				Продолжить;
			КонецЕсли;
			НовыйРеквизит = Новый РеквизитФормы("СтатьяОборотов_"+ИмяРеквизита, ОписаниеТипаБулево, "Объект.УвеличениеЛимита", КлючИЗначение.Значение);
			МассивРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("СтатьяОборотов_"+ИмяРеквизита, ОписаниеТипаБулево, "Объект.УменьшениеЛимита", КлючИЗначение.Значение);
			МассивРеквизитов.Добавить(НовыйРеквизит);
		КонецЕсли;
	КонецЦикла;
	
	// Добавим разрезы по количеству и сумме
	НовыйРеквизит = Новый РеквизитФормы("СтатьяОборотов_Учет_Количество", ОписаниеТипаБулево, "Объект.УвеличениеЛимита", "Количество");
	МассивРеквизитов.Добавить(НовыйРеквизит);
	НовыйРеквизит = Новый РеквизитФормы("СтатьяОборотов_Учет_Количество", ОписаниеТипаБулево, "Объект.УменьшениеЛимита", "Количество");
	МассивРеквизитов.Добавить(НовыйРеквизит);

	НовыйРеквизит = Новый РеквизитФормы("СтатьяОборотов_Учет_Сумма", ОписаниеТипаБулево, "Объект.УвеличениеЛимита", "Сумма");
	МассивРеквизитов.Добавить(НовыйРеквизит);
	НовыйРеквизит = Новый РеквизитФормы("СтатьяОборотов_Учет_Сумма", ОписаниеТипаБулево, "Объект.УменьшениеЛимита", "Сумма");
	МассивРеквизитов.Добавить(НовыйРеквизит);
	
	// Обновим реквизитный состав формы
	ИзменитьРеквизиты(МассивРеквизитов);
	
КонецПроцедуры

&НаСервере
Процедура ИзменениеСтатьиОборотов(Знач ИДСтроки, Знач ПолеОбъекта)
	
	ТекущиеДанные = Объект[ПолеОбъекта].НайтиПоИдентификатору(ИДСтроки);
	
	Если Не ТекущиеДанные.СтатьяОборотов.Учет_Сумма Тогда
		ТекущиеДанные.Сумма = 0;
	КонецЕсли;
	
	Если Не ТекущиеДанные.СтатьяОборотов.Учет_Количество Тогда
		ТекущиеДанные.Количество = 0;
	КонецЕсли;
	
	// Запомним разрезы бюджетирования используемые в статье оборотов.
	ЗаполнитьИспользуемыеРазрезыСтатьиОборотов(ТекущиеДанные, ПолеОбъекта);
	Если ПолеОбъекта = "УвеличениеЛимита" Тогда
		УстановитьАвтовидимостьУвеличениеЛимита();
	Иначе	
		УстановитьАвтовидимостьУменьшениеЛимита()
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИспользуемыеРазрезыСтатьиОборотов(ТекущиеДанные, ПолеОбъекта)
		
	РеквизитыСтатьи = ПолучитьРеквизиты("Объект." + ПолеОбъекта);
	
	Для Каждого РеквизитСтатьи Из РеквизитыСтатьи Цикл
		НайденнаяПозиция = Найти(РеквизитСтатьи.Имя, "СтатьяОборотов_Учет_");
		Если НайденнаяПозиция = 0 Тогда
			Продолжить;
		КонецЕсли;
		ИмяРеквизитаСтатьи = СтрЗаменить(РеквизитСтатьи.Имя, "СтатьяОборотов_", "");
		ТекущиеДанные[РеквизитСтатьи.Имя] = ТекущиеДанные.СтатьяОборотов[ИмяРеквизитаСтатьи];
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьАвтовидимостьКолонок(Знач ОбновлятьБезусловно = Ложь)
	
	УстановитьАвтовидимостьУвеличениеЛимита(ОбновлятьБезусловно);
	УстановитьАвтовидимостьУменьшениеЛимита(ОбновлятьБезусловно);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьАвтовидимостьУвеличениеЛимита(Знач ОбновлятьБезусловно = Ложь)
	
	ПолеОбъекта    = "УвеличениеЛимита";
	ПолеФормы 	   = "УвеличениеЛимита";
	
	УстановитьАвтовидимостьКолонокТабличнойЧасти(ПолеОбъекта, ПолеФормы, ОбновлятьБезусловно); 
	
КонецПроцедуры

&НаСервере
Процедура УстановитьАвтовидимостьУменьшениеЛимита(Знач ОбновлятьБезусловно = Ложь)

	ПолеОбъекта    = "УменьшениеЛимита";
	ПолеФормы 	   = "УменьшениеЛимита";
	
	УстановитьАвтовидимостьКолонокТабличнойЧасти(ПолеОбъекта, ПолеФормы, ОбновлятьБезусловно); 

КонецПроцедуры

&НаСервере
Процедура УстановитьАвтовидимостьКолонокТабличнойЧасти(ПолеОбъекта, ПолеФормы, ОбновлятьБезусловно = Ложь)
	
	КэшСтатей = ЭтотОбъект["Статьи" + ПолеОбъекта].ВыгрузитьЗначения();
	
	СтатьиТаблицы = Новый Массив;
	Для каждого СтрокаТаблицы Из Объект[ПолеОбъекта] Цикл
		Если ЗначениеЗаполнено(СтрокаТаблицы.СтатьяОборотов) Тогда
			СтатьиТаблицы.Добавить(СтрокаТаблицы.СтатьяОборотов);
		КонецЕсли;
	КонецЦикла;
	СтатьиТаблицы = ОбщегоНазначенияКлиентСервер.СвернутьМассив(СтатьиТаблицы);

	Если АвтовидимостьКолонок Тогда
		
		НеобходимоИзменение = бит_РаботаСДиалогамиСервер.НужноИзменитьВидимостьКолонокБюджета(
								СтатьиТаблицы, КэшСтатей, КэшЗначений.НастройкаВидимостиКолонок,
								КэшЗначений.НастройкиИзмерений);
		
		Если НеобходимоИзменение Тогда
			бит_РаботаСДиалогамиСервер.УправлениеВидимостьюКолонокТабличногоПоля(Элементы,
				КэшЗначений.НастройкаВидимостиКолонок, ПолеФормы);
				
			// КоличествоУменьшение, СуммаУменьшение.
			Если ПолеОбъекта = "УвеличениеЛимита" Тогда
				Если Объект.ВидКорректировки = Перечисления.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет Тогда
					Постфикс = "Уменьшение";
					бит_РаботаСДиалогамиСервер.УправлениеВидимостьюКолонокТабличногоПоля(Элементы,
						КэшЗначений.НастройкаВидимостиКолонок, ПолеФормы, Постфикс);
				Иначе
					Элементы.УвеличениеЛимитаСуммаУменьшение.Видимость		= Ложь;
					Элементы.УвеличениеЛимитаКоличествоУменьшение.Видимость = Ложь;
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли; 
	Иначе
		Если ОбновлятьБезусловно Тогда
			бит_РаботаСДиалогамиСервер.УправлениеВидимостьюКолонокТабличногоПоля(Элементы, 
				КэшЗначений.НастройкаВидимостиКолонок, ПолеФормы);

			// КоличествоУменьшение, СуммаУменьшение.
			Если ПолеОбъекта = "УвеличениеЛимита" Тогда
				Если Объект.ВидКорректировки = Перечисления.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет Тогда
					Постфикс = "Уменьшение";
					бит_РаботаСДиалогамиСервер.УправлениеВидимостьюКолонокТабличногоПоля(Элементы,
						КэшЗначений.НастройкаВидимостиКолонок, ПолеФормы, Постфикс);
				Иначе
					Элементы.УвеличениеЛимитаСуммаУменьшение.Видимость		= Ложь;
					Элементы.УвеличениеЛимитаКоличествоУменьшение.Видимость = Ложь;
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли; 
	
	Если АвтовидимостьКолонок Тогда
		ЭтотОбъект["Статьи" + ПолеОбъекта].ЗагрузитьЗначения(СтатьиТаблицы);
	Иначе	
		ЭтотОбъект["Статьи" + ПолеОбъекта].Очистить();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УвеличениеЛимитаПериодПриИзмененииНаСервере(Знач ИДСтроки)
	
	ТекущаяСтрока = Объект.УвеличениеЛимита.НайтиПоИдентификатору(ИДСтроки);
	
	Если ТекущаяСтрока = Неопределено И НЕ ЗначениеЗаполнено(Объект.Сценарий) Тогда
		Возврат;
	КонецЕсли;
	
	// Приводим выбранный период на начало периода в зависимости от реквизита "Периодичность" выбранного сценария.
	ТекущаяСтрока.Период = бит_ОбщегоНазначенияКлиентСервер.ПолучитьНачалоПериода(ТекущаяСтрока.Период, ПериодичностьСценария);
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьРеквизитыСценария(Знач Сценарий)

	РеквизитыСценария = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Сценарий, "бит_Периодичность, Валюта");
	ПериодичностьСценария = РеквизитыСценария.бит_Периодичность;
	ВалютаСценария		  = РеквизитыСценария.Валюта;
	
КонецПроцедуры 

#КонецОбласти

#Область СерверныеПроцедурыИФункцииПоРаботеСНастройками

// Процедура сохраняет настройки формы в хранилища общих настроек.
// 
&НаСервере
Процедура СохранитьНастройкиНаСервере() 
	
	Настройки = Новый Структура;
	Настройки.Вставить("АвтовидимостьКолонок", АвтовидимостьКолонок);
	
	УстановитьПривилегированныйРежим(Истина);
	ХранилищеОбщихНастроек.Сохранить("Документ.бит_КорректировкаКонтрольныхЗначений", "Настройки", Настройки);	
	УстановитьПривилегированныйРежим(Ложь);
	
	СохранитьНастройкиФормы = Ложь;	
	
КонецПроцедуры

// Процедура восстанавливает настройки формы из хранилища общих настроек.
// 
&НаСервере
Процедура ВосстановитьНастройки() 
	
	ЗначениеНастроек = ХранилищеОбщихНастроек.Загрузить("Документ.бит_КорректировкаКонтрольныхЗначений", "Настройки");
	Если ЗначениеЗаполнено(ЗначениеНастроек) И ТипЗнч(ЗначениеНастроек) = Тип("Структура") Тогда
		ЗначениеНастроек.Свойство("АвтовидимостьКолонок", АвтовидимостьКолонок);		
	КонецЕсли;                                                	
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	ТекущийВидКонтроля 		= Объект.ВидКонтроля;
	ТекущийВидКорректировки = Объект.ВидКорректировки;
	ТекущийСценарий 	  	= Объект.Сценарий;

	Если НЕ ФормаИнициализирована Тогда
		ИнициализироватьФорму();
	КонецЕсли;
	
	ЗаполнитьДобавленныеКолонкиТаблиц();
	
	Если ЗначениеЗаполнено(Объект.Сценарий) Тогда
		ПрочитатьРеквизитыСценария(Объект.Сценарий);
	Иначе
		ВалютаСценария = Константы.ВалютаРегламентированногоУчета.Получить();
	КонецЕсли;
	
	УстановитьСостояниеДокумента();
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДобавленныеКолонкиТаблиц()

	// Заполним добавленные реквизиты значениями.
	Для Каждого ТекущаяСтрока Из Объект.УвеличениеЛимита Цикл
		ЗаполнитьИспользуемыеРазрезыСтатьиОборотов(ТекущаяСтрока, "УвеличениеЛимита");
	КонецЦикла;
	
	// Заполним добавленные реквизиты значениями.
	Для Каждого ТекущаяСтрока Из Объект.УменьшениеЛимита Цикл
		ЗаполнитьИспользуемыеРазрезыСтатьиОборотов(ТекущаяСтрока, "УменьшениеЛимита");
	КонецЦикла;

	Если Объект.ВидКорректировки = Перечисления.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет 
	   И Объект.УменьшениеЛимита.Количество() > 0 Тогда
		ЗаполнитьДобавленныеКолонкиИтоговСвязанныхСтрок();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДобавленныеКолонкиИтоговСвязанныхСтрок()
	
	Увеличение = Объект.УвеличениеЛимита.Выгрузить();
	Уменьшение = Объект.УменьшениеЛимита.Выгрузить();
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Увеличение", Увеличение);
	Запрос.УстановитьПараметр("Уменьшение", Уменьшение);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Увеличение.НомерСтроки КАК НомерСтроки,
	|	Увеличение.КлючСтроки КАК КлючСтроки
	|ПОМЕСТИТЬ Увеличение
	|ИЗ
	|	&Увеличение КАК Увеличение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Уменьшение.КлючСтроки КАК КлючСтроки,
	|	Уменьшение.Сумма КАК Сумма,
	|	Уменьшение.Количество КАК Количество
	|ПОМЕСТИТЬ Уменьшение
	|ИЗ
	|	&Уменьшение КАК Уменьшение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Увеличение.НомерСтроки - 1 КАК ИндексСтроки,
	|	СУММА(Уменьшение.Сумма) КАК СуммаУменьшение,
	|	СУММА(Уменьшение.Количество) КАК КоличествоУменьшение
	|ИЗ
	|	Увеличение КАК Увеличение
	|		ЛЕВОЕ СОЕДИНЕНИЕ Уменьшение КАК Уменьшение
	|		ПО Увеличение.КлючСтроки = Уменьшение.КлючСтроки
	|
	|СГРУППИРОВАТЬ ПО
	|	Увеличение.НомерСтроки - 1";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаТаблицы = Объект.УвеличениеЛимита[Выборка.ИндексСтроки];
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Выборка);
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьИтогиСвязанныхСтрок()
	
	Если Объект.ВидКорректировки <> ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет") Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.УменьшениеЛимита.Количество() = 0 Тогда
		Для каждого СтрокаТаблицы Из Объект.УвеличениеЛимита Цикл
			СтрокаТаблицы.СуммаУменьшение	   = 0;	
			СтрокаТаблицы.КоличествоУменьшение = 0;
		КонецЦикла;
	Иначе
		ТекущиеДанные = Элементы.УвеличениеЛимита.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		КлючСтроки = ТекущиеДанные.КлючСтроки;
		ТекущиеДанные.СуммаУменьшение	   = 0;
		ТекущиеДанные.КоличествоУменьшение = 0;
		
		Для каждого СтрокаТаблицы Из Объект.УменьшениеЛимита Цикл
			Если СтрокаТаблицы.КлючСтроки = КлючСтроки Тогда
				ТекущиеДанные.СуммаУменьшение	   = ТекущиеДанные.СуммаУменьшение + СтрокаТаблицы.Сумма;
				ТекущиеДанные.КоличествоУменьшение = ТекущиеДанные.КоличествоУменьшение + СтрокаТаблицы.Количество;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПостоянныеРеквизитыТаблицы()

	РеквизитыТаблицыМД = Метаданные.Документы.бит_КорректировкаКонтрольныхЗначений.ТабличныеЧасти.УвеличениеЛимита.Реквизиты;
	Для каждого РеквизитМД Из РеквизитыТаблицыМД Цикл
		ПостоянныеРеквизитыТаблицы.Добавить(РеквизитМД.Имя);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьФорму()

	ЗаполнитьКэшЗначений();	

	ПроводитьПослеУтверждения = ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения");

	// Добавление элементов управления в табличных полях.
	бит_РаботаСДиалогамиПереопределяемый.СоздатьЭлементыУправленияКорректировкаКонтрольныхЗначений(Элементы, 
		"УвеличениеЛимита", "УвеличениеЛимита", Элементы.УвеличениеЛимитаСумма);

	бит_РаботаСДиалогамиПереопределяемый.СоздатьЭлементыУправления(Элементы, "УменьшениеЛимита", 
		"УменьшениеЛимита", Элементы.УменьшениеЛимитаСумма);																					 
	
	// Отображение дополнительных измерений в табличных полях.
	бит_МеханизмДопИзмерений.ПоказатьДополнительныеИзмеренияВТабличномПоле(ЭтотОбъект,
		"УвеличениеЛимита", КэшЗначений.ИзмеренияДоп, КэшЗначений.НастройкиИзмерений);
	
	бит_МеханизмДопИзмерений.ПоказатьДополнительныеИзмеренияВТабличномПоле(ЭтотОбъект,
		"УменьшениеЛимита", КэшЗначений.ИзмеренияДоп, КэшЗначений.НастройкиИзмерений);
	
	// Заполним список колонок с флажками "контролировать".
	ВывестиКонтрольРазрезов(КэшЗначений.ИзмеренияДоп, КэшЗначений.НастройкиИзмерений);
	ЗаполнитьПостоянныеРеквизитыТаблицы();

	ДобавитьРеквизитыФормы();
	
	УстановитьУсловноеОформление();

	ФормаИнициализирована = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьГраницыКонтроля()

	Объект.ДатаНачалаКонтроля = бит_ОбщегоНазначенияКлиентСервер.ПолучитьНачалоПериода(
									Объект.ДатаНачалаКонтроля, Объект.ПериодичностьКонтроля);
									
	Объект.ДатаОкончанияКонтроля = бит_ОбщегоНазначенияКлиентСервер.ПолучитьКонецПериода(
									Объект.ДатаОкончанияКонтроля, Объект.ПериодичностьКонтроля);								
	
КонецПроцедуры
								
&НаСервере
Процедура УстановитьСостояниеДокумента()
	
	СостояниеДокумента = бит_ОбщегоНазначения.СостояниеДокумента(Объект);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьКонтролируемыйСценарий()
	
	Если Объект.ВидКонтроля = ПредопределенноеЗначение("Перечисление.бит_РежимыКонтроляПоБюджету.ГрафикиДоговоров") Тогда
		Объект.СценарийКонтролируемый = Объект.Сценарий;
	ИначеЕсли Объект.ВидКонтроля = ПредопределенноеЗначение("Перечисление.бит_РежимыКонтроляПоБюджету.Заявки") Тогда
		Объект.СценарийКонтролируемый = Объект.Сценарий;
	Иначе
		Если НЕ ЗначениеЗаполнено(Объект.СценарийКонтролируемый) Тогда
			Объект.СценарийКонтролируемый = Объект.Сценарий;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция РеквизитыСтатьи(Знач Статья)
	
	Если ЗначениеЗаполнено(Статья) Тогда
		РеквизитыСтатьи = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Статья,"ТипСтатьи, РасходДоход");
	Иначе	
		РеквизитыСтатьи = Новый Структура; 
		РеквизитыСтатьи.Вставить("ТипСтатьи", Перечисления.бит_ТипыСтатейОборотов.ПустаяСсылка());
		РеквизитыСтатьи.Вставить("РасходДоход", Перечисления.бит_РасходДоход.ПустаяСсылка());
	КонецЕсли; 
	
	Возврат РеквизитыСтатьи;
	
КонецФункции	

// Процедура открывает форму подбора записей из регистра контрольные значения бюджетов.
// 
// Параметры:
// 	Направление - строка - Приход,Расход - используется для определения ТЧ в которую будет производиться подбор.
// 
&НаКлиенте
Процедура ОткрытьФормуПодбораЗаписей(Направление)
	
	ОчиститьСообщения();
		
	Если Объект.ВидКонтроля = ПредопределенноеЗначение("Перечисление.бит_РежимыКонтроляПоБюджету.Бюджет")
		И НЕ ЗначениеЗаполнено(Объект.СценарийКонтролируемый) Тогда
		ТекстСообщения = ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("ПОЛЕ" , 
							"Заполнение",НСтр("ru = 'Контролируемый сценарий'"));
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "СценарийКонтролируемый", "Объект"); 
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе",	  Ложь);
	ПараметрыФормы.Вставить("Сценарий", 			  Объект.Сценарий);
	ПараметрыФормы.Вставить("СценарийКонтролируемый", Объект.СценарийКонтролируемый);
	ПараметрыФормы.Вставить("Направление", 			  Направление);
	ПараметрыФормы.Вставить("РежимКонтроля",		  Объект.ВидКонтроля);
	ПараметрыФормы.Вставить("АдресЗаСчет",		 	  "");
	
	КлючСтроки 		= "";
	СтруктураОтбора = Новый Структура;
	
	Если Объект.ВидКорректировки = ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет")
		И Направление = "Расход" Тогда
		
		// В этом случае даем подбирать статьи с тем направлением и типом,
		// какие установлены в статье-владельце таблицы Увеличение.
		ТекущиеДанные = Элементы.УвеличениеЛимита.ТекущиеДанные;
		
		Если НЕ ТекущиеДанные = Неопределено Тогда
			РеквизитыСтатьи = РеквизитыСтатьи(ТекущиеДанные.СтатьяОборотов);
			СтруктураОтбора.Вставить("ТипСтатьи",   РеквизитыСтатьи.ТипСтатьи);
			СтруктураОтбора.Вставить("РасходДоход", РеквизитыСтатьи.РасходДоход);
			КлючСтроки = ТекущиеДанные.КлючСтроки;
		КонецЕсли;
	Иначе
		Если бит_ОбщегоНазначенияКлиентСервер.ЭтоУказанныйТип(ТипЗнч(Объект.ДокументОснование), "ДокументСсылка.бит_ЗаявкаНаРасходованиеСредств") Тогда
			СтруктураОтбора.Вставить("ТипСтатьи"	 , ПредопределенноеЗначение("Перечисление.бит_ТипыСтатейОборотов.БДДС"));
			СтруктураОтбора.Вставить("РасходДоход", ПредопределенноеЗначение("Перечисление.бит_РасходДоход.Расходование"));
		ИначеЕсли бит_ОбщегоНазначенияКлиентСервер.ЭтоУказанныйТип(ТипЗнч(Объект.ДокументОснование), "ДокументСсылка.бит_ЗаявкаНаЗатраты") Тогда
			СтруктураОтбора.Вставить("ТипСтатьи"	 , ПредопределенноеЗначение("Перечисление.бит_ТипыСтатейОборотов.БДР"));
			СтруктураОтбора.Вставить("РасходДоход", ПредопределенноеЗначение("Перечисление.бит_РасходДоход.Расходование"));	
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыФормы.Вставить("СтруктураОтбора", СтруктураОтбора);
	
	Если Направление = "Расход" Тогда
		ПолеОбъекта = "УменьшениеЛимита";
	Иначе
		ПолеОбъекта = "УвеличениеЛимита";	
	КонецЕсли;
	ПараметрыФормы.Вставить("АдресЗаСчет", АдресПодобранныхСтрокВХранилище(ПолеОбъекта, КлючСтроки));
	
	ОткрытьФорму("Документ.бит_КорректировкаКонтрольныхЗначений.Форма.ФормаПодбораЗаписей", 
		ПараметрыФормы, ЭтотОбъект,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры 

&НаКлиентеНаСервереБезКонтекста
Процедура ПроверитьУникальностьСтроки(Форма, ВыбранноеЗначение, ПолеОбъекта, Отказ = Ложь, ВыводитьСообщения = Истина, КлючСтроки = "")
	
	Объект  = Форма.Объект;
	Таблица = Объект[ПолеОбъекта];
	
	Исключения = Новый Массив;
	Исключения.Добавить("КлючСтроки");
	Исключения.Добавить("Сумма");
	Исключения.Добавить("Количество");	
		
	СтруктураПоиска = Новый Структура;
	Для каждого Запись Из Форма.ПостоянныеРеквизитыТаблицы Цикл
		Если Исключения.Найти(Запись.Значение) <> Неопределено
			ИЛИ СтрНачинаетсяС(Запись.Значение, "Контроль") Тогда
			Продолжить;		
		КонецЕсли;
		ИмяРеквизита = Запись.Значение;
		ЕстьСвойство = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ВыбранноеЗначение, ИмяРеквизита); 
		Если ЕстьСвойство И ЗначениеЗаполнено(ВыбранноеЗначение[ИмяРеквизита]) Тогда
			СтруктураПоиска.Вставить(ИмяРеквизита, ВыбранноеЗначение[ИмяРеквизита]);
		КонецЕсли;
	КонецЦикла;
	
	ВидКорректировкиЗаСчет = ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет");
	Если Объект.ВидКорректировки = ВидКорректировкиЗаСчет И ЗначениеЗаполнено(КлючСтроки) Тогда
		СтруктураПоиска.Вставить("КлючСтроки", КлючСтроки);
	КонецЕсли;
	
	// Поиск сканированием, что бы не делать неявный серверный вызов с клиента методом 
	// "Объект.УвеличениеЛимита.НайтиСтроки()";
	РезультатПоиска = Новый Массив;
	Для каждого СтрокаТаблицы Из Таблица Цикл
		ЕстьСовпадение = Истина;
		Для каждого Колонка Из СтруктураПоиска Цикл
			Если СтрокаТаблицы[Колонка.Ключ] <> Колонка.Значение Тогда
				ЕстьСовпадение = Ложь;			
			КонецЕсли;
		КонецЦикла;
		Если ЕстьСовпадение Тогда
			РезультатПоиска.Добавить(СтрокаТаблицы);	
		КонецЕсли;
	КонецЦикла;
	
	Если ПолеОбъекта = "УвеличениеЛимита" Тогда
		ИмяТаблицы = НСтр("ru = 'Увеличение лимита'; en = 'Increasing the limit'");
	Иначе	
		ИмяТаблицы = НСтр("ru = 'Уменьшение лимита'; en = 'Limit reduction'");
	КонецЕсли;
	
	Если РезультатПоиска.Количество() <> 0 Тогда
		Отказ = Истина;
	КонецЕсли;
	
	Если Отказ И ВыводитьСообщения Тогда
		ТекстСообщения = НСтр("ru='Данная строка уже подобрана в табличную часть ""%1"" в строке № %2';
							  |en='This line is already matched in the tabular part ""%1"" in row  №%2'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ИмяТаблицы, РезультатПоиска[0].НомерСтроки);
		#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		#Иначе
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		#КонецЕсли
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПараметрыВыбораСтатей(Контейнер)

	МассивПараметров = Новый Массив;
	
	Если бит_ОбщегоНазначенияКлиентСервер.ЭтоУказанныйТип(ТипЗнч(Объект.ДокументОснование), "ДокументСсылка.бит_ЗаявкаНаРасходованиеСредств") Тогда
		
		НовыйПараметр = Новый ПараметрВыбора("Отбор.ТипСтатьи"	, ПредопределенноеЗначение("Перечисление.бит_ТипыСтатейОборотов.БДДС"));
		МассивПараметров.Добавить(НовыйПараметр);
		
		НовыйПараметр = Новый ПараметрВыбора("Отбор.РасходДоход", ПредопределенноеЗначение("Перечисление.бит_РасходДоход.Расходование"));
		МассивПараметров.Добавить(НовыйПараметр);
		
	ИначеЕсли бит_ОбщегоНазначенияКлиентСервер.ЭтоУказанныйТип(ТипЗнч(Объект.ДокументОснование), "ДокументСсылка.бит_ЗаявкаНаЗатраты") Тогда
		
		НовыйПараметр = Новый ПараметрВыбора("Отбор.ТипСтатьи"	, ПредопределенноеЗначение("Перечисление.бит_ТипыСтатейОборотов.БДР"));
		МассивПараметров.Добавить(НовыйПараметр);
		
		НовыйПараметр = Новый ПараметрВыбора("Отбор.РасходДоход", ПредопределенноеЗначение("Перечисление.бит_РасходДоход.Расходование"));
		МассивПараметров.Добавить(НовыйПараметр);
	КонецЕсли;
	
	Контейнер.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);

КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораПодборНаСервере(Знач ВыбранноеЗначение, КлючСтроки, Результат = Ложь)
	
	ТаблицаКонтрольныхЗначений = ПолучитьИзВременногоХранилища(ВыбранноеЗначение.АдресПодобранныхКонтрольныхЗначенийВХранилище);
	
	Если ТаблицаКонтрольныхЗначений.Количество() = 0 Тогда
		Возврат;	
	КонецЕсли;
	
	Если ВыбранноеЗначение.Направление = "Приход" Тогда
		Для Каждого КонтрольноеЗначение Из ТаблицаКонтрольныхЗначений Цикл
			Отказ = Ложь;
			ПроверитьУникальностьСтроки(ЭтотОбъект, КонтрольноеЗначение, "УвеличениеЛимита", Отказ);
			Если Отказ Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока = Объект.УвеличениеЛимита.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, КонтрольноеЗначение);
			НоваяСтрока.КлючСтроки = Новый УникальныйИдентификатор();

			Если Объект.ВидКорректировки = Перечисления.бит_ВидыКорректировокКонтрольныхЗначений.ВозвратЛимита Тогда
				НоваяСтрока.Сумма		= КонтрольноеЗначение.СуммаСценарийИсполнение;
				НоваяСтрока.Количество	= КонтрольноеЗначение.КоличествоСценарийИсполнение;
			Иначе	
				НоваяСтрока.Сумма		= КонтрольноеЗначение.СуммаРазность;
				НоваяСтрока.Количество	= КонтрольноеЗначение.КоличествоРазность;
			КонецЕсли;
		
			ЗаполнитьИспользуемыеРазрезыСтатьиОборотов(НоваяСтрока, "УвеличениеЛимита");
		КонецЦикла;
		
	Иначе	
		// Для вида корректировки ЗаСчет строки таблицы уменьшение подчинены строкам увеличения.
		Если Объект.ВидКорректировки = Перечисления.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет Тогда
			Если КлючСтроки = "" Тогда
				ТекстСообщения = НСтр("ru='Не указана строка в которой происходит увеличение.';
									  |en='Not specified string in which the increase occurs.'");
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
				Возврат;
			КонецЕсли;
		Иначе
			КлючСтроки = "";
		КонецЕсли;
		
		// При установке значений подбора в список "За счет" применяем метод уменьшения остатка.
		УменьшатьОстаток 	  = ЗначениеЗаполнено(КлючСтроки);
		СуммаОсталосьСписать  = 0;
		КолВоОсталосьСписать  = 0;
		
		Если УменьшатьОстаток Тогда
			СтрокаПоступление 	  = Объект.УвеличениеЛимита.НайтиСтроки(Новый Структура("КлючСтроки", КлючСтроки))[0];
			РезультатПоиска 	  = Объект.УменьшениеЛимита.НайтиСтроки(Новый Структура("КлючСтроки", КлючСтроки));
			
			СуммаСписано = 0;
			КолВоСписано = 0;
			Для каждого СтрокаТаблицы Из РезультатПоиска Цикл
				СуммаСписано = СуммаСписано + СтрокаТаблицы.Сумма;
				КолВоСписано = КолВоСписано + СтрокаТаблицы.Количество;
			КонецЦикла; 
			
			СуммаОсталосьСписать  = Макс(СтрокаПоступление.Сумма - СуммаСписано, 0);
			КолВоОсталосьСписать  = Макс(СтрокаПоступление.Количество - КолВоСписано, 0);
		КонецЕсли;
		
		Для Каждого КонтрольноеЗначение Из ТаблицаКонтрольныхЗначений Цикл
			Если УменьшатьОстаток Тогда
				Если СуммаОсталосьСписать = 0 И КолВоОсталосьСписать = 0 Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
			
			Отказ = Ложь;
			ПроверитьУникальностьСтроки(ЭтотОбъект, КонтрольноеЗначение, "УменьшениеЛимита", Отказ, Истина, КлючСтроки);
			Если Отказ Тогда
				Продолжить;
			КонецЕсли;
			
			// Добавим строку расхода.
			НоваяСтрока = Объект.УменьшениеЛимита.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, КонтрольноеЗначение);
			
			Если УменьшатьОстаток Тогда
				Сумма 	   			 = Мин(СуммаОсталосьСписать, КонтрольноеЗначение.СуммаРазность);
				Количество 			 = Мин(СуммаОсталосьСписать, КонтрольноеЗначение.КоличествоРазность);
				СуммаОсталосьСписать = Макс(СуммаОсталосьСписать - Сумма, 0);
				КолВоОсталосьСписать = Макс(КолВоОсталосьСписать - Количество, 0);
			Иначе	
				Сумма 		= КонтрольноеЗначение.СуммаРазность;
				Количество	= КонтрольноеЗначение.КоличествоРазность;
			КонецЕсли;
			
			НоваяСтрока.КлючСтроки = КлючСтроки;
			НоваяСтрока.Сумма		= Сумма;
			НоваяСтрока.Количество	= Количество;
				
			ЗаполнитьИспользуемыеРазрезыСтатьиОборотов(НоваяСтрока, "УменьшениеЛимита");
		КонецЦикла;
	КонецЕсли;
	
	Если НЕ НоваяСтрока = Неопределено Тогда
		Результат = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
	
	Элементы = Форма.Элементы;
	Объект	 = Форма.Объект;
	
	бит_НастройкиДоступностиЭлементовФормКлиентСервер.РазблокироватьЭлементы(Форма);
	
	Элементы.ФормаОбработкаУстановкаВизСогласование.Видимость = Ложь;
	
	Элементы.СценарийКонтролируемый.Видимость = (Объект.ВидКонтроля = 
													ПредопределенноеЗначение("Перечисление.бит_РежимыКонтроляПоБюджету.Бюджет"));
				
	Если Форма.ПроводитьПослеУтверждения 
		И Объект.Проведен И Объект.ОтправленНаСогласование
		И Объект.РежимПринятияКУчету = 1
		И Форма.ТипСтатуса <> ПредопределенноеЗначение("Перечисление.бит_ТипыСтатусовОбъектов.Утвержден") Тогда
		Элементы.ПредупреждениеОПринятиеКУчетуПослеУтверждения.Видимость = Истина;
	Иначе
		Элементы.ПредупреждениеОПринятиеКУчетуПослеУтверждения.Видимость = Ложь;
	КонецЕсли;
	
	ЭтоКонтрольБюджета  = Объект.ВидКонтроля = ПредопределенноеЗначение("Перечисление.бит_РежимыКонтроляПоБюджету.Бюджет");
	ЭтоКонтрольЗаявок   = Объект.ВидКонтроля = ПредопределенноеЗначение("Перечисление.бит_РежимыКонтроляПоБюджету.Заявки");
	ЭтоКонтрольГрафиков = Объект.ВидКонтроля = ПредопределенноеЗначение("Перечисление.бит_РежимыКонтроляПоБюджету.ГрафикиДоговоров");

	ВидКорректировкиЗаСчет 		  = ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет");
	ВидКорректировкиИзменение 	  = ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.Изменение");
	ВидКорректировкиВозвратЛимита = ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ВозвратЛимита");
	
	Элементы.ГруппаУменьшениеЛимита.Видимость = 
		Объект.ВидКорректировки = ВидКорректировкиЗаСчет ИЛИ Объект.ВидКорректировки = ВидКорректировкиИзменение;
			
	Элементы.СуммаДокументаРасход.Видимость		= Элементы.ГруппаУменьшениеЛимита.Видимость;
	Элементы.ВалютаСценарияУменьшение.Видимость = Элементы.ГруппаУменьшениеЛимита.Видимость;

	Элементы.ДокументОснование.Видимость = ЭтоКонтрольЗаявок;	
	
	Элементы.УменьшениеЛимитаПодменюСкопировать.Видимость = 
		Объект.ВидКорректировки = ВидКорректировкиИзменение;
		
	Если Объект.ВидКорректировки = ВидКорректировкиЗаСчет Тогда
		Элементы.ГруппаУменьшениеЛимита.Заголовок = НСтр("ru='За счет';en='At the expense of'");
	Иначе
		Элементы.ГруппаУменьшениеЛимита.Заголовок = НСтр("ru = 'Уменьшение лимита'; en = 'Limit reduction'");
	КонецЕсли;
	
	Если Объект.ВидКорректировки <> ВидКорректировкиЗаСчет Тогда
		Элементы.УвеличениеЛимитаСуммаУменьшение.Видимость		= Ложь;
		Элементы.УвеличениеЛимитаКоличествоУменьшение.Видимость = Ложь;
	Иначе
		Элементы.УвеличениеЛимитаСуммаУменьшение.Видимость		= Элементы.УвеличениеЛимитаСумма.Видимость;
		Элементы.УвеличениеЛимитаКоличествоУменьшение.Видимость = Элементы.УвеличениеЛимитаКоличество.Видимость;
	КонецЕсли;	

	Элементы.ГруппаНастройкиПериодичности.Видимость = ЭтоКонтрольЗаявок ИЛИ ЭтоКонтрольГрафиков;
	
	Если ЭтоКонтрольЗаявок ИЛИ ЭтоКонтрольГрафиков Тогда
		Элементы.ПериодичностьКонтроля.Видимость = Объект.ПроизвольнаяПериодичностьКонтроля;
		Элементы.ГруппаПериодКонтроля.Видимость  = Объект.ПроизвольнаяПериодичностьКонтроля 
			И НЕ ЗначениеЗаполнено(Объект.ПериодичностьКонтроля);
	КонецЕсли;
	
	ТекущаяСтраница  = Элементы.СтраницыСпособаУстановкиРазрезовКонтроля.Текущаястраница;
	ПоказатьСтраницы = Истина;
	ПоказатьКолонки  = Истина;
	
	УстановитьАвтоматически    = ПредопределенноеЗначение("Перечисление.бит_СпособыУстановкиРазрезовКонтроля.Автоматически");
	УстановитьВручнуюИзШапки   = ПредопределенноеЗначение("Перечисление.бит_СпособыУстановкиРазрезовКонтроля.ВручнуюИзШапки");
	УстановитьВручнуюПоСтрочно = ПредопределенноеЗначение("Перечисление.бит_СпособыУстановкиРазрезовКонтроля.ВручнуюПоСтрочно");
	УстановитьИзНастройки	   = ПредопределенноеЗначение("Перечисление.бит_СпособыУстановкиРазрезовКонтроля.ИзНастройки");
	
	Если Объект.СпособУстановкиРазрезовКонтроля = УстановитьАвтоматически Тогда
		ПоказатьСтраницы = Ложь;
		ПоказатьКолонки  = Ложь;
		ТекстСообщения 	 = НСтр("ru = 'Разрезы контроля будут определены при проведении.'; 
								|en = 'The sections of the control will be determined during the implementation.'");
	ИначеЕсли Объект.СпособУстановкиРазрезовКонтроля = УстановитьВручнуюИзШапки Тогда
		ТекущаяСтраница  = Элементы.СтраницаВручнуюИзШапки;
		ПоказатьКолонки  = Ложь;
		ТекстСообщения   = НСтр("ru = 'Разрезы контроля нужно указать в шапке этого документа.';
								|en = 'The sections must be specified in the header of this document.'");
	ИначеЕсли Объект.СпособУстановкиРазрезовКонтроля = УстановитьВручнуюПоСтрочно Тогда
		ПоказатьСтраницы = Ложь;
		ТекстСообщения   = НСтр("ru = 'Разрезы контроля нужно указать в строках списка лимитов.'; 
								|en = 'The sections must be specified in the lines of the list of limits.'");
	ИначеЕсли Объект.СпособУстановкиРазрезовКонтроля = УстановитьИзНастройки Тогда	
		ТекущаяСтраница = Элементы.СтраницаИзНастройки;
		ПоказатьКолонки = Ложь;
		ТекстСообщения  = НСтр("ru = 'Разрезы контроля будут получены из настроек документа установки контроля.';
								|en = 'The control sections will be obtained from the settings of the control installation document.'");
	КонецЕсли;
	
	Элементы.СтраницыСпособаУстановкиРазрезовКонтроля.Текущаястраница = ТекущаяСтраница;
	Элементы.СтраницыСпособаУстановкиРазрезовКонтроля.Видимость 	  = ПоказатьСтраницы;
	Элементы.СпособУстановкиРазрезовКонтроля.Подсказка				  = ТекстСообщения;
	
	// Управлет видимостью колонок контроля в зависимости от способа установки разрезов,
	// с учетом "автовидимости колонок" и настроек измерений бюджетирования.
	Для каждого Запись Из Форма.КолонкиКонтроля Цикл
		ИмяКолонки		  = "УвеличениеЛимита" + Запись.Значение;
		ИмяКолонкиРазреза = СтрЗаменить(ИмяКолонки, "Контроль", "");
		Если Запись.Пометка Тогда
			РазрезИспользуется = ОбщегоНазначенияКлиентСервер.ЗначениеСвойстваЭлементаФормы(Элементы, 
									ИмяКолонкиРазреза, "Видимость");
									
			// Для контроля отличного от "Бюджет" разрез "Банковский счет" выключен всегда.
			Если НЕ ЭтоКонтрольБюджета И СтрСравнить(ИмяКолонки, "УвеличениеЛимитаКонтрольБанковскийСчет") = 0 Тогда
				РазрезИспользуется = Ложь;		
			КонецЕсли;
						
			Если ПоказатьКолонки И РазрезИспользуется Тогда
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяКолонки, 
					"Видимость", Истина);
			Иначе
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяКолонки, 
					"Видимость", Ложь);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	бит_НастройкиДоступностиЭлементовФормКлиентСервер.ЗаблокироватьЭлементы(Форма);
	
КонецПроцедуры
 
&НаСервере
Функция АдресПодобранныхСтрокВХранилище(Знач ДанныеОбъекта, Знач КлючСтроки)

	СуммыЗаСчет = Объект[ДанныеОбъекта].Выгрузить();
	
	// Если передается "КлючСтроки", значит подбор идет в подчиненные строки.
	// Удалим строки, не удовлетворяющие отбору КлючСтроки.
	Если ЗначениеЗаполнено(КлючСтроки) Тогда
		Индекс = СуммыЗаСчет.Количество() - 1;
		Пока Индекс >= 0 Цикл
			СтрокаТаблицы = СуммыЗаСчет[Индекс]; 
			Если СтрокаТаблицы.КлючСтроки <> КлючСтроки Тогда
				СуммыЗаСчет.Удалить(СтрокаТаблицы);			
			КонецЕсли;
			Индекс = Индекс - 1;
		КонецЦикла;
	КонецЕсли;
	АдресВХранилище = ПоместитьВоВременноеХранилище(СуммыЗаСчет, УникальныйИдентификатор);
	
	Возврат АдресВХранилище;
	
КонецФункции

&НаСервере
Процедура ОбработкаОповещенияИзмененияСтатуса()
	
	Прочитать();
	
КонецПроцедуры

// Управление флажками разрезов в зависимости от настроек измерений бюджетирования.
//
&НаСервере
Процедура ВывестиКонтрольРазрезов(Измерения, НастройкиИзмерений)
	
	СоответствиеИмен = Новый Соответствие;
	ЗаголовокКолонки = НСтр("ru = 'Контроль (%1)'");
	
	// "Все измерения" нужны для обработки колонок таблицы в зависимости от решения БФ.
	ВсеИзмерения = бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Все","Синоним");
	ВсеИзмерения.Удалить("Сценарий");
	ВсеИзмерения.Удалить("СтатьяОборотов");
	
	МетаданныеРеквизиты = Объект.Ссылка.Метаданные().Реквизиты;
	
	Для каждого КлючИЗначение Из ВсеИзмерения Цикл
		ИмяИзмерения = КлючИЗначение.Ключ;
		
		// "Дополнительные" измерения обрабатываются по настройкам.
		ИскатьНастройку = Измерения.Свойство(ИмяИзмерения);
		Если ИскатьНастройку Тогда
			ТекущаяНастройка = НастройкиИзмерений[ИмяИзмерения];
			Если ТекущаяНастройка <> Неопределено Тогда
				ПоказатьИзмерение	   = Истина;				
				ПредставлениеИзмерения = ТекущаяНастройка.Синоним;
			Иначе
				ПоказатьИзмерение	   = Ложь;
				ПредставлениеИзмерения = "";
			КонецЕсли;
		Иначе
			ПоказатьИзмерение	   = Истина;
			ПредставлениеИзмерения = КлючИЗначение.Значение;
		КонецЕсли;
		
		ИмяРеквизита	   = "Контроль" + ИмяИзмерения;
		МетаданныеРеквизит = МетаданныеРеквизиты.Найти(ИмяРеквизита);
		Если МетаданныеРеквизит <> Неопределено Тогда
			Если ПоказатьИзмерение Тогда
				НоваяСтрока                    = НастройкаЗаполнения.Добавить();
				НоваяСтрока.ИмяРеквизита       = ИмяРеквизита;
				НоваяСтрока.ИспользоватьРазрез = Объект[ИмяРеквизита];
				НоваяСтрока.Измерение          = ПредставлениеИзмерения;
			КонецЕсли;
		КонецЕсли;
		
		ИмяКолонки	   = "УвеличениеЛимитаКонтроль" + ИмяИзмерения;
		ТекущаяКолонка = Элементы.Найти(ИмяКолонки);
				
		Если ТекущаяКолонка <> Неопределено Тогда
			ТекущаяКолонка.Заголовок = СтрШаблон(ЗаголовокКолонки, ПредставлениеИзмерения);
			ТекущаяКолонка.Видимость = ПоказатьИзмерение;
			КолонкиКонтроля.Добавить("Контроль" + ИмяИзмерения,, ПоказатьИзмерение);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ДобавитьВУвеличениеЛимита(ТекущаяСтрока)
	
	НоваяСтрока = Объект.УвеличениеЛимита.Добавить();	
	ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекущаяСтрока);
	НоваяСтрока.КлючСтроки = Новый УникальныйИдентификатор();
	НоваяСтрока.Период 	   = бит_ОбщегоНазначенияКлиентСервер.ПолучитьНачалоПериода(Объект.Дата, ПериодичностьСценария);;
	
	ЗаполнитьИспользуемыеРазрезыСтатьиОборотов(НоваяСтрока, "УвеличениеЛимита");

КонецПроцедуры

&НаСервере
Процедура СкопироватьТекущуюСтрокуНаСервере(Знач СтрокаТаблицы)

	ДобавитьВУвеличениеЛимита(СтрокаТаблицы);
	УстановитьАвтовидимостьУвеличениеЛимита();
	
КонецПроцедуры

&НаСервере
Процедура СкопироватьВсеНаСеревере()

	КУдалению = Новый Массив;
	КУдалению.Добавить("НомерСтроки");
	КУдалению.Добавить("ИсходныйНомерСтроки");
	КУдалению.Добавить("КлючСтроки");
	КУдалению.Добавить("Сумма");
	КУдалению.Добавить("Количество");

	УменьшениеЛимита = Объект.УменьшениеЛимита.Выгрузить();
	ИменаКолонок = Новый Массив;
	Для каждого Колонка Из УменьшениеЛимита.Колонки Цикл
		ИменаКолонок.Добавить(Колонка.Имя);	
	КонецЦикла;
	
	КолонкиГруппировок	= ОбщегоНазначенияКлиентСервер.РазностьМассивов(ИменаКолонок, КУдалению);
	КолонкиГруппировок	= СтрСоединить(КолонкиГруппировок, ",");
	КолонкиСуммирования = "Сумма, Количество";
	
	ЗначениеПериод = бит_ОбщегоНазначенияКлиентСервер.ПолучитьНачалоПериода(Объект.Дата, ПериодичностьСценария);
	
	УменьшениеЛимита.ЗаполнитьЗначения(ЗначениеПериод, "Период");
	УменьшениеЛимита.Свернуть(КолонкиГруппировок, КолонкиСуммирования);
	
	Для каждого СтрокаТаблицы Из УменьшениеЛимита Цикл
		ДобавитьВУвеличениеЛимита(СтрокаТаблицы);
	КонецЦикла;
	
	УстановитьАвтовидимостьУвеличениеЛимита();

КонецПроцедуры

&НаСервере
Функция ПараметрыИзмененияТаблицыДокумента()

	ИмяТабличнойЧасти = "УвеличениеЛимита";
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Команда",			"бит_КорректировкаКонтрольныхЗначений");
	ПараметрыФормы.Вставить("Объект",			Объект.Ссылка);
	ПараметрыФормы.Вставить("ИмяТабличнойЧасти",ИмяТабличнойЧасти);
	ПараметрыФормы.Вставить("ТабличнаяЧасть",	 
		ПоместитьВоВременноеХранилище(Объект[ИмяТабличнойЧасти].Выгрузить(), УникальныйИдентификатор));
		
	Возврат ПараметрыФормы;	
	
КонецФункции

&НаСервере
Процедура ОбработатьИзменениеТабличнойЧастиНаСервере(Знач ПараметрыОповещения)

	ИмяТабличнойЧасти		  = ПараметрыОповещения.ИмяТабличнойЧасти;
	АдресВоВременномХранилище = ПараметрыОповещения.АдресВоВременномХранилище;
		
	Модифицированность = Истина;
	ДанныеЗаполнения   = ПолучитьИзВременногоХранилища(АдресВоВременномХранилище);
	
	Индекс = 0;
	Для каждого СтрокаТаблицы Из ДанныеЗаполнения Цикл
		ТекущиеДанные		  = Объект[ИмяТабличнойЧасти][Индекс];
		ТекущаяСтатьяОборотов = ТекущиеДанные.СтатьяОборотов;
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, СтрокаТаблицы);
		
		Если ТекущиеДанные.СтатьяОборотов <> ТекущаяСтатьяОборотов Тогда
			ТекстСообщения = НСтр("ru = 'Обработать изменение статьо оборотов в ТЧ при загрузке измененной строки.'; 
								  |en = 'Process the change in the article of revolutions in TP when loading the changed line.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		КонецЕсли; 
		Индекс = Индекс + 1;
	КонецЦикла; 

КонецПроцедуры

#КонецОбласти
