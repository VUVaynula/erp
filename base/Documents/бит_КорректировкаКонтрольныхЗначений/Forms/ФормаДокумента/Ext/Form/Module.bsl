&НаКлиенте
Процедура КомандаПодборЗаписейРасход(Команда)
	
	ОчиститьСообщения();
	
	Отказ = Ложь;
	Если НЕ ЗначениеЗаполнено(Объект.ВидКорректировки) Тогда
		ПредставлениеПоля = НСтр("ru = 'Вид корректировки'; en = 'Correction Type'"); 
		ТекстСообщения 	  = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("ПОЛЕ", 
								"Заполнение", ПредставлениеПоля);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,,"ВидКорректировки", "Объект", Отказ);
	КонецЕсли;
	
	ВидКорректировкиЗаСчет = ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет");
	Если Объект.ВидКорректировки = ВидКорректировкиЗаСчет Тогда
		ТекущиеДанные = Элементы.УвеличениеЛимита.ТекущиеДанные;
		
		Если ТекущиеДанные = Неопределено Тогда
			ТекстСообщения = НСтр("ru='Не выбрана строка в которой происходит увеличение.';
								  |en='Not specified string in which the increase occurs.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,,,,Отказ);
		Иначе
			СинонимТаблицы	  = НСтр("ru = 'Увеличение лимита'; en = 'Increasing the limit'");
			СинонимСумма	  = НСтр("ru = 'Сумма'; en = 'Amount'");
			СинонимКоличество = НСтр("ru = 'Количество'; en = 'Quantity'");
			
			Префикс = "УвеличениеЛимита[%1].";
			Префикс = СтрШаблон(Префикс, Формат(ТекущиеДанные.НомерСтроки - 1, "ЧН=0; ЧГ="));

			Если ТекущиеДанные.СтатьяОборотов_Учет_Сумма И ТекущиеДанные.СтатьяОборотов_Учет_Количество Тогда
				Если ТекущиеДанные.Сумма = 0 И ТекущиеДанные.Количество = 0 Тогда
					Поле = Префикс + "Сумма";
					ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(
										"КОЛОНКА",, СинонимСумма, ТекущиеДанные.НомерСтроки,
										СинонимТаблицы);
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, Поле, "Объект", Отказ);
					
					Поле = Префикс + "Количество";
					ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(
										"КОЛОНКА",, СинонимКоличество, ТекущиеДанные.НомерСтроки,
										СинонимТаблицы);
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, Поле, "Объект", Отказ);
				КонецЕсли;
			ИначеЕсли ТекущиеДанные.СтатьяОборотов_Учет_Сумма И ТекущиеДанные.Сумма = 0 Тогда
					Поле = Префикс + "Сумма";
					ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(
										"КОЛОНКА",, СинонимСумма, ТекущиеДанные.НомерСтроки,
										СинонимТаблицы);
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, Поле, "Объект", Отказ);
			ИначеЕсли ТекущиеДанные.СтатьяОборотов_Учет_Количество И ТекущиеДанные.Количество = 0 Тогда
					Поле = Префикс + "Количество";
					ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(
										"КОЛОНКА",, СинонимКоличество, ТекущиеДанные.НомерСтроки,
										СинонимТаблицы);
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, Поле, "Объект", Отказ);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Отказ Тогда
		Возврат;	
	КонецЕсли;
	
	ОткрытьФормуПодбораЗаписей("Расход");

КонецПроцедуры

&НаКлиенте
Процедура КомандаСкопироватьВсе(Команда)
		
	СкопироватьВсеНаСеревере();
	ЗаполнитьИтогиСвязанныхСтрок();

КонецПроцедуры

&НаКлиенте
Процедура КомандаСкопироватьТекущуюСтроку(Команда)
	
	ТекущиеДанные = Элементы.УменьшениеЛимита.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РеквизитыСтроки = СтрСоединить(ПостоянныеРеквизитыТаблицы.ВыгрузитьЗначения(), ",");
	СтрокаТаблицы 	= Новый Структура(РеквизитыСтроки);
	ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ТекущиеДанные);
	СкопироватьТекущуюСтрокуНаСервере(СтрокаТаблицы);
	
	ЗаполнитьИтогиСвязанныхСтрок();
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаАвтовидимостьКолонок(Команда)
	
	АвтовидимостьКолонок = Не АвтовидимостьКолонок;
	СохранитьНастройкиФормы = Не СохранитьНастройкиФормы;
	Элементы.ФормаКомандаАвтовидимостьКолонок.Пометка = АвтовидимостьКолонок;
	УстановитьАвтовидимостьКолонок(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьУвеличениеЛимита(Команда)
	
	Оповещение = Новый ОписаниеОповещения("ОбработатьИзменениеТабличнойЧасти", ЭтотОбъект);

	ПараметрыФормы = ПараметрыИзмененияТаблицыДокумента();
	ОткрытьФорму("Обработка.бит_ИзменениеТабличнойЧастиДокументаБюджетирования.Форма", ПараметрыФормы, 
		ЭтотОбъект,,,,Оповещение);
	
КонецПроцедуры
	
// Обработчик завершения открытия формы.
//  См. Синтакс-помощник: ОткрытьФорму().
//
&НаКлиенте
Процедура ОбработатьИзменениеТабличнойЧасти(Результат, Дополнительно) Экспорт

	Если ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;

	ИмяТабличнойЧасти		  = Результат.ИмяТабличнойЧасти;
	АдресВоВременномХранилище = Результат.АдресВоВременномХранилище;
	
	Если НЕ ЭтоАдресВременногоХранилища(АдресВоВременномХранилище) Тогда
		Возврат;
	КонецЕсли; 
	
	ОбработатьИзменениеТабличнойЧастиНаСервере(Результат);
	
КонецПроцедуры

