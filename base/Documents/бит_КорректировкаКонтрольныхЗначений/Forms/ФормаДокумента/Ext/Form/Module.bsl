&НаКлиенте
Процедура УстановитьОтборСтрок(Форма, ТекущиеДанные)
		
	ВидКорректировки = Объект.ВидКорректировки;
		
	ОтборСтрокРасход = Новый Структура;
	
	Если ВидКорректировки = ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет") Тогда
		Если ТекущиеДанные <> Неопределено Тогда
			КлючСтроки = ТекущиеДанные.КлючСтроки;
		Иначе
			КлючСтроки = "";
		КонецЕсли;	
		ОтборСтрокРасход.Вставить("КлючСтроки", КлючСтроки);
	КонецЕсли;	
	
	Элементы.УменьшениеЛимита.ОтборСтрок = Новый ФиксированнаяСтруктура(ОтборСтрокРасход);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	РеквизитыСтатьи = ПолучитьРеквизиты("Объект.УвеличениеЛимита");
	
	ПоказатьФлажки = (Объект.СпособУстановкиРазрезовКонтроля = Перечисления.бит_СпособыУстановкиРазрезовКонтроля.ВручнуюПоСтрочно);
	
	Для Каждого РеквизитСтатьи Из РеквизитыСтатьи Цикл
		НайденнаяПозиция = Найти(РеквизитСтатьи.Имя, "СтатьяОборотов_Учет_");
		
		Если НайденнаяПозиция = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяРеквизита = СтрЗаменить(РеквизитСтатьи.Имя, "СтатьяОборотов_Учет_", "");		
		
		// Поля разрезов контроля "УвеличениеЛимита".
		ЭлементУО = УсловноеОформление.Элементы.Добавить();
		// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
		КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "УвеличениеЛимита" + ИмяРеквизита);
		// АПК:277-вкл
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Объект.УвеличениеЛимита." + РеквизитСтатьи.Имя, ВидСравненияКомпоновкиДанных.Равно, Ложь);

		ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.бит_ТекстНедоступнойНадписи);
		ЭлементУО.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<не требуется>'; en = '<not required>'"));
		ЭлементУО.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
		
		// Поля разрезов контроля "УменьшениеЛимита".
		ЭлементУО = УсловноеОформление.Элементы.Добавить();
		// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
		КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "УменьшениеЛимита" + ИмяРеквизита);
		// АПК:277-вкл
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Объект.УменьшениеЛимита." + РеквизитСтатьи.Имя, ВидСравненияКомпоновкиДанных.Равно, Ложь);

		ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.бит_ТекстНедоступнойНадписи);
		ЭлементУО.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<не требуется>'; en = '<not required>'"));
		ЭлементУО.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);		
		
		// Флажки разрезов контроля "УвеличениеЛимита".
		ЭлементУО = УсловноеОформление.Элементы.Добавить();
		// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
		КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "УвеличениеЛимитаКонтроль" + ИмяРеквизита);
		// АПК:277-вкл
		
		ГруппаИЛИ = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(ЭлементУО.Отбор, "", 
							ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли);
							
		ГруппаЕстьУчет = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(ГруппаИЛИ, "", 
							ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ);
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаЕстьУчет,
			"Объект.УвеличениеЛимита." + РеквизитСтатьи.Имя, ВидСравненияКомпоновкиДанных.Равно, Истина);
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаЕстьУчет,
			"Объект.СпособУстановкиРазрезовКонтроля", ВидСравненияКомпоновкиДанных.НеРавно,
			Перечисления.бит_СпособыУстановкиРазрезовКонтроля.ВручнуюПоСтрочно);
			
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаИЛИ,
			"Объект.УвеличениеЛимита." + РеквизитСтатьи.Имя, ВидСравненияКомпоновкиДанных.Равно, Ложь);	
		
		ЭлементУО.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	КонецЦикла;
	
	// НастройкаЗаполнения.Измерение
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	бит_ОтчетыБФКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НастройкаЗаполненияИзмерение");
	
