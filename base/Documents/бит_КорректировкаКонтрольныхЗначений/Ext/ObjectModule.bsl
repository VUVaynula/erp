#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ПрограммныйИнтерфейс

// Заполняет наборы значений доступа.
// Параметры:
//  Таблица - ТаблицаЗначений - передает в этот параметр подготовленные наборы значений
//            доступа. Описание колонок см. в функции УправлениеДоступом.ТаблицаНаборыЗначенийДоступа.
//
Процедура ЗаполнитьНаборыЗначенийДоступа(Таблица) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	ДобавитьСтрокуВНаборЗначенийДоступа(Ответственный, Таблица);
	
	// Таблица "УвеличениеЛимита"
	Для каждого СтрокаТаблицы Из УвеличениеЛимита Цикл
		КлючДоступаЦФОСтатьяОборотов = Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.КлючиЦФОСтатьяОборотовДокумента(
			СтрокаТаблицы.ЦФО, СтрокаТаблицы.СтатьяОборотов);
		ДобавитьСтрокуВНаборЗначенийДоступа(КлючДоступаЦФОСтатьяОборотов, Таблица);
	КонецЦикла; 
	
	// Таблица "УменьшениеЛимита"
	Для каждого СтрокаТаблицы Из УменьшениеЛимита Цикл
		КлючДоступаЦФОСтатьяОборотов = Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.КлючиЦФОСтатьяОборотовДокумента(
			СтрокаТаблицы.ЦФО, СтрокаТаблицы.СтатьяОборотов);
		ДобавитьСтрокуВНаборЗначенийДоступа(КлючДоступаЦФОСтатьяОборотов, Таблица);
	КонецЦикла; 
	
	// Удалим дубли
	ПоляГруппировки = "";
	Для каждого Колонка Из Таблица.Колонки Цикл
		ПоляГруппировки = "," + Колонка.Имя + ПоляГруппировки;
	КонецЦикла; 
	
	ПоляГруппировки = Сред(ПоляГруппировки, 2);
	Таблица.Свернуть(ПоляГруппировки);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;	
	КонецЕсли; 
	
	// СтандартныеПодсистемы.ОбновлениеВерсииИБ
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ОбновлениеВерсииИБ

	бит_ОбщегоНазначенияПереопределяемый.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	ДополнительныеСвойства.Вставить("ПроводитьПослеУтверждения", ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения"));
	
	Если ВидКонтроля <> Перечисления.бит_РежимыКонтроляПоБюджету.Заявки Тогда
		ДокументОснование = Неопределено;
	КонецЕсли;
	
	Если ВидКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
		ПроизвольнаяПериодичностьКонтроля = Ложь;
	КонецЕсли;
	
	УстановитьКонтролируемыйСценарий();

	Если НЕ ПроизвольнаяПериодичностьКонтроля Тогда
		Если ВидКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
			ПериодичностьКонтроля = бит_КонтрольИсполненияБюджета.ПериодичностьКонтроляСценария(СценарийКонтролируемый);
		Иначе
			ПериодичностьКонтроля = бит_КонтрольИсполненияБюджета.ПериодичностьКонтроляСценария(Сценарий);
		КонецЕсли;
		ДатаНачалаКонтроля 	  = Дата;
		ДатаОкончанияКонтроля = Дата;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПериодичностьКонтроля) Тогда
		ДатаНачалаКонтроля = бит_ОбщегоНазначенияКлиентСервер.ПолучитьНачалоПериода(
								ДатаНачалаКонтроля, ПериодичностьКонтроля);
		
		ДатаОкончанияКонтроля = бит_ОбщегоНазначенияКлиентСервер.ПолучитьКонецПериода(
									ДатаОкончанияКонтроля, ПериодичностьКонтроля);								
	КонецЕсли;

	Если ВидКорректировки = Перечисления.бит_ВидыКорректировокКонтрольныхЗначений.ВозвратЛимита Тогда
		УменьшениеЛимита.Очистить();
	КонецЕсли; 
	
	Если СпособУстановкиРазрезовКонтроля <> Перечисления.бит_СпособыУстановкиРазрезовКонтроля.ИзНастройки Тогда
		НастройкаКонтроля = Документы.бит_УстановкаКонтрольныхЗначений.ПустаяСсылка();
	КонецЕсли;
	
	Если СпособУстановкиРазрезовКонтроля <> Перечисления.бит_СпособыУстановкиРазрезовКонтроля.ВручнуюИзШапки Тогда
		ИменаРеквизитов = ИменаРеквизитовКонтроль();
		Для каждого Имя Из ИменаРеквизитов Цикл
			ЭтотОбъект[Имя] = Ложь;	
		КонецЦикла;
	КонецЕсли;
	
	Если СпособУстановкиРазрезовКонтроля <> Перечисления.бит_СпособыУстановкиРазрезовКонтроля.ВручнуюПоСтрочно Тогда
		ИменаРеквизитов = ИменаРеквизитовКонтроль();
		Для каждого СтрокаТаблицы Из УвеличениеЛимита Цикл
			Для каждого Имя Из ИменаРеквизитов Цикл
				СтрокаТаблицы[Имя] = Ложь;	
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	КопияТаблицы = УвеличениеЛимита.Выгрузить();
	бит_КонтрольИсполненияБюджета.ОчиститьНеИспользуемыеАналитики(КопияТаблицы);
	УвеличениеЛимита.Загрузить(КопияТаблицы);
	
	КопияТаблицы = УменьшениеЛимита.Выгрузить();
	бит_КонтрольИсполненияБюджета.ОчиститьНеИспользуемыеАналитики(УменьшениеЛимита.Выгрузить());
	УменьшениеЛимита.Загрузить(КопияТаблицы);
	
	Если ДополнительныеСвойства.ПроводитьПослеУтверждения Тогда
		Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
			ОтправленНаСогласование = Истина;
		Иначе
			ОтправленНаСогласование = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЭтоНовый() Тогда
		ПовторноеПроведение = Проведен И РежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения;
		УстановитьРежимПринятияКУчету(ПовторноеПроведение);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	бит_ОбщегоНазначенияПереопределяемый.ОбработкаПроведенияНачало(ЭтотОбъект, Ложь);
	Если РучнаяКорректировка Тогда
		Возврат;
	КонецЕсли;
	
	ПриниматьКУчету = Истина;
	ПроводитьПослеУтверждения = ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения");
	Если ПроводитьПослеУтверждения И РежимПринятияКУчету = 1 Тогда
		ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(Ссылка);
		Если НЕ Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ТекущийСтатус,
					Перечисления.бит_ТипыСтатусовОбъектов.Утвержден) Тогда
			ПриниматьКУчету = Ложь;
		КонецЕсли;
	КонецЕсли;

	ПараметрыПроведения = Документы.бит_КорректировкаКонтрольныхЗначений.ПодготовитьПараметрыПроведения(Ссылка, Отказ);
	
	Если Отказ Тогда  
		Возврат;
	КонецЕсли;
	
	Документы.бит_КорректировкаКонтрольныхЗначений.ВыполнитьКонтрольПересеченияНастроек(
		ПараметрыПроведения.КорректировкиНастроекКонтроля, 
		ПараметрыПроведения.КорректировкиНастроекКонтроляРеквизиты, Отказ);
		
	Если НЕ ПриниматьКУчету Тогда
		бит_ОбщегоНазначенияПереопределяемый.ОбработкаПроведенияЗавершение(ЭтотОбъект, Отказ); 
		Возврат;
	КонецЕсли;
	
	КонтрольныеЗначенияБюджетов = бит_КонтрольИсполненияБюджета.ПодготовитьТаблицуКорректировкиЛимитов(
									ПараметрыПроведения.ИсполнениеБюджета,
									ПараметрыПроведения.ИсполнениеБюджетаРеквизиты,
									Отказ);

	Если Отказ Тогда  
		Возврат;
	КонецЕсли; 

	бит_КонтрольИсполненияБюджета.СформироватьДвиженияКонтрольныеЗначенияБюджетов(
		КонтрольныеЗначенияБюджетов, Движения);
			
	бит_КонтрольИсполненияБюджета.СформироватьДвиженияКорректировкиСроковКонтроля(
		ПараметрыПроведения.КорректировкиНастроекКонтроля,
		ПараметрыПроведения.КорректировкиНастроекКонтроляРеквизиты,
		Движения);
		
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаПроведенияЗавершение(ЭтотОбъект, Отказ); 
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаУдаленияПроведения(ЭтотОбъект, Отказ); 
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	НепроверяемыеРеквизиты = Новый Массив();
	
	Если ВидКонтроля <> Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
		НепроверяемыеРеквизиты.Добавить("СценарийКонтролируемый");
	КонецЕсли;
	
	Если ВидКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
		НепроверяемыеРеквизиты.Добавить("ДатаНачалаКонтроля");
		НепроверяемыеРеквизиты.Добавить("ДатаОкончанияКонтроля");
	Иначе
		Если НЕ ПроизвольнаяПериодичностьКонтроля Тогда
			НепроверяемыеРеквизиты.Добавить("ДатаНачалаКонтроля");
			НепроверяемыеРеквизиты.Добавить("ДатаОкончанияКонтроля");
		Иначе
			Если ЗначениеЗаполнено(ПериодичностьКонтроля) Тогда
				НепроверяемыеРеквизиты.Добавить("ДатаНачалаКонтроля");
				НепроверяемыеРеквизиты.Добавить("ДатаОкончанияКонтроля");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	Если СпособУстановкиРазрезовКонтроля <> Перечисления.бит_СпособыУстановкиРазрезовКонтроля.ИзНастройки Тогда
		НепроверяемыеРеквизиты.Добавить("НастройкаКонтроля");
	КонецЕсли;
	
	ПроверитьЗаполнениеНастройкиКонтроля(Отказ, ПроверяемыеРеквизиты);
	ПроверитьЗаполнениеУвеличениеЛимита(Отказ);
	ПроверитьЗаполнениеУменьшениеЛимита(Отказ);
	
	бит_НастройкиДоступностиЭлементовФорм.ЗаполнитьПроверяемыеРеквизиты(ЭтотОбъект,ПроверяемыеРеквизиты);
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		Если ДанныеЗаполнения.Свойство("ДокументОснование") Тогда
			ЗаполнитьПоЗаявке(ДанныеЗаполнения);
		Иначе
			ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения);
		КонецЕсли;
	КонецЕсли;
	
	ЗаполнитьШапкуДокумента();
	УстановитьРежимПринятияКУчету();
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	// Сбрасываем признак начала согласования.
	ОтправленНаСогласование = Ложь;
	ДокументОснование 		= Неопределено;
	ВидКонтроля 			= ОбъектКопирования.ВидКонтроля;
	Ответственный			= Пользователи.ТекущийПользователь();
	УстановитьРежимПринятияКУчету();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьСтрокуВНаборЗначенийДоступа(ЗначениеДоступа, Таблица)
	
	СтрокаТаб = Таблица.Добавить();
	СтрокаТаб.ЗначениеДоступа = ЗначениеДоступа;

КонецПроцедуры

// Процедура заполняет шапку документа.
// 
// Параметры:
// 	ПараметрОбъектКопирования - ДокументСсылка.
// 
Процедура ЗаполнитьШапкуДокумента(ПараметрОбъектКопирования = Неопределено)
	
	Если НЕ ЗначениеЗаполнено(ВидКонтроля) Тогда
		ВидКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Заявки;
	КонецЕсли;											
	
	Если НЕ ЗначениеЗаполнено(ВидКорректировки) Тогда
		ВидКорректировки = Перечисления.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СпособУстановкиРазрезовКонтроля) Тогда
		СпособУстановкиРазрезовКонтроля = Перечисления.бит_СпособыУстановкиРазрезовКонтроля.Автоматически;	
	КонецЕсли;

	бит_ОбщегоНазначения.ЗаполнитьШапкуДокумента(ЭтотОбъект, Пользователи.ТекущийПользователь(), ПараметрОбъектКопирования);
		
	УстановитьКонтролируемыйСценарий();

КонецПроцедуры

Процедура УстановитьКонтролируемыйСценарий()
	
	Если ВидКонтроля <> Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
		СценарийКонтролируемый = Сценарий;
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьПоЗаявке(ДанныеЗаполнения)
	
	Если ТипЗнч(ДанныеЗаполнения.ДокументОснование) <> Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
		Возврат;	
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения);
	
	ВидКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Заявки;
		
	Если НЕ ЗначениеЗаполнено(ВидКорректировки) Тогда
		ВидКорректировки = Перечисления.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет;
	КонецЕсли;	
	
	ИзмеренияДоп       = бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Дополнительные","Синоним");
	НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");

	АдресДанныхДляКорректировки = "";
	Если ДанныеЗаполнения.Свойство("АдресДанныхДляКорректировки", АдресДанныхДляКорректировки) Тогда
		Если НЕ ЭтоАдресВременногоХранилища(АдресДанныхДляКорректировки) Тогда
			Возврат;	
		КонецЕсли;
		
		Результат = ПолучитьИзВременногоХранилища(АдресДанныхДляКорректировки);
		Если НЕ ТипЗнч(Результат) = Тип("Структура") Тогда
			Возврат;
		КонецЕсли;
		
		ОжидаемыеДанные = Новый Структура("ЕстьДанныеКорректировки, АдресКорректировки", Ложь, "");
		ЗаполнитьЗначенияСвойств(ОжидаемыеДанные, Результат);
		
		ЕстьДанныеКорректировки = ОжидаемыеДанные.ЕстьДанныеКорректировки;
		АдресКорректировки		= ОжидаемыеДанные.АдресКорректировки;
		
		Если НЕ ЭтоАдресВременногоХранилища(АдресКорректировки) Тогда
			Возврат;	
		КонецЕсли;
		
		Корректировки = ПолучитьИзВременногоХранилища(АдресКорректировки);
		Если ТипЗнч(Корректировки) <> Тип("ТаблицаЗначений") Тогда
			Возврат;
		КонецЕсли;
		
		ТаблицаДокумента = УвеличениеЛимита.ВыгрузитьКолонки();
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Корректировки, ТаблицаДокумента);
		
		Группировки = бит_КонтрольИсполненияБюджета.ПереченьИзмеренийКонтроля(); 
		ТаблицаДокумента.Свернуть(Группировки + ", Период", "Сумма, Количество"); 
		УвеличениеЛимита.Загрузить(ТаблицаДокумента);
		
		Для каждого СтрокаТаблицы Из УвеличениеЛимита Цикл
			СтрокаТаблицы.КлючСтроки = Строка(Новый УникальныйИдентификатор());
		КонецЦикла;
		
		ИсполнениеБюджетаРеквизиты = Новый ТаблицаЗначений;
		ИсполнениеБюджетаРеквизиты.Колонки.Добавить("РежимКонтроля", 		  Новый ОписаниеТипов("ПеречислениеСсылка.бит_РежимыКонтроляПоБюджету"));
		ИсполнениеБюджетаРеквизиты.Колонки.Добавить("СценарийКонтролируемый", Метаданные.ОпределяемыеТипы.бит_СценарииПланирования.Тип);
		ИсполнениеБюджетаРеквизиты.Колонки.Добавить("Сценарий", 			  Метаданные.ОпределяемыеТипы.бит_СценарииПланирования.Тип);
		
		НоваяСтрока = ИсполнениеБюджетаРеквизиты.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭтотОбъект);
		НоваяСтрока.РежимКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Заявки;
		
		Если Корректировки.Колонки.Найти("НомерСтроки") = Неопределено Тогда
			Корректировки.Колонки.Добавить("НомерСтроки", ОбщегоНазначения.ОписаниеТипаЧисло(5));
			Счетчик = 1;
			Для каждого СтрокаТаблицы Из Корректировки Цикл
				СтрокаТаблицы.НомерСтроки = Счетчик; 
				Счетчик = Счетчик + 1;		
			КонецЦикла;
		КонецЕсли;
				
		РезультатПодбора = РезультатПодбораНастроекКонтроля(Корректировки, ИсполнениеБюджетаРеквизиты);
		Если ЗначениеЗаполнено(РезультатПодбора) Тогда
			
			УстановкиКонтрольныхЗначений = РезультатПодбора.ВыгрузитьКолонку("НастройкаКонтроля");
			УстановкиКонтрольныхЗначений = ОбщегоНазначенияКлиентСервер.СвернутьМассив(УстановкиКонтрольныхЗначений);
			
			Если УстановкиКонтрольныхЗначений.Количество() = 1 И ЗначениеЗаполнено(УстановкиКонтрольныхЗначений[0]) Тогда
				СпособУстановкиРазрезовКонтроля = Перечисления.бит_СпособыУстановкиРазрезовКонтроля.ИзНастройки;	
				НастройкаКонтроля				= УстановкиКонтрольныхЗначений[0]; 
			Иначе
				
				СпособУстановкиРазрезовКонтроля = Перечисления.бит_СпособыУстановкиРазрезовКонтроля.ВручнуюПоСтрочно;
				ПоляКонтроля				    = СтрСоединить(ИменаРеквизитовКонтроль(), ",");
				
				Для каждого СтрокаТаблицы Из УвеличениеЛимита Цикл
					ПараметрыПоиска = Новый Структура("НомерСтроки");
					ЗаполнитьЗначенияСвойств(ПараметрыПоиска, СтрокаТаблицы); 
					РезультатПоиска = РезультатПодбора.НайтиСтроки(ПараметрыПоиска);
					Если ЗначениеЗаполнено(РезультатПоиска) Тогда
						ЗаполнитьЗначенияСвойств(СтрокаТаблицы, РезультатПоиска[0], ПоляКонтроля);	
					КонецЕсли;				
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Процедура УстановитьРежимПринятияКУчету(ПовторноеПроведение = Ложь)
	
	Если ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения") Тогда
		Если НЕ ПовторноеПроведение Тогда
			РежимПринятияКУчету = 1;
		КонецЕсли;
	Иначе
		РежимПринятияКУчету = 0;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьЗаполнениеНастройкиКонтроля(Отказ, ПроверяемыеРеквизиты)

	Если НЕ ЗначениеЗаполнено(НастройкаКонтроля) Тогда
		Возврат;
	КонецЕсли;
	
	ВидКонтроляНастройки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НастройкаКонтроля, "ВидКонтроля");
	
	Если ВидКонтроляНастройки <> ВидКонтроля Тогда
		ТекстПояснения = НСтр("ru = 'Не подходящий вид операции.'; en = 'Inappropriate type of operation.'");
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("ПОЛЕ", "КОРРЕКТНОСТЬ",
							НСтр("ru = 'Настройка контроля'; en = 'Setting up control'"),,, ТекстПояснения);
							
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "НастройкаКонтроля", ,Отказ);	
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьЗаполнениеУвеличениеЛимита(Отказ)
	
	РеквизитыСтатей = Новый Соответствие(); 
	СинонимТаблицы 	  = НСтр("ru = 'Увеличение лимита'; en = 'Increasing the limit'");
	СинонимСумма 	  = НСтр("ru='Сумма';en='Amount'");
	СинонимКоличество = НСтр("ru='Количество';en='Quantity'");
	
	Для Каждого ТекущаяСтрока Из УвеличениеЛимита Цикл
		
		РеквизитыСтатьи = РеквизитыСтатей[ТекущаяСтрока.СтатьяОборотов];
		Если РеквизитыСтатьи = Неопределено Тогда
			Если ЗначениеЗаполнено(ТекущаяСтрока.СтатьяОборотов) Тогда
				РеквизитыСтатьи = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТекущаяСтрока.СтатьяОборотов, "Учет_Сумма, Учет_Количество");
			Иначе	
				РеквизитыСтатьи = Новый Структура("Учет_Сумма, Учет_Количество", Ложь, Ложь); 
			КонецЕсли;
			РеквизитыСтатей.Вставить(ТекущаяСтрока.СтатьяОборотов, РеквизитыСтатьи);
		КонецЕсли; 
		
		
		// Проверим заполненность суммы.
		Если РеквизитыСтатьи.Учет_Сумма И РеквизитыСтатьи.Учет_Количество Тогда			
			// Проверим заполненность суммы.
			Если ТекущаяСтрока.Сумма = 0 И ТекущаяСтрока.Количество = 0 Тогда				
				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА",,
									СинонимСумма, ТекущаяСтрока.НомерСтроки, СинонимТаблицы);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект,,, Отказ);
				
				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА",,
									СинонимКоличество, ТекущаяСтрока.НомерСтроки, СинонимТаблицы);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект,,, Отказ);
			КонецЕсли;
		Иначе
			// Проверим заполненность суммы.
			Если РеквизитыСтатьи.Учет_Сумма И ТекущаяСтрока.Сумма = 0 Тогда
				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА",,
									СинонимСумма, ТекущаяСтрока.НомерСтроки, СинонимТаблицы);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект,,, Отказ);
			КонецЕсли;			
			// Проверим заполненность количество.
			Если РеквизитыСтатьи.Учет_Количество И ТекущаяСтрока.Количество = 0 Тогда
				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА",,
									СинонимКоличество, ТекущаяСтрока.НомерСтроки, СинонимТаблицы);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект,,, Отказ);
			КонецЕсли;
		КонецЕсли;
		
		// Для вида корректировки ЗаСчет сумма прихода должна совпадать с суммой расхода.
		Если ВидКорректировки = Перечисления.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет Тогда
			
			СуммаПриход = ТекущаяСтрока.Сумма;
			СуммаРасход = 0;
			
			КоличествоПриход = ТекущаяСтрока.Количество;
			КоличествоРасход = 0;
			
			// Найдем подчиненные строки.
			Фильтр = Новый Структура;
			Фильтр.Вставить("КлючСтроки", ТекущаяСтрока.КлючСтроки);
			
			РезультатПоиска = УменьшениеЛимита.НайтиСтроки(Фильтр);
			
			Для Каждого ПодчиненнаяСтрока Из РезультатПоиска Цикл
				СуммаРасход 	 = СуммаРасход + ПодчиненнаяСтрока.Сумма;
				КоличествоРасход = КоличествоРасход + ПодчиненнаяСтрока.Количество;
			КонецЦикла;
			
			Префикс = СтрШаблон("УвеличениеЛимита[%1].", Формат(ТекущаяСтрока.НомерСтроки - 1, "ЧН=0; ЧГ="));
			
			Если СуммаПриход <> СуммаРасход Тогда
				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА","КОРРЕКТНОСТЬ",
									СинонимСумма, ТекущаяСтрока.НомерСтроки,  СинонимТаблицы,
									НСтр("ru='Сумма корректировки не совпадает с общей суммой корректировки по списку ""За счет"".';
										|en='The amount of adjustment is not the same as the total amount of the adjustment of the list of ""Through"".'"));
				Поле = Префикс + "Сумма";
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле, ,Отказ);
			КонецЕсли;
			
			Если ВидКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.ГрафикиДоговоров
			 ИЛИ ВидКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
			 
				Если КоличествоПриход <> КоличествоРасход Тогда
					ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА","КОРРЕКТНОСТЬ",
										СинонимКоличество, ТекущаяСтрока.НомерСтроки, СинонимТаблицы,
										НСтр("ru='Количество не совпадает с общим количеством по списку ""За счет"".';
											|en='The number does not coincide with the total number in list ""Through"".'"));					
					Поле = Префикс + "Количество";
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле, ,Отказ);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// Данные документа поддерживают ввод отрицательных значений.
		// Это исторически сложившийся факт. Сообщим об ошибке, но отказ изменять не станем.
		// В будущих релизах эта возможность будет отключена.
		Если ВидКорректировки = Перечисления.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет Тогда
			НазваниеПравильнойТаблицы = НСтр("ru='За счет';en='At the expense of'");
		Иначе
			НазваниеПравильнойТаблицы = НСтр("ru = 'Уменьшение лимита'; en = 'Limit reduction'");
		КонецЕсли;
		
		Если ВидКорректировки = Перечисления.бит_ВидыКорректировокКонтрольныхЗначений.ВозвратЛимита Тогда
			
			Пояснение = НСтр("ru = 'Отрицательные значения не поддерживаются. Для уменьшения величины лимита используйте список ""%1"".'; 
							|en = 'Negative values are not supported. To reduce the limit, use the ""%1 "" list.'");
			Пояснение = СтрШаблон(Пояснение, НазваниеПравильнойТаблицы);
			КритическаяОшибка = Истина;
			
			Префикс = СтрШаблон("УвеличениеЛимита[%1].", Формат(ТекущаяСтрока.НомерСтроки - 1, "ЧН=0; ЧГ="));
			
			Если ТекущаяСтрока.Сумма < 0 Тогда	 
				Поле 		   = Префикс + "Сумма";
				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА", "КОРРЕКТНОСТЬ",
									СинонимСумма, ТекущаяСтрока.НомерСтроки, СинонимТаблицы, Пояснение);
				Если КритическаяОшибка Тогда
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле,, Отказ);
				Иначе	
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле);
				КонецЕсли;					 
			КонецЕсли;

			Если ТекущаяСтрока.Количество < 0 Тогда	 
				Поле 		   = Префикс + "Количество";
				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА", "КОРРЕКТНОСТЬ",
									СинонимКоличество, ТекущаяСтрока.НомерСтроки, СинонимТаблицы, Пояснение);
				
				Если КритическаяОшибка Тогда
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле,, Отказ);
				Иначе	
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле);
				КонецЕсли;					 
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

