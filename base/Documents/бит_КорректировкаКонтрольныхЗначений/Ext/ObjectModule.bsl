Функция РезультатПодбораНастроекКонтроля(ИсполнениеБюджета, ИсполнениеБюджетаРеквизиты)
	
	Если НЕ ЗначениеЗаполнено(ИсполнениеБюджетаРеквизиты) ИЛИ НЕ ЗначениеЗаполнено(ИсполнениеБюджета) Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	Реквизиты = ИсполнениеБюджетаРеквизиты[0];

	Если Реквизиты.РежимКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
		Сценарий 	  = Реквизиты.СценарийКонтролируемый;
		Периодичность = бит_КонтрольИсполненияБюджета.ПериодичностьКонтроляСценария(Реквизиты.СценарийКонтролируемый);
	Иначе
		Сценарий 	  = Реквизиты.Сценарий;
		Периодичность = бит_КонтрольИсполненияБюджета.ПериодичностьКонтроляСценария(Реквизиты.Сценарий);
	КонецЕсли;
	
	ТаблицаДляЦелейКонтроля = бит_КонтрольИсполненияБюджета.ПустаяТаблицаИсполнениеБюджетаДляЦелейКонтроля();
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсполнениеБюджета, ТаблицаДляЦелейКонтроля);
	бит_КонтрольИсполненияБюджета.ОчиститьНеИспользуемыеАналитики(ТаблицаДляЦелейКонтроля);
	
	Запрос = Новый Запрос(); 
	Запрос.УстановитьПараметр("ИсполнениеБюджета", 		ТаблицаДляЦелейКонтроля);
	Запрос.УстановитьПараметр("СценарийКонтролируемый", Сценарий);
	Запрос.УстановитьПараметр("РежимКонтроля", 	   		Реквизиты.РежимКонтроля);
	Запрос.УстановитьПараметр("Периодичность", 	   		Периодичность);
	Запрос.УстановитьПараметр("КодПериода", 	   		бит_КонтрольИсполненияБюджета.КодПериодичности(Периодичность));
	
	// Аналог см. бит_КонтрольИсполненияБюджета.ПодготовитьТаблицуИсполнениеБюджетаДляЦелейКонтроля().
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИсполнениеБюджета.ИмяСписка КАК ИмяСписка,
	|	ИсполнениеБюджета.СинонимСписка КАК СинонимСписка,
	|	ИсполнениеБюджета.НомерСтроки КАК НомерСтроки,
	|	ИсполнениеБюджета.Период КАК Период,
	|	ИсполнениеБюджета.ЦФО КАК ЦФО,
	|	ИсполнениеБюджета.СтатьяОборотов КАК СтатьяОборотов,
	|	ИсполнениеБюджета.Аналитика_1 КАК Аналитика_1,
	|	ИсполнениеБюджета.Аналитика_2 КАК Аналитика_2,
	|	ИсполнениеБюджета.Аналитика_3 КАК Аналитика_3,
	|	ИсполнениеБюджета.Аналитика_4 КАК Аналитика_4,
	|	ИсполнениеБюджета.Аналитика_5 КАК Аналитика_5,
	|	ИсполнениеБюджета.Аналитика_6 КАК Аналитика_6,
	|	ИсполнениеБюджета.Аналитика_7 КАК Аналитика_7,
	|	ИсполнениеБюджета.Сумма КАК Сумма,
	|	ИсполнениеБюджета.Количество КАК Количество,
	|	ИсполнениеБюджета.КонтролироватьСумму КАК КонтролироватьСумму,
	|	ИсполнениеБюджета.КонтролироватьКоличество КАК КонтролироватьКоличество,
