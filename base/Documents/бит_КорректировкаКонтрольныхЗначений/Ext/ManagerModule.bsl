	// 1. 	Если данные документа совпали с данными регистра "бит_СрокиКонтроляПоБюджету",
	// 		тогда считается, что автоподбор состоялся.
	// 2. 	Если автоподбор не состоялся, считаем что контроль ведется по всем полям и периодичность
	// 		берем из сценария. 
	//		Такое допущение применяется потому что, если при проведении документов исполнения
	// 		не удается определить настройку, используется такая же методика.
	//		Однако, при возврате (уменьшении) все равно будет выполнен контроль наличия лимитов,
	//		возврат которых выполняется.
	
	НомераТаблиц.Вставить("КорректировкиНастроекКонтроляРеквизиты", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("КорректировкиНастроекКонтроля", НомераТаблиц.Количество());
