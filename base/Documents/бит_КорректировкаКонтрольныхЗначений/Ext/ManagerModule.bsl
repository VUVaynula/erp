Процедура СообщитьОПересеченииНастроек(Выборка, НастройкиКонтроля, Отказ)
	
	Перем КлючЗначение, Поля, Счетчик, ТекстСообщения;
	
	Счетчик = 1;
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(НастройкиКонтроля, Выборка);
		Поля = Новый Массив; 
		Поля.Добавить(ПредставлениеПериода(Выборка.НачалоПериода, Выборка.КонецПериода, "ФП = Истина"));
		Поля.Добавить(Выборка.СтатьяОборотов);
		Для каждого КлючЗначение Из НастройкиКонтроля Цикл
			ИмяПоля = "Контроль" + КлючЗначение.Ключ;
			Если Выборка[ИмяПоля] Тогда
				Поля.Добавить(КлючЗначение.Значение);
			КонецЕсли;
		КонецЦикла; 
		
		ТекстСообщения = НСтр("ru = 'Для настроек контроля %1 уже установлены лимиты документом %2'; 
							|en = 'The %1 control settings already have limits set for % 2'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, СтрСоединить(Поля, "/"), Выборка.Регистратор);

		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Выборка.Регистратор, , ,Отказ);
		
		Если Счетчик = 25 Тогда
			ТекстСообщения = НСтр("ru = 'И еще %1 таких же ошибок.'; en = 'And another %1 of the same errors.'"); 	
			ТекстСообщения = СтрШаблон(ТекстСообщения, Выборка.Количество() - Счетчик);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , ,Отказ);
		КонецЕсли;
		Счетчик = Счетчик + 1;
	КонецЦикла;

КонецПроцедуры 

