Процедура ВыполнитьКонтрольПересеченияНастроек(КорректировкиНастроек, КорректировкиНастроекРеквизиты, Отказ) Экспорт

	Если НЕ ЗначениеЗаполнено(КорректировкиНастроек) ИЛИ НЕ ЗначениеЗаполнено(КорректировкиНастроекРеквизиты) ИЛИ Отказ Тогда 
		Возврат;
	КонецЕсли;
	
	Реквизиты 	  = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(КорректировкиНастроекРеквизиты[0]);
	Периодичность = Реквизиты.Периодичность;
	
	НастройкиКонтроля = бит_КонтрольИсполненияБюджета.ИзмеренияКонтроля(); 
	НастройкиКонтроля.Удалить("СтатьяОборотов");

	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Регистратор", 			Реквизиты.Регистратор);
	Запрос.УстановитьПараметр("КорректировкиНастроек", 	КорректировкиНастроек);
	Запрос.УстановитьПараметр("СценарийКонтролируемый", Реквизиты.СценарийКонтролируемый);
	Запрос.УстановитьПараметр("Сценарий", 				Реквизиты.Сценарий);
	Запрос.УстановитьПараметр("РежимКонтроля", 	   		Реквизиты.РежимКонтроля);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Таблица.КонтрольЦФО КАК КонтрольЦФО,
	|	Таблица.НачалоПериода КАК ДатаНачалаКонтроля,
	|	Таблица.КонецПериода КАК ДатаОкончанияКонтроля,
	|	Таблица.Периодичность КАК Периодичность,
	|	&РежимКонтроля КАК РежимКонтроля,
	|	&Регистратор КАК Регистратор,
	|	&СценарийКонтролируемый КАК СценарийКонтролируемый,
	|	&Сценарий КАК Сценарий,
	|	Таблица.ИмяСписка КАК ИмяСписка,
	|	Таблица.СинонимСписка КАК СинонимСписка,
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.Период КАК Период,
	|	Таблица.ЦФО КАК ЦФО,
	|	Таблица.СтатьяОборотов КАК СтатьяОборотов,
	|	Таблица.КонтрольАналитика_1 КАК КонтрольАналитика_1,
	|	Таблица.КонтрольАналитика_2 КАК КонтрольАналитика_2,
	|	Таблица.КонтрольАналитика_3 КАК КонтрольАналитика_3,
	|	Таблица.КонтрольАналитика_4 КАК КонтрольАналитика_4,
	|	Таблица.КонтрольАналитика_5 КАК КонтрольАналитика_5,
	|	Таблица.КонтрольАналитика_6 КАК КонтрольАналитика_6,
	|	Таблица.КонтрольАналитика_7 КАК КонтрольАналитика_7,
	|	Таблица.КонтрольАналитика_8 КАК КонтрольАналитика_8,
	|	Таблица.КонтрольАналитика_9 КАК КонтрольАналитика_9,
	|	Таблица.КонтрольАналитика_10 КАК КонтрольАналитика_10,
	|	Таблица.КонтрольАналитика_11 КАК КонтрольАналитика_11,
	|	Таблица.КонтрольАналитика_12 КАК КонтрольАналитика_12,
	|	Таблица.Аналитика_1 КАК Аналитика_1,
	|	Таблица.Аналитика_2 КАК Аналитика_2,
	|	Таблица.Аналитика_3 КАК Аналитика_3,
	|	Таблица.Аналитика_4 КАК Аналитика_4,
	|	Таблица.Аналитика_5 КАК Аналитика_5,
	|	Таблица.Аналитика_6 КАК Аналитика_6,
	|	Таблица.Аналитика_7 КАК Аналитика_7,
	|	Таблица.Аналитика_8 КАК Аналитика_8,
	|	Таблица.Аналитика_9 КАК Аналитика_9,
	|	Таблица.Аналитика_10 КАК Аналитика_10,
	|	Таблица.Аналитика_11 КАК Аналитика_11,
	|	Таблица.Аналитика_12 КАК Аналитика_12
	|ПОМЕСТИТЬ ВременнаяТаблица
	|ИЗ
	|	&КорректировкиНастроек КАК Таблица";
	
	Запрос.Выполнить();
	
	// По данным документа.
	ВыполнитьКонтрольПересеченияНастроекЧ11(Запрос, НастройкиКонтроля, Отказ);
	ВыполнитьКонтрольПересеченияНастроекЧ21(Запрос, НастройкиКонтроля, Отказ);
	ВыполнитьКонтрольПересеченияНастроекЧ31(Запрос, НастройкиКонтроля, Отказ);

	// По данным базы.
	ВыполнитьКонтрольПересеченияНастроекЧ1(Запрос, НастройкиКонтроля, Отказ);
	ВыполнитьКонтрольПересеченияНастроекЧ2(Запрос, НастройкиКонтроля, Отказ);
	ВыполнитьКонтрольПересеченияНастроекЧ3(Запрос, НастройкиКонтроля, Отказ);

КонецПроцедуры

Процедура ДобавитьКолонкиКонтрольныхЗначенийВФормеПодбора(Форма) Экспорт

	// ++ ЕРП 
	ДобавляемыеРеквизиты = Новый Массив();
	Для Номер = 1 По 12 Цикл
		ИмяРеквизита       = СтрШаблон("Аналитика_%1", Номер);
		ТипРеквизита       = Метаданные.ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.Тип;
		ПутьКДанным        = "КонтрольныеЗначенияБюджетов";
		ЗаголовокРеквизита = СтрШаблон(НСтр("ru = 'Аналитика № %1'"), Номер);
		
		НовыйРеквизит = Новый РеквизитФормы(ИмяРеквизита,ТипРеквизита,ПутьКДанным); 
		ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);
	КонецЦикла; 
	
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	// -- ЕРП  
	
КонецПроцедуры

