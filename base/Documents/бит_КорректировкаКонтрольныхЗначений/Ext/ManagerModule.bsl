Функция ТекстЗапросаВременныеТаблицыДокумента(НомераТаблиц)

	НомераТаблиц.Вставить("ВременнаяТаблицаСуммыКорректировок", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ВременнаяТаблицаКорректировкиНастроекКонтроля", НомераТаблиц.Количество());

	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(&ИмяСпискаУвеличениеЛимита КАК СТРОКА(50)) КАК ИмяСписка,
	|	ВЫРАЗИТЬ(&СинонимСпискаУвеличениеЛимита КАК СТРОКА(50)) КАК СинонимСписка,
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.Период КАК Период,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольЦФО
	|			ТОГДА Таблица.ЦФО
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка)
	|	КОНЕЦ КАК ЦФО,
	|	Таблица.СтатьяОборотов КАК СтатьяОборотов,
	|	ВЫБОР &ВидКорректировки
	|		КОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ВозвратЛимита)
	|			ТОГДА Таблица.Сумма
	|		ИНАЧЕ ВЫБОР
	|				КОГДА Таблица.Сумма >= 0
	|					ТОГДА Таблица.Сумма
	|				ИНАЧЕ -Таблица.Сумма
	|			КОНЕЦ
	|	КОНЕЦ КАК Сумма,
	|	ВЫБОР &ВидКорректировки
	|		КОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ВозвратЛимита)
	|			ТОГДА Таблица.Количество
	|		ИНАЧЕ ВЫБОР
	|				КОГДА Таблица.Количество >= 0
	|					ТОГДА Таблица.Количество
	|				ИНАЧЕ -Таблица.Количество
	|			КОНЕЦ
	|	КОНЕЦ КАК Количество,
	|	ВЫБОР &ВидКорректировки
	|		КОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ВозвратЛимита)
	|			ТОГДА ""ВозвратЛимита""
	|		ИНАЧЕ ВЫБОР
	|				КОГДА Таблица.Сумма >= 0
	|					ТОГДА ""УвеличениеЛимита""
	|				ИНАЧЕ ""УменьшениеЛимита""
	|			КОНЕЦ
	|	КОНЕЦ КАК ГруппаСтрок,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольЦФО КАК КонтрольЦФО,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_1 КАК КонтрольАналитика_1,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_2 КАК КонтрольАналитика_2,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_3 КАК КонтрольАналитика_3,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_4 КАК КонтрольАналитика_4,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_5 КАК КонтрольАналитика_5,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_6 КАК КонтрольАналитика_6,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_7 КАК КонтрольАналитика_7,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_1
	|			ТОГДА Таблица.Аналитика_1
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_1,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_2
	|			ТОГДА Таблица.Аналитика_2
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_2,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_3
	|			ТОГДА Таблица.Аналитика_3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_3,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_4
	|			ТОГДА Таблица.Аналитика_4
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_4,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_5
	|			ТОГДА Таблица.Аналитика_5
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_5,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_6
	|			ТОГДА Таблица.Аналитика_6
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_6,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_7
	|			ТОГДА Таблица.Аналитика_7
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_7,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_8 КАК КонтрольАналитика_8,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_9 КАК КонтрольАналитика_9,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_10 КАК КонтрольАналитика_10,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_11 КАК КонтрольАналитика_11,
	|	ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_12 КАК КонтрольАналитика_12,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_8
	|			ТОГДА Таблица.Аналитика_8
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_8,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_9
	|			ТОГДА Таблица.Аналитика_9
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_9,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_10
	|			ТОГДА Таблица.Аналитика_10
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_10,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_11
	|			ТОГДА Таблица.Аналитика_11
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_11,
	|	ВЫБОР
	|		КОГДА ВТИсточникНастроекКонтроляВДокументе.КонтрольАналитика_12
	|			ТОГДА Таблица.Аналитика_12
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Аналитика_12
	|ПОМЕСТИТЬ ТаблицаСуммыКорректировок
	|ИЗ
	|	Документ.бит_КорректировкаКонтрольныхЗначений.УвеличениеЛимита КАК Таблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсточникНастроекКонтроляВДокументе КАК ВТИсточникНастроекКонтроляВДокументе
	|		ПО Таблица.НомерСтроки = ВТИсточникНастроекКонтроляВДокументе.НомерСтроки
	|ГДЕ
	|	Таблица.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(&ИмяСпискаУменьшениеЛимита КАК СТРОКА(50)),
	|	ВЫРАЗИТЬ(&СинонимСпискаУменьшениеЛимита КАК СТРОКА(50)),
	|	Таблица.НомерСтроки,
	|	Таблица.Период,
	|	Таблица.ЦФО,
	|	Таблица.СтатьяОборотов,
		|	ВЫБОР &ВидКорректировки
	|		КОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ВозвратЛимита)
	|			ТОГДА Таблица.Сумма
	|		ИНАЧЕ ВЫБОР
	|				КОГДА Таблица.Сумма >= 0
	|					ТОГДА Таблица.Сумма
	|				ИНАЧЕ -Таблица.Сумма
	|			КОНЕЦ
