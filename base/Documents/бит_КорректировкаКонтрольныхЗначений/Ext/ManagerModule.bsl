// Функция подготавливает параметры проведения.
// 
// Параметры:
//  ДокументСсылка - ДокументСсылка.бит_КорректировкаКонтрольныхЗначений - ссылка на документ.
//  Отказ          - Булево - признак обнаружения ошибки и отказа от дальнейших действий.
//
// Возвращаемое значение:
//  Структура - структура параметров проведения.
//
Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт
	
	ПараметрыПроведения = Новый Структура(); 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Дата КАК Период,
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.Сценарий КАК Сценарий,
	|	Реквизиты.РежимПринятияКУчету КАК РежимПринятияКУчету,
	|	Реквизиты.СценарийКонтролируемый КАК СценарийКонтролируемый,
	|	Реквизиты.ВидКорректировки КАК ВидКорректировки,
	|	Реквизиты.ВидКонтроля КАК ВидКонтроля,
	|	Реквизиты.ПериодичностьКонтроля КАК ПериодичностьКонтроля,
	|	Реквизиты.ДатаНачалаКонтроля КАК ДатаНачалаКонтроля,
	|	Реквизиты.ДатаОкончанияКонтроля КАК ДатаОкончанияКонтроля,
	|	Реквизиты.СпособУстановкиРазрезовКонтроля КАК СпособУстановкиРазрезовКонтроля
	|ИЗ
	|	Документ.бит_КорректировкаКонтрольныхЗначений КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";
	Результат = Запрос.Выполнить().Выгрузить();
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Результат[0]);
	
	Если НЕ бит_ОбщегоНазначения.ВалютаУпрУчетаУстановлена(Истина, ДокументСсылка) Тогда
		Отказ = Истина;
		Возврат ПараметрыПроведения;
	КонецЕсли;
			
	ПараметрыНастройки		= Новый Структура;
	НеУчитыватьСверхБюджета = бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеЗаявкиПриКонтролеПоБюджету(ПараметрыНастройки, 
									Реквизиты.Период);

	Запрос = Новый Запрос(); 
	Запрос.УстановитьПараметр("Ссылка",					ДокументСсылка);
	Запрос.УстановитьПараметр("Период",					Реквизиты.Период);
	Запрос.УстановитьПараметр("СценарийКонтролируемый", Реквизиты.СценарийКонтролируемый);
	Запрос.УстановитьПараметр("Сценарий", 				Реквизиты.Сценарий);
	Запрос.УстановитьПараметр("Периодичность",			Реквизиты.ПериодичностьКонтроля);
	Запрос.УстановитьПараметр("КодПериода",				бит_КонтрольИсполненияБюджета.КодПериодичности(Реквизиты.ПериодичностьКонтроля));
	Запрос.УстановитьПараметр("ДатаНачалаКонтроля",		Реквизиты.ДатаНачалаКонтроля);
	Запрос.УстановитьПараметр("ДатаОкончанияКонтроля",	Реквизиты.ДатаОкончанияКонтроля);
	Запрос.УстановитьПараметр("КодПериода",				бит_КонтрольИсполненияБюджета.КодПериодичности(Реквизиты.ПериодичностьКонтроля));
	Запрос.УстановитьПараметр("ВидКорректировки",		Реквизиты.ВидКорректировки);
	Запрос.УстановитьПараметр("РежимКонтроля",			Реквизиты.ВидКонтроля);
	Запрос.УстановитьПараметр("НеУчитыватьСверхБюджета",НеУчитыватьСверхБюджета);
	
	Запрос.УстановитьПараметр("ИмяСпискаУвеличениеЛимита", "УвеличениеЛимита"); 
	Запрос.УстановитьПараметр("СинонимСпискаУвеличениеЛимита", НСтр("ru = 'Увеличение лимита'; en = 'Increasing the limit'"));
	Запрос.УстановитьПараметр("ИмяСпискаУменьшениеЛимита", "УменьшениеЛимита"); 
	Запрос.УстановитьПараметр("СинонимСпискаУменьшениеЛимита", НСтр("ru = 'Уменьшение лимита'; en = 'Limit reduction'"));

	СпособУстановкиКонтроля = Реквизиты.СпособУстановкиРазрезовКонтроля;
	
	НомераТаблиц = Новый Структура(); 
	ТекстЗапроса = ТекстЗапросаВременнаяТаблицаИсточникНастроекКонтроляВДокументе(НомераТаблиц, СпособУстановкиКонтроля)
				 + ТекстЗапросаВременныеТаблицыДокумента(НомераТаблиц)
				 + ТекстЗапросаКорректировкаНастроекКонтроля(НомераТаблиц) 
				 + ТекстЗапросаИсполнениеБюджета(НомераТаблиц); 
				 			 
	Запрос.Текст = ТекстЗапроса;
	Результат 	 = Запрос.ВыполнитьПакет();
	
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла; 	
	ПараметрыПроведения.Вставить("Реквизиты", Реквизиты);
	
	ПроверитьПротиворечиеНастроек(ПараметрыПроведения.КонтрольПротиворечияНастроек, 
		ПараметрыПроведения.КорректировкиНастроекКонтроляРеквизиты , Отказ);
	
	Если Отказ Тогда
		Возврат ПараметрыПроведения;
	КонецЕсли;
	
	Возврат ПараметрыПроведения;
	
КонецФункции 

