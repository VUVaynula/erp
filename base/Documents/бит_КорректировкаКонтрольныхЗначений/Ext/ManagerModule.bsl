#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПроверитьПротиворечиеНастроек(КонтрольПротиворечияНастроек, КорректировкиНастроекКонтроляРеквизиты, Отказ)

	// См."Множественный Контроль" в установке КЗ.
	Реквизиты = КорректировкиНастроекКонтроляРеквизиты[0];
	Сценарий  = Реквизиты.Сценарий;	
	Для каждого СтрокаТаблицы Из КонтрольПротиворечияНастроек Цикл
		ПредставлениеПериода = бит_ОбщегоНазначения.СформироватьПредставлениеПериода(СтрокаТаблицы.Период, Реквизиты.Периодичность);
		
		Пояснение = НСтр("ru = 'В течение периода ""%1"" статья ""%2"" контролируется и сценарием ""%3"" и сценарием ""%4"". Множественный контроль запрещен.';
					|en = 'During ""%1"" period in article ""%2"" control in same time by ""%3"" and ""%4"" scenario. Multiple control is prohibited.'");
		Пояснение = СтрШаблон(Пояснение, ПредставлениеПериода, СтрокаТаблицы.СтатьяОборотов, СтрокаТаблицы.Сценарий, Сценарий);				
		
		// Шаблон вида: "ИмяТабличнойЧасти[ИндексСтроки].СтатьяОборотов".
		Поле 		   = СтрШаблон("%1[%2].СтатьяОборотов", СтрокаТаблицы.ИмяСписка, 
							Формат(СтрокаТаблицы.НомерСтроки - 1, "ЧН=0; ЧГ="));
							
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка", 
							"Корректность", НСтр("ru = 'Статья оборотов'; en = 'Line Item'"), 
							СтрокаТаблицы.НомерСтроки, СтрокаТаблицы.СинонимСписка, Пояснение);

		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Реквизиты.Регистратор, Поле, ,Отказ); 
	КонецЦикла; 	

КонецПроцедуры

Функция ТекстЗапросаВременнаяТаблицаИсточникНастроекКонтроляВДокументе(НомераТаблиц, СпособУстановкиКонтроля)

	НомераТаблиц.Вставить("ВременнаяТаблицаИсточникНастроекКонтроляВДокументе", НомераТаблиц.Количество());
	
	Если СпособУстановкиКонтроля = Перечисления.бит_СпособыУстановкиРазрезовКонтроля.ВручнуюИзШапки Тогда
	
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Таблица.НомерСтроки КАК НомерСтроки,
		|	Реквизиты.КонтрольЦФО КАК КонтрольЦФО,
		|	Реквизиты.КонтрольАналитика_1 КАК КонтрольАналитика_1,
		|	Реквизиты.КонтрольАналитика_2 КАК КонтрольАналитика_2,
		|	Реквизиты.КонтрольАналитика_3 КАК КонтрольАналитика_3,
		|	Реквизиты.КонтрольАналитика_4 КАК КонтрольАналитика_4,
		|	Реквизиты.КонтрольАналитика_5 КАК КонтрольАналитика_5,
		|	Реквизиты.КонтрольАналитика_6 КАК КонтрольАналитика_6,
		|	Реквизиты.КонтрольАналитика_7 КАК КонтрольАналитика_7,
		|	Реквизиты.КонтрольАналитика_8 КАК КонтрольАналитика_8,
		|	Реквизиты.КонтрольАналитика_9 КАК КонтрольАналитика_9,
		|	Реквизиты.КонтрольАналитика_10 КАК КонтрольАналитика_10,
		|	Реквизиты.КонтрольАналитика_11 КАК КонтрольАналитика_11,
		|	Реквизиты.КонтрольАналитика_12 КАК КонтрольАналитика_12
		|ПОМЕСТИТЬ ВТИсточникНастроекКонтроляВДокументе
		|ИЗ
		|	Документ.бит_КорректировкаКонтрольныхЗначений.УвеличениеЛимита КАК Таблица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_КорректировкаКонтрольныхЗначений КАК Реквизиты
		|		ПО Таблица.Ссылка = Реквизиты.Ссылка И Реквизиты.Ссылка = &Ссылка";
		
	ИначеЕсли СпособУстановкиКонтроля = Перечисления.бит_СпособыУстановкиРазрезовКонтроля.ИзНастройки Тогда
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	Таблица.НомерСтроки КАК НомерСтроки,
		|	УстановкиКонтрольныхЗначений.НЗ_ЦФО КАК КонтрольЦФО,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_1 КАК КонтрольАналитика_1,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_2 КАК КонтрольАналитика_2,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_3 КАК КонтрольАналитика_3,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_4 КАК КонтрольАналитика_4,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_5 КАК КонтрольАналитика_5,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_6 КАК КонтрольАналитика_6,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_7 КАК КонтрольАналитика_7,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_8 КАК КонтрольАналитика_8,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_9 КАК КонтрольАналитика_9,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_10 КАК КонтрольАналитика_10,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_11 КАК КонтрольАналитика_11,
		|	УстановкиКонтрольныхЗначений.НЗ_Аналитика_12 КАК КонтрольАналитика_12
		|ПОМЕСТИТЬ ВТИсточникНастроекКонтроляВДокументе
		|ИЗ
		|	Документ.бит_КорректировкаКонтрольныхЗначений.УвеличениеЛимита КАК Таблица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_КорректировкаКонтрольныхЗначений КАК Реквизиты
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_УстановкаКонтрольныхЗначений КАК УстановкиКонтрольныхЗначений
		|			ПО Реквизиты.НастройкаКонтроля = УстановкиКонтрольныхЗначений.Ссылка
		|		ПО Таблица.Ссылка = Реквизиты.Ссылка И Реквизиты.Ссылка = &Ссылка";
		
	ИначеЕсли СпособУстановкиКонтроля = Перечисления.бит_СпособыУстановкиРазрезовКонтроля.ВручнуюПоСтрочно Тогда
		
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Таблица.НомерСтроки КАК НомерСтроки,
		|	Таблица.КонтрольЦФО КАК КонтрольЦФО,
		|	Таблица.КонтрольАналитика_1 КАК КонтрольАналитика_1,
		|	Таблица.КонтрольАналитика_2 КАК КонтрольАналитика_2,
		|	Таблица.КонтрольАналитика_3 КАК КонтрольАналитика_3,
		|	Таблица.КонтрольАналитика_4 КАК КонтрольАналитика_4,
		|	Таблица.КонтрольАналитика_5 КАК КонтрольАналитика_5,
		|	Таблица.КонтрольАналитика_6 КАК КонтрольАналитика_6,
		|	Таблица.КонтрольАналитика_7 КАК КонтрольАналитика_7,
		|	Таблица.КонтрольАналитика_8 КАК КонтрольАналитика_8,
		|	Таблица.КонтрольАналитика_9 КАК КонтрольАналитика_9,
		|	Таблица.КонтрольАналитика_10 КАК КонтрольАналитика_10,
		|	Таблица.КонтрольАналитика_11 КАК КонтрольАналитика_11,
		|	Таблица.КонтрольАналитика_12 КАК КонтрольАналитика_12
		|ПОМЕСТИТЬ ВТИсточникНастроекКонтроляВДокументе
		|ИЗ
		|	Документ.бит_КорректировкаКонтрольныхЗначений.УвеличениеЛимита КАК Таблица
		|ГДЕ
		|	Таблица.Ссылка = &Ссылка";
		
	ИначеЕсли СпособУстановкиКонтроля = Перечисления.бит_СпособыУстановкиРазрезовКонтроля.Автоматически Тогда
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	Таблица.НомерСтроки КАК НомерСтроки,
		|	Таблица.ЦФО <> ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка) КАК КонтрольЦФО,
		|	Таблица.Аналитика_1 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_1,
		|	Таблица.Аналитика_2 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_2,
		|	Таблица.Аналитика_3 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_3,
		|	Таблица.Аналитика_4 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_4,
		|	Таблица.Аналитика_5 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_5,
		|	Таблица.Аналитика_6 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_6,
		|	Таблица.Аналитика_7 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_7,
		|	Таблица.Аналитика_8 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_8,
		|	Таблица.Аналитика_9 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_9,
		|	Таблица.Аналитика_10 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_10,
		|	Таблица.Аналитика_11 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_11,
		|	Таблица.Аналитика_12 <> НЕОПРЕДЕЛЕНО КАК КонтрольАналитика_12
		|ПОМЕСТИТЬ ВТИсточникНастроекКонтроляВДокументе
		|ИЗ
		|	Документ.бит_КорректировкаКонтрольныхЗначений.УвеличениеЛимита КАК Таблица
		|ГДЕ
		|	Таблица.Ссылка = &Ссылка";
		
	КонецЕсли;
	
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();

