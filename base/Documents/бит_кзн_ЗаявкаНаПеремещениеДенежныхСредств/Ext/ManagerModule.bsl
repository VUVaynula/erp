// Функция получает плановую и фактическую сумму оплат по позиции.
//
// Параметры:
//  Позиция	 - ДокументСсылка.бит_кзн_ПозицияПоступления - позиция поступления.
// 
// Возвращаемое значение:
//  СтруктураРезультат - Структура: структура.
//
Функция СтруктураОплатыПоЗаявкеНаПеремещение(Заявка) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	СтруктураРезультат = Новый Структура;
	СтруктураРезультат.Вставить("СуммаПлан"	 , 0);
	СтруктураРезультат.Вставить("СуммаОплата", 0);
	СтруктураРезультат.Вставить("Разность"	 , 0);
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", Заявка);
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЕСТЬNULL(ПоступлениеПлан.СуммаКонечныйОстаток, 0) + ЕСТЬNULL(РасходПлан.СуммаКонечныйОстаток, 0) КАК СуммаОстаток,
	               |	ЕСТЬNULL(ПоступлениеПлан.СуммаПриход, 0) + ЕСТЬNULL(РасходПлан.СуммаПриход, 0) КАК СуммаПлан,
	               |	ЕСТЬNULL(ПоступлениеПлан.СуммаРасход, 0) + ЕСТЬNULL(РасходПлан.СуммаРасход, 0) КАК СуммаФакт
	               |ИЗ
	               |	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ОстаткиИОбороты(, , , , ДокументПланирования = &ДокументПланирования) КАК ПоступлениеПлан,
	               |	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.ОстаткиИОбороты(, , , , ДокументПланирования = &ДокументПланирования) КАК РасходПлан";

	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		СтруктураРезультат.СуммаПлан   = Выборка.СуммаПлан;
		СтруктураРезультат.СуммаОплата = Выборка.СуммаФакт;
		СтруктураРезультат.Разность    = Выборка.СуммаОстаток;
		
	КонецЕсли; 

	Возврат СтруктураРезультат;
	
КонецФункции

Функция ИспользованиеРеквизитовПоХозяйственнойОперации(ХозяйственнаяОперация) Экспорт

	ИспользованиеРеквизитов = Новый Структура;
	ИспользованиеРеквизитов.Вставить("БанковскийСчет", Ложь);
	ИспользованиеРеквизитов.Вставить("БанковскийСчетПолучатель", Ложь);
	ИспользованиеРеквизитов.Вставить("Касса", Ложь);
	ИспользованиеРеквизитов.Вставить("КассаПолучатель", Ложь);
		
	Если ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствВДругуюКассу Тогда
		
		ИспользованиеРеквизитов.Касса 			= Истина;
		ИспользованиеРеквизитов.КассаПолучатель = Истина;
		
	ИначеЕсли ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствВБанк 
		ИЛИ ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.СдачаДенежныхСредствВБанк Тогда		
		
		ИспользованиеРеквизитов.БанковскийСчетПолучатель = Истина;
		ИспользованиеРеквизитов.Касса					 = Истина;
		
	ИначеЕсли ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствИзБанка 
		ИЛИ ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ПоступлениеДенежныхСредствИзБанка Тогда		
		
		ИспользованиеРеквизитов.КассаПолучатель = Истина;
		ИспользованиеРеквизитов.БанковскийСчет 	= Истина;
		
	ИначеЕсли ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеДенежныхСредствНаДругойСчет Тогда	
		
		ИспользованиеРеквизитов.БанковскийСчет 			 = Истина;
		ИспользованиеРеквизитов.БанковскийСчетПолучатель = Истина;
		
	КонецЕсли;	
	
	Возврат ИспользованиеРеквизитов;
	
КонецФункции

Процедура ЗаполнитьРеквизитыДокументаПоХозяйственнойОперации(Объект) Экспорт
	
	Если Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.СдачаДенежныхСредствВБанк
		ИЛИ Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствВБанк
		ИЛИ Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствВДругуюКассу Тогда
		
		СтруктураПараметров = ДенежныеСредстваСервер.ПараметрыЗаполненияКассыОрганизацииПоУмолчанию();
		СтруктураПараметров.Организация  = Объект.Организация;
		СтруктураПараметров.Касса        = Объект.Касса;
		
		Объект.Касса = ЗначениеНастроекПовтИсп.ПолучитьКассуОрганизацииПоУмолчанию(СтруктураПараметров);
		Объект.ВалютаДокумента = Справочники.Кассы.ПолучитьРеквизитыКассы(Объект.Касса).Валюта;
		
	ИначеЕсли Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ПоступлениеДенежныхСредствИзБанка
		ИЛИ Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствИзБанка
		ИЛИ Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеДенежныхСредствНаДругойСчет Тогда
		
		СтруктураПараметров = ДенежныеСредстваСервер.ПараметрыЗаполненияБанковскогоСчетаОрганизацииПоУмолчанию();
		СтруктураПараметров.Организация      = Объект.Организация;
		СтруктураПараметров.БанковскийСчет   = Объект.БанковскийСчет;
		
		Объект.БанковскийСчет = ЗначениеНастроекПовтИсп.ПолучитьБанковскийСчетОрганизацииПоУмолчанию(СтруктураПараметров);
		Объект.ВалютаДокумента = Справочники.БанковскиеСчетаОрганизаций.ПолучитьРеквизитыБанковскогоСчетаОрганизации(Объект.БанковскийСчет).Валюта;
	КонецЕсли;
	
	Если Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ПоступлениеДенежныхСредствИзБанка
		ИЛИ Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствИзБанка 
		ИЛИ Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствВДругуюКассу Тогда
		
		ОрганизацияПолучатель = Объект.Организация;
		
		КассаПолучатель = Справочники.Кассы.ПолучитьКассуПоУмолчанию(
			ОрганизацияПолучатель,
			Объект.ВалютаДокумента);
		Если ЗначениеЗаполнено(КассаПолучатель) Тогда
			Объект.КассаПолучатель = КассаПолучатель;
		КонецЕсли;
		
	ИначеЕсли Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.СдачаДенежныхСредствВБанк
		ИЛИ Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствВБанк 
		ИЛИ Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеДенежныхСредствНаДругойСчет Тогда
		ОрганизацияПолучатель = Объект.Организация;
		
		БанковскийСчетПолучатель = Справочники.БанковскиеСчетаОрганизаций.ПолучитьБанковскийСчетОрганизацииПоУмолчанию(
			ОрганизацияПолучатель,
			Объект.ВалютаДокумента);
		Если ЗначениеЗаполнено(БанковскийСчетПолучатель) Тогда
			Объект.БанковскийСчетПолучатель = БанковскийСчетПолучатель;
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

Функция СтатьяОборотовПоВидуОперации(ХозяйственнаяОперация) Экспорт
	
	СтатьяОборотов = Справочники.бит_СтатьиОборотов.ПустаяСсылка();
	
	Если ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.СдачаДенежныхСредствВБанк
		ИЛИ ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствВБанк Тогда
		СтатьяОборотов = Справочники.бит_СтатьиОборотов.СдачаДенежныхСредствВБанк_РасходованиеПоКассе;
	ИначеЕсли ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствВДругуюКассу Тогда
		СтатьяОборотов = Справочники.бит_СтатьиОборотов.ВыдачаДенежныхСредствВДругуюКассу;
	ИначеЕсли ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеДенежныхСредствНаДругойСчет Тогда
		СтатьяОборотов = Справочники.бит_СтатьиОборотов.ПеречислениеДенежныхСредствНаДругойСчет_расходование;
	ИначеЕсли ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ПоступлениеДенежныхСредствИзБанка
		ИЛИ ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствИзБанка Тогда
		СтатьяОборотов = Справочники.бит_СтатьиОборотов.ПоступлениеДенежныхСредствИзБанка_РасходПоБанку;
	КонецЕсли;
	
	Возврат СтатьяОборотов;
	
КонецФункции

Функция ФормаОплатыПоВидуОперации(ХозяйственнаяОперация) Экспорт
	
	ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
	
	Если ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствВДругуюКассу
		ИЛИ ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ИнкассацияДенежныхСредствВБанк
		ИЛИ ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.СдачаДенежныхСредствВБанк Тогда
		ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Наличные;
	КонецЕсли;
	
	Возврат ФормаОплаты;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДанныеПозиций(ДокументОснование)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПлатежныеПозиции.БанковскийСчет КАК БанковскийСчет,
	|	ПлатежныеПозиции.Касса КАК Касса,
	|	ПлатежныеПозиции.Ссылка КАК Позиция,
	|	ПлатежныеПозиции.НазначениеПлатежа КАК НазначениеПлатежа,
	|	ПлатежныеПозиции.СтатьяОборотов КАК СтатьяОборотов,
	|	ПлатежныеПозиции.ДатаПлан КАК Дата
	|ПОМЕСТИТЬ ВТ_ПлатежныеПозиции
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|ГДЕ
	|	ПлатежныеПозиции.ДокументПланирования = &ДокументПланирования
	|	И НЕ ПлатежныеПозиции.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПозицииПоступления.БанковскийСчет КАК БанковскийСчет,
	|	ПозицииПоступления.Касса КАК Касса,
	|	ПозицииПоступления.Ссылка КАК Позиция,
	|	ПозицииПоступления.НазначениеПлатежа КАК НазначениеПлатежа,
	|	ПозицииПоступления.СтатьяОборотов КАК СтатьяОборотов,
	|	ПозицииПоступления.ДатаПлан КАК Дата
	|ПОМЕСТИТЬ ВТ_ПозицииПоступления
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК ПозицииПоступления
	|ГДЕ
	|	ПозицииПоступления.ДокументПланирования = &ДокументПланирования
	|	И НЕ ПозицииПоступления.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПлатежныеПозиции.БанковскийСчет КАК БанковскийСчет,
	|	ВТ_ПлатежныеПозиции.Касса КАК Касса,
	|	ВТ_ПлатежныеПозиции.Позиция КАК Позиция,
	|	ВТ_ПлатежныеПозиции.НазначениеПлатежа КАК НазначениеПлатежа,
	|	ВТ_ПлатежныеПозиции.СтатьяОборотов КАК СтатьяОборотов,
	|	ВТ_ПлатежныеПозиции.Дата КАК Дата,
	|	ЕСТЬNULL(ПланируемыйРасходДенежныхСредств.СуммаОстаток, 0) КАК Сумма,
	|	"""" КАК ИдентификаторСтроки
	|ИЗ
	|	ВТ_ПлатежныеПозиции КАК ВТ_ПлатежныеПозиции
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.Остатки(
	|				,
	|				Позиция В
	|					(ВЫБРАТЬ
	|						ВТ_ПлатежныеПозиции.Позиция КАК Позиция
	|					ИЗ
	|						ВТ_ПлатежныеПозиции КАК ВТ_ПлатежныеПозиции)) КАК ПланируемыйРасходДенежныхСредств
	|		ПО ВТ_ПлатежныеПозиции.Позиция = ПланируемыйРасходДенежныхСредств.Позиция
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПозицииПоступления.БанковскийСчет КАК БанковскийСчет,
	|	ВТ_ПозицииПоступления.Касса КАК Касса,
	|	ВТ_ПозицииПоступления.Позиция КАК Позиция,
	|	ВТ_ПозицииПоступления.НазначениеПлатежа КАК НазначениеПлатежа,
	|	ВТ_ПозицииПоступления.СтатьяОборотов КАК СтатьяОборотов,
	|	ВТ_ПозицииПоступления.Дата КАК Дата,
	|	ЕСТЬNULL(ПланируемоеПоступлениеДенежныхСредств.СуммаОстаток, 0) КАК Сумма,
	|	"""" КАК ИдентификаторСтроки
	|ИЗ
	|	ВТ_ПозицииПоступления КАК ВТ_ПозицииПоступления
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Остатки(
	|				,
	|				Позиция В
	|					(ВЫБРАТЬ
	|						ВТ_ПозицииПоступления.Позиция КАК Позиция
	|					ИЗ
	|						ВТ_ПозицииПоступления КАК ВТ_ПозицииПоступления)) КАК ПланируемоеПоступлениеДенежныхСредств
	|		ПО ВТ_ПозицииПоступления.Позиция = ПланируемоеПоступлениеДенежныхСредств.Позиция";
	
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументОснование);
	
	Результат = Запрос.ВыполнитьПакет();
	ВыборкаРасход = Результат[2].Выбрать();
	ВыборкаПриход = Результат[3].Выбрать();	
	
	КлючиСтруктуры 	   = "БанковскийСчет, Касса, Позиция, НазначениеПлатежа, СтатьяОборотов, Дата, Сумма, ИдентификаторСтроки";
	ПлатежнаяПозиция   = Новый Структура(КлючиСтруктуры);
	ПозицияПоступления = Новый Структура(КлючиСтруктуры);
	
	Пока ВыборкаРасход.Следующий() Цикл	
		ЗаполнитьЗначенияСвойств(ПлатежнаяПозиция, ВыборкаРасход);
	КонецЦикла;
	
	Пока ВыборкаПриход.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ПозицияПоступления, ВыборкаПриход);
	КонецЦикла;
	
	ДанныеПозиций = Новый Структура;
	ДанныеПозиций.Вставить("ПлатежнаяПозиция",	 ПлатежнаяПозиция);
	ДанныеПозиций.Вставить("ПозицияПоступления", ПозицияПоступления);
	
	Возврат ДанныеПозиций;

КонецФункции

Процедура ЗаполнитьИнкассациюДенежныхСредствВБанк(РеквизитыОснования, ПараметрыЗаполнения, ПлатежныеДокументы)
	
	ДокументОснование = РеквизитыОснования.Ссылка;
	ДанныеПозиций	  = ДанныеПозиций(ДокументОснование);
	
	СоздаватьПоступления = ПараметрыЗаполнения.СоздаватьПоступления;
	СуммаДокумента	 	 = ПараметрыЗаполнения.СуммаДокумента;
	ФактическаяСумма 	 = ПараметрыЗаполнения.ФактическаяСумма;
	
	ДанныеЗаполнения = ДанныеЗаполненияСписаниеЧерезКассу(РеквизитыОснования, ДанныеПозиций, ПараметрыЗаполнения, 
							Перечисления.ХозяйственныеОперации.ИнкассацияДенежныхСредствВБанк);	
								
	ДокументОбъект 		= Документы.РасходныйКассовыйОрдер.СоздатьДокумент();	
	ДокументОбъект.Дата = ДанныеПозиций.ПлатежнаяПозиция.Дата;		
	ДокументОбъект.Заполнить(ДанныеЗаполнения);
	ДокументОбъект.Записать();
	
	ПлатежныеДокументы.Добавить(ДокументОбъект.Ссылка);
	
	ПлатежныеПозиции = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДанныеПозиций.ПлатежнаяПозиция);
	ЗаполнитьОтражениеФакта(ДокументОбъект.Ссылка, ПлатежныеПозиции, ПараметрыЗаполнения);		
		
	Если СоздаватьПоступления Тогда
		ДанныеЗаполнения = ДанныеЗаполненияПоступлениеЧерезБанк(РеквизитыОснования, ДанныеПозиций, ПараметрыЗаполнения, 
								Перечисления.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзКассыНаРасчетныйСчет);
		
		ДокументОбъект		= Документы.ПоступлениеБезналичныхДенежныхСредств.СоздатьДокумент();
		ДокументОбъект.Дата = ДанныеПозиций.ПозицияПоступления.Дата;		
		ДокументОбъект.Заполнить(ДанныеЗаполнения);
		ДокументОбъект.Записать();
		
		ПлатежныеДокументы.Добавить(ДокументОбъект.Ссылка);
		
		ПлатежныеПозиции = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДанныеПозиций.ПозицияПоступления);
		ЗаполнитьОтражениеФакта(ДокументОбъект.Ссылка, ПлатежныеПозиции, ПараметрыЗаполнения);
	КонецЕсли;

КонецПроцедуры

