#Область ОбновлениеИнформационнойБазы

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьКОбработкеДокументыБезМестаХраненияДС(Параметры) Экспорт

	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Дата УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Дата УБЫВ");
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств КАК Реквизиты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПозицияПоступления КАК РеквизитыПозицияПоступления
	|		ПО (РеквизитыПозицияПоступления.ДокументПланирования = Реквизиты.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК РеквизитыПлатежнойПозиции
	|		ПО (РеквизитыПлатежнойПозиции.ДокументПланирования = Реквизиты.Ссылка)
	|ГДЕ
	|	(Реквизиты.БанковскийСчет <> РеквизитыПлатежнойПозиции.БанковскийСчет
	|			ИЛИ Реквизиты.Касса <> РеквизитыПлатежнойПозиции.Касса
	|			ИЛИ Реквизиты.БанковскийСчетПолучатель <> РеквизитыПозицияПоступления.БанковскийСчет
	|			ИЛИ Реквизиты.КассаПолучатель <> РеквизитыПозицияПоступления.Касса)";
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));

КонецПроцедуры

// Обработчик обновления.
// 
// Параметры:
//  Параметры - Структура - параметры.
//
Процедура ОбработатьДокументыБезМестаХраненияДСОтложенно(Параметры) Экспорт
	
	МетаданныеОбъекта = ПустаяСсылка().Метаданные();
	ПолноеИмяОбъекта  = МетаданныеОбъекта.ПолноеИмя();
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если НЕ ЗначениеЗаполнено(ОбновляемыеДанные) Тогда
		Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
											Параметры.Очередь, ПолноеИмяОбъекта);
		Возврат;
	КонецЕсли;
	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылки", ОбновляемыеДанные.ВыгрузитьКолонку("Ссылка"));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка,
	|	РеквизитыПлатежнойПозиции.БанковскийСчет КАК БанковскийСчет,
	|	РеквизитыПлатежнойПозиции.Касса КАК Касса,
	|	РеквизитыПозицияПоступления.БанковскийСчет КАК БанковскийСчетПолучатель,
	|	РеквизитыПозицияПоступления.Касса КАК КассаПолучатель
	|ИЗ
	|	Документ.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств КАК Реквизиты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПозицияПоступления КАК РеквизитыПозицияПоступления
	|		ПО (РеквизитыПозицияПоступления.ДокументПланирования = Реквизиты.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК РеквизитыПлатежнойПозиции
	|		ПО (РеквизитыПлатежнойПозиции.ДокументПланирования = Реквизиты.Ссылка)
	|ГДЕ
	|	Реквизиты.Ссылка В (&Ссылки)";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка 		 = РезультатЗапроса.Выбрать();
	
	ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();

	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			Блокировка.Заблокировать();
			
			ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ЗаполнитьЗначенияСвойств(ДокументОбъект, Выборка);
			
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			
			ОбъектовОбработано = ОбъектовОбработано + 1;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			бит_ОбновлениеИнформационнойБазыБФ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Выборка.Ссылка);
		КонецПопытки;		
	КонецЦикла;
	
	Если ОбъектовОбработано = 0 И ПроблемныхОбъектов <> 0 Тогда
		ШаблонСообщения = НСтр("ru = 'Не удалось обработать некоторые документы ""Заявка на перемещение денежных средств"" (пропущены): %1'; 
								|en = 'Some documents ""Application for the movement of funds"" could not be processed (skipped): %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ПроблемныхОбъектов);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация, МетаданныеОбъекта,, ТекстСообщения);
	Иначе
		ШаблонСообщения = НСтр("ru = 'Обработана очередная порция документов ""Заявка на перемещение денежных средств"": %1';
								|en = 'The next batch of documents ""Application for the movement of funds"" has been processed: %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ОбъектовОбработано);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация,
			МетаданныеОбъекта,, ТекстСообщения);
	КонецЕсли;
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
		Параметры.Очередь, ПолноеИмяОбъекта);

КонецПроцедуры
	
#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Функция определяет новый статус объекта в зависимости от режима записи документа
//и предыдущего статуса. Механизм определения статусов может быть переопределен алгоритмами.
//
// Параметры:
//  ТекущийОбъект - ДокументОбъект.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.
//  ПараметрыУстановкиСтатуса - Структура - состав полей см. в функции бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса.
//
// Возвращаемое значение:
//   НовыйСтатус - СправочникСсылка.бит_СтатусыОбъектов.
//
Функция НовыйСтатусОбъекта(ТекущийОбъект, ПараметрыУстановкиСтатуса) Экспорт
	
	Если ПараметрыУстановкиСтатуса.ПараметрыОплаты = Неопределено Тогда
		СтруктураРасход      = Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.ПолучитьОстатокРасход(ТекущийОбъект.Ссылка);
		СтруктураПоступления = Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.ПолучитьОстатокПоступление(ТекущийОбъект.Ссылка);
		СтруктураОплаты = Новый Структура("Расход, Поступление", СтруктураРасход, СтруктураПоступления);
	Иначе	
		СтруктураОплаты = ПараметрыУстановкиСтатуса.ПараметрыОплаты;
	КонецЕсли;
	
	РежимЗаписи = ПараметрыУстановкиСтатуса.РежимЗаписи;
	
	ПроводитьПослеУтверждения = ОбщегоНазначения.ЕстьРеквизитОбъекта("ОтправленНаСогласование", ТекущийОбъект.Метаданные())
									И ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения");
									
	Если ПроводитьПослеУтверждения Тогда
		Если НЕ ТекущийОбъект.ОтправленНаСогласование Тогда
			Возврат Справочники.бит_СтатусыОбъектов.Черновик;
		КонецЕсли;
	ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
		ИЛИ (РежимЗаписи = РежимЗаписиДокумента.Запись И НЕ ТекущийОбъект.Проведен) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Черновик;
	КонецЕсли;
	
	БезПоступлений = бит_ОбщегоНазначенияПовтИсп.ЗначениеПеременной("бит_кзн_НеСоздаватьДокументыПоступления");
	
	СсылкаНаОбъект = ТекущийОбъект.Ссылка;
	
	Если бит_ВизированиеСервер.ЕстьБлокирующиеРешения(СсылкаНаОбъект) Тогда
		
		Возврат Справочники.бит_СтатусыОбъектов.Отклонен;
		
	ИначеЕсли (БезПоступлений ИЛИ СтруктураОплаты.Поступление.Остаток <= 0.01 И СтруктураОплаты.Поступление.Факт > 0)
			И СтруктураОплаты.Расход.Остаток <= 0.01 И СтруктураОплаты.Расход.Факт > 0 Тогда
		
		Возврат Справочники.бит_СтатусыОбъектов.Оплачен;
		
	ИначеЕсли СтруктураОплаты.Поступление.Факт > 0 ИЛИ СтруктураОплаты.Расход.Факт > 0 Тогда
		
		Возврат Справочники.бит_СтатусыОбъектов.ЧастичноОплачен;
		
		
	ИначеЕсли бит_ВизированиеСервер.ВсеВизыСогласованы(СсылкаНаОбъект) Тогда
		
		Возврат Справочники.бит_СтатусыОбъектов.Утвержден;
		
	КонецЕсли;
	
	Возврат Справочники.бит_СтатусыОбъектов.НаСогласовании;
	
КонецФункции

//  Функция создает платежный документ.
//
// Параметры:
//  ПараметрыДокумента - См. бит_Казначейство.НовыеПараметрыСозданияПлатежногоДокумента().
//
// Возвращаемое значение:
//  ПлатежныеДокументы - Массив.
//
Функция СоздатьПлатежныйДокументНаОсновании(ПараметрыДокумента) Экспорт 

	ДокументОснование = ПараметрыДокумента.ДокументОснование;
	СуммаКОплате	  = ПараметрыДокумента.СуммаКОплате;
	ИзРеестра		  = ПараметрыДокумента.ВызовИзРеестра;
	РежимЗаписи 	  = ПараметрыДокумента.РежимЗаписи;
									
	Отказ = Ложь;
	бит_Казначейство.ПроверитьПлатежныеПозицииИзРеестраПоИсточникуВызова(Неопределено, ПараметрыДокумента, Отказ);
	Если Отказ Тогда
		Возврат Новый Массив;
	КонецЕсли;
								
	ПлатежныеДокументы   = Новый Массив;
	СоздаватьПоступления = НЕ бит_ОбщегоНазначенияПовтИсп.ЗначениеПеременной("бит_кзн_НеСоздаватьДокументыПоступления");
	РеквизитыОснования 	 = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОснование, 
								"Организация, ВалютаДокумента, СуммаДокумента, ХозяйственнаяОперация, Ссылка");
	
	Если ИзРеестра Тогда
		СуммаДокумента	 = ПараметрыДокумента.СуммаКОплате;
		ФактическаяСумма = ПараметрыДокумента.СуммаКОплате;
	Иначе 
		СуммаДокумента	 = РеквизитыОснования.СуммаДокумента;
		ФактическаяСумма = 0;
	КонецЕсли; 

    СценарийФакт = бит_НастройкиПрограммы.СценарийОтраженияФактаБДДС(РеквизитыОснования.Организация, ТекущаяДатаСеанса());	
							
    Если НЕ ЗначениеЗаполнено(СценарийФакт) Тогда
		СценарийФакт = Справочники.СценарииПланирования.ФАКТ;
	КонецЕсли; 

	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("ИзРеестра", 			 ИзРеестра);
	ПараметрыЗаполнения.Вставить("СоздаватьПоступления", СоздаватьПоступления);
	ПараметрыЗаполнения.Вставить("ПлатежныеДокументы", 	 ПлатежныеДокументы);
	ПараметрыЗаполнения.Вставить("СуммаДокумента", 		 СуммаДокумента);
	ПараметрыЗаполнения.Вставить("ФактическаяСумма", 	 ФактическаяСумма);
	ПараметрыЗаполнения.Вставить("СценарийФакт", 	 	 СценарийФакт);
	
	ВидОперации = бит_Казначейство.ХозяйственнаяОперацияУП(РеквизитыОснования.ХозяйственнаяОперация);

	Попытка
		НачатьТранзакцию();
		
		Если ВидОперации = Перечисления.ХозяйственныеОперации.СдачаДенежныхСредствВБанк Тогда
			ЗаполнитьСдачуДенежныхСредствВБанк(РеквизитыОснования, ПараметрыЗаполнения, ПлатежныеДокументы);
		ИначеЕсли ВидОперации = Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствВДругуюКассу Тогда	
			ЗаполнитьВыдачуДенежныхСредствВДругуюКассу(РеквизитыОснования, ПараметрыЗаполнения, ПлатежныеДокументы);
		ИначеЕсли ВидОперации = Перечисления.ХозяйственныеОперации.ПеречислениеДенежныхСредствНаДругойСчет Тогда	
			ЗаполнитьПеречислениеДенежныхСредствНаДругойСчет(РеквизитыОснования, ПараметрыЗаполнения, ПлатежныеДокументы);
		ИначеЕсли ВидОперации = Перечисления.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзБанка Тогда
			ЗаполнитьПоступлениеДенежныхСредствИзБанка(РеквизитыОснования, ПараметрыЗаполнения, ПлатежныеДокументы);
		ИначеЕсли ВидОперации = Перечисления.ХозяйственныеОперации.ИнкассацияДенежныхСредствИзБанка Тогда
			ЗаполнитьИнкассациюДенежныхСредствИзБанка(РеквизитыОснования, ПараметрыЗаполнения, ПлатежныеДокументы);
		ИначеЕсли ВидОперации = Перечисления.ХозяйственныеОперации.ИнкассацияДенежныхСредствВБанк Тогда 	
			ЗаполнитьИнкассациюДенежныхСредствВБанк(РеквизитыОснования, ПараметрыЗаполнения, ПлатежныеДокументы);
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ПлатежныеДокументы.Очистить();
		
		ТекстСообщения = НСтр("ru = 'Не удалось записать документы оплаты по причине: %1.'; 
								|en = 'Failed to record payment documents due to: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;

	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		Для каждого Документ Из ПлатежныеДокументы Цикл
			Попытка
				ТекущийОбъект = Документ.ПолучитьОбъект();
				ТекущийОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ТекстСообщения = НСтр("ru = 'Не удалось провести документ оплаты по причине: %1.'; 
										|en = 'Failed to record payment document due to: %1'");
				ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
				
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Документ);
			КонецПопытки;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ПлатежныеДокументы;
	
КонецФункции

//  Функция получает неоплаченный остаток по расходованию.
//
// Параметры:
//   ДокументПланирования - ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеСредств
//
// Возвращаемое значение:
//  СтрОплата - Структура.
//
Функция ПолучитьОстатокРасход(ДокументПланирования) Экспорт

	СтрОплата = Новый Структура("План, Факт, Остаток",0, 0, 0);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументПланирования);
	Запрос.УстановитьПараметр("Организация"         , ДокументПланирования.Организация);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(ПланируемыйРасход.СуммаКонечныйОстаток, 0) КАК СуммаОстаток,
	|	ЕСТЬNULL(ПланируемыйРасход.СуммаПриход, 0) КАК СуммаПлан,
	|	ЕСТЬNULL(ПланируемыйРасход.СуммаРасход, 0) КАК СуммаФакт
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.ОстаткиИОбороты(
	|			,
	|			,
	|			,
	|			,
	|			ДокументПланирования = &ДокументПланирования
	|				И Организация = &Организация) КАК ПланируемыйРасход";

	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		СтрОплата.План    = Выборка.СуммаПлан;
		СтрОплата.Факт    = Выборка.СуммаФакт;
		СтрОплата.Остаток = Выборка.СуммаОстаток;
	
	КонецЕсли; 

	Возврат СтрОплата;
	
КонецФункции // ПолучитьОстаток()

