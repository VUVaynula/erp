Процедура ЗаполнитьОтражениеФакта(ДокументОплаты, ДокументыПланирования, ПараметрыЗаполнения)
		
	СуммаКОплате = ПараметрыЗаполнения.ФактическаяСумма;
	СценарийФакт = ПараметрыЗаполнения.СценарийФакт;
	
	ОтражениеФакта		 = Документы.бит_ОтражениеФактаДДС.НайтиДокументОтражение(ДокументОплаты);
	ОтражениеФактаОбъект = ОтражениеФакта.ПолучитьОбъект();
	
	Позиции = ТаблицаДокументовПланирования(ДокументыПланирования);
	Документы.бит_ОтражениеФактаДДС.ЗаполнитьОтражениеФактаПоДокументамПланирования(ДокументОплаты, Позиции, СценарийФакт);
	
КонецПроцедуры

Функция ДанныеЗаполненияСписаниеЧерезБанк(РеквизитыОснования, ДанныеПозиций, ПараметрыЗаполнения, ВидОперации)

	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("Организация", 				   РеквизитыОснования.Организация);
	ДанныеЗаполнения.Вставить("Подразделение", 				   Неопределено);
	ДанныеЗаполнения.Вставить("Валюта", 					   РеквизитыОснования.ВалютаДокумента);
	ДанныеЗаполнения.Вставить("ХозяйственнаяОперация", 		   ВидОперации);
	ДанныеЗаполнения.Вставить("БанковскийСчет",				   ДанныеПозиций.ПлатежнаяПозиция.БанковскийСчет);
	ДанныеЗаполнения.Вставить("БанковскийСчетПолучатель", 	   ДанныеПозиций.ПозицияПоступления.БанковскийСчет);
	ДанныеЗаполнения.Вставить("КассаПолучатель", 	  		   ДанныеПозиций.ПозицияПоступления.Касса);
