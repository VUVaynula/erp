//  Функция создает платежный документ на основании документа перемещения.
//
// Возвращаемое значение:
//  ПлатежныйДокумент - Массив.
//
&НаСервере
Функция СоздатьПлатежныйДокументСервер()
	
	ПараметрыДокумента = бит_Казначейство.НовыеПараметрыСозданияПлатежногоДокумента();
	ПараметрыДокумента.ДокументОснование = Объект.Ссылка;
	ПлатежныйДокумент  = Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.СоздатьПлатежныйДокументНаОсновании(ПараметрыДокумента);
	
	Возврат ПлатежныйДокумент;
	
КонецФункции // СоздатьПлатежныйДокументСервер()

&НаСервере
Процедура ЗаполнитьСценарий(ПричинаИзменения)

	СтруктураПараметров = Новый Структура;
	Если ПричинаИзменения = "Организация" Тогда
		
		СтруктураПараметров.Вставить("Организация", Объект.Организация);
		
	ИначеЕсли ПричинаИзменения = "ЦФО" Тогда 	
		
		СтруктураПараметров.Вставить("ЦФО", Объект.ЦФО);
		
	КонецЕсли; 
	
	КонтролироватьЗаявку 	  = бит_НастройкиПрограммы.КонтролироватьЗаявкуПоБюджету(СтруктураПараметров, Объект.Дата);
	СценарийКонтроляПоБюджету = бит_НастройкиПрограммы.КазначействоСценарийКонтроляПоБюджету(СтруктураПараметров, Объект.Дата);
	
	Если ЗначениеЗаполнено(СценарийКонтроляПоБюджету) И КонтролироватьЗаявку Тогда
		Объект.Сценарий = СценарийКонтроляПоБюджету;
	КонецЕсли; 

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста 
Процедура УстановитьПараметрыВыбораВидаОперации(Форма)
	
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	НовыеПараметры = Новый Массив; 
	НовыеПараметры.Добавить(Новый ПараметрВыбора("Отбор.ТипДокумента", ТипЗнч(Объект.Ссылка)));
	
	Элементы.ХозяйственнаяОперация.ПараметрыВыбора = Новый ФиксированныйМассив(НовыеПараметры);
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьФормуНаСервере(СтандартнаяОбработка = Ложь)

	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.Организация, Объект.ЦФО, Объект.Дата);
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ПолучитьФункциональнуюОпцию("бит_ЗапретитьИзменениеЗаявкиВключеннойВРеестр") Тогда
			ЗаявкаВключенаВРеестр = бит_Казначейство.ЗаявкаВключенаВРеестр(Объект.Ссылка);
		Иначе
			ЗаявкаВключенаВРеестр = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	ИспользованиеРеквизитов = Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.ИспользованиеРеквизитовПоХозяйственнойОперации(Объект.ХозяйственнаяОперация);
	ЦветОсобогоТекста 		= ЦветаСтиля.ЦветОсобогоТекста;
	
	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект, СтандартнаяОбработка);
	УстановитьСостояниеДокумента();
	УправлениеФормой(ЭтотОбъект);

КонецПроцедуры

&НаСервере
Процедура ОбработкаОповещенияИзмененияСтатуса()
	
	Прочитать();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НеУчитыватьСверхБюджета(Организация, ЦФО, Период)

	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("Организация", Организация);
	ПараметрыНастройки.Вставить("ЦФО",		   ЦФО);
								
	НеУчитыватьСверхБюджета = бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеЗаявкиПриКонтролеПоБюджету(ПараметрыНастройки, 
									Период);
	Возврат НеУчитыватьСверхБюджета;
	
КонецФункции

&НаСервере
Процедура ДатаПриИзмененииНаСервере()

	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.Организация, Объект.ЦФО, Объект.Дата);
	УправлениеФормой(ЭтотОбъект);

КонецПроцедуры

&НаСервере
Процедура ОрганизацияПриИзмененииНаСервере()

	Объект.БанковскийСчет			= Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
	Объект.Касса         			= Справочники.Кассы.ПустаяСсылка();
	Объект.БанковскийСчетПолучатель = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
	Объект.КассаПолучатель          = Справочники.Кассы.ПустаяСсылка();
	
	Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.ЗаполнитьРеквизитыДокументаПоХозяйственнойОперации(Объект);
	
	ЗаполнитьСценарий("Организация");
	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.Организация, Объект.ЦФО, Объект.Дата);
	УправлениеФормой(ЭтотОбъект);
	
	ЗаполнитьКонтролируемыеРеквизиты(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ЦФОПриИзмененииНаСервере()

	ЗаполнитьСценарий("ЦФО");
	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.Организация, Объект.ЦФО, Объект.Дата);
	УправлениеФормой(ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура ПредложитьЗаписатьДокумент()

	Оповещение 	   = Новый ОписаниеОповещения("ПредложитьЗаписатьДокументЗавершение", ЭтотОбъект);
	ТекстСообщения = НСтр("ru = 'Документ изменен. Для отражения изменений в связанных позициях необходимо записать документ.'; 
							|en = 'The document has been changed. To reflect changes in related items, you need to write a document.'");

	ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура ПредложитьЗаписатьДокументЗавершение(Результат, Дополнительно) Экспорт

	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;	

	Попытка
		Записать();		
	Исключение
		ВызватьИсключение ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки; 

	Если Элементы.ТаблицаПозиции.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(Элементы.ТаблицаПозиции.ТекущаяСтрока));
	
КонецПроцедуры

&НаСервере
Процедура ХозяйственнаяОперацияПриИзмененииНаСервере()

	ИспользованиеРеквизитов = Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.ИспользованиеРеквизитовПоХозяйственнойОперации(Объект.ХозяйственнаяОперация);
	Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.ЗаполнитьРеквизитыДокументаПоХозяйственнойОперации(Объект);
	
	ЗаполнитьКонтролируемыеРеквизиты(ЭтотОбъект);
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура БанковскийСчетПриИзмененииНаСервере(РеквизитыСчета, ПересчитыватьСуммы)
	
	ТекущийБанковскийСчет = Объект.БанковскийСчет;
	
	Если ЗначениеЗаполнено(Объект.БанковскийСчет) Тогда
		Объект.Организация = РеквизитыСчета.Организация;
	КонецЕсли;
	
	ТекущаяВалюта		   = Объект.ВалютаДокумента;
	Объект.ВалютаДокумента = РеквизитыСчета.Валюта;
	
	Если ПересчитыватьСуммы Тогда
		ПересчетСуммДокументаВВалюту(ТекущаяВалюта);
	КонецЕсли;
	
	Объект.БанковскийСчетПолучатель = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
	Объект.КассаПолучатель          = Справочники.Кассы.ПустаяСсылка();
	
	ЗаполнитьКонтролируемыеРеквизиты(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура КассаПриИзмененииНаСервере(РеквизитыКассы, ПересчитыватьСуммы)
	
	ТекущаяКасса = Объект.Касса;
	
	Если ЗначениеЗаполнено(Объект.Касса) Тогда
		Объект.Организация = РеквизитыКассы.Организация;
	КонецЕсли;
	
	ТекущаяВалюта 		   = Объект.ВалютаДокумента;
	Объект.ВалютаДокумента = РеквизитыКассы.Валюта;
	
	Если ПересчитыватьСуммы Тогда
		ПересчетСуммДокументаВВалюту(ТекущаяВалюта);
	КонецЕсли;
	
	Объект.БанковскийСчетПолучатель = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
	Объект.КассаПолучатель          = Справочники.Кассы.ПустаяСсылка();
	
	ЗаполнитьКонтролируемыеРеквизиты(ЭтотОбъект);
	
КонецПроцедуры

