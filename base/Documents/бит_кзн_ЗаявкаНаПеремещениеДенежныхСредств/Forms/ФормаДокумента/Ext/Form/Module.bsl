&НаКлиенте
Процедура БанковскийСчетПриИзменении(Элемент)
	
	РеквизитыСчета			 = РеквизитыБанковскогоСчета(Объект.БанковскийСчет);
	НеобходимПересчетВВалюту = Ложь;
	
	Если Объект.СуммаДокумента <> 0 Тогда
		НеобходимПересчетВВалюту = ФинансыКлиент.НеобходимПересчетВВалюту(Объект, Объект.ВалютаДокумента, РеквизитыСчета.Валюта);
	КонецЕсли;
	
	Если НЕ НеобходимПересчетВВалюту Тогда
		БанковскийСчетПриИзмененииНаСервере(РеквизитыСчета, Ложь);
		ОтобразитьБюджетСПаузой();
	Иначе
		ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Пересчитать суммы в документе в валюту %1?';
				|en = 'Convert amounts in the document into currency %1?'"),
			РеквизитыСчета.Валюта);
		
		КнопкиДиалогаВопрос = Новый СписокЗначений;
		КнопкиДиалогаВопрос.Добавить(КодВозвратаДиалога.Да, НСтр("ru = 'Пересчитать';
																|en = 'Recalculate'"));
		КнопкиДиалогаВопрос.Добавить(КодВозвратаДиалога.Отмена, НСтр("ru = 'Отменить';
																	|en = 'Cancel'"));
		
		ОписаниеОповещения = Новый ОписаниеОповещения("РазрешенПересчетВВалютуСчет", 
								ЭтотОбъект, Новый Структура("РеквизитыСчета", РеквизитыСчета));
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, КнопкиДиалогаВопрос);
	КонецЕсли;

КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура РазрешенПересчетВВалютуСчет(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ТекущаяВалюта = Объект.ВалютаДокумента;
		БанковскийСчетПриИзмененииНаСервере(ДополнительныеПараметры.РеквизитыСчета, Истина);
		ЦенообразованиеКлиент.ОповеститьОбОкончанииПересчетаСуммВВалюту(ТекущаяВалюта, Объект.ВалютаДокумента);
		ОтобразитьБюджетСПаузой();
	Иначе
		Объект.БанковскийСчет = КонтролируемыеРеквизиты.БанковскийСчет;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КассаПриИзменении(Элемент)
	
	РеквизитыКассы			 = РеквизитыКассы(Объект.Касса);
	НеобходимПересчетВВалюту = Ложь;
	
	Если Объект.СуммаДокумента <> 0 Тогда
		НеобходимПересчетВВалюту = ФинансыКлиент.НеобходимПересчетВВалюту(Объект, Объект.ВалютаДокумента, РеквизитыКассы.Валюта);
	КонецЕсли;
	
	Если НЕ НеобходимПересчетВВалюту Тогда
		КассаПриИзмененииНаСервере(РеквизитыКассы, Ложь);
		ОтобразитьБюджетСПаузой();
	Иначе
		ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Пересчитать суммы в документе в валюту %1?';
				|en = 'Convert amounts in the document into currency %1?'"),
			РеквизитыКассы.Валюта);
		
		КнопкиДиалогаВопрос = Новый СписокЗначений;
		КнопкиДиалогаВопрос.Добавить(КодВозвратаДиалога.Да, НСтр("ru = 'Пересчитать';
																|en = 'Recalculate'"));
		КнопкиДиалогаВопрос.Добавить(КодВозвратаДиалога.Отмена, НСтр("ru = 'Отменить';
																	|en = 'Cancel'"));
		
		ОписаниеОповещения = Новый ОписаниеОповещения("РазрешенПересчетВВалютуКасса", ЭтотОбъект, 
			Новый Структура("РеквизитыКассы", РеквизитыКассы));
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, КнопкиДиалогаВопрос);
	КонецЕсли;

КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура РазрешенПересчетВВалютуКасса(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ТекущаяВалюта = Объект.ВалютаДокумента;
		КассаПриИзмененииНаСервере(ДополнительныеПараметры.РеквизитыКассы, Истина);
		ЦенообразованиеКлиент.ОповеститьОбОкончанииПересчетаСуммВВалюту(ТекущаяВалюта, Объект.ВалютаДокумента);
		ОтобразитьБюджетСПаузой();
	Иначе
		Объект.Касса = КонтролируемыеРеквизиты.Касса;
	КонецЕсли;
	
КонецПроцедуры

