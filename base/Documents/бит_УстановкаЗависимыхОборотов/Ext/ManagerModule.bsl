Процедура ПроверитьтЗацикливаниеТаблицы(Реквизиты, Заголовок, Отказ)  Экспорт
	
	// Проверка на зацикливание.
	Результат = ЗапросЗависисмыеОбороты(Реквизиты.ДатаНачала, Реквизиты.Сценарий, Реквизиты.Ссылка);
	Если НЕ Результат.Пустой() Тогда
		ТекстСообщения = НСтр("ru='Обнаружено зацикливание по статьям:';en='Loop detected under:'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Реквизиты.Ссылка,,, Отказ); 
		Выборка	= Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			ТекстСообщения = НСтр("ru='%1 - %2';en='%1 - %2'"); 
			ТекстСообщения = СтрШаблон(ТекстСообщения, Выборка.СтатьяОборотов, Выборка.СтатьяОборотов_Зависимые);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Реквизиты.Ссылка,,, Отказ); 
			ЗаголовокСообщения = "";
		КонецЦикла; 
	КонецЕсли;
	
КонецПроцедуры

Функция ФорматКоэффициентаСуммы(ТочностьКоэффициентаСуммы, УстанавливатьПредставлениеНуля = Ложь) Экспорт

	Если УстанавливатьПредставлениеНуля Тогда
		ПредставлениеНуля = ?(ТочностьКоэффициентаСуммы = 0, "0", Лев("0,000000000", ТочностьКоэффициентаСуммы+2));
		ФорматКоэффициентаСуммы = СтрШаблон("ЧЦ=%1; ЧДЦ=%2; ЧН=%3",
									6 + ТочностьКоэффициентаСуммы, ТочностьКоэффициентаСуммы, ПредставлениеНуля);
	Иначе	
		ФорматКоэффициентаСуммы = СтрШаблон("ЧЦ=%1; ЧДЦ=%2", 
									6 + ТочностьКоэффициентаСуммы, ТочностьКоэффициентаСуммы);
	КонецЕсли;
	
	Возврат ФорматКоэффициентаСуммы;
	
КонецФункции

