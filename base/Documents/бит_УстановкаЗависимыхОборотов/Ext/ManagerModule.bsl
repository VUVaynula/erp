Процедура ЗаполнитьВидОперацииПриПереходеНаНовуюВерсию() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	УстановкаЗависимыхОборотов.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.бит_УстановкаЗависимыхОборотов КАК УстановкаЗависимыхОборотов
	|ГДЕ
	|	УстановкаЗависимыхОборотов.ВидОперации = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийУстановкиЗависимыхОборотов.ПустаяСсылка)";
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ТекущийОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		ТекущийОбъект.ВидОперации = Перечисления.бит_ВидыОперацийУстановкиЗависимыхОборотов.ЗависимыеОборотыСценария;
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ТекущийОбъект);
		
	КонецЦикла;	

КонецПроцедуры

