Функция ПараметрыИзмененияТаблицыДокумента()

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Команда",			"бит_УстановкаЗависимыхОборотов");
	ПараметрыФормы.Вставить("Объект",			Объект.Ссылка);
	ПараметрыФормы.Вставить("ИмяТабличнойЧасти","ЗависимыеОбороты");
	ПараметрыФормы.Вставить("ТабличнаяЧасть",	 
		ПоместитьВоВременноеХранилище(ЗависимыеОборотыТаблицей(РеквизитФормыВЗначение("ДеревоЗависимостей")),
										УникальныйИдентификатор));
		
	Возврат ПараметрыФормы;	
	
