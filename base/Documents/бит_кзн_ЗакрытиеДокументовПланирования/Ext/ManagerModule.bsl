Процедура СторноКонтрольныеЗначенияБюджетовПоДокументамРасходованияДенежныхСредств(ТаблицыДокумента, Движения) 
	
	Реквизиты		 = ТаблицыДокумента.Реквизиты;
	ПлатежныеПозиции = ТаблицыДокумента.ПланируемыйРасходДенежныхСредств;
	
	Если НЕ ЗначениеЗаполнено(ПлатежныеПозиции) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос(); 
	Запрос.УстановитьПараметр("Позиции",ПлатежныеПозиции.ВыгрузитьКолонку("Позиция"));
	Запрос.УстановитьПараметр("Заявки", ПлатежныеПозиции.ВыгрузитьКолонку("ДокументПланирования"));
	Запрос.УстановитьПараметр("Период", Новый МоментВремени(Реквизиты.Период, Реквизиты.Регистратор)); 
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПлатежныеПозиции.Ссылка КАК Ссылка,
	|	ПлатежныеПозиции.ДатаПлан КАК Период
	|ПОМЕСТИТЬ ПлатежныеПозиции
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|ГДЕ
	|	ПлатежныеПозиции.Ссылка В(&Позиции)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПланируемыйРасходДенежныхСредств.Позиция КАК Позиция,
	|	ВЫБОР
	|		КОГДА ПланируемыйРасходДенежныхСредств.СуммаРасход = 0
	|			ТОГДА 1
	|		КОГДА ПланируемыйРасходДенежныхСредств.СуммаРасход > ПланируемыйРасходДенежныхСредств.СуммаПриход
	|			ТОГДА 0
	|		ИНАЧЕ 1 - ПланируемыйРасходДенежныхСредств.СуммаРасход / ПланируемыйРасходДенежныхСредств.СуммаПриход
	|	КОНЕЦ КАК КоэффициентСписания
	|ПОМЕСТИТЬ ВТ_КоэффициентыСписания
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.Обороты(
	|			,
	|			&Период,
	|			,
	|			Позиция В
	|				(ВЫБРАТЬ
	|					ПлатежныеПозиции.Ссылка
	|				ИЗ
	|					ПлатежныеПозиции КАК ПлатежныеПозиции)) КАК ПланируемыйРасходДенежныхСредств
	|ГДЕ
	|	ПланируемыйРасходДенежныхСредств.СуммаРасход < ПланируемыйРасходДенежныхСредств.СуммаПриход
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Позиция
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонтрольныеЗначенияБюджетов.ЦФО КАК ЦФО,
	|	КонтрольныеЗначенияБюджетов.СтатьяОборотов КАК СтатьяОборотов,
	|	КонтрольныеЗначенияБюджетов.Аналитика_1 КАК Аналитика_1,
	|	КонтрольныеЗначенияБюджетов.Аналитика_2 КАК Аналитика_2,
	|	КонтрольныеЗначенияБюджетов.Аналитика_3 КАК Аналитика_3,
	|	КонтрольныеЗначенияБюджетов.Аналитика_4 КАК Аналитика_4,
	|	КонтрольныеЗначенияБюджетов.Аналитика_5 КАК Аналитика_5,
	|	КонтрольныеЗначенияБюджетов.Аналитика_6 КАК Аналитика_6,
	|	КонтрольныеЗначенияБюджетов.Аналитика_7 КАК Аналитика_7,
	|	КонтрольныеЗначенияБюджетов.Аналитика_8 КАК Аналитика_8,
	|	КонтрольныеЗначенияБюджетов.Аналитика_9 КАК Аналитика_9,
	|	КонтрольныеЗначенияБюджетов.Аналитика_10 КАК Аналитика_10,
	|	КонтрольныеЗначенияБюджетов.Аналитика_11 КАК Аналитика_11,
	|	КонтрольныеЗначенияБюджетов.Аналитика_12 КАК Аналитика_12,
	|	СУММА(КонтрольныеЗначенияБюджетов.СуммаСценарийИсполнение + КонтрольныеЗначенияБюджетов.СуммаСценарийСверхЛимита) * ВТ_КоэффициентыСписания.КоэффициентСписания КАК Сумма,
	|	ПлатежныеПозиции.Ссылка КАК ДокументПланирования,
	|	ПлатежныеПозиции.Период КАК Период,
	|	0 КАК Количество,
	|	ИСТИНА КАК КонтролироватьСумму,
	|	ЛОЖЬ КАК КонтролироватьКоличество,
	|	НЕ КонтрольныеЗначенияБюджетов.СтатьяОборотов.НеКонтролировать_Заявки КАК КонтролироватьПоСтатье,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(25)) КАК ИмяСписка,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(25)) КАК СинонимСписка,
	|	1 КАК НомерСтроки
	|ИЗ
	|	ПлатежныеПозиции КАК ПлатежныеПозиции
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КоэффициентыСписания КАК ВТ_КоэффициентыСписания
	|		ПО ПлатежныеПозиции.Ссылка = ВТ_КоэффициентыСписания.Позиция
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.бит_КонтрольныеЗначенияБюджетов КАК КонтрольныеЗначенияБюджетов
	|		ПО (ВТ_КоэффициентыСписания.Позиция = КонтрольныеЗначенияБюджетов.Регистратор)
	|
	|СГРУППИРОВАТЬ ПО
	|	КонтрольныеЗначенияБюджетов.Аналитика_11,
	|	КонтрольныеЗначенияБюджетов.Аналитика_1,
	|	КонтрольныеЗначенияБюджетов.Аналитика_10,
	|	КонтрольныеЗначенияБюджетов.Аналитика_8,
	|	КонтрольныеЗначенияБюджетов.Аналитика_2,
	|	КонтрольныеЗначенияБюджетов.Аналитика_12,
	|	КонтрольныеЗначенияБюджетов.Аналитика_6,
	|	КонтрольныеЗначенияБюджетов.Аналитика_7,
	|	КонтрольныеЗначенияБюджетов.Аналитика_4,
	|	КонтрольныеЗначенияБюджетов.Аналитика_3,
	|	КонтрольныеЗначенияБюджетов.ЦФО,
	|	КонтрольныеЗначенияБюджетов.Аналитика_9,
	|	КонтрольныеЗначенияБюджетов.Аналитика_5,
	|	КонтрольныеЗначенияБюджетов.СтатьяОборотов,
	|	ПлатежныеПозиции.Период,
	|	ПлатежныеПозиции.Ссылка,
	|	ВТ_КоэффициентыСписания.КоэффициентСписания,
	|	НЕ КонтрольныеЗначенияБюджетов.СтатьяОборотов.НеКонтролировать_Заявки";
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	ОбработатьДанныеДляСторноКонтрольныеЗначенияБюджетов(Результат, Движения);
	
КонецПроцедуры

Процедура СторноКонтрольныеЗначенияБюджетовПоДокументамЗатрат(ТаблицыДокумента, Движения) 
	
	Реквизиты		   = ТаблицыДокумента.Реквизиты;
	ПланируемыеЗатраты = ТаблицыДокумента.ПланируемыеЗатраты;
	
	Если НЕ ЗначениеЗаполнено(ПланируемыеЗатраты) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос(); 
	Запрос.УстановитьПараметр("ЗаявкиНаЗатраты",ПланируемыеЗатраты.ВыгрузитьКолонку("ЗаявкаНаЗатраты"));
	Запрос.УстановитьПараметр("ДокументыПланирования", ПланируемыеЗатраты.ВыгрузитьКолонку("ДокументПланирования"));
	Запрос.УстановитьПараметр("Период", Новый МоментВремени(Реквизиты.Период, Реквизиты.Регистратор)); 
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаявкиНаЗатраты.Ссылка КАК Ссылка,
	|	ЗаявкиНаЗатраты.КурсДокумента КАК КурсДокумента,
	|	ЗаявкиНаЗатраты.КратностьДокумента КАК КратностьДокумента,
	|	ЗаявкиНаЗатраты.Сценарий КАК Сценарий,
	|	ЗаявкиНаЗатраты.Сценарий.Валюта КАК ВалютаСценария,
	|	ЗаявкиНаЗатраты.ВалютаДокумента КАК ВалютаДокумента,
	|	ЗаявкиНаЗатраты.Организация КАК Организация,
	|	ЗаявкиНаЗатраты.Дата КАК Дата
	|ПОМЕСТИТЬ ЗаявкиНаЗатраты
	|ИЗ
	|	Документ.бит_пз_ЗаявкаНаЗатраты КАК ЗаявкиНаЗатраты
	|ГДЕ
	|	ЗаявкиНаЗатраты.Ссылка В(&ЗаявкиНаЗатраты)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СводныеЗаявкиНаЗатраты.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_СводныеЗаявкиНаЗатраты
	|ИЗ
	|	Документ.бит_пз_СводнаяЗаявкаНаЗатраты КАК СводныеЗаявкиНаЗатраты
	|ГДЕ
	|	СводныеЗаявкиНаЗатраты.Ссылка В(&ДокументыПланирования)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПланируемыеЗатраты.ЗаявкаНаЗатраты КАК ЗаявкаНаЗатраты,
	|	ВЫБОР
	|		КОГДА ПланируемыеЗатраты.КоличествоРасход = 0
	|			ТОГДА 1
	|		КОГДА ПланируемыеЗатраты.КоличествоРасход > ПланируемыеЗатраты.КоличествоПриход
	|			ТОГДА 0
	|		ИНАЧЕ 1 - ПланируемыеЗатраты.КоличествоРасход / ПланируемыеЗатраты.КоличествоПриход
	|	КОНЕЦ КАК КоэффициентКоличество,
	|	ВЫБОР
	|		КОГДА ПланируемыеЗатраты.СуммаРасход = 0
	|			ТОГДА 1
	|		КОГДА ПланируемыеЗатраты.СуммаРасход > ПланируемыеЗатраты.СуммаПриход
	|			ТОГДА 0
	|		ИНАЧЕ 1 - ПланируемыеЗатраты.СуммаРасход / ПланируемыеЗатраты.СуммаПриход
	|	КОНЕЦ КАК КоэффициентСумма
	|ПОМЕСТИТЬ ВТ_КоэффициентыСписания
	|ИЗ
	|	РегистрНакопления.бит_пз_ПланируемыеЗатраты.Обороты(
	|			,
	|			&Период,
	|			,
	|			ДокументПланирования В
	|				(ВЫБРАТЬ
	|					ЗаявкиНаЗатраты.Ссылка КАК Ссылка
	|				ИЗ
	|					ЗаявкиНаЗатраты КАК ЗаявкиНаЗатраты)) КАК ПланируемыеЗатраты
	|ГДЕ
	|	(ПланируемыеЗатраты.КоличествоРасход < ПланируемыеЗатраты.КоличествоПриход
	|			ИЛИ ПланируемыеЗатраты.СуммаРасход < ПланируемыеЗатраты.СуммаПриход)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПланируемыеЗатраты.ЗаявкаНаЗатраты,
	|	ВЫБОР
	|		КОГДА ПланируемыеЗатраты.КоличествоРасход = 0
	|			ТОГДА 1
	|		КОГДА ПланируемыеЗатраты.КоличествоРасход > ПланируемыеЗатраты.КоличествоПриход
	|			ТОГДА 0
	|		ИНАЧЕ 1 - ПланируемыеЗатраты.КоличествоРасход / ПланируемыеЗатраты.КоличествоПриход
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ПланируемыеЗатраты.СуммаРасход = 0
	|			ТОГДА 1
	|		КОГДА ПланируемыеЗатраты.СуммаРасход > ПланируемыеЗатраты.СуммаПриход
	|			ТОГДА 0
	|		ИНАЧЕ 1 - ПланируемыеЗатраты.СуммаРасход / ПланируемыеЗатраты.СуммаПриход
	|	КОНЕЦ
	|ИЗ
	|	РегистрНакопления.бит_пз_ПланируемыеЗатраты.Обороты(
	|			,
	|			&Период,
	|			,
	|			ЗаявкаНаЗатраты В
	|					(ВЫБРАТЬ
	|						ЗаявкиНаЗатраты.Ссылка КАК Ссылка
	|					ИЗ
	|						ЗаявкиНаЗатраты КАК ЗаявкиНаЗатраты)
	|				И ДокументПланирования В
	|					(ВЫБРАТЬ
	|						ВТ_СводныеЗаявкиНаЗатраты.Ссылка КАК Ссылка
	|					ИЗ
	|						ВТ_СводныеЗаявкиНаЗатраты КАК ВТ_СводныеЗаявкиНаЗатраты)) КАК ПланируемыеЗатраты
	|ГДЕ
	|	(ПланируемыеЗатраты.КоличествоРасход < ПланируемыеЗатраты.КоличествоПриход
	|			ИЛИ ПланируемыеЗатраты.СуммаРасход < ПланируемыеЗатраты.СуммаПриход)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ЗаявкаНаЗатраты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаявкиНаЗатраты.Ссылка КАК ДокументПланирования,
	|	ЗаявкиНаЗатраты.Дата КАК Период,
	|	КонтрольныеЗначенияБюджетов.ЦФО КАК ЦФО,
	|	КонтрольныеЗначенияБюджетов.СтатьяОборотов КАК СтатьяОборотов,
	|	КонтрольныеЗначенияБюджетов.Аналитика_1 КАК Аналитика_1,
	|	КонтрольныеЗначенияБюджетов.Аналитика_2 КАК Аналитика_2,
	|	КонтрольныеЗначенияБюджетов.Аналитика_3 КАК Аналитика_3,
	|	КонтрольныеЗначенияБюджетов.Аналитика_4 КАК Аналитика_4,
	|	КонтрольныеЗначенияБюджетов.Аналитика_5 КАК Аналитика_5,
	|	КонтрольныеЗначенияБюджетов.Аналитика_6 КАК Аналитика_6,
	|	КонтрольныеЗначенияБюджетов.Аналитика_7 КАК Аналитика_7,
	|	КонтрольныеЗначенияБюджетов.Аналитика_8 КАК Аналитика_8,
	|	КонтрольныеЗначенияБюджетов.Аналитика_9 КАК Аналитика_9,
	|	КонтрольныеЗначенияБюджетов.Аналитика_10 КАК Аналитика_10,
	|	КонтрольныеЗначенияБюджетов.Аналитика_11 КАК Аналитика_11,
	|	КонтрольныеЗначенияБюджетов.Аналитика_12 КАК Аналитика_12,
	|	СУММА(КонтрольныеЗначенияБюджетов.КоличествоСценарийИсполнение + КонтрольныеЗначенияБюджетов.КоличествоСценарийСверхЛимита) * ВТ_КоэффициентыСписания.КоэффициентКоличество КАК Количество,
	|	СУММА(КонтрольныеЗначенияБюджетов.СуммаСценарийИсполнение + КонтрольныеЗначенияБюджетов.СуммаСценарийСверхЛимита) * ВТ_КоэффициентыСписания.КоэффициентСумма КАК Сумма,
	|	ИСТИНА КАК КонтролироватьСумму,
	|	ИСТИНА КАК КонтролироватьКоличество,
	|	НЕ КонтрольныеЗначенияБюджетов.СтатьяОборотов.НеКонтролировать_Заявки КАК КонтролироватьПоСтатье,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(25)) КАК ИмяСписка,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(25)) КАК СинонимСписка,
	|	1 КАК НомерСтроки
	|ИЗ
	|	ЗаявкиНаЗатраты КАК ЗаявкиНаЗатраты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КоэффициентыСписания КАК ВТ_КоэффициентыСписания
	|		ПО ЗаявкиНаЗатраты.Ссылка = ВТ_КоэффициентыСписания.ЗаявкаНаЗатраты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.бит_КонтрольныеЗначенияБюджетов КАК КонтрольныеЗначенияБюджетов
	|		ПО ЗаявкиНаЗатраты.Ссылка = КонтрольныеЗначенияБюджетов.Регистратор
	|
	|СГРУППИРОВАТЬ ПО
	|	КонтрольныеЗначенияБюджетов.Аналитика_12,
	|	КонтрольныеЗначенияБюджетов.СтатьяОборотов,
	|	КонтрольныеЗначенияБюджетов.Аналитика_6,
	|	КонтрольныеЗначенияБюджетов.Аналитика_11,
	|	КонтрольныеЗначенияБюджетов.Аналитика_10,
	|	КонтрольныеЗначенияБюджетов.Аналитика_1,
	|	КонтрольныеЗначенияБюджетов.Аналитика_9,
	|	КонтрольныеЗначенияБюджетов.Аналитика_2,
	|	КонтрольныеЗначенияБюджетов.Аналитика_8,
	|	КонтрольныеЗначенияБюджетов.ЦФО,
	|	КонтрольныеЗначенияБюджетов.Аналитика_3,
	|	КонтрольныеЗначенияБюджетов.Аналитика_7,
	|	КонтрольныеЗначенияБюджетов.Аналитика_5,
	|	КонтрольныеЗначенияБюджетов.Аналитика_4,
	|	ЗаявкиНаЗатраты.Ссылка,
	|	ЗаявкиНаЗатраты.Дата,
	|	ВТ_КоэффициентыСписания.КоэффициентКоличество,
	|	ВТ_КоэффициентыСписания.КоэффициентСумма,
	|	НЕ КонтрольныеЗначенияБюджетов.СтатьяОборотов.НеКонтролировать_Заявки";
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	ОбработатьДанныеДляСторноКонтрольныеЗначенияБюджетов(Результат, Движения);

КонецПроцедуры

Процедура ОбработатьДанныеДляСторноКонтрольныеЗначенияБюджетов(ВыборкаДокументов, Движения)

	Заявки = ВыборкаДокументов.Скопировать(, "ДокументПланирования");
	Заявки.Свернуть("ДокументПланирования");
	
	Для каждого СтрокаТаблицы Из Заявки Цикл
		ДокументПланирования = СтрокаТаблицы.ДокументПланирования;
		Менеджер    		 = ОбщегоНазначения.МенеджерОбъектаПоСсылке(ДокументПланирования);
		ПараметрыПроведения  = Менеджер.ПодготовитьПараметрыПроведения(ДокументПланирования, Ложь);
		
		Если НЕ ЗначениеЗаполнено(ПараметрыПроведения.ИсполнениеБюджета) Тогда
			// Методологически документ не контролируется по бюджету.
			Продолжить;		
		КонецЕсли;
		
		ИсполнениеБюджета = ПараметрыПроведения.ИсполнениеБюджета.СкопироватьКолонки();
		Остатки = ВыборкаДокументов.Скопировать(Новый Структура("ДокументПланирования", ДокументПланирования));
		Для каждого СтрокаТаблицы Из Остатки Цикл
			НоваяСтрока = ИсполнениеБюджета.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
			НоваяСтрока.НомерСтроки = ИсполнениеБюджета.Количество();
		КонецЦикла;
		
		ТаблицаИсполнениеБюджета = бит_КонтрольИсполненияБюджета.ПодготовитьТаблицуВозвратЛимита(
									ИсполнениеБюджета,
									ПараметрыПроведения.ИсполнениеБюджетаРеквизиты,
									Ложь);
									
		бит_КонтрольИсполненияБюджета.СформироватьДвиженияКонтрольныеЗначенияБюджетов(ТаблицаИсполнениеБюджета, Движения);
	КонецЦикла; 

КонецПроцедуры

#КонецОбласти

#КонецЕсли
