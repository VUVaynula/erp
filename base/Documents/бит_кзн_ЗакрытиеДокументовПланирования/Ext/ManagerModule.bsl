Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт
	
	ПараметрыПроведения = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Дата КАК Период,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.Ссылка КАК Регистратор
	|ИЗ
	|	Документ.бит_кзн_ЗакрытиеДокументовПланирования КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";
	
	Результат = Запрос.Выполнить().Выгрузить();
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Результат[0]);
	
	НомераТаблиц = Новый Структура;

	ТекстЗапроса = ТекстЗапросаВременныеТаблицыДокумента(НомераТаблиц)
				 + ТекстЗапросаДокументыПланирования(НомераТаблиц)
				 + ТекстЗапросаПланируемыйРасходДенежныхСредств(НомераТаблиц)
				 + ТекстЗапросаПланируемоеПоступлениеДенежныхСредств(НомераТаблиц)
				 + ТекстЗапросаПланируемыеЗатраты(НомераТаблиц);
				 
	Запрос.Текст = ТекстЗапроса;
	
	Результат = Запрос.ВыполнитьПакет();
	
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла;
	
	ПараметрыПроведения.Вставить("Реквизиты", Реквизиты);	
	Возврат ПараметрыПроведения;
	
КонецФункции 

Процедура СформироватьКонтрольныеЗначенияБюджетов(ПараметрыПроведения, Движения) Экспорт
	
	СторноКонтрольныеЗначенияБюджетовПоДокументамРасходованияДенежныхСредств(ПараметрыПроведения, Движения);
	СторноКонтрольныеЗначенияБюджетовПоДокументамЗатрат(ПараметрыПроведения, Движения);
	
КонецПроцедуры

Процедура СформироватьПланируемыйРасходДенежныхСредств(ПланируемыйРасходДенежныхСредств, Реквизиты, Движения) Экспорт

	Если НЕ ЗначениеЗаполнено(ПланируемыйРасходДенежныхСредств) Тогда
		Возврат;
	КонецЕсли;
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств");
	ЭлементБлокировки.ИсточникДанных = ПланируемыйРасходДенежныхСредств;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ДокументПланирования","ДокументПланирования");
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Позиция","Позиция");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;	
	Блокировка.Заблокировать();
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредствАналитика");
	ЭлементБлокировки.ИсточникДанных = ПланируемыйРасходДенежныхСредств;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ДокументПланирования","ДокументПланирования");
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Позиция","Позиция");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;	
	Блокировка.Заблокировать();

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МоментДокумента"		  , Новый МоментВремени(Реквизиты.Период, Реквизиты.Регистратор));
	Запрос.УстановитьПараметр("ДокументыПланирования" , ПланируемыйРасходДенежныхСредств);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДокументыПланирования.ДокументПланирования КАК ДокументПланирования,
	|	ДокументыПланирования.Позиция КАК Позиция
	|ПОМЕСТИТЬ ДокументыПланирования
	|ИЗ
	|	&ДокументыПланирования КАК ДокументыПланирования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПланируемыйРасходДенежныхСредств.Организация КАК Организация,
	|	ПланируемыйРасходДенежныхСредств.ДокументПланирования КАК ДокументПланирования,
	|	ПланируемыйРасходДенежныхСредств.СуммаОстаток КАК Сумма,
	|	ПланируемыйРасходДенежныхСредств.ВидПлана КАК ВидПлана,
	|	ПланируемыйРасходДенежныхСредств.Позиция КАК Позиция
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.Остатки(
	|			&МоментДокумента,
	|			(ДокументПланирования, Позиция) В
	|				(ВЫБРАТЬ
	|					ДокументыПланирования.ДокументПланирования,
	|					ДокументыПланирования.Позиция
	|				ИЗ
	|					ДокументыПланирования КАК ДокументыПланирования)) КАК ПланируемыйРасходДенежныхСредств
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументыПланирования.ДокументПланирования КАК ДокументПланирования,
	|	ДокументыПланирования.Позиция КАК Позиция,
	|	РасширенныйПланируемыйРасход.Организация КАК Организация,
	|	РасширенныйПланируемыйРасход.ВидПлана КАК ВидПлана,
	|	РасширенныйПланируемыйРасход.ВидДенежныхСредств КАК ВидДенежныхСредств,
	|	РасширенныйПланируемыйРасход.Валюта КАК Валюта,
	|	РасширенныйПланируемыйРасход.ЦФО КАК ЦФО,
	|	РасширенныйПланируемыйРасход.СтатьяОборотов КАК СтатьяОборотов,
	|	РасширенныйПланируемыйРасход.БанковскийСчет КАК БанковскийСчет,
	|	РасширенныйПланируемыйРасход.Аналитика_1 КАК Аналитика_1,
	|	РасширенныйПланируемыйРасход.Аналитика_2 КАК Аналитика_2,
	|	РасширенныйПланируемыйРасход.Аналитика_3 КАК Аналитика_3,
	|	РасширенныйПланируемыйРасход.Аналитика_4 КАК Аналитика_4,
	|	РасширенныйПланируемыйРасход.Аналитика_5 КАК Аналитика_5,
	|	РасширенныйПланируемыйРасход.Аналитика_6 КАК Аналитика_6,
	|	РасширенныйПланируемыйРасход.Аналитика_7 КАК Аналитика_7,
	|	РасширенныйПланируемыйРасход.Аналитика_8 КАК Аналитика_8,
	|	РасширенныйПланируемыйРасход.Аналитика_9 КАК Аналитика_9,
	|	РасширенныйПланируемыйРасход.Аналитика_10 КАК Аналитика_10,
	|	РасширенныйПланируемыйРасход.Аналитика_11 КАК Аналитика_11,
	|	РасширенныйПланируемыйРасход.Аналитика_12 КАК Аналитика_12,
	|	СУММА(ЕСТЬNULL(РасширенныйПланируемыйРасход.Сумма, 0)) КАК Сумма,
	|	СУММА(ЕСТЬNULL(РасширенныйПланируемыйРасход.СуммаОплаты, 0)) КАК СуммаОплаты,
	|	СУММА(ЕСТЬNULL(РасширенныйПланируемыйРасход.СуммаРегл, 0)) КАК СуммаРегл,
	|	СУММА(ЕСТЬNULL(РасширенныйПланируемыйРасход.СуммаУпр, 0)) КАК СуммаУпр
	|ИЗ
	|	ДокументыПланирования КАК ДокументыПланирования
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредствАналитика КАК РасширенныйПланируемыйРасход
	|		ПО ДокументыПланирования.Позиция = РасширенныйПланируемыйРасход.Регистратор
	|			И (РасширенныйПланируемыйРасход.Регистратор ССЫЛКА Документ.бит_кзн_ПлатежнаяПозиция)
	|
	|СГРУППИРОВАТЬ ПО
	|	РасширенныйПланируемыйРасход.Аналитика_10,
	|	РасширенныйПланируемыйРасход.Аналитика_11,
	|	РасширенныйПланируемыйРасход.Аналитика_12,
	|	РасширенныйПланируемыйРасход.Аналитика_4,
	|	РасширенныйПланируемыйРасход.БанковскийСчет,
	|	РасширенныйПланируемыйРасход.Аналитика_5,
	|	РасширенныйПланируемыйРасход.Аналитика_2,
	|	ДокументыПланирования.Позиция,
	|	РасширенныйПланируемыйРасход.Валюта,
	|	РасширенныйПланируемыйРасход.ВидПлана,
	|	РасширенныйПланируемыйРасход.ВидДенежныхСредств,
	|	РасширенныйПланируемыйРасход.ЦФО,
	|	РасширенныйПланируемыйРасход.Организация,
	|	РасширенныйПланируемыйРасход.Аналитика_3,
	|	РасширенныйПланируемыйРасход.Аналитика_8,
	|	РасширенныйПланируемыйРасход.Аналитика_9,
	|	РасширенныйПланируемыйРасход.Аналитика_7,
	|	РасширенныйПланируемыйРасход.Аналитика_6,
	|	РасширенныйПланируемыйРасход.СтатьяОборотов,
	|	РасширенныйПланируемыйРасход.Аналитика_1,
	|	ДокументыПланирования.ДокументПланирования";
	
	РезультатПакета 			 = Запрос.ВыполнитьПакет();
	ПланируемыйРасход			 = РезультатПакета[1].Выгрузить();
	РасширенныйПланируемыйРасход = РезультатПакета[2].Выгрузить();
	
	Для каждого СтрокаТаблицы Из ПланируемыйРасход Цикл
		НоваяСтрока = Движения.бит_кзн_ПланируемыйРасходДенежныхСредств.Добавить();
		НоваяСтрока.ВидДвижения = ВидДвиженияНакопления.Расход;
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизиты);
		
		РезультатПоиска = РасширенныйПланируемыйРасход.Скопировать(Новый Структура("Позиция", СтрокаТаблицы.Позиция));
		Если ЗначениеЗаполнено(РезультатПоиска) И РезультатПоиска.Итог("Сумма") <> 0 Тогда
			
			Коэффициент = Окр(СтрокаТаблицы.Сумма / РезультатПоиска.Итог("Сумма"), 2);
			
			Ресурсы = Новый Массив;
			Ресурсы.Добавить("Сумма");
			Ресурсы.Добавить("СуммаОплаты");
			Ресурсы.Добавить("СуммаРегл");
			Ресурсы.Добавить("СуммаУпр");
			
			Для каждого Ресурс Из Ресурсы Цикл
				РаспределяемаяСумма =  - РезультатПоиска.Итог(Ресурс) * Коэффициент;
				Если РаспределяемаяСумма <> 0 Тогда
					КоэффициентыРаспределения = РезультатПоиска.ВыгрузитьКолонку(Ресурс);
					РезультатРаспределения 	  = ОбщегоНазначенияКлиентСервер.РаспределитьСуммуПропорциональноКоэффициентам(
													РаспределяемаяСумма, КоэффициентыРаспределения, 2);
					РезультатПоиска.ЗагрузитьКолонку(РезультатРаспределения, Ресурс);								
				КонецЕсли;
			КонецЦикла;
													
			Для каждого Запись Из РезультатПоиска Цикл
				НоваяСтрока = Движения.бит_кзн_ПланируемыйРасходДенежныхСредствАналитика.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Запись);
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизиты);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;

	Движения.бит_кзн_ПланируемыйРасходДенежныхСредств.Записывать = Истина;
	Движения.бит_кзн_ПланируемыйРасходДенежныхСредствАналитика.Записывать = Истина;

КонецПроцедуры

Процедура СформироватьПланируемоеПоступлениеДенежныхСредств(ПланируемоеПоступлениеДенежныхСредств, Реквизиты, Движения) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ПланируемоеПоступлениеДенежныхСредств) Тогда
		Возврат;
	КонецЕсли;
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств");
	ЭлементБлокировки.ИсточникДанных = ПланируемоеПоступлениеДенежныхСредств;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ДокументПланирования","ДокументПланирования");
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Позиция","Позиция");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;	
	Блокировка.Заблокировать();

	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредствАналитика");
	ЭлементБлокировки.ИсточникДанных = ПланируемоеПоступлениеДенежныхСредств;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ДокументПланирования","ДокументПланирования");
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Позиция","Позиция");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;	
	Блокировка.Заблокировать();

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МоментДокумента"		  , Новый МоментВремени(Реквизиты.Период, Реквизиты.Регистратор));
	Запрос.УстановитьПараметр("ДокументыПланирования" , ПланируемоеПоступлениеДенежныхСредств);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДокументыПланирования.ДокументПланирования КАК ДокументПланирования,
	|	ДокументыПланирования.Позиция КАК Позиция
	|ПОМЕСТИТЬ ДокументыПланирования
	|ИЗ
	|	&ДокументыПланирования КАК ДокументыПланирования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ПланируемоеПоступление.ДокументПланирования ССЫЛКА Документ.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию
	|			ТОГДА ПланируемоеПоступление.ДокументПланирования.ОрганизацияПолучатель
	|		ИНАЧЕ ПланируемоеПоступление.Организация
	|	КОНЕЦ КАК Организация,
	|	ПланируемоеПоступление.ДокументПланирования КАК ДокументПланирования,
	|	ПланируемоеПоступление.СуммаОстаток КАК Сумма,
	|	ПланируемоеПоступление.ВидПлана КАК ВидПлана,
	|	ПланируемоеПоступление.Позиция КАК Позиция
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Остатки(
	|			&МоментДокумента,
	|			(ДокументПланирования, Позиция) В
	|				(ВЫБРАТЬ
	|					ДокументыПланирования.ДокументПланирования,
	|					ДокументыПланирования.Позиция
	|				ИЗ
	|					ДокументыПланирования КАК ДокументыПланирования)) КАК ПланируемоеПоступление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументыПланирования.ДокументПланирования КАК ДокументПланирования,
	|	ДокументыПланирования.Позиция КАК Позиция,
	|	РасширенноеПланируемоеПоступление.Организация КАК Организация,
	|	РасширенноеПланируемоеПоступление.ВидПлана КАК ВидПлана,
	|	РасширенноеПланируемоеПоступление.ВидДенежныхСредств КАК ВидДенежныхСредств,
	|	РасширенноеПланируемоеПоступление.Валюта КАК Валюта,
	|	РасширенноеПланируемоеПоступление.ЦФО КАК ЦФО,
	|	РасширенноеПланируемоеПоступление.СтатьяОборотов КАК СтатьяОборотов,
	|	РасширенноеПланируемоеПоступление.БанковскийСчет КАК БанковскийСчет,
	|	РасширенноеПланируемоеПоступление.Аналитика_1 КАК Аналитика_1,
	|	РасширенноеПланируемоеПоступление.Аналитика_2 КАК Аналитика_2,
	|	РасширенноеПланируемоеПоступление.Аналитика_3 КАК Аналитика_3,
	|	РасширенноеПланируемоеПоступление.Аналитика_4 КАК Аналитика_4,
	|	РасширенноеПланируемоеПоступление.Аналитика_5 КАК Аналитика_5,
	|	РасширенноеПланируемоеПоступление.Аналитика_6 КАК Аналитика_6,
	|	РасширенноеПланируемоеПоступление.Аналитика_7 КАК Аналитика_7,
	|	РасширенноеПланируемоеПоступление.Аналитика_8 КАК Аналитика_8,
	|	РасширенноеПланируемоеПоступление.Аналитика_9 КАК Аналитика_9,
	|	РасширенноеПланируемоеПоступление.Аналитика_10 КАК Аналитика_10,
	|	РасширенноеПланируемоеПоступление.Аналитика_11 КАК Аналитика_11,
	|	РасширенноеПланируемоеПоступление.Аналитика_12 КАК Аналитика_12,
	|	СУММА(ЕСТЬNULL(РасширенноеПланируемоеПоступление.Сумма, 0)) КАК Сумма,
	|	СУММА(ЕСТЬNULL(РасширенноеПланируемоеПоступление.СуммаОплаты, 0)) КАК СуммаОплаты,
	|	СУММА(ЕСТЬNULL(РасширенноеПланируемоеПоступление.СуммаРегл, 0)) КАК СуммаРегл,
	|	СУММА(ЕСТЬNULL(РасширенноеПланируемоеПоступление.СуммаУпр, 0)) КАК СуммаУпр
	|ИЗ
	|	ДокументыПланирования КАК ДокументыПланирования
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредствАналитика КАК РасширенноеПланируемоеПоступление
	|		ПО ДокументыПланирования.Позиция = РасширенноеПланируемоеПоступление.Регистратор
	|
	|СГРУППИРОВАТЬ ПО
	|	РасширенноеПланируемоеПоступление.Аналитика_10,
	|	РасширенноеПланируемоеПоступление.Аналитика_11,
	|	РасширенноеПланируемоеПоступление.Аналитика_12,
	|	РасширенноеПланируемоеПоступление.Аналитика_4,
	|	РасширенноеПланируемоеПоступление.БанковскийСчет,
	|	РасширенноеПланируемоеПоступление.Аналитика_5,
	|	РасширенноеПланируемоеПоступление.Аналитика_2,
	|	ДокументыПланирования.Позиция,
	|	РасширенноеПланируемоеПоступление.Валюта,
	|	РасширенноеПланируемоеПоступление.ВидПлана,
	|	РасширенноеПланируемоеПоступление.ВидДенежныхСредств,
	|	РасширенноеПланируемоеПоступление.ЦФО,
	|	РасширенноеПланируемоеПоступление.Организация,
	|	РасширенноеПланируемоеПоступление.Аналитика_3,
	|	РасширенноеПланируемоеПоступление.Аналитика_8,
	|	РасширенноеПланируемоеПоступление.Аналитика_9,
	|	РасширенноеПланируемоеПоступление.Аналитика_7,
	|	РасширенноеПланируемоеПоступление.Аналитика_6,
	|	РасширенноеПланируемоеПоступление.СтатьяОборотов,
	|	РасширенноеПланируемоеПоступление.Аналитика_1,
	|	ДокументыПланирования.ДокументПланирования";

	РезультатПакета 			 = Запрос.ВыполнитьПакет();
	ПланируемыйРасход			 = РезультатПакета[1].Выгрузить();
	РасширенныйПланируемыйРасход = РезультатПакета[2].Выгрузить();
	
	Для каждого СтрокаТаблицы Из ПланируемыйРасход Цикл
		НоваяСтрока = Движения.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Добавить();
		НоваяСтрока.ВидДвижения = ВидДвиженияНакопления.Расход;
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизиты);
		
		РезультатПоиска = РасширенныйПланируемыйРасход.Скопировать(Новый Структура("Позиция", СтрокаТаблицы.Позиция));
		Если ЗначениеЗаполнено(РезультатПоиска) И РезультатПоиска.Итог("Сумма") <> 0 Тогда
			
			Коэффициент = Окр(СтрокаТаблицы.Сумма / РезультатПоиска.Итог("Сумма"), 2);
			
			Ресурсы = Новый Массив;
			Ресурсы.Добавить("Сумма");
			Ресурсы.Добавить("СуммаОплаты");
			Ресурсы.Добавить("СуммаРегл");
			Ресурсы.Добавить("СуммаУпр");
			
			Для каждого Ресурс Из Ресурсы Цикл
				РаспределяемаяСумма =  - РезультатПоиска.Итог(Ресурс) * Коэффициент;
				Если РаспределяемаяСумма <> 0 Тогда
					КоэффициентыРаспределения = РезультатПоиска.ВыгрузитьКолонку(Ресурс);
					РезультатРаспределения 	  = ОбщегоНазначенияКлиентСервер.РаспределитьСуммуПропорциональноКоэффициентам(
													РаспределяемаяСумма, КоэффициентыРаспределения, 2);
					РезультатПоиска.ЗагрузитьКолонку(РезультатРаспределения, Ресурс);								
				КонецЕсли;
			КонецЦикла;
													
			Для каждого Запись Из РезультатПоиска Цикл
				НоваяСтрока = Движения.бит_кзн_ПланируемоеПоступлениеДенежныхСредствАналитика.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Запись);
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизиты);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;

	Движения.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Записывать 		   = Истина;
	Движения.бит_кзн_ПланируемоеПоступлениеДенежныхСредствАналитика.Записывать = Истина;
	
КонецПроцедуры

Процедура СформироватьПланируемыеЗатраты(ПланируемыеЗатраты, Реквизиты, Движения) Экспорт

	Если НЕ ЗначениеЗаполнено(ПланируемыеЗатраты) Тогда
		Возврат;
	КонецЕсли;
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.бит_пз_ПланируемыеЗатраты");
	ЭлементБлокировки.ИсточникДанных = ПланируемыеЗатраты;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ДокументПланирования","ДокументПланирования");
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ЗаявкаНаЗатраты","ЗаявкаНаЗатраты");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;	
	Блокировка.Заблокировать();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МоментВремени"		  , Новый МоментВремени(Реквизиты.Период, Реквизиты.Регистратор));
	Запрос.УстановитьПараметр("ДокументыПланирования" , ПланируемыеЗатраты);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДокументыПланирования.ДокументПланирования КАК ДокументПланирования,
	|	ДокументыПланирования.ЗаявкаНаЗатраты КАК ЗаявкаНаЗатраты
	|ПОМЕСТИТЬ ДокументыПланирования
	|ИЗ
	|	&ДокументыПланирования КАК ДокументыПланирования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПланируемыеЗатраты.ДокументПланирования КАК ДокументПланирования,
	|	ПланируемыеЗатраты.Номенклатура КАК Номенклатура,
	|	ПланируемыеЗатраты.Организация КАК Организация,
	|	ПланируемыеЗатраты.ЗаявкаНаЗатраты КАК ЗаявкаНаЗатраты,
	|	ПланируемыеЗатраты.Характеристика КАК Характеристика,
	|	ПланируемыеЗатраты.КоличествоОстаток КАК Количество,
	|	ПланируемыеЗатраты.СуммаОстаток КАК Сумма
	|ИЗ
	|	РегистрНакопления.бит_пз_ПланируемыеЗатраты.Остатки(
	|			&МоментВремени,
	|			(ДокументПланирования, ЗаявкаНаЗатраты) В
	|				(ВЫБРАТЬ
	|					ДокументыПланирования.ДокументПланирования,
	|					ДокументыПланирования.ЗаявкаНаЗатраты
	|				ИЗ
	|					ДокументыПланирования КАК ДокументыПланирования)) КАК ПланируемыеЗатраты";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Движения.бит_пз_ПланируемыеЗатраты.Добавить();
		НоваяСтрока.ВидДвижения = ВидДвиженияНакопления.Расход;
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизиты);	
	КонецЦикла; 
	Движения.бит_пз_ПланируемыеЗатраты.Записывать = Истина;
	
КонецПроцедуры
	
