// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти  

&НаКлиенте
Процедура Подбор(Команда)
	
	ПараметрыФормы	   = Новый Структура;
	ПараметрыФормы.Вставить("РежимПодбора", Истина);
	ПараметрыФормы.Вставить("Организация", Объект.Организация);
	
	РежимОтрытия	   = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
	ОписаниеОповещения = Новый ОписаниеОповещения("ПодборЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("Обработка.бит_ЗакрытиеДокументовПланирования.Форма", ПараметрыФормы, ЭтотОбъект, 
		ЭтотОбъект,,, ОписаниеОповещения, РежимОтрытия);
		
КонецПроцедуры
	
// Обработчик завершения открытия формы.
//  См. Синтакс-помощник: ОткрытьФорму().
//
&НаКлиенте
Процедура ПодборЗавершение(Результат, Дополнительно) Экспорт

	Если Результат <> Неопределено И ЭтоАдресВременногоХранилища(Результат) Тогда
		ОбработатьРезультатПодбораНаСерере(Результат)	
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура заполняет кэш значений, необходимый при работе на клиенте.
//
&НаСервере
Процедура ЗаполнитьКэшЗначений(КэшированныеЗначения)

	КэшированныеЗначения = Новый Структура;
		
	// заполним список типов для быстрого выбора составного
	МассивТипов  = Объект.Ссылка.Метаданные().ТабличныеЧасти.ДокументыПланирования.Реквизиты.ДокументПланирования.Тип.Типы();
	СписокВыбора = бит_ОбщегоНазначения.ПодготовитьСписокВыбораТипа(МассивТипов);
	
	КэшированныеЗначения.Вставить("СписокТиповДокументПланирования",СписокВыбора);
	
КонецПроцедуры

//  Процедура проверяет возможность создания документа закрытия. 
//
// Параметры:
//  Основание - ДокументСсылка.
//  Отказ - Булево.
//
&НаСервере
Процедура ПроверитьВозможностьСозданияЗакрытия(Основание, Отказ)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РегистрСтатусыОбъектов.Объект КАК Документ
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК РегистрСтатусыОбъектов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_СтатусыОбъектов КАК СправочникСтатусыОбъектов
	|		ПО РегистрСтатусыОбъектов.Статус = СправочникСтатусыОбъектов.Ссылка
	|			И (РегистрСтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))
	|			И (РегистрСтатусыОбъектов.Объект = &Документ)
	|			И (СправочникСтатусыОбъектов.ТипСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ТипыСтатусовОбъектов.Закрыт))";	
	Запрос.УстановитьПараметр("Документ", Основание);	
	Результат = Запрос.Выполнить();
	
	Если НЕ Результат.Пустой() Тогда
		ТекстСообщения = НСтр("ru='Создание Закрытия документов планирования, невозможно в статусе Закрыт.';
								  |en='Creating a private planning documents, it is impossible in the status of closing.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ТипСтатуаВыбранногоЗначения(ВыбранноеЗначение)
	
	Статус = бит_ВизированиеСервер.ТекущийСтатус(ВыбранноеЗначение);
	Возврат Справочники.бит_СтатусыОбъектов.ТипСтатусаОбъкта(Статус);
	
КонецФункции

&НаСервере
Процедура ОбработатьРезультатПодбораНаСерере(АдресРезультата)

	Перем ПереченьДокументов;
	Перем ПричинаЗакрытия;
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Результат.Свойство("ПереченьДокументов", ПереченьДокументов);
		Результат.Свойство("ПричинаЗакрытия", 	 ПричинаЗакрытия);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПереченьДокументов) Тогда
		Возврат;	
	КонецЕсли;
	
    Запрос = Новый Запрос;
    Запрос.УстановитьПараметр("ПереченьДокументов", ПереченьДокументов);
	Запрос.УстановитьПараметр("ПричинаЗакрытия", 	ПричинаЗакрытия);
	Запрос.УстановитьПараметр("Организация", 		Объект.Организация);
	
	Запрос.Текст	 = ТекстЗапросаПереченьДокументов();
    РезультатЗапроса = Запрос.Выполнить();
    
    Если РезультатЗапроса.Пустой() Тогда
        Возврат;
	КонецЕсли;
	
	Объект.ДокументыПланирования.Очистить();
	ВыборкаПоДокументам   = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаПоДокументам.Следующий() Цикл
		НоваяСтрока = Объект.ДокументыПланирования.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаПоДокументам);
	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ТекстЗапросаПереченьДокументов()

	ТекстЗапроса = 
    "ВЫБРАТЬ
    |	ПереченьДокументов.Организация КАК Организация,
    |	ПереченьДокументов.ДокументПланирования КАК ДокументПланирования,
    |	ПереченьДокументов.Позиция КАК Позиция,
    |	ВЫБОР
    |		КОГДА ПереченьДокументов.ПричинаЗакрытия = ЗНАЧЕНИЕ(Справочник.бит_ПричиныЗакрытияДокументовПланированияПлатежа.ПустаяСсылка)
    |			ТОГДА &ПричинаЗакрытия
    |		ИНАЧЕ ПереченьДокументов.ПричинаЗакрытия
    |	КОНЕЦ КАК ПричинаЗакрытия,
    |	ПереченьДокументов.Закрыть КАК Закрыть
    |ПОМЕСТИТЬ ВТ_ОбщийСписок
    |ИЗ
    |	&ПереченьДокументов КАК ПереченьДокументов
    |ГДЕ
    |	ПереченьДокументов.Закрыть
    |	И ПереченьДокументов.Организация = &Организация
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	ВТ_ОбщийСписок.Организация КАК Организация,
    |	ВТ_ОбщийСписок.ДокументПланирования КАК ДокументПланирования,
    |	МАКСИМУМ(ВТ_ОбщийСписок.ПричинаЗакрытия) КАК ПричинаЗакрытия,
    |	ВТ_ОбщийСписок.Закрыть КАК Закрыть
    |ИЗ
    |	ВТ_ОбщийСписок КАК ВТ_ОбщийСписок
    |
    |СГРУППИРОВАТЬ ПО
    |	ВТ_ОбщийСписок.Организация,
    |	ВТ_ОбщийСписок.ДокументПланирования,
    |	ВТ_ОбщийСписок.Закрыть
    |
    |ОБЪЕДИНИТЬ ВСЕ
    |
    |ВЫБРАТЬ
    |	ВТ_ОбщийСписок.Организация,
    |	ВТ_ОбщийСписок.Позиция,
    |	ВТ_ОбщийСписок.ПричинаЗакрытия,
    |	ВТ_ОбщийСписок.Закрыть
    |ИЗ
    |	ВТ_ОбщийСписок КАК ВТ_ОбщийСписок
    |ГДЕ
    |	ВТ_ОбщийСписок.Позиция <> НЕОПРЕДЕЛЕНО";

	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();

КонецФункции

#КонецОбласти
