#Область ЗаполнениеЗначенийПоИсточникам

&НаКлиенте
Процедура ОбработкаЗаполненияИзИсточникаДанных(ВыбранноеЗначение)
	
	Если ВыбранноеЗначение.Режим = "Заполнить" 
		И Объект.ЗначенияПараметра.Количество() > 0 Тогда 
		
		// В режиме заполнения существующие данные следует очистить.
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("ВыбранноеЗначение", ВыбранноеЗначение);
		бит_РаботаСДиалогамиКлиент.ЗапросПодтвержденияОчисткиДанных(ЭтотОбъект, ДопПараметры);
	Иначе
		ЗаполнитьТабЧасть(ВыбранноеЗначение, Ложь);
	КонецЕсли; // Режим заполнения.
	
КонецПроцедуры

// Оповещение на вопрос о подтверждение очистки.
//
// Параметры:
//  Результат    - КодВозвратаДиалога.
//  ДопПараметры - Структура.
//
&НаКлиенте
Процедура ОтветНаПотверждениеОчистки(РезультатОтвет, ДопПараметры) Экспорт
	
	ОчищатьДанные = РезультатОтвет = КодВозвратаДиалога.Да;
    
    Если ОчищатьДанные Тогда
        ЗаполнитьТабЧасть(ДопПараметры.ВыбранноеЗначение, ОчищатьДанные);
    КонецЕсли;
    
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТабЧасть(Знач ВыбранноеЗначение, Знач ОчищатьДанные)
	
	Модифицированность = Истина;
	
	Если ОчищатьДанные Тогда
		Объект.ЗначенияПараметра.Очистить();
	КонецЕсли; 
	
	ДанныеЗаполнения = ПолучитьИзВременногоХранилища(ВыбранноеЗначение.АдресОборотовПоБюджетам);	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ТаблицаЗначений") Тогда
		
		КолонкиГруппировки  = "Аналитика_1, Аналитика_2, Аналитика_3, Аналитика_4";
		КолонкиСуммирования = "СуммаСценарийВВалютеДокумента";
		
		ТаблицаЗаполнения = ДанныеЗаполнения.Скопировать(, КолонкиГруппировки + ", " + КолонкиСуммирования);
		ТаблицаЗаполнения.Свернуть(КолонкиГруппировки, КолонкиСуммирования);
		ТаблицаЗаполнения.Колонки.СуммаСценарийВВалютеДокумента.Имя = "ЗначениеПараметра";
		
		Если ОчищатьДанные Тогда
			Объект.ЗначенияПараметра.Загрузить(ТаблицаЗаполнения);
		Иначе
			Для каждого СтрокаЗаполнения Из ТаблицаЗаполнения Цикл
				НоваяСтрокаЗначения = Объект.ЗначенияПараметра.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаЗначения, СтрокаЗаполнения);
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
	
	ТекстСообщения = НСтр("ru='Заполнение завершено.';en='Filling in completed.'");
	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ПодготовитьФормуНаСервере()

	УстановитьСостояниеДокумента();
	НастройкиАналитик = НовыеНастройкиАналитик();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСостояниеДокумента()
	
	СостояниеДокумента = бит_ОбщегоНазначения.СостояниеДокумента(Объект);
	
КонецПроцедуры

&НаСервере
Процедура ОформитьАналитики()
	
	ЭлементыКолонокАналитики = ЭлементыКолонокАналитики();
	
	ТекущийПараметр = Объект.Параметр;
	
	Если Объект.Параметр.Пустая() Тогда
		Для каждого ЭлементКолонкаАналитики Из ЭлементыКолонокАналитики Цикл
			ЭлементКолонкаАналитики.Видимость = Ложь;
		КонецЦикла;
		Возврат;
	КонецЕсли;
	
	АтрибутыПараметра = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Параметр, "ЕдиницаИзмерения, ТипЗначения, КоличествоАналитик");
	Элементы.ЗначенияПараметраЗначениеПараметра.ОграничениеТипа = АтрибутыПараметра.ТипЗначения;
	КоличествоАналитик = АтрибутыПараметра.КоличествоАналитик;
	
	ФорматРедактированияЗначения = "";
	Если АтрибутыПараметра.ТипЗначения.СодержитТип(Тип("Число")) Тогда
		КвЧисла                      = АтрибутыПараметра.ТипЗначения.КвалификаторыЧисла;
		ФорматРедактированияЗначения = СтрШаблон("ЧЦ=%1; ЧДЦ=%2", Строка(КвЧисла.Разрядность), Строка(КвЧисла.РазрядностьДробнойЧасти));
	КонецЕсли;	
	Элементы.ЗначенияПараметраЗначениеПараметра.Формат = ФорматРедактированияЗначения;
	
	ВсегоАналитикДокумента = ЭлементыКолонокАналитики.Количество();
	ВыборкаАналитик = Документы.бит_УстановкаЗначенийПроизвольныхПараметров.АтрибутыПроизвольногоПараметра(Объект.Параметр, ВсегоАналитикДокумента);

	Пока ВыборкаАналитик.Следующий() Цикл
		ЭлементКолонкаАналитики = ЭлементыКолонокАналитики.Получить(ВыборкаАналитик.НомерСтроки - 1);
		ЭлементКолонкаАналитики.Видимость       = Истина;
		ЭлементКолонкаАналитики.Заголовок       = ВыборкаАналитик.НаименованиеАналитики;
		ЭлементКолонкаАналитики.ОграничениеТипа = ВыборкаАналитик.ТипЗначенияАналитики;
		ЭлементКолонкаАналитики.ВыбиратьТип     = ВыборкаАналитик.ТипЗначенияАналитики.Типы().Количество() > 1;	
		
		НоваяЗапись = НастройкиАналитик["Аналитика_" + ВыборкаАналитик.НомерСтроки];
		НоваяЗапись.Аналитика 		= ВыборкаАналитик.Аналитика;
		НоваяЗапись.ЭтоСоставнойТип = ВыборкаАналитик.ТипЗначенияАналитики.Типы().Количество() > 1;
		НоваяЗапись.ТипЗначения 	= ВыборкаАналитик.ТипЗначенияАналитики;
	КонецЦикла;
	
	Если КоличествоАналитик < ВсегоАналитикДокумента Тогда
		Для Сч = (КоличествоАналитик + 1) По ВсегоАналитикДокумента Цикл
			ЭлементКолонкаАналитики = ЭлементыКолонокАналитики.Получить(Сч - 1);
			ЭлементКолонкаАналитики.Видимость = Ложь;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция НовыеНастройкиАналитик()

	НовыеНастройкиАналитик = Новый Структура; 
	
	ВГраница = ЭлементыКолонокАналитики().Количество();
	Для Счетчик = 1 По ВГраница Цикл
		НоваяЗапись = Новый Структура;
		НоваяЗапись.Вставить("Аналитика", 		Неопределено);
		НоваяЗапись.Вставить("ЭтоСоставнойТип", Ложь);
		НоваяЗапись.Вставить("ТипЗначения", 	Новый ОписаниеТипов);
		НовыеНастройкиАналитик.Вставить("Аналитика_" + Счетчик, НоваяЗапись);
	КонецЦикла;	

	Возврат НовыеНастройкиАналитик;
	
КонецФункции

&НаСервере
Функция ЭлементыКолонокАналитики()
	
	ЭлементыКолонокАналитики = Новый Массив;
	ЭлементыКолонокАналитики.Добавить(Элементы.ЗначенияПараметраАналитика_1);
	ЭлементыКолонокАналитики.Добавить(Элементы.ЗначенияПараметраАналитика_2);
	ЭлементыКолонокАналитики.Добавить(Элементы.ЗначенияПараметраАналитика_3);
	ЭлементыКолонокАналитики.Добавить(Элементы.ЗначенияПараметраАналитика_4);
	
	Возврат ЭлементыКолонокАналитики;
	
КонецФункции

&НаКлиенте
Процедура ВызватьФормуЗаполненияПоИсточнику()
	
	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("ВалютаДокумента"              , Объект.ЕдиницаИзмерения);
	ПараметрыЗаполнения.Вставить("КурсДокумента"                , 1);
	ПараметрыЗаполнения.Вставить("КратностьДокумента"           , 1);
	ПараметрыЗаполнения.Вставить("Сценарий"                     , Объект.Сценарий);
	ПараметрыЗаполнения.Вставить("ЕдиницаИзмеренияСуммДокумента", Объект.ЕдиницаИзмерения);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ПараметрыЗаполнения", ПараметрыЗаполнения);
	ПараметрыФормы.Вставить("ДатаДок"            , Объект.Дата);
	ПараметрыФормы.Вставить("ДокументЗаполнения" , Объект.Ссылка);
	ПараметрыФормы.Вставить("РежимЗаполнения"    , "ПроизвольныеПараметры");
	
	ОткрытьФорму("Обработка.бит_ПолучениеДанныхБюджета.Форма", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)

	Объект	 = Форма.Объект;
	Элементы = Форма.Элементы;
	
