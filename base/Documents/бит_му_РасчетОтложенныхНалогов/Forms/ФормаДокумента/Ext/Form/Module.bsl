&НаКлиенте
Процедура РасчетыОНСубконтоАвтоПодбор(Элемент, Текст, ДанныеВыбора, Параметры, Ожидание, СтандартнаяОбработка)
	
	Если Ожидание = 0 Тогда
		
		Имя = Прав(Элемент.Имя, 10);
	
		ТекущиеДанные = Элементы.РасчетыОН.ТекущиеДанные;	
		ЗначениеСубконто = ТекущиеДанные[Имя];	
		
		ПараметрыСубконто = Новый Структура;
		ПараметрыСубконто.Вставить("ИмяСубконто"       , "Субконто_");
		ПараметрыСубконто.Вставить("ЗначениеСубконто"  , ЗначениеСубконто);
		ПараметрыСубконто.Вставить("КоличествоСубконто", КоличествоСубконтоМУ);
		бит_БухгалтерияКлиент.СубконтоАвтоПодбор(Элемент, Параметры, ТекущиеДанные, Объект, ПараметрыСубконто);
	
	КонецЕсли;

КонецПроцедуры

