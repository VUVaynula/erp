#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	
	Поля.Добавить("Номер");
	Поля.Добавить("Дата");
	Поля.Добавить("ВидПлана");
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	Если Данные.ВидПлана = Перечисления.бит_кзн_ВидыПланов.Прогноз  Тогда	
		СтандартнаяОбработка = Ложь;
		Представление = НСтр("ru='Прогноз поступления ДС %1 от %2';en='Prediction DS incoming %1 from %2'");
		Представление = СтрШаблон(Представление, Данные.Номер, Формат(Данные.Дата, "ДЛФ=DT"));	
	КонецЕсли; 
	
КонецПроцедуры

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		
		Режим = "";
		Параметры.Свойство("Режим", Режим);
		
		Если НЕ Режим = "ОткрытиеСпискаПозиций" И Параметры.Свойство("Ключ") Тогда
			// Форма открывается по ссылке.
			РезультатПоиска = Документы.бит_кзн_ПозицияПоступления.НайтиПозициюПоОснованию(Параметры.Ключ);
			Позиция		    = РезультатПоиска.Позиция;
			Если РезультатПоиска.КоличествоПозиций = 1 Тогда
				Параметры.Ключ = Позиция;
				ВыбраннаяФорма = Метаданные.Документы.бит_кзн_ПозицияПоступления.ОсновнаяФормаОбъекта;
				СтандартнаяОбработка = Ложь;
			КонецЕсли; 
		КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область ВводНаОсновании

// Подключаемый, см. бит_КазначействоВызовСервера.ПараметрыФормыВводНаОсновании().
//	
Функция ПараметрыФормыВводНаОсновании(Основание) Экспорт

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ИмяФормы", "Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ФормаОбъекта");
	ПараметрыФормы.Вставить("ПараметрыФормы", Новый Структура);
	ПараметрыФормы.Вставить("Отказ", Ложь);

	ДанныеЗаполнения = Документы.бит_кзн_ПозицияПоступления.ДанныеЗаполненияИзОснования(Основание);
	
	Если ДанныеЗаполнения.Количество() = 0 Тогда 
		ТекстСообщения = НСтр("ru = 'Не требуется вводить планируемое поступление денежных средств на основании документа %1.';
								|en = 'It is not required to enter the planned receipt of funds based on the document %1.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, Основание);
		ВызватьИсключение ТекстСообщения;
	ИначеЕсли ДанныеЗаполнения.Количество() = 1 Тогда
		// Ввод однострочного Планируемого поступления.
		// Открываем новую Позицию поступления. 
		ПараметрыФормы.ИмяФормы 	  = "Документ.бит_кзн_ПозицияПоступления.ФормаОбъекта";
		ПараметрыФормы.ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ДанныеЗаполнения[0]);
	Иначе
		// Записываем Позиции поступления, связывая с одним Планируемым поступлением.
		// Открываем Планируемое поступление.
		ДокументПланирования = ДокументПоДаннымПозицийПоступления(ДанныеЗаполнения);
		ПараметрыФормы.ИмяФормы 	  = "Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ФормаОбъекта";
		ПараметрыФормы.ПараметрыФормы = Новый Структура("Ключ", ДокументПланирования);
	КонецЕсли;
	
	Возврат ПараметрыФормы;

КонецФункции

// Добавляет команду создания документа "Заявка на расходование денежных средств (БИТ)".
//
// Параметры:
//   КомандыСозданияНаОсновании - ТаблицаЗначений - Таблица с командами создания на основании. Для изменения.
//       См. описание 1 параметра процедуры СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании().
//
Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании) Экспорт
	
	Если ПравоДоступа("Добавление", Метаданные.Документы.бит_кзн_ПозицияПоступления) Тогда
		КомандаСоздатьНаОсновании = КомандыСозданияНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Обработчик	= "бит_КазначействоКлиент.СоздатьПланируемоеПоступлениеСредств";
		КомандаСоздатьНаОсновании.Идентификатор = "СоздатьПланируемоеПоступлениеСредств";
		КомандаСоздатьНаОсновании.Представление = НСтр("ru = 'Планируемое поступление ДС (БИТ)';
														|en = 'Planned cash receipt transaction'");
		КомандаСоздатьНаОсновании.РежимЗаписи 	= "Проводить";		
		Возврат КомандаСоздатьНаОсновании;		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ДокументПоДаннымПозицийПоступления(ДанныеЗаполнения) Экспорт
	
	Попытка
		НачатьТранзакцию();
		ДокументПланирования = Неопределено;
		Для каждого Элемент Из ДанныеЗаполнения Цикл
			Элемент.ДокументПланирования = ДокументПланирования;
			
			ПозицияОбъект = Документы.бит_кзн_ПозицияПоступления.СоздатьДокумент();
			ПозицияОбъект.Заполнить(Элемент);
			ПозицияОбъект.Записать(РежимЗаписиДокумента.Запись);
			Если ДокументПланирования = Неопределено Тогда
				ДокументПланирования = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПозицияОбъект.Ссылка, "ДокументПланирования");
			КонецЕсли;
		КонецЦикла;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат ДокументПланирования;

КонецФункции

#КонецОбласти

Функция СоздатьДокументыНаОсновеЗаявки(ДокументОснование) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументОснование);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПозицияПоступления.ДатаПлан КАК Дата,
	|	ВЫБОР
	|		КОГДА ПозицияПоступления.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|			ТОГДА ПозицияПоступления.БанковскийСчет
	|		ИНАЧЕ ПозицияПоступления.Касса
	|	КОНЕЦ КАК БанковскийСчетКасса,
	|	ПозицияПоступления.БанковскийСчетПолучателя КАК БанковскийСчетПолучателя,
	|	ПозицияПоступления.Ссылка КАК Позиция,
	|	ПозицияПоступления.Подразделение КАК Подразделение
	|ПОМЕСТИТЬ ВТ_Позиции
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК ПозицияПоступления
	|ГДЕ
	|	ПозицияПоступления.ДокументПланирования = &ДокументПланирования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОстаткиПланируемыхПоступлений.Позиция КАК Позиция,
	|	ОстаткиПланируемыхПоступлений.СуммаОстаток КАК Сумма
	|ПОМЕСТИТЬ ВТ_ОстаткиПланируемыхПоступлений
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Остатки(
	|			,
	|			Позиция В
	|				(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|					ВТ_Позиции.Позиция КАК Позиция
	|				ИЗ
	|					ВТ_Позиции КАК ВТ_Позиции)) КАК ОстаткиПланируемыхПоступлений
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Позиции.БанковскийСчетКасса КАК БанковскийСчетКасса,
	|	ВТ_Позиции.БанковскийСчетПолучателя КАК БанковскийСчетПолучателя,
	|	ВТ_Позиции.Дата КАК Дата,
	|	ВТ_Позиции.Позиция КАК Позиция,
	|	ЕСТЬNULL(ВТ_ОстаткиПланируемыхПоступлений.Сумма, 0) КАК Сумма,
	|	ВТ_Позиции.Подразделение КАК Подразделение
	|ИЗ
	|	ВТ_Позиции КАК ВТ_Позиции
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОстаткиПланируемыхПоступлений КАК ВТ_ОстаткиПланируемыхПоступлений
	|		ПО ВТ_Позиции.Позиция = ВТ_ОстаткиПланируемыхПоступлений.Позиция
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	БанковскийСчетКасса,
	|	БанковскийСчетПолучателя,
	|	Подразделение";
				   
	Результат = Запрос.Выполнить();                             
	Выборка = Результат.Выбрать();
	
	ПараметрыДокументов = Новый Массив;

	Пока Выборка.СледующийПоЗначениюПоля("Дата") Цикл
		Пока Выборка.СледующийПоЗначениюПоля("БанковскийСчетКасса") Цикл
			Пока Выборка.СледующийПоЗначениюПоля("БанковскийСчетПолучателя") Цикл
				Пока Выборка.СледующийПоЗначениюПоля("Подразделение") Цикл
					ДанныеЗаполнения = НовыеПараметрыДокументаСоздатьПлатежныеДокументы();
					ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка);
					
					Пока Выборка.Следующий() Цикл
						Если Выборка.Сумма = 0 Тогда
							ТекстСообщения = НСтр("ru = 'Недостаточно запланированных средств по %1. Документ пропущен.'");
							ТекстСообщения = СтрШаблон(ТекстСообщения, Выборка.Позиция);
							ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Выборка.Позиция);
						Иначе	
							ЗаполнитьЗначенияСвойств(ДанныеЗаполнения.Позиции.Добавить(), Выборка)
						КонецЕсли;
					КонецЦикла;
					
					Если ЗначениеЗаполнено(ДанныеЗаполнения.Позиции) Тогда
						ПараметрыДокументов.Добавить(ДанныеЗаполнения);
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	НовыеДокументы = Новый ТаблицаЗначений;
	Если ЗначениеЗаполнено(ПараметрыДокументов) Тогда
		НовыеДокументы = СоздатьДокументыПоступления(ДокументОснование, ПараметрыДокументов);
	КонецЕсли;
	
	Возврат НовыеДокументы;
	
КонецФункции

// Функция создает документы поступления на основе списка выделенных документов.
//
Функция СоздатьДокументыНаОсновеВыделенных(ДокументОснование, ПараметрыВыделенных) Экспорт 
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВыделенныеСтроки", ПараметрыВыделенных.Позиции);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВыделенныеСтроки.Позиция КАК Позиция,
	|	ВыделенныеСтроки.Сумма КАК Сумма
	|ПОМЕСТИТЬ ВыделенныеСтроки
	|ИЗ
	|	&ВыделенныеСтроки КАК ВыделенныеСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОстаткиПланируемыхПоступлений.Позиция КАК Позиция,
	|	ЕСТЬNULL(ОстаткиПланируемыхПоступлений.СуммаОстаток, 0) КАК Сумма
	|ПОМЕСТИТЬ ВТ_ОстаткиПланируемыхПоступлений
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Остатки(
	|			,
	|			Позиция В
	|				(ВЫБРАТЬ
	|					ВыделенныеСтроки.Позиция КАК Позиция
	|				ИЗ
	|					ВыделенныеСтроки КАК ВыделенныеСтроки)) КАК ОстаткиПланируемыхПоступлений
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВыделенныеСтроки.Позиция КАК Позиция,
	|	ВЫБОР
	|		КОГДА ВыделенныеСтроки.Сумма = 0
	|			ТОГДА ЕСТЬNULL(ОстаткиПланируемыхПоступлений.Сумма, 0)
	|		ИНАЧЕ ВыделенныеСтроки.Сумма
	|	КОНЕЦ КАК Сумма,
	|	ПозицииПоступления.ДатаПлан КАК Дата,
	|	ВЫБОР
	|		КОГДА ПозицииПоступления.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|			ТОГДА ПозицииПоступления.БанковскийСчет
	|		ИНАЧЕ ПозицииПоступления.Касса
	|	КОНЕЦ КАК БанковскийСчетКасса,
	|	ПозицииПоступления.БанковскийСчетПолучателя КАК БанковскийСчетПолучателя,
	|	ПозицииПоступления.Подразделение КАК Подразделение
	|ИЗ
	|	ВыделенныеСтроки КАК ВыделенныеСтроки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПозицияПоступления КАК ПозицииПоступления
	|		ПО ВыделенныеСтроки.Позиция = ПозицииПоступления.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОстаткиПланируемыхПоступлений КАК ОстаткиПланируемыхПоступлений
	|		ПО ВыделенныеСтроки.Позиция = ОстаткиПланируемыхПоступлений.Позиция
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	БанковскийСчетКасса,
	|	БанковскийСчетПолучателя,
	|	Подразделение";

	Результат = Запрос.Выполнить();                             
	Выборка = Результат.Выбрать();

	ПараметрыДокументов = Новый Массив;

	Пока Выборка.СледующийПоЗначениюПоля("Дата") Цикл
		Пока Выборка.СледующийПоЗначениюПоля("БанковскийСчетКасса") Цикл
			Пока Выборка.СледующийПоЗначениюПоля("БанковскийСчетПолучателя") Цикл
				Пока Выборка.СледующийПоЗначениюПоля("Подразделение") Цикл
					ДанныеЗаполнения = НовыеПараметрыДокументаСоздатьПлатежныеДокументы();
					ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, ПараметрыВыделенных,, "Позиции");
					ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка,, "Дата");
					Если НЕ ЗначениеЗаполнено(ПараметрыВыделенных.Дата) Тогда
						ДанныеЗаполнения.Дата = Выборка.Дата;					
					КонецЕсли;
					
	 				Пока Выборка.Следующий() Цикл
						Если Выборка.Сумма = 0 Тогда
							ТекстСообщения = НСтр("ru = 'Недостаточно запланированных средств по %1. Документ пропущен.'");
							ТекстСообщения = СтрШаблон(ТекстСообщения, Выборка.Позиция);
							ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Выборка.Позиция);
						Иначе	
							ЗаполнитьЗначенияСвойств(ДанныеЗаполнения.Позиции.Добавить(), Выборка)
						КонецЕсли;
					КонецЦикла;
					Если ЗначениеЗаполнено(ДанныеЗаполнения.Позиции) Тогда
						ПараметрыДокументов.Добавить(ДанныеЗаполнения);
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	НовыеДокументы = Новый ТаблицаЗначений;
	НовыеДокументы.Колонки.Добавить("ДокументОплаты");
	НовыеДокументы.Колонки.Добавить("Позиция");
	
	Если ЗначениеЗаполнено(ПараметрыДокументов) Тогда
		НовыеДокументы = СоздатьДокументыПоступления(ДокументОснование, ПараметрыДокументов);
	КонецЕсли;
	
	Возврат НовыеДокументы;
	
КонецФункции

Функция НовыеПараметрыДокументаСоздатьПлатежныеДокументы() Экспорт

	Позиции = Новый ТаблицаЗначений;
	Позиции.Колонки.Добавить("Позиция", 			Новый ОписаниеТипов("ДокументСсылка.бит_кзн_ПозицияПоступления"));
	Позиции.Колонки.Добавить("Сумма",				ОбщегоНазначения.ОписаниеТипаЧисло(15, 2));
	Позиции.Колонки.Добавить("ИдентификаторСтроки", ОбщегоНазначения.ОписаниеТипаСтрока(36));
	
	НовыеПараметры = Новый Структура;
	НовыеПараметры.Вставить("Дата", '0001-01-01');
	НовыеПараметры.Вставить("БанковскийСчетКасса", Неопределено);
	НовыеПараметры.Вставить("БанковскийСчетПолучателя", Неопределено);
	НовыеПараметры.Вставить("Позиции", Позиции);

	НовыеПараметры.Вставить("ОбъединятьНазначениеПлатежа", Истина);
	НовыеПараметры.Вставить("РежимЗаписи", 				   Перечисления.бит_РежимыЗаписиДокумента.Запись);

	Возврат НовыеПараметры;

КонецФункции

// Функция создает документы поступления денежных средств.
//
// Параметры:
//  ДокументОснование - ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.
//
Функция СоздатьДокументыПоступления(ДокументОснование, ПараметрыДокументов) Экспорт 

	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ДокументОплаты");
	Результат.Колонки.Добавить("Позиция");
	
	Если НЕ ЗначениеЗаполнено(ПараметрыДокументов) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.ФормаОплаты КАК ФормаОплаты,
	|	Реквизиты.Контрагент КАК Контрагент
	|ИЗ
	|	Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";
	
	РезультатЗапроса   = Запрос.Выполнить().Выгрузить();
	РеквизитыОснования = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(РезультатЗапроса[0]);
	
	ВидОперацииБФ = Перечисления.бит_ВидыОперацийКазначейства.ПоступлениеОплатыОтКлиента; 
	ВидОперации   = Перечисления.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента;
	РеквизитыОснования.Вставить("ХозяйственнаяОперация", ВидОперацииБФ);

	ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();

	// определим фактическией сценарий
	ПараметрыНастроек  = Новый Структура("Организация", РеквизитыОснования.Организация);
    СценарийФакт 	   = бит_НастройкиПрограммы.СценарийОтраженияФактаБДДС(ПараметрыНастроек, ТекущаяДатаСеанса());	
							
    Если НЕ ЗначениеЗаполнено(СценарийФакт) Тогда
		СценарийФакт = Справочники.СценарииПланирования.ФАКТ;
	КонецЕсли; 
	
	Если РеквизитыОснования.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
		МенеджерПлатежногоДокумента   = Документы.ПоступлениеБезналичныхДенежныхСредств;
		МетаданныеПлатежногоДокумента = Метаданные.Документы.ПоступлениеБезналичныхДенежныхСредств;
		Безналичные 		  		  = Истина;
	ИначеЕсли РеквизитыОснования.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Наличные Тогда
		МенеджерПлатежногоДокумента   = Документы.ПриходныйКассовыйОрдер;
		МетаданныеПлатежногоДокумента = Метаданные.Документы.ПриходныйКассовыйОрдер;
		Безналичные 				  = Ложь;
	КонецЕсли;

	ЕстьРасшифровкаПлатежа	   = НЕ бит_КазначействоКлиентСервер.ЭтоОперацияБезРасшифровкиПлатежа(ВидОперацииБФ);
	ЕстьПодразделение		   = ОбщегоНазначения.ЕстьРеквизитОбъекта("Подразделение", МетаданныеПлатежногоДокумента);
	ЕстьТипПлатежногоДокумента = ОбщегоНазначения.ЕстьРеквизитОбъекта("ТипПлатежногоДокумента", МетаданныеПлатежногоДокумента);
	ЕстьНазначениеПлатежа	   = ОбщегоНазначения.ЕстьРеквизитОбъекта("НазначениеПлатежа", МетаданныеПлатежногоДокумента);

	Для каждого ТекущиеПараметры Из ПараметрыДокументов Цикл
		
		ПараметрыЗаполнения = Новый Структура;
		ПараметрыЗаполнения.Вставить("СуммыКОплате", 				ТекущиеПараметры);
		ПараметрыЗаполнения.Вставить("Безналичные", 				Безналичные);
		ПараметрыЗаполнения.Вставить("ВидОперации", 				ВидОперации);
		ПараметрыЗаполнения.Вставить("ЕстьНазначениеПлатежа", 		ЕстьНазначениеПлатежа);
		ПараметрыЗаполнения.Вставить("ЕстьПодразделение", 			ЕстьПодразделение);
		ПараметрыЗаполнения.Вставить("ЕстьТипПлатежногоДокумента", 	ЕстьТипПлатежногоДокумента);
		ПараметрыЗаполнения.Вставить("МенеджерПлатежногоДокумента", МенеджерПлатежногоДокумента);
		ПараметрыЗаполнения.Вставить("ОбъединятьНазначениеПлатежа", ТекущиеПараметры.ОбъединятьНазначениеПлатежа);
		ПараметрыЗаполнения.Вставить("РеквизитыОснования", 			РеквизитыОснования);
		ПараметрыЗаполнения.Вставить("СценарийФакт", 				СценарийФакт);
		ПараметрыЗаполнения.Вставить("ВалютаРеглУчета", 			ВалютаРеглУчета);
		ПараметрыЗаполнения.Вставить("ЕстьРасшифровкаПлатежа", 		ЕстьРасшифровкаПлатежа);
		ПараметрыЗаполнения.Вставить("РежимЗаписиПлатДокумента", 	ТекущиеПараметры.РежимЗаписи);
		ПараметрыЗаполнения.Вставить("ДатаДокумента", 				'0001-01-01');
		
		ДокументПозиция = ТекущиеПараметры.Позиции[0].Позиция;
		
		ЗначениеРеквизитовПозиции = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументПозиция, "ДатаПлан");
		
		Если НЕ ЗначениеЗаполнено(ТекущиеПараметры.Дата) Тогда
			ПараметрыЗаполнения.ДатаДокумента = ЗначениеРеквизитовПозиции.ДатаПлан;
		Иначе			
			ПараметрыЗаполнения.ДатаДокумента = ТекущиеПараметры.Дата;
		КонецЕсли;

		СоздатьДокументПоступления(ПараметрыЗаполнения, Результат);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция РазбитьПозицию(Позиция, СуммаНач, СуммаНов, ДатаПлатежа) Экспорт 
	
	ВыводСообщений	   = "Ошибки";
	РазбиениеВыполнено = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Позиция", Позиция);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бит_СтатусыОбъектов.Объект,
	|	бит_СтатусыОбъектов.Статус,
	|	бит_СтатусыОбъектов.Пользователь,
	|	бит_СтатусыОбъектов.ДатаИзмененияСтатуса,
	|	бит_СтатусыОбъектов.СтатусПредыдущий
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК бит_СтатусыОбъектов
	|ГДЕ
	|	бит_СтатусыОбъектов.Объект = &Позиция
	|	И бит_СтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус)";
	
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
	
		Статус		 		 = Выборка.Статус;
		ПредыдущийСтатус	 = Выборка.СтатусПредыдущий;
		Пользователь 		 = Выборка.Пользователь;
	    ДатаИзмененияСтатуса = Выборка.ДатаИзмененияСтатуса;
		
	КонецЦикла;
	
	ДанныеСообщения = Неопределено;
	
	НачатьТранзакцию();
	Попытка	
		//Получаем текущую позицию и меняем в ней сумму на разницу между начальной суммой и новой
		Объект = Позиция.ПолучитьОбъект();
		
		РежимЗаписи = ?(Объект.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись);
		
		Объект.СуммаДокумента = СуммаНач - СуммаНов;
		Если Объект.ВалютаВзаиморасчетов <> Объект.ВалютаДокумента Тогда
			Объект.СуммаВзаиморасчетов = 0;
		Иначе
			Объект.СуммаВзаиморасчетов = Объект.СуммаДокумента;
		КонецЕсли;

		Если Объект.ВалютаДокумента = Объект.ВалютаВзаиморасчетов Тогда
			Объект.СуммаВзаиморасчетов = Объект.СуммаДокумента;
		Иначе
			Данные = Новый Структура;
			Данные.Вставить("Сумма", 						 Объект.СуммаДокумента);
			Данные.Вставить("КурсЧислительВзаиморасчетов",	 Объект.КурсЧислительВзаиморасчетов);
			Данные.Вставить("КурсЗнаменательВзаиморасчетов", Объект.КурсЗнаменательВзаиморасчетов);
			Данные.Вставить("СуммаВзаиморасчетов",			 Объект.СуммаВзаиморасчетов);
			
			ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
				Данные, Объект.ВалютаДокумента, Константы.ВалютаРегламентированногоУчета.Получить());
			
			Объект.СуммаВзаиморасчетов = Данные.СуммаВзаиморасчетов; 		
		КонецЕсли;
		
		Объект.СуммаНДС = РасчитатьСуммуНДС(Объект.СуммаДокумента, Объект.СтавкаНДС);
		
		Попытка
			Объект.Записать(РежимЗаписи);		
		Исключение
			ТекстСообщения  = НСтр("ru = 'Не удалось записать документ %1. По причине: %2.'");
			ТекстСообщения  = СтрШаблон(ТекстСообщения, Позиция, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ДанныеСообщения = Позиция;
			
			ВызватьИсключение ТекстСообщения;
		КонецПопытки;	
		
		НоваяПозиция = Позиция.Скопировать();
		НоваяПозиция.ДополнительныеСвойства.Вставить("НеСинхронизировать", Истина);

		НоваяПозиция.Дата			= Позиция.Дата;
		
		Если НЕ ЗначениеЗаполнено(ДатаПлатежа) Тогда
			НоваяПозиция.ДатаПлан		 = Позиция.ДатаПлан;
			НоваяПозиция.ДатаПланКрайняя = Позиция.ДатаПланКрайняя;
		Иначе 
			НоваяПозиция.ДатаПлан = ДатаПлатежа;
		КонецЕсли; 	
		
		НоваяПозиция.СуммаДокумента = СуммаНов;
		
		Если НоваяПозиция.ВалютаДокумента = НоваяПозиция.ВалютаВзаиморасчетов Тогда
			НоваяПозиция.СуммаВзаиморасчетов = НоваяПозиция.СуммаДокумента;
		Иначе
			Данные = Новый Структура;
			Данные.Вставить("Сумма", 						 НоваяПозиция.СуммаДокумента);
			Данные.Вставить("КурсЧислительВзаиморасчетов",	 НоваяПозиция.КурсЧислительВзаиморасчетов);
			Данные.Вставить("КурсЗнаменательВзаиморасчетов", НоваяПозиция.КурсЗнаменательВзаиморасчетов);
			Данные.Вставить("СуммаВзаиморасчетов",			 НоваяПозиция.СуммаВзаиморасчетов);
			
			ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
				Данные, НоваяПозиция.ВалютаДокумента, Константы.ВалютаРегламентированногоУчета.Получить());
			
			НоваяПозиция.СуммаВзаиморасчетов = НоваяПозиция.СуммаВзаиморасчетов; 		
		КонецЕсли;
			
		НоваяПозиция.СуммаНДС = РасчитатьСуммуНДС(НоваяПозиция.СуммаДокумента, НоваяПозиция.СтавкаНДС);
		
		НоваяПозиция.Записать(РежимЗаписиДокумента.Запись);
		
		Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
			Попытка
				НоваяПозиция.Записать(РежимЗаписиДокумента.Проведение);
				
				ПараметрыУстановкиСтатуса = бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса();
				ПараметрыУстановкиСтатуса.Объект               = НоваяПозиция.Ссылка; 
				ПараметрыУстановкиСтатуса.Статус               = Статус;
				ПараметрыУстановкиСтатуса.СтатусПредыдущий     = ПредыдущийСтатус;
				ПараметрыУстановкиСтатуса.ДатаИзмененияСтатуса = ДатаИзмененияСтатуса;
				ПараметрыУстановкиСтатуса.Пользователь         = Пользователь;
			
				ДействиеВыполнено = бит_ВизированиеСервер.УстановитьСтатусОбъекта(ПараметрыУстановкиСтатуса);

			Исключение
				ТекстСообщения  = НСтр("ru = 'Не удалось провести документ %1. По причине: %2.'");
				ТекстСообщения  = СтрШаблон(ТекстСообщения, НоваяПозиция.Ссылка, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
				ДанныеСообщения = НоваяПозиция.Ссылка;
				
				ВызватьИсключение ТекстСообщения;
			КонецПопытки;
		КонецЕсли;
				
		РазбиениеВыполнено = Истина;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ДанныеСообщения, "Ссылка");
	КонецПопытки;	
	
	Возврат РазбиениеВыполнено;
	
КонецФункции

Процедура СоздатьДокументПоступления(ПараметрыЗаполнения, Результат)

	Безналичные 				= ПараметрыЗаполнения.Безналичные;
	ВидОперации 				= ПараметрыЗаполнения.ВидОперации;
	ЕстьНазначениеПлатежа 		= ПараметрыЗаполнения.ЕстьНазначениеПлатежа;
	ЕстьПодразделение 			= ПараметрыЗаполнения.ЕстьПодразделение;
	ЕстьТипПлатежногоДокумента	= ПараметрыЗаполнения.ЕстьТипПлатежногоДокумента;
	МенеджерПлатежногоДокумента = ПараметрыЗаполнения.МенеджерПлатежногоДокумента;
	ОбъединятьНазначениеПлатежа = ПараметрыЗаполнения.ОбъединятьНазначениеПлатежа;
	РеквизитыОснования 			= ПараметрыЗаполнения.РеквизитыОснования;
	СценарийФакт 				= ПараметрыЗаполнения.СценарийФакт;
	ВалютаРеглУчета 			= ПараметрыЗаполнения.ВалютаРеглУчета;
	ЕстьРасшифровкаПлатежа 		= ПараметрыЗаполнения.ЕстьРасшифровкаПлатежа;
	ДатаДокумента               = ПараметрыЗаполнения.ДатаДокумента;
	РежимЗаписиПлатДокумента    = ПараметрыЗаполнения.РежимЗаписиПлатДокумента;
	СуммыКОплате               	= ПараметрыЗаполнения.СуммыКОплате;
	
	ВсеПозиции 		 = СуммыКОплате.Позиции.ВыгрузитьКолонку("Позиция");
	РеквизитыПозиций = Документы.бит_кзн_ПозицияПоступления.РеквизитыДокумента(ВсеПозиции);		
		
	РезультатФормирования = Новый Структура("ОткрытьФорму, Ссылка, Позиции");
	ТекущийОбъект = МенеджерПлатежногоДокумента.СоздатьДокумент();
	
	ТекущийОбъект.Дата					= ДатаДокумента;
	ТекущийОбъект.ХозяйственнаяОперация = ВидОперации;
	
	Если Безналичные Тогда
		ТекущийОбъект.БанковскийСчет			= СуммыКОплате.БанковскийСчетКасса;
		ТекущийОбъект.БанковскийСчетКонтрагента = РеквизитыПозиций[0].БанковскийСчетПолучателя;	
	Иначе 
		ТекущийОбъект.Касса = СуммыКОплате.БанковскийСчетКасса;
	КонецЕсли; 
	
	Если ЕстьНазначениеПлатежа Тогда
		// ВАЖНО! "Назначение платежа" формируется окончательно перед записью документа.
		Если ОбъединятьНазначениеПлатежа Тогда
			НазначениеПлатежа = Новый Массив; 
			Для каждого Запись Из РеквизитыПозиций Цикл
				ТекстНазначение = Запись.НазначениеПлатежа;
				Если ПустаяСтрока(ТекстНазначение) И ЗначениеЗаполнено(ТекущийОбъект.БанковскийСчетКонтрагента) Тогда
					ТекстНазначение = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьРеквизитыБанковскогоСчета(
											ТекущийОбъект.БанковскийСчетКонтрагента).ТекстНазначения;
				КонецЕсли;
				Если ЗначениеЗаполнено(ТекстНазначение) Тогда
					ЧастиТекста = ЧастиТекстаНазначениеПлатежа(ТекстНазначение);
					НазначениеПлатежа.Добавить(ЧастиТекста.Назначение);
				КонецЕсли;
			КонецЦикла; 
			НазначениеПлатежа = ОбщегоНазначенияКлиентСервер.СвернутьМассив(НазначениеПлатежа);
			ТекущийОбъект.НазначениеПлатежа = СтрСоединить(НазначениеПлатежа, ", ");	
		Иначе
			ТекстНазначение = РеквизитыПозиций[0].НазначениеПлатежа;	
			Если ПустаяСтрока(ТекстНазначение) И ЗначениеЗаполнено(ТекущийОбъект.БанковскийСчетКонтрагента) Тогда
				ТекстНазначение = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьРеквизитыБанковскогоСчета(
				ТекущийОбъект.БанковскийСчетКонтрагента).ТекстНазначения;
			КонецЕсли;
			ЧастиТекста = ЧастиТекстаНазначениеПлатежа(ТекстНазначение);
			ТекущийОбъект.НазначениеПлатежа = ЧастиТекста.Назначение;
		КонецЕсли; 
	КонецЕсли; 
	
	РеквизитыПозиции = ЗначениеРеквизитовПозиции(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(РеквизитыПозиций[0]));
	ОпределитьСтатьюДДС(ТекущийОбъект, РеквизитыПозиции, ВидОперации);
	
	ИспользоватьПодразделения = ПолучитьФункциональнуюОпцию("ИспользоватьПодразделения");
	Если ЕстьПодразделение И ИспользоватьПодразделения Тогда
		ТекущийОбъект.Подразделение = РеквизитыПозиций[0].Подразделение;
	КонецЕсли;
	
	ТекущийОбъект.Организация = РеквизитыОснования.Организация;
	ТекущийОбъект.Контрагент  = РеквизитыОснования.Контрагент;
	
	Если ЕстьТипПлатежногоДокумента Тогда
		ТекущийОбъект.ТипПлатежногоДокумента = Перечисления.ТипыПлатежныхДокументов.ПлатежноеПоручение;		
	КонецЕсли;
	
	//Шапку документа из первой позиции.
	ПлатежнаяПозиция = РеквизитыПозиций[0];
	
	ТекущийОбъект.Валюта = ПлатежнаяПозиция.ВалютаДенежныхСредств;
	
	Дополнительно = Новый Структура;
	Дополнительно.Вставить("ЕстьПодразделение", 		ЕстьПодразделение);
	Дополнительно.Вставить("ИспользоватьПодразделения", ИспользоватьПодразделения);
	Дополнительно.Вставить("ВалютаРеглУчета", 	 		ВалютаРеглУчета);
	
	ПодготовитьРасшифровкуПлатежа(РеквизитыПозиций, СуммыКОплате, ТекущийОбъект, Дополнительно);
	
	ТекущийОбъект.СуммаДокумента = ТекущийОбъект.РасшифровкаПлатежа.Итог("Сумма");
	
	ТекущийОбъект.СуммаДокумента = ТекущийОбъект.РасшифровкаПлатежа.Итог("Сумма");
	
	Если НЕ ЕстьРасшифровкаПлатежа Тогда
		ТекущийОбъект.РасшифровкаПлатежа.Очистить();
	КонецЕсли;
	
	Если ЕстьНазначениеПлатежа И ЕстьРасшифровкаПлатежа Тогда
		ТекстСумма 	  = СтрШаблон(НСтр("ru = 'Сумма %1'; en = 'Amount %1'") , 
		Формат(ТекущийОбъект.СуммаДокумента, "ЧДЦ=2; ЧРД=-; ЧН=0-00; ЧГ="));
		ТекстСуммаНДС = ДенежныеСредстваСервер.ТекстСуммаНДСПлатежа(ТекущийОбъект.Организация, ТекущийОбъект.Валюта, ТекущийОбъект.РасшифровкаПлатежа, Истина);
		ТекущийОбъект.НазначениеПлатежа = ТекущийОбъект.НазначениеПлатежа + Символы.ПС + ТекстСумма + Символы.ПС + ТекстСуммаНДС;
	КонецЕсли; 
	
	// Если сумма по всем позициям этого документа нулевая то не открываем форму.
	РезультатФормирования.ОткрытьФорму = ТекущийОбъект.СуммаДокумента <> 0;
	
	РежимСообщений = "Ошибки";		
	
	Если ТекущийОбъект.СуммаДокумента = 0 Тогда
		Успешно = Ложь;
	Иначе	
		Успешно = бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ТекущийОбъект, РежимЗаписиДокумента.Запись,, РежимСообщений);		
	КонецЕсли;
	
	Если Успешно Тогда
		
		Документы.бит_ОтражениеФактаДДС.ЗаполнитьОтражениеФактаПоДокументамПланирования(ТекущийОбъект, СуммыКОплате.Позиции, СценарийФакт);
		
		Для каждого Позиция Из СуммыКОплате.Позиции Цикл
			НоваяСтрока = Результат.Добавить(); 			
			НоваяСтрока.Позиция = Позиция;
			НоваяСтрока.ДокументОплаты = ТекущийОбъект.Ссылка;
		КонецЦикла;
		
		Если РежимЗаписиПлатДокумента = РежимЗаписиДокумента.Проведение
			И бит_Казначейство.ПроверитьЗаполнениеПлатежногоДокумента(ТекущийОбъект, РежимЗаписиПлатДокумента, Ложь) Тогда 				
			бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ТекущийОбъект, РежимЗаписиДокумента.Проведение);			
		КонецЕсли; 
	КонецЕсли; 

КонецПроцедуры

Процедура ПодготовитьРасшифровкуПлатежа(ДанныеПозиций, СуммыКОплате, ТекущийОбъект, Дополнительно)
	
	ЕстьПодразделение		  = Дополнительно.ЕстьПодразделение;
	ИспользоватьПодразделения = Дополнительно.ИспользоватьПодразделения;
	ВалютаРеглУчета			  = Дополнительно.ВалютаРеглУчета;

	ДатаДокумента = ТекущийОбъект.Дата;
	ВидОперации   = ТекущийОбъект.ХозяйственнаяОперация;
	
	РасшифровкаПлатежа = ТекущийОбъект.РасшифровкаПлатежа.Выгрузить();
	РасшифровкаПлатежа.Колонки.Добавить("Позиция");
	
	Для каждого ПлатежнаяПозиция Из ДанныеПозиций Цикл
		
		ОбъектРасчетов = ?(ЗначениеЗаполнено(ПлатежнаяПозиция.ОбъектРасчетов), ПлатежнаяПозиция.ОбъектРасчетов, ПлатежнаяПозиция.Договор);
		СуммаКОплате   = СуммыКОплате.Позиции.Найти(ПлатежнаяПозиция.Ссылка, "Позиция").Сумма;
		
		Если ПлатежнаяПозиция.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
			
			Коэффициенты = бит_Казначейство.ПолучитьКоэффициентыПересчетаВалюты(ПлатежнаяПозиция.ВалютаДокумента,
							ПлатежнаяПозиция.ВалютаВзаиморасчетов, ДатаДокумента, ПлатежнаяПозиция.Организация,,, ОбъектРасчетов);
			
			Сумма				= СуммаКОплате;
			СуммаВзаиморасчетов = Сумма * Коэффициенты.КоэффициентПересчетаВВалютуВзаиморасчетов;
			СуммаНДС			= ПлатежнаяПозиция.СуммаНДС;
		Иначе
			
			Коэффициенты = бит_Казначейство.ПолучитьКоэффициентыПересчетаВалюты(ПлатежнаяПозиция.ВалютаДокумента,
							ПлатежнаяПозиция.ВалютаДенежныхСредств, ДатаДокумента, ПлатежнаяПозиция.Организация,,, ОбъектРасчетов);
			
			СуммаВзаиморасчетов = СуммаКОплате;
			Сумма				= СуммаВзаиморасчетов * Коэффициенты.КоэффициентПересчетаВВалютуВзаиморасчетов;
			СуммаНДС			= РасчитатьСуммуНДС(Сумма, ПлатежнаяПозиция.СтавкаНДС);					
		КонецЕсли;
				
		НоваяСтрока = РасшифровкаПлатежа.Добавить();
		
		НоваяСтрока.ВалютаВзаиморасчетов 		  = ПлатежнаяПозиция.ВалютаВзаиморасчетов;
		НоваяСтрока.СуммаВзаиморасчетов  		  = СуммаВзаиморасчетов;
		НоваяСтрока.Сумма 						  = Сумма;
		
		НоваяСтрока.СтавкаНДС = ПлатежнаяПозиция.СтавкаНДС;
		НоваяСтрока.СуммаНДС  = СуммаНДС;
				
		РеквизитыПозиции = ЗначениеРеквизитовПозиции(ПлатежнаяПозиция.Ссылка);
		ОпределитьСтатьюДДС(НоваяСтрока, РеквизитыПозиции, ВидОперации);
		
		Если ЕстьПодразделение И ИспользоватьПодразделения Тогда
			НоваяСтрока.Подразделение = ПлатежнаяПозиция.Подразделение;
		КонецЕсли;
		
		НоваяСтрока.ДоговорКредитаДепозита	 = ПлатежнаяПозиция.ДоговорКредитаДепозита;
		// ++ NB  НоваяСтрока.ДоговорАренды 			 = ПлатежнаяПозиция.ДоговорАренды;
		НоваяСтрока.ОбъектРасчетов 			 = ПлатежнаяПозиция.ОбъектРасчетов;
		НоваяСтрока.ОснованиеПлатежа     	 = ПлатежнаяПозиция.ОснованиеПлатежа;
		НоваяСтрока.Организация				 = ПлатежнаяПозиция.Организация;
		НоваяСтрока.Партнер 				 = ДенежныеСредстваСервер.ПолучитьПартнераПоКонтрагенту(
													ПлатежнаяПозиция.Контрагент, ТекущийОбъект.ХозяйственнаяОперация);
															
		Если ЗначениеЗаполнено(НоваяСтрока.ДоговорАренды) Тогда
			РеквизитыДоговораАренды = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(НоваяСтрока.ДоговорАренды, 
										"СтатьяДвиженияДенежныхСредств");
			НоваяСтрока.СтатьяДвиженияДенежныхСредств = РеквизитыДоговораАренды.СтатьяДвиженияДенежныхСредств;
			НоваяСтрока.ТипПлатежаПоАренде			  = Перечисления.ТипыПлатежейПоАренде.УслугаПоАренде;
		КонецЕсли;
		
		КурсИКратность = ДенежныеСредстваСервер.КурсЧислительИКурсЗнаменательВзаиморасчетов(
							ТекущийОбъект.Валюта, НоваяСтрока.ВалютаВзаиморасчетов, ВалютаРеглУчета, 
							ТекущийОбъект.Дата, НоваяСтрока.ОбъектРасчетов, ПлатежнаяПозиция.Договор);
			
		НоваяСтрока.КурсЧислительВзаиморасчетов   = КурсИКратность.КурсЧислитель;
		НоваяСтрока.КурсЗнаменательВзаиморасчетов = КурсИКратность.КурсЗнаменатель;
		
		НоваяСтрока.Позиция = ПлатежнаяПозиция.Ссылка;
	КонецЦикла;

	КолонкиГруппировок = ГруппировкиДляРасшифровкиПлатежа();
	КолонкиРесурсов	   = "СуммаВзаиморасчетов, Сумма, СуммаНДС";
	
	ИтоговаяРасшифровкаПлатежа = РасшифровкаПлатежа.Скопировать();
	ИтоговаяРасшифровкаПлатежа.ЗаполнитьЗначения(0, "СуммаВзаиморасчетов");
	ИтоговаяРасшифровкаПлатежа.ЗаполнитьЗначения(0, "Сумма");
	ИтоговаяРасшифровкаПлатежа.ЗаполнитьЗначения(0, "СуммаНДС");
	
	ИтоговаяРасшифровкаПлатежа.Свернуть(СтрСоединить(КолонкиГруппировок, ",") + ", ИдентификаторСтроки", КолонкиРесурсов);
	
	Для каждого СтрокаТаблицы Из ИтоговаяРасшифровкаПлатежа Цикл
		
		ПараметрыПоиска = Новый Структура(СтрСоединить(КолонкиГруппировок, ","));
		ЗаполнитьЗначенияСвойств(ПараметрыПоиска, СтрокаТаблицы);
		РезультатПоиска  = РасшифровкаПлатежа.НайтиСтроки(ПараметрыПоиска);
		
		СвязанныеПозиции = Новый Массив;
		Для каждого Запись Из РезультатПоиска Цикл
			СтрокаТаблицы.СуммаВзаиморасчетов = СтрокаТаблицы.СуммаВзаиморасчетов + Запись.СуммаВзаиморасчетов;
			СтрокаТаблицы.Сумма				  = СтрокаТаблицы.Сумма + Запись.Сумма;
			СтрокаТаблицы.СуммаНДС			  = СтрокаТаблицы.СуммаНДС + Запись.СуммаНДС;
			СвязанныеПозиции.Добавить(Запись.Позиция);
		КонецЦикла;
		СтрокаТаблицы.ИдентификаторСтроки = Новый УникальныйИдентификатор();
		Для каждого Позиция Из СвязанныеПозиции Цикл
			РезультатПоискаПозиций = СуммыКОплате.Позиции.Найти(Позиция, "Позиция");
			РезультатПоискаПозиций.ИдентификаторСтроки = СтрокаТаблицы.ИдентификаторСтроки;
		КонецЦикла;
	КонецЦикла;
	
	ТекущийОбъект.РасшифровкаПлатежа.Загрузить(ИтоговаяРасшифровкаПлатежа);

КонецПроцедуры

