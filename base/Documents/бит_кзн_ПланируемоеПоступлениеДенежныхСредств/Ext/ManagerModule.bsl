	Группировки = Новый Массив;
	Группировки.Добавить("ВалютаВзаиморасчетов");
	Группировки.Добавить("СтавкаНДС");
	Группировки.Добавить("ДоговорЗаймаСотруднику");
	Группировки.Добавить("СтатьяДоходов");
	Группировки.Добавить("АналитикаДоходов");
	Группировки.Добавить("АналитикаАктивовПассивов");
	Группировки.Добавить("ОбъектРасчетов");
	Группировки.Добавить("Партнер");
	Группировки.Добавить("Подразделение");
	Группировки.Добавить("ТипСуммыКредитаДепозита");
	Группировки.Добавить("ДоговорАренды");
	Группировки.Добавить("ТипПлатежаПоАренде");
	
	Группировки.Добавить("СтатьяДвиженияДенежныхСредств");
	Группировки.Добавить("КурсЧислительВзаиморасчетов");
	Группировки.Добавить("КурсЗнаменательВзаиморасчетов");
	
	Возврат Группировки;
	
КонецФункции

// Функция получает плановую и фактическую сумму оплат по поступлению.
//
// Параметры:
//  Заявка			  - ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств, Массив.
//  ПлатежныйДокумент - Платежный документ ссылка. По умолчанию Неопределено.
//
// Возвращаемое значение:
//   РезСтруктура 
//		- 1. Структура 	- Заявка - ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.
// 		- 2. Соответствие - Заявка - Массив.
//
Функция ПолучитьОплатыПоПоступлению(Заявка, ПлатежныйДокумент = Неопределено) Экспорт

	УказанМассивЗаявок = ?(ТипЗнч(Заявка) = Тип("Массив"), Истина, Ложь);
	
	Если УказанМассивЗаявок Тогда
		МассивЗаявок = Заявка;
	Иначе
		
		МассивЗаявок = Новый Массив;
		МассивЗаявок.Добавить(Заявка);
		
	КонецЕсли;
	
	РезСтруктураШаблон = Новый Структура;
	РезСтруктураШаблон.Вставить("СуммаПлан"				, 0);
	РезСтруктураШаблон.Вставить("СуммаОплата"			, 0);
	РезСтруктураШаблон.Вставить("СуммаЗакрыта"			, 0);
	РезСтруктураШаблон.Вставить("Разность"				, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаПлан"	, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаОплата"	, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаЗакрыта"	, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаРазность", 0);
	
	СтрОплата = РезСтруктураШаблон;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Заявка", Заявка);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ЕСТЬNULL(ПлПоступлениеДенежныхСредств.СуммаКонечныйОстаток, 0) КАК СуммаОстаток,
	               |	ЕСТЬNULL(ПлПоступлениеДенежныхСредств.СуммаПриход, 0) КАК СуммаПлан,
	               |	ЕСТЬNULL(ПлПоступлениеДенежныхСредств.СуммаРасход, 0) КАК СуммаФакт
	               |ИЗ
	               |	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ОстаткиИОбороты(, , , , ДокументПланирования В (&Заявка)) КАК ПлПоступлениеДенежныхСредств";

	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		СтрОплата.СуммаПлан    			= Выборка.СуммаПлан;
		СтрОплата.СуммаОплата    		= Выборка.СуммаФакт;
		СтрОплата.Разность 				= Выборка.СуммаОстаток;
		СтрОплата.СуммаДокументаПлан    = Выборка.СуммаПлан;
		СтрОплата.СуммаДокументаОплата  = Выборка.СуммаФакт;
		СтрОплата.СуммаДокументаРазность = Выборка.СуммаОстаток;
		
	КонецЕсли; 

	Возврат СтрОплата;
	
КонецФункции // ПолучитьОплатыПоПоступлению()

// Функция определяет новый статус объекта в зависимости от режима записи документа
//и предыдущего статуса. Механизм определения статусов может быть переопределен алгоритмами.
//
// Параметры:
//  ТекущийОбъект - ДокументОбъект.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.
//  ПараметрыУстановкиСтатуса - Структура - состав полей см. в функции бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса.
//
// Возвращаемое значение:
//   НовыйСтатус - СправочникСсылка.бит_СтатусыОбъектов.
//
Функция НовыйСтатусОбъекта(ТекущийОбъект, ПараметрыУстановкиСтатуса) Экспорт
	
	Если ПараметрыУстановкиСтатуса.ПараметрыОплаты = Неопределено Тогда
		СтруктураОплаты = Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ПолучитьОстаток(ТекущийОбъект.Ссылка);
	Иначе
		СтруктураОплаты = ПараметрыУстановкиСтатуса.ПараметрыОплаты;
	КонецЕсли;
	
	Если СтруктураОплаты.Остаток <= 0.01 И СтруктураОплаты.Факт > 0 Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Оплачен;
	ИначеЕсли СтруктураОплаты.Факт > 0 Тогда
		Возврат Справочники.бит_СтатусыОбъектов.ЧастичноОплачен;
	КонецЕсли;
	
	Возврат бит_ВизированиеСервер.НовыйСтатусПоСтандартномуАлгоритму(ТекущийОбъект, ПараметрыУстановкиСтатуса);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Функция получает неоплаченный остаток по планируемому поступлению.
//
// Параметры:
//   Позиция - ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств
//
// Возвращаемое значение:
//  СтрОплата - Структура.
//
Функция ПолучитьОстаток(ДокументПланирования) Экспорт

	СтрОплата = Новый Структура("План, Факт, Остаток",0, 0, 0);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидПлана"            , ДокументПланирования.ВидПлана);
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументПланирования);
	Запрос.УстановитьПараметр("Организация"         , ДокументПланирования.Организация);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(ОстаткиПланируемыхПоступлений.СуммаКонечныйОстаток, 0) КАК СуммаОстаток,
	|	ЕСТЬNULL(ОстаткиПланируемыхПоступлений.СуммаПриход, 0) КАК СуммаПлан,
	|	ЕСТЬNULL(ОстаткиПланируемыхПоступлений.СуммаРасход, 0) КАК СуммаФакт
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ОстаткиИОбороты(
	|			,
	|			,
	|			,
	|			,
	|			ВидПлана = &ВидПлана
	|				И ДокументПланирования = &ДокументПланирования
	|				И Организация = &Организация) КАК ОстаткиПланируемыхПоступлений";

	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		СтрОплата.План    = Выборка.СуммаПлан;
		СтрОплата.Факт    = Выборка.СуммаФакт;
		СтрОплата.Остаток = Выборка.СуммаОстаток;
	
	КонецЕсли; 

	Возврат СтрОплата;
	
КонецФункции // ПолучитьОстаток()

Процедура ОпределитьСтатьюДДС(ДанныеЗаполнения, РеквизитыПозиции, ВидОперации)

	ДоговорКонтрагента = РеквизитыПозиции.ДоговорКонтрагента;
	Если ЗначениеЗаполнено(ДоговорКонтрагента) Тогда
		СтатьяДДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДоговорКонтрагента, "СтатьяДвиженияДенежныхСредств");
		Если ЗначениеЗаполнено(СтатьяДДС) Тогда
			ДанныеЗаполнения.СтатьяДвиженияДенежныхСредств = СтатьяДДС;
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	СтатьяОборотов = РеквизитыПозиции.СтатьяОборотов;
	Если ЗначениеЗаполнено(СтатьяОборотов) Тогда
		СтатьяДДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтатьяОборотов, "ОсновнаяСтатьяДДС");
		Если ЗначениеЗаполнено(СтатьяДДС) Тогда
			ДанныеЗаполнения.СтатьяДвиженияДенежныхСредств = СтатьяДДС;
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	СтатьиДДС = РегистрыСведений.бит_СоответствияАналитик.ПолучитьЛевуюАналитику(
						ПредопределенноеЗначение("Справочник.бит_ВидыСоответствийАналитик.СтатьиДДС_СтатьиОборотов"),
						СтатьяОборотов, ТекущаяДатаСеанса());

	Если ЗначениеЗаполнено(СтатьиДДС) Тогда
		ДанныеЗаполнения.СтатьяДвиженияДенежныхСредств = СтатьиДДС[0];
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(ДанныеЗаполнения.СтатьяДвиженияДенежныхСредств) Тогда
		Кандидат = Справочники.СтатьиДвиженияДенежныхСредств.СтатьяДвиженияДенежныхСредствПоХозяйственнойОперации(ВидОперации);
		
		Если ЗначениеЗаполнено(Кандидат) Тогда
			ДанныеЗаполнения.СтатьяДвиженияДенежныхСредств = Кандидат;
		КонецЕсли;	
	КонецЕсли; 

КонецПроцедуры

Функция ЗначениеРеквизитовПозиции(Позиция)
	
	Если ТипЗнч(Позиция) = Тип("Структура") Тогда
		ДокументПозиции = Позиция.Позиция;
	Иначе
		ДокументПозиции = Позиция;
	КонецЕсли;
	
	РеквизитыПозиции = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументПозиции, "СтатьяОборотов, ЦФО, ОбъектРасчетов");
	
	ОбъектРасчетов = РеквизитыПозиции.ОбъектРасчетов;
	
	ДоговорКонтрагента = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	Если ТипЗнч(ОбъектРасчетов) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		ДоговорКонтрагента = ОбъектРасчетов;
	ИначеЕсли ЗначениеЗаполнено(ОбъектРасчетов) Тогда
		МетаданныеОбъектаРасчетов = ОбъектРасчетов.Метаданные();
		Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ДоговорКонтрагента", МетаданныеОбъектаРасчетов) Тогда
			ДоговорКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектРасчетов, "ДоговорКонтрагента");
		ИначеЕсли ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор", МетаданныеОбъектаРасчетов) Тогда
			ДоговорКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектРасчетов, "Договор");
		КонецЕсли;
	КонецЕсли;
	РеквизитыПозиции.Вставить("ДоговорКонтрагента", ДоговорКонтрагента);
	
	Возврат РеквизитыПозиции;
	
КонецФункции

Процедура ОпределитьПодразделение(ДанныеЗаполнения, Позиция)

	Подразделение = Документы.бит_кзн_ПлатежнаяПозиция.ПодразделениеДополнительныеИзмерения(Позиция);
	Если ЗначениеЗаполнено(Подразделение) Тогда
		ДанныеЗаполнения.Подразделение = Подразделение;
		Возврат;
	КонецЕсли;
	
	СтатьиДДС = РегистрыСведений.бит_СоответствияАналитик.ПолучитьЛевуюАналитику(
						ПредопределенноеЗначение("Справочник.бит_ВидыСоответствийАналитик.СтруктураПредприятия_ЦФО"), 
						Позиция.ЦФО, ТекущаяДатаСеанса());
																
	Если ЗначениеЗаполнено(СтатьиДДС) Тогда
		ДанныеЗаполнения.Подразделение = СтатьиДДС[0];
	КонецЕсли;
		
КонецПроцедуры

Функция ЧастиТекстаНазначениеПлатежа(НазначениеПлатежа)
	
	ТекстНазначение = "";
	ТекстСуммы		= "";
	
	Если НЕ ПустаяСтрока(НазначениеПлатежа) Тогда
		// Решено для экспремента отказаться от поиска слова "сумма" потому, что
		// назначение платежа, введенное руками начинают с этого слова.
		// ПозицияСумма = СтрНайти(НазначениеПлатежа, "Сумма");
		ПозицияСумма = 0;
		
		Если ПозицияСумма = 0 Тогда // для совместимости, при редактировании старых платежек
			ПозицияСумма = СтрНайти(НазначениеПлатежа, "В т.ч. НДС");
			Если ПозицияСумма = 0 Тогда
				ПозицияСумма = СтрНайти(НазначениеПлатежа, "Без налога (НДС)");
			КонецЕсли;
			Если ПозицияСумма = 0 Тогда
				ПозицияСумма = СтрНайти(НазначениеПлатежа, "НДС не облагается");
			КонецЕсли;
		КонецЕсли;
		
		ТекстНазначение = ?(ПозицияСумма = 0, НазначениеПлатежа, Лев(НазначениеПлатежа, ПозицияСумма - 1));
		Если Прав(ТекстНазначение, 1) = Символы.ПС Тогда
			ТекстНазначение = Лев(ТекстНазначение, СтрДлина(ТекстНазначение) - 1);
		КонецЕсли;
		ТекстСуммы = СтрЗаменить(НазначениеПлатежа, ТекстНазначение, "");
		Если Лев(ТекстСуммы, 1) = Символы.ПС Тогда
			ТекстСуммы = Сред(ТекстСуммы, 2);
		КонецЕсли;
	КонецЕсли;

	ЧастиТекста = Новый Структура; 
	ЧастиТекста.Вставить("Назначение", ТекстНазначение);
	ЧастиТекста.Вставить("Суммы", ТекстСуммы);
	
	Возврат ЧастиТекста;

КонецФункции

Функция РасчитатьСуммуНДС(Сумма, СтавкаНДС)

	ЗначениеСтавки = бит_БухгалтерскийУчет.ПолучитьСтавкуНДС(СтавкаНДС);
	СуммаНДС 	   = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(Сумма,
							Истина, Истина, ЗначениеСтавки);
	Возврат СуммаНДС;
	
КонецФункции
																	
#КонецОбласти

#КонецЕсли
