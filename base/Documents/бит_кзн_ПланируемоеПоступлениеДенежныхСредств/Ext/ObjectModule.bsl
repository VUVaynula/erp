#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ПрограммныйИнтерфейс

// Заполняет наборы значений доступа.
// Параметры:
//  Таблица - ТаблицаЗначений - передает в этот параметр подготовленные наборы значений
//            доступа. Описание колонок см. в функции УправлениеДоступом.ТаблицаНаборыЗначенийДоступа.
//
Процедура ЗаполнитьНаборыЗначенийДоступа(Таблица) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	ДобавитьСтрокуВНаборЗначенийДоступа(Организация, Таблица);
	ДобавитьСтрокуВНаборЗначенийДоступа(Ответственный, Таблица);
	
	ТаблицаДанных = бит_УправлениеДоступомБФСлужебный.ДанныеПозицийПоЗаявке(Ссылка);
	
	Для каждого СтрокаТаблицы Из ТаблицаДанных Цикл
		КлючДоступаЦФОСтатьяОборотов = Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.КлючиЦФОСтатьяОборотовДокумента(
			СтрокаТаблицы.ЦФО, СтрокаТаблицы.СтатьяОборотов);
		ДобавитьСтрокуВНаборЗначенийДоступа(КлючДоступаЦФОСтатьяОборотов, Таблица);
	КонецЦикла; 
			
	// Удалим дубли
	ПоляГруппировки = "";
	Для каждого Колонка Из Таблица.Колонки Цикл
		ПоляГруппировки = "," + Колонка.Имя + ПоляГруппировки;
	КонецЦикла; 
	
	ПоляГруппировки = Сред(ПоляГруппировки, 2);
	Таблица.Свернуть(ПоляГруппировки);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	Если ТипДанныхЗаполнения = Тип("Структура") Тогда
		бит_ОбщегоНазначения.ЗаполнитьПоСтруктуре(ЭтотОбъект, ДанныеЗаполнения);
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств") Тогда
		ЗаполнитьНаОснованииПланируемогоПоступленияДенежныхСредств(ДанныеЗаполнения);
	КонецЕсли;
	
	ИнициализироватьДокумент();
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	ОтправленНаСогласование = Ложь;
	Ответственный 			= Пользователи.ТекущийПользователь();
	Дата					= ТекущаяДатаСеанса();
		
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли; 
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	
	бит_ОбщегоНазначенияПереопределяемый.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	ДополнительныеСвойства.Вставить("УстановкаПометкиУдаления", ПометкаУдаления <> Ссылка.ПометкаУдаления);

КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли; 
	
	РежимЗаписи = ДополнительныеСвойства.РежимЗаписи;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение 
		ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		ПроверитьПравоПроведения(Отказ);
	КонецЕсли; 
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
	
	ВыполнитьСинхронизацию(Отказ);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	ПроверитьПравоПроведения(Отказ);
	
	ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(Ссылка);
	бит_Казначейство.ПроверитьВозможностьПроведения(Ссылка, ТекущийСтатус, Отказ);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ДокументОснование)
		И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств") Тогда
	
		ДокПрогноз = ДокументОснование.ПолучитьОбъект();
		бит_ВизированиеСервер.УстановитьСтатус(ДокПрогноз);
		
	КонецЕсли; 
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ПроверитьПравоПроведения(Отказ);
	
	ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(Ссылка);
	бит_Казначейство.ПроверитьВозможностьПроведения(Ссылка, ТекущийСтатус, Отказ);

КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	бит_НастройкиДоступностиЭлементовФорм.ЗаполнитьПроверяемыеРеквизиты(ЭтотОбъект, ПроверяемыеРеквизиты);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ИнициализацияИЗаполнение

Процедура ЗаполнитьНаОснованииПланируемогоПоступленияДенежныхСредств(Основание)

	МетаОснование = Основание.Метаданные();
	
	Если МетаОснование.Имя = "бит_кзн_ПланируемоеПоступлениеДенежныхСредств" Тогда
		
		 Исключения = "Дата,Номер,Проведен,ПометкаУдаления,ДокументОснование,ВидПлана,ОтправленНаСогласование";
		 ЗаполнитьЗначенияСвойств(ЭтотОбъект, Основание,,Исключения);
		 ЭтотОбъект.ДокументОснование = Основание.Ссылка;
	
	КонецЕсли; 

КонецПроцедуры

Процедура ИнициализироватьДокумент()
	
	Если НЕ ЗначениеЗаполнено(Дата) Тогда
		Дата = ТекущаяДатаСеанса();
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(ВидПлана) Тогда
		ВидПлана = Перечисления.бит_кзн_ВидыПланов.План;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ФормаОплаты) Тогда
		ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		Организация = ЗначениеНастроекПовтИсп.ПолучитьОрганизациюПоУмолчанию(Организация);
	КонецЕсли;
	
	Ответственный = Пользователи.ТекущийПользователь();
	
	Инициатор = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
					ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнойИнициаторКазначейства);
	
	Если НЕ ЗначениеЗаполнено(Инициатор) Тогда
		Инициатор = Ответственный;
	КонецЕсли;
			
КонецПроцедуры	

#КонецОбласти

Процедура ДобавитьСтрокуВНаборЗначенийДоступа(ЗначениеДоступа, Таблица)
	
	СтрокаТаб = Таблица.Добавить();
	СтрокаТаб.ЗначениеДоступа = ЗначениеДоступа;

КонецПроцедуры

// Процедура выполняет синхронизацию планируемого поступления и позиций поступления. 
//
Процедура ВыполнитьСинхронизацию(Отказ)

	Синхронизировать = Истина;
	Если ДополнительныеСвойства.Свойство("НеСинхронизировать") 
		 И ДополнительныеСвойства.НеСинхронизировать = Истина Тогда
	     Возврат;
	КонецЕсли; 	
	
	БезПомеченныхНаУдаление = Истина;
	Если ДополнительныеСвойства.УстановкаПометкиУдаления Тогда
		БезПомеченныхНаУдаление = Ложь;	
	ИначеЕсли ПометкаУдаления Тогда	
		БезПомеченныхНаУдаление = Ложь;
	КонецЕсли;

	РезультатПоиска = Документы.бит_кзн_ПозицияПоступления.НайтиПозициюПоОснованию(Ссылка, БезПомеченныхНаУдаление);
	
	ИменаРеквизитов 	  = Документы.бит_кзн_ПозицияПоступления.СинхронизируемыйРеквизиты();
	НастройкиДопИзмерений = бит_МеханизмДопИзмерений.ПолучитьНастройкиДополнительныхИзмерений();
	СовпадающиеАналитики  = Документы.бит_кзн_ПозицияПоступления.НайтиАналитикиСовпадающиеСРеквизитами(
								Метаданные.Документы.бит_кзн_ПозицияПоступления);
	
	Для каждого Позиция Из РезультатПоиска.МассивПозиций Цикл

		ПозицияОбъект = Позиция.ПолучитьОбъект();
		
		// Признак того, что дальнейшая синхронизация не нужна, необходимо, чтобы не было циклических синхронизаций.
		ПозицияОбъект.ДополнительныеСвойства.Вставить("НеСинхронизировать", Истина);
		
		// синхронизация пометки удаления
		Если ПометкаУдаления <> ПозицияОбъект.ПометкаУдаления Тогда
			ПозицияОбъект.УстановитьПометкуУдаления(ПометкаУдаления);
		КонецЕсли; 
		
		ТекущаяВалютаДокумента 		= ПозицияОбъект.ВалютаДокумента;
		ТекущаяВалютаВзаиморасчетов = ПозицияОбъект.ВалютаВзаиморасчетов;
		ТекущееПланированиеСуммы	= ПозицияОбъект.ПланированиеСуммы;

		Для каждого Имя Из ИменаРеквизитов Цикл
			
			Если ЭтотОбъект[Имя] <> ПозицияОбъект[Имя] Тогда
				
				ПозицияОбъект[Имя] = ЭтотОбъект[Имя];			
				ЕстьИзменения = Истина;
				
				Если Врег(Имя) = ВРег("Организация") Тогда
					ПозицияОбъект.БанковскийСчет 		  = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
					ПозицияОбъект.Касса			 		  = Справочники.Кассы.ПустаяСсылка();
					ПозицияОбъект.ОбъектРасчетов		  = Неопределено;
					ПозицияОбъект.ОснованиеПлатежа		  = Неопределено;
					ПозицияОбъект.ДоговорКредитаДепозита  = Неопределено;
					ПозицияОбъект.Договор 				  = Неопределено;
				ИначеЕсли Врег(Имя) = ВРег("Контрагент") Тогда
					ПозицияОбъект.ОбъектРасчетов 		   = Неопределено;
					ПозицияОбъект.ОснованиеПлатежа		   = Неопределено;
					ПозицияОбъект.ДоговорКредитаДепозита   = Неопределено;
					ПозицияОбъект.Договор 				   = Неопределено;	
				КонецЕсли; 
				
				// Сихронизируем совпадающие аналитики.
				Для каждого Соотв Из СовпадающиеАналитики Цикл
					Если Соотв.Значение = Имя Тогда
						ТекущаяНастройка = НастройкиДопИзмерений[Соотв.Ключ];
						Если ТекущаяНастройка <> Неопределено И ЗначениеЗаполнено(ПозицияОбъект[Соотв.Ключ])
							И НЕ ТекущаяНастройка.Предопределенная Тогда
							Продолжить;
						КонецЕсли;
						ПозицияОбъект[Соотв.Ключ] = ЭтотОбъект[Имя];
					КонецЕсли; 
				КонецЦикла; 
			КонецЕсли; 
		КонецЦикла; 
		
		Если ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов Тогда			
			ПозицияОбъект.ВалютаВзаиморасчетов 			 = ВалютаДокумента;
			ПозицияОбъект.ВалютаДокумента	   			 = ВалютаДокумента; 
			ПозицияОбъект.КурсЧислительВзаиморасчетов 	 = 1;
			ПозицияОбъект.КурсЗнаменательВзаиморасчетов  = 1;
			ПозицияОбъект.СуммаДокумента 				 = ПозицияОбъект.СуммаВзаиморасчетов;
		КонецЕсли;
				
		Если ТекущаяВалютаДокумента <> ПозицияОбъект.ВалютаДокумента 
			И ПозицияОбъект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
			
			ПозицияОбъект.БанковскийСчет = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
			ПозицияОбъект.Касса 		 = Справочники.Кассы.ПустаяСсылка();
		КонецЕсли;
		
		Если ТекущаяВалютаВзаиморасчетов <> ПозицияОбъект.ВалютаВзаиморасчетов Тогда
			ПозицияОбъект.ОбъектРасчетов		  = Неопределено;
			ПозицияОбъект.ОснованиеПлатежа		  = Неопределено;
			ПозицияОбъект.ДоговорКредитаДепозита  = Неопределено;
			ПозицияОбъект.Договор 				  = Неопределено;
		КонецЕсли;
				
		Если Проведен И НЕ ПозицияОбъект.Проведен Тогда
			Если ПозицияОбъект.ПроверитьЗаполнение() Тогда					
				Выполнено = бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ПозицияОбъект, 
					РежимЗаписиДокумента.Проведение, "", "Ошибки");	
				Если НЕ Выполнено Тогда
					Отказ = Истина;
				КонецЕсли;	
			Иначе					
				ВызватьИсключение СтрШаблон(НСтр("ru = 'Не удалось записать %1. Документ заполнен с ошибками.'"), Позиция);
			КонецЕсли; 
		ИначеЕсли НЕ Проведен И ПозицияОбъект.Проведен Тогда 
			бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ПозицияОбъект, РежимЗаписиДокумента.ОтменаПроведения, "", "Ошибки");
		Иначе
			ПозицияОбъект.Записать(РежимЗаписиДокумента.Запись);			
		КонецЕсли;
		
		Если Отказ Тогда
			Прервать;		
		КонецЕсли;
	КонецЦикла; 

КонецПроцедуры

// Проверка наличия у пользователя права проводить заявки
//
// Параметры:
//  Отказ - Булево.
//
Процедура ПроверитьПравоПроведения(Отказ)
	
	ТекПользователь = Пользователи.ТекущийПользователь();
	флРазрешеноПроводить = бит_ПраваДоступа.ПолучитьЗначениеДопПраваПользователя(ТекПользователь, 
		ПланыВидовХарактеристик.бит_ДополнительныеПраваПользователей.РазрешеноПроводитьПланируемыеПоступленияДС);
	
	Если НЕ флРазрешеноПроводить Тогда		
		ТекстСообщения = НСтр("ru='У пользователя отсутствует дополнительное право на проведение планируемых поступлений ДС.';
							  |en='The user has no right to conduct additional DS planned revenues.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Отказ = Истина;		
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли