#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	Результат = СоздатьПлатежныеДокументы(ПараметрКоманды);
	
	Если Результат.Ошибка Тогда
		ПоказатьПредупреждение(, Результат.ТекстСообщения);
	Иначе	
		Если ЗначениеЗаполнено(Результат.НовыеДокументы) Тогда
			Для каждого ДокументОплаты Из Результат.НовыеДокументы Цикл
				ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(ДокументОплаты));
			КонецЦикла;				
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция СоздатьПлатежныеДокументы(Заявки)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Заявки", Заявки);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РегистрСтатусыОбъектов.Статус КАК Статус,
	|	РегистрСтатусыОбъектов.Объект КАК Заявка,
	|	СправочникСтатусыОбъектов.ТипСтатуса КАК ТипСтатуса
	|ПОМЕСТИТЬ УтвержденныеЗаявки
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК РегистрСтатусыОбъектов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_СтатусыОбъектов КАК СправочникСтатусыОбъектов
	|		ПО РегистрСтатусыОбъектов.Статус = СправочникСтатусыОбъектов.Ссылка
	|			И (РегистрСтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))
	|			И (РегистрСтатусыОбъектов.Объект В (&Заявки))
	|			И (СправочникСтатусыОбъектов.ТипСтатуса В (ЗНАЧЕНИЕ(Перечисление.бит_ТипыСтатусовОбъектов.Утвержден), ЗНАЧЕНИЕ(Перечисление.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен)))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УтвержденныеЗаявки.Заявка КАК Заявка,
	|	ПозицииПоступления.Ссылка КАК Позиция
	|ИЗ
	|	УтвержденныеЗаявки КАК УтвержденныеЗаявки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПозицияПоступления КАК ПозицииПоступления
	|		ПО УтвержденныеЗаявки.Заявка = ПозицииПоступления.ДокументПланирования
	|
	|УПОРЯДОЧИТЬ ПО
	|	Заявка,
	|	Позиция";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Результат = Новый Структура("НовыеДокументы, Ошибка, ТекстСообщения", Новый Массив, Ложь, "");

	Если РезультатЗапроса.Пустой() Тогда
		ТекстСообщения = НСтр("ru = 'Ввод платежных документов поддерживается для утвержденных или частично оплаченных документов.'; 
								|en = 'The entry of payment documents is supported for approved or partially paid documents.'");	
		
		Результат.Ошибка		 = Истина;
		Результат.ТекстСообщения = ТекстСообщения;
		Возврат Результат;
	КонецЕсли;
	
	Выборка	= РезультатЗапроса.Выбрать();
	Пока Выборка.СледующийПоЗначениюПоля("Заявка") Цикл
		
		ДанныеЗаполнения = Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.НовыеПараметрыДокументаСоздатьПлатежныеДокументы(); 
		ДанныеЗаполнения.Дата = ТекущаяДатаСеанса();
		Пока Выборка.Следующий() Цикл
			ЗаполнитьЗначенияСвойств(ДанныеЗаполнения.Позиции.Добавить(), Выборка);
		КонецЦикла;

		НовыеДокументы = Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.СоздатьДокументыНаОсновеВыделенных(
							Выборка.Заявка, ДанныеЗаполнения); 
		Для каждого СтрокаТаблицы Из НовыеДокументы Цикл
			Результат.НовыеДокументы.Добавить(СтрокаТаблицы.ДокументОплаты);		
		КонецЦикла;					
	КонецЦикла;

	Возврат Результат;
	
КонецФункции

#КонецОбласти

