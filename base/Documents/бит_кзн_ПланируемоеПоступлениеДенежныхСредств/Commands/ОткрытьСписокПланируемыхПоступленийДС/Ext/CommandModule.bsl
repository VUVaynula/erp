
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ПараметрыФормы = Новый Структура("ВидПлана", ПредопределенноеЗначение("Перечисление.бит_кзн_ВидыПланов.План"));
	
	ОткрытьФорму("Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.ФормаСписка"
	               , ПараметрыФормы
				   , ПараметрыВыполненияКоманды.Источник
				   , "План"
				   , ПараметрыВыполненияКоманды.Окно);
	
КонецПроцедуры
