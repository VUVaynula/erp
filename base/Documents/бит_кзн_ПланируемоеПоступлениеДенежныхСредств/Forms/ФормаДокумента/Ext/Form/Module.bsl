
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
	ЗаполнитьКэшЗначений();
	УстановитьЗаголовокФормыДокумента(ЭтотОбъект);

	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект);
	ПодготовитьФормуНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);
	
	// Стандартные действия при создании на сервере
	бит_РаботаСДиалогамиСервер.ФормаОбъектаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства
	
	Параметры.Свойство("ЗначениеКопирования", ЗначениеКопирования);
	
	ЗаполнитьКэшЗначений();
	УстановитьЗаголовокФормыДокумента(ЭтотОбъект);
		
	// Настроим отображение полей доп. аналитик в табличном поле Распределение.
	бит_МеханизмДопИзмерений.ПоказатьДополнительныеИзмеренияВТабличномПоле(ЭтотОбъект, "ТаблицаПлатежи",
		КэшЗначений.ИзмеренияДоп, КэшЗначений.НастройкиИзмерений);
	
	УстановитьОтборПлатежей();
	
	Если Параметры.Ключ.Пустая() Тогда
		ПодготовитьФормуНаСервере();
	КонецЕсли;
	
	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) 
		 И (ЗначениеЗаполнено(ЗначениеКопирования) 
		    ИЛИ ЗначениеЗаполнено(Объект.ДокументОснование)) Тогда
		
		ПодключитьОбработчикОжидания("ОжиданиеОткрытияФормы", 0.1, Истина);
		
	КонецЕсли; 
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.Свойств
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если КопироватьПозиции Тогда
		СкопироватьПозицииПриЗаписи(ТекущийОбъект.Ссылка, Отказ);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	УстановитьЗаголовокФормыДокумента(ЭтотОбъект);
	
	УстановитьОтборПлатежей();	
	Элементы.ТаблицаПлатежи.Обновить();
	
	ОбновитьИтоги();
	
	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект);
    ПодготовитьФормуНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	УстановитьЗаголовокФормыДокумента(ЭтотОбъект);
	
	Если ЗначениеЗаполнено(Объект.ДокументОснование)
		И ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств") Тогда
	
		Оповестить("бит_ИзмененСтатус");
	
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзмененСтатус"
		ИЛИ ИмяСобытия = "бит_ИзмененСтатус" Тогда
		ОбработкаОповещенияИзмененияСтатуса();
	КонецЕсли;
	
	// СтандартныеПодсистемы.Свойства
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтотОбъект, ИмяСобытия, Параметр) Тогда
		ОбновитьЭлементыДополнительныхРеквизитов();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства

	бит_КазначействоКлиент.ОбработкаОповещенияФормыДокумента(ЭтотОбъект, Объект.Ссылка, ИмяСобытия, Параметр, Источник);
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты);
	// Конец СтандартныеПодсистемы.Свойства
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ИнформацияСтатусНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Фильтр 		   = Новый Структура("Объект", Объект.Ссылка);
	ПараметрыФормы = Новый Структура("Отбор", Фильтр);
	Открытьформу("РегистрСведений.бит_ИсторияИзмененияСтатусовОбъектов.ФормаСписка", 
		ПараметрыФормы, ЭтотОбъект, ЭтотОбъект,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ФормаОплатыПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(Объект.ФормаОплаты) Тогда
		Объект.ФормаОплаты = ТекущаяФормаОплаты; 
	КонецЕсли; 

	Если ТекущаяФормаОплаты = Объект.ФормаОплаты Тогда
		Возврат;
	КонецЕсли; 

	ТекущаяФормаОплаты = Объект.ФормаОплаты;
    УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	 УстановитьЗаголовокФормыДокумента(ЭтотОбъект);
	 УправлениеФормой(ЭтотОбъект);
	 
КонецПроцедуры

&НаКлиенте
Процедура НомерПриИзменении(Элемент)
	
	УстановитьЗаголовокФормыДокумента(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаПлатежи

&НаКлиенте
Процедура ТаблицаПлатежиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Модифицированность Тогда
		СтандартнаяОбработка  = Ложь;
		ПредставлениеДействия = НСтр("ru = 'Просмотр и редактирование позиции.'; en = 'View and edit the position.'");
		
		ПредложитьЗаписатьДокумент(ПредставлениеДействия, Новый Структура);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаНаСогласование(Команда)
	
	Объект.ОтправленНаСогласование = НЕ Объект.ОтправленНаСогласование;
	Отказ = Ложь;
	Попытка
		Записать();
	Исключение
		Отказ = Истина;
		ТекстСообщения = НСтр("ru = 'Не удалось записать документ по причине: %1.'; 
							|en = 'The document could not be recorded due to:'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ПоказатьПредупреждение(, ТекстСообщения);
	КонецПопытки;
	
	Если Отказ Тогда
		Объект.ОтправленНаСогласование = НЕ Объект.ОтправленНаСогласование;
	Иначе
		Если НЕ Объект.ОтправленНаСогласование  Тогда
			ОчиститьВсеВизы();
		КонецЕсли; 
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВвестиДокументыПоступленияДС(Команда)
	
	Если Модифицированность Тогда
		Записать();
	КонецЕсли;
	
	НовыеДокументы = СформироватьДокументыПоступленияДС();
	
	Для каждого Документ Из НовыеДокументы Цикл
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(Документ));
	КонецЦикла;

КонецПроцедуры

// Создает платежные документы на основании документа планирования. 
//
&НаКлиенте
Процедура ВвестиДокументыПоступленияДСВыделенные(Команда)
	
	Если ЭтотОбъект.Модифицированность Тогда
		Записать();
	КонецЕсли;
	
	ВыделенныеСтроки = Элементы.ТаблицаПлатежи.ВыделенныеСтроки;
	НовыеДокументы   = СоздатьПлатежныеДокументыВыделенные(ВыделенныеСтроки);
	
	Для каждого Документ Из НовыеДокументы Цикл
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(Документ));
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаУдалитьПозицию(Команда)
	
	ТекущиеДанные = Элементы.ТаблицаПлатежи.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекстСообщения = НСтр("ru='Удалить документ?';en='Delete a document?'");
	Оповещение 	   = Новый ОписаниеОповещения("КомандаУдалитьПозициюЗавершение", ЭтотОбъект); 
	ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет)
	
КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура КомандаУдалитьПозициюЗавершение(Результат, Дополнительно) Экспорт
	
	Если Не Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		КомандаУдалитьПозициюНаСервере(Элементы.ТаблицаПлатежи.ТекущаяСтрока);
		ОповеститьОбИзменении(Тип("ДокументСсылка.бит_кзн_ПозицияПоступления"));
		ОбновитьИтоги();
	Исключение
		ПоказатьПредупреждение(, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки; 

КонецПроцедуры

&НаКлиенте
Процедура СделатьБезРазбиения(Команда)
	
	ОчиститьСообщения();
	
	Если НЕ МожноСделатьБезРазбиения() Тогда
		Возврат;	
	КонецЕсли;	 
	
	Если Модифицированность Тогда
		ПредставлениеДействия = НСтр("ru = 'Переход в режим ""без разбиения""'; 
								|en = 'Switching to the ""no-split"" mode'");
		
		ДополнительныеДанные = Новый Структура("ЗакрытьЭтуФорму", Истина);
		ПредложитьЗаписатьДокумент(ПредставлениеДействия, ДополнительныеДанные);	
	Иначе
		ОткрытьФормуПозиции(Неопределено);
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

