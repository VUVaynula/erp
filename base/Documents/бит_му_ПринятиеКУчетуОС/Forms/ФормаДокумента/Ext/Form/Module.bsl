// Процедура добавляет/загружает подобранные основные средства.
// 
// Параметры:
//  ВыбранноеЗначение.
// 
&НаСервере
Процедура ДобавитьЗагрузитьОС(ВыбранноеЗначение)
	
	ДокОбъект = РеквизитФормыВЗначение("Объект");
	ДокОбъект.ЗаполнитьОсновныеСредства(ВыбранноеЗначение);
	ЗначениеВРеквизитФормы(ДокОбъект, "Объект");
	
	ВыполнитьРасчетСумм();
	
КонецПроцедуры // ДобавитьЗагрузитьОС()

&НаКлиенте
Процедура РассчитатьСуммы(Команда)
	ВыполнитьРасчетСумм();
КонецПроцедуры

&НаСервере
Процедура ВыполнитьРасчетСумм()
	
	Если Не Объект.ВидОперации=Перечисления.бит_му_ВидыОперацийПринятиеКУчетуОС.ВводНачальныхОстатковОСДетализацияПоСуммам
		И Не Объект.ВидОперации=Перечисления.бит_му_ВидыОперацийПринятиеКУчетуОС.ПринятиеКУчетуОСДетализацияПоСуммам Тогда 
		Возврат;
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивСчетов", Объект.ОсновныеСредства.Выгрузить(,"КорСчет"));
	Запрос.УстановитьПараметр("Период", Объект.Дата);
	Запрос.УстановитьПараметр("СписокОС", Объект.ОсновныеСредства.Выгрузить(,"ОсновноеСредство")); 
	Субконто = Новый Массив;
	Субконто.Добавить(ПланыВидовХарактеристик.бит_ВидыСубконтоДополнительные_2.ОсновныеСредства);
	Запрос.УстановитьПараметр("Субконто", Субконто);
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	МеждународныйОстатки.Субконто1 КАК ОсновноеСредство,
		|	МеждународныйОстатки.СуммаРеглОстаток КАК СуммаРегл,
		|	МеждународныйОстатки.СуммаУпрОстаток КАК СуммаУпр,
		|	МеждународныйОстатки.СуммаМУОстаток КАК СуммаМУ,
		|	МеждународныйОстатки.Счет КАК Счет
		|ИЗ
		|	РегистрБухгалтерии.бит_Дополнительный_2.Остатки(&Период, Счет В (&МассивСчетов), &Субконто, Субконто1 В (&СписокОС)) КАК МеждународныйОстатки";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("ОсновноеСредство", Выборка.ОсновноеСредство);
		СтруктураОтбора.Вставить("КорСчет", Выборка.Счет);
		
		МассивСтрок = Объект.ОсновныеСредства.НайтиСтроки(СтруктураОтбора);
		Для каждого СтрокаТч Из МассивСтрок Цикл
			ЗаполнитьЗначенияСвойств(СтрокаТч, Выборка);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

