Процедура УстановитьПараметрыВыбораДоговораКонрагента()

	ИмяРеквизитаКонтрагента = бит_ОбщегоНазначения.ОпределитьИмяРеквизитаКонтрагента();
    ОтборКонтрагент = СтрШаблон("Отбор.%1", ИмяРеквизитаКонтрагента);
	
