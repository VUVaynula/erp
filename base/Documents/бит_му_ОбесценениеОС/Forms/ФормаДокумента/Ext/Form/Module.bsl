#КонецОбласти

&НаКлиенте
Процедура ПодборОС(Команда)
	
	ПараметрыФормы = ЗаполнитьПараметрыПодбора();
	
	ОткрытьФорму("Обработка.бит_му_ПодборВНА.Форма",ПараметрыФормы,ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьВсе(Команда)
	
	Если Объект.ОсновныеСредства.Количество() > 0 Тогда
		
		Оповещение = Новый ОписаниеОповещения("КомандаЗаполнитьВсеЗавершение", ЭтотОбъект);
		ТекстВопроса = НСтр("ru='Параметры в табличной части будут перезаполнены. Продолжить?';
							|en='The parameters in the tabular part will be refilled. Continue?'");
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 5, КодВозвратаДиалога.Нет);
		
	Иначе
		
		ЗаполнитьОС();
		
	КонецЕсли; 
	
КонецПроцедуры

// Процедура - завершение обработки команды "ЗаполнитьВсе".
// 
&НаКлиенте
Процедура КомандаЗаполнитьВсеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьОС();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоТекущейСтроке(Команда)
	
	ТекущаяСтрока = Элементы.ОсновныеСредства.ТекущиеДанные;
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПриИзмененииОС(ТекущаяСтрока.ПолучитьИдентификатор());
	
КонецПроцедуры

&НаКлиенте
Процедура РаспределитьПоГруппеОС(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("БалансоваяСтоимость", Объект.ОсновныеСредства.Итог("БалансоваяСтоимость"));
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ЗакрытиеОбесценениеГруппыОС", ЭтотОбъект);
	ОткрытьФорму("Документ.бит_му_ОбесценениеОС.Форма.ОбесценениеГруппыОС", ПараметрыФормы, 
		ЭтотОбъект,,,,ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытиеОбесценениеГруппыОС(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	БалансоваяСтоимость = Объект.ОсновныеСредства.Итог("БалансоваяСтоимость");
	СуммаВозмещения     = Результат.ВозмещаемаяСтоимость;
	
	Макс     = 0;
	ИдСтроки = 0;
	СуммаВозмещенияОстаток = СуммаВозмещения;
	Для каждого СтрокаТаблицы Из Объект.ОсновныеСредства Цикл
		Если СтрокаТаблицы.БалансоваяСтоимость > Макс Тогда
			Макс     = СтрокаТаблицы.БалансоваяСтоимость;
			ИдСтроки = СтрокаТаблицы.ПолучитьИдентификатор();
		КонецЕсли; 
		СтрокаТаблицы.ВозмещаемаяСтоимость = СуммаВозмещения * (СтрокаТаблицы.БалансоваяСтоимость/БалансоваяСтоимость);
		СтрокаТаблицы.Сумма = СтрокаТаблицы.БалансоваяСтоимость - СтрокаТаблицы.ВозмещаемаяСтоимость;
		СуммаВозмещенияОстаток = СуммаВозмещенияОстаток - СтрокаТаблицы.ВозмещаемаяСтоимость;
	КонецЦикла; 
	
	Если СуммаВозмещенияОстаток > 0 Тогда
		СтрокаТаблицы = Объект.ОсновныеСредства.НайтиПоИдентификатору(ИдСтроки);
	    СтрокаТаблицы.ВозмещаемаяСтоимость = СтрокаТаблицы.ВозмещаемаяСтоимость + СуммаВозмещенияОстаток;
		СтрокаТаблицы.Сумма = СтрокаТаблицы.БалансоваяСтоимость - СтрокаТаблицы.ВозмещаемаяСтоимость;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	ЗаполнитьВалютуМСФО();
	УстановитьСостояниеДокумента();     
	
	РазрешеноОтражениеДокументовВЗакрытомПериоде = бит_ПраваДоступа.ПолучитьЗначениеДопПраваПользователя(
		Пользователи.ТекущийПользователь(),
	 	ПланыВидовХарактеристик.бит_ДополнительныеПраваПользователей.РазрешеноОтражениеДокументовВЗакрытомПериоде);
		
    ТекущаяОрганизация = Объект.Организация;
	КоличествоСубконтоМУ = 4;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСостояниеДокумента()
	
	СостояниеДокумента = бит_ОбщегоНазначения.СостояниеДокумента(Объект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
																   
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	Элементы.ОтразитьВЗакрытомПериоде.Видимость = Форма.РазрешеноОтражениеДокументовВЗакрытомПериоде;
	// ++ ЕРП
	Элементы.ДанныеБУ.Видимость = Истина;   
	// -- ЕРП
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВалютуМСФО(ИзменениеОрганизации = Истина)
	
	// Получим валюту международного учета.
	ВалютаМСФО = бит_му_ОбщегоНазначения.ПолучитьВалютуМеждународногоУчета(Объект.Организация);
	СтрокаВалютаМежУчета = Строка(ВалютаМСФО);
	
	Элементы.ДекорацияВалютаМСФО.Заголовок = ?(ПустаяСтрока(СтрокаВалютаМежУчета), "НЕ УСТАНОВЛЕНА", СтрокаВалютаМежУчета);
	
	Если ИзменениеОрганизации Тогда
		Объект.ВалютаДокумента = ВалютаМСФО;
		УстановитьКурсКратностьДокумента(Объект.ВалютаДокумента, Объект.Дата, Объект.КурсДокумента, Объект.КратностьДокумента);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьКурсКратностьДокумента(Валюта, Дата, Курс, Кратность)
    
    СтрКурса = бит_КурсыВалют.ПолучитьКурсВалюты(Валюта, Дата);
    
    Курс      = СтрКурса.Курс;
    Кратность = СтрКурса.Кратность;
    
КонецПроцедуры // ИзменениеВалюты()

&НаКлиентеНаСервереБезКонтекста
Функция ПараметрыУстановкиСвойствСубконтоСчетДоходовРасходов(Форма)
	
	Результат = бит_БухгалтерияКлиентСервер.НовыеПараметрыУстановкиСвойствСубконто();
	                       
	Результат.ПоляФормы.Субконто1   = "ОсновныеСредстваСубконто1";
	Результат.ПоляОбъекта.Субконто1 = "Субконто1";
	Результат.ПоляФормы.Субконто2   = "ОсновныеСредстваСубконто2";
	Результат.ПоляОбъекта.Субконто2 = "Субконто2";
	Результат.ПоляФормы.Субконто3   = "ОсновныеСредстваСубконто3";
	Результат.ПоляОбъекта.Субконто3 = "Субконто3";
	Результат.ПоляФормы.Субконто4   = "ОсновныеСредстваСубконто4";
	Результат.ПоляОбъекта.Субконто4 = "Субконто4";
	Результат.ПоляОбъекта.СчетУчета = "СчетДоходовРасходов";
	
	Результат.ДопРеквизиты.Вставить("Организация", Форма.Объект.Организация);

	Возврат Результат;

КонецФункции

&НаСервере
Процедура ЗаполнитьИнвентарныеНомера(ИДСтроки = Неопределено)
	
	СоответствиеОС_ИнвентарныйНомер = Новый Соответствие;
	
	Если ИДСтроки = Неопределено Тогда
		
		бит_му_ВНА.ЗаполнитьСоответствиеОС_ИнвентарныйНомер(СоответствиеОС_ИнвентарныйНомер,
			Объект.ОсновныеСредства.Выгрузить().ВыгрузитьКолонку("ОсновноеСредство"), Объект.Организация);
													   
		Для Каждого ТекСтрока Из Объект.ОсновныеСредства Цикл
			ТекСтрока.ИнвентарныйНомер = СоответствиеОС_ИнвентарныйНомер[ТекСтрока.ОсновноеСредство];
		КонецЦикла;
		
	Иначе
		
		ДанныеСтроки = Объект.ОсновныеСредства.НайтиПоИдентификатору(ИДСтроки);		
		Если ДанныеСтроки <> Неопределено Тогда
			ДанныеСтроки.ИнвентарныйНомер = бит_му_ВНА.ИнвентарныйНомерОсновногоСредства(СоответствиеОС_ИнвентарныйНомер,
												ДанныеСтроки.ОсновноеСредство, Объект.Организация);
		КонецЕсли;
																				
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьПодборОС(ВыбранноеЗначение)
	
	ЗаполнитьТчОсновныеСредстваПоДаннымПодбора(ВыбранноеЗначение);
	
	ЗаполнитьИнвентарныеНомера();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТчОсновныеСредстваПоДаннымПодбора(ВыбранноеЗначение, ЭтоНовыйДокумент = Истина)
	
	ОписаниеТаблицы = ВыбранноеЗначение.Данные;
	ТаблицаДанных = бит_ОбщегоНазначения.РаспаковатьТаблицуИзМассива(ОписаниеТаблицы.ПереченьОбъектов, ОписаниеТаблицы.ПереченьОбъектов_Колонки);
	
	МассивОС = ТаблицаДанных.ВыгрузитьКолонку("ВНА");
	бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(МассивОС); 
	ПараметрыОбъектов = ПолучитьПараметры(МассивОС);
	Если ДанныеБУ Тогда   
	    ДополнитьПараметрыОбъектовДаннымиБУ(ПараметрыОбъектов, МассивОС);	
	КонецЕсли;
	
	ВыполнитьВалютныеПересчетыИзВалютыМУВВалютуДокумента(ПараметрыОбъектов); 
		
	Для Каждого СтрокаТаблицы Из ТаблицаДанных Цикл
		
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("ОсновноеСредство", СтрокаТаблицы.ВНА);
		
		МассивСтрок = Объект.ОсновныеСредства.НайтиСтроки(СтруктураОтбора);
		
		Если МассивСтрок.Количество() = 0 Тогда
			НайденнаяСтрока = Неопределено;
		Иначе
			НайденнаяСтрока = МассивСтрок[0];
		КонецЕсли;
		
		Если НайденнаяСтрока = Неопределено Тогда
			
			НоваяСтрока = Объект.ОсновныеСредства.Добавить();
			НоваяСтрока.ОсновноеСредство = СтрокаТаблицы.ВНА;
			СтрокаПараметров = ПараметрыОбъектов[НоваяСтрока.ОсновноеСредство];
			ЗаполнитьСтрокуТЧПоСтрокеДанных(НоваяСтрока, СтрокаПараметров);
			
		Иначе
			
			ТекстСообщения = НСтр("ru = 'Основное средство ""%1"" инв. №%2 уже подобрано в строке №%3.'; 
			                      |en = 'Fixed asset ""%1"" inv. №%2 is already matched in line №%3.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения,
			                           СтрокаТаблицы.ВНА,
									   СтрокаТаблицы.ИнвентарныйНомер,
									   НайденнаяСтрока.НомерСтроки);
									   
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
		КонецЕсли;
				
	КонецЦикла; // По строкам таблицы данных			

КонецПроцедуры // ЗаполнитьТчОсновныеСредстваПоДаннымПодбора()

&НаСервере
Процедура ДополнитьПараметрыОбъектовДаннымиБУ(ПараметрыОбъектов, МассивОС)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Счет",        ПланыСчетов.Хозрасчетный.ОбесценениеОС_01);
	Запрос.УстановитьПараметр("МассивОС",    МассивОС);
	Запрос.УстановитьПараметр("КонецПериода",Объект.Дата);
	
	Субконто = Новый Массив;
	Субконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ОсновныеСредства);
	Запрос.УстановитьПараметр("Субконто", Субконто);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ХозрасчетныйОбороты.Счет КАК Счет,
	               |	ХозрасчетныйОбороты.СуммаОборотДт КАК СуммаОборотДт,
	               |	ХозрасчетныйОбороты.СуммаОборотКт КАК СуммаОборотКт,
	               |	ХозрасчетныйОбороты.Субконто1 КАК ОсновноеСредство
	               |ИЗ
	               |	РегистрБухгалтерии.Хозрасчетный.Обороты(
	               |			,
	               |			&КонецПериода,
	               |			,
	               |			Счет = &Счет,
	               |			&Субконто,
	               |			Организация = &Организация
	               |				И Субконто1 В (&МассивОС),
	               |			,
	               |			) КАК ХозрасчетныйОбороты";
				   
    Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	ДанныеКурсаДокумент = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Объект.ВалютаДокумента, Объект.Дата);
	ДанныеКурсаБУ       = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Константы.ВалютаРегламентированногоУчета.Получить(), Объект.Дата);
	
	ОбесценениеБУ = Новый Соответствие; 
	Пока Выборка.Следующий() Цикл     
		СуммаОбесценения = ?(Объект.ВидДвижения = Перечисления.бит_му_ВидыДвиженияОбесценения.ВозвратОбесценения, Выборка.СуммаОборотДт, Выборка.СуммаОборотКт);
		ПараметрыОбъектов[Выборка.ОсновноеСредство].СуммаОбесценения = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(СуммаОбесценения, ДанныеКурсаБУ, ДанныеКурсаДокумент);
	КонецЦикла;
			
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииОрганизации()
	
	ПараметрыПроверки = бит_ОбщегоНазначения.НовыеПараметрыПроверитьПринадлежностьАналитики();
	ПараметрыПроверки.Контейнер 			   = Объект;
	ПараметрыПроверки.ИмяРеквизита			   = "Подразделение";
	ПараметрыПроверки.ИмяПроверочногоРеквизита = "Владелец";
	ПараметрыПроверки.ИмяКонтрольногоЗначения  = "Организация";
	ПараметрыПроверки.ИмяТипа 				   = "СправочникСсылка.ПодразделенияОрганизаций";
	ПараметрыПроверки.НачалоСообщения 		   = НСтр("ru = 'В документе'; en = 'In the document'");
	ПараметрыПроверки.Заголовок 			   = НСтр("ru = 'Изменение значения реквизита Организация'; en = 'Changing the value of the requisite Organization'");

	бит_ОбщегоНазначения.ПроверитьПринадлежностьАналитики(ПараметрыПроверки);
														  
	// Установим валюту межд. учета
	ЗаполнитьВалютуМСФО(Истина);
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииОС(Знач ИДСтроки)
	
	ТекущаяСтрока = Объект.ОсновныеСредства.НайтиПоИдентификатору(ИДСтроки);	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОбъектов = ПолучитьПараметры(ТекущаяСтрока.ОсновноеСредство);
	
	Если ДанныеБУ Тогда 
		МассивОС = Новый Массив;
		МассивОС.Добавить(ТекущаяСтрока.ОсновноеСредство);
	    ДополнитьПараметрыОбъектовДаннымиБУ(ПараметрыОбъектов, МассивОС);	
	КонецЕсли;
	
	ВыполнитьВалютныеПересчетыИзВалютыМУВВалютуДокумента(ПараметрыОбъектов); 
	
	СтрокаДанных = ПараметрыОбъектов[ТекущаяСтрока.ОсновноеСредство];
	
	ВидыОперацийПоКлассу = Новый Соответствие;
	ВидыОперацийПоКлассу.Вставить(Перечисления.бит_му_ВидыКлассовОС.ОсновныеСредства,
		Перечисления.бит_му_ВидыОперацийОбесценениеОС.ОсновныеСредства);
	ВидыОперацийПоКлассу.Вставить(Перечисления.бит_му_ВидыКлассовОС.ИнвестиционнаяСобственность,
		Перечисления.бит_му_ВидыОперацийОбесценениеОС.ИнвестиционнаяСобственность);
									
	Если СтрокаДанных <> Неопределено Тогда
	
		Если ВидыОперацийПоКлассу[СтрокаДанных.ВидКласса] <> Объект.ВидОперации Тогда
			
			ТекстСообщения = НСтр("ru = 'В строке №%1 табличной части ""Основные средства"" вид класса ""%2"" основного средства ""%3"" не соответствует виду операции документа.'; 
			                      |en = 'In line №%1 of the fixed assets tabular part, class type ""%2"" of fixed asset ""%3"" does not correspond to the document transaction type.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ТекущаяСтрока.НомерСтроки, СтрокаДанных.ВидКласса, ТекущаяСтрока.ОсновноеСредство);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
			ТекущаяСтрока.ОсновноеСредство = Неопределено;
			
		КонецЕсли; 
		
	КонецЕсли; 
	
	ЗаполнитьСтрокуТЧПоСтрокеДанных(ТекущаяСтрока, СтрокаДанных);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьПараметры(ПереченьОбъектов)
	
	Реквизиты = Новый Структура;
	Реквизиты.Вставить("Организация", Объект.Организация);
	Реквизиты.Вставить("Дата",        Объект.Дата);
	Реквизиты.Вставить("ВидДвижения", Объект.ВидДвижения);
	Реквизиты.Вставить("ЭтоНовыйДокумент", Параметры.Ключ.Пустая());
		
	Возврат Документы.бит_му_ОбесценениеОС.ПолучитьПараметры(Реквизиты, ПереченьОбъектов);

КонецФункции // ПолучитьПараметрыОС()

&НаСервере
Процедура РассчитатьСуммуВСтрокеТЧ(Идентификатор)

	ТекущаяСтрока = Объект.ОсновныеСредства.НайтиПоИдентификатору(Идентификатор);
	
	ТекущаяСтрока.Сумма = ТекущаяСтрока.БалансоваяСтоимость - ТекущаяСтрока.ВозмещаемаяСтоимость;

	Если Объект.ВидДвижения = Перечисления.бит_му_ВидыДвиженияОбесценения.ВозвратОбесценения Тогда		
		ТекущаяСтрока.Сумма = -ТекущаяСтрока.Сумма; 		
	КонецЕсли;
	
КонецПроцедуры // РассчитатьСуммуВСтрокеТЧ()

&НаСервере
Процедура ЗаполнитьСтрокуТЧПоСтрокеДанных(СтрокаТабличнойЧасти, СтрокаДанных)
		
	ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтрокаДанных);   
	
	Если ДанныеБУ Тогда
		
		СтрокаТабличнойЧасти.Сумма = СтрокаДанных.СуммаОбесценения;
		Если Объект.ВидДвижения = Перечисления.бит_му_ВидыДвиженияОбесценения.ВозвратОбесценения Тогда		
			СтрокаТабличнойЧасти.ВозмещаемаяСтоимость = СтрокаТабличнойЧасти.БалансоваяСтоимость + СтрокаТабличнойЧасти.Сумма;
		Иначе
		    СтрокаТабличнойЧасти.ВозмещаемаяСтоимость = СтрокаТабличнойЧасти.БалансоваяСтоимость - СтрокаТабличнойЧасти.Сумма;	
		КонецЕсли;  
		
	Иначе
		
		СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.БалансоваяСтоимость - СтрокаТабличнойЧасти.ВозмещаемаяСтоимость;

		Если Объект.ВидДвижения = Перечисления.бит_му_ВидыДвиженияОбесценения.ВозвратОбесценения Тогда		
			СтрокаТабличнойЧасти.Сумма = -СтрокаТабличнойЧасти.Сумма; 		
		КонецЕсли;
	
	КонецЕсли;
	
	
	ЗаполнитьИнвентарныеНомера();
	
КонецПроцедуры // ЗаполнитьСтрокуТЧПоСтрокеДанных()

&НаСервере
Процедура ЗаполнитьОС()
	
	МассивОС = Объект.ОсновныеСредства.Выгрузить().ВыгрузитьКолонку("ОсновноеСредство");
	бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(МассивОС);
	ПараметрыОбъектов = ПолучитьПараметры(МассивОС);	
	
	Если ДанныеБУ Тогда 
	    ДополнитьПараметрыОбъектовДаннымиБУ(ПараметрыОбъектов, МассивОС);	
	КонецЕсли;
	
	ВыполнитьВалютныеПересчетыИзВалютыМУВВалютуДокумента(ПараметрыОбъектов); 
	
	ЗаполнитьИнвентарныеНомера();
	
	Для Каждого ТекущаяСтрока Из Объект.ОсновныеСредства Цикл
		
		СтрокаДанных = ПараметрыОбъектов[ТекущаяСтрока.ОсновноеСредство];
		ЗаполнитьСтрокуТЧПоСтрокеДанных(ТекущаяСтрока,СтрокаДанных);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьКурсыВалютПоПериодам(КешСтарыеКурсы = Неопределено, флНовыеКурсы = Ложь)
	
	Если флНовыеКурсы Тогда
		
		НовыеКурсы = Новый Структура;
		НовыеКурсы.Вставить("Валюта", Объект.ВалютаДокумента);
		НовыеКурсы.Вставить("Кратность", Объект.КратностьДокумента);
		НовыеКурсы.Вставить("Курс", Объект.КурсДокумента);
		
		СтруктураКурсовВалют = Новый Структура;
		СтруктураКурсовВалют.Вставить("НовыеКурсы", НовыеКурсы);
		
	Иначе
		
		СтарыеКурсы = Новый Структура;
		СтарыеКурсы.Вставить("Валюта", КешСтарыеКурсы.ВалютаДокумента); 
		СтарыеКурсы.Вставить("Кратность", КешСтарыеКурсы.КратностьДокумента);
		СтарыеКурсы.Вставить("Курс", КешСтарыеКурсы.КурсДокумента);
		
		СтруктураКурсовВалют = Новый Структура;
		СтруктураКурсовВалют.Вставить("СтарыеКурсы", СтарыеКурсы);
		
	КонецЕсли; 
	
	МассивОС = Объект.ОсновныеСредства.Выгрузить().ВыгрузитьКолонку("ОсновноеСредство");
	ТаблицаДанных = Документы.бит_му_ОбесценениеОС.ПодготовитьТаблицуДатПринятияОС(Объект.Организация, МассивОС);
	ТаблицаПериодов = ТаблицаДанных.Скопировать(, "Период");
	Курсы = бит_КурсыВалют.ПолучитьКурсыВалютПоПериодам(ТаблицаПериодов, Неопределено, СтруктураКурсовВалют);
	
	СоответствиеКурсовИОС = Новый Соответствие;
	
	Для каждого Строка Из ТаблицаДанных Цикл
		СоответствиеКурсовИОС.Вставить(Строка.ОсновноеСредство, Курсы[Строка.Период])
	КонецЦикла; 

	Возврат СоответствиеКурсовИОС;
	
КонецФункции

// Процедура обрабатывает изменение валюты документа.
// 
// Параметры:
//  Нет.
// 
&НаСервере
Процедура ИзменениеВалютыСервер()
	                 
	КурсыВалют = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Объект.ВалютаДокумента, Объект.Дата);
	Объект.КурсДокумента      = КурсыВалют.Курс;
	Объект.КратностьДокумента = КурсыВалют.Кратность;
	
	ЗаполнитьИнвентарныеНомера();
	  
КонецПроцедуры // ИзменениеВалютыСервер()

// Функция получает параметры, передаваемые в обработку подбора ОС.
//
&НаСервере
Функция ЗаполнитьПараметрыПодбора()

	Если Объект.ВидОперации = Перечисления.бит_му_ВидыОперацийОбесценениеОС.ОсновныеСредства Тогда
		ВидКласса = Перечисления.бит_му_ВидыКлассовОС.ОсновныеСредства;
	Иначе
		ВидКласса = Перечисления.бит_му_ВидыКлассовОС.ИнвестиционнаяСобственность;
	КонецЕсли;
	
	ПараметрыПодбора = Новый Структура;
	ПараметрыПодбора.Вставить("ЗакрыватьПриВыборе", Ложь);
	ПараметрыПодбора.Вставить("Организация"		  , Объект.Организация);                             
	ПараметрыПодбора.Вставить("Режим"			  , Перечисления.бит_му_РежимыПодбораВНА.ОбесценениеОС);
	ПараметрыПодбора.Вставить("ДатаОкончания"	  , КонецМесяца(Объект.Дата));
	ПараметрыПодбора.Вставить("МОЛ"				  , Объект.МОЛ);
	ПараметрыПодбора.Вставить("Местонахождение"	  , Объект.Подразделение);
	ПараметрыПодбора.Вставить("ВидКласса"		  , ВидКласса);
	ПараметрыПодбора.Вставить("МодельУчета"		  , Перечисления.бит_му_МоделиУчетаВНА.ПоПервоначальнойСтоимости);	
	
	Возврат ПараметрыПодбора;
	
КонецФункции // ЗаполнитьПараметрыПодбора()

#Область РаботаСКэшемРеквизитовФормы

