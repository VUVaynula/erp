	ПараметрыФормы.Вставить("Режим"        				 	  , "Одиночный");
	
	ОткрытьФорму("Обработка.бит_ПолучениеДанныхРегистровБухгалтерии.Форма", ПараметрыФормы, ЭтотОбъект);
	
