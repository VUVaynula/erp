&НаКлиенте
Процедура КомандаЗаполнить(Кнопка)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЭтоЗаполнениеИзДокументаОперации", Истина);
	ПараметрыФормы.Вставить("ОбъектСистемы"				      , Объект.РегистрБухгалтерии);
