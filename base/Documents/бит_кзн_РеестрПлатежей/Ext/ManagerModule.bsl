КонецФункции

#КонецОбласти	

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаРеестрПлатежей(НомераТаблиц)

	НомераТаблиц.Вставить("РеестрПлатежейРеквизиты", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("РеестрПлатежейТаблица", НомераТаблиц.Количество());

	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.Ссылка КАК РеестрПлатежей,
	|	Реквизиты.Дата КАК Период
	|ИЗ
	|	Документ.бит_кзн_РеестрПлатежей КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Список.ЗаявкаПлатежнаяПозиция КАК Заявка,
	|	Список.ПлатежнаяПозиция КАК ПлатежнаяПозиция
	|ИЗ
	|	Документ.бит_кзн_РеестрПлатежей.ТаблицаПлатежи КАК Список
	|ГДЕ
	|	Список.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Список.НомерСтроки";
	
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции

// Функция получает результат запроса к табличной части Реестра платежей
//
// Параметры:
//  МассивСсылок - Массив документов РеестрПлатежей.
//  
// Возвращаемое значение:
//   Результат запроса.
//
Функция ПолучитьРезультатЗапроса(МассивСсылок, Полный)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивСсылок", МассивСсылок);
	Запрос.УстановитьПараметр("Полный"		, Полный);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РеестрТЧ.Ссылка КАК РеестрПлатежей,
	|	РеестрТЧ.Ссылка.Дата КАК ДатаРеестра,
	|	РеестрТЧ.Организация КАК Организация,
	|	РеестрТЧ.НомерСтроки КАК Номер,
	|	РеестрТЧ.ЗаявкаПлатежнаяПозиция КАК Заявка,
	|	РеестрТЧ.ПлатежнаяПозиция КАК ПлатежнаяПозиция,
	|	РеестрТЧ.СуммаКОплате КАК СуммаКОплате,
	|	РеестрТЧ.ВалютаДокумента КАК ВалютаДокумента
	|ПОМЕСТИТЬ ВТРеестрТЧ
	|ИЗ
	|	Документ.бит_кзн_РеестрПлатежей.ТаблицаПлатежи КАК РеестрТЧ
	|ГДЕ
	|	РеестрТЧ.Ссылка В(&МассивСсылок)
	|	И ВЫБОР
	|			КОГДА &Полный = ИСТИНА
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ РеестрТЧ.Оплачено = ИСТИНА
	|		КОНЕЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	РеестрТЧ.ПлатежнаяПозиция
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТРеестрТЧ.РеестрПлатежей КАК РеестрПлатежей,
	|	ВТРеестрТЧ.ДатаРеестра КАК ДатаРеестра,
	|	ВТРеестрТЧ.Организация КАК Организация,
	|	ВТРеестрТЧ.Номер КАК Номер,
	|	ВТРеестрТЧ.Заявка КАК Заявка,
	|	ВТРеестрТЧ.ПлатежнаяПозиция КАК ПлатежнаяПозиция,
	|	ПлатежнаяПоз.ЦФО КАК ЦФО,
	|	ПлатежнаяПоз.СтатьяОборотов КАК СтатьяОборотов,
	|	ПлатежнаяПоз.Аналитика_1 КАК Аналитика_1,
	|	ПлатежнаяПоз.Аналитика_2 КАК Аналитика_2,
	|	ПлатежнаяПоз.Аналитика_3 КАК Аналитика_3,
	|	ПлатежнаяПоз.Аналитика_4 КАК Аналитика_4,
	|	ПлатежнаяПоз.Аналитика_5 КАК Аналитика_5,
	|	ПлатежнаяПоз.Аналитика_6 КАК Аналитика_6,
	|	ПлатежнаяПоз.Аналитика_7 КАК Аналитика_7,
	|	ПлатежнаяПоз.Аналитика_8 КАК Аналитика_8,
	|	ПлатежнаяПоз.Аналитика_9 КАК Аналитика_9,
	|	ПлатежнаяПоз.Аналитика_10 КАК Аналитика_10,
	|	ПлатежнаяПоз.Аналитика_11 КАК Аналитика_11,
	|	ПлатежнаяПоз.Аналитика_12 КАК Аналитика_12,
	|	ПлатежнаяПоз.Контрагент КАК Контрагент,
	|	ПлатежнаяПоз.ОбъектРасчетов КАК ДоговорКонтрагента,
	|	ПлатежнаяПоз.НазначениеПлатежа КАК НазначениеПлатежа,
	|	ПлатежнаяПоз.НазначениеПлатежаУпр КАК НазначениеПлатежаУпр,
	|	ВТРеестрТЧ.СуммаКОплате КАК СуммаКОплате,
	|	ВТРеестрТЧ.ВалютаДокумента КАК ВалютаДокумента,
	|	ПлатежнаяПоз.ДатаПлан КАК ДатаПлан,
	|	ПлатежнаяПоз.СверхБюджета КАК СверхБюджета,
	|	ПлатежнаяПоз.ФизЛицо КАК ФизЛицо,
	|	ПлатежнаяПоз.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ПлатежнаяПоз.ОбъектРасчетов КАК ОбъектРасчетов,
	|	ВЫБОР
	|		КОГДА ПлатежнаяПоз.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|			ТОГДА ПлатежнаяПоз.БанковскийСчет
	|		ИНАЧЕ ПлатежнаяПоз.Касса
	|	КОНЕЦ КАК БанковскийСчетКасса
	|ИЗ
	|	ВТРеестрТЧ КАК ВТРеестрТЧ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПоз
	|		ПО ВТРеестрТЧ.ПлатежнаяПозиция = ПлатежнаяПоз.Ссылка
	|ИТОГИ
	|	МИНИМУМ(ДатаРеестра),
	|	МАКСИМУМ(Номер)
	|ПО
	|	РеестрПлатежей,
	|	Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеестрТЧ.Ссылка КАК РеестрПлатежей,
	|	РеестрТЧ.ПлатежнаяПозиция.Организация КАК Организация,
	|	РеестрТЧ.ВалютаПлатежа КАК Валюта,
	|	СУММА(РеестрТЧ.СуммаКОплате) КАК Сумма
	|ИЗ
	|	Документ.бит_кзн_РеестрПлатежей.ТаблицаПлатежи КАК РеестрТЧ
	|ГДЕ
	|	РеестрТЧ.Ссылка В(&МассивСсылок)
	|	И ВЫБОР
	|			КОГДА &Полный = ИСТИНА
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ РеестрТЧ.Оплачено = ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	РеестрТЧ.ПлатежнаяПозиция.Организация,
	|	РеестрТЧ.Ссылка,
	|	РеестрТЧ.ВалютаПлатежа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	бит_УстановленныеВизы.Объект КАК РеестрПлатежей,
	|	бит_УстановленныеВизы.Виза КАК Виза,
	|	бит_УстановленныеВизы.ФизическоеЛицо КАК ФИО,
	|	бит_УстановленныеВизы.ДатаУстановки КАК ДатаУстановки
	|ИЗ
	|	РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы
	|ГДЕ
	|	бит_УстановленныеВизы.Объект В(&МассивСсылок)
	|	И НЕ бит_УстановленныеВизы.Виза.РежимПечати = ЗНАЧЕНИЕ(Перечисление.бит_РежимПечатиВиз.НеВыводить)";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Возврат РезультатЗапроса;
	
КонецФункции // ПолучитьРезультатЗапроса()

// Функция формирует печатную форму заявки на оплату.
//
// Параметры:
//  МассивСсылок - Массив.
//  Полный 		 - Булево - печать всех заявок из реестра или только тех, которые помечены в оплату.
//
// Возвращаемое значение:
//  ТабличныйДокумент - ТабличныйДокумент.
// 
Функция СформироватьПечатнуюФормуРеестраПлатежей(Ссылки, Полный = Ложь, БезВиз = Ложь) Экспорт

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_бит_кзн_РеестрПлатежей_РеестрПлатежей";
	
	РезультатЗапросаПакеты = ПолучитьРезультатЗапроса(Ссылки, Полный);
	
	РезультатЗапроса 		= РезультатЗапросаПакеты[1];
	РезультатЗапросаИтоги 	= РезультатЗапросаПакеты[2].Выгрузить();
	РезультатЗапросаВизы 	= РезультатЗапросаПакеты[3].Выгрузить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		
		// Получаем макет и области.
		Макет = ПолучитьМакет("РеестрПлатежей");
		// Получаем области.
		ОбластьШапка	 	  = Макет.ПолучитьОбласть("Шапка");
		ОбластьОрганизация	  = Макет.ПолучитьОбласть("Организация");
		ОбластьТабличнаяЧасть = Макет.ПолучитьОбласть("ТабличнаяЧасть");
		ОбластьШапкаИтоги	  = Макет.ПолучитьОбласть("ШапкаИтоги");
		ОбластьИтоги		  = Макет.ПолучитьОбласть("Итоги");
		ОбластьВизыШапка	  = Макет.ПолучитьОбласть("ВизыШапка");
		ОбластьВизыТЧ		  = Макет.ПолучитьОбласть("ВизыТЧ");
		ОбластьПодвал		  = Макет.ПолучитьОбласть("Подвал");
		
		// Вывод результатов.
		Выборка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);		
		Пока Выборка.Следующий() Цикл
			
			ТекДокумент = Выборка.РеестрПлатежей;
			
			// Отбор для таблиц по текущему документу.
			Отбор = Новый Структура;
			Отбор.Вставить("РеестрПлатежей", ТекДокумент); 			
			
			ЗначениеНомер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекДокумент, "Номер");
			НомерДок = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ЗначениеНомер);
			
			Заголовок = СтрШаблон(НСтр("ru='РЕЕСТР ПЛАТЕЖЕЙ №%1 от %2';en='REGISTRY FEES №%1 from %2'"),
								  НомерДок, Формат(Выборка.ДатаРеестра, "ДЛФ=D")); 
			
			ОбластьШапка.Параметры.Заголовок = Заголовок;
			
			ТабличныйДокумент.Вывести(ОбластьШапка);
			
			ВыборкаИзЗапросаОрганизация = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаИзЗапросаОрганизация.Следующий() Цикл
				
				ОбластьОрганизация.Параметры.Организация = ВыборкаИзЗапросаОрганизация.Организация;
				
				ТабличныйДокумент.Вывести(ОбластьОрганизация);
				
				ВыборкаИзЗапросаЗаявка = ВыборкаИзЗапросаОрганизация.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				
				Пока ВыборкаИзЗапросаЗаявка.Следующий() Цикл
					
					ОбластьТабличнаяЧасть.Параметры.Заполнить(ВыборкаИзЗапросаЗаявка);
					
					ЗначениеНомер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыборкаИзЗапросаЗаявка.Заявка, "Номер");
					НомерЗаявки = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ЗначениеНомер);
					Если ТипЗнч(ВыборкаИзЗапросаЗаявка.Заявка) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда			
						ЗаявкаТекст = НСтр("ru='Заявка на расходование №%1 от %2';en='Application for spending №%1 from %2'"); 						
						ЗаявкаТекст = СтрШаблон(ЗаявкаТекст, НомерЗаявки, Формат(ВыборкаИзЗапросаЗаявка.Заявка.Дата, "ДФ = дд.ММ.гггг"));	
					ИначеЕсли ТипЗнч(ВыборкаИзЗапросаЗаявка.Заявка) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда					
						ЗаявкаТекст = НСтр("ru='Заявка на перемещение ДС №%1 от %2';en='Application for moving the DS №%1 from %2'"); 						
						ЗаявкаТекст = СтрШаблон(ЗаявкаТекст, НомерЗаявки, Формат(ВыборкаИзЗапросаЗаявка.Заявка.Дата, "ДФ = дд.ММ.гггг"));	
					ИначеЕсли ТипЗнч(ВыборкаИзЗапросаЗаявка.Заявка) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда						
						ЗаявкаТекст = НСтр("ru='Заявка на перевод ДС в другую организацию №%1 от %2';
										   |en='Application for transfer to another organization DS №%1 from %2'"); 						
						ЗаявкаТекст = СтрШаблон(ЗаявкаТекст, НомерЗаявки, Формат(ВыборкаИзЗапросаЗаявка.Заявка.Дата, "ДФ = дд.ММ.гггг"));	
					Иначе	
						ЗаявкаТекст = ""; 
					КонецЕсли; 
					ОбластьТабличнаяЧасть.Параметры.Заявка = ЗаявкаТекст;
					
					ВалютыРассчетов = бит_Казначейство.ВалютыРассчетов(ВыборкаИзЗапросаЗаявка.ОбъектРасчетов, 
									ВыборкаИзЗапросаЗаявка.БанковскийСчетКасса, ВыборкаИзЗапросаЗаявка.ВалютаДокумента);
									
					ОбластьТабличнаяЧасть.Параметры.ВалютаДокумента = ВалютыРассчетов.ВалютаОплаты;
					
					// Если договор представлен в виде документа.
					Если ЗначениеЗаполнено(ВыборкаИзЗапросаЗаявка.ДоговорКонтрагента) 
						И НЕ ТипЗнч(ВыборкаИзЗапросаЗаявка.ДоговорКонтрагента) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
						ЗначениеНомер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыборкаИзЗапросаЗаявка.ДоговорКонтрагента, "Номер");
						НомерДоговора = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ЗначениеНомер);
						ДоговорТекст = НСтр("ru = '%1 №%2 от %3 %4'; en = '%1 №%2 from %3 %4'");
						ДоговорТекст = СтрШаблон(ДоговорТекст, Строка(ТипЗнч(ВыборкаИзЗапросаЗаявка.ДоговорКонтрагента)),
												 НомерДоговора, Формат(ВыборкаИзЗапросаЗаявка.ДоговорКонтрагента.Дата, "ДЛФ=D"));
						ОбластьТабличнаяЧасть.Параметры.ДоговорКонтрагента = ДоговорТекст;					
					КонецЕсли; 
					
					ОбластьТабличнаяЧасть.Параметры.ДатаПлатежа	= Формат(ВыборкаИзЗапросаЗаявка.ДатаПлан, "ДЛФ=D");
					
					Если ВыборкаИзЗапросаЗаявка.СверхБюджета Тогда
						ТекстСверхБюджета = НСтр("ru = 'Да'; en = 'Yes'"); 
					Иначе
						ТекстСверхБюджета = НСтр("ru = 'Нет'; en = 'No'"); 
					КонецЕсли;
					
					ОбластьТабличнаяЧасть.Параметры.СверхБюджета = ТекстСверхБюджета;
					
					ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияУП(ВыборкаИзЗапросаЗаявка.ХозяйственнаяОперация);
					Если ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствПодотчетнику 
						ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыПоЗарплатномуПроекту
						ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыРаздатчиком
						ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета
						ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыРаботнику Тогда					
						ОбластьТабличнаяЧасть.Параметры.Контрагент = ВыборкаИзЗапросаЗаявка.ФизЛицо;					
					КонецЕсли;	
					
					Проект = ОпределитьПроект(ВыборкаИзЗапросаЗаявка);
					ОбластьТабличнаяЧасть.Параметры.Проект = Проект;
					
					ТабличныйДокумент.Вывести(ОбластьТабличнаяЧасть);
					
				КонецЦикла;	
					
			КонецЦикла;
			
			ТабличныйДокумент.Вывести(ОбластьШапкаИтоги);
			
			РезультатПоиска = РезультатЗапросаИтоги.НайтиСтроки(Отбор);
			Для Каждого Запись Из РезультатПоиска Цикл
				ОбластьИтоги.Параметры.Заполнить(Запись);
				ТабличныйДокумент.Вывести(ОбластьИтоги);
			КонецЦикла;
			
			
			Если БезВиз = Ложь Тогда
				ТабличныйДокумент.Вывести(ОбластьВизыШапка);
				// Заполняем визы
				МассивВиз = РезультатЗапросаВизы.НайтиСтроки(Отбор);
				Для Каждого вТекСтрока Из МассивВиз Цикл
					ОбластьВизыТЧ.Параметры.Заполнить(вТекСтрока);
					ТабличныйДокумент.Вывести(ОбластьВизыТЧ);
				КонецЦикла;
			КонецЕсли;
			
			ТабличныйДокумент.Вывести(ОбластьПодвал);
			
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЦикла;	
	
	КонецЕсли;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуРеестрПлатежей()

// Функция определяет есть ли в аналитиках проект.
//
Функция ОпределитьПроект(Выборка)

	Сч = 0;
	Для Сч = Сч+1 По 7 Цикл
		
		Аналитика = Выборка["Аналитика_" + Сч];
		Если ТипЗнч(Аналитика) = Тип("СправочникСсылка.Проекты") Тогда		
			Проект = Аналитика;		
		КонецЕсли; 
	
	КонецЦикла; 
	
	Возврат Проект;
	
КонецФункции // ОпределитьПроект()

#КонецОбласти

#КонецЕсли
