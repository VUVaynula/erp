// СтандартныеПодсистемы.ВариантыОтчетов
// Определяет список команд отчетов.
//
// Параметры:
//   КомандыОтчетов - ТаблицаЗначений - Таблица с командами отчетов. Для изменения.
//       См. описание 1 параметра процедуры ВариантыОтчетовПереопределяемый.ПередДобавлениемКомандОтчетов().
//   Параметры - Структура - Вспомогательные параметры. Для чтения.
//       См. описание 2 параметра процедуры ВариантыОтчетовПереопределяемый.ПередДобавлениемКомандОтчетов().
//
Процедура ДобавитьКомандыОтчетов(КомандыОтчетов, Параметры) Экспорт
	
	ИнтеграцияИСПереопределяемый.ДобавитьКомандуСтруктураПодчиненности(КомандыОтчетов);
	
	Если ПравоДоступа("Просмотр", Метаданные.Отчеты.бит_РеестрыПлатежей) Тогда
        КомандаОтчет = КомандыОтчетов.Добавить();
		КомандаОтчет.Менеджер			= Метаданные.Отчеты.бит_РеестрыПлатежей.ПолноеИмя();
		КомандаОтчет.Представление		= НСтр("ru = 'Реестр платежей'");
		КомандаОтчет.ИмяПараметраФормы  = "Отбор.РеестрПлатежей";
		КомандаОтчет.РежимЗаписи        = "ЗаписыватьТолькоНовые";
		КомандаОтчет.КлючВарианта 		= "РеестрыПлатежей";
		КомандаОтчет.МножественныйВыбор = Истина;
		КомандаОтчет.Важность			= "Обычное";
		
		КомандаОтчет = КомандыОтчетов.Добавить();
		КомандаОтчет.Менеджер			= Метаданные.Отчеты.бит_РеестрыПлатежей.ПолноеИмя();
		КомандаОтчет.Представление		= НСтр("ru = 'Печатная форма'");
		КомандаОтчет.ИмяПараметраФормы  = "Отбор.РеестрПлатежей";
		КомандаОтчет.РежимЗаписи        = "ЗаписыватьТолькоНовые";
		КомандаОтчет.КлючВарианта 		= "ПечатнаяФорма";
		КомандаОтчет.МножественныйВыбор = Истина;
		КомандаОтчет.Важность			= "Обычное";
	КонецЕсли;

КонецПроцедуры
