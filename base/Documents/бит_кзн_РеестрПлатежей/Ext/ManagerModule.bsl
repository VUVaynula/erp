	Настройки.Вставить("ОтобразитьТаблоСчетов", 				Истина);
	Настройки.Вставить("ИсточникДанныхТабло", 					Перечисления.бит_кзн_РежимОтображенияОстатковДС.ДанныеРегУчета);
	Настройки.Вставить("РежимЗаписиРасчетыЧерезБанк",			Перечисления.бит_РежимыЗаписиДокумента.Запись);
	Настройки.Вставить("РежимЗаписиРасчетыЧерезКассу",			Перечисления.бит_РежимыЗаписиДокумента.Запись);
