#Область ОрганизацияПодбораПлатежныхПозиций

Процедура ИнициализироватьСхемуПодбораДокументовКОплате(КомпоновщикНастроек, АдресСхемыКомпоновкиДанных) Экспорт

	СхемаКомпоновкиДанных = Документы.бит_кзн_РеестрПлатежей.ПолучитьМакет("ПереченьДокументовНаОплату");
	НастройкиИзмерений	  = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");

	бит_МеханизмДопИзмерений.СформироватьЗаголовкиПолейДополнительныхИзмеренийВСКД(СхемаКомпоновкиДанных, 
		"НаборДанных1", НастройкиИзмерений);

	АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных, Новый УникальныйИдентификатор);
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных);
	
	КомпоновщикНастроек.Инициализировать(ИсточникНастроек);
	КомпоновщикНастроек.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);

КонецПроцедуры

// Контруктор параметров бит_Казначейство.ЗаполнитьСписокПодбораДокументовКОплате().
// 
// Возвращаемое значение:
// 	ПараметрыЗаполнения  - структура. 
//
Функция НовыеПараметрыЗаполнитьСхемуПодбораДокументовКОплате() Экспорт

	ПараметрыЗаполнения = Новый Структура;
	
	ПараметрыЗаполнения.Вставить("КомпоновщикНастроек", 		Новый КомпоновщикНастроекКомпоновкиДанных);
	ПараметрыЗаполнения.Вставить("НачалоПериода", 				НачалоДня(ТекущаяДатаСеанса())); 
	ПараметрыЗаполнения.Вставить("КонецПериода", 				КонецДня(ТекущаяДатаСеанса()));
	ПараметрыЗаполнения.Вставить("ДатаОплаты", 					НачалоДня(ТекущаяДатаСеанса())); 
	ПараметрыЗаполнения.Вставить("ВыбранныеДокументы", 			Новый Массив); 
	ПараметрыЗаполнения.Вставить("АдресСхемыКомпоновкиДанных", 	ПоместитьВоВременноеХранилище("", Новый УникальныйИдентификатор));
	ПараметрыЗаполнения.Вставить("РеестрПлатежей", 				Документы.бит_кзн_РеестрПлатежей.ПустаяСсылка());
	
	Возврат ПараметрыЗаполнения;

КонецФункции

// Заполняет спискок выбранными документами.
//
// Параметры:
//  Список				 - ТаблицаЗначений - таблица для заполнения. 
//  ПараметрыЗаполнения	 - Структура - см. бит_Казначейство.НовыеПараметрыЗаполнитьСхемуПодбораДокументовКОплате().
//
Процедура ЗаполнитьСписокПодбораДокументовКОплате(Список, ПараметрыЗаполнения) Экспорт

	КомпоновщикНастроек 		= ПараметрыЗаполнения.КомпоновщикНастроек;
	НачалоПериода 	    		= ПараметрыЗаполнения.НачалоПериода; 
	КонецПериода  	   			= ПараметрыЗаполнения.КонецПериода;
	ДатаОплаты	 	   			= ПараметрыЗаполнения.ДатаОплаты; 
	ВыбранныеДокументы 			= ПараметрыЗаполнения.ВыбранныеДокументы;
	РеестрПлатежей 				= ПараметрыЗаполнения.РеестрПлатежей;
	АдресСхемыКомпоновкиДанных  = ПараметрыЗаполнения.АдресСхемыКомпоновкиДанных;
	
	КонецПериода 	   = КонецДня(?(ЗначениеЗаполнено(КонецПериода), КонецПериода, '2030-12-31'));
	ДатаОплаты		   = ?(ЗначениеЗаполнено(ДатаОплаты), ДатаОплаты, ТекущаяДатаСеанса());
	БазоваяВалюта 	   = Константы.ВалютаРегламентированногоУчета.Получить();
	
	// ВАЖНО. Это валюта упр. учета ЕРП. Используется для получения курсов документов - объектов расчетов.
	ВалютаУпр = ЗначениеНастроекПовтИсп.ВалютаУправленческогоУчета();
	
	бит_ОтчетыСервер.УстановитьЗначениеПараметраКомпоновщика(КомпоновщикНастроек, НачалоПериода, "НачалоПериода");
	бит_ОтчетыСервер.УстановитьЗначениеПараметраКомпоновщика(КомпоновщикНастроек, КонецПериода, "КонецПериода");
	бит_ОтчетыСервер.УстановитьЗначениеПараметраКомпоновщика(КомпоновщикНастроек, ВыбранныеДокументы, "ВыбранныеДокументы");
	бит_ОтчетыСервер.УстановитьЗначениеПараметраКомпоновщика(КомпоновщикНастроек, РеестрПлатежей, "РеестрПлатежей");	
	бит_ОтчетыСервер.УстановитьЗначениеПараметраКомпоновщика(КомпоновщикНастроек, БазоваяВалюта, "БазоваяВалюта");
	бит_ОтчетыСервер.УстановитьЗначениеПараметраКомпоновщика(КомпоновщикНастроек, БазоваяВалюта, "Валюта");
	бит_ОтчетыСервер.УстановитьЗначениеПараметраКомпоновщика(КомпоновщикНастроек, ВалютаУпр, "ВалютаУпр");
	бит_ОтчетыСервер.УстановитьЗначениеПараметраКомпоновщика(КомпоновщикНастроек, ДатаОплаты, "ДатаОплаты");
				
	Настройки = КомпоновщикНастроек.ПолучитьНастройки();
		
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки	  = КомпоновщикМакета.Выполнить(ПолучитьИзВременногоХранилища(АдресСхемыКомпоновкиДанных), 
							Настройки,,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
		
	// Выполнение компоновки с помощью процессора компоновки
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, , , );
		
	Результат = Новый ТаблицаЗначений;

	// Вывод таблицы   	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.ОтображатьПроцентВывода = Истина;
	ПроцессорВывода.УстановитьОбъект(Результат); 	
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);	
	
	Для Каждого СтрокаТаблицы Из Результат Цикл
		НоваяСтрока = Список.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		
		Шаблон = НСтр("ru = '№ %1 от %2'; en = '# %1 from %2'"); 		
		НоваяСтрока.НадписьЗаявка  = СтрШаблон(Шаблон, СтрокаТаблицы.ЗаявкаНомер, Формат(СтрокаТаблицы.ЗаявкаДата, "ДЛФ=D"));
		НоваяСтрока.НадписьПозиция = СтрШаблон(Шаблон, СтрокаТаблицы.ПозицияНомер, 
											Формат(СтрокаТаблицы.ПозицияДата, "ДЛФ=D"));
	КонецЦикла;

КонецПроцедуры

#КонецОбласти // ОрганизацияПодбораПлатежныхПозиций

Процедура ОбработатьПриЗаписиДокументаДДС(ОтражениеФакта) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ОтражениеФакта", ОтражениеФакта);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ФактическиеДанные.Позиция КАК ПлатежнаяПозиция,
	|	ФактическиеДанные.Ссылка.ДокументОснование КАК ДокументОплаты
	|ПОМЕСТИТЬ ПлатежныеПозиции
	|ИЗ
	|	Документ.бит_ОтражениеФактаДДС.ФактическиеДанные КАК ФактическиеДанные
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(ФактическиеДанные.Позиция) = ТИП(Документ.бит_кзн_ПлатежнаяПозиция)
	|	И ФактическиеДанные.Позиция <> ЗНАЧЕНИЕ(Документ.бит_кзн_ПлатежнаяПозиция.ПустаяСсылка)
	|	И ФактическиеДанные.Ссылка = &ОтражениеФакта
	|	И НЕ ФактическиеДанные.Ссылка.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеестрыПлатежей.Ссылка КАК Ссылка,
	|	РеестрыПлатежей.НомерСтроки КАК НомерСтроки,
	|	ПлатежныеПозиции.ДокументОплаты КАК ДокументОплаты
	|ИЗ
	|	Документ.бит_кзн_РеестрПлатежей.ТаблицаПлатежи КАК РеестрыПлатежей
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПлатежныеПозиции КАК ПлатежныеПозиции
	|		ПО РеестрыПлатежей.ПлатежнаяПозиция = ПлатежныеПозиции.ПлатежнаяПозиция
	|ГДЕ
	|	РеестрыПлатежей.ПлатежныйДокумент = НЕОПРЕДЕЛЕНО
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка,
	|	НомерСтроки";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка			 = РезультатЗапроса.Выбрать();
	
	Пока Выборка.СледующийПоЗначениюПоля("Ссылка") Цикл
		ПредставлениеДокумента = Строка(Выборка.Ссылка);
		РеестрПлатежей = Выборка.Ссылка.ПолучитьОбъект(); 	
		Пока Выборка.Следующий() Цикл
			СтрокаТаблицы = РеестрПлатежей.ТаблицаПлатежи[Выборка.НомерСтроки - 1]; 
			СтрокаТаблицы.ПлатежныйДокумент = Выборка.ДокументОплаты;
		КонецЦикла;
		Попытка
			РеестрПлатежей.Заблокировать();
			РежимЗаписи = ?(РеестрПлатежей.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись);
			РеестрПлатежей.Записать(РежимЗаписи);
		Исключение
			ТекстСообщения = НСтр("ru = 'Не удалось установить ссылку на документы оплаты и записать документ ""%1"" по причине: %2'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ПредставлениеДокумента, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ИмяСобытия 	   = НСтр("ru = 'БИТ.ОшибкаЗаписиДокумента'; en = 'BIT.DocumentWritingError'"); 
			Уровень 	   = УровеньЖурналаРегистрации.Предупреждение;
			ЗаписьЖурналаРегистрации(ИмяСобытия, Уровень,, Выборка.Ссылка, ТекстСообщения);
		КонецПопытки;
	КонецЦикла;

КонецПроцедуры

Функция СтатусЗаявкиПравильный(ТекущаяСтрока) Экспорт
	
	ТипСтатуса = Справочники.бит_СтатусыОбъектов.ТипСтатусаОбъкта(ТекущаяСтрока.СтатусЗаявки); 
	СтатусПравильный = ТекущаяСтрока.ПозицияПроведен
						И (ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.Утвержден
						ИЛИ ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен
						ИЛИ ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.ВРеестре);
	
	Возврат СтатусПравильный;
	
КонецФункции

Функция ДанныеПлатежныхПозиций(ПлатежныеПозиции, ВалютаРеглУчета, ДатаОплаты, Организация) Экспорт
	
	Период = ?(ЗначениеЗаполнено(ДатаОплаты), ДатаОплаты, НачалоДня(ТекущаяДатаСеанса()));
	
	Если ЗначениеЗаполнено(Организация) Тогда
		БазоваяВалюта = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Организация);
	Иначе	
		БазоваяВалюта = ВалютаРеглУчета;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПлатежныеПозиции", 	ПлатежныеПозиции);
	Запрос.УстановитьПараметр("ДатаОплаты",       	Период);
	Запрос.УстановитьПараметр("Валюта",  		  	ВалютаРеглУчета);
	Запрос.УстановитьПараметр("БазоваяВалюта",    	БазоваяВалюта);
	// ВАЖНО. Это валюта упр. учета ЕРП. Используется для получения курсов документов - объектов расчетов.
	Запрос.УстановитьПараметр("ВалютаУпр",		  	ЗначениеНастроекПовтИсп.ВалютаУправленческогоУчета());
	
