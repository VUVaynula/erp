			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ТабДок.Ссылка КАК Ссылка,
	ТабДок.ВерсияДанных КАК ВерсияДанных,
	ТабДок.ПометкаУдаления КАК ПометкаУдаления,
	ТабДок.Номер КАК Номер,
	ТабДок.Дата КАК Дата,
	ТабДок.Проведен КАК Проведен,
	ТабДок.Организация КАК Организация,
	ТабДок.ТаблицаПлатежи.(
		Ссылка КАК Ссылка,
		НомерСтроки КАК НомерСтроки,
		ФормаОплаты КАК ФормаОплаты,
		Организация КАК Организация,
		ВалютаДокумента КАК ВалютаДокумента,
		ПлатежнаяПозиция КАК ПлатежнаяПозиция,
		ЗаявкаПлатежнаяПозиция КАК ЗаявкаПлатежнаяПозиция,
		Статус КАК Статус,
		ОдиночнаяПозиция КАК ОдиночнаяПозиция,
		Оплачено КАК Оплачено,
		ЗаблокироватьСтроку КАК ЗаблокироватьСтроку,
		ПлатежныйДокумент КАК ПлатежныйДокумент
	) КАК ТаблицаПлатежи,
	ТабДок.МоментВремени КАК МоментВремени,
	ТабСтатусы.Статус КАК Статус,
	ТабСтатусы.ДатаИзмененияСтатуса КАК ДатаИзмененияСтатуса,
	ТабДок.Комментарий КАК Комментарий,
	ТабДок.Ответственный КАК Ответственный,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА 0
		КОГДА НаличиеФайлов.ЕстьФайлы
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЕстьФайлы
ИЗ
	Документ.бит_кзн_РеестрПлатежей КАК ТабДок
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_СтатусыОбъектов КАК ТабСтатусы
		ПО ТабДок.Ссылка = ТабСтатусы.Объект
			И (ТабСтатусы.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус)),
	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО ТабДок.Ссылка = НаличиеФайлов.ОбъектСФайлами</QueryText>
				<MainTable>Document.бит_кзн_РеестрПлатежей</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
