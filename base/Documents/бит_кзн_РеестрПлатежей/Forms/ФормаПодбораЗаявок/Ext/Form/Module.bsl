
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	
	ДатаОплаты = Параметры.ДатаОплаты;
	
	Заголовок = НСтр("ru='Подбор заявок на расходование денежных средств';
						 |en='Selection of requests for spending money'");

	Если ЭтоАдресВременногоХранилища(Параметры.АдресВХранилище) Тогда
		ВыбранныеДокументы.ЗагрузитьЗначения(ПолучитьИзВременногоХранилища(Параметры.АдресВХранилище));
	КонецЕсли;
	
	ПараметрыПередачи = Новый Структура;
	УстановитьКлючиСохраненныхНастроек(ПараметрыПередачи);
	НастройкаПоУмолчанию = бит_ОтчетыСервер.НайтиНастройкуПоУмолчаниюДляОбъекта(ПараметрыПередачи.НастраиваемыйОбъект);
		
	ИнициализироватьСхемуПодбораДаных();
	
	ПрименитьНастройки(НастройкаПоУмолчанию);

	Если ЗначениеЗаполнено(Параметры.Организация) И ОтборОрганизация <> Параметры.Организация Тогда
		// Организация, переданная как параметр, имеет высокий приоритет.
		ОтборОрганизация = Параметры.Организация;
		УстановитьОтборПоОрганизации();
	КонецЕсли;
	
	Если Период.Вариант = ВариантСтандартногоПериода.ПроизвольныйПериод Тогда
		Если ЗначениеЗаполнено(Параметры.НачалоПериода) Тогда
			НачалоПериода = Параметры.НачалоПериода;
		КонецЕсли;
		Если ЗначениеЗаполнено(Параметры.КонецПериода) Тогда
			КонецПериода = Параметры.КонецПериода;
		КонецЕсли;
		Период.ДатаНачала 	 = НачалоПериода;
		Период.ДатаОкончания = КонецДня(КонецПериода);
	КонецЕсли;

	РеестрПлатежей = Параметры.РеестрПлатежей;

	бит_ОтчетыСервер.УстановитьЗначениеПараметраКомпоновщика(КомпоновщикНастроек,
		РеестрПлатежей, "РеестрПлатежей");
		
	бит_ОтчетыСервер.УстановитьЗначениеПараметраКомпоновщика(КомпоновщикНастроек,
		Константы.ВалютаРегламентированногоУчета.Получить(), "ВалютаРегламентированногоУчета");
		
	УстановитьСостояниеСписка(ЭтотОбъект, Истина);
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	Если ЗначениеЗаполнено(КонецПериода) И НачалоПериода > КонецПериода Тогда
		ТекстСообщения = НСтр("ru = 'Дата начала периода не может быть больше даты конца периода'; 
							|en = 'The start date is greater than the end date.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,, "НачалоПериода",, Отказ);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НачалоПериодаПриИзменении(Элемент)
	
	Период.ДатаНачала = НачалоПериода;
	УстановитьСостояниеСписка(ЭтотОбъект, Истина);

КонецПроцедуры

&НаКлиенте
Процедура КонецПериодаПриИзменении(Элемент)
	
	Период.ДатаОкончания = КонецДня(КонецПериода);
	УстановитьСостояниеСписка(ЭтотОбъект, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборОрганизацияПриИзменении(Элемент)
	
	УстановитьОтборПоОрганизации();
	УстановитьСостояниеСписка(ЭтотОбъект, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	
	Если Поле = Элементы.СписокПометка Тогда

		ТекущиеДанные.Пометка = НЕ ТекущиеДанные.Пометка;
		
	ИначеЕсли Поле = Элементы.СписокНадписьЗаявка Тогда
		
		СтандартнаяОбработка = Ложь;
		ИмяФормыОбъекта		 = "Документ.бит_кзн_ЗаявкаНаРасходованиеСредств.ФормаОбъекта";
		
		Если ТипЗнч(ТекущиеДанные.ЗаявкаПлатежнаяПозиция) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда
			ИмяФормыОбъекта = "Документ.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию.ФормаОбъекта"; 
		ИначеЕсли ТипЗнч(ТекущиеДанные.ЗаявкаПлатежнаяПозиция) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда
			ИмяФормыОбъекта = "Документ.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.ФормаОбъекта"; 
		КонецЕсли;
		
		ПараметрыФормы = Новый Структура("Ключ", ТекущиеДанные.ЗаявкаПлатежнаяПозиция);
		ОткрытьФорму(ИмяФормыОбъекта, ПараметрыФормы, ЭтотОбъект, ТекущиеДанные.ЗаявкаПлатежнаяПозиция);
		
	ИначеЕсли Поле = Элементы.СписокНадписьПозиция Тогда
		
		СтандартнаяОбработка = Ложь;
		ПараметрыФормы = Новый Структура("Ключ", ТекущиеДанные.ПлатежнаяПозиция);
		
		ОткрытьФорму("Документ.бит_кзн_ПлатежнаяПозиция.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект, 
			ТекущиеДанные.ПлатежнаяПозиция);
			
	Иначе
		бит_РаботаСДиалогамиКлиент.ОбработкаВыбораПоляТабличногоПоля("Список", 
			Список, Поле, ВыбраннаяСтрока);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыбратьПериод(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ВыбратьПериодЗавершение", ЭтотОбъект);
	
	ВыборПериода = Новый ДиалогРедактированияСтандартногоПериода;
	ВыборПериода.Период = Период;
	ВыборПериода.Показать(ОписаниеОповещения);

КонецПроцедуры

// Обработчик завершения редактирования периода.
//  См. Синтакс-помощник: Показать().
//
&НаКлиенте
Процедура ВыбратьПериодЗавершение(РезультатВыбора, ДопПараметры) Экспорт
	
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Период 		  = РезультатВыбора;
	НачалоПериода = РезультатВыбора.ДатаНачала;
	КонецПериода  = РезультатВыбора.ДатаОкончания;
	
	УстановитьСостояниеСписка(ЭтотОбъект, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиЗаявки(Команда)
	
	РезультатПодбора = Новый Массив; 
	Для каждого СтрокаТаблицы Из Список Цикл
		Если СтрокаТаблицы.Пометка Тогда
			РезультатПодбора.Добавить(ЭлементРезультатаПодбора(СтрокаТаблицы));
		КонецЕсли;
	КонецЦикла; 
	
	Если РезультатПодбора.Количество() > 0 Тогда
		ОповеститьВладельцаОВыборе(РезультатПодбора);
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ПеренестиЗаявкиЗавершение", ЭтотОбъект); 
	Если РезультатПодбора.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru = 'Нет выбранных элементов. Закрыть форму подбора?'; 
							  |en = 'No selected items. Close the selection form?'");
		ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет);
	Иначе
		ВыполнитьОбработкуОповещения(Оповещение, КодВозвратаДиалога.Да);
	КонецЕсли;
	
КонецПроцедуры
 
// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура ПеренестиЗаявкиЗавершение(Результат, Дополнительно) Экспорт

	Если Результат = КодВозвратаДиалога.Да Тогда
		Закрыть();
	КонецЕсли;

КонецПроцедуры
 
&НаКлиенте
Процедура ПоказатьНастройки(Команда)
	
	ОткрытьНастройки();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьНастройки(Команда)
	
	СкрытьНастройки();

КонецПроцедуры

&НаКлиенте
Процедура Сформировать(Команда)
	
	ОчиститьСообщения();
	
	Если ПроверитьЗаполнение() Тогда
		СкрытьНастройки();
		УстановитьСостояниеСписка(ЭтотОбъект, Ложь);
		УИДЗамера = ОценкаПроизводительностиКлиент.ЗамерВремени("бит_РеестрПлатежейПодборЗаявокОбновлениеСписка",,Ложь);
		ОбновитьСписок();
		ОценкаПроизводительностиКлиент.ЗавершитьЗамерВремени(УИДЗамера);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьНастройки(Кнопка)
	
	ПараметрыФормы     = Новый Структура;
	ПараметрыФормы.Вставить("СтруктураНастройки" , СохраняемыеНастройки());
	УстановитьКлючиСохраненныхНастроек(ПараметрыФормы);
	
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаСохранения", ПараметрыФормы, ЭтотОбъект,,,,, 
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
Процедура ВосстановитьНастройки(Кнопка)
	
	ПараметрыФормы     = Новый Структура;
	УстановитьКлючиСохраненныхНастроек(ПараметрыФормы);
	
	Оповещение = Новый ОписаниеОповещения("ВосстановитьНастройкиЗавершение",ЭтотОбъект);
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаЗагрузки", ПараметрыФормы, ЭтотОбъект,,,,
		Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры
      
// Процедура - обработчик оповещения о закрытии формы применения настроек. 
// 
&НаКлиенте 
Процедура ВосстановитьНастройкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда        
		ПрименитьНастройки(Результат);
		УстановитьСостояниеСписка(ЭтотОбъект, Истина);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПометки(Команда)
	
	ИзменитьПометки(1);  
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьПометки(Команда)
	
	ИзменитьПометки(0);

КонецПроцедуры

&НаКлиенте
Процедура СтандартныеНастройкиОтбора(Команда)
	
	ИнициализироватьСхемуПодбораДаных();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ИзменитьПометки(Пометка)

	бит_РаботаСДиалогамиКлиент.ОбработатьФлагиТаблицы(Список, "Пометка", Пометка, Элементы.Список);
	
КонецПроцедуры
 
&НаСервере
Процедура ИнициализироватьСхемуПодбораДаных()

	Документы.бит_кзн_РеестрПлатежей.ИнициализироватьСхемуПодбораДокументовКОплате(КомпоновщикНастроек, АдресСхемыКомпоновкиДанных);
	
КонецПроцедуры
 
&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьКлючиСохраненныхНастроек(ПараметрыПередачи)

	ПараметрыПередачи.Вставить("ТипНастройки", 
		ПредопределенноеЗначение("Перечисление.бит_ТипыСохраненныхНастроек.Обработки"));
	ПараметрыПередачи.Вставить("НастраиваемыйОбъект", "Документ.бит_кзн_РеестрПлатежей.ФормаПодбораЗаявок");
	
КонецПроцедуры
 
&НаСервере
Процедура УстановитьОтборПоОрганизации()
	
	ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(
		КомпоновщикНастроек.Настройки.Отбор, "Организация");
		
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
		КомпоновщикНастроек.Настройки.Отбор, "Организация",
		ОтборОрганизация, Неопределено,, ЗначениеЗаполнено(ОтборОрганизация));
		
КонецПроцедуры
		 
&НаСервере
Процедура ПрименитьНастройки(Настройки)

	Если НЕ ЗначениеЗаполнено(НачалоПериода) Тогда
		НачалоПериода = ТекущаяДатаСеанса();
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(КонецПериода) Тогда
		КонецПериода = ТекущаяДатаСеанса();
	КонецЕсли; 

	Если НЕ ЗначениеЗаполнено(Настройки) Тогда	
		Период = Новый СтандартныйПериод(НачалоПериода, КонецПериода);
	Иначе
		СохраненныеНастройки = Настройки.ХранилищеНастроек.Получить();
		ПользовательскиеНастройки = Неопределено;
		Если ТипЗнч(СохраненныеНастройки) = Тип("Структура") 
			И СохраненныеНастройки.Свойство("ПользовательскиеНастройки") Тогда
			
			ПользовательскиеНастройки = СохраненныеНастройки.ПользовательскиеНастройки;
			Если ТипЗнч(ПользовательскиеНастройки) = Тип("ПользовательскиеНастройкиКомпоновкиДанных") Тогда
				ТекстСообщения = НСтр("ru = 'Не удалось восстановить сохраненные настройки.'; 
									|en = 'Invalid call of the object on the client.'");
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			Иначе	
				КомпоновщикНастроек.ЗагрузитьНастройки(ПользовательскиеНастройки);
				КомпоновщикНастроек.Восстановить();
			КонецЕсли;
						
			Период = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
						ПользовательскиеНастройки.ДополнительныеСвойства, "Период",
						Новый СтандартныйПериод(НачалоПериода, КонецПериода));
			НачалоПериода = Период.ДатаНачала;
			КонецПериода  = Период.ДатаОкончания;
			
			Если НЕ ЗначениеЗаполнено(Параметры.Организация) Тогда
				ОтборОрганизация = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
										ПользовательскиеНастройки.ДополнительныеСвойства, "Организация",
										ОтборОрганизация);
			КонецЕсли;				
		Иначе
			ТекстСообщения = НСтр("ru = 'Настройки не восстановлены.'; en = 'Settings not restored.'"); 
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;  		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСписок()

	ПараметрыЗаполнения = Документы.бит_кзн_РеестрПлатежей.НовыеПараметрыЗаполнитьСхемуПодбораДокументовКОплате(); 
	
	ПараметрыЗаполнения.КомпоновщикНастроек 		= КомпоновщикНастроек;
	ПараметрыЗаполнения.НачалоПериода 	    		= НачалоПериода; 
	ПараметрыЗаполнения.КонецПериода  	   			= КонецПериода;
	ПараметрыЗаполнения.ДатаОплаты	 	   			= ДатаОплаты; 
	ПараметрыЗаполнения.ВыбранныеДокументы 			= ВыбранныеДокументы;
	ПараметрыЗаполнения.АдресСхемыКомпоновкиДанных 	= АдресСхемыКомпоновкиДанных;
	ПараметрыЗаполнения.РеестрПлатежей 				= РеестрПлатежей;
	
	Список.Очистить();
	Результат = РеквизитФормыВЗначение("Список");
	Документы.бит_кзн_РеестрПлатежей.ЗаполнитьСписокПодбораДокументовКОплате(Результат, ПараметрыЗаполнения);
	ЗначениеВРеквизитФормы(Результат, "Список");
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНастройки()
	
	Элементы.РазделыПодбора.ТекущаяСтраница = Элементы.НастройкиПодбора;
	Элементы.ПрименитьНастройки.КнопкаПоУмолчанию = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура СкрытьНастройки()

	Элементы.РазделыПодбора.ТекущаяСтраница = Элементы.Подбор;
	Элементы.Сформировать.КнопкаПоУмолчанию = Истина;
	
КонецПроцедуры

&НаСервере
Функция СохраняемыеНастройки()

	ПользовательскиеНастройки = КомпоновщикНастроек.ПолучитьНастройки();
	ПользовательскиеНастройки.ДополнительныеСвойства.Вставить("Период", 	 Период);
	ПользовательскиеНастройки.ДополнительныеСвойства.Вставить("Организация", ОтборОрганизация);
	
	СохраняемыеНастройки = Новый Структура;
	СохраняемыеНастройки.Вставить("ПользовательскиеНастройки", ПользовательскиеНастройки);
	
	Возврат СохраняемыеНастройки;
	
КонецФункции

&НаКлиенте
Функция ЭлементРезультатаПодбора(СтрокаСДанными)
	
	ЭлементПодбора = Новый Структура();
	ЭлементПодбора.Вставить("ФормаОплаты");
	ЭлементПодбора.Вставить("Организация");
	ЭлементПодбора.Вставить("ВалютаДокумента");
	ЭлементПодбора.Вставить("ПлатежнаяПозиция");
	ЭлементПодбора.Вставить("ЗаявкаПлатежнаяПозиция");
	ЭлементПодбора.Вставить("СуммаКОплате");
	ЭлементПодбора.Вставить("СуммаДокумента");
	ЭлементПодбора.Вставить("ВалютаПлатежа");
	ЭлементПодбора.Вставить("СуммаПлан");
	ЭлементПодбора.Вставить("СуммаОстаток");
	// Добавленные колонки таблицы Реестра платежей.
	ЭлементПодбора.Вставить("СчетКасса");
	ЭлементПодбора.Вставить("СтатусЗаявки");
	ЭлементПодбора.Вставить("ЗаявкаНомер");
	ЭлементПодбора.Вставить("ЗаявкаДата");
	ЭлементПодбора.Вставить("ЗаявкаВажность");
	ЭлементПодбора.Вставить("ПозицияСостояние");
	ЭлементПодбора.Вставить("ЗаявкаСостояние");
	ЭлементПодбора.Вставить("ПозицияНазначениеПлатежа");
	ЭлементПодбора.Вставить("ПозицияПроведен");
	ЭлементПодбора.Вставить("НадписьЗаявка");
	ЭлементПодбора.Вставить("ПозицияНомер");
	ЭлементПодбора.Вставить("ПозицияДата");
	ЭлементПодбора.Вставить("НадписьПозиция");
	ЭлементПодбора.Вставить("ДатаПлан");
	ЭлементПодбора.Вставить("ДатаПланКрайняя");
	ЭлементПодбора.Вставить("КурсЗнаменательВзаиморасчетов");
	ЭлементПодбора.Вставить("КурсЧислительВзаиморасчетов");
	
	ЗаполнитьЗначенияСвойств(ЭлементПодбора, СтрокаСДанными); 
	Возврат ЭлементПодбора;
	
КонецФункции

