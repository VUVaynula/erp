&НаСервере
Процедура УстановитьУсловноеОформление()

	// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
	УсловноеОформление.Элементы.Очистить();
			
	// ТаблоСчетов
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ТаблоСчетов");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ТаблоСчетов.СуммаКонОстаток", ВидСравненияКомпоновкиДанных.Меньше, 0);
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветОтрицательногоЧисла);
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ТаблоСчетов");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ТаблоСчетов.КонтрольнаяСумма", ВидСравненияКомпоновкиДанных.Равно, Новый ПолеКомпоновкиДанных("ТекущаяКонтрольнаяСумма"));
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ТаблоСчетов.КонтрольнаяСумма", ВидСравненияКомпоновкиДанных.Заполнено, "");
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Шрифт", ШрифтыСтиля.бит_ОсновнойЭлементСписка);
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ТаблоСчетовСуммаПриход");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		Новый ПолеКомпоновкиДанных("ПоказыватьСуммуПланируемыхПоступлений"), ВидСравненияКомпоновкиДанных.Равно, Ложь);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ТаблоСчетов.КонтрольнаяСумма", ВидСравненияКомпоновкиДанных.Заполнено, "");
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.бит_ТекстНедоступнойНадписи);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru='<не требуется>';en='<not required>'"));
		
	// ТаблицаПлатежиСчетКасса, ТаблицаПлатежиСуммаКОплате.
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ТаблицаПлатежиСчетКасса");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ТаблицаПлатежиСуммаКОплате");
	
	ГруппаИЛИ = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(ЭлементУО.Отбор.Элементы, "",
					ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаИЛИ,
		"Объект.ТаблицаПлатежи.ПлатежныйДокумент", ВидСравненияКомпоновкиДанных.Заполнено, "");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаИЛИ,
		"Объект.ТаблицаПлатежи.СтатусЗаявкиПравильный", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);

	// ТаблицаПлатежиОплачено.
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ТаблицаПлатежиОплачено");
	ГруппаИЛИ = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(ЭлементУО.Отбор.Элементы, "",
					ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаИЛИ,
		"Объект.ТаблицаПлатежи.ПлатежныйДокумент", ВидСравненияКомпоновкиДанных.Заполнено, "");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаИЛИ,
		"Объект.ТаблицаПлатежи.СтатусЗаявкиПравильный", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаИЛИ,
		"Объект.ТаблицаПлатежи.СуммаКОплате", ВидСравненияКомпоновкиДанных.Равно, 0);
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);

	// ТаблоПлатежейСуммаКОплате
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ТаблоПлатежейСуммаКОплате");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ТаблоПлатежей.СуммаКОплате", ВидСравненияКомпоновкиДанных.НеРавно, Новый ПолеКомпоновкиДанных("ТаблоПлатежей.СуммаОплачено"));
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.бит_ЦветЗаголовкаСтатуса);
	
	// АПК:277-вкл
	
КонецПроцедуры

// Заполняет реквизиты таблицы из платежных позиций. 
// Состав заполняемых реквизитов определяется значением параметра РежимЗаполнения.
//
// Параметры:
//  РежимЗаполнения	 - Число - режим копирования данных платежных позиций:
//		0 - заполнение полей формы по данным платежной позиции,
//		1 - заполнение полей формы и объекта по данным платежной позиции.
// ПроверятьЗаполнение - Булево - проверить совпадение полей объекта по данным платежной позиции.
//								  Проверка не требуется при заполнении полей формы "После записи" 
//								  и в режиме заполнения 1.
//
&НаСервере
Процедура ЗаполнитьДобавленныеКолонкиТаблиц(РежимЗаполнения, ПроверятьЗаполнение = Истина)
	
	ПлатежныеПозиции = Объект.ТаблицаПлатежи.Выгрузить(, "ПлатежнаяПозиция").ВыгрузитьКолонку("ПлатежнаяПозиция");
	ДанныеПозиций 	 = ДанныеПлатежныхПозиций(ПлатежныеПозиции);

	СнятьПометкуПостоянныхДанныхПлатежнойПозиции();
	
	Для Каждого ТекущаяСтрока Из Объект.ТаблицаПлатежи Цикл
		ЗаполнитьДобавленныеКолонкиСтроки(ТекущаяСтрока, ДанныеПозиций, РежимЗаполнения, ПроверятьЗаполнение);
	КонецЦикла;

КонецПроцедуры

// См. ЗаполнитьДобавленныеКолонкиТаблиц().
&НаСервере
Процедура ЗаполнитьДобавленныеКолонкиСтроки(ТекущаяСтрока, ДанныеПозиций, РежимЗаполнения, ПроверятьЗаполнение)

	Если НЕ ЗначениеЗаполнено(ТекущаяСтрока.ПлатежнаяПозиция) Тогда
		Возврат;	
	КонецЕсли;
	
	РезультатПоиска = ДанныеПозиций.Найти(ТекущаяСтрока.ПлатежнаяПозиция, "ПлатежнаяПозиция");
	Если РезультатПоиска = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	ДанныеЗаполнения = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(РезультатПоиска);
	
	ЕстьРазличия = Ложь;
	Сумма 		 = ТекущаяСтрока.СуммаДокумента;
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.ПлатежныйДокумент) Тогда
		// Вычислим курс фактической оплаты, что бы показать в списке.
		Если ТекущаяСтрока.СуммаОстаток <> 0 И ТекущаяСтрока.СуммаКОплате <> 0 Тогда
			ДанныеЗаполнения.КурсЗнаменательВзаиморасчетов = 1;
			ДанныеЗаполнения.КурсЧислительВзаиморасчетов = ОКР(ТекущаяСтрока.СуммаКОплате / ТекущаяСтрока.СуммаОстаток, 4);			
		КонецЕсли;
	КонецЕсли;

	Если РежимЗаполнения = 0 Тогда
		ПостоянныеСвойстваПозиций = ОбщегоНазначенияКлиентСервер.КлючиСтруктурыВСтроку(ПостоянныеСвойстваПозиций(), ",");
		
		// ВАЖНО. Здесь в строчках ТЧ, где нет документов оплаты, меняются данные (СуммаКОплате, СуммаПлан).
		// Однако, форма не модифицируется потому, что, до оплаты, это условнопостоянные величины,
		// зависящие от курса и суммы в валюте планирования.
		Если ЗначениеЗаполнено(ТекущаяСтрока.ПлатежныйДокумент) Тогда
			ПостоянныеСвойстваПозиций = ПостоянныеСвойстваПозиций + ", СуммаОстаток, СуммаКОплате, СуммаПлан";
		Иначе
			ПостоянныеСвойстваПозиций = ПостоянныеСвойстваПозиций + ", СуммаОстаток";
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(ТекущаяСтрока, ДанныеЗаполнения,, ПостоянныеСвойстваПозиций);
		Если ПроверятьЗаполнение Тогда
			ПроверитьЗаполнениеПостоянныхДанныхПлатежнойПозиции(ТекущаяСтрока, ДанныеЗаполнения, ЕстьРазличия, Истина);
		КонецЕсли;
	Иначе	
		Если ПроверятьЗаполнение Тогда
			ПроверитьЗаполнениеПостоянныхДанныхПлатежнойПозиции(ТекущаяСтрока, ДанныеЗаполнения, ЕстьРазличия, Ложь);
			ЗаполнитьЗначенияСвойств(ТекущаяСтрока, ДанныеЗаполнения);
			Если ЕстьРазличия Тогда
				Модифицированность = Истина;
			КонецЕсли;
		Иначе	
			ЗаполнитьЗначенияСвойств(ТекущаяСтрока, ДанныеЗаполнения);
		КонецЕсли;
	КонецЕсли;

	СформироватьКурсЗнаменательТекстом(ТекущаяСтрока);
	
	Шаблон = НСтр("ru = '№ %1 от %2'; en = '# %1 from %2'"); 		
	ТекущаяСтрока.НадписьЗаявка  = СтрШаблон(Шаблон, ТекущаяСтрока.ЗаявкаНомер, Формат(ТекущаяСтрока.ЗаявкаДата, "ДЛФ=D"));
	ТекущаяСтрока.НадписьПозиция = СтрШаблон(Шаблон, ТекущаяСтрока.ПозицияНомер, 
										Формат(ТекущаяСтрока.ПозицияДата, "ДЛФ=D"));

	Если РежимЗаполнения = 1 Тогда
		Если Сумма <> ТекущаяСтрока.СуммаДокумента Тогда
			Если ПроверятьЗаполнение Тогда
				Пояснение = НСтр("ru = 'Изменилась сумма позиции. Вычисленное значение отличается от значения в документе. Было: %1, стало: %2.';
								 |en = 'The calculated value differs from the value in the document.'"); 
				Пояснение  = СтрШаблон(Пояснение, Формат(Сумма, "ЧДЦ=2; ЧН="), 
								Формат(ТекущаяСтрока.СуммаДокумента, "ЧДЦ=2; ЧН="));
				
				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка" , "Корректность",
									НСтр("ru = 'Сумма документа'; en = 'Document Total Amount'") , ТекущаяСтрока.НомерСтроки, 
									НСтр("ru = 'Платежи'; en = 'Payments'"), Пояснение);
				
				Поле = "ТаблицаПлатежи[%1].СуммаДокумента";
				Поле = СтрШаблон(Поле, Формат(ТекущаяСтрока.НомерСтроки - 1, "ЧН=0; ЧГ="));	
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , Поле, "Объект"); 	
			КонецЕсли;
			
			ТекущаяСтрока.СуммаОстаток = ДанныеЗаполнения.СуммаОстаток;
			ТекущаяСтрока.СуммаКОплате = ДанныеЗаполнения.СуммаКОплате;
			ТекущаяСтрока.СуммаПлан	   = ДанныеЗаполнения.СуммаПлан;
		КонецЕсли;
	КонецЕсли;
		
	ТекущаяСтрока.СтатусЗаявкиПравильный = СтатусЗаявкиПравильный(ТекущаяСтрока);
	ТекущаяСтрока.КонтрольнаяСумма		 = КонтрольнаяСуммаСтрокой(ТекущаяСтрока.СчетКасса, 
												ТекущаяСтрока.Организация);

КонецПроцедуры
 
&НаСервере
Функция ДанныеПлатежныхПозиций(ПлатежныеПозиции)
	
	Возврат Документы.бит_кзн_РеестрПлатежей.ДанныеПлатежныхПозиций(ПлатежныеПозиции, ВалютаРеглУчета, ДатаОплаты,
	    Объект.Организация);
	
КонецФункции
 
&НаСервере
Функция КонтрольнаяСуммаСтрокой(БанковскийСчет, Организация)
		
	Данные = Новый Массив(); 
	Данные.Добавить(БанковскийСчет);
	Данные.Добавить(Организация);
	
	Возврат ОбщегоНазначения.КонтрольнаяСуммаСтрокой(Данные);
		
КонецФункции

&НаСервере
Функция ПостоянныеСвойстваПозиций()
	
	Возврат Документы.бит_кзн_РеестрПлатежей.ПостоянныеСвойстваПозиций();
	
КонецФункции
 
// Проверяет совпадение данных документа и постоянных данных платежной позиции.
// См. ЗаполнитьДобавленныеКолонкиСтроки().
&НаСервере
Процедура ПроверитьЗаполнениеПостоянныхДанныхПлатежнойПозиции(ТекущаяСтрока, ДанныеПозиции, ЕстьРазличия, СообщитьОРазличиях)
	
	ПоляДляПроверки = ПостоянныеСвойстваПозиций();
	Для каждого КлючЗначение Из ПоляДляПроверки Цикл
		ИмяПоля			   = КлючЗначение.Ключ;
		ПараметрыСообщения = КлючЗначение.Значение;
		Если ТекущаяСтрока[ИмяПоля] <> ДанныеПозиции[ИмяПоля] Тогда
			ПараметрыСообщения.НомерСтроки = ТекущаяСтрока.НомерСтроки;
			ЕстьРазличия = Истина;
			Если СообщитьОРазличиях Тогда
				СообщитьОНесовпаденииДанных(ПараметрыСообщения);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла; 
	
КонецПроцедуры

// Снимает пометку незаполненного, установленную при проверке, после повторного заполнения.
// См. ПроверитьЗаполнениеПостоянныхДанныхПлатежнойПозиции().
&НаСервере
Процедура СнятьПометкуПостоянныхДанныхПлатежнойПозиции()

	ПоляДляПроверки = ПостоянныеСвойстваПозиций();
	Для каждого КлючЗначение Из ПоляДляПроверки Цикл
		ИмяПоля = КлючЗначение.Ключ;	
		ИмяЭлемента = СтрШаблон("ТаблицаПлатежи%1",ИмяПоля); 
		Элементы[ИмяЭлемента].ОтметкаНезаполненного = Ложь;
	КонецЦикла; 

КонецПроцедуры
 
&НаСервере
Процедура СообщитьОНесовпаденииДанных(ПараметрыСообщения)

	Пояснение = НСтр("ru = 'Значение отличается от значения в платежной позиции. Обновите список заявок.';
							|en = 'The value differs from the value in the payment item.'"); 

	ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка" , "Корректность",
		ПараметрыСообщения.СинонимПоля, ПараметрыСообщения.НомерСтроки, ПараметрыСообщения.ИмяСписка, Пояснение);
		
	Поле = "ТаблицаПлатежи[%1].%2";
	Поле = СтрШаблон(Поле, Формат(ПараметрыСообщения.НомерСтроки - 1, "ЧН=0; ЧГ="), ПараметрыСообщения.ИмяПоля);	
	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , Поле, "Объект"); 

КонецПроцедуры

&НаСервере
Процедура ОбработатьИзмененияВПлатежнойПозиции(Идентификаторы)
	
	ВыбранныеСтроки	 	 = Новый Массив; 
	ПлатежныеПозиции	 = Новый Массив; 
	ДополнительныйСписок = Новый Массив;
	
	Если ТипЗнч(Идентификаторы) = Тип("Массив") Тогда
		Для каждого Идентификатор Из Идентификаторы Цикл
			ТекущаяСтрока = Объект.ТаблицаПлатежи.НайтиПоИдентификатору(Идентификатор); 
			ВыбранныеСтроки.Добавить(ТекущаяСтрока);	
			ПлатежныеПозиции.Добавить(ТекущаяСтрока.ПлатежнаяПозиция);
		КонецЦикла; 
	Иначе	
		ТекущаяСтрока 	 = Объект.ТаблицаПлатежи.НайтиПоИдентификатору(Идентификаторы);
		ВыбранныеСтроки  = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ТекущаяСтрока);
		ПлатежныеПозиции = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ТекущаяСтрока.ПлатежнаяПозиция);
	КонецЕсли;

	ДанныеПозиций 	= ДанныеПлатежныхПозиций(ПлатежныеПозиции);
	РежимЗаполнения = 1;
	
	Для каждого СтрокаТаблицы Из ВыбранныеСтроки Цикл
		ЗаполнитьДобавленныеКолонкиСтроки(СтрокаТаблицы, ДанныеПозиций, РежимЗаполнения, Истина);
	КонецЦикла; 

КонецПроцедуры

&НаКлиенте 
Процедура УправлениеТаблоСчетов()
	
	Если Элементы.ТаблоСчетов.Видимость <> ОтобразитьТаблоСчетов Тогда
		Элементы.ТаблоСчетов.Видимость = ОтобразитьТаблоСчетов;		
	КонецЕсли;
	
	Если ОтобразитьТаблоСчетов Тогда
		ТекстСообщения = НСтр("ru = 'Скрыть табло счетов'; en = 'Hide Accounts board'");
	Иначе	
		ТекстСообщения = НСтр("ru = 'Показать табло счетов'; en = 'Show Accounts board'");
	КонецЕсли;
	
	Элементы.ФормаОтобразитьСкрытьТаблоСчетов.Пометка 						= ОтобразитьТаблоСчетов;
	Элементы.ФормаОтобразитьСкрытьТаблоСчетовРасширеннаяПодсказка.Заголовок = ТекстСообщения;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКэшЗначений()
	
	КэшЗначений = Новый Структура;
	КэшЗначений.Вставить("ИзмеренияДоп"	     , бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Дополнительные","Синоним"));
	КэшЗначений.Вставить("НастройкиИзмерений", бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений"));
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)

	Элементы = Форма.Элементы;
	Объект	 = Форма.Объект;
	
	бит_НастройкиДоступностиЭлементовФормКлиентСервер.РазблокироватьЭлементы(Форма);
			
	бит_НастройкиДоступностиЭлементовФормКлиентСервер.ЗаблокироватьЭлементы(Форма);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаСегодняНаСервере()
												
	КомпоновщикНастроек 	   = Новый КомпоновщикНастроекКомпоновкиДанных;
	АдресСхемыКомпоновкиДанных = "";
	
	Документы.бит_кзн_РеестрПлатежей.ИнициализироватьСхемуПодбораДокументовКОплате(КомпоновщикНастроек, АдресСхемыКомпоновкиДанных);
	
	ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(
		КомпоновщикНастроек.Настройки.Отбор, "Организация");
		
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
		КомпоновщикНастроек.Настройки.Отбор, "Организация",
		Объект.Организация, Неопределено,, ЗначениеЗаполнено(Объект.Организация));
		
	ПараметрыЗаполнения = Документы.бит_кзн_РеестрПлатежей.НовыеПараметрыЗаполнитьСхемуПодбораДокументовКОплате();
	Период = ?(ЗначениеЗаполнено(ДатаОплаты), ДатаОплаты, НачалоДня(ТекущаяДатаСеанса()));
	
	ПараметрыЗаполнения.КомпоновщикНастроек 		= КомпоновщикНастроек;
	ПараметрыЗаполнения.НачалоПериода 	    		= Период; 
	ПараметрыЗаполнения.КонецПериода  	   			= КонецДня(Период);
	ПараметрыЗаполнения.ДатаОплаты	 	   			= Период; 
	ПараметрыЗаполнения.АдресСхемыКомпоновкиДанных 	= АдресСхемыКомпоновкиДанных;
	ПараметрыЗаполнения.РеестрПлатежей 				= Объект.Ссылка;
	
	Объект.ТаблицаПлатежи.Очистить();
	Результат = Объект.ТаблицаПлатежи.Выгрузить();
	
	Документы.бит_кзн_РеестрПлатежей.ЗаполнитьСписокПодбораДокументовКОплате(Результат, ПараметрыЗаполнения);
	
	Если ЗначениеЗаполнено(Результат) Тогда
		Объект.ТаблицаПлатежи.Очистить();
		ПодборВРеестрПлатежейЗавершение(Результат);	
		ОбновитьИнформационныеТаблоНаСервере(Истина, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОплатитьДокумент(Заявка, ПлатежныеПозиции, ОплаченныеДокументы)
	
	Если НЕ ЗначениеЗаполнено(ПлатежныеПозиции) Тогда // ТекущиеДанные
		Возврат;
	КонецЕсли;
	
	// Беру данные первой строки потому, что для "перемещения" и "перевода" - 
	// это единственная строка, а для "заявки" свойства позиции совпадают с "заявкой".
	ТекущиеДанные = ПлатежныеПозиции[0];
	
	Если ТекущиеДанные.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
		РежимЗаписиДокументаОплаты = РежимЗаписиРасчетыЧерезБанк;
	Иначе
		РежимЗаписиДокументаОплаты = РежимЗаписиРасчетыЧерезКассу;
	КонецЕсли;
	
	Если ТипЗнч(Заявка) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда  
		
		ПараметрыДокумента = бит_Казначейство.НовыеПараметрыСозданияПлатежногоДокумента();
		ПараметрыДокумента.ВызовИзРеестра	 = Истина;
		ПараметрыДокумента.ДатаДокумента     = ДатаОплаты;
		ПараметрыДокумента.СуммаКОплате      = ТекущиеДанные.СуммаКОплате;
		ПараметрыДокумента.РежимЗаписи       = РежимЗаписиДокументаОплаты;
		ПараметрыДокумента.ДокументОснование = ТекущиеДанные.ЗаявкаПлатежнаяПозиция;
		НовыеДокументы = Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.СоздатьПлатежныйДокументНаОсновании(ПараметрыДокумента);
							
		Если НовыеДокументы.Количество() > 0 Тогда
			ТекущиеДанные.ПлатежныйДокумент = НовыеДокументы[0].Ссылка;
			ОплаченныеДокументы.Добавить(ТекущиеДанные.ПлатежнаяПозиция);
		Иначе
			СообщитьОПроблемеСозданияПлатежногоДокумента(ТекущиеДанные);
		КонецЕсли;
		
	// Заявка на перевод ДС в другую организацию.
	ИначеЕсли ТипЗнч(Заявка) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда  
		
		СообщитьОПроблемеСозданияПлатежногоДокумента(ТекущиеДанные);
							
	Иначе // Одиночная позиция, либо заявка списком с одной попавшей в дерево позицией.
					
		ДанныеЗаполнения = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.НовыеПараметрыДокументаСоздатьПлатежныеДокументы(); 
		ДанныеЗаполнения.Дата		 				  = ДатаОплаты;
		ДанныеЗаполнения.РежимЗаписи 				  = РежимЗаписиДокументаОплаты;
		ДанныеЗаполнения.ВызовИзРеестра 			  = Истина;
		
		Для каждого СтрокаТаблицы Из ПлатежныеПозиции Цикл
			НоваяСтрока = ДанныеЗаполнения.Позиции.Добавить();
			НоваяСтрока.Позиция = СтрокаТаблицы.ПлатежнаяПозиция;
			НоваяСтрока.Сумма 	= СтрокаТаблицы.СуммаОстаток;
		КонецЦикла;
		
		НовыеДокументы = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.СоздатьДокументыНаОсновеВыделенных(
							Заявка, ДанныеЗаполнения);		
		Для каждого СтрокаТаблицы Из ПлатежныеПозиции Цикл
			Если НовыеДокументы.Количество() > 0 Тогда
				РезультатПоиска = НовыеДокументы.Найти(СтрокаТаблицы.ПлатежнаяПозиция, "Позиция");
				Если РезультатПоиска <> Неопределено Тогда
					СтрокаТаблицы.ПлатежныйДокумент = РезультатПоиска.ДокументОплаты;			
				КонецЕсли;
				ОплаченныеДокументы.Добавить(СтрокаТаблицы.ПлатежнаяПозиция);
			Иначе
				СообщитьОПроблемеСозданияПлатежногоДокумента(СтрокаТаблицы);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура СообщитьОПроблемеСозданияПлатежногоДокумента(Запись)
	
	ТекстСообщения = НСтр("ru = 'Не удалось создать платежный документ на основании %1.'; 
						|en = 'Can not create payment document for %1.'");	
	ТекстСообщения = СтрШаблон(ТекстСообщения, Запись.ЗаявкаПлатежнаяПозиция);
	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьПлатежныеДокументы(ФормаОплаты = Неопределено)

	Если Объект.ТаблицаПлатежи.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Проверка статуса.
	Если НЕ СтатусДокументаПравильный() Тогда
		Возврат;
	КонецЕсли;
	
	ЗаблокироватьДанныеФормыДляРедактирования();
	СоздатьПлатежныеДокументыНаСервере(ФормаОплаты);	
	
	ТекстНачала	   = НСтр("ru = 'Обработка завершена'; en = 'Processing is complete'");
	ТекстСообщения = НСтр("ru = 'Формирование документов оплаты завершено'; en = 'Formation of payment documents is completed'");  
	ПоказатьОповещениеПользователя(ТекстНачала,,ТекстСообщения, БиблиотекаКартинок.Информация32);
	
	// Раскроем табло счетов.
	РазвернутьУзлыТаблоСчетов();
	РазблокироватьДанныеФормыДляРедактирования();
	
КонецПроцедуры

&НаСервере
Процедура СоздатьПлатежныеДокументыНаСервере(ФормаОплаты)

	// Нужно обновить статусы для ограничения списка документов оплаты.
	РежимЗаполнения = 0;
	ЗаполнитьДобавленныеКолонкиТаблиц(РежимЗаполнения, Ложь);
	
	ИзмененныеОбъекты 	= Новый Массив; 
	ОплаченныеДокументы = Новый Массив; 
	ПредставлениеСписка = НСтр("ru = 'Платежи';en = 'Payments'");
	ДокументыКОплате 	= Новый Соответствие;
	
	Для каждого СтрокаТаблицы Из Объект.ТаблицаПлатежи Цикл
		
		ЕстьОшибки = Ложь;
		
		// Оплаченные платежные позиции не обрабатываются.
		Если НЕ СтрокаТаблицы.Оплачено Тогда
			Продолжить;
		КонецЕсли; 
		
		Если НЕ СтрокаТаблицы.СтатусЗаявкиПравильный Тогда
			Продолжить;
		КонецЕсли; 

		Если ЗначениеЗаполнено(ФормаОплаты) И ФормаОплаты <> СтрокаТаблицы.ФормаОплаты Тогда
			Продолжить;
		КонецЕсли; 
		
		Если ЗначениеЗаполнено(СтрокаТаблицы.ПлатежныйДокумент) Тогда
			Продолжить;
		КонецЕсли;		

		Префикс = "ТаблицаПлатежи[%1].";
		Префикс = СтрШаблон(Префикс, Формат(СтрокаТаблицы.НомерСтроки - 1, "ЧН=0; ЧГ="));

		// Проверка заполнения банковского счета
		Если  НЕ ЗначениеЗаполнено(СтрокаТаблицы.СчетКасса) Тогда
			 
			Поле = Префикс + "СчетКасса";
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА", 
								"Заполнение", НСтр("ru = 'Счет / касса';en = 'cash / account'"), 
								СтрокаТаблицы.НомерСтроки, ПредставлениеСписка);
			
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,, Поле,"Объект", ЕстьОшибки);
			
		КонецЕсли; 
		
		// Проверим статус платежной позиции
		ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(СтрокаТаблицы.ПлатежнаяПозиция);
		Если Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ТекущийСтатус,
				Перечисления.бит_ТипыСтатусовОбъектов.Закрыт) Тогда
			
			Поле	  = Префикс + "СтатусЗаявки";
			Пояснение = НСтр("ru = 'Указана закрытая платежная позиция';
									 |en = 'A closed payment position is specified'");
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА", 
								"КОРРЕКТНОСТЬ", НСтр("ru = 'Статус';en = 'Status'"), 
								СтрокаТаблицы.НомерСтроки, ПредставлениеСписка, Пояснение);
			
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,, Поле, "Объект",ЕстьОшибки);
		КонецЕсли; 
		
		// Проверка на превышение суммы оплаты
		Если СтрокаТаблицы.СуммаКОплате > СтрокаТаблицы.СуммаПлан Тогда
			Пояснение = СтрШаблон(НСтр("ru='Сумма к оплате %1 превышает плановую сумму %2.';
									   |en='Payment amount %1 higher than the target amount of %2.'"),
								  бит_ОбщегоНазначения.ФорматСумм(СтрокаТаблицы.СуммаКОплате, СтрокаТаблицы.ВалютаПлатежа),
								  бит_ОбщегоНазначения.ФорматСумм(СтрокаТаблицы.СуммаПлан, СтрокаТаблицы.ВалютаПлатежа));

			Поле = Префикс + "ПлатежнаяПозиция";
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("КОЛОНКА", 
											"КОРРЕКТНОСТЬ",НСтр("ru = 'ПлатежнаяПозиция';en = 'Payment Record'"), 
											СтрокаТаблицы.НомерСтроки, ПредставлениеСписка, Пояснение);
			
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,Поле, "Объект", ЕстьОшибки);
		КонецЕсли; 
		
		Если ЕстьОшибки Тогда
			Продолжить;
		КонецЕсли;
		
		НаборПозиций = ДокументыКОплате.Получить(СтрокаТаблицы.ЗаявкаПлатежнаяПозиция);
		Если НаборПозиций = Неопределено Тогда
			НаборПозиций = Новый Массив;				
		КонецЕсли;
		НаборПозиций.Добавить(СтрокаТаблицы);
		ДокументыКОплате.Вставить(СтрокаТаблицы.ЗаявкаПлатежнаяПозиция, НаборПозиций);
	КонецЦикла; 
	
	Если НЕ ЗначениеЗаполнено(ДокументыКОплате) Тогда
		ТекстПояснения = НСтр("ru = 'Нет отмеченных документов.'; en = 'There are no marked documents.'");
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Список" , "Корректность",,, 
							НСтр("ru = 'Заявки к оплате'; en = 'Applications for payment'"), ТекстПояснения);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,, "ТаблицаПлатежи", "Объект");
		Возврат;
	КонецЕсли;
	
	Для каждого ДокументКОплате Из ДокументыКОплате Цикл
		ОплатитьДокумент(ДокументКОплате.Ключ, ДокументКОплате.Значение, ОплаченныеДокументы);
	КонецЦикла;
	
	Если РежимСообщений = "Все" Тогда
		ТекстСообщения = НСтр("ru = 'Создание платежных документов завершено.';
							  |en = 'The creation of payment documents is completed.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения); 
	КонецЕсли; 

	// Заполним дополнительные колонки в списке.
	Если ОплаченныеДокументы.Количество() > 0 Тогда
		Если НЕ Модифицированность Тогда
			ПараметрыЗаписи = Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись); 	
			Записать(ПараметрыЗаписи);
		КонецЕсли;
	КонецЕсли;

	ОбновитьИнформационныеТаблоНаСервере(ОтобразитьТаблоСчетов, Истина);
	
КонецПроцедуры

&НаСервере
Процедура ПодборВРеестрПлатежейЗавершение(РезультатПодбора)
	
	Для Каждого ЭлементПодбора Из РезультатПодбора Цикл
		
		ПлатежнаяПозиция = ЭлементПодбора.ПлатежнаяПозиция;
		СтрокаТаблицы 	 = Неопределено;
		Отбор 			 = Новый Структура("ПлатежнаяПозиция", ПлатежнаяПозиция);
		РезультатПоиска  = Объект.ТаблицаПлатежи.НайтиСтроки(Отбор);
		
		Если РезультатПоиска.Количество() > 0 Тогда
			СтрокаТаблицы = РезультатПоиска[0];
		КонецЕсли;
		
		Если СтрокаТаблицы <> Неопределено Тогда
			ТекстСообщения = НСтр("ru = 'Платежная позиция ""%1"" уже подобрана в строке № %2.';
								  |en = 'The payment position ""%1"" has already been selected in line # %2.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ПлатежнаяПозиция, СтрокаТаблицы.НомерСтроки);								
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения); 
			
		ИначеЕсли ЗначениеЗаполнено(Объект.Организация) И ЭлементПодбора.Организация <> Объект.Организация Тогда
			ТекстСообщения = НСтр("ru = 'Не добавлена позиция ""%1"". Организация не соответствует значению, указанному в реестре.';
								  |en = 'The ""%1 ""position was not added. The organization does not match the value specified in the registry.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ПлатежнаяПозиция);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Иначе
			НоваяСтрока = Объект.ТаблицаПлатежи.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ЭлементПодбора);
						
			СформироватьКурсЗнаменательТекстом(НоваяСтрока);
			
			НоваяСтрока.СтатусЗаявкиПравильный = СтатусЗаявкиПравильный(НоваяСтрока);
			НоваяСтрока.КонтрольнаяСумма	   = КонтрольнаяСуммаСтрокой(НоваяСтрока.СчетКасса, НоваяСтрока.Организация);
		КонецЕсли;		
	КонецЦикла;
	
	Объект.ТаблицаПлатежи.Сортировать("СчетКасса, ЗаявкаПлатежнаяПозиция");
	
	ОбновитьИнформационныеТаблоНаСервере(Истина, Истина);
	
КонецПроцедуры

&НаСервере
Функция ПозицииДляГрупповойОплаты()

	Позиций = Новый Массив;
	
	Для Каждого СтрокаТаблицы Из Объект.ТаблицаПлатежи Цикл
		
		Если НЕ СтрокаТаблицы.СтатусЗаявкиПравильный Тогда
			Продолжить;
		КонецЕсли; 
		
		Если НЕ СтрокаТаблицы.Оплачено Тогда
			Продолжить;
		КонецЕсли;  		

		Если ЗначениеЗаполнено(СтрокаТаблицы.ПлатежныйДокумент) Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ ПоддерживаетсяГрупповаяОплата(СтрокаТаблицы) Тогда
			Продолжить;		
		КонецЕсли;
		
		// Проверим статус платежной позиции.
		ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(СтрокаТаблицы.ПлатежнаяПозиция);
		Если Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ТекущийСтатус,
				Перечисления.бит_ТипыСтатусовОбъектов.Закрыт) Тогда
			Продолжить;
		КонецЕсли; 
		
		// Проверка на превышение суммы оплаты.
		Если СтрокаТаблицы.СуммаКОплате > СтрокаТаблицы.СуммаПлан Тогда
			Продолжить;
		КонецЕсли;
		
		Структура = Новый Структура;
		Структура.Вставить("ПлатежнаяПозиция", СтрокаТаблицы.ПлатежнаяПозиция);
		Структура.Вставить("СуммаКОплате"	 , СтрокаТаблицы.СуммаОстаток);
	
		Позиций.Добавить(Структура);
		
	КонецЦикла;
	
	Возврат Позиций;

КонецФункции

&НаСервере
Процедура ОбработатьДокументыГрупповойОплаты(АдресВХранилище)

	Результат  = ПолучитьИзВременногоХранилища(АдресВХранилище);
	Добавлено = 0;
	Для каждого СтрокаРезультат Из Результат Цикл
		Отбор = Новый Структура("ПлатежнаяПозиция", СтрокаРезультат.Позиция);
		РезультатПоиска = Объект.ТаблицаПлатежи.НайтиСтроки(Отбор);
		Для каждого СтрокаТаблицы Из РезультатПоиска Цикл
			СтрокаТаблицы.ПлатежныйДокумент = СтрокаРезультат.ДокументОплаты;
			Добавлено = Добавлено + 1;
		КонецЦикла; 
	КонецЦикла; 

	Если Добавлено > 0 Тогда
		ТекстСообщения = НСтр("ru = 'Обработка завершена. Записано %1 документов.'; 
							|en = 'Processing is complete. %1 of documents recorded.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, Добавлено);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Если НЕ Модифицированность Тогда
			Записать();
		Иначе
			РежимЗаполнения = 0;
			ЗаполнитьДобавленныеКолонкиТаблиц(РежимЗаполнения, Ложь);
			ОбновитьИнформационныеТаблоНаСервере(Истина, Истина)
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьТаблоСчетовНаСервере() 
	
	СтрокиТаблоСчетов = ТаблоСчетов.ПолучитьЭлементы();
	СтрокиТаблоСчетов.Очистить();
	
	Если Объект.ТаблицаПлатежи.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;   	
	
	ТекстЗапроса = ТекстЗапросаТаблоСчетовПлатежныеПозиции();
		
	Если ИсточникДанныхТабло = Перечисления.бит_кзн_РежимОтображенияОстатковДС.ДанныеРегУчета Тогда
		ТекстЗапроса = ТекстЗапроса + ТекстЗапросаТаблоСчетовДанныеРегУчета();
	ИначеЕсли ИсточникДанныхТабло = Перечисления.бит_кзн_РежимОтображенияОстатковДС.УправленческаяВыписка Тогда	
		ТекстЗапроса = ТекстЗапроса + ТекстЗапросаТаблоСчетовУправленческаяВыписка();
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", 				  Объект.Организация);
	Запрос.УстановитьПараметр("ВсеОрганизации", 			  НЕ ЗначениеЗаполнено(Объект.Организация));
	Запрос.УстановитьПараметр("ТаблицаПлатежи", 			  Объект.ТаблицаПлатежи.Выгрузить());
	Запрос.УстановитьПараметр("НачалоПериода", 				  НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("КонецПериода", 				  КонецДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("Период", 					  КонецДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("ОтменитьФильтрПоСчетамВТабло", ОтменитьФильтрПоСчетамВТабло);
	Запрос.Текст = ТекстЗапроса;
	
	Результат = Запрос.Выполнить();
	ВыборкаОрганизация = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
	Пока ВыборкаОрганизация.Следующий() Цикл
		СтрокаОрганизация 			  = СтрокиТаблоСчетов.Добавить();
		СтрокаОрганизация.Организация = ВыборкаОрганизация.Организация;
		СтрокаОрганизация.Описание 	  = Строка(ВыборкаОрганизация.Организация);
		
		ВыборкаНалБезнал = ВыборкаОрганизация.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаНалБезнал.Следующий() Цикл 
			
			СтрокаНалБезнал = СтрокаОрганизация.ПолучитьЭлементы().Добавить();
			Если ВыборкаНалБезнал.БезНал = 1 Тогда
				СтрокаНалБезнал.Описание = НСтр("ru='Безналичные';en='Cash-In-Bank'");
			Иначе 
				СтрокаНалБезнал.Описание = НСтр("ru='Наличные';en='Cash-On-Hand'");
			КонецЕсли; 
			
			ВыборкаБанковскийСчетКасса = ВыборкаНалБезнал.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаБанковскийСчетКасса.Следующий() Цикл 
				
				Детали = СтрокаНалБезнал.ПолучитьЭлементы().Добавить();
				Детали.Описание 		   = ВыборкаБанковскийСчетКасса.БанковскийСчетКасса;
				Детали.БанковскийСчетКасса = ВыборкаБанковскийСчетКасса.БанковскийСчетКасса;
				
				Детали.КонтрольнаяСумма = КонтрольнаяСуммаСтрокой(ВыборкаБанковскийСчетКасса.БанковскийСчетКасса, 
												ВыборкаБанковскийСчетКасса.Организация);
				
				ВыборкаДетали = ВыборкаБанковскийСчетКасса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаДетали.Следующий() Цикл
					Детали.СуммаНачОстаток = ВыборкаДетали.НачальныйОстаток;
					Детали.СуммаРасход 	   = ВыборкаДетали.СуммаРасход;
					Если ПоказыватьСуммуПланируемыхПоступлений Тогда
						Детали.СуммаПриход = Детали.СуммаПриход + ВыборкаДетали.СуммаПриход;
					КонецЕсли; 
					Детали.СуммаКонОстаток = Детали.СуммаНачОстаток + Детали.СуммаПриход - Детали.СуммаРасход;
				КонецЦикла;	
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ТекстЗапросаТаблоСчетовПлатежныеПозиции()
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ТаблицаПлатежи.ПлатежнаяПозиция КАК ПлатежнаяПозиция,
	|	ТаблицаПлатежи.ФормаОплаты КАК ФормаОплаты,
	|	ТаблицаПлатежи.Организация КАК Организация,
	|	ТаблицаПлатежи.ВалютаПлатежа КАК ВалютаПлатежа,
	|	ТаблицаПлатежи.Статус КАК Статус,
	|	ТаблицаПлатежи.ОдиночнаяПозиция КАК ОдиночнаяПозиция,
	|	ТаблицаПлатежи.Оплачено КАК Оплачено,
	|	ТаблицаПлатежи.ЗаблокироватьСтроку КАК ЗаблокироватьСтроку,
	|	ТаблицаПлатежи.ПлатежныйДокумент КАК ПлатежныйДокумент,
	|	ТаблицаПлатежи.СуммаКОплате КАК СуммаКОплате,
	|	ТаблицаПлатежи.ЗаявкаПлатежнаяПозиция КАК ЗаявкаПлатежнаяПозиция,
	|	ТаблицаПлатежи.КонтрольнаяСумма КАК КонтрольнаяСумма
	|ПОМЕСТИТЬ ТаблицаПлатежи
	|ИЗ
	|	&ТаблицаПлатежи КАК ТаблицаПлатежи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаПлатежи.ПлатежнаяПозиция КАК ПлатежнаяПозиция,
	|	бит_кзн_ПлатежнаяПозиция.БанковскийСчет КАК БанковскийСчет,
	|	бит_кзн_ПлатежнаяПозиция.Касса КАК Касса,
	|	ВЫБОР
	|		КОГДА ТаблицаПлатежи.Оплачено
	|			ТОГДА ТаблицаПлатежи.СуммаКОплате
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК СуммаРасход
	|ПОМЕСТИТЬ СписокПлатежныхПозиций
	|ИЗ
	|	ТаблицаПлатежи КАК ТаблицаПлатежи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК бит_кзн_ПлатежнаяПозиция
	|		ПО ТаблицаПлатежи.ПлатежнаяПозиция = бит_кзн_ПлатежнаяПозиция.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	БанковскиеСчетаОрганизаций.Владелец КАК Организация,
	|	БанковскиеСчетаОрганизаций.Ссылка КАК БанковскийСчет,
	|	БанковскиеСчетаОрганизаций.ВалютаДенежныхСредств КАК Валюта,
	|	СУММА(ЕСТЬNULL(СписокПлатежныхПозиций.СуммаРасход, 0)) КАК СуммаРасход
	|ПОМЕСТИТЬ Счета
	|ИЗ
	|	Справочник.БанковскиеСчетаОрганизаций КАК БанковскиеСчетаОрганизаций
	|		ЛЕВОЕ СОЕДИНЕНИЕ СписокПлатежныхПозиций КАК СписокПлатежныхПозиций
	|		ПО (СписокПлатежныхПозиций.БанковскийСчет = БанковскиеСчетаОрганизаций.Ссылка)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ОтменитьФильтрПоСчетамВТабло
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НЕ СписокПлатежныхПозиций.ПлатежнаяПозиция ЕСТЬ NULL
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ВсеОрганизации
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ БанковскиеСчетаОрганизаций.Владелец = &Организация
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	БанковскиеСчетаОрганизаций.Ссылка,
	|	БанковскиеСчетаОрганизаций.Владелец,
	|	БанковскиеСчетаОрганизаций.ВалютаДенежныхСредств
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Кассы.Владелец КАК Организация,
	|	Кассы.Ссылка КАК Касса,
	|	Кассы.ВалютаДенежныхСредств КАК Валюта,
	|	СУММА(ЕСТЬNULL(СписокПлатежныхПозиций.СуммаРасход, 0)) КАК СуммаРасход
	|ПОМЕСТИТЬ Кассы
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|		ЛЕВОЕ СОЕДИНЕНИЕ СписокПлатежныхПозиций КАК СписокПлатежныхПозиций
	|		ПО (СписокПлатежныхПозиций.Касса = Кассы.Ссылка)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ОтменитьФильтрПоСчетамВТабло
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ НЕ СписокПлатежныхПозиций.ПлатежнаяПозиция ЕСТЬ NULL
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ВсеОрганизации
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ Кассы.Владелец = &Организация
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	Кассы.Ссылка,
	|	Кассы.Владелец,
	|	Кассы.ВалютаДенежныхСредств
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫБОР
	|		КОГДА ПланируемоеПоступлениеДСОбороты.Позиция.ФормаОплаты = ЗНАЧЕНИЕ(перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|			ТОГДА ПланируемоеПоступлениеДСОбороты.Позиция.БанковскийСчет
	|		ИНАЧЕ ПланируемоеПоступлениеДСОбороты.Позиция.Касса
	|	КОНЕЦ КАК БанковскийСчетКасса,
	|	СУММА(ЕСТЬNULL(ПланируемоеПоступлениеДСОбороты.СуммаОборот, 0)) КАК СуммаОборот,
	|	ПланируемоеПоступлениеДСОбороты.Организация КАК Организация
	|ПОМЕСТИТЬ ПланируемыеПоступления
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			,
	|			ВидПлана = ЗНАЧЕНИЕ(Перечисление.бит_кзн_ВидыПланов.План)
	|				И Организация В
	|					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|						Счета.Организация КАК Организация
	|					ИЗ
	|						Счета КАК Счета
	|			
	|					ОБЪЕДИНИТЬ ВСЕ
	|			
	|					ВЫБРАТЬ РАЗЛИЧНЫЕ
	|						Кассы.Организация
	|					ИЗ
	|						Кассы КАК Кассы)) КАК ПланируемоеПоступлениеДСОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	ВЫБОР
	|		КОГДА ПланируемоеПоступлениеДСОбороты.Позиция.ФормаОплаты = ЗНАЧЕНИЕ(перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|			ТОГДА ПланируемоеПоступлениеДСОбороты.Позиция.БанковскийСчет
	|		ИНАЧЕ ПланируемоеПоступлениеДСОбороты.Позиция.Касса
	|	КОНЕЦ,
	|	ПланируемоеПоступлениеДСОбороты.Организация";

	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции

&НаСервере
Функция ТекстЗапросаТаблоСчетовУправленческаяВыписка()
	
	Перем ТекстЗапросаУправленческаяВыписка;
	
	ТекстЗапросаУправленческаяВыписка =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК БезНал,
	|	Счета.БанковскийСчет КАК БанковскийСчетКасса,
	|	ЕСТЬNULL(ОстаткиБезнал.СуммаОстаток, 0) КАК НачальныйОстаток,
	|	ЕСТЬNULL(ПланируемыеПоступления.СуммаОборот, 0) КАК СуммаПриход,
	|	Счета.Организация КАК Организация,
	|	Счета.Валюта КАК Валюта,
	|	Счета.СуммаРасход КАК СуммаРасход
	|ИЗ
	|	Счета КАК Счета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.бит_СведенияОбОстаткахДенежныхСредств.Остатки(
	|				&Период,
	|				ВидДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|					И (Организация, БанковскийСчет) В
	|						(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|							Счета.Организация КАК Организация,
	|							Счета.БанковскийСчет КАК БанковскийСчет
	|						ИЗ
	|							Счета КАК Счета)) КАК ОстаткиБезнал
	|		ПО Счета.Организация = ОстаткиБезнал.Организация
	|			И Счета.БанковскийСчет = ОстаткиБезнал.БанковскийСчет
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланируемыеПоступления КАК ПланируемыеПоступления
	|		ПО Счета.Организация = ПланируемыеПоступления.Организация
	|			И Счета.БанковскийСчет = ПланируемыеПоступления.БанковскийСчетКасса
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	0,
	|	Кассы.Касса,
	|	ЕСТЬNULL(ОстаткиНал.СуммаОстаток, 0),
	|	ЕСТЬNULL(ПланируемыеПоступления.СуммаОборот, 0),
	|	Кассы.Организация,
	|	Кассы.Валюта,
	|	Кассы.СуммаРасход
	|ИЗ
	|	Кассы КАК Кассы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.бит_СведенияОбОстаткахДенежныхСредств.Остатки(
	|				&Период,
	|				ВидДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Наличные)
	|					И (Организация, БанковскийСчет) В
	|						(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|							Кассы.Организация КАК Организация,
	|							Кассы.Касса КАК Касса
	|						ИЗ
	|							Кассы КАК Кассы)) КАК ОстаткиНал
	|		ПО Кассы.Организация = ОстаткиНал.Организация
	|			И Кассы.Касса = ОстаткиНал.БанковскийСчет
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланируемыеПоступления КАК ПланируемыеПоступления
	|		ПО Кассы.Организация = ПланируемыеПоступления.Организация
	|			И Кассы.Касса = ПланируемыеПоступления.БанковскийСчетКасса
	|ИТОГИ
	|	МАКСИМУМ(Валюта)
	|ПО
	|	Организация,
	|	БезНал,
	|	БанковскийСчетКасса";
	Возврат ТекстЗапросаУправленческаяВыписка;

КонецФункции

&НаСервере
Функция ТекстЗапросаТаблоСчетовДанныеРегУчета()
	
	Перем ТекстЗапросаДанныеРегУчета;
	
	ТекстЗапросаДанныеРегУчета =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК БезНал,
	|	ЕСТЬNULL(ДенежныеСредстваБезналичныеОстатки.СуммаОстаток, 0) КАК НачальныйОстаток,
	|	Счета.БанковскийСчет КАК БанковскийСчетКасса,
	|	ЕСТЬNULL(ПланируемыеПоступления.СуммаОборот, 0) КАК СуммаПриход,
	|	Счета.Организация КАК Организация,
	|	Счета.Валюта КАК Валюта,
	|	Счета.СуммаРасход КАК СуммаРасход
	|ИЗ
	|	Счета КАК Счета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ДенежныеСредстваБезналичные.Остатки(
	|				&Период,
	|				(Организация, БанковскийСчет) В
	|					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|						Счета.Организация КАК Организация,
	|						Счета.БанковскийСчет КАК БанковскийСчет
	|					ИЗ
	|						Счета КАК Счета)) КАК ДенежныеСредстваБезналичныеОстатки
	|		ПО Счета.Организация = ДенежныеСредстваБезналичныеОстатки.Организация
	|			И Счета.БанковскийСчет = ДенежныеСредстваБезналичныеОстатки.БанковскийСчет
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланируемыеПоступления КАК ПланируемыеПоступления
	|		ПО Счета.Организация = ПланируемыеПоступления.Организация
	|			И Счета.БанковскийСчет = ПланируемыеПоступления.БанковскийСчетКасса
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	0,
	|	ЕСТЬNULL(ДенежныеСредстваНаличныеОстатки.СуммаОстаток, 0),
	|	Кассы.Касса,
	|	ЕСТЬNULL(ПланируемыеПоступления.СуммаОборот, 0),
	|	Кассы.Организация,
	|	Кассы.Валюта,
	|	Кассы.СуммаРасход
	|ИЗ
	|	Кассы КАК Кассы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ДенежныеСредстваНаличные.Остатки(
	|				&Период,
	|				(Организация, Касса) В
	|					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|						Кассы.Организация КАК Организация,
	|						Кассы.Касса КАК Касса
	|					ИЗ
	|						Кассы КАК Кассы)) КАК ДенежныеСредстваНаличныеОстатки
	|		ПО Кассы.Организация = ДенежныеСредстваНаличныеОстатки.Организация
	|			И Кассы.Касса = ДенежныеСредстваНаличныеОстатки.Касса
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланируемыеПоступления КАК ПланируемыеПоступления
	|		ПО Кассы.Организация = ПланируемыеПоступления.Организация
	|			И Кассы.Касса = ПланируемыеПоступления.БанковскийСчетКасса
	|ИТОГИ
	|	МАКСИМУМ(Валюта)
	|ПО
	|	Организация,
	|	БезНал,
	|	БанковскийСчетКасса";
	Возврат ТекстЗапросаДанныеРегУчета;

КонецФункции
 
&НаСервере
Процедура ОбновитьТаблоПлатежейНаСервере()
		
	Итоги = РеквизитФормыВЗначение("ТаблоПлатежей");
	Итоги.Очистить();
	Для каждого СтрокаТаблицы Из Объект.ТаблицаПлатежи Цикл
		Если СтрокаТаблицы.Оплачено И СтрокаТаблицы.СуммаКОплате <> 0 Тогда		
			НоваяСтрока = Итоги.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
			Если ЗначениеЗаполнено(СтрокаТаблицы.ПлатежныйДокумент) Тогда
				НоваяСтрока.СуммаОплачено = СтрокаТаблицы.СуммаКОплате;
			КонецЕсли;
		КонецЕсли; 
	КонецЦикла; 
	
	Итоги.Свернуть("ВалютаПлатежа", "СуммаКОплате, СуммаОплачено");
	ЗначениеВРеквизитФормы(Итоги, "ТаблоПлатежей");

КонецПроцедуры

&НаСервере
Процедура РазбитьПлатежНаСервере(ИДСтроки, ДатаПлатежа)
	
	ТекущаяСтрока = Объект.ТаблицаПлатежи.НайтиПоИдентификатору(ИДСтроки);
	
	НоваяСумма   = ТекущаяСтрока.СуммаОстаток;
	ТекущаяСумма = ТекущаяСтрока.СуммаДокумента;
	
	// Сумма на которую будет создана новая Позиция.
	СуммаНовогоДокумента = ТекущаяСумма - НоваяСумма;
	
	ДействиеВыполнено = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.РазбитьПозицию(ТекущаяСтрока.ПлатежнаяПозиция, 
							ТекущаяСумма, СуммаНовогоДокумента, ДатаПлатежа);
	
	// Теперь сумма у текущего документа станет равна сумме к оплате.
	Если ДействиеВыполнено Тогда
		
		ТекущаяСтрока.СуммаПлан = ТекущаяСтрока.СуммаКОплате;		
		
		Отбор = Новый Структура;
		Отбор.Вставить("ПлатежнаяПозиция", ТекущаяСтрока.ПлатежнаяПозиция);
		
		РезультатПоиска = Объект.ТаблицаПлатежи.НайтиСтроки(Отбор);
		Если РезультатПоиска.Количество() > 0 Тогда		
			СтрокаТаблицыПлатежей = РезультатПоиска[0];
			СтрокаТаблицыПлатежей.СуммаПлан = ТекущаяСтрока.СуммаКОплате;		
		КонецЕсли;
		
		Если ТекущаяСтрока.Оплачено Тогда
			ОбновитьТаблоПлатежейНаСервере();
		КонецЕсли; 
		
	КонецЕсли; 															 
		
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборыБанковскийСчетКасса(ИД)

	СтрокаТаблицы = Объект.ТаблицаПлатежи.НайтиПоИдентификатору(ИД);
	
	ПлатежнаяПозиция = СтрокаТаблицы.ПлатежнаяПозиция;
	
	НовыеПараметры = бит_Казначейство.УстановитьОтборыДляБанковскихСчетовКасс(СтрокаТаблицы.Организация, 
							СтрокаТаблицы.ВалютаДокумента, СтрокаТаблицы.ЗаявкаПлатежнаяПозиция, ВалютаРеглУчета);
	
	Элементы.ТаблицаПлатежиСчетКасса.ПараметрыВыбора = НовыеПараметры;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьНастройки()
	
	НовыеНастройки = НовыеНастройкиФормыДокумента();
	ЗаполнитьЗначенияСвойств(НовыеНастройки, ЭтотОбъект);
	ОбщегоНазначенияВызовСервера.ХранилищеОбщихНастроекСохранить(
		"НастройкиПользователя","НастройкиРеестраПлатежей", НовыеНастройки);

КонецПроцедуры

&НаСервере
Процедура ВосстановитьНастройки()
	
	НовыеНастройки		 = НовыеНастройкиФормыДокумента();
	СохраненныеНастройки = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(
								"НастройкиПользователя","НастройкиРеестраПлатежей", НовыеНастройки);
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, СохраненныеНастройки);
	
	Если НЕ ЗначениеЗаполнено(РежимТабло) Тогда
		РежимТабло = НовыеНастройки.РежимТабло;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(РежимЗаписиРасчетыЧерезБанк) Тогда
		РежимЗаписиРасчетыЧерезБанк = НовыеНастройки.РежимЗаписиРасчетыЧерезБанк;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(РежимЗаписиРасчетыЧерезКассу) Тогда
		РежимЗаписиРасчетыЧерезКассу = НовыеНастройки.РежимЗаписиРасчетыЧерезКассу;
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция НовыеНастройкиФормыДокумента()
		
	Возврат Документы.бит_кзн_РеестрПлатежей.НовыеНастройкиФормыДокумента();
	
КонецФункции

&НаСервере
Процедура ОбработкаОповещенияИзмененияСтатуса()
	
	Прочитать();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПодборДокументов()
		
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("НачалоПериода", НачалоДня(Объект.Дата));
	ПараметрыФормы.Вставить("КонецПериода",  КонецДня(Объект.Дата));
	ПараметрыФормы.Вставить("ДатаОплаты", 	 ДатаОплаты);
	ПараметрыФормы.Вставить("Организация", 	 Объект.Организация);
	ПараметрыФормы.Вставить("РеестрПлатежей",Объект.Ссылка);
	ПараметрыФормы.Вставить("ЗакрыватьПриЗакрытииВладельца", Истина);
	
	ВыбранныеДокументы = Новый Массив; 
	Для каждого СтрокаТаблицы Из Объект.ТаблицаПлатежи Цикл
		ВыбранныеДокументы.Добавить(СтрокаТаблицы.ПлатежнаяПозиция);	
	КонецЦикла; 
	
	АдресВыбранных = ПоместитьВоВременноеХранилище(ВыбранныеДокументы, УникальныйИдентификатор);
	ПараметрыФормы.Вставить("АдресВХранилище", АдресВыбранных);
	
	ОткрытьФорму("Документ.бит_кзн_РеестрПлатежей.Форма.ФормаПодбораЗаявок", ПараметрыФормы, ЭтотОбъект, ЭтотОбъект);

КонецПроцедуры

&НаСервереБезКонтекста
Функция СтатусЗаявкиПравильный(ТекущаяСтрока) 
	
	Возврат Документы.бит_кзн_РеестрПлатежей.СтатусЗаявкиПравильный(ТекущаяСтрока);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ОбработатьИзменениеВОплату(ТекущаяСтрока, Форма)

	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	            
	 СтрокаТабло = СтрокаТаблоСКонтрольнойСуммой(ТекущаяСтрока.КонтрольнаяСумма, Форма.ТаблоСчетов.ПолучитьЭлементы());
	 
	 Если СтрокаТабло <> Неопределено Тогда
		 СуммаОплаты = 0;
		 Если ТекущаяСтрока.СуммаФактическойОплаты = 0 Тогда
			 Если ТекущаяСтрока.Оплачено Тогда 
				 СуммаОплаты = ТекущаяСтрока.СуммаКОплате;
			 Иначе
				 СуммаОплаты = - ТекущаяСтрока.СуммаКОплате; 
			 КонецЕсли;
		 КонецЕсли;
	 	 СтрокаТабло.СуммаРасход 	= СтрокаТабло.СуммаРасход + СуммаОплаты;
	 	 СтрокаТабло.СуммаКонОстаток = СтрокаТабло.СуммаНачОстаток + СтрокаТабло.СуммаПриход - СтрокаТабло.СуммаРасход;
	 КонецЕсли; 
	
КонецПроцедуры 

&НаСервере
Процедура ОбновитьИнформационныеТаблоНаСервере(ОбновитьТаблоСчетов, ОбновитьТаблоПлатежей)

	Если ОбновитьТаблоСчетов Тогда
		ОбновитьТаблоСчетовНаСервере();
	КонецЕсли; 
	
	Если ОбновитьТаблоПлатежей Тогда
		ОбновитьТаблоПлатежейНаСервере();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИнформационныеТабло(ОбновитьТаблоПлатежей = Ложь)
	
	ОбновитьИнформационныеТаблоНаСервере(ОтобразитьТаблоСчетов, ОбновитьТаблоПлатежей); 
	
	РазвернутьУзлыТаблоСчетов();	
	         	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЗначениеВОплату(ЗначениеФлага)
		
	Для каждого СтрокаТаблицы Из Объект.ТаблицаПлатежи Цикл
		ИдентификаторСтроки = СтрокаТаблицы.ПолучитьИдентификатор();
		Если Элементы.ТаблицаПлатежи.ПроверитьСтроку(ИдентификаторСтроки) <> Истина // Может быть Неопределено.
			ИЛИ НЕ СтрокаТаблицы.СтатусЗаявкиПравильный
			ИЛИ ЗначениеЗаполнено(СтрокаТаблицы.ПлатежныйДокумент) Тогда
			Продолжить;		
		КонецЕсли; 		
		
		ПредыдущееЗначениеФлага = СтрокаТаблицы.Оплачено;
		
		Если ЗначениеФлага = 0 Тогда
			СтрокаТаблицы.Оплачено = Ложь;
		ИначеЕсли ЗначениеФлага = 1 Тогда
			СтрокаТаблицы.Оплачено = Истина;
		ИначеЕсли ЗначениеФлага = 2 Тогда	
			СтрокаТаблицы.Оплачено = НЕ СтрокаТаблицы.Оплачено;
		КонецЕсли; 
		
		Если ПредыдущееЗначениеФлага <> СтрокаТаблицы.Оплачено Тогда
			ОбработатьИзменениеВОплату(СтрокаТаблицы, ЭтотОбъект);
		КонецЕсли; 
	КонецЦикла;
	
	ОбновитьТаблоПлатежейНаСервере();
	
КонецПроцедуры

&НаКлиенте
Функция СтатусДокументаПравильный()
	
	СтатусДокументаПравильный = Истина;
	Если ТипСтатуса <> ПредопределенноеЗначение("Перечисление.бит_ТипыСтатусовОбъектов.Утвержден")
		И ТипСтатуса <> ПредопределенноеЗначение("Перечисление.бит_ТипыСтатусовОбъектов.Исполнен")
		И ТипСтатуса <> ПредопределенноеЗначение("Перечисление.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен") Тогда
		ТекстСообщения = НСтр("ru = 'Формирование сводных платежных документов разрешено в утвержденном реестре платежей.';
							  |en = 'Formation allowed in the summary payment documents approved payment registry.'");
		СтатусДокументаПравильный = Ложь;
		ПоказатьПредупреждение(,ТекстСообщения);
	КонецЕсли;

	Возврат СтатусДокументаПравильный;
	
КонецФункции

&НаКлиенте
Процедура ВыполнитьДействияСТаблоСчетов()
	
	УправлениеТаблоСчетов();
	
	ОтключитьОбработчикОжидания("ОбработчикОжиданияОбновитьТабло");
	
	Если ОтобразитьТаблоСчетов Тогда
		ОбновитьИнформационныеТабло();
		
		Если ИнтервалАвтообновленияТаблоСчетов > 0 Тогда
			ПодключитьОбработчикОжидания("ОбработчикОжиданияОбновитьТабло", ИнтервалАвтообновленияТаблоСчетов, Ложь);
		КонецЕсли; 
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВыделитьТекущуюСтрокуВТабло(ТекущаяСтрока)
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;	
	КонецЕсли; 
	
	ТекущаяКонтрольнаяСумма = ТекущаяСтрока.КонтрольнаяСумма;
	Элемент = СтрокаТаблоСКонтрольнойСуммой(ТекущаяКонтрольнаяСумма, ТаблоСчетов.ПолучитьЭлементы());
	Если Элемент <> Неопределено  Тогда
		Элементы.ТаблоСчетов.ТекущаяСтрока = Элемент.ПолучитьИдентификатор();
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикОжиданияОбновитьТабло()

	// Обновим табло счетов.
	ОбновитьИнформационныеТабло();

КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборВЗаявках(КонтрольнаяСумма)

	Элементы.ТаблицаПлатежи.ОтборСтрок = Неопределено;
	
	Если ПустаяСтрока(КонтрольнаяСумма) Тогда
		Элементы.ТаблицаПлатежи.ОтборСтрок = Неопределено;
	Иначе
		Отбор = Новый Структура("КонтрольнаяСумма", КонтрольнаяСумма);
		Элементы.ТаблицаПлатежи.ОтборСтрок = Новый ФиксированнаяСтруктура(Отбор);
	КонецЕсли; 
		
КонецПроцедуры

&НаСервере
Процедура ОбновитьСписокЗаявокНаСервере()
	
	РежимЗаполнения = 1;
	ЗаполнитьДобавленныеКолонкиТаблиц(РежимЗаполнения, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПлатежиПриАктивизацииСтрокиОжидание()

	ТекущиеДанные = Элементы.ТаблицаПлатежи.ТекущиеДанные;
	ВыделитьТекущуюСтрокуВТабло(ТекущиеДанные);

КонецПроцедуры

&НаСервере
Функция ПоддерживаетсяГрупповаяОплата(СтрокаТаблицы)

	Поддерживается = Истина;
	
	ШаблонСообщения = НСтр("ru = 'Групповая оплата не поддерживается.'; en = 'Group payment is not supported.'") ;
	Префикс			= "ТаблицаПлатежи[%1].";
	Префикс			= СтрШаблон(Префикс, Формат(СтрокаТаблицы.НомерСтроки - 1, "ЧН=0; ЧГ="));
	Отказ 			= Ложь;
	
	Если ТипЗнч(СтрокаТаблицы.ЗаявкаПлатежнаяПозиция) <> Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств")  Тогда
		Поле = Префикс + "ЗаявкаПлатежнаяПозиция";
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(
							"КОЛОНКА","КОРРЕКТНОСТЬ", НСтр("ru = 'Заявка'; en = 'Request'"), СтрокаТаблицы.НомерСтроки,
							НСтр("ru = 'Платежи'; en = 'Payments'"), ШаблонСообщения);
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, Поле, "Объект", Отказ);
	КонецЕсли;

	Если Отказ Тогда
		Поддерживается = Ложь;	
	КонецЕсли;
	
	Возврат Поддерживается;

КонецФункции

&НаСервере
Процедура СформироватьКурсЗнаменательТекстом(СтрокаТЧ)
					
	ШаблонКурса = "%1 %2 = %3 %4";
	
	Если СтрокаТЧ.КурсЧислительВзаиморасчетов <> 0 Тогда
		Если СтрокаТЧ.ВалютаДокумента = СтрокаТЧ.ВалютаПлатежа Тогда
			СтрокаТЧ.КурсЧислительВзаиморасчетовТекст = "";
			
		ИначеЕсли СтрокаТЧ.ВалютаДокумента = ВалютаРеглУчета Тогда
			
			СтрокаТЧ.КурсЧислительВзаиморасчетовТекст = СтрШаблон(ШаблонКурса,
				СтрокаТЧ.КурсЗнаменательВзаиморасчетов,
				СтрокаТЧ.ВалютаПлатежа,
				Строка(Формат(СтрокаТЧ.КурсЧислительВзаиморасчетов, "ЧДЦ=4")),
				СтрокаТЧ.ВалютаДокумента);
		Иначе
			СтрокаТЧ.КурсЧислительВзаиморасчетовТекст = СтрШаблон(ШаблонКурса,
				СтрокаТЧ.КурсЗнаменательВзаиморасчетов,
				СтрокаТЧ.ВалютаДокумента,
				Строка(Формат(СтрокаТЧ.КурсЧислительВзаиморасчетов, "ЧДЦ=4")),
				СтрокаТЧ.ВалютаПлатежа);
		КонецЕсли;
	Иначе
		СтрокаТЧ.КурсЧислительВзаиморасчетовТекст = "0";
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
