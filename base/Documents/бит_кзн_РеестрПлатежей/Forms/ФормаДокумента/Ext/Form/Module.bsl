#Область ОписаниеПеременных

&НаКлиенте
Перем УстанавливатьОтборВПеречне; // Хранит признак повторного входа в процедуру активизации строки в табло счетов
                                   // (пока значение переменной неопределено - отбор в перечне не устанавливается).

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	// Стандартные действия при создании на сервере
	бит_РаботаСДиалогамиСервер.ФормаОбъектаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	ДополнительныеПараметры.Вставить("ОтложеннаяИнициализация", Истина);
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства
	
	// ИнтеграцияС1СДокументооборотом
	Если ОбщегоНазначения.ПодсистемаСуществует("ИнтеграцияС1СДокументооборотом") Тогда
		МодульИнтеграцияС1СДокументооборотБазоваяФункциональность =
			ОбщегоНазначения.ОбщийМодуль("ИнтеграцияС1СДокументооборотБазоваяФункциональность");
		МодульИнтеграцияС1СДокументооборотБазоваяФункциональность.ПриСозданииНаСервере(ЭтотОбъект);
	КонецЕсли;
	// Конец ИнтеграцияС1СДокументооборотом

	Если Параметры.Ключ.Пустая() Тогда
		ПодготовитьФормуНаСервере();
	КонецЕсли;
	
	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект, СтандартнаяОбработка);
	
	ТекущаяКонтрольнаяСумма = ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор();
	
	УстановитьУсловноеОформление();
	
	УправлениеФормой(ЭтотОбъект);

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
		
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
	ПодготовитьФормуНаСервере();
	
	РежимЗаполнения = 0;
	ЗаполнитьДобавленныеКолонкиТаблиц(РежимЗаполнения);

	ОбновитьИнформационныеТаблоНаСервере(Истина, Истина);
	
	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект);
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// ИнтеграцияС1СДокументооборотом
	Если ОбщегоНазначения.ПодсистемаСуществует("ИнтеграцияС1СДокументооборотом") Тогда
		МодульИнтеграцияС1СДокументооборотБазоваяФункциональность =
			ОбщегоНазначения.ОбщийМодуль("ИнтеграцияС1СДокументооборотБазоваяФункциональность");
		МодульИнтеграцияС1СДокументооборотБазоваяФункциональность.ПередЗаписьюНаСервере(ЭтотОбъект,
																						ТекущийОбъект,
																						ПараметрыЗаписи);
	КонецЕсли;
	// Конец ИнтеграцияС1СДокументооборотом
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)	
	
	РежимЗаполнения = 0;
	ЗаполнитьДобавленныеКолонкиТаблиц(РежимЗаполнения, Ложь);
	
	ПодготовитьФормуНаСервере();
	
	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект);
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.Свойств
	
	УправлениеТаблоСчетов();
	
	Если НЕ Параметры.Ключ.Пустая() Тогда 
		Если ИнтервалАвтообновленияТаблоСчетов > 0 И ОтобразитьТаблоСчетов Тогда
			ПодключитьОбработчикОжидания("ОбработчикОжиданияОбновитьТабло", ИнтервалАвтообновленияТаблоСчетов, Ложь);
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ОбработатьОповещение = Ложь;
	
	Если Источник = УникальныйИдентификатор Тогда
		Если ИмяСобытия = "ИзмененСтатус" Тогда
			ОбработкаОповещенияИзмененияСтатуса();
		КонецЕсли;
	ИначеЕсли Источник = ЭтотОбъект Тогда 
		Если ИмяСобытия = "бит_ИзменениеДокументаПлатежнаяПозиция" Тогда
			Для каждого СтрокаТаблицы Из Объект.ТаблицаПлатежи Цикл
				Если СтрокаТаблицы.ПлатежнаяПозиция = Параметр.Ссылка Тогда
					ОбработатьИзмененияВПлатежнойПозиции(СтрокаТаблицы.ПолучитьИдентификатор());
					ОбработатьОповещение = Истина;
				КонецЕсли;
			КонецЦикла;
		ИначеЕсли ИмяСобытия = "бит_ИзменениеДокументаЗаявкаНаРасходованиеДС" 
			  ИЛИ ИмяСобытия = "бит_ИзменениеДокументаПеремещениеДС"
			  ИЛИ ИмяСобытия = "бит_ИзменениеДокументаПереводДСВДругуюОрганизацию" Тогда	
			Для каждого СтрокаТаблицы Из Объект.ТаблицаПлатежи Цикл
				КоллекцияСтрок = Новый Массив;
				Если СтрокаТаблицы.ЗаявкаПлатежнаяПозиция = Параметр Тогда
					КоллекцияСтрок.Добавить(СтрокаТаблицы.ПолучитьИдентификатор());
					ОбработатьОповещение = Истина;
				КонецЕсли;
				Если ОбработатьОповещение Тогда
					ОбработатьИзмененияВПлатежнойПозиции(КоллекцияСтрок);
				КонецЕсли;
			КонецЦикла;
		ИначеЕсли Источник = ЭтотОбъект И ИмяСобытия = "ПодборВРеестрПлатежей" Тогда
			Если ТипЗнч(Параметр) = Тип("Массив") Тогда
				ПодборВРеестрПлатежейЗавершение(Параметр);
				ОбработатьОповещение = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
		
	// СтандартныеПодсистемы.Свойства
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтотОбъект, ИмяСобытия, Параметр) Тогда
		ОбновитьЭлементыДополнительныхРеквизитов();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства

	Если ОбработатьОповещение Тогда
		ОбновитьИнформационныеТабло(Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
		
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	Если НЕ ЗавершениеРаботы Тогда
		СохранитьНастройки();
	КонецЕсли;  
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ГруппаСтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	// СтандартныеПодсистемы.Свойства
	Если ЭтотОбъект.ПараметрыСвойств.Свойство(ТекущаяСтраница.Имя)
		И Не ЭтотОбъект.ПараметрыСвойств.ВыполненаОтложеннаяИнициализация Тогда
		СвойстваВыполнитьОтложеннуюИнициализацию();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
		УправлениеФормой(ЭтотОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	Если Не ЗначениеЗаполнено(Объект.Организация) Тогда
		Возврат;	
	КонецЕсли; 
	
	ОбновитьСписки = Ложь;
	Индекс 		   = Объект.ТаблицаПлатежи.Количество() - 1;
	
	Пока Индекс >= 0 Цикл
		СтрокаТаблицы = Объект.ТаблицаПлатежи.Получить(Индекс);		
		Если СтрокаТаблицы.Организация <> Объект.Организация Тогда
			Объект.ТаблицаПлатежи.Удалить(Индекс);	
			ОбновитьСписки = Истина;
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла; 
	
	Если ОбновитьСписки Тогда
		ОбновитьИнформационныеТабло(Истина);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ИнформацияСтатусНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Фильтр 		   = Новый Структура("Объект", Объект.Ссылка);
	ПараметрыФормы = Новый Структура("Отбор", Фильтр);
	Открытьформу("РегистрСведений.бит_ИсторияИзмененияСтатусовОбъектов.ФормаСписка", 
		ПараметрыФормы, ЭтотОбъект, ЭтотОбъект,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаОплатыПриИзменении(Элемент)
	
	РежимЗаполнения = 1;
	ЗаполнитьДобавленныеКолонкиТаблиц(РежимЗаполнения);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблоСчетов

&НаКлиенте
Процедура ТаблоСчетовПриАктивизацииСтроки(Элемент)
	
	Если УстанавливатьОтборВПеречне <> Неопределено Тогда
		
		ТекущаяСтрока = Элементы.ТаблоСчетов.ТекущиеДанные;
		
		Если ТекущаяСтрока <> Неопределено И РежимТабло = "УстанавливатьОтборы" Тогда
			УстановитьОтборВЗаявках(ТекущаяСтрока.КонтрольнаяСумма);
		КонецЕсли; 	
	КонецЕсли; 
	
	УстанавливатьОтборВПеречне = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаПлатежи

&НаКлиенте
Процедура ТаблицаПлатежиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ТаблицаПлатежи.ТекущиеДанные;

	Если Поле = Элементы.ТаблицаПлатежиНадписьЗаявка Тогда
		
		СтандартнаяОбработка = Ложь;
		ИмяФормыОбъекта		 = "Документ.бит_кзн_ЗаявкаНаРасходованиеСредств.ФормаОбъекта";
		
		Если ТипЗнч(ТекущиеДанные.ЗаявкаПлатежнаяПозиция) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда
			ИмяФормыОбъекта = "Документ.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию.ФормаОбъекта"; 
		ИначеЕсли ТипЗнч(ТекущиеДанные.ЗаявкаПлатежнаяПозиция) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда
			ИмяФормыОбъекта = "Документ.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.ФормаОбъекта"; 
		КонецЕсли;
		
		ПараметрыФормы = Новый Структура("Ключ", ТекущиеДанные.ЗаявкаПлатежнаяПозиция);
		ОткрытьФорму(ИмяФормыОбъекта, ПараметрыФормы, ЭтотОбъект, ТекущиеДанные.ЗаявкаПлатежнаяПозиция);
		
	ИначеЕсли Поле = Элементы.ТаблицаПлатежиНадписьПозиция Тогда
		
		СтандартнаяОбработка = Ложь;
		ПараметрыФормы = Новый Структура("Ключ", ТекущиеДанные.ПлатежнаяПозиция);
		
		ОткрытьФорму("Документ.бит_кзн_ПлатежнаяПозиция.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект, 
			ТекущиеДанные.ПлатежнаяПозиция);
			
	ИначеЕсли Поле = Элементы.ТаблицаПлатежиПлатежныйДокумент Тогда
		
		СтандартнаяОбработка = Ложь;		
		Если ЗначениеЗаполнено(ТекущиеДанные.ПлатежныйДокумент) Тогда
			ПоказатьЗначение(, ТекущиеДанные.ПлатежныйДокумент);
		КонецЕсли;	
		
	Иначе
		бит_РаботаСДиалогамиКлиент.ОбработкаВыбораПоляТабличногоПоля("ТаблицаПлатежи", 
			Объект.ТаблицаПлатежи, Поле, ВыбраннаяСтрока);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПлатежиПриАктивизацииСтроки(Элемент)
	
	ПодключитьОбработчикОжидания("ПлатежиПриАктивизацииСтрокиОжидание", 0.5, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПлатежиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Отказ = Истина;
	ОткрытьПодборДокументов();
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПлатежиПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТекущиеДанные = Элементы.ТаблицаПлатежи.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; 

	ТекущееМестоХранения = ТекущиеДанные.СчетКасса;
	
	Если ТекущиеДанные.ФормаОплаты = ПредопределенноеЗначение("Перечисление.бит_ВидыДенежныхСредств.Безналичные") Тогда
		Элементы.ТаблицаПлатежиСчетКасса.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчетаОрганизаций");	
	Иначе	
		Элементы.ТаблицаПлатежиСчетКасса.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Кассы");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ПлатежнаяПозиция) Тогда
		УстановитьОтборыБанковскийСчетКасса(ТекущиеДанные.ПолучитьИдентификатор());
	КонецЕсли; 

КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПлатежиПослеУдаления(Элемент)
	
	ОбновитьИнформационныеТабло(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПлатежиОплаченоПриИзменении(Элемент)

	ТекущиеДанные  = Элементы.ТаблицаПлатежи.ТекущиеДанные;
	Если ТекущиеДанные.СтатусЗаявкиПравильный Тогда
		// Произведем вычисления в табличном поле "ТаблоСчетов".
		ОбработатьИзменениеВОплату(ТекущиеДанные, ЭтотОбъект);
		ОбновитьТаблоПлатежейНаСервере();
	Иначе		
		ТекущиеДанные.Оплачено = НЕ ТекущиеДанные.Оплачено;
		ТекстСообщения = НСтр("ru='К оплате могут быть допущены только проведенные платежные позиции.';
							  |en='Only entered payment positions may be paid.'");
		ПоказатьПредупреждение(,ТекстСообщения,, НСтр("ru='Реестр платежей';en='Registry of Amounts to Pay'"));
	КонецЕсли;	

КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПлатежиСчетКассаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ТаблицаПлатежи.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	Если ВыбранноеЗначение = ТекущееМестоХранения Тогда
		Возврат;	
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Идентификатор = ТекущиеДанные.ПолучитьИдентификатор();
		ОбновитьПлатежнуюПозицию(Идентификатор, ВыбранноеЗначение, "Все");
		Если ТекущиеДанные.СчетКасса <> ТекущееМестоХранения Тогда
			ОбновитьИнформационныеТабло(Ложь);
			ОповеститьОбИзменении(ТекущиеДанные.ПлатежнаяПозиция);
		КонецЕсли; 
	КонецЕсли; 

	ТекущееМестоХранения = ТекущиеДанные.СчетКасса; 

КонецПроцедуры

