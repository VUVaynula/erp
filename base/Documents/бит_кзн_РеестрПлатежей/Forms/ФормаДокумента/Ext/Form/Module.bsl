&НаСервере
Функция ОсталосьОплатить(Позиция)

	ОсталосьОплатить = 0;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Позиция", Позиция);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПланируемыйРасходДенежныхСредств.СуммаОстаток КАК Сумма
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.Остатки(, Позиция = &Позиция) КАК ПланируемыйРасходДенежныхСредств";
	
	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	Если Выборка.Следующий() Тогда
		ОсталосьОплатить = Выборка.Сумма;
	КонецЕсли;
		
	Возврат ОсталосьОплатить;
	
КонецФункции

&НаСервере
Процедура ОбновитьПлатежнуюПозицию(Идентификатор, МестоХранения, РежимСообщений)

	// Обновим платежную позицию
	СтрокаТаблицы 	 = Объект.ТаблицаПлатежи.НайтиПоИдентификатору(Идентификатор); 
	ПлатежнаяПозиция = СтрокаТаблицы.ПлатежнаяПозиция;
	
	ДокументОбъект = ПлатежнаяПозиция.ПолучитьОбъект();
	Заблокирован   = бит_ОбщегоНазначения.ЗаблокироватьОбъект(ДокументОбъект,
								Строка(ПлатежнаяПозиция),, РежимСообщений);
								
	Если НЕ Заблокирован Тогда
		Возврат;		
	КонецЕсли;            		

	Если ТипЗнч(МестоХранения) = Тип("СправочникСсылка.БанковскиеСчетаОрганизаций") Тогда
		ДокументОбъект.БанковскийСчет = МестоХранения;
	Иначе
		ДокументОбъект.Касса = МестоХранения;
	КонецЕсли;
	
	РежимЗаписи = РежимЗаписиДокумента.Запись;
	
	Если ДокументОбъект.Проведен Тогда
		РежимЗаписи = РежимЗаписиДокумента.Проведение;
	КонецЕсли;
										
	Записан = бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ДокументОбъект, РежимЗаписи,, РежимСообщений);
					
	Если Записан Тогда
		СтрокаТаблицы.СчетКасса 	   = МестоХранения;
		СтрокаТаблицы.КонтрольнаяСумма = КонтрольнаяСуммаСтрокой(СтрокаТаблицы.СчетКасса, СтрокаТаблицы.Организация); 
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриИзмененииСуммыКОплатеВТаблицеПлатежейНаСервере(Знач ИдентификаторСтроки)

	ТекущиеДанные	 = Объект.ТаблицаПлатежи.НайтиПоИдентификатору(ИдентификаторСтроки);
	ОсталосьОплатить = ОсталосьОплатить(ТекущиеДанные.ПлатежнаяПозиция);
	
	Если ТекущиеДанные.ВалютаПлатежа = ТекущиеДанные.ВалютаДокумента Тогда
		Если ТекущиеДанные.СуммаКОплате > ОсталосьОплатить Тогда
			ТекущиеДанные.СуммаКОплате = ОсталосьОплатить;
		КонецЕсли;
		ТекущиеДанные.СуммаОстаток = ТекущиеДанные.СуммаКОплате;
	Иначе
		
		ПараметрыПередачи = Новый Структура;
		ПараметрыПередачи.Вставить("КурсЧислительВзаиморасчетов", 	ТекущиеДанные.КурсЧислительВзаиморасчетов);
		ПараметрыПередачи.Вставить("КурсЗнаменательВзаиморасчетов", ТекущиеДанные.КурсЗнаменательВзаиморасчетов);
		ПараметрыПередачи.Вставить("СуммаВзаиморасчетов", 			ОсталосьОплатить);
		ПараметрыПередачи.Вставить("Сумма", 						0);
		
		ДенежныеСредстваКлиентСервер.РассчитатьСуммуВСтрокеРасшифровки(
			ПараметрыПередачи, ТекущиеДанные.ВалютаПлатежа, ВалютаРеглУчета);
		
		Если ТекущиеДанные.СуммаКОплате > ПараметрыПередачи.Сумма Тогда
			ТекущиеДанные.СуммаКОплате = ПараметрыПередачи.Сумма;
		КонецЕсли;	
		
		ПараметрыПередачи = Новый Структура;
		ПараметрыПередачи.Вставить("КурсЧислительВзаиморасчетов", 	ТекущиеДанные.КурсЧислительВзаиморасчетов);
		ПараметрыПередачи.Вставить("КурсЗнаменательВзаиморасчетов", ТекущиеДанные.КурсЗнаменательВзаиморасчетов);
		ПараметрыПередачи.Вставить("СуммаВзаиморасчетов", 			ТекущиеДанные.СуммаКОплате);
		ПараметрыПередачи.Вставить("Сумма", 						ТекущиеДанные.СуммаОстаток);
		
		ДенежныеСредстваКлиентСервер.РассчитатьСуммуВСтрокеРасшифровки(
			ПараметрыПередачи, ТекущиеДанные.ВалютаДокумента, ВалютаРеглУчета);
		
		ТекущиеДанные.СуммаОстаток = ПараметрыПередачи.Сумма; 	
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриИзмененииСуммыОстатокВТаблицеПлатежейНаСервере(Знач ИдентификаторСтроки)
	
	ТекущиеДанные 	 = Объект.ТаблицаПлатежи.НайтиПоИдентификатору(ИдентификаторСтроки);
	ОсталосьОплатить = ОсталосьОплатить(ТекущиеДанные.ПлатежнаяПозиция);
		
	Если ТекущиеДанные.СуммаОстаток > ОсталосьОплатить Тогда
		ТекущиеДанные.СуммаОстаток = ОсталосьОплатить;
	КонецЕсли;
		
	Если ТекущиеДанные.ВалютаПлатежа = ТекущиеДанные.ВалютаДокумента Тогда
		ТекущиеДанные.СуммаКОплате = ТекущиеДанные.СуммаОстаток;
	Иначе
		
		ПараметрыПередачи = Новый Структура;
		ПараметрыПередачи.Вставить("КурсЧислительВзаиморасчетов", 	ТекущиеДанные.КурсЧислительВзаиморасчетов);
		ПараметрыПередачи.Вставить("КурсЗнаменательВзаиморасчетов", ТекущиеДанные.КурсЗнаменательВзаиморасчетов);
		ПараметрыПередачи.Вставить("СуммаВзаиморасчетов", 			ТекущиеДанные.СуммаОстаток);
		ПараметрыПередачи.Вставить("Сумма", 						ТекущиеДанные.СуммаКОплате);
		
		ДенежныеСредстваКлиентСервер.РассчитатьСуммуВСтрокеРасшифровки(
			ПараметрыПередачи, ТекущиеДанные.ВалютаПлатежа, ВалютаРеглУчета);
		
		ТекущиеДанные.СуммаКОплате = ПараметрыПередачи.Сумма; 	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СтрокаТаблоСКонтрольнойСуммой(КонтрольнаяСумма, Коллекция)
	
	Результат = Неопределено;
	
	Для каждого Элемент Из Коллекция Цикл
		Если Результат <> Неопределено Тогда
			Прервать;
		КонецЕсли;
		Если Элемент.КонтрольнаяСумма = КонтрольнаяСумма Тогда
			Результат = Элемент;
		Иначе
			ПодчиненныеСтроки = Элемент.ПолучитьЭлементы();
			Если ПодчиненныеСтроки.Количество() > 0 Тогда
				Результат = СтрокаТаблоСКонтрольнойСуммой(КонтрольнаяСумма, ПодчиненныеСтроки);
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла; 
	
	Возврат Результат;
	
КонецФункции

