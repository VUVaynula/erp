&НаКлиенте
Процедура РазбитьДокумент(Команда)
	
	ТекущиеДанные = Элементы.ТаблицаПлатежи.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ПлатежныйДокумент) Тогда
		ТекстСообщения = НСтр("ru = 'Документ оплачен. Операция не поддерживается.'; 
								|en = 'The document is paid. The operation is not supported.'");
		ВызватьИсключение ТекстСообщения;		
	КонецЕсли;
	
	Если ТипЗнч(ТекущиеДанные.ЗаявкаПлатежнаяПозиция) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств")
	 ИЛИ ТипЗнч(ТекущиеДанные.ЗаявкаПлатежнаяПозиция) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда			
		ТекстСообщения = НСтр("ru='Запрещено разбивать платеж для Заявок на перемещение ДС и Заявок на перевод ДС в другую организацию.';
								|en='It is forbidden to divide the payment for applications for moving the DS and DS Applications for transfer to another organization.'");
		ВызватьИсключение ТекстСообщения;
	КонецЕсли;
	
	Дополнительно = Новый Структура; 
	Дополнительно.Вставить("Сумма", ТекущиеДанные.СуммаПлан);
	Дополнительно.Вставить("Идентификатор", ТекущиеДанные.ПолучитьИдентификатор());
	
	Оповещение = Новый ОписаниеОповещения("РазбитьПлатежЗавершение", ЭтотОбъект, Дополнительно);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Запланировано", ТекущиеДанные.СуммаПлан);
	ПараметрыФормы.Вставить("Валюта", 		 ТекущиеДанные.ВалютаПлатежа);
	
	Открытьформу("Документ.бит_кзн_РеестрПлатежей.Форма.ДатаПлатежаИСуммаОплаты",
		ПараметрыФормы, ЭтотОбъект, ЭтотОбъект,,, Оповещение); 
		
КонецПроцедуры
	
