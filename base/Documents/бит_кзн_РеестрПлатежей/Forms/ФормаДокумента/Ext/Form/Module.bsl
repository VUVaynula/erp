&НаКлиенте
Процедура ГрупповаяОплата(Команда)

	Если Объект.ТаблицаПлатежи.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Проверка статуса
	Если НЕ СтатусДокументаПравильный() Тогда
		Возврат;
	КонецЕсли;
	
	Позиции = ПозицииДляГрупповойОплаты();
	
	Если ЗначениеЗаполнено(Позиции) Тогда	
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Позиции" , 					Новый ФиксированныйМассив(Позиции));
		ПараметрыФормы.Вставить("ДатаОплаты" , 					ДатаОплаты);
		ПараметрыФормы.Вставить("РежимЗаписиРасчетыЧерезБанк", 	РежимЗаписиРасчетыЧерезБанк);
		ПараметрыФормы.Вставить("РежимЗаписиРасчетыЧерезКассу", РежимЗаписиРасчетыЧерезКассу);
		ПараметрыФормы.Вставить("ВызовИзРеестра", 				Истина);
		
		Оповещение = Новый ОписаниеОповещения("ГрупповаяОплатаОкончание", ЭтотОбъект); 
		ОткрытьФорму("Обработка.бит_ГрупповаяОплатаЗаявок.Форма", ПараметрыФормы, ЭтотОбъект,,,, Оповещение);
	Иначе
		ТекстСообщения = НСтр("ru='Отсутствуют платежные позиции для групповой оплаты';
							  |en='Payment positions for group payment are missing'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЕсли; 
	
КонецПроцедуры

