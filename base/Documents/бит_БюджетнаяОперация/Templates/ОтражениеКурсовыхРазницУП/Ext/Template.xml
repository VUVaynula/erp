			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КорСчет</dataPath>
			<field>КорСчет</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>БанковскийСчет</dataPath>
			<field>БанковскийСчет</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Банковский счет</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Подразделение</dataPath>
			<field>Подразделение</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
				<dcscom:ignoreNullValues>true</dcscom:ignoreNullValues>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Сумма</dataPath>
			<field>Сумма</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДоговорКонтрагента</dataPath>
			<field>ДоговорКонтрагента</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Договор контрагента</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДокументДвижения</dataPath>
			<field>ДокументДвижения</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Документ движения</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Период</dataPath>
			<field>Период</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Период</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТипДокумента</dataPath>
			<field>ТипДокумента</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Тип документа</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПрочиеДоходыИРасходы</dataPath>
			<field>ПрочиеДоходыИРасходы</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Прочие доходы и расходы</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СтатьяОборотов</dataPath>
			<field>СтатьяОборотов</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Статья оборотов</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЦФО</dataPath>
			<field>ЦФО</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>ЦФО</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СтатьиДоходов.Ссылка КАК ПрочиеДоходыИРасходы
ПОМЕСТИТЬ ВТПрочиеДоходыИРасходы
ИЗ
	ПланВидовХарактеристик.СтатьиДоходов КАК СтатьиДоходов
{ГДЕ
	СтатьиДоходов.Ссылка.* КАК ПрочиеДоходыИРасходы}

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	СтатьиРасходов.Ссылка
ИЗ
	ПланВидовХарактеристик.СтатьиРасходов КАК СтатьиРасходов
{ГДЕ
	СтатьиРасходов.Ссылка.* КАК ПрочиеДоходыИРасходы}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	СоответствияАналитик.ЛеваяАналитика_1 КАК Организация,
	СоответствияАналитик.ПраваяАналитика_1 КАК ЦФО
ПОМЕСТИТЬ ВТСтруктураПредприятияЦФО
ИЗ
	РегистрСведений.бит_СоответствияАналитик.СрезПоследних({(&amp;КонецПериода)}, ВидСоответствия = ЗНАЧЕНИЕ(Справочник.бит_ВидыСоответствийАналитик.Организации_ЦФО)) КАК СоответствияАналитик
ГДЕ
	СоответствияАналитик.Используется
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Хозрасчетный.Ссылка КАК СчетУчета
ПОМЕСТИТЬ ВТСчетаУчетаНаличныхИБезналичных
ИЗ
	ПланСчетов.Хозрасчетный КАК Хозрасчетный
ГДЕ
	Хозрасчетный.Ссылка В ИЕРАРХИИ (ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.Касса))

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	Хозрасчетный.Ссылка
ИЗ
	ПланСчетов.Хозрасчетный КАК Хозрасчетный
ГДЕ
	Хозрасчетный.Ссылка В ИЕРАРХИИ (ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетныеСчета), ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ВалютныеСчета), ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.СпециальныеСчета), ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПереводыВПути_))
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВТПрочиеДоходыИРасходы.ПрочиеДоходыИРасходы КАК ПрочиеДоходыИРасходы,
	СоответствияАналитик.ПраваяАналитика_1 КАК СтатьяОборотов
ПОМЕСТИТЬ ВТСоответствиеСтатей
ИЗ
	ВТПрочиеДоходыИРасходы КАК ВТПрочиеДоходыИРасходы
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_СоответствияАналитик.СрезПоследних({(&amp;КонецПериода)}, ВидСоответствия В (ЗНАЧЕНИЕ(Справочник.бит_ВидыСоответствийАналитик.СтатьиПрочихРасходовСтатьиОборотов), ЗНАЧЕНИЕ(Справочник.бит_ВидыСоответствийАналитик.СтатьиДоходов_СтатьиОборотов))) КАК СоответствияАналитик
		ПО ВТПрочиеДоходыИРасходы.ПрочиеДоходыИРасходы = СоответствияАналитик.ЛеваяАналитика_1
ГДЕ
	СоответствияАналитик.Используется
{ГДЕ
	СоответствияАналитик.ПраваяАналитика_1.* КАК СтатьяОборотов}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ХозрасчетныйОбороты.Счет КАК Счет,
	ХозрасчетныйОбороты.КорСчет КАК КорСчет,
	ЕСТЬNULL(ХозрасчетныйОбороты.ПодразделениеКор, НЕОПРЕДЕЛЕНО) КАК Подразделение,
	ВЫБОР
		КОГДА ХозрасчетныйОбороты.СуммаОборот &lt; 0
			ТОГДА ХозрасчетныйОбороты.СуммаОборот * -1 / &amp;РазмерностьЕдиницы
		ИНАЧЕ ХозрасчетныйОбороты.СуммаОборот / &amp;РазмерностьЕдиницы
	КОНЕЦ * &amp;КратностьДокумента / &amp;КурсДокумента КАК Сумма,
	ХозрасчетныйОбороты.Организация КАК Организация,
	ХозрасчетныйОбороты.Организация КАК ОрганизацияАналитика,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ХозрасчетныйОбороты.КорСубконто1) = ТИП(Справочник.Контрагенты)
			ТОГДА ХозрасчетныйОбороты.КорСубконто1
		КОГДА ТИПЗНАЧЕНИЯ(ХозрасчетныйОбороты.КорСубконто2) = ТИП(Справочник.Контрагенты)
			ТОГДА ХозрасчетныйОбороты.КорСубконто2
		КОГДА ТИПЗНАЧЕНИЯ(ХозрасчетныйОбороты.КорСубконто3) = ТИП(Справочник.Контрагенты)
			ТОГДА ХозрасчетныйОбороты.КорСубконто3
		ИНАЧЕ НЕОПРЕДЕЛЕНО
	КОНЕЦ КАК Контрагент,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ХозрасчетныйОбороты.КорСубконто1) = ТИП(Справочник.ДоговорыКонтрагентов)
			ТОГДА ХозрасчетныйОбороты.КорСубконто1
		КОГДА ТИПЗНАЧЕНИЯ(ХозрасчетныйОбороты.КорСубконто2) = ТИП(Справочник.ДоговорыКонтрагентов)
			ТОГДА ХозрасчетныйОбороты.КорСубконто2
		КОГДА ТИПЗНАЧЕНИЯ(ХозрасчетныйОбороты.КорСубконто3) = ТИП(Справочник.ДоговорыКонтрагентов)
			ТОГДА ХозрасчетныйОбороты.КорСубконто3
		ИНАЧЕ НЕОПРЕДЕЛЕНО
	КОНЕЦ КАК ДоговорКонтрагента,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ХозрасчетныйОбороты.КорСубконто1) = ТИП(Справочник.БанковскиеСчетаОрганизаций)
			ТОГДА ХозрасчетныйОбороты.КорСубконто1
		КОГДА ТИПЗНАЧЕНИЯ(ХозрасчетныйОбороты.КорСубконто2) = ТИП(Справочник.БанковскиеСчетаОрганизаций)
			ТОГДА ХозрасчетныйОбороты.КорСубконто2
		КОГДА ТИПЗНАЧЕНИЯ(ХозрасчетныйОбороты.КорСубконто3) = ТИП(Справочник.БанковскиеСчетаОрганизаций)
			ТОГДА ХозрасчетныйОбороты.КорСубконто3
		ИНАЧЕ НЕОПРЕДЕЛЕНО
	КОНЕЦ КАК БанковскийСчет,
	ХозрасчетныйОбороты.Регистратор КАК ДокументДвижения,
	ХозрасчетныйОбороты.ПериодДень КАК Период,
	ТИПЗНАЧЕНИЯ(ХозрасчетныйОбороты.Регистратор) КАК ТипДокумента,
	ХозрасчетныйОбороты.Субконто1 КАК ПрочиеДоходыИРасходы
ПОМЕСТИТЬ ВТКурсовыеРазницы
ИЗ
	РегистрБухгалтерии.Хозрасчетный.Обороты(
			&amp;НачалоПериода {(&amp;НачалоПериода)},
			&amp;КонецПериода {(&amp;КонецПериода)},
			Авто,
			{(Счет).* КАК Счет},
			ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.ПрочиеДоходыИРасходы),
			Субконто1 В
				(ВЫБРАТЬ РАЗЛИЧНЫЕ
					ВТПрочиеДоходыИРасходы.ПрочиеДоходыИРасходы КАК ПрочиеДоходыИРасходы
				ИЗ
					ВТПрочиеДоходыИРасходы КАК ВТПрочиеДоходыИРасходы) {(Организация).* КАК Организация},
			{(КорСчет).* КАК КорСчет},
			) КАК ХозрасчетныйОбороты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТКурсовыеРазницы.Счет КАК Счет,
	ВТКурсовыеРазницы.КорСчет КАК КорСчет,
	ЕСТЬNULL(ВТПрочиеДоходыИРасходы.ПрочиеДоходыИРасходы, НЕОПРЕДЕЛЕНО) КАК ПрочиеДоходыИРасходы,
	ВТКурсовыеРазницы.Подразделение КАК Подразделение,
	ВТКурсовыеРазницы.Сумма КАК Сумма,
	ВТКурсовыеРазницы.Организация КАК Организация,
	ВТКурсовыеРазницы.ОрганизацияАналитика КАК ОрганизацияАналитика,
	ВТКурсовыеРазницы.Контрагент КАК Контрагент,
	ВТКурсовыеРазницы.ДоговорКонтрагента КАК ДоговорКонтрагента,
	ВТКурсовыеРазницы.БанковскийСчет КАК БанковскийСчет,
	ВТКурсовыеРазницы.ДокументДвижения КАК ДокументДвижения,
	ВТКурсовыеРазницы.Период КАК Период,
	ВТКурсовыеРазницы.ТипДокумента КАК ТипДокумента,
	ВЫБОР
		КОГДА НЕ ВТСчетаУчетаНаличныхИБезналичных.СчетУчета ЕСТЬ NULL
			ТОГДА ЕСТЬNULL(ВТСоответствиеСтатей.СтатьяОборотов, ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.ПустаяСсылка))
		КОГДА ВТКурсовыеРазницы.Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПрочиеДоходы)
			ТОГДА ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.КурсовыеРазницыБДРПоложительные)
		КОГДА ВТКурсовыеРазницы.Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПрочиеРасходы)
			ТОГДА ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.КурсовыеРазницыБДРОтрицательные)
		ИНАЧЕ ЕСТЬNULL(ВТСоответствиеСтатей.СтатьяОборотов, ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.ПустаяСсылка))
	КОНЕЦ КАК СтатьяОборотов,
	ЕСТЬNULL(ВТСтруктураПредприятияЦФО.ЦФО, ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка)) КАК ЦФО
{ВЫБРАТЬ
	Счет.*,
	КорСчет.*,
	ПрочиеДоходыИРасходы.*,
	Подразделение.*,
	Сумма,
	Организация.*,
	ОрганизацияАналитика.*,
	Контрагент.*,
	ДоговорКонтрагента.*,
	БанковскийСчет.*,
	ДокументДвижения.*,
	Период,
	ТипДокумента,
	СтатьяОборотов.*,
	ЦФО.*}
ИЗ
	ВТКурсовыеРазницы КАК ВТКурсовыеРазницы
		ЛЕВОЕ СОЕДИНЕНИЕ ВТПрочиеДоходыИРасходы КАК ВТПрочиеДоходыИРасходы
		ПО ВТКурсовыеРазницы.ПрочиеДоходыИРасходы = ВТПрочиеДоходыИРасходы.ПрочиеДоходыИРасходы
		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтруктураПредприятияЦФО КАК ВТСтруктураПредприятияЦФО
		ПО ВТКурсовыеРазницы.Организация = ВТСтруктураПредприятияЦФО.Организация
		ЛЕВОЕ СОЕДИНЕНИЕ ВТСоответствиеСтатей КАК ВТСоответствиеСтатей
		ПО ВТКурсовыеРазницы.ПрочиеДоходыИРасходы = ВТСоответствиеСтатей.ПрочиеДоходыИРасходы
		ЛЕВОЕ СОЕДИНЕНИЕ ВТСчетаУчетаНаличныхИБезналичных КАК ВТСчетаУчетаНаличныхИБезналичных
		ПО ВТКурсовыеРазницы.КорСчет = ВТСчетаУчетаНаличныхИБезналичных.СчетУчета
{ГДЕ
	ВТКурсовыеРазницы.Счет.*,
	ВТКурсовыеРазницы.КорСчет.*,
	ВТКурсовыеРазницы.Подразделение.*,
	ВТКурсовыеРазницы.Сумма,
	ВТКурсовыеРазницы.Организация.*,
	ВТКурсовыеРазницы.ОрганизацияАналитика.*,
	ВТКурсовыеРазницы.Контрагент.*,
	ВТКурсовыеРазницы.ДоговорКонтрагента.*,
	ВТКурсовыеРазницы.БанковскийСчет.*,
	ВТКурсовыеРазницы.ДокументДвижения.*,
	ВТКурсовыеРазницы.Период,
	ВТКурсовыеРазницы.ТипДокумента,
	(ВЫБОР
