Функция ТекстЗапросаВременнаяТаблицаДокумента(НомераТаблиц)

	НомераТаблиц.Вставить("ВременнаяТаблицаДокумента", НомераТаблиц.Количество());
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	""БДДС"" КАК ИмяСписка,
	|	&СинонимБДДС КАК СинонимСписка,
	|	1 КАК НомерТаблицы,
	|	Таблица.Ссылка КАК Ссылка,
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.Период КАК Период,
	|	&Сценарий КАК Сценарий,
	|	&Валюта КАК Валюта,
	|	Таблица.ЦФО КАК ЦФО,
	|	Таблица.СтатьяОборотов КАК СтатьяОборотов,
	|	ЕСТЬNULL(Таблица.СтатьяОборотов.СтавкаНДС, ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.ПустаяСсылка)) КАК СтавкаНДС,
	|	ЕСТЬNULL(Таблица.СтатьяОборотов.ЭтоКоэффициент, ЛОЖЬ) КАК ЭтоКоэффициент,
	|	Таблица.Количество КАК Количество,
	|	ВЫБОР
	|		КОГДА Таблица.СтатьяОборотов.ЭтоКоэффициент
	|			ТОГДА ЕСТЬNULL(Таблица.Сумма, 0)
	|		ИНАЧЕ ЕСТЬNULL(Таблица.Сумма, 0) * &КоэффициентСуммы
	|	КОНЕЦ КАК Сумма,
	|	0 КАК СуммаРегл,
	|	0 КАК СуммаУпр,
	|	0 КАК СуммаСценарий,
	|	Таблица.Комментарий КАК Комментарий,
	|	Таблица.Аналитика_1 КАК Аналитика_1,
	|	Таблица.Аналитика_2 КАК Аналитика_2,
	|	Таблица.Аналитика_3 КАК Аналитика_3,
	|	Таблица.Аналитика_4 КАК Аналитика_4,
	|	Таблица.Аналитика_5 КАК Аналитика_5,
	|	Таблица.Аналитика_6 КАК Аналитика_6,
	|	Таблица.Аналитика_7 КАК Аналитика_7,
	|	Таблица.Аналитика_8 КАК Аналитика_8,
	|	Таблица.Аналитика_9 КАК Аналитика_9,
	|	Таблица.Аналитика_10 КАК Аналитика_10,
	|	Таблица.Аналитика_11 КАК Аналитика_11,
	|	Таблица.Аналитика_12 КАК Аналитика_12
	|ПОМЕСТИТЬ ВременнаяТаблицаДокумента
	|ИЗ
	|	Документ.бит_БюджетнаяОперация.БДДС КАК Таблица
	|ГДЕ
	|	Таблица.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	""ЗависимыеОбороты"",
	|	&СинонимЗависимыеОбороты,
	|	2,
	|	Таблица.Ссылка,
	|	Таблица.НомерСтроки,
	|	Таблица.Период,
	|	&Сценарий,
	|	&Валюта,
	|	Таблица.ЦФО,
	|	Таблица.СтатьяОборотов,
	|	ЕСТЬNULL(Таблица.СтатьяОборотов.СтавкаНДС, ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.ПустаяСсылка)),
	|	ЕСТЬNULL(Таблица.СтатьяОборотов.ЭтоКоэффициент, ЛОЖЬ),
	|	Таблица.Количество,
	|	Таблица.Сумма * &КоэффициентСуммы,
	|	0,
	|	0,
	|	0,
	|	"""",
	|	Таблица.Аналитика_1,
	|	Таблица.Аналитика_2,
	|	Таблица.Аналитика_3,
	|	Таблица.Аналитика_4,
	|	Таблица.Аналитика_5,
	|	Таблица.Аналитика_6,
	|	Таблица.Аналитика_7,
	|	Таблица.Аналитика_8,
	|	Таблица.Аналитика_9,
	|	Таблица.Аналитика_10,
	|	Таблица.Аналитика_11,
	|	Таблица.Аналитика_12
	|ИЗ
	|	Документ.бит_БюджетнаяОперация.ЗависимыеОбороты КАК Таблица
	|ГДЕ
	|	Таблица.Ссылка = &Ссылка";

	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции

Функция ТекстЗапросаТаблицыВалютногоПерерасчета(НомераТаблиц)
	
