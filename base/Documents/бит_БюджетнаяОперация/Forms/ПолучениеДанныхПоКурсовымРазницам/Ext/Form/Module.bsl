
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПодготовитьФормуНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПериодДатаНачалаПриИзменении(Элемент)
	
	ПриИзмененииПериода();
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодДатаОкончанияПриИзменении(Элемент)
	
	ПриИзмененииПериода();
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантПериодаПриИзменении(Элемент)
	
    ПриИзмененииПериода();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыОтборы
&НаКлиенте
Процедура ОтборыПриИзменении(Элемент)
	
	ИзмененыНастройки = Истина;
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиСобытийЭлементовТаблицыФормыСортировка

&НаКлиенте
Процедура СортировкаПриИзменении(Элемент)
	
	ИзмененыНастройки = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПервичныеДокументы 

&НаКлиенте
Процедура ПервичныеДокументыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПервичныеДокументы.ТекущиеДанные;
	Если Поле = Элементы.ПервичныеДокументыДокументДвижения 
	   И ЗначениеЗаполнено(ТекущиеДанные.ДокументДвижения) Тогда
		НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(ТекущиеДанные.ДокументДвижения);
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(НавигационнаяСсылка);
	КонецЕсли;
	
КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыбратьНастройки(Команда)
	
	ПараметрыФормы = ПараметрыХраненияНастроек();
	Оповещение	   = Новый ОписаниеОповещения("ВыбратьНастройкиЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаЗагрузки", ПараметрыФормы, 
		ЭтотОбъект,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

// Обработчик завершения открытия формы.
//  См. Синтакс-помощник: ОткрытьФорму().
// 
&НаКлиенте 
Процедура ВыбратьНастройкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда        
		ПрименитьНастройки(Результат);
		
		ИзмененыНастройки = Истина;
		ОбработатьИзменениеНастроек(ЭтотОбъект);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьНастройки(Команда)
	
	Если НЕ ПериодЗаполненПравильно() Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = ПараметрыХраненияНастроек();
	ПараметрыФормы.Вставить("СтруктураНастройки" , СохраняемыеНастройки());
	
	Оповещение = Новый ОписаниеОповещения("СохранитьНастройкиЗавершение",ЭтотОбъект);
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаСохранения", ПараметрыФормы, 
		ЭтотОбъект,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры
	
// Обработчик завершения открытия формы.
//  См. Синтакс-помощник: ОткрытьФорму().
// 
&НаКлиенте
Процедура СохранитьНастройкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		УстановитьЗаголовок(Результат, ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры // СохранитьНастройки()

&НаКлиенте
Процедура ЗакрытьНастройки(Команда)
	
	СкрытьНастройки();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьНастройки(Команда)
	
	ОткрытьНастройки();
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьПериод(Команда)
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода();
	Диалог.Период = Период;
	
	Оповещение = Новый ОписаниеОповещения("НастроитьПериодЗавершение", ЭтотОбъект);
	Диалог.Показать(Оповещение);

КонецПроцедуры

// Обработчик завершения редактирования периода.
//  См. Синтакс-помощник: Показать().
// 
&НаКлиенте 
Процедура НастроитьПериодЗавершение(РезультатВыбора, ДополнительныеПараметры) Экспорт
	
	Если РезультатВыбора <> Неопределено Тогда
		Период = РезультатВыбора;
		ПриИзмененииПериода();
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура Сформировать(Команда)
	
	Если НЕ ПериодЗаполненПравильно() Тогда
		Возврат;
	КонецЕсли;	
		
	СкрытьНастройки();
		
	НачатьЗаполнениеСпискаДокументов();

КонецПроцедуры

&НаКлиенте
Процедура ПервичныеДокументыСнятьФлажки(Команда)
	
	ОбработатьФлаги(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПервичныеДокументыУстановитьФлажки(Команда)
	
	ОбработатьФлаги(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьВДокумент(Команда)
	
	Если ИзмененыНастройки Тогда
		ТекстСообщения = НСтр("ru = 'Изменились настройки. Нажмите ""Заполнить"" для заполнения списка документов.'; 
						|en = 'The settings have changed. Click ""Update"" to fill in the list of documents.'");
		ПоказатьПредупреждение(,ТекстСообщения);
		Возврат;
	КонецЕсли; 
	
	ПомеченныеСтроки = Новый Массив; 
	Для каждого СтрокаТаблицы Из ПервичныеДокументы Цикл
		Если СтрокаТаблицы.Пометка  Тогда
			ПомеченныеСтроки.Добавить(СтрокаТаблицы.ПолучитьИдентификатор());	
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ ЗначениеЗаполнено(ПомеченныеСтроки) Тогда
		Пояснение 	   = НСтр("ru = 'Нет помеченных строк.'");
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Список" , "Корректность",,,
							НСтр("ru = 'Курсовые разницы'"), Пояснение); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "ПервичныеДокументы"); 
	Иначе
		ПервичныеДокументыАдресВХранилище = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор());
		ЗагрузитьВДокументНаСервере(ПомеченныеСтроки, ПервичныеДокументыАдресВХранилище); 
		Закрыть(ПервичныеДокументыАдресВХранилище);
	КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте
Процедура СтандартныеНастройки(Команда)
	
	ПрименитьНастройки(Неопределено);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ФоновоеЗаполнение

&НаКлиенте
Процедура НачатьЗаполнениеСпискаДокументов()
	
	ИзмененыНастройки = Ложь;
	ОбработатьИзменениеНастроек(ЭтотОбъект);

	ДлительнаяОперация = ЗапуститьФоновоеЗаполнениеСпискаДокументов();
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ТекстСообщения 	   = НСтр("ru = 'Идет заполнение списка документов'"); 
	ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗаполненияСпискаДокументов", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОписаниеОповещения, ПараметрыОжидания);

КонецПроцедуры

&НаСервере
Функция ЗапуститьФоновоеЗаполнениеСпискаДокументов()
		
	// Заполнение пераметов длительной операции.
	НаименованиеЗадания = НСтр("ru = 'Заполнение списка документов.'");
	ВыполняемыйМетод	= "Документы.бит_БюджетнаяОперация.ДанныеПоКурсовымРазницам";

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	
	НастройкиКомпоновкиДанных = КомпоновщикНастроек.ПолучитьНастройки();
	
	бит_ОтчетыБФКлиентСервер.УстановитьПараметр(НастройкиКомпоновкиДанных, "Период", 			 Период);
	бит_ОтчетыБФКлиентСервер.УстановитьПараметр(НастройкиКомпоновкиДанных, "КурсДокумента", 	 КурсДокумента);
	бит_ОтчетыБФКлиентСервер.УстановитьПараметр(НастройкиКомпоновкиДанных, "КратностьДокумента", КратностьДокумента);
	бит_ОтчетыБФКлиентСервер.УстановитьПараметр(НастройкиКомпоновкиДанных, "РазмерностьЕдиницы", РазмерностьЕдиницы);
	
	СхемаКомпоновкиДанных = ПолучитьИзВременногоХранилища(АдресСхемыПолученияДанных);	
	
	ОбщегоНазначения.ХранилищеОбщихНастроекСохранить(ПараметрыВыполнения.КлючФоновогоЗадания, 
	          "НастройкиФоновогоЗадания_" + ПараметрыВыполнения.ИдентификаторФормы, НастройкиКомпоновкиДанных);
	
	ФоновоеЗадание = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ВыполняемыйМетод, 
						СхемаКомпоновкиДанных, ПараметрыВыполнения);
	Возврат ФоновоеЗадание;

КонецФункции

// Обработка оповещения. Подробности см.ДлительныеОперацииКлиент.ОжидатьЗавершение.
//
&НаКлиенте
Процедура ПослеЗаполненияСпискаДокументов(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Если Результат.Статус <> "Выполнено" Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка при выполнении: %1'"); 
		ПоказатьПредупреждение(, СтрШаблон(ТекстСообщения, Результат.КраткоеПредставлениеОшибки));
	Иначе
		ПослеЗаполненияСпискаДокументовНаСервере(Результат.АдресРезультата)	
	КонецЕсли; 

КонецПроцедуры

&НаСервере
Процедура ПослеЗаполненияСпискаДокументовНаСервере(АдресРезультата)
	
	ТаблицаДокументов = ПолучитьИзВременногоХранилища(АдресРезультата);
	ПервичныеДокументы.Загрузить(ТаблицаДокументов);
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ИнициироватьКомпоновщик(НастройкиКомпоновкиДанных)

	АдресСхемыПолученияДанных = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор);
	Документы.бит_БюджетнаяОперация.ИнициализироватьКомпоновщикПолученияДанныхПоКурсовымРазницам(
		КомпоновщикНастроек, НастройкиКомпоновкиДанных, АдресСхемыПолученияДанных);
		
	СхемаКомпоновкиДанных = ПолучитьИзВременногоХранилища(АдресСхемыПолученияДанных);
		
	ВГраница = бит_МеханизмДопИзмеренийКлиентСерверПереопределяемый.КоличествоДополнительныхИзмерений();
	Для Номер = 1 По ВГраница Цикл
		ИмяПоля			= "Аналитика_" + Номер;
		ВычисляемоеПоле = СхемаКомпоновкиДанных.ВычисляемыеПоля.Найти(ИмяПоля);
		Если ВычисляемоеПоле <> Неопределено Тогда    
			Элементы["ПервичныеДокументы" + ИмяПоля].Видимость = НЕ ВычисляемоеПоле.ОграничениеИспользования.Поле;
		КонецЕсли;	
	КонецЦикла;   
		
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция НастраиваемыйОбъект()

	Возврат "Документ.бит_БюджетнаяОперация.ОтражениеКурсовыхРазниц";

КонецФункции

&НаСервере
Процедура ПодготовитьФормуНаСервере()

	Перем НастройкаПоУмолчанию;
	
	ДатаДокумента	   = Параметры.Дата;
	Сценарий 		   = Параметры.Сценарий;
	КурсДокумента 	   = ?(Параметры.КурсДокумента = 0, 1, Параметры.КурсДокумента);
	КратностьДокумента = ?(Параметры.КратностьДокумента = 0, 1, Параметры.КратностьДокумента);
	РазмерностьЕдиницы = бит_ОбщегоНазначения.ПолучитьРазмерностьЕдиницыИзмеренияСумм(Параметры.ЕдиницаИзмеренияСумм);
	
	Периодичность = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сценарий, "бит_Периодичность");
	Если НЕ ЗначениеЗаполнено(Периодичность) Тогда
		Периодичность = Перечисления.бит_ПериодичностьПланирования.Месяц;
	КонецЕсли;
	
	НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	ИзмеренияДоп	   = бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Дополнительные", "Синоним");
	
	бит_МеханизмДопИзмерений.ПоказатьДополнительныеИзмеренияВТабличномПоле(ЭтотОбъект, "ПервичныеДокументы",
		ИзмеренияДоп, НастройкиИзмерений);

	НастройкаПоУмолчанию = бит_ОтчетыСервер.НайтиНастройкуПоУмолчаниюДляОбъекта(НастраиваемыйОбъект());
		
	ПрименитьНастройки(НастройкаПоУмолчанию);
	
	ИзмененыНастройки = Ложь;
	ОбработатьИзменениеНастроек(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Функция НовыеСохраняемыеНастройки() 

	СохраняемыеНастройки = Новый Структура;
	СохраняемыеНастройки.Вставить("НастройкиКомпоновкиДанных", Новый НастройкиКомпоновкиДанных);
	СохраняемыеНастройки.Вставить("ВариантПериода", 		   ВариантСтандартногоПериода.ЭтотМесяц);
	
	Возврат СохраняемыеНастройки;

КонецФункции

&НаСервере
Процедура ПрименитьНастройки(НастройкаПоУмолчанию)

	НачалоПериода 	 = бит_ОбщегоНазначенияКлиентСервер.ПолучитьНачалоПериода(ДатаДокумента, Периодичность);
	КонецПериода  	 = бит_ОбщегоНазначенияКлиентСервер.ПолучитьКонецПериода(ДатаДокумента, Периодичность);
	ПериодПомолчанию = Новый СтандартныйПериод(НачалоПериода, КонецПериода);
	
	ШаблонНастроек = НовыеСохраняемыеНастройки();
	Если ЗначениеЗаполнено(НастройкаПоУмолчанию) Тогда
		
		РеквизитыНастройки 	 = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(НастройкаПоУмолчанию, "ХранилищеНастроек");
		СохраненныеНастройки = РеквизитыНастройки.ХранилищеНастроек.Получить();
		
		Если ТипЗнч(СохраненныеНастройки) = Тип("Структура") Тогда
			ЗаполнитьЗначенияСвойств(ШаблонНастроек, СохраненныеНастройки);
		КонецЕсли;                                                       
		Если ШаблонНастроек.ВариантПериода = ВариантСтандартногоПериода.ПроизвольныйПериод Тогда
			Период = ПериодПомолчанию;
		Иначе	
			Период = Новый СтандартныйПериод(ШаблонНастроек.ВариантПериода); 
		КонецЕсли;
	Иначе
		Период = ПериодПомолчанию;
	КонецЕсли;	                                                    
	
	ИнициироватьКомпоновщик(ШаблонНастроек.НастройкиКомпоновкиДанных);
	
	УстановитьЗаголовок(НастройкаПоУмолчанию, ЭтотОбъект); 
	
КонецПроцедуры
		
&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗаголовок(Настройка, Форма)

	Заголовок = НСтр("ru = 'Получение данных по курсовым разницам %1'; 
							|en = 'Getting data on exchange rate differences %1'");
	Если ЗначениеЗаполнено(Настройка) Тогда
		Заголовок = СтрШаблон(Заголовок, "(" + Строка(Настройка) + ")");
	Иначе	
		Заголовок = СтрШаблон(Заголовок, "");
	КонецЕсли;

	Форма.Заголовок = Заголовок;

КонецПроцедуры

&НаКлиенте
Функция ПараметрыХраненияНастроек()

	ПараметрыХранения = Новый Структура;
	ПараметрыХранения.Вставить("ТипНастройки",		  ПредопределенноеЗначение("Перечисление.бит_ТипыСохраненныхНастроек.Обработки"));
	ПараметрыХранения.Вставить("НастраиваемыйОбъект", НастраиваемыйОбъект());

	Возврат ПараметрыХранения;
	
КонецФункции

&НаСервере
Функция СохраняемыеНастройки()
	
	СохраняемыеНастройки = НовыеСохраняемыеНастройки();

	СохраняемыеНастройки.НастройкиКомпоновкиДанных = КомпоновщикНастроек.ПолучитьНастройки();
	СохраняемыеНастройки.ВариантПериода			   = Период.Вариант;
	
	Возврат СохраняемыеНастройки;
	
КонецФункции

&НаКлиенте
Процедура СкрытьНастройки()

	Элементы.РазделыОбработки.ТекущаяСтраница 				  = Элементы.Обработка;
	Элементы.ПервичныеДокументыСформировать.КнопкаПоУмолчанию = Истина;
	
	Если ИзмененыНастройки Тогда
		ОбработатьИзменениеНастроек(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНастройки()

	Элементы.РазделыОбработки.ТекущаяСтраница	  = Элементы.НастройкиОбработки;
	Элементы.ПрименитьНастройки.КнопкаПоУмолчанию = Истина;	

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьФлаги(Пометка)
	
	Если ИзмененыНастройки Тогда
		Возврат;	
	КонецЕсли;  
	
	Для Каждого ТекущаяСтрока Из ПервичныеДокументы Цикл
		ТекущаяСтрока.Пометка = Пометка;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииПериода()
	
	ИзмененыНастройки = Истина;
	ОбработатьИзменениеНастроек(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОбработатьИзменениеНастроек(Форма)

	Форма.Элементы.ДекорацияИзмененыНастройки.Видимость = Форма.ИзмененыНастройки;
	Форма.Элементы.ПервичныеДокументы.Доступность    	= НЕ Форма.ИзмененыНастройки;
	
КонецПроцедуры

&НаКлиенте
Функция ПериодЗаполненПравильно()

	ЗаполненПравильно = Истина;
	
	Отказ  = Ложь;
	
	Если НЕ ЗначениеЗаполнено(Период.ДатаНачала) Тогда
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Начало периода';en = 'Period start'")); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "Период.ДатаНачала",, Отказ);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Период.ДатаОкончания) Тогда
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Конец периода';en = 'Period end'")); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "Период.ДатаОкончания",, Отказ);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Период.ДатаНачала) И ЗначениеЗаполнено(Период.ДатаОкончания) Тогда
		Если Период.ДатаОкончания < Период.ДатаНачала Тогда
			ТекстСообщения = НСтр("ru='Период указан неверно. Дата начала больше даты окончания.';
								  |en='The period is incorrect. The start date is greater than the end date.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "Период.ДатаНачала", , Отказ);
		КонецЕсли;
	КонецЕсли; 
	
	Если Отказ Тогда
		ЗаполненПравильно = Ложь;
	КонецЕсли;  
	
	Возврат ЗаполненПравильно; 

КонецФункции

&НаСервере
Процедура ЗагрузитьВДокументНаСервере(Знач ПомеченныеСтроки, Знач ПервичныеДокументыАдресВХранилище)

	Копия = РеквизитФормыВЗначение("ПервичныеДокументы").СкопироватьКолонки();	
    Для каждого ПомеченнаяСтрока Из ПомеченныеСтроки Цикл
		СтрокаТаблицы = ПервичныеДокументы.НайтиПоИдентификатору(ПомеченнаяСтрока); 
		ЗаполнитьЗначенияСвойств(Копия.Добавить(), СтрокаТаблицы);
	КонецЦикла;  
	
	ПоместитьВоВременноеХранилище(Копия, ПервичныеДокументыАдресВХранилище);
	
КонецПроцедуры

#КонецОбласти