				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ДокументПереопределяемый.Ссылка КАК Ссылка,
	ДокументПереопределяемый.Номер КАК Номер,
	ДокументПереопределяемый.Дата КАК Дата,
	ДокументПереопределяемый.Сценарий КАК Сценарий,
	ДокументПереопределяемый.ЦФО КАК ЦФО,
	ДокументПереопределяемый.СтатьяОборотов КАК СтатьяОборотов,
	&amp;Проект КАК Проект,
	ДокументПереопределяемый.ВалютаДокумента КАК ВалютаДокумента,
	ДокументПереопределяемый.КурсДокумента КАК КурсДокумента,
	ДокументПереопределяемый.КратностьДокумента КАК КратностьДокумента,
	ДокументПереопределяемый.ЕдиницаИзмеренияСумм КАК ЕдиницаИзмеренияСумм,
	ДокументПереопределяемый.РежимЗависимыхОборотов КАК РежимЗависимыхОборотов,
	ДокументПереопределяемый.СверхБюджета КАК СверхБюджета,
	ДокументПереопределяемый.Ответственный КАК Ответственный,
	ДокументПереопределяемый.Комментарий КАК Комментарий,
	ЕСТЬNULL(СтатусыОбъектовПереопределяемый.Статус, ЗНАЧЕНИЕ(Справочник.бит_СтатусыОбъектов.ПустаяСсылка)) КАК Статус,
	ЕСТЬNULL(СтатусыОбъектовПереопределяемый.ДатаИзмененияСтатуса, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаИзмененияСтатуса,
	ВЫБОР
		КОГДА НаличиеФайловПереопределяемый.ЕстьФайлы ЕСТЬ NULL
			ТОГДА 0
		КОГДА НаличиеФайловПереопределяемый.ЕстьФайлы
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЕстьФайлы,
	ВЫБОР
		КОГДА ДокументПереопределяемый.РучнаяКорректировка = ИСТИНА
			ТОГДА ВЫБОР
					КОГДА ДокументПереопределяемый.ПометкаУдаления = ИСТИНА
						ТОГДА 10
					КОГДА ДокументПереопределяемый.Проведен = ЛОЖЬ
						ТОГДА 9
					ИНАЧЕ 8
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА ДокументПереопределяемый.ПометкаУдаления = ИСТИНА
					ТОГДА 2
				КОГДА ДокументПереопределяемый.Проведен = ИСТИНА
					ТОГДА 1
				ИНАЧЕ 0
			КОНЕЦ
