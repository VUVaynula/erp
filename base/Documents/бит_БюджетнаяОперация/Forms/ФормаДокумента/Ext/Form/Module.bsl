&НаСервере
Процедура УстановитьУсловноеОформление()

	// ЗависимыеОборотыКомментарийРасчета
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ЗависимыеОборотыКомментарийРасчета");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
	"Объект.Таблица.АналитикиСтатьи", ВидСравненияКомпоновкиДанных.НеЗаполнено, "");
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ГиперссылкаЦвет);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Текст"	 , НСтр("ru='<Комментарий расчета>';en='<Calculation comment>'"));

КонецПроцедуры 

&НаСервере
Функция ПараметрыРасчетаЦен()
	
	ПараметрыРасчетаЦен = Новый Структура;
	ПараметрыРасчетаЦен.Вставить("ЗаполнитьПоТипуЦен", Ложь);
	ПараметрыРасчетаЦен.Вставить("ЗаполнитьПоНорме"  , Ложь);
	ПараметрыРасчетаЦен.Вставить("ТипЦен"); 
	ПараметрыРасчетаЦен.Вставить("АналитикаНоменклатуры");
	ПараметрыРасчетаЦен.Вставить("СтруктураКурсаДокумента");
	ПараметрыРасчетаЦен.Вставить("ДатаДокумента");
	ПараметрыРасчетаЦен.Вставить("ТолькоНулевыеСуммы", Ложь);
	ПараметрыРасчетаЦен.Вставить("ПараметрНорм"); 
	ПараметрыРасчетаЦен.Вставить("ИменаПараметраНорм");
	
	Если Объект.ЗаполнятьПоЦенамНоменклатуры И ЗначениеЗаполнено(Объект.ТипЦен) Тогда
		ПараметрыРасчетаЦен.ТипЦен  = Объект.ТипЦен;
		
		ТипНоменклатура = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
		Для каждого НастройкаИзмерения Из фКэшЗначений.НастройкиИзмерений Цикл
			Если ТипЗнч(НастройкаИзмерения.Значение) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			
			Если НастройкаИзмерения.Значение.ТипЗначения = ТипНоменклатура Тогда
				ПараметрыРасчетаЦен.АналитикаНоменклатуры = НастройкаИзмерения.Ключ;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ ЗначениеЗаполнено(ПараметрыРасчетаЦен.АналитикаНоменклатуры) Тогда
			ТекстСообщения = НСтр("ru = 'Не удалось определить аналитики для расчета цен.';
								  |en = 'Cant find match dimensions for price count.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Иначе
			ПараметрыРасчетаЦен.ЗаполнитьПоТипуЦен = Истина;
		КонецЕсли;
	ИначеЕсли НЕ Объект.ЗаполнятьПоЦенамНоменклатуры И ЗначениеЗаполнено(Объект.ПараметрНорм) И ИспользоватьНормы Тогда
		ПараметрыРасчетаЦен.ПараметрНорм       = Объект.ПараметрНорм;
		ПараметрыРасчетаЦен.ЗаполнитьПоНорме   = Истина;
		ПараметрыРасчетаЦен.ИменаПараметраНорм = ПланыВидовХарактеристик.бит_ВидыПроизвольныхПараметров.ПодготовитьСтруктурыСвязи(Объект.ПараметрНорм);
	КонецЕсли;
		
	СтруктураКурсаДокумента     = Новый Структура("Валюта, Курс, Кратность",
									Объект.ВалютаДокумента, Объект.КурсДокумента, Объект.КратностьДокумента);
	ПараметрыРасчетаЦен.СтруктураКурсаДокумента = СтруктураКурсаДокумента;	
	ПараметрыРасчетаЦен.ДатаДокумента           = Объект.Дата;
	
	Возврат ПараметрыРасчетаЦен;
	
КонецФункции

