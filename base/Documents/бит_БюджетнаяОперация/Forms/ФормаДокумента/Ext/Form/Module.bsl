&НаКлиенте
Процедура ПолучениеДанныхПоКурсовымРазницам(Команда)
	
	ОчиститьСообщения(); 
	
	Если НЕ ЗначениеЗаполнено(Объект.Сценарий) Тогда
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("ПОЛЕ" , "Заполнение", НСтр("ru = 'Сценарий'; en = 'scenario'"));
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "Сценарий", "Объект"); 
		Возврат;
	КонецЕсли;

	Если Объект.БДДС.Количество() <> 0 Тогда
		ТекстВопроса = НСтр("ru='Данные бюджета будут очищены. Продолжить?';
							|en='Budget data will be cleared. Continue?'");
		ОповещениеВопрос = Новый ОписаниеОповещения("ПолучениеДанныхПоКурсовымРазницамЗавершение", ЭтотОбъект);
		ПоказатьВопрос(ОповещениеВопрос, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе
		ЗаполнитьДанныеБюджетаПоКурсовымРазницам();
	КонецЕсли;
	
КонецПроцедуры

