	ТекущаяСтраницаЗависимые = ?(ТекущаяСтраница.Имя = "СтраницаЗависимыеОбороты", Истина, Ложь);
	Элементы.ЗависимыеОборотыИтогСумма.Видимость = ТекущаяСтраницаЗависимые;
	Элементы.ЗависимыеОборотыИтогКоличество.Видимость = ТекущаяСтраницаЗависимые;
	Элементы.БДДСИтогСумма.Видимость = НЕ ТекущаяСтраницаЗависимые;
	Элементы.БДДСИтогКоличество.Видимость = НЕ ТекущаяСтраницаЗависимые;
	
	// СтандартныеПодсистемы.Свойства
	Если ЭтотОбъект.ПараметрыСвойств.Свойство(ТекущаяСтраница.Имя)
