// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

&НаКлиенте
Процедура КомандаПодбор(Команда)
	
	Если Модифицированность ИЛИ НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		Оповещение = Новый ОписаниеОповещения("ВопросОткрытьОбработкуПодбораЗавершение", ЭтотОбъект);
		ТекстВопроса = НСтр("ru='Для продолжения необходимо записать документ. Выполнить запись?';
							|en='To continue, you must write the document. Record?'");
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 15, КодВозвратаДиалога.Нет);
		
	Иначе	
		
		// Безусловное открытие обработки
		ОткрытиеОбработкиПодборЗаявокНаЗатраты();
		
	КонецЕсли;	
	
КонецПроцедуры

//  Процедура обработчик оповещения вопроса о необходимости записи документа 
// при открытии обработки заполнения. 
// 
&НаКлиенте
Процедура ВопросОткрытьОбработкуПодбораЗавершение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		флОК = Записать();
		
		Если флОК Тогда
			ОткрытиеОбработкиПодборЗаявокНаЗатраты();
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры // ВопросОткрытьОбработкуПодбораЗавершение	

#КонецОбласти 

