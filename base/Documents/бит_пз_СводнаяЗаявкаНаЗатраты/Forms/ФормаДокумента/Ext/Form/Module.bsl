//  Процедура заполняет кэш значений, необходимый при работе на клиенте.
// 
&НаСервере
Процедура ЗаполнитьКэшЗначений()
	
	мКэшЗначений = Новый Структура;
	
	ДокументЗаявка = ДанныеФормыВЗначение(Объект, Тип("ДокументОбъект.бит_пз_СводнаяЗаявкаНаЗатраты"));
	
	мКэшЗначений.Вставить("ИзмеренияДоп"      		  , ДокументЗаявка.мИзмеренияДоп);
	мКэшЗначений.Вставить("НастройкиИзмерений"		  , ДокументЗаявка.мНастройкиИзмерений);
	мКэшЗначений.Вставить("ВалютаРеглУчета"			  , Константы.ВалютаРегламентированногоУчета.Получить());
	
	// Запишем параметр для формирования заголовка.
	мКэшЗначений.Вставить("ПредставлениеОбъекта", Объект.Ссылка.Метаданные().ПредставлениеОбъекта);
	
КонецПроцедуры

//  Процедура управляем видимостью-доступностью элементов формы. 
// 
&НаСервере
Процедура УправлениеЭлементамиФормы()

	бит_НастройкиДоступностиЭлементовФорм.РазблокироватьЭлементы(ЭтотОбъект);
	
	// Управление доступностью некоторых элементов в зависимости от статуса Черновик.
	Если ТипСтатуса <> Перечисления.бит_ТипыСтатусовОбъектов.Черновик Тогда
		Элементы.ЗаявкиНаЗатраты.КоманднаяПанель.Доступность = Ложь;
		Элементы.ЗаявкиНаЗатраты.КонтекстноеМеню.Доступность = Ложь;
	Иначе
		Элементы.ЗаявкиНаЗатраты.КоманднаяПанель.Доступность = Истина;
		Элементы.ЗаявкиНаЗатраты.КонтекстноеМеню.Доступность = Истина;
	КонецЕсли;
	
	бит_НастройкиДоступностиЭлементовФорм.ЗаблокироватьЭлементы(ЭтотОбъект);
	
КонецПроцедуры

// Процедура пересчитывает суммы табличной части при изменении цены или количества.
// 
&НаКлиентеНаСервереБезКонтекста
Процедура ПриИзмененииКоличествоЦена(Сумма, Количество, Цена, СуммаНДС, Всего, СтавкаНДС)

	Сумма = Цена * Количество;
	
	СуммаНДС = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(Сумма,
					Истина, Ложь, бит_БухгалтерияВызовСервера.ПолучитьСтавкуНДС(СтавкаНДС));
	
	Всего = Сумма + СуммаНДС;

КонецПроцедуры // ПриИзмененииКоличествоЦена()

//  Процедура обновляет итоги по всем суммам.
// 
// Параметры:
//  СтрокаТабличнойЧасти - строка табличной части документа.
// 
&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьИтоги(Форма)

	Объект = Форма.Объект;

	Форма.ИтогиВсего    = Объект.ЗаявкиНаЗатраты.Итог("СуммаСНДС");
	Форма.ИтогиВсегоНДС = Объект.ЗаявкиНаЗатраты.Итог("СуммаНДС");
	
КонецПроцедуры

//  Процедура обрабатывает заполнение табличной части из подбора заявок на потребность.
// 
// Параметры:
//  СтрЗаполнения - Структура.
// 
&НаСервере
Процедура ОбработкаЗаполненияИзПодбора(СтрЗаполнения)

	Если СтрЗаполнения.ОчищатьТабЧасть Тогда
	
		Объект.ЗаявкиНаЗатраты.Очистить();
	
	КонецЕсли; 
	
	ТаблицаПодбор = бит_ОбщегоНазначения.РаспаковатьТаблицуЗначений(СтрЗаполнения.Хранилище);
	
	Для каждого Строка Из ТаблицаПодбор Цикл
	
		СтрОтбора = Новый Структура;
		СтрОтбора.Вставить("Номенклатура"	, Строка.Номенклатура);
		СтрОтбора.Вставить("ЗаявкаНаЗатраты", Строка.ЗаявкаНаЗатраты);
		СтрОтбора.Вставить("Характеристика"	, Строка.Характеристика);
		НайденныеСтроки = Объект.ЗаявкиНаЗатраты.НайтиСтроки(СтрОтбора);
		
		Если НайденныеСтроки.Количество() > 0 Тогда
			
			НайденныеСтроки[0].Количество 	= НайденныеСтроки[0].Количество + Строка.Количество;
			НайденныеСтроки[0].Сумма 		= НайденныеСтроки[0].Сумма 		+ Строка.Сумма;
			НайденныеСтроки[0].СуммаНДС 	= НайденныеСтроки[0].СуммаНДС 	+ Строка.СуммаНДС;
			НайденныеСтроки[0].СуммаСНДС 	= НайденныеСтроки[0].СуммаСНДС 	+ Строка.СуммаСНДС;
			
		Иначе
			
			НоваяСтрока = Объект.ЗаявкиНаЗатраты.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
			
			Если ТипЗнч(Строка.Номенклатура) = Тип("СправочникСсылка.Номенклатура") Тогда
			
				НоваяСтрока.Упаковка = Строка.Номенклатура.ЕдиницаИзмерения;
			
			КонецЕсли; 
			
		КонецЕсли; 
		
	КонецЦикла; 
	
КонецПроцедуры // ОбработкаЗаполненияИзПодбора()

//  Процедура открывает обработку подбора заявок на затраты. 
//
&НаКлиенте
Процедура ОткрытиеОбработкиПодборЗаявокНаЗатраты()

	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Документ"		, Объект.Ссылка);
	СтруктураПараметров.Вставить("ИмяМакета"	, "СКД");
	СтруктураПараметров.Вставить("ИмяСобытия"	, "ПодборЗаявокНаЗатраты");
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("СтруктураПараметров",	СтруктураПараметров);
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе", 	Истина);
	
	ОткрытьФорму("Обработка.бит_пз_ПодборЗаявокНаЗатраты.Форма.Форма", ПараметрыФормы, ЭтотОбъект);

КонецПроцедуры // ОткрытиеОбработкиПодборЗаявокНаЗатраты()

//  Процедура при изменении валюты на сервере. 
//
&НаСервере
Процедура ВалютаДокументаПриИзмененииСервер()

	ДокументЗаявка = ДанныеФормыВЗначение(Объект, Тип("ДокументОбъект.бит_пз_СводнаяЗаявкаНаЗатраты"));
	ДокументЗаявка.ИзменениеВалютыМодуль();
	
	ЗначениеВДанныеФормы(ДокументЗаявка, Объект);

КонецПроцедуры // ВалютаДокументаПриИзмененииСервер()

//  Процедура пересчитывает суммы табличной части при суммы.
// 
&НаКлиентеНаСервереБезКонтекста
Процедура ПриИзмененииСумма(Сумма, СуммаНДС, Всего, СтавкаНДС)

	СуммаНДС = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(
										Сумма,
										Истина,
										Ложь,
										бит_БухгалтерияВызовСервера.ПолучитьСтавкуНДС(СтавкаНДС));
										
	Всего = Сумма + СуммаНДС;									

КонецПроцедуры // ПриИзмененииСумма()

//  Процедура обработка события ПриИзменении поля Номенклатура. 
//
&НаСервере
Процедура НоменклатураПриИзмененииСервер(ИД)

	СтрокаТабличнойЧасти = Объект.ЗаявкиНаЗатраты.НайтиПоИдентификатору(ИД);
	СтрокаТабличнойЧасти.Упаковка = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;

КонецПроцедуры // НоменклатураПриИзмененииСервер()

&НаСервере
Процедура ПодготовитьФормуНаСервере(СтандартнаяОбработка = Ложь)

	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект, СтандартнаяОбработка);
	УстановитьСостояниеДокумента();
	УправлениеЭлементамиФормы();
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаОповещенияИзмененияСтатуса()
	
	Прочитать();
	
КонецПроцедуры

#КонецОбласти 
