			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ТабДокумент.Ссылка КАК Ссылка,
	ТабДокумент.ПометкаУдаления КАК ПометкаУдаления,
	ТабДокумент.Номер КАК Номер,
	ТабДокумент.Дата КАК Дата,
	ТабДокумент.Проведен КАК Проведен,
	ТабДокумент.ВидОперации КАК ВидОперации,
	ТабДокумент.Организация КАК Организация,
	ТабДокумент.Контрагент КАК Контрагент,
	ТабДокумент.Договор КАК Договор,
	ТабДокумент.ВалютаДокумента КАК ВалютаДокумента,
	ТабДокумент.Склад КАК Склад,
	ТабДокумент.ЖелаемаяДатаПоступления КАК ЖелаемаяДатаПоступления,
	ТабДокумент.Ответственный КАК Ответственный,
	ТабДокумент.Комментарий КАК Комментарий,
	ТабДокумент.Важность КАК Важность,
	ТабДокумент.РучнаяКорректировка КАК РучнаяКорректировка,
	ТабДокумент.МоментВремени КАК МоментВремени,
	ТабСтатусы.Статус КАК Статус,
	ТабСтатусы.ДатаИзмененияСтатуса КАК ДатаИзмененияСтатуса,
	ТабДокумент.Сумма КАК Сумма,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА 0
		КОГДА НаличиеФайлов.ЕстьФайлы
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЕстьФайлы
ИЗ
	Документ.бит_пз_СводнаяЗаявкаНаЗатраты КАК ТабДокумент
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_СтатусыОбъектов КАК ТабСтатусы
		ПО ТабДокумент.Ссылка = ТабСтатусы.Объект
			И (ТабСтатусы.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО ТабДокумент.Ссылка = НаличиеФайлов.ОбъектСФайлами</QueryText>
				<MainTable>Document.бит_пз_СводнаяЗаявкаНаЗатраты</MainTable>
