
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	СтрОшибок = ПроверкаВозможностиСозданияЗаказаПоставщику(ПараметрКоманды);
	
	Если Не СтрОшибок.Разрешено Тогда
		
		бит_ОбщегоНазначенияКлиентСервер.ВывестиСообщение(СтрОшибок.ТекстСообщения);
		Возврат;
	
	КонецЕсли; 
	
	ДокументЗаказПостащику = СоздатьДокументЗаказПоставщику(ПараметрКоманды);
	
	Если ДокументЗаказПостащику <> Неопределено Тогда
	
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Ключ", ДокументЗаказПостащику.Ссылка);

		ФормаДокумента = ОткрытьФорму("Документ.ЗаказПоставщику.Форма."+ДокументЗаказПостащику.ФормаОткрытия, ПараметрыФормы);
		
	КонецЕсли; 
	
КонецПроцедуры

//  Функция проверки возможности создания Заказа поставщику. 
// 
&НаСервере
Функция ПроверкаВозможностиСозданияЗаказаПоставщику(ПараметрКоманды)

	СтрВозврата = Новый Структура("Разрешено, ТекстСообщения", Ложь, "");
	
	Если ПараметрКоманды.ВидОперации = Перечисления.бит_пз_ВидыОперацийЗаявокНаЗатраты.Услуги Тогда	
		СтрВозврата.Разрешено = Ложь;
		СтрВозврата.ТекстСообщения = НСтр("ru='Создание Заказа поставщику возможно только на основании заявки с видом операции ""Товары"".';
										  |en='Creation order, the supplier is only possible on the basis of an application to view the operation ""Goods"".'");
		Возврат СтрВозврата;		
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РегистрСтатусыОбъектов.Статус КАК Статус,
	|	РегистрСтатусыОбъектов.Объект КАК Заявка,
	|	СправочникСтатусыОбъектов.ТипСтатуса КАК ТипСтатуса
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК РегистрСтатусыОбъектов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_СтатусыОбъектов КАК СправочникСтатусыОбъектов
	|		ПО РегистрСтатусыОбъектов.Статус = СправочникСтатусыОбъектов.Ссылка
	|			И (РегистрСтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))
	|			И (РегистрСтатусыОбъектов.Объект = &Заявка)";
	
	Запрос.УстановитьПараметр("Заявка", ПараметрКоманды);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.Утвержден
			ИЛИ Выборка.ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен Тогда		
			СтрВозврата.Разрешено = Истина;			
		Иначе	
			СтрВозврата.Разрешено = Ложь;
			СтрВозврата.ТекстСообщения = НСтр("ru='Создание Заказа поставщику возможно только в статусах Утверждена, Частично исполнена.';
											  |en='Create Purchase Orders can only be in the status of Approved, partially fulfilled.'");
		КонецЕсли; 
	
	КонецЦикла;

	Возврат СтрВозврата;
	
КонецФункции // ПроверкаВозможностиСозданияЗаказаПоставщику()

//  Функция создает документ Заказ поставщику. 
// 
&НаСервере
Функция СоздатьДокументЗаказПоставщику(ПараметрКоманды)

	ДокументЗаказПостащику = бит_пз_ОбщегоНазначения.СоздатьДокументЗаказПоставщику(ПараметрКоманды);
	
	Возврат ДокументЗаказПостащику;
	
КонецФункции // СоздатьДокументЗаказПоставщику()
