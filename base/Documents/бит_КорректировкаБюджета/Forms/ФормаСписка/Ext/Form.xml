	<Attributes>
		<Attribute name="Список" id="1">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Список</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>List</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>~Список.Ref</Field>
				<Field>Список.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДокументПереопределяемый.Ссылка КАК Ссылка,
	ДокументПереопределяемый.Номер КАК Номер,
	ДокументПереопределяемый.Дата КАК Дата,
	ДокументПереопределяемый.Сценарий КАК Сценарий,
	ДокументПереопределяемый.Ответственный КАК Ответственный,
	ДокументПереопределяемый.Комментарий КАК Комментарий,
	ДокументПереопределяемый.ВалютаДокумента КАК ВалютаДокумента,
	ДокументПереопределяемый.КурсДокумента КАК КурсДокумента,
	ДокументПереопределяемый.КратностьДокумента КАК КратностьДокумента,
	ДокументПереопределяемый.ЦФО КАК ЦФО,
	ДокументПереопределяемый.СтатьяОборотов КАК СтатьяОборотов,
	&amp;Проект КАК Проект,
	ЕСТЬNULL(СтатусыОбъектовПереопределяемый.Статус, ЗНАЧЕНИЕ(Справочник.бит_СтатусыОбъектов.ПустаяСсылка)) КАК Статус,
	ЕСТЬNULL(СтатусыОбъектовПереопределяемый.ДатаИзмененияСтатуса, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаИзмененияСтатуса,
	ВЫБОР
		КОГДА НаличиеПрисоединенныхФайловПереопределяемый.ЕстьФайлы ЕСТЬ NULL
			ТОГДА 0
		КОГДА НаличиеПрисоединенныхФайловПереопределяемый.ЕстьФайлы
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЕстьФайлы,
	ВЫБОР
		КОГДА ДокументПереопределяемый.РучнаяКорректировка = ИСТИНА
			ТОГДА ВЫБОР
					КОГДА ДокументПереопределяемый.ПометкаУдаления = ИСТИНА
						ТОГДА 10
					КОГДА ДокументПереопределяемый.Проведен = ЛОЖЬ
						ТОГДА 9
					ИНАЧЕ 8
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА ДокументПереопределяемый.ПометкаУдаления = ИСТИНА
					ТОГДА 2
				КОГДА ДокументПереопределяемый.Проведен = ИСТИНА
					ТОГДА 1
				ИНАЧЕ 0
			КОНЕЦ
	КОНЕЦ КАК СостояниеДокумента
ИЗ
	Документ.бит_КорректировкаБюджета КАК ДокументПереопределяемый
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_СтатусыОбъектов КАК СтатусыОбъектовПереопределяемый
		ПО ДокументПереопределяемый.Ссылка = СтатусыОбъектовПереопределяемый.Объект
			И (СтатусыОбъектовПереопределяемый.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))}
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеПрисоединенныхФайловПереопределяемый
		ПО ДокументПереопределяемый.Ссылка = НаличиеПрисоединенныхФайловПереопределяемый.ОбъектСФайлами}</QueryText>
				<MainTable>Document.бит_КорректировкаБюджета</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:item xsi:type="dcsset:FilterItemComparison">
							<dcsset:use>false</dcsset:use>
							<dcsset:left xsi:type="dcscor:Field">Сценарий</dcsset:left>
							<dcsset:comparisonType>Equal</dcsset:comparisonType>
							<dcsset:userSettingID>8577052a-9e14-44a4-9530-9a235d387564</dcsset:userSettingID>
						</dcsset:item>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
