Процедура ПодготовитьТаблицыДокументаРасчетыВВалюте(ДанныеБюджета, Периоды, Реквизиты)

	КурсыПоПериодам = Неопределено;				
	Если Реквизиты.ИспользоватьКурсыСценария Тогда
		ПараметрыКурсов = бит_Бюджетирование.ЗаполнитьСтруктуруПараметровПолученияКурсовПоПериодам(Реквизиты.Сценарий, Реквизиты.ВалютаДокумента);
		КурсыПоПериодам = бит_КурсыВалют.ПолучитьКурсыВалютПоПериодам(Периоды, ПараметрыКурсов, Реквизиты.Сценарий);
	КонецЕсли; 
	
	КурсыВалют = бит_КурсыВалют.КурсыВалютДокумента(Реквизиты.Регистратор, Реквизиты.Дата, 
					Новый Структура("Документ, Регл, Упр, Сценарий"));
					
	бит_Бюджетирование.ВыполнитьПересчетыВТаблицеОборотов(ДанныеБюджета, КурсыПоПериодам, КурсыВалют);
	
КонецПроцедуры

Процедура ПодготовитьТаблицуИсполнениеБюджетаРасчетыВВалюте(ИсполнениеБюджета, ИсполнениеБюджетаРеквизиты)

	Если НЕ ЗначениеЗаполнено(ИсполнениеБюджета) ИЛИ НЕ ЗначениеЗаполнено(ИсполнениеБюджетаРеквизиты) Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты = ИсполнениеБюджетаРеквизиты[0];
		
	КурсВалютыСценария = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Реквизиты.ВалютаСценария, Реквизиты.Дата);

	КурсыВалютДокумента = Новый Соответствие; 
	Валюты = ИсполнениеБюджета.Скопировать(, "Валюта");
	Валюты.Свернуть("Валюта");
	
	Для каждого СтрокаТаблицы Из Валюты Цикл
		Если СтрокаТаблицы.Валюта = Реквизиты.ВалютаСценария Тогда
			КурсВалюты = КурсВалютыСценария;
		Иначе	
			КурсВалюты = РаботаСКурсамиВалют.ПолучитьКурсВалюты(СтрокаТаблицы.Валюта, Реквизиты.Дата);
		КонецЕсли;
		КурсыВалютДокумента.Вставить(СтрокаТаблицы.Валюта, КурсВалюты);
	КонецЦикла; 
	
	Для каждого СтрокаТаблицы Из ИсполнениеБюджета Цикл
		Если СтрокаТаблицы.Валюта = Реквизиты.ВалютаСценария Тогда
			Продолжить;		
		КонецЕсли;
		КурсВалютыДокумента = КурсыВалютДокумента.Получить(СтрокаТаблицы.Валюта);
		СтрокаТаблицы.Сумма = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(
								СтрокаТаблицы.Сумма, КурсВалютыДокумента, КурсВалютыСценария);
	КонецЦикла;																	

КонецПроцедуры

Функция НакопленныеОборотыДоИзменения(ДанныеБюджета, Реквизиты)

	Периоды = ДанныеБюджета.Скопировать(,"Период");
	Периоды.Сортировать("Период Возр");
	МаксИндекс = Периоды.Количество() - 1;
	
	Если Периоды.Количество() > 0 Тогда
		ЗаВесьПериодУчета = Ложь;
		НачалоПериода = НачалоДня(Периоды[0].Период);
		КонецПериода = ПолучитьКонецПериода(Периоды[МаксИндекс].Период, Реквизиты.ПериодичностьПланирования);
	Иначе
		ЗаВесьПериодУчета = Истина;
		НачалоПериода = Дата('00010101');
		КонецПериода  = Дата('00010101');
	КонецЕсли; 
	
	Если ТранзакцияАктивна() Тогда
	
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.бит_ОборотыПоБюджетам");
		Если НЕ ЗаВесьПериодУчета Тогда
			ЭлементБлокировки.УстановитьЗначение("Период", Новый Диапазон(НачалоПериода, КонецПериода));
		КонецЕсли;

		ЭлементБлокировки.ИсточникДанных = ДанныеБюджета;
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Сценарий","Сценарий");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ЦФО","ЦФО");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("СтатьяОборотов","СтатьяОборотов");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Валюта","Валюта");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_1","Аналитика_1");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_2","Аналитика_2");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_3","Аналитика_3");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_4","Аналитика_4");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_5","Аналитика_5");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_6","Аналитика_6");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_7","Аналитика_7");
		// ++ ЕРП  
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_8","Аналитика_8");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_9","Аналитика_9");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_10","Аналитика_10");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_11","Аналитика_11");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Аналитика_12","Аналитика_12");
		// -- ЕРП 
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;	
		Блокировка.Заблокировать()
	
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ДанныеДокумента.Сценарий КАК Сценарий,
	|	ДанныеДокумента.ЦФО КАК ЦФО,
	|	ДанныеДокумента.СтатьяОборотов КАК СтатьяОборотов,
	|	ДанныеДокумента.Валюта КАК Валюта,
	|	ДанныеДокумента.Аналитика_1 КАК Аналитика_1,
	|	ДанныеДокумента.Аналитика_2 КАК Аналитика_2,
	|	ДанныеДокумента.Аналитика_3 КАК Аналитика_3,
	|	ДанныеДокумента.Аналитика_4 КАК Аналитика_4,
	|	ДанныеДокумента.Аналитика_5 КАК Аналитика_5,
	|	ДанныеДокумента.Аналитика_6 КАК Аналитика_6,
	|	ДанныеДокумента.Аналитика_7 КАК Аналитика_7,
	|	ДанныеДокумента.Аналитика_8 КАК Аналитика_8,
	|	ДанныеДокумента.Аналитика_9 КАК Аналитика_9,
	|	ДанныеДокумента.Аналитика_10 КАК Аналитика_10,
