#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Заполняет наборы значений доступа.
// Параметры:
//  Таблица - ТаблицаЗначений - передает в этот параметр подготовленные наборы значений
//            доступа. Описание колонок см. в функции УправлениеДоступом.ТаблицаНаборыЗначенийДоступа.
//
Процедура ЗаполнитьНаборыЗначенийДоступа(Таблица) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	КлючДоступаЦФОСтатьяОборотов = Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.КлючиЦФОСтатьяОборотовДокумента(
		ЦФО, СтатьяОборотов);
	ДобавитьСтрокуВНаборЗначенийДоступа(КлючДоступаЦФОСтатьяОборотов, Таблица);
	ДобавитьСтрокуВНаборЗначенийДоступа(Ответственный, Таблица);
	
	// Таблица "БДДС"
	Для каждого СтрокаТаблицы Из БДДС Цикл
		КлючДоступаЦФОСтатьяОборотов = Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.КлючиЦФОСтатьяОборотовДокумента(
			СтрокаТаблицы.ЦФО, СтрокаТаблицы.СтатьяОборотов);
		ДобавитьСтрокуВНаборЗначенийДоступа(КлючДоступаЦФОСтатьяОборотов, Таблица);
	КонецЦикла; 
			
	// Удалим дубли
	ПоляГруппировки = "";
	Для каждого Колонка Из Таблица.Колонки Цикл
		ПоляГруппировки = "," + Колонка.Имя + ПоляГруппировки;
	КонецЦикла; 
	
	ПоляГруппировки = Сред(ПоляГруппировки, 2);
	Таблица.Свернуть(ПоляГруппировки);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;	
	КонецЕсли; 
	
	// ++ ЕРП 
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	// -- ЕРП 
	
	бит_ОбщегоНазначенияПереопределяемый.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	ДополнительныеСвойства.Вставить("ПроводитьПослеУтверждения", ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения"));
	
	// Очистка неиспользуемых разрезов бюджетирования по статье оборотов.
	бит_Бюджетирование.ОчиститьНеИспользуемыеАналитикиСтатейОборотов(БДДС);
	бит_ОбщегоНазначения.ЗаполнитьАналитикуВШапкеДокумента(ЭтотОбъект, БДДС, Отказ);
	Если ЭтоНовый()
		ИЛИ (РежимЗаписи <> РежимЗаписиДокумента.ОтменаПроведения 
		И ПометкаУдаления = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ПометкаУдаления")) Тогда
		УстановитьПривилегированныйРежим(Истина);
		ЗаполнитьЗависимыеОбороты();
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("ЦФО", ЦФО);
								
	ОтражатьСверхБюджета = НЕ бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеОперацииПриКонтролеПоБюджету(
									ПараметрыНастройки, Дата);
									
	Если ОтражатьСверхБюджета ИЛИ НЕ СверхБюджета Тогда
		СписатьЛимиты = Ложь;	
	КонецЕсли;	
	
	Если ДополнительныеСвойства.ПроводитьПослеУтверждения Тогда
		Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
			ОтправленНаСогласование = Истина;
		Иначе
			ОтправленНаСогласование = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЭтоНовый() Тогда
		Если ДополнительныеСвойства.ПроводитьПослеУтверждения Тогда
			// Если документ был проведен в системе ранее, без отправки на согласование,
			// при повторном проведении его движения стирать нельзя.
			Если НЕ Проведен ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
				РежимПринятияКУчету = 1;
			КонецЕсли;
		Иначе
			РежимПринятияКУчету = 0;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаПроведенияНачало(ЭтотОбъект, Ложь);
	Если РучнаяКорректировка Тогда
		Возврат;
	КонецЕсли;

	ПараметрыПроведения = Документы.бит_КорректировкаБюджета.ПодготовитьПараметрыПроведения(Ссылка, Отказ);
	
	// Проверим соответствие исторических данных и данных для сторнирования.
	Документы.бит_КорректировкаБюджета.ОбработатьПревышениеДанныхБюджетаДоИзменения(
		ПараметрыПроведения.ИсторическиеДанныеБюджета, 
		ПараметрыПроведения.Реквизиты, Отказ);

	Если Отказ Тогда
		Возврат;	
	КонецЕсли; 
	
	ТаблицаИсполнениеБюджета = бит_КонтрольИсполненияБюджета.ПодготовитьТаблицуВозвратЛимита(
									ПараметрыПроведения.ВозвратЛимита,
									ПараметрыПроведения.ИсполнениеБюджетаРеквизиты,
									Отказ);
	
	бит_КонтрольИсполненияБюджета.СформироватьДвиженияКонтрольныеЗначенияБюджетов(
		ТаблицаИсполнениеБюджета, Движения);
	// АПК:105-выкл Явная запись требуеся для анализа движений.	
	Движения.бит_КонтрольныеЗначенияБюджетов.Записать();
	// АПК:105-вкл
	ТаблицаИсполнениеБюджета = бит_КонтрольИсполненияБюджета.ПодготовитьТаблицуИсполнениеБюджета(
									ПараметрыПроведения.ИсполнениеБюджета,
									ПараметрыПроведения.ИсполнениеБюджетаРеквизиты,
									Отказ);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	бит_КонтрольИсполненияБюджета.СформироватьДвиженияКонтрольныеЗначенияБюджетов(ТаблицаИсполнениеБюджета, Движения);
	
	Документы.бит_КорректировкаБюджета.СформироватьДвиженияОборотыПоБюджетам(ПараметрыПроведения.ТаблицаДанныеБюджета,
		ПараметрыПроведения.Реквизиты, Движения, Отказ);
		
	Документы.бит_КорректировкаБюджета.СформироватьДвиженияОборотыПоБюджетам(ПараметрыПроведения.ТаблицаЗависимыеОбороты,
		ПараметрыПроведения.Реквизиты, Движения, Отказ);
		
	Документы.бит_КорректировкаБюджета.СформироватьДвиженияБюджетирование(ПараметрыПроведения.ТаблицаДанныеБюджета, 
		ПараметрыПроведения.Реквизиты, Движения, Отказ);
		
	Документы.бит_КорректировкаБюджета.СформироватьДвиженияБюджетирование(ПараметрыПроведения.ТаблицаЗависимыеОбороты, 
		ПараметрыПроведения.Реквизиты, Движения, Отказ);
	
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаПроведенияЗавершение(ЭтотОбъект, Отказ); 

КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаУдаленияПроведения(ЭтотОбъект, Отказ); 
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	ИменаПолейДо = Новый Массив;
	ИменаПолейДо.Добавить("СуммаСценарий_Старый");
	ИменаПолейДо.Добавить("СуммаРегл_Старый");
	ИменаПолейДо.Добавить("СуммаУпр_Старый");
	ИменаПолейДо.Добавить("Сумма_Старый");
	ИменаПолейДо.Добавить("Количество_Старый");

	ИменаПолейПосле = Новый Массив;
	ИменаПолейПосле.Добавить("СуммаСценарий");
	ИменаПолейПосле.Добавить("СуммаРегл");
	ИменаПолейПосле.Добавить("СуммаУпр");
	ИменаПолейПосле.Добавить("Сумма");
	ИменаПолейПосле.Добавить("Количество");

	МетаДокумент = Метаданные.Документы.бит_КорректировкаБюджета;
	МетаРеквизитыБДДС = МетаДокумент.ТабличныеЧасти.БДДС.Реквизиты;
	
	Для каждого СтрокаТаблицы Из БДДС Цикл
							
		ПоляДоЗаполнены    = Ложь;
		ПоляПослеЗаполнены = Ложь;
		
		Если НЕ СтрокаТаблицы.РучнаяКорректировка Тогда
			Для каждого ИмяПоля Из ИменаПолейДо Цикл
				ПоляДоЗаполнены = Макс(ПоляДоЗаполнены, СтрокаТаблицы[ИмяПоля] <> 0);	
			КонецЦикла;
		Иначе
			ПоляДоЗаполнены = Истина;
		КонецЕсли;
		
		Для каждого ИмяПоля Из ИменаПолейПосле Цикл
			ПоляПослеЗаполнены = Макс(ПоляПослеЗаполнены, СтрокаТаблицы[ИмяПоля] <> 0);	
		КонецЦикла;
		
		Если НЕ ПоляДоЗаполнены Тогда
			ТекстПояснения = НСтр("ru = 'В строке ""%1"" не заполнено ни одной суммы или количество ""до изменения"".'");
			ТекстПояснения = СтрШаблон(ТекстПояснения, СтрокаТаблицы.НомерСтроки);
			Поле 		   = СтрШаблон("БДДС[%1].%2", Формат(СтрокаТаблицы.НомерСтроки - 1, "ЧГ="), "НомерСтроки");
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("СПИСОК", "КОРРЕКТНОСТЬ",,
								СтрокаТаблицы.НомерСтроки, НСтр("ru='Данные бюджета';en='Budget Data'"), ТекстПояснения);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, Поле, "Объект", Отказ);
		КонецЕсли;
	КонецЦикла;
		
	// Обязательные измерения из разряда дополнительных.
	НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	Для каждого КлючИЗначение Из НастройкиИзмерений Цикл
		ИмяИзмерения = "БДДС." + КлючИЗначение.Ключ;
		Настройка    = КлючИЗначение.Значение;
		
		Если Настройка.Обязательное Тогда  			
			ПроверяемыеРеквизиты.Добавить(ИмяИзмерения);		
		КонецЕсли; 
	КонецЦикла; 
	
	бит_Бюджетирование.ПроверитьОбязательныеРазрезыСтатейОборотов(ЭтотОбъект, "БДДС", Отказ);
	бит_Бюджетирование.ПроверитьОбязательныеРазрезыСтатейОборотов(ЭтотОбъект, "ЗависимыеОбороты", Отказ);
	
	бит_НастройкиДоступностиЭлементовФорм.ЗаполнитьПроверяемыеРеквизиты(ЭтотОбъект, ПроверяемыеРеквизиты);
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения);	
	КонецЕсли; 
	
	// Заполнение шапки.
	бит_ОбщегоНазначения.ЗаполнитьШапкуДокумента(ЭтотОбъект, Пользователи.ТекущийПользователь(), Неопределено);
	
	Если ЗначениеЗаполнено(Сценарий) Тогда
		ИзменениеСценарияОбъект(); 
	КонецЕсли;
	
	Если РежимЗависимыхОборотов.Пустая() Тогда
		РежимЗависимыхОборотов = Перечисления.бит_РежимыЗависимыхОборотов.НеФормировать;
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения") Тогда
		РежимПринятияКУчету = 1;	
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	СверхБюджета 			 = Ложь;
	СторнироватьСверхБюджета = Ложь;
	
	// Сбрасываем признак начала согласования.
	ОтправленНаСогласование = Ложь;
	Ответственный = Пользователи.ТекущийПользователь();
	Если ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения") Тогда
		РежимПринятияКУчету = 1;
	Иначе
		РежимПринятияКУчету = 0;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс 

// Процедура обрабатывает изменение валюты документа.
// 
// Параметры:
//  Нет.
// 
Процедура ИзменениеВалютыОбъект() Экспорт
	
	СтрКурса = бит_Бюджетирование.ПолучитьКурсПоСценарию(Сценарий, ВалютаДокумента, Дата);
	КурсДокумента      = СтрКурса.Курс;
	КратностьДокумента = СтрКурса.Кратность;
	
КонецПроцедуры

// Процедура обрабатывает изменение сценария в шапке документа.
// 
// Параметры:
//  ОчищатьТч - Булево (По умолчанию = Ложь).
// 
Процедура ИзменениеСценарияОбъект(ОчищатьТч = Ложь)  Экспорт

	Если ОчищатьТч Тогда
		БДДС.Очистить();
	КонецЕсли;
	
	ВалютаДокумента = Сценарий.Валюта;
		
	ИзменениеВалютыОбъект();
	
КонецПроцедуры

// Процедура заполняет табличную часть ЗависимыеОбороты.
// 
// Параметры:
//  Нет.
// 
Процедура ЗаполнитьЗависимыеОбороты() Экспорт

	УстановитьПривилегированныйРежим(Истина);	
		
	Если НЕ ЗначениеЗаполнено(РежимЗависимыхОборотов)
		ИЛИ РежимЗависимыхОборотов = Перечисления.бит_РежимыЗависимыхОборотов.НеФормировать Тогда
		// Не формируем зависимые обороты.
		Возврат;
	КонецЕсли;
	
	ПараметыЗаполнения = бит_Бюджетирование.НовыеПараметыЗаполненияЗависимыхОборотов();
	ПараметыЗаполнения.ТаблицаИсточник      = БДДС.Выгрузить();
	ПараметыЗаполнения.ТаблицаПриемник      = ЗависимыеОбороты.ВыгрузитьКолонки();
	ПараметыЗаполнения.Сценарий             = Сценарий;
	ПараметыЗаполнения.ВестиПротокол        = Истина;
	
	ТаблицаПриемник = бит_Бюджетирование.ЗависимыеОборотыПоИсточнику(ПараметыЗаполнения);
	
	ЗависимыеОбороты.Очистить();
	Для каждого СтрокаТаблицы Из ТаблицаПриемник Цикл
		Если СтрокаТаблицы.Сумма <> 0 ИЛИ СтрокаТаблицы.Количество <> 0  Тогда
			ЗаполнитьЗначенияСвойств(ЗависимыеОбороты.Добавить(), СтрокаТаблицы);		
		КонецЕсли;
	КонецЦикла;
	
	Если СторнироватьЗависимыеОбороты Тогда
		СторнироватьРанееСозданныеЗависимыеОбороты();
	КонецЕсли; 														 
	
	УстановитьПривилегированныйРежим(Ложь);	
	бит_Бюджетирование.ОчиститьНеИспользуемыеАналитикиСтатейОборотов(ЗависимыеОбороты);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьСтрокуВНаборЗначенийДоступа(ЗначениеДоступа, Таблица)
	
	СтрокаТаб = Таблица.Добавить();
	СтрокаТаб.ЗначениеДоступа = ЗначениеДоступа;

КонецПроцедуры

// Процедура сторнирует ранее созданные зависимые обороты при нажатии флага СторнироватьЗависимыеОбороты. 
// 
Процедура СторнироватьРанееСозданныеЗависимыеОбороты()

	ТаблицаКолонок = БДДС.Выгрузить();
	
	НеобходимыеКолонки = Новый Массив;
	Для каждого Колонка Из ТаблицаКолонок.Колонки Цикл
		Если Колонка.Имя = "НомерСтроки" ИЛИ СтрНайти(Колонка.Имя, "_Старый") > 0 Тогда
			НеобходимыеКолонки.Добавить(Колонка.Имя);
		КонецЕсли; 
	КонецЦикла; 
	
	ТаблицаИсточник = БДДС.Выгрузить(, СтрСоединить(НеобходимыеКолонки, ","));
	Для каждого Колонка Из ТаблицаИсточник.Колонки Цикл
		Если Колонка.Имя = "НомерСтроки" Тогда
			Продолжить;
		КонецЕсли; 
		
		Если СтрНайти(Колонка.Имя, "_Старый") > 0 Тогда
			Колонка.Имя = СтрЗаменить(Колонка.Имя, "_Старый", "");  
		КонецЕсли; 
	КонецЦикла; 
	
	// Копия зависимых оборотов, сформированных по "новым" строкам.
	ЗависимыеОборотыПослеИзменения = ЗависимыеОбороты.Выгрузить();
	ЗависимыеОбороты.Очистить();
	
	Для каждого СтрокаИсточника Из ТаблицаИсточник Цикл
		СтрокаИсточника.Сумма 		  = - СтрокаИсточника.Сумма;
		СтрокаИсточника.СуммаРегл 	  = - СтрокаИсточника.СуммаРегл;
		СтрокаИсточника.СуммаСценарий = - СтрокаИсточника.СуммаСценарий;
		СтрокаИсточника.СуммаУпр	  = - СтрокаИсточника.СуммаУпр;
		СтрокаИсточника.Количество	  = - СтрокаИсточника.Количество;
	КонецЦикла;
	
	ПараметыЗаполнения = бит_Бюджетирование.НовыеПараметыЗаполненияЗависимыхОборотов();
	ПараметыЗаполнения.ТаблицаИсточник      = ТаблицаИсточник;
	ПараметыЗаполнения.ТаблицаПриемник      = ЗависимыеОбороты.ВыгрузитьКолонки();
	ПараметыЗаполнения.Сценарий             = Сценарий;
	ПараметыЗаполнения.ВестиПротокол        = Истина;
												
	ТаблицаПриемник = бит_Бюджетирование.ЗависимыеОборотыПоИсточнику(ПараметыЗаполнения);
	Для каждого СтрокаТаблицы Из ТаблицаПриемник Цикл
		Если СтрокаТаблицы.Сумма <> 0 ИЛИ СтрокаТаблицы.Количество <> 0  Тогда
			НоваяСтрока = ЗависимыеОбороты.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
			НоваяСтрока.Сторно = Истина;
		КонецЕсли;
	КонецЦикла;
	
	// Восстановление "новых" зависимых оборотов из копии.
	Для каждого СтрокаТаблицы Из ЗависимыеОборотыПослеИзменения Цикл
		ЗаполнитьЗначенияСвойств(ЗависимыеОбороты.Добавить(), СтрокаТаблицы);	
	КонецЦикла; 
	
КонецПроцедуры
 
#КонецОбласти

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли