&НаКлиенте
Процедура КомандаОбновить(Команда)
	
	ГенерироватьФорму();
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаЗаполнить(Команда)
	
	Организация = ПредопределенноеЗначение("Справочник.Организации.ПустаяСсылка");
	Сценарий    = ПредопределенноеЗначение("Справочник.СценарииПланирования.ПустаяСсылка");
	ЦФО         = ПредопределенноеЗначение("Справочник.Подразделения.ПустаяСсылка");
	
	Для каждого МетаРеквизит Из ПсевдоМетаданные.Реквизиты Цикл
		ИмяРеквизита = ИмяРеквизитаШапки(МетаРеквизит.Имя);
		Если СтрНайти(ИмяРеквизита, "Организация") <> 0 Тогда 
			Организация = ЭтотОбъект[ИмяРеквизита]; 
	    ИначеЕсли СтрНайти(ИмяРеквизита, "Сценарий") <> 0 Тогда 
			Сценарий = ЭтотОбъект[ИмяРеквизита];
		ИначеЕсли СтрНайти(ИмяРеквизита, "ЦФО") <> 0 Тогда 
			ЦФО = ЭтотОбъект[ИмяРеквизита];
		КонецЕсли;
	КонецЦикла;
			
	ИмяТаблицы = "Таблица_"+ СтрЗаменить(Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя, "Страница_", "");
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Дата"                 , Объект.Дата);
	ПараметрыФормы.Вставить("Организация"          , Организация);
	ПараметрыФормы.Вставить("Сценарий"             , Сценарий);
	ПараметрыФормы.Вставить("ЦФО"                  , ЦФО);
	ПараметрыФормы.Вставить("ИмяЗаполняемойТаблицы", ИмяТаблицы);
	
	ОткрытьФорму("Обработка.бит_ПолучениеДанныхПоИсточникам.Форма.Форма", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаВыгрузить(Команда)
	
	Если Модифицированность Тогда
		
		Оповещение = Новый ОписаниеОповещения("ВыгрузитьВопросЗавершение", ЭтотОбъект);
		ТекстСообщения = НСтр("ru='Для выполнение действия необходимо записать документ. Продолжить?';
							  |en='To perform this action document must be saved. Continue?'");
		ПоказатьВопрос(Оповещение,ТекстСообщения, РежимДиалогаВопрос.ДаНет, 15, КодВозвратаДиалога.Да);
		
	Иначе
		
		Состояние(НСтр("ru='Выгрузка в Excel...';en='Export to Excel...'"));
		ДанныеДляВыгрузки = ПодготовитьДанныеДляВыгрузки();
		бит_ПроформыКлиент.ВыгрузитьПроформы(ДанныеДляВыгрузки);
		
	КонецЕсли; 
	
КонецПроцедуры

// Процедура обработчик оповещения "ВыгрузитьВопросЗавершение".
// 
// Параметры:
// Ответ - КодВозвратаДиалога
// ДополнительныеДанные - Структура.
// 
&НаКлиенте 
Процедура ВыгрузитьВопросЗавершение(Ответ, ДополнительныеДанные) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		Выгружать = Записать();
		
		Если Выгружать Тогда
			
			Состояние(НСтр("ru='Выгрузка в Excel...';en='Export to Excel...'"));
			ДанныеДляВыгрузки = ПодготовитьДанныеДляВыгрузки();
			бит_ПроформыКлиент.ВыгрузитьПроформы(ДанныеДляВыгрузки);
			
		КонецЕсли; 
		
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

