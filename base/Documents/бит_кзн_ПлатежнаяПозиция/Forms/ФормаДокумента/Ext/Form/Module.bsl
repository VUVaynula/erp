&НаСервере
Процедура ДекорацияВалютыИКурсПлатежаНажатиеЗавершениеНаСервере(Знач ИзмененаСумма)
	
	ЗаполнитьКурсКратностьТекстом();
	ЗаполнитьВалютуВзаиморасчетовДокумента();
	
	Если ИзмененаСумма Тогда
		ОбработатьИзмененииСуммыДокумента(Истина);
		ОбновитьКонтролируемыеРеквизиты("СуммаДокумента", ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СуммаВзаиморасчетовПриИзмененииНаСервере()
	
	ТекущаяСуммаДокумента = Объект.СуммаДокумента;
	
	Если Объект.СуммаДокумента = 0 Тогда
		Если Объект.ВалютаДокумента = ВалютаРеглУчета Тогда
			Если Объект.КурсЗнаменательВзаиморасчетов <> 0 Тогда
				Объект.СуммаДокумента = Объект.СуммаВзаиморасчетов * Объект.КурсЧислительВзаиморасчетов / Объект.КурсЗнаменательВзаиморасчетов;
			Иначе
				Объект.СуммаДокумента = 0;
			КонецЕсли;
		Иначе
			Если Объект.КурсЧислительВзаиморасчетов <> 0 Тогда
				Объект.СуммаДокумента = Объект.СуммаВзаиморасчетов / Объект.КурсЧислительВзаиморасчетов * Объект.КурсЗнаменательВзаиморасчетов;
			Иначе
				Объект.СуммаДокумента = 0;
			КонецЕсли;
		КонецЕсли;
	Иначе
		Если Объект.ВалютаВзаиморасчетов = Объект.ВалютаДокумента Тогда
			
			Объект.КурсЧислительВзаиморасчетов = 1;
			
		ИначеЕсли Объект.ВалютаДокумента = ВалютаРеглУчета Тогда
			Если Объект.СуммаВзаиморасчетов <> 0 Тогда
				Объект.КурсЧислительВзаиморасчетов = Объект.СуммаДокумента / Объект.СуммаВзаиморасчетов * Объект.КурсЗнаменательВзаиморасчетов;
			Иначе
				Объект.КурсЧислительВзаиморасчетов = 1;
			КонецЕсли;
		Иначе
			Если Объект.СуммаДокумента <> 0 Тогда
				Объект.КурсЧислительВзаиморасчетов = Объект.СуммаВзаиморасчетов / Объект.СуммаДокумента * Объект.КурсЗнаменательВзаиморасчетов;
			Иначе
				Объект.КурсЧислительВзаиморасчетов = 0;
			КонецЕсли;
		КонецЕсли;
		СформироватьКурсЗнаменательТекстом();
	КонецЕсли;
	
	Если Объект.СуммаДокумента <> ТекущаяСуммаДокумента Тогда
		ОбработатьИзмененииСуммыДокумента(Истина);	
	КонецЕсли;
	
	ЗаполнитьВалютуВзаиморасчетовДокумента();
		
КонецПроцедуры

&НаСервере
Процедура ОбработатьИзменениеВалютыВзаиморасчетов()

	Объект.ВалютаДокумента = ВалютаПланированияДенежныхСредств();
	
	ЗаполнитьКурсВзаиморасчетов();
	
	РассчитатьСуммуВзаиморасчетов();
	СформироватьКурсЗнаменательТекстом();
	ЗаполнитьВалютуВзаиморасчетовДокумента();

	ОбновитьКонтролируемыеРеквизиты("ВалютаДокумента", ЭтотОбъект);
	УправлениеФормой();

КонецПроцедуры

&НаСервере
Процедура КурсЧислительВзаиморасчетовПриИзмененииНаСервере()
	
	// ++ NB См. РасшифровкаПлатежаКурсЧислительВзаиморасчетовПриИзмененииНаСервере 
	
	РассчитатьСуммуВзаиморасчетов();
	СформироватьКурсЗнаменательТекстом();
	ЗаполнитьВалютуВзаиморасчетовДокумента();
	
КонецПроцедуры

// См. ДенежныеСредстваСервер.НадписьВалютыИКурсПлатежа().
//
&НаСервере
Функция НадписьВалютыИКурсПлатежа()
		
	ШаблонКурса = "(%1 %2 = %3 %4)";
	СтрокиНадписи = Новый Массив;
	СтрокиНадписи.Добавить(НСтр("ru = 'Расчеты';
								|en = 'AR/AP accounting'"));

	СтрокиНадписи.Добавить(Строка(Объект.СуммаВзаиморасчетов));
	СтрокиНадписи.Добавить(Строка(Объект.ВалютаВзаиморасчетов));
		
	Если Объект.КурсЧислительВзаиморасчетов <> 0 Тогда
		Если Объект.ВалютаДокумента = ВалютаРеглУчета Тогда
			
			СтрокиНадписи.Добавить(СтрШаблон(ШаблонКурса,
				Объект.КурсЗнаменательВзаиморасчетов,
				Объект.ВалютаВзаиморасчетов,
				Строка(Формат(Объект.КурсЧислительВзаиморасчетов, "ЧДЦ=4")),
				Объект.ВалютаДокумента));
		Иначе
			СтрокиНадписи.Добавить(СтрШаблон(ШаблонКурса,
				Объект.КурсЗнаменательВзаиморасчетов,
				Объект.ВалютаДокумента,
				Строка(Формат(Объект.КурсЧислительВзаиморасчетов, "ЧДЦ=4")),
				Объект.ВалютаВзаиморасчетов));
		КонецЕсли;
	КонецЕсли;

	Возврат СтрСоединить(СтрокиНадписи, " ");
	
КонецФункции

&НаСервере
Процедура СформироватьКурсЗнаменательТекстом()

	Данные = Новый Структура;
	Данные.Вставить("КурсЗнаменательВзаиморасчетовНадпись", КурсЗнаменательВзаиморасчетовНадпись);
	Данные.Вставить("КурсЧислительВзаиморасчетов", 			Объект.КурсЧислительВзаиморасчетов);
	Данные.Вставить("КурсЗнаменательВзаиморасчетов", 		Объект.КурсЗнаменательВзаиморасчетов);
	Данные.Вставить("ВалютаВзаиморасчетов",					Объект.ВалютаВзаиморасчетов);
	Данные.Вставить("КурсЧислительВзаиморасчетовТекст",		"");
	
	ДенежныеСредстваКлиентСервер.СформироватьКурсЗнаменательТекстом(Данные, Объект.ВалютаДокумента, ВалютаРеглУчета);

	КурсЗнаменательВзаиморасчетовНадпись = Данные.КурсЗнаменательВзаиморасчетовНадпись;
	
КонецПроцедуры

