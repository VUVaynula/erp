	Если ЗначениеЗаполнено(Объект.СуммаВзаиморасчетов)
		И Объект.ВалютаВзаиморасчетов = Объект.ВалютаДокумента
		И Объект.СуммаВзаиморасчетов <> Объект.СуммаДокумента Тогда
		Объект.СуммаВзаиморасчетов = Объект.СуммаДокумента;
	Иначе
		СуммаВзаиморасчетовПриИзмененииНаСервере();
	КонецЕсли;

