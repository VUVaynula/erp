&НаКлиенте
Процедура ДекорацияВалютыИКурсПлатежаНажатие(Элемент)
				
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТолькоПросмотр",          		 ТолькоПросмотр);
	ПараметрыФормы.Вставить("ВалютаДокумента",         		 Объект.ВалютаДокумента);
	ПараметрыФормы.Вставить("СуммаДокумента",          		 Объект.СуммаДокумента);
	ПараметрыФормы.Вставить("ВалютаВзаиморасчетов",    		 Объект.ВалютаВзаиморасчетов);
	ПараметрыФормы.Вставить("СуммаВзаиморасчетов",     		 Объект.СуммаВзаиморасчетов);
	ПараметрыФормы.Вставить("КурсЧислительВзаиморасчетов",   Объект.КурсЧислительВзаиморасчетов);
	ПараметрыФормы.Вставить("КурсЗнаменательВзаиморасчетов", Объект.КурсЗнаменательВзаиморасчетов);
	ПараметрыФормы.Вставить("ВалютаРеглУчета",         		 ВалютаРеглУчета);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", ЭтотОбъект);
	ДополнительныеПараметры.Вставить("ПараметрыФормы", ПараметрыФормы);
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ДекорацияВалютыИКурсПлатежаНажатиеЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	ОткрытьФорму("ОбщаяФорма.ВалютыИКурсПлатежа", ПараметрыФормы, ЭтотОбъект,,,, ОповещениеОЗакрытии);
	
КонецПроцедуры

// Обработчик завершения открытия формы.
//  См. Синтакс-помощник: ОткрытьФорму().
// 
&НаКлиенте
Процедура ДекорацияВалютыИКурсПлатежаНажатиеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	РезультатыОбработки = Новый Структура;
		
	ПараметрыФормы = ДополнительныеПараметры.ПараметрыФормы;
	
	ИзмененныеРеквизиты = Новый Массив;
	Для каждого КлючИЗначение Из Результат Цикл
		Если КлючИЗначение.Значение <> ПараметрыФормы[КлючИЗначение.Ключ] Тогда
			ИзмененныеРеквизиты.Добавить(КлючИЗначение.Ключ);
		КонецЕсли;
	КонецЦикла;
	РезультатыОбработки.Вставить("ИзмененныеРеквизиты", ИзмененныеРеквизиты);
	
	ИзмененаСумма = Ложь;
	Если ИзмененныеРеквизиты.Количество() Тогда
		
		Модифицированность = Истина;
		
		Если ИзмененныеРеквизиты.Найти("КурсЧислительВзаиморасчетов") <> Неопределено Тогда
			Объект.КурсЧислительВзаиморасчетов = Результат.КурсЧислительВзаиморасчетов;
		КонецЕсли;
		
		Если ИзмененныеРеквизиты.Найти("КурсЗнаменательВзаиморасчетов") <> Неопределено Тогда
			Объект.КурсЗнаменательВзаиморасчетов = Результат.КурсЗнаменательВзаиморасчетов;
		КонецЕсли;
		
		Если ИзмененныеРеквизиты.Найти("СуммаДокумента") <> Неопределено Тогда
			Объект.СуммаДокумента = Результат.СуммаДокумента;
			ИзмененаСумма		  = Истина;
			Если Объект.ВалютаВзаиморасчетов <> Объект.ВалютаДокумента Тогда
				Объект.СуммаВзаиморасчетов = 0;
			Иначе
				Объект.СуммаВзаиморасчетов = Объект.СуммаДокумента;
			КонецЕсли;
		КонецЕсли;
		
		Если ИзмененныеРеквизиты.Найти("СуммаДокумента") <> Неопределено
			И ИзмененныеРеквизиты.Найти("СуммаВзаиморасчетов") = Неопределено Тогда
			РассчитатьСуммуВзаиморасчетов();
		КонецЕсли;
		
		Если ИзмененныеРеквизиты.Найти("СуммаВзаиморасчетов") <> Неопределено
			ИЛИ Объект.СуммаВзаиморасчетов <> Результат.СуммаВзаиморасчетов Тогда
			Объект.СуммаВзаиморасчетов = Результат.СуммаВзаиморасчетов;
		КонецЕсли;
	КонецЕсли;
	
	ДекорацияВалютыИКурсПлатежаНажатиеЗавершениеНаСервере(ИзмененаСумма);
	
КонецПроцедуры

&НаКлиенте
