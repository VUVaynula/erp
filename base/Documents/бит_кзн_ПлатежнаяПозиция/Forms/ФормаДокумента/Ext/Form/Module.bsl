&НаСервере
Функция  СоздатьПлатежныйДокумент()
		
	ДанныеЗаполнения = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.НовыеПараметрыДокументаСоздатьПлатежныеДокументы(); 
	ДанныеЗаполнения.Дата = Объект.ДатаПлан;
	
	НоваяСтрока = ДанныеЗаполнения.Позиции.Добавить();
	НоваяСтрока.Позиция = Объект.Ссылка;	

	Результат = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.СоздатьДокументыНаОсновеВыделенных(
					Объект.ДокументПланирования, ДанныеЗаполнения);
					
	УстановитьСсылкиНаДокументыОплаты();
	
	Возврат Результат.ВыгрузитьКолонку("ДокументОплаты");
		
КонецФункции

//  Процедура определяет документы оплаты и устанвливает ссылки на них в форму.
//
// Параметры:
//
&НаСервере
Процедура УстановитьСсылкиНаДокументыОплаты()

	ДокументыОплаты = НайтиДокументыОплаты();
	
	ЭлементыКУдалению = Новый Массив;
	Для каждого Элемент Из Элементы.ГруппаПлатежныеДокументы.ПодчиненныеЭлементы Цикл
		ЭлементыКУдалению.Добавить(Элемент);
	КонецЦикла;
	
	Для каждого Элемент Из ЭлементыКУдалению Цикл
		Элементы.Удалить(Элемент);	
	КонецЦикла;
	
	Индекс = 1;
	Для Каждого Документ Из ДокументыОплаты Цикл
		ИмяЭлемента = "Документ" + Индекс;
		Элемент = Элементы.Добавить(ИмяЭлемента, Тип("ДекорацияФормы"), Элементы.ГруппаПлатежныеДокументы);
		Элемент.Гиперссылка = Истина;
		Элемент.Заголовок = Документ.Ссылка;
		Элемент.РастягиватьПоГоризонтали = Истина;
		Элемент.РастягиватьПоВертикали = Ложь;
		Элемент.ВысотаЗаголовка = 1;
		Элемент.УстановитьДействие("Нажатие", "Подключаемый_ДокументОплатыНажатие");
		Индекс = Индекс+1;
	КонецЦикла;
	
КонецПроцедуры // ОпределитьДокументыОплаты()

//  Функция возвращает массив с документами оплаты по позиции.
//
// Возвращаемое значение:
//  ДокументыОплаты - Массив.
//
&НаСервере
Функция НайтиДокументыОплаты()

	ДокументыОплаты = Новый Массив;
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда	
		ДокументыОплаты = Документы.бит_кзн_ПлатежнаяПозиция.НайтиДокументыОплатыПоПозиции(Объект.Ссылка);	
	КонецЕсли; 

	Возврат ДокументыОплаты;
	
КонецФункции // НайтиДокументыОплаты()

// Процедура заполняет сценарий при изменении поля документа. 
// 
// Параметры: 
//  Имя - Строка.
//
&НаСервере
Процедура ЗаполнитьСценарий(Имя)

	СтруктураПараметров = Новый Структура;
	Если Имя = "Организация" Тогда		
		СтруктураПараметров.Вставить("Организация", Объект.Организация);		
	ИначеЕсли Имя = "ЦФО" Тогда 		
		СтруктураПараметров.Вставить("ЦФО", Объект.ЦФО);		
	КонецЕсли; 
	
	КонтролироватьЗаявку = бит_НастройкиПрограммы.КонтролироватьЗаявкуПоБюджету(СтруктураПараметров, Объект.Дата);
	Сценарий = бит_НастройкиПрограммы.КазначействоСценарийКонтроляПоБюджету(СтруктураПараметров, Объект.Дата);
	
	Если ЗначениеЗаполнено(Сценарий) И КонтролироватьЗаявку Тогда	
		Объект.Сценарий = Сценарий;	
	КонецЕсли; 
	
	ПриИзмененииПоставляемыхРеквизитов(Объект.ЦФО);

КонецПроцедуры // ЗаполнитьСценарий()

&НаСервере
Процедура УстановитьПараметрыВыбораОрганизацияКонтрагент(ИмяЭлемента)

	Если ТипЗнч(Объект[ИмяЭлемента]) = Тип("СправочникСсылка.ДоговорыКонтрагентов")
		ИЛИ (бит_ОбщегоНазначенияКлиентСерверПереопределяемый.ЕстьДоговорыАренды()
			 И ТипЗнч(Объект[ИмяЭлемента]) = Тип("СправочникСсылка.ДоговорыАренды"))
		ИЛИ ТипЗнч(Объект[ИмяЭлемента]) = Тип("СправочникСсылка.ДоговорыКредитовИДепозитов") Тогда
	
		НоваяСвязь1 = Новый СвязьПараметраВыбора("Отбор.Организация", "Объект.Организация");
		НоваяСвязь2 = Новый СвязьПараметраВыбора("Отбор.Контрагент", "Объект.Контрагент");
		НовыйМассив = Новый Массив();
		НовыйМассив.Добавить(НоваяСвязь1);
		НовыйМассив.Добавить(НоваяСвязь2);
		НовыеСвязи = Новый ФиксированныйМассив(НовыйМассив);
		Элементы[ИмяЭлемента].СвязиПараметровВыбора = НовыеСвязи;
	Иначе 
		НовыеСвязи = Новый ФиксированныйМассив(Новый Массив());
		Элементы[ИмяЭлемента].СвязиПараметровВыбора = НовыеСвязи;
	КонецЕсли;	
		
КонецПроцедуры

//  Процедура обрабатывает изменение договора. 
//
&НаСервере
Процедура ДоговорПриИзмененииНаСервере()
								 
	РеквизитыДоговора = Новый Структура; 
	РеквизитыДоговора.Вставить("БанковскийСчет");
	РеквизитыДоговора.Вставить("бит_ЦФО");
	РеквизитыДоговора.Вставить("бит_ОсновнаяСтатьяОборотов");
	РеквизитыДоговора.Вставить("бит_Проект");
	РеквизитыДоговора.Вставить("ВалютаВзаиморасчетов");
	РеквизитыДоговора.Вставить("НаправлениеДеятельности");
	РеквизитыДоговора.Вставить("ГруппаФинансовогоУчета");
	
	Если ТипЗнч(Объект.Договор) = Тип("СправочникСсылка.ДоговорыМеждуОрганизациями") Тогда
		РеквизитыДоговора.Вставить("ВариантКурсаДоговора");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Договор) Тогда
		РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Договор, 
								Новый ФиксированнаяСтруктура(РеквизитыДоговора));
	КонецЕсли;
						 
	Если НЕ ЗначениеЗаполнено(Объект.ЦФО) 
		И ЗначениеЗаполнено(РеквизитыДоговора.бит_ЦФО) Тогда
		Объект.ЦФО = РеквизитыДоговора.бит_ЦФО; 
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Объект.СтатьяОборотов) 
		И ЗначениеЗаполнено(РеквизитыДоговора.бит_ОсновнаяСтатьяОборотов) Тогда
		Если РеквизитыДоговора.бит_ОсновнаяСтатьяОборотов.РасходДоход = Перечисления.бит_РасходДоход.Расходование Тогда
			Объект.СтатьяОборотов = РеквизитыДоговора.бит_ОсновнаяСтатьяОборотов;
			СтатьяОборотовПриИзмененииНаСервере(Ложь);
		КонецЕсли; 
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Объект.ОбъектРасчетов) И ЗначениеЗаполнено(Объект.Договор) Тогда
		Объект.ВалютаВзаиморасчетов	   = РеквизитыДоговора.ВалютаВзаиморасчетов;
		Объект.НаправлениеДеятельности = РеквизитыДоговора.НаправлениеДеятельности;
		Объект.ГруппаФинансовогоУчета  = РеквизитыДоговора.ГруппаФинансовогоУчета;
		
		ЗаполнитьКурсВзаиморасчетов();
		РассчитатьСуммуВзаиморасчетов();
		СформироватьКурсЗнаменательТекстом();
		ЗаполнитьВалютуВзаиморасчетовДокумента();
		УстановитьПараметрыВыбораБанковскийСчетКасса();
		
		ПриИзмененииПоставляемыхРеквизитов(Объект.ГруппаФинансовогоУчета);
		ПриИзмененииПоставляемыхРеквизитов(Объект.НаправлениеДеятельности);

		Если ТипЗнч(Объект.Договор) = Тип("СправочникСсылка.ДоговорыМеждуОрганизациями") Тогда
			ВариантКурсаДоговора = РеквизитыДоговора.ВариантКурсаДоговора;	
		КонецЕсли;
	Иначе
		Объект.ГруппаФинансовогоУчета  = Неопределено;
		Объект.НаправлениеДеятельности = Неопределено;
	КонецЕсли;
		
	// Заполним проект из договора.
	Если ЗначениеЗаполнено(Объект.Договор) Тогда
		ПриИзмененииПоставляемыхРеквизитов(РеквизитыДоговора.бит_Проект);
	КонецЕсли;

	Если ЗначениеЗаполнено(Объект.Договор) Тогда
		ПриИзмененииПоставляемыхРеквизитов(Объект.Договор);
	Иначе
		ПриИзмененииПоставляемыхРеквизитов(Справочники.ДоговорыКонтрагентов.ПустаяСсылка());
	КонецЕсли;
		
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораБанковскийСчетПолучателя()
	
	СвязиПараметровВыбора = Новый Массив;
	
	Если ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствПодотчетнику
	 ИЛИ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета 
	 ИЛИ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыдачаЗаймаСотруднику Тогда		
		Если Объект.ПеречислениеСотрудникуЧерезБанк Тогда
			СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Отбор.Владелец", "Объект.Контрагент"));
		Иначе
			СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Отбор.Владелец", "Объект.ФизЛицо"));
		КонецЕсли;
	Иначе	
		СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Отбор.Владелец", "Объект.Контрагент"));
	КонецЕсли;	
	
	НовыеСвязи = Новый ФиксированныйМассив(СвязиПараметровВыбора);
	Элементы.БанковскийСчетПолучателя.СвязиПараметровВыбора = НовыеСвязи;
		
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораБанковскийСчетКасса()

	Если ТипЗнч(Объект.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
		ОтборОрганизация = Новый Массив();
		ОтборОрганизация.Добавить(Объект.Организация);
		Если Объект.Организация.ДопускаютсяВзаиморасчетыЧерезГоловнуюОрганизацию Тогда
			ОтборОрганизация.Добавить(Объект.Организация.ГоловнаяОрганизация);
		КонецЕсли; 
		ПараметрыОтбора = Новый ФиксированныйМассив(ОтборОрганизация);
		ПараметрВыбораОрганизация  = Новый ПараметрВыбора("Отбор.Владелец", ПараметрыОтбора);
		
		// Формирование итогового отбора.
		ОтборИтог = Новый Массив;
		ОтборИтог.Добавить(ПараметрВыбораОрганизация);
		
		Если НЕ ЭтоРежимЗаявки И Объект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
			ПараметрВыбораВалюта = Новый ПараметрВыбора("Отбор.ВалютаДенежныхСредств", Объект.ВалютаДокумента);		
			ОтборИтог.Добавить(ПараметрВыбораВалюта);	
		КонецЕсли;
		
		НовыеПараметры = Новый ФиксированныйМассив(ОтборИтог);

	Иначе	
		НовыеПараметры = бит_Казначейство.УстановитьОтборыДляБанковскихСчетовКасс(Объект.Организация, 
							Объект.ВалютаДокумента, Объект.ДокументПланирования, ВалютаРеглУчета);
	КонецЕсли;
	
	Элементы.БанковскийСчет.ПараметрыВыбора = НовыеПараметры;
	Элементы.Касса.ПараметрыВыбора			= НовыеПараметры;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораТипПлатежаПоАренде()

	// См. Документ.СписаниеБезналичныхДенежныхСредств.Форма.ФормаДокумента: 
	// РасшифровкаПлатежаДоговорАрендыПриИзмененииСервер().
	
	Элементы.ТипПлатежаПоАренде.ПараметрыВыбора = Новый ФиксированныйМассив(Новый Массив);

	НовыеПараметры = Новый Массив;
	
	НовыйПараметр = Новый ПараметрВыбора("Отбор.Договор", Объект.ДоговорАренды);
	НовыеПараметры.Добавить(НовыйПараметр);
	
	НовыйПараметр = Новый ПараметрВыбора("Отбор.Платеж", Истина);
	НовыеПараметры.Добавить(НовыйПараметр);
	
	Элементы.ТипПлатежаПоАренде.ПараметрыВыбора = Новый ФиксированныйМассив(НовыеПараметры);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораТипаНалогов()
	
	ТекущаяДата = ?(ЗначениеЗаполнено(Объект.ДатаПлан), Объект.ДатаПлан, ТекущаяДатаСеанса());
	Если НЕ ПлатежиВБюджет.ИспользуетсяЕдиныйНалоговыйПлатеж(Объект.Организация, ТекущаяДата) Тогда
		Возврат;
	КонецЕсли;
	
	ДоступныеТипыНалогов = Новый Массив;
	ДоступныеТипыНалогов.Добавить(Справочники.ВидыНалоговВзносов.ПрочиеНалогиИСборы);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДоступныеТипыНалогов, ПлатежиВБюджет.ТипыНалоговУплачиваемыеОтдельно());
	
	ПараметрыВыбораНалогов = Новый Массив;
	ПараметрыВыбораНалогов.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", ДоступныеТипыНалогов));
	Элементы.ТипНалога.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбораНалогов);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораОрганизацииПолучателя()
	
	НовыеПараметры = Новый Массив;
	
	Если Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВнутренняяПередачаДенежныхСредств Тогда
		
		НовыеПараметры.Добавить(Новый ПараметрВыбора("РежимВыбораВзаимосвязанныхОрганизаций", "ТолькоВзаимосвязанные"));
		НовыеПараметры.Добавить(Новый ПараметрВыбора("Организация", Объект.Организация));
		
	ИначеЕсли Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ОплатаДенежныхСредствВДругуюОрганизацию
		ИЛИ Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВозвратДенежныхСредствВДругуюОрганизацию Тогда
		
		НовыеПараметры.Добавить(Новый ПараметрВыбора("РежимВыбораВзаимосвязанныхОрганизаций", "ТолькоНеВзаимосвязанные"));
		НовыеПараметры.Добавить(Новый ПараметрВыбора("Организация", Объект.Организация));
		
	КонецЕсли;
	
	Элементы.ОрганизацияПолучатель.ПараметрыВыбора = Новый ФиксированныйМассив(НовыеПараметры);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораПартнера()

	ПараметрыОбъекта = Новый Структура("ХозяйственнаяОперация", ХозОперацияУП);
	ДенежныеСредстваСервер.УстановитьПараметрыВыбораПартнера(Объект, Элементы.Партнер);

КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораГруппыФинансовогоУчета()
	
	НовыеПараметры = Новый Массив;
	НовыеПараметры.Добавить(Новый СвязьПараметраВыбора("Отбор.Договор", "Объект.Договор", РежимИзмененияСвязанногоЗначения.Очищать));
	НовыеПараметры.Добавить(Новый СвязьПараметраВыбора("Отбор.ХозяйственнаяОперация", "ХозОперацияУП", РежимИзмененияСвязанногоЗначения.Очищать));

	Элементы.ГруппаФинансовогоУчета.СвязиПараметровВыбора = Новый ФиксированныйМассив(НовыеПараметры);
	
КонецПроцедуры

// Заполняет данные выбора во время автоподбора аналитики по введенному тексту.
//
// Параметры:
//  ДанныеВыбора - СписокЗначений - Список значений для заполнения.
//  Текст 		 - Строка - Текст, введенный в поле.
//  Отбор 		 - Структура - Отбор по реквизитам справочников договоров.
//  ТипДоговора  - Тип - Тип ссылки договора.
//
&НаСервереБезКонтекста
Процедура АналитикаПолучениеДанныхВыбора(ДанныеВыбора, Текст, Отбор, ТипДоговора)
	
	ДанныеВыбора = Новый СписокЗначений;
	бит_МеханизмДопИзмерений.ЗаполнитьДанныеВыбораАналитикиДоговоров(ДанныеВыбора, Текст, Отбор, ТипДоговора);
	
КонецПроцедуры

&НаСервере
Процедура КонтрагентПриИзмененииНаСервере()
		
	Объект.ОбъектРасчетов = Справочники.ОбъектыРасчетов.ПустаяСсылка();
	Объект.Договор		  = Неопределено;
		
	УстановитьПараметрыВыбораДоговораСЗаказчиком(Истина);
	УстановитьПараметрыВыбораБанковскийСчетПолучателя();
	УправлениеЭлементамиОплатыЗасчетСредствГОЗ();
	УправлениеФормой();
	КодВидаДоходаПоУмолчанию();
	УстановитьПараметрыВыбораТипПлатежаПоАренде();
	
	Объект.Партнер = ДенежныеСредстваСервер.ПолучитьПартнераПоКонтрагенту(Объект.Контрагент, ХозОперацияУП);
	
	Если НЕ СчетСоответствуетВладельцу() Тогда
		Объект.БанковскийСчетПолучателя = Неопределено;	
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.БанковскийСчетПолучателя) Тогда
		Объект.БанковскийСчетПолучателя =
				Справочники.БанковскиеСчетаКонтрагентов.ПолучитьБанковскийСчетПоУмолчанию(Объект.Контрагент, Объект.ВалютаДокумента);		
	КонецЕсли;
		
	Объект.ПеречислениеСотрудникуЧерезБанк = ЗначениеЗаполнено(Объект.Контрагент)
												И (Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствПодотчетнику
												ИЛИ Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыплатаЗарплатыНаЛицевыеСчета
												ИЛИ Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаЗаймаСотруднику);
	ПеречислениеСотрудникуЧерезБанк = Число(Объект.ПеречислениеСотрудникуЧерезБанк);
	
	ОбновитьКонтролируемыеРеквизиты("Контрагент", ЭтотОбъект);
	ОбновитьКонтролируемыеРеквизиты("ОбъектРасчетов", ЭтотОбъект);
	
	ПриИзмененииПоставляемыхРеквизитов(Объект.Контрагент);
	ПриИзмененииПоставляемыхРеквизитов(Объект.ОбъектРасчетов);
	ПриИзмененииПоставляемыхРеквизитов(Справочники.ДоговорыКонтрагентов.ПустаяСсылка());
	ПриИзмененииПоставляемыхРеквизитов(Объект.БанковскийСчетПолучателя);
	ПроверитьКорректностьЗаполненияПлатежаВБюджет();
	
КонецПроцедуры

&НаСервере
Процедура ФизЛицоПриИзмененииНаСервере()
	
	//++ НЕ УТ
	Если НЕ СчетСоответствуетВладельцу() Тогда
		Объект.БанковскийСчетПолучателя = Неопределено;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ФизЛицо) Тогда
		Если НЕ ЗначениеЗаполнено(Объект.БанковскийСчетПолучателя)
			И НЕ Объект.ПеречислениеСотрудникуЧерезБанк Тогда
			Объект.БанковскийСчетПолучателя =
				Справочники.БанковскиеСчетаКонтрагентов.ПолучитьБанковскийСчетПоУмолчанию(Объект.ФизЛицо, Объект.ВалютаДокумента);
		КонецЕсли;
	КонецЕсли;
	
	ПриИзмененииПоставляемыхРеквизитов(Объект.ФизЛицо);
	//-- НЕ УТ
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРеквизитыПлательщика()
	
	РеквизитыПлательщика = ДенежныеСредстваСерверЛокализация.РеквизитыПлательщика(Объект);
	ЗаполнитьЗначенияСвойств(Объект, РеквизитыПлательщика);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьНадписьРеквизитыПлательщика()
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		НадписьРеквизитыПлательщика = ДенежныеСредстваСерверЛокализация.НадписьРеквизитыПлательщика(
			Объект.ИННПлательщика, Объект.КПППлательщика, Объект.ТекстПлательщика, ЮрФизЛицо, ХозОперацияУП);
	Иначе
		НадписьРеквизитыПлательщика = "";
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ХозяйственнаяОперацияУП()

	Возврат бит_КазначействоКлиентСервер.ХозяйственнаяОперацияУП(Объект.ХозяйственнаяОперация);
	
КонецФункции

&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	ЗаполнитьКэшЗначений();

	Пользователь	   = Пользователи.ТекущийПользователь();
	РазрешеноПроводить = бит_ПраваДоступа.ПолучитьЗначениеДопПраваПользователя(Пользователь, 
							ПланыВидовХарактеристик.бит_ДополнительныеПраваПользователей.РазрешеноПроводитьЗаявкиНаРасходованиеДС);

	ТекущаяДата 					= ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДата());
	ДатаНачалаПримененияПриказа107н = Константы.ДатаНачалаПримененияПриказа107н.Получить();
	ПрименениеПриказа107н 			= ТекущаяДата >= ДатаНачалаПримененияПриказа107н;
	ДатаНачалаПримененияПриказа126н = Константы.ДатаНачалаПримененияПриказа126н.Получить();
	ПрименениеПриказа126н 			= ДатаНачалаПримененияПриказа126н <> '00010101' И ТекущаяДата >= ДатаНачалаПримененияПриказа126н;

	ЭтоЗаявкаНаПеремещение	  = ТипЗнч(Объект.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств");
	ЭтоЗаявкаНаПереводСредств = ТипЗнч(Объект.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию");
	ЭтоЗаявкаНаРасходование	  = НЕ ЭтоЗаявкаНаПеремещение И НЕ ЭтоЗаявкаНаПереводСредств;
	
	УстановитьЭтоРежимЗаявки();
			
	Если ЗначениеЗаполнено(Объект.ДокументПланирования) Тогда		
		НомерЗаявки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ДокументПланирования, "Номер");		
	КонецЕсли;
		
	ХозОперацияУП = ХозяйственнаяОперацияУП();
	Если НЕ бит_ОбщегоНазначения.ЭтоУТ() Тогда
		ИспользоватьНачислениеЗарплаты = ПолучитьФункциональнуюОпцию("ИспользоватьНачислениеЗарплатыУТ");
		// Изменено наименование функциональной опции для релиза 2.5.10.
		ПоддержкаПлатежей275ФЗ = ПолучитьФункциональнуюОпцию("ПоддержкаБанковскогоИКазначейскогоСопровожденияГосконтрактов");
		
		ОплатаНДСВБюджетПоОтдельнымОперациям = (Объект.ТипНалога = Справочники.ВидыНалоговВзносов.НДС_ВвозимыеТовары
			ИЛИ Объект.ТипНалога = Справочники.ВидыНалоговВзносов.НДС_НалоговыйАгент);
	КонецЕсли;

	ТоварыРаботыУслугиСТарифнымРегулированием.Загрузить(ОбщегоНазначения.ПрочитатьXMLВТаблицу(
		Документы.ЗаявкаНаРасходованиеДенежныхСредств.ПолучитьМакет("ТоварыРаботыУслугиСТарифнымРегулированием").ПолучитьТекст()).Данные);
	
	Если Объект.ПлатежиПо275ФЗ И ЗначениеЗаполнено(Объект.ДоговорСЗаказчиком)
		И ТипЗнч(Объект.ДоговорСЗаказчиком) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.ДоговорСЗаказчиком,
			"ОплатаРасходовПоТарифамСГосрегулированием, ИностранныйИсполнительВУтвержденномПеречнеГОЗ, ГосударственныйКонтракт");
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ЗначенияРеквизитов);
	КонецЕсли;	
	
	ЗаполнитьСписокКодовВидаДохода();
	УстановитьПараметрыВыбораВидаОперации(ЭтотОбъект);
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		ЮрФизЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Организация, "ЮрФизЛицо", Истина);
	КонецЕсли;
	УстановитьНадписьРеквизитыПлательщика();
	
	СписокФизЛиц = Число(Объект.СписокФизЛиц);
	
	//++ НЕ УТ 
	ПараметрыНастройки = Документы.бит_кзн_ПлатежнаяПозиция.ПараметрыНастройкиСчетовУчета(
							Объект.ХозяйственнаяОперация, Объект.ТипНалога);
	НастройкаСчетовУчетаСервер.ПриЧтенииНаСервере(ЭтотОбъект, ПараметрыНастройки);
	//-- НЕ УТ 

	ДенежныеСредстваСервер.ЗаполнитьСписокВыбораПериодовАвансовогоОтчета(ЭтотОбъект, Объект.Дата);
	ПериодАвансовогоОтчетаДата = (ТипЗнч(ПериодАвансовогоОтчета) = Тип("Дата"));

	Если ЭтоЗаявкаНаПереводСредств Тогда
		ОрганизацияПолучатель = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ДокументПланирования, "ОрганизацияПолучатель");
	КонецЕсли;
	
	ИспользоватьДоговорыСПоставщиками	   = ПолучитьФункциональнуюОпцию("ИспользоватьДоговорыСПоставщиками");
	ИспользоватьДоговорыМеждуОрганизациями = ПолучитьФункциональнуюОпцию("ИспользоватьДоговорыМеждуОрганизациями");
	ИспользоватьДоговорыСКлиентами		   = ПолучитьФункциональнуюОпцию("ИспользоватьДоговорыСКлиентами");
	ИспользоватьПодразделения			   = ПолучитьФункциональнуюОпцию("ИспользоватьПодразделения");
	НоваяАрхитектураВзаиморасчетов 		   = ПолучитьФункциональнуюОпцию("НоваяАрхитектураВзаиморасчетов");
	ИспользоватьПартнеровИКонтрагентов	   = ПолучитьФункциональнуюОпцию("ИспользоватьПартнеровИКонтрагентов");
	ИспользоватьГруппыФинансовогоУчета	   = ПолучитьФункциональнуюОпцию("ИспользоватьГруппыФинансовогоУчета");
	НеУчитыватьСверхБюджета				   = НеУчитыватьСверхБюджета(Объект.Организация, Объект.ЦФО, Объект.Дата);
	ВалютаРеглУчета						   = Константы.ВалютаРегламентированногоУчета.Получить();
	
	ИспользоватьУчетЗатратПоНаправлениямДеятельности = ПолучитьФункциональнуюОпцию("ИспользоватьУчетЗатратПоНаправлениямДеятельности");

	ПеречислениеСотрудникуЧерезБанк = Число(Объект.ПеречислениеСотрудникуЧерезБанк);

	ЗаполнитьКурсВзаиморасчетов(Истина);
	ДокументДолженБытьОформленБезНДС();
	
	// Найти документы оплаты если таковые имеются.
	УстановитьСсылкиНаДокументыОплаты();
			
	УстановитьПараметрыВыбораБанковскийСчетКасса();
	УстановитьПараметрыВыбораБанковскийСчетПолучателя();
	УстановитьПараметрыВыбораТипПлатежаПоАренде();
	УстановитьПараметрыВыбораТипаНалогов();
	УстановитьПараметрыВыбораОрганизацииПолучателя();
	УстановитьПараметрыВыбораПартнера();
	УстановитьЗаголовокЭлементаПартнер();
	УстановитьПараметрыВыбораГруппыФинансовогоУчета();
	
	бит_МеханизмДопИзмерений.ПоказатьДополнительныеИзмеренияНаФорме(ЭтотОбъект,
		КэшЗначений.ИзмеренияДоп, КэшЗначений.НастройкиИзмерений);
	                                                                             	
	УстановитьВидимостьАналитик();
	
	УстановитьПараметрыВыбораДоговораСЗаказчиком();
	УстановитьПараметрыВыбораСтатьиРасходов();
	
	ЗаполнитьКонтролируемыеРеквизиты(ЭтотОбъект);

	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ПолучитьФункциональнуюОпцию("бит_ЗапретитьИзменениеЗаявкиВключеннойВРеестр") Тогда
			ЗаявкаВключенаВРеестр = бит_Казначейство.ЗаявкаВключенаВРеестр(Объект.ДокументПланирования);
		Иначе
			ЗаявкаВключенаВРеестр = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	УстановитьЗаголовокГруппыДанныеОбменаСБанком();	
	УстановитьСостояниеДокумента();
	УстановитьЗаголовокФормыДокумента();
	ПроверитьКорректностьЗаполненияПлатежаВБюджет();
	
	ЗаполнитьВалютуВзаиморасчетовДокумента();
	
	Элементы.ГруппаБюджетИВзаиморасчеты.Видимость = ВидимостьПанелиКонтроля();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЭтоРежимЗаявки()
	
	Перем РезультатПоиска;
	
	Если ЗначениеЗаполнено(Объект.ДокументПланирования) Тогда
		Если ТипЗнч(Объект.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
			РезультатПоиска = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(Объект.ДокументПланирования);
			Если РезультатПоиска.КоличествоПозиций = 0 Тогда
				ЭтоРежимЗаявки = Истина;
			Иначе	
				Если ЗначениеЗаполнено(Объект.Ссылка) И РезультатПоиска.КоличествоПозиций = 1 Тогда
					ЭтоРежимЗаявки = Истина;
				Иначе	
					ЭтоРежимЗаявки = Ложь;
				КонецЕсли;
			КонецЕсли;
		Иначе	
			ЭтоРежимЗаявки = Ложь;
		КонецЕсли;
	Иначе	
		ЭтоРежимЗаявки = Истина;	
	КонецЕсли;

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста 
Процедура УстановитьПараметрыВыбораВидаОперации(Форма)
	
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	НовыеПараметры = Новый Массив; 
	НовыеПараметры.Добавить(Новый ПараметрВыбора("Отбор.ФормаОплаты", Объект.ФормаОплаты));
	Если Объект.ДокументПланирования <> Неопределено Тогда
		НовыеПараметры.Добавить(Новый ПараметрВыбора("Отбор.ТипДокумента", ТипЗнч(Объект.ДокументПланирования)));
	КонецЕсли;
	
	Элементы.ХозяйственнаяОперация.ПараметрыВыбора = Новый ФиксированныйМассив(НовыеПараметры);
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаОповещенияИзмененияСтатуса()
	
	Прочитать();
	
КонецПроцедуры

&НаКлиенте
Функция ДоступныеПорядкиРасчетов()
	СписокПорядков = Новый СписокЗначений;
	СписокПорядков.Добавить(ПредопределенноеЗначение("Перечисление.ПорядокРасчетов.ПоЗаказам"));
	СписокПорядков.Добавить(ПредопределенноеЗначение("Перечисление.ПорядокРасчетов.ПоНакладным"));
	СписокПорядков.Добавить(ПредопределенноеЗначение("Перечисление.ПорядокРасчетов.ПоЗаказамНакладным"));
	СписокПорядков.Добавить(ПредопределенноеЗначение("Перечисление.ПорядокРасчетов.ПоДоговорамНакладным"));
	Если ХозОперацияУП = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВозвратОплатыКлиенту")
		ИЛИ ХозОперацияУП = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВозвратДенежныхСредствВДругуюОрганизацию") Тогда
		СписокПорядков.Добавить(ПредопределенноеЗначение("Перечисление.ПорядокРасчетов.ПоДоговорамКонтрагентов"));
	КонецЕсли;
	Возврат СписокПорядков;
КонецФункции

&НаСервереБезКонтекста
Функция НеУчитыватьСверхБюджета(Организация, ЦФО, Период)

	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("Организация", Организация);
	ПараметрыНастройки.Вставить("ЦФО",		   ЦФО);
								
	НеУчитыватьСверхБюджета = бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеЗаявкиПриКонтролеПоБюджету(ПараметрыНастройки, 
									Период);
	Возврат НеУчитыватьСверхБюджета;
	
КонецФункции

&НаСервере
Процедура ДатаПриИзмененииНаСервере()

	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.Организация, Объект.ЦФО, Объект.Дата);
	УправлениеФормой();	
	УстановитьЗаголовокФормыДокумента();
	
КонецПроцедуры

&НаСервере
Процедура ОрганизацияПриИзмененииНаСервере()
	
	ЗаполнитьСценарий("Организация");
	
	Если КонтролируемыеРеквизиты.Организация <> Объект.Организация Тогда
		Объект.БанковскийСчет = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
		Объект.Касса 		  = Справочники.Кассы.ПустаяСсылка();
		Объект.ОбъектРасчетов = Неопределено;
		Объект.Договор		  = Неопределено;
		
		ОбновитьКонтролируемыеРеквизиты("ОбъектРасчетов", ЭтотОбъект);
		ОбновитьКонтролируемыеРеквизиты("БанковскийСчет", ЭтотОбъект);
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		
		Если Объект.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
			
			ПараметрыПередачи = ДенежныеСредстваСервер.ПараметрыЗаполненияБанковскогоСчетаОрганизацииПоУмолчанию();
			ПараметрыПередачи.Организация    = Объект.Организация;
			ПараметрыПередачи.ФормаОплаты	 = Перечисления.ФормыОплаты.Безналичная;
			ПараметрыПередачи.БанковскийСчет = Объект.БанковскийСчет;
			
			Если Объект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
				ПараметрыПередачи.Валюта = Объект.ВалютаДокумента;
			КонецЕсли;
			Объект.БанковскийСчет = ЗначениеНастроекПовтИсп.ПолучитьБанковскийСчетОрганизацииПоУмолчанию(ПараметрыПередачи);
			ОбновитьКонтролируемыеРеквизиты("БанковскийСчет", ЭтотОбъект);
		Иначе	
			
			ПараметрыПередачи = ДенежныеСредстваСервер.ПараметрыЗаполненияКассыОрганизацииПоУмолчанию();
			ПараметрыПередачи.Организация = Объект.Организация;
			ПараметрыПередачи.ФормаОплаты = Перечисления.ФормыОплаты.Наличная;
			ПараметрыПередачи.Касса       = Объект.Касса;
			Если Объект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
				ПараметрыПередачи.Валюта = Объект.ВалютаДокумента;
			КонецЕсли;
			Объект.Касса = ЗначениеНастроекПовтИсп.ПолучитьКассуОрганизацииПоУмолчанию(ПараметрыПередачи);
		КонецЕсли;
	КонецЕсли;

	УстановитьПараметрыВыбораДоговораСЗаказчиком(Истина);
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		ЮрФизЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Организация, "ЮрФизЛицо", Истина);
	КонецЕсли;
	
	ЗаполнитьРеквизитыПлательщика();
	УстановитьНадписьРеквизитыПлательщика();
	
	ПроверитьИОчиститьОрганизациюПолучатель();
	УстановитьПараметрыВыбораОрганизацииПолучателя();
	УстановитьПараметрыВыбораБанковскийСчетПолучателя();

	ВзаиморасчетыСервер.ФормаПриИзмененииРеквизитов(ЭтотОбъект, "Организация");

	УстановитьПараметрыВыбораБанковскийСчетКасса();
		
	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.Организация, Объект.ЦФО, Объект.Дата);
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура ЦФОПриИзмененииНаСервере()

	ЗаполнитьСценарий("ЦФО");
	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.Организация, Объект.ЦФО, Объект.Дата);
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура СтатьяРасходовПриИзмененииНаСервере()
	
	Если ТипЗнч(Объект.СтатьяРасходов) = Тип("ПланВидовХарактеристикСсылка.СтатьиАктивовПассивов") Тогда
		ПриИзмененииСтатьиАктивовПассивов();
		Если ЗначениеЗаполнено(Объект.АналитикаРасходов) Тогда
			Объект.АналитикаРасходов = Неопределено;
		КонецЕсли;
	Иначе
		ПриИзмененииСтатьиРасходов();
		Если ЗначениеЗаполнено(Объект.АналитикаАктивовПассивов) Тогда
			Объект.АналитикаАктивовПассивов = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииСтатьиРасходов()
	
	РеквизитыСтатьи = Новый Структура("ТипЗначения", Новый ОписаниеТипов); 
	Если ЗначениеЗаполнено(Объект.СтатьяРасходов) Тогда
		РеквизитыСтатьи = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.СтатьяРасходов, "ТипЗначения")
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.АналитикаРасходов) Тогда
		Если ЗначениеЗаполнено(Объект.СтатьяРасходов) Тогда
			ОписаниеТипов 	  = РеквизитыСтатьи.ТипЗначения;
			ОчиститьАналитику = НЕ ОписаниеТипов.СодержитТип(ТипЗнч(Объект.АналитикаРасходов)); 
		Иначе
			ОчиститьАналитику = Истина;
		КонецЕсли;
		Если ОчиститьАналитику Тогда
			Объект.АналитикаРасходов = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.АналитикаРасходов) И ЗначениеЗаполнено(Объект.СтатьяРасходов) Тогда
		Объект.АналитикаРасходов = ДоходыИРасходыКлиентСервер.ПолучитьАналитикуПоУмолчанию(РеквизитыСтатьи, Объект);
	Иначе
		ОчиститьАналитикуПрочихРасходов(Объект.СтатьяРасходов, Объект.АналитикаРасходов);
	КонецЕсли;

КонецПроцедуры
 
&НаСервере
Процедура ОчиститьАналитикуПрочихРасходов(СтатьяРасходов, АналитикаРасходов)
	
	Если ТипЗнч(АналитикаРасходов) = Тип("СправочникСсылка.ПрочиеРасходы") Тогда
	
		Запрос = Новый Запрос("
		|ВЫБРАТЬ
		|	ИСТИНА КАК ОчиститьАналитику
		|ИЗ
		|	Справочник.ПрочиеРасходы КАК ДанныеСправочника
		|ГДЕ
		|	ДанныеСправочника.Ссылка = &АналитикаРасходов
		|	И ДанныеСправочника.Владелец <> &СтатьяРасходов
		|");
		Запрос.УстановитьПараметр("СтатьяРасходов", СтатьяРасходов);
		Запрос.УстановитьПараметр("АналитикаРасходов", АналитикаРасходов);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Если Выборка.ОчиститьАналитику Тогда
				АналитикаРасходов = Справочники.ПрочиеРасходы.ПустаяСсылка();
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииСтатьиАктивовПассивов()
	
	РеквизитыСтатьи = Новый Структура("ТипЗначения", Новый ОписаниеТипов); 
	Если ЗначениеЗаполнено(Объект.СтатьяРасходов) Тогда
		РеквизитыСтатьи = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.СтатьяРасходов, "ТипЗначения")
	КонецЕсли;

	Если ЗначениеЗаполнено(Объект.АналитикаАктивовПассивов) Тогда
		Если ЗначениеЗаполнено(Объект.СтатьяРасходов) Тогда
			ОписаниеТипов 	  = РеквизитыСтатьи.ТипЗначения;
			ОчиститьАналитику = НЕ ОписаниеТипов.СодержитТип(ТипЗнч(Объект.АналитикаАктивовПассивов)); 
		Иначе
			ОчиститьАналитику = Истина;
		КонецЕсли;
		Если ОчиститьАналитику Тогда
			Объект.АналитикаАктивовПассивов = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.АналитикаАктивовПассивов) И ЗначениеЗаполнено(Объект.СтатьяРасходов) Тогда
		Объект.АналитикаАктивовПассивов = ДоходыИРасходыКлиентСервер.ПолучитьАналитикуПоУмолчанию(РеквизитыСтатьи, Объект);
	Иначе
		ОчиститьАналитикуПрочихАктивовПассивов(Объект.СтатьяРасходов, Объект.АналитикаАктивовПассивов);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьАналитикуПрочихАктивовПассивов(СтатьяАктивовПассивов, АналитикаАктивовПассивов)
	
	Если ТипЗнч(АналитикаАктивовПассивов) = Тип("СправочникСсылка.ПрочиеАктивыПассивы") Тогда
	
		Запрос = Новый Запрос("
		|ВЫБРАТЬ
		|	ИСТИНА КАК ОчиститьАналитику
		|ИЗ
		|	Справочник.ПрочиеАктивыПассивы КАК ДанныеСправочника
		|ГДЕ
		|	ДанныеСправочника.Ссылка = &АналитикаАктивовПассивов
		|	И ДанныеСправочника.Владелец <> &СтатьяАктивовПассивов
		|");
		Запрос.УстановитьПараметр("СтатьяАктивовПассивов", СтатьяАктивовПассивов);
		Запрос.УстановитьПараметр("АналитикаАктивовПассивов", АналитикаАктивовПассивов);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Если Выборка.ОчиститьАналитику Тогда
				АналитикаАктивовПассивов = Справочники.ПрочиеАктивыПассивы.ПустаяСсылка();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПредложитьЗаписатьДокумент()

	Оповещение 	   = Новый ОписаниеОповещения("ПредложитьЗаписатьДокументЗавершение", ЭтотОбъект);
	ТекстСообщения = НСтр("ru='Для перехода в режим списка необходимо записать документ.';
							  |en='To go to the list mode you want to record the document.'");

	ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура ПредложитьЗаписатьДокументЗавершение(Результат, Дополнительно) Экспорт

	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;	
	
	Если ПроверитьЗаполнение() Тогда
		Попытка
			Записать();		
		Исключение
			ВызватьИсключение ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки; 
		ОткрытьФормуЗаявкиНаРасходованиеДС();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуЗаявкиНаРасходованиеДС()

	Если НЕ ЗначениеЗаполнено(Объект.ДокументПланирования) Тогда
		Возврат;
	КонецЕсли; 
	
	// Открываем заявку для возможности работы в списке позиций.
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Ключ" , Объект.ДокументПланирования);
	ПараметрыФормы.Вставить("Режим", "ОткрытиеСпискаПозиций");
	
	ОткрытьФорму("Документ.бит_кзн_ЗаявкаНаРасходованиеСредств.ФормаОбъекта", ПараметрыФормы);
	
	Закрыть();

КонецПроцедуры

&НаСервере
Процедура ОбъектРасчетовОбработкаВыбораНаСервере(ВыбранноеЗначение)
	
	ДополнитьВыбранноеЗначение(ВыбранноеЗначение);

	// Известные свойства.
	ИсключаяСвойства = Новый Массив;
	ИсключаяСвойства.Добавить("Дата");
	ИсключаяСвойства.Добавить("Номер");
	ИсключаяСвойства.Добавить("СтавкаНДС");
	ИсключаяСвойства.Добавить("СуммаНДС");
	
	Индекс = ИсключаяСвойства.ВГраница();
	Пока Индекс >= 0 Цикл
		Если НЕ ВыбранноеЗначение.Свойство(ИсключаяСвойства[Индекс]) Тогда
			ИсключаяСвойства.Удалить(Индекс);		
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	
	ЗаполнитьЗначенияСвойств(Объект, ВыбранноеЗначение, , СтрСоединить(ИсключаяСвойства, ","));
	
	//++ НЕ УТ
	Если ПоддержкаПлатежей275ФЗ И ВыбранноеЗначение.ПлатежиПо275ФЗ Тогда
		// ++ NB  ЗаполнитьПоДоговору(ВыбранноеЗначение.Договор);
	КонецЕсли;
	//-- НЕ УТ
	
	ОбновитьКонтролируемыеРеквизиты("ОбъектРасчетов", ЭтотОбъект);
	Модифицированность = Истина;
		
	ДоговорПриИзмененииНаСервере();
	
	ПараметрыОбъекта = ПараметрыУстановитьСтавкуНДС();
	ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект);
	ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, ЭтотОбъект);
	ПараметрыОбъекта.СтавкаНДСДоговора = ВыбранноеЗначение.СтавкаНДС;
	
	УстановитьСтавкуНДС(ПараметрыОбъекта);
	Объект.СтавкаНДС = ПараметрыОбъекта.СтавкаНДС;
	
	ВалютаДляСравнения = ВалютаПланированияДенежныхСредств();
	Если КонтролируемыеРеквизиты.ВалютаДокумента <> ВалютаДляСравнения Тогда
		Объект.ВалютаДокумента = ВалютаДляСравнения;
		ОбработатьИзмененииВалюты();
	Иначе
		ЗаполнитьКурсВзаиморасчетов();
		РассчитатьСуммуВзаиморасчетов();
		ЗаполнитьВалютуВзаиморасчетовДокумента();
	КонецЕсли;

	УстановитьПараметрыВыбораБанковскийСчетКасса();
	
	ПриИзмененииПоставляемыхРеквизитов(Объект.ОбъектРасчетов);
	
КонецПроцедуры

&НаСервере
Процедура ОбъектРасчетовПриИзмененииНаСервере()
	
	Если НЕ ЗначениеЗаполнено(Объект.ОбъектРасчетов) Тогда
		Объект.Договор = Неопределено;	
		ДоговорПриИзмененииНаСервере();
	КонецЕсли;
	
	ПриИзмененииПоставляемыхРеквизитов(Объект.ОбъектРасчетов);
	УправлениеФормой();

КонецПроцедуры

&НаСервере
Процедура ДополнитьВыбранноеЗначение(ВыбранноеЗначение)
	
	//++ НЕ УТ
	Если ЗначениеЗаполнено(ВыбранноеЗначение.Договор) Тогда
		ПлатежиПо275ФЗ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыбранноеЗначение.Договор, "ПлатежиПо275ФЗ");
	Иначе
		ПлатежиПо275ФЗ = Ложь;
	КонецЕсли;
	ВыбранноеЗначение.Вставить("ПлатежиПо275ФЗ", ПлатежиПо275ФЗ);
	//-- НЕ УТ
	
	ВыбранноеЗначение.Вставить("СтавкаНДС");
	ВыбранноеЗначение.Вставить("СуммаНДС");
	
	Если НЕ ОперацияБезНДС Тогда
		ОбъектыРасчетов = Новый Массив;
		ОбъектыРасчетов.Добавить(ВыбранноеЗначение.ОбъектРасчетов);
		
		ТаблицаНДС = ДенежныеСредстваСервер.РасшифровкаПлатежаНДС(Объект.Организация, Неопределено, 
		Неопределено, ОбъектыРасчетов, ВыбранноеЗначение.ЭтоРасчетыСКлиентами);
		Если ТаблицаНДС.Количество() = 1 Тогда
			ВыбранноеЗначение.Вставить("СтавкаНДС", ТаблицаНДС[0].СтавкаНДС);
			Если ВыбранноеЗначение.СуммаПлатежа = ВыбранноеЗначение.СуммаЗаказа Тогда
				ВыбранноеЗначение.Вставить("СуммаНДС", ТаблицаНДС[0].СуммаНДС);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение.ВалютаВзаиморасчетов) Тогда
		КурсВалюты = РаботаСКурсамиВалютУТ.ПолучитьКурсВалюты(ВыбранноеЗначение.ВалютаВзаиморасчетов, Неопределено, ВалютаРеглУчета);
		ВыбранноеЗначение.Вставить("КурсЧислительВзаиморасчетов", КурсВалюты.КурсЧислитель);
		ВыбранноеЗначение.Вставить("КурсЗнаменательВзаиморасчетов", КурсВалюты.КурсЗнаменатель);
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура БанковскийСчетПриИзмененииНаСервере()
	
	ПриИзмененииПоставляемыхРеквизитов(Объект.БанковскийСчет);
	ЗаполнитьРеквизитыПлательщика();
	УстановитьНадписьРеквизитыПлательщика();
	
	Объект.ВалютаДокумента = ВалютаПланированияДенежныхСредств();
	ОбработатьИзмененииВалюты();
	
	ПроверитьКорректностьЗаполненияПлатежаВБюджет();
	ЗаполнитьДанныеОбменаСБанком();
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура КассаПриИзмененииНаСервере()
	
	ПриИзмененииПоставляемыхРеквизитов(Объект.Касса);
	Объект.ВалютаДокумента = ВалютаПланированияДенежныхСредств();
	ОбработатьИзмененииВалюты();
	
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура ПеречислениеСотрудникуЧерезБанкПриИзмененииНаСервере()

	// См. ДенежныеСредстваСервер.ПеречислениеСотрудникуЧерезБанкПриИзмененииНаСервере(Объект, ЭтотОбъект);	
	Объект.ПеречислениеСотрудникуЧерезБанк = Булево(ПеречислениеСотрудникуЧерезБанк);
	УстановитьПараметрыВыбораБанковскийСчетПолучателя();
	
	Если НЕ Объект.ПеречислениеСотрудникуЧерезБанк Тогда
		
		Если ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствПодотчетнику
			ИЛИ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыдачаЗаймаСотруднику
			ИЛИ (ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыплатаЗарплаты
			И ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета) Тогда
			Объект.Контрагент = Справочники.Контрагенты.ПустаяСсылка();
		КонецЕсли;
		
		Объект.БанковскийСчетПолучателя = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьБанковскийСчетПоУмолчанию(Объект.ФизЛицо, Объект.ВалютаДокумента);
		
	Иначе
		Объект.БанковскийСчетПолучателя = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьБанковскийСчетПоУмолчанию(Объект.Контрагент, Объект.ВалютаДокумента);
	КонецЕсли;
	
	УправлениеФормой();

КонецПроцедуры

&НаСервере
Функция СчетСоответствуетВладельцу()
	
	Результат = Ложь;
	
	Если бит_КазначействоКлиентСервер.ЭтоРасчетыСФизЛицами(Объект.ХозяйственнаяОперация) Тогда
		Если Объект.ПеречислениеСотрудникуЧерезБанк Тогда
			Результат = Справочники.БанковскиеСчетаКонтрагентов.ПроверитьВладельцаБанковскогоСчета(
							Объект.БанковскийСчетПолучателя, Объект.Контрагент);
		Иначе
			Результат = Справочники.БанковскиеСчетаКонтрагентов.ПроверитьВладельцаБанковскогоСчета(
							Объект.БанковскийСчетПолучателя, Объект.ФизЛицо);
		КонецЕсли;
	Иначе	
		Результат = Справочники.БанковскиеСчетаКонтрагентов.ПроверитьВладельцаБанковскогоСчета(
			Объект.БанковскийСчетПолучателя, Объект.Контрагент);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ПараметрыФормыПриКопировании(ДокументПланирования)

	Возврат Документы.бит_кзн_ПлатежнаяПозиция.ПараметрыФормыПриКопировании(ДокументПланирования);

КонецФункции

&НаКлиенте
Процедура ОбработатьИзменениеПериодаРассчетов()
	
	ТекущаяДатаПлан = Объект.ДатаПлан;
	
	Если ЗначениеЗаполнено(Объект.ДатаПлан) Тогда		
		ПараметрыПроверки = бит_КазначействоКлиентСервер.НовыеПараметрыПериодЗаданКорректно();
		ПараметрыПроверки.ПоляОбъекта.ДатаНачала	= "Дата";
		ПараметрыПроверки.ПоляОбъекта.ДатаОкончания = "ДатаПлан";
		
		ПараметрыПроверки.ПоляФормы.ДатаНачала	  = НСтр("ru = 'Дата'; en = 'Date'");
		ПараметрыПроверки.ПоляФормы.ДатаОкончания = НСтр("ru = 'Дата платежа'; en = 'Payment Date'");
		
		ПериодЗаданКорректно = бит_КазначействоКлиентСервер.ПериодЗаданКорректно(Объект, ПараметрыПроверки);
		Если НЕ ПериодЗаданКорректно Тогда
			Объект.ДатаПлан = Объект.Дата;
		КонецЕсли;
	КонецЕсли;

	Если ЗначениеЗаполнено(Объект.ДатаПлан) И КонтролируемыеРеквизиты.ДатаПлан <> Объект.ДатаПлан Тогда
		ПараметрыПроверки = бит_КазначействоКлиентСервер.НовыеПараметрыПериодЗаданКорректно();
		ПараметрыПроверки.ПоляОбъекта.ДатаНачала	= "Дата";
		ПараметрыПроверки.ПоляОбъекта.ДатаОкончания = "ДатаПлан";
		
		ПараметрыПроверки.ПоляФормы.ДатаНачала	  = НСтр("ru = 'Дата'; en = 'Date'");
		ПараметрыПроверки.ПоляФормы.ДатаОкончания = НСтр("ru = 'Дата платежа'; en = 'Payment Date'");
		
		ПериодЗаданКорректно = бит_КазначействоКлиентСервер.ПериодЗаданКорректно(Объект, ПараметрыПроверки);
		Если НЕ ПериодЗаданКорректно Тогда
			Объект.ДатаПлан = Объект.Дата;
		КонецЕсли;

		Если ЗначениеЗаполнено(Объект.ДатаПланКрайняя) Тогда
			РазностьДат = бит_ОбщегоНазначенияКлиентСервер.РазностьДат(КонтролируемыеРеквизиты.ДатаПлан, Объект.ДатаПлан, "День");
			Объект.ДатаПланКрайняя = бит_ОбщегоНазначенияКлиентСервер.ПолучитьПериодПоСдвигу(
										КонтролируемыеРеквизиты.ДатаПланКрайняя, РазностьДат, "День");
			ОбновитьКонтролируемыеРеквизиты("ДатаПланКрайняя", ЭтотОбъект);							
		КонецЕсли;

		Если КонтролируемыеРеквизиты.ДатаПлан <> Объект.ДатаПлан Тогда
			УправлениеФормой();
		КонецЕсли;

		ОбновитьКонтролируемыеРеквизиты("ДатаПлан", ЭтотОбъект);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ДатаПланКрайняя) И КонтролируемыеРеквизиты.ДатаПланКрайняя <> Объект.ДатаПланКрайняя Тогда
		
		ПараметрыПроверки = бит_КазначействоКлиентСервер.НовыеПараметрыПериодЗаданКорректно();
		ПараметрыПроверки.ПоляОбъекта.ДатаНачала	= "ДатаПлан";
		ПараметрыПроверки.ПоляОбъекта.ДатаОкончания = "ДатаПланКрайняя";
		
		ПараметрыПроверки.ПоляФормы.ДатаНачала	  = НСтр("ru = 'Дата платежа'; en = 'Payment Date'");
		ПараметрыПроверки.ПоляФормы.ДатаОкончания = НСтр("ru = 'Не позднее'; en = 'on or before'");
		
		ПериодЗаданКорректно = бит_КазначействоКлиентСервер.ПериодЗаданКорректно(Объект, ПараметрыПроверки);
		Если НЕ ПериодЗаданКорректно Тогда
			Объект.ДатаПланКрайняя = КонтролируемыеРеквизиты.ДатаПланКрайняя;
		КонецЕсли;

		ОбновитьКонтролируемыеРеквизиты("ДатаПланКрайняя", ЭтотОбъект);
	КонецЕсли;	
	
	УстановитьПараметрыВыбораТипаНалогов();
	ПроверитьКорректностьЗаполненияПлатежаВБюджет();
	
	Если Объект.ДатаПлан <> ТекущаяДатаПлан Тогда
		ЗаполнитьКурсВзаиморасчетов();
		РассчитатьСуммуВзаиморасчетов();
		ЗаполнитьВалютуВзаиморасчетовДокумента();
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ОтображениеЗаголовкаПоляПодотчетноеЛицо()
	
	Если Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствПодотчетнику
		И Объект.ПеречислениеСотрудникуЧерезБанк
		И ПолучитьФункциональнуюОпцию("ИспользоватьПеречислениеДенежныхСредствСпискуСотрудников") Тогда
		Элементы.ФизЛицо.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	Иначе
		Элементы.ФизЛицо.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовокГруппыДанныеОбменаСБанком()

	ТекстЗаголовка = НСтр("ru = 'Договор обмена с банком № %1 от %2, отделение банка: %3, филиал: %4';
									|en = 'The contract of EDI with the bank No. %1 dated %2, bank branch: %3, branch office: %4'");
								
	ПредставлениеНомерДоговораСБанком = ?(Объект.НомерДоговораСБанком = "", "-", Объект.НомерДоговораСБанком);
	ПредставлениеДатаДоговораСБанком  = Формат(Объект.ДатаДоговораСБанком, "ДЛФ=D; ДП=-");
	ПредставлениеОтделениеБанка		  = ?(Объект.ОтделениеБанка = "", "-", Объект.ОтделениеБанка);
	ПредставлениеФилиалОтделенияБанка = ?(Объект.ФилиалОтделенияБанка = "", "-", Объект.ФилиалОтделенияБанка);

	ТекстЗаголовка = СтрШаблон(ТекстЗаголовка, ПредставлениеНомерДоговораСБанком, ПредставлениеДатаДоговораСБанком,
								ПредставлениеОтделениеБанка, ПредставлениеФилиалОтделенияБанка);
	
	Элементы.ГруппаРеквизитыОбменаСБанком.Заголовок = ТекстЗаголовка;

КонецПроцедуры

&НаСервере
Процедура РеквизитДоговораСБанкомПриИзмененииНаСервере()
	
	УстановитьЗаголовокГруппыДанныеОбменаСБанком();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеОбменаСБанком()

	Документы.бит_кзн_ПлатежнаяПозиция.ЗаполнитьДанныеОбменаСБанком(Объект);
	УстановитьЗаголовокГруппыДанныеОбменаСБанком();
	
КонецПроцедуры

&НаСервере
Процедура ДоговорАрендыПриИзмененииНаСервере()
	
	// См. Документ.СписаниеБезналичныхДенежныхСредств.Форма.ФормаДокумента: 
	// РасшифровкаПлатежаДоговорАрендыПриИзмененииСервер().
		
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	УсловияДоговоровАренды.СтавкаНДС КАК СтавкаНДС
	|ИЗ
	|	Справочник.ДоговорыАренды КАК ДоговорыАренды
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УсловияДоговоровАренды.СрезПоследних(, Договор = &ДоговорАренды) КАК УсловияДоговоровАренды
	|		ПО УсловияДоговоровАренды.Договор = &ДоговорАренды
	|ГДЕ
	|	ДоговорыАренды.Ссылка = &ДоговорАренды";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ДоговорАренды", Объект.ДоговорАренды);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Объект, Выборка);
	КонецЕсли;	
	
	Объект.ТипПлатежаПоАренде = Перечисления.ТипыПлатежейПоАренде.УслугаПоАренде;

	УстановитьПараметрыВыбораТипПлатежаПоАренде();
	
	РассчитатьСуммуНДС();
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьИОчиститьОрганизациюПолучатель()
		
	Если ЗначениеЗаполнено(Объект.Организация)
		И Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВнутренняяПередачаДенежныхСредств
		И НЕ Справочники.Организации.ОрганизацииВзаимосвязаныПоОрганизационнойСтруктуре(
			Объект.Организация, Объект.ОрганизацияПолучатель) Тогда
		Объект.ОрганизацияПолучатель 	= Неопределено;
		Объект.БанковскийСчетПолучатель = Неопределено;
		Объект.КассаПолучатель 			= Неопределено;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОрганизацияПолучательПриИзмененииНаСервере()

	Если ЗначениеЗаполнено(Объект.ОрганизацияПолучатель) Тогда
		Объект.БанковскийСчетПолучатель = Справочники.БанковскиеСчетаОрганизаций.ПолучитьБанковскийСчетОрганизацииПоУмолчанию(
											Объект.ОрганизацияПолучатель, Объект.ВалютаДокумента);
		УправлениеФормой();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораБанковскогоСчетаКассыПолучателя()

	ДанныеОбъекта = Новый Структура;
	ДанныеОбъекта.Вставить("ХозяйственнаяОперация", ХозОперацияУП);
	ДанныеОбъекта.Вставить("ОрганизацияПолучатель", Объект.ОрганизацияПолучатель);
	ДанныеОбъекта.Вставить("Организация", 			Объект.Организация);
	ДанныеОбъекта.Вставить("ПланированиеСуммы", 	Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов);

	ДенежныеСредстваСервер.УстановитьПараметрыВыбораБанковскогоСчетаКассыПолучателя(ДанныеОбъекта, Элементы.БанковскийСчетПолучатель);
	ДенежныеСредстваСервер.УстановитьПараметрыВыбораБанковскогоСчетаКассыПолучателя(ДанныеОбъекта, Элементы.КассаПолучатель);

КонецПроцедуры

&НаСервере
Процедура ОбработатьИзмененииВалюты()

	ИзмениласьВалюта = КонтролируемыеРеквизиты.ВалютаДокумента <> Объект.ВалютаДокумента;
	Если НЕ ИзмениласьВалюта Тогда
		Возврат;	
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Объект.ВалютаДокумента) Тогда
		Если Объект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов Тогда
			Объект.ВалютаВзаиморасчетов			 = Объект.ВалютаДокумента;
			Объект.КурсЧислительВзаиморасчетов 	 = 1;
			Объект.КурсЗнаменательВзаиморасчетов = 1;
			Объект.СуммаДокумента 				 = Объект.СуммаВзаиморасчетов;
		Иначе
			Если НЕ ЗначениеЗаполнено(Объект.ОбъектРасчетов) И НЕ ЗначениеЗаполнено(Объект.Договор) Тогда
				Объект.ВалютаВзаиморасчетов			 = Объект.ВалютаДокумента;
				Объект.КурсЧислительВзаиморасчетов	 = 1;
				Объект.КурсЗнаменательВзаиморасчетов = 1;
				Объект.СуммаДокумента				 = Объект.СуммаВзаиморасчетов;
			Иначе	
				РасшифровкаПлатежа.Очистить();
				НоваяСтрока = РасшифровкаПлатежа.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Объект);
				НоваяСтрока.Сумма = Объект.СуммаДокумента;
				
				Контекст = Новый Структура;
				Контекст.Вставить("РасшифровкаПлатежа", РасшифровкаПлатежа);
				Контекст.Вставить("СуммаДокумента", 	Объект.СуммаДокумента);
				Контекст.Вставить("Дата",				Объект.ДатаПлан);
				
				ДенежныеСредстваСервер.ПересчетСуммДокументаВВалюту(Контекст, КонтролируемыеРеквизиты.ВалютаДокумента, 
					Объект.ВалютаДокумента);
					
				Объект.СуммаДокумента = Контекст.СуммаДокумента;
				
				ЗаполнитьКурсВзаиморасчетов();
				ЗаполнитьКурсКратностьТекстом();
				ЗаполнитьВалютуВзаиморасчетовДокумента();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ОбработатьИзмененииСуммыДокумента(Истина);
	
	ОбновитьКонтролируемыеРеквизиты("ВалютаДокумента", ЭтотОбъект);
	УстановитьПараметрыВыбораБанковскийСчетКасса();
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьИзмененииСуммыДокумента(ИзмененаВалюта = Ложь)
	
	Если НЕ ОперацияБезНДС Тогда
		РассчитатьСуммуНДС();
	КонецЕсли;
	
	Если НЕ ИзмененаВалюта Тогда
		ЗаполнитьКурсВзаиморасчетов();
		РассчитатьСуммуВзаиморасчетов();
		ЗаполнитьВалютуВзаиморасчетовДокумента();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКурсВзаиморасчетов(ТолькоДанныеФормы = Ложь)

	ПараметрыЗаполнения = ДенежныеСредстваСервер.ПараметрыЗаполненияКурсаИКратности();

	ПараметрыЗаполнения.Валюта 				 = Объект.ВалютаДокумента;
	ПараметрыЗаполнения.Договор				 = Объект.Договор;
	ПараметрыЗаполнения.ВалютаВзаиморасчетов = Объект.ВалютаВзаиморасчетов;
	
	ПараметрыЗаполнения.ВалютаРегламентированногоУчета = ВалютаРеглУчета;
	ПараметрыЗаполнения.Дата						   = Объект.ДатаПлан;
	
	Данные = Новый Структура;
	Данные.Вставить("КурсЧислительВзаиморасчетов",  0);
	Данные.Вставить("КурсЗнаменательВзаиморасчетов",0);
	Данные.Вставить("ВариантКурсаДоговора", 		Перечисления.ВариантыКурсаДоговора.ПустаяСсылка());
	Данные.Вставить("ТипОбъектаРасчетов", 			Перечисления.ТипыОбъектовРасчетов.ПустаяСсылка());
	
	ЗаполнитьЗначенияСвойств(Данные, Объект);
	ЗаполнитьЗначенияСвойств(Данные, ЭтотОбъект);
	
	ДенежныеСредстваСервер.ЗаполнитьКурсИКратностьВСтрокеРасшифровки(Данные, ПараметрыЗаполнения);
	
	Если ТолькоДанныеФормы Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Данные, "ВариантКурсаДоговора");
	Иначе	
		ЗаполнитьЗначенияСвойств(Объект, Данные);
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Данные);
	КонецЕсли;
	
КонецПроцедуры

