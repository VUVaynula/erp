	бит_МеханизмДопИзмеренийКлиент.ВыбратьТипСоставнойАналитики(ЭтотОбъект,
			Элемент, Объект, Элемент.Имя, СтандартнаяОбработка, КэшЗначений.НастройкиИзмерений);
			
	ТипДоговора = ТипЗнч(Объект[Элемент.Имя]); 
	Если ЗначениеЗаполнено(Текст) 
		И (ТипДоговора = Тип("СправочникСсылка.ДоговорыКонтрагентов")
		ИЛИ (бит_ОбщегоНазначенияКлиентСерверПереопределяемый.ЕстьДоговорыАренды()
			 И ТипДоговора = Тип("СправочникСсылка.ДоговорыАренды"))
		ИЛИ ТипДоговора = Тип("СправочникСсылка.ДоговорыКредитовИДепозитов")) Тогда
		
		СтандартнаяОбработка = Ложь;
		Отбор = Новый Структура("Организация, Контрагент", Объект.Организация, Объект.Контрагент);
		АналитикаПолучениеДанныхВыбора(ДанныеВыбора, Текст, Отбор, ТипДоговора);
		
	КонецЕсли;
															   															   
