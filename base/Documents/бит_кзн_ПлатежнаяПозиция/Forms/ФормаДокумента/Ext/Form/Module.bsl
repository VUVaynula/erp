	Данные.Вставить("КурсЧислительВзаиморасчетов",	 Объект.КурсЧислительВзаиморасчетов);
	Данные.Вставить("КурсЗнаменательВзаиморасчетов", Объект.КурсЗнаменательВзаиморасчетов);
	Данные.Вставить("СуммаВзаиморасчетов",			 Объект.СуммаВзаиморасчетов);
	
	ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
			Данные, Объект.ВалютаДокумента, ВалютаРеглУчета);
			
	Объект.СуммаВзаиморасчетов = Данные.СуммаВзаиморасчетов; 		
		
КонецПроцедуры
		
