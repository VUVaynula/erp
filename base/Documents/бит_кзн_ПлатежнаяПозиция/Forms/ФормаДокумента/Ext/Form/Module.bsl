&НаСервере
Процедура УстановитьПараметрыВыбораДоговораСЗаказчиком(СброситьЗначение = Ложь)
	
	Если НЕ Объект.ПлатежиПо275ФЗ Тогда
		Возврат;	
	КонецЕсли;
	
	НаборПараметров = Новый Массив;

	Если ХозОперацияУП = Перечисления.ХозяйственныеОперации.ОплатаПоКредитам
	 ИЛИ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ПеречислениеНаДепозиты
	 ИЛИ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыдачаЗаймов Тогда
		
		Если СброситьЗначение Тогда
			Объект.ДоговорКредитаДепозита = Справочники.ДоговорыКредитовИДепозитов.ПустаяСсылка();
		КонецЕсли;
		
		Если НЕ Объект.Организация.Пустая() Тогда
			НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.Организация", Объект.Организация));
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.ФормаОплаты) Тогда
			Если Объект.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
				НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.ФормаОплаты", Перечисления.ФормыОплаты.Безналичная));
			ИначеЕсли Объект.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Наличные Тогда	
				НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.ФормаОплаты", Перечисления.ФормыОплаты.Наличная));
			КонецЕсли;
		КонецЕсли;
		НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.Статус", Перечисления.СтатусыДоговоровКонтрагентов.Действует));
		НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.ХарактерДоговора",
		Справочники.ДоговорыКредитовИДепозитов.ХарактерДоговораПоОперации(ХозОперацияУП)));
		НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.ПометкаУдаления",Ложь));
		
		Если НЕ Объект.Контрагент.Пустая() Тогда
			НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.Контрагент", Объект.Контрагент));
		КонецЕсли;
		НовыеПараметрыВыбора = Новый ФиксированныйМассив(НаборПараметров);
		Элементы.ДоговорКредитаДепозита.ПараметрыВыбора = НовыеПараметрыВыбора;
	КонецЕсли;
	
	Если СброситьЗначение Тогда
		Объект.ДоговорСЗаказчиком = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	
	Если НЕ Объект.Организация.Пустая() Тогда
		НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.Организация", Объект.Организация));
	КонецЕсли;
	
	НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.Статус", Перечисления.СтатусыДоговоровКонтрагентов.Действует));
	НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.ДоговорСУчастникомГОЗ",Истина));
	НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.ПометкаУдаления",Ложь));
	
	Если НЕ Объект.Контрагент.Пустая() Тогда
		НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.Контрагент", Объект.Контрагент));
	КонецЕсли;
	НовыеПараметрыВыбора = Новый ФиксированныйМассив(НаборПараметров);
	
	Элементы.ДоговорСЗаказчиком.ПараметрыВыбора = НовыеПараметрыВыбора;
		
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораСтатьиРасходов()

	НаборПараметров = Новый Массив;
	НаборПараметров.Добавить(Новый ПараметрВыбора("Отбор.ХозяйственнаяОперация", Перечисления.ХозяйственныеОперации.ПрочаяВыдачаДенежныхСредств));
	НаборПараметров.Добавить(Новый ПараметрВыбора("ДополнитьСтатьямиРасходов", Истина));
	НаборПараметров.Добавить(Новый ПараметрВыбора("ДополнитьСтатьямиДоходов", Ложь));
	НаборПараметров.Добавить(Новый ПараметрВыбора("ДополнитьСтатьямиАктивовПассивов", Истина));
	
	Элементы.СтатьяРасходов.ПараметрыВыбора = Новый ФиксированныйМассив(НаборПараметров);

КонецПроцедуры
 
&НаКлиенте
Процедура ОбновитьСписокВладельцевПодтверждающихДокументов()
	
	ОбъектОбъектаРасчетов = Неопределено;
	
	ВладельцыПодтверждающихДокументов.Очистить();

	Если ЗначениеЗаполнено(Объект.ОбъектРасчетов) Тогда
		ОбъектОбъектаРасчетов = ОбъектОбъектаРасчетов(Объект.ОбъектРасчетов);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ДоговорКредитаДепозита) Тогда
		ВладельцыПодтверждающихДокументов.Добавить(Объект.ДоговорКредитаДепозита);
	Иначе 	
		Если (ТипЗнч(ОбъектОбъектаРасчетов) = Тип("СправочникСсылка.ДоговорыКонтрагентов")
		  ИЛИ ТипЗнч(ОбъектОбъектаРасчетов) = Тип("СправочникСсылка.ДоговорыМеждуОрганизациями")) Тогда
			
			ВладельцыПодтверждающихДокументов.Добавить(ОбъектОбъектаРасчетов);
			
		ИначеЕсли ЗначениеЗаполнено(Объект.Договор) Тогда
			ВладельцыПодтверждающихДокументов.Добавить(Объект.Договор);
		КонецЕсли;
	КонецЕсли;
	
	Если Объект.ТипПлатежаФЗ275 = ПредопределенноеЗначение("Справочник.ТипыПлатежейФЗ275.ПеречислениеПрибылиГоловномуИсполнителю")
	 ИЛИ Объект.ТипПлатежаФЗ275 = ПредопределенноеЗначение("Справочник.ТипыПлатежейФЗ275.ПеречисленияПрибылиИсполнителю")
	 ИЛИ Объект.ТипПлатежаФЗ275 = ПредопределенноеЗначение("Справочник.ТипыПлатежейФЗ275.СписаниеНаВозмещениеЗатратЗаСчетСобственныхСредств") Тогда
		
		Если ЗначениеЗаполнено(Объект.ДоговорСЗаказчиком) Тогда
			ВладельцыПодтверждающихДокументов.Добавить(Объект.ДоговорСЗаказчиком);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

