&НаСервере
Процедура УстановитьСчетУчетаНалогов()
	
	//++ НЕ УТ 
	СчетУчетДоИзменения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.НастройкаСчетовУчета, "СчетУчета");
	СчетПоТипуНалога 	= РеглУчетСервер.СчетУчетаПоТипуНалога(Объект.ТипНалога);
	
	Если СчетУчетДоИзменения <> СчетПоТипуНалога Тогда
		НоваяНастройка = НастройкаСчетовУчетаКлиентСервер.СоставНастройкиСчетовУчета();
		НоваяНастройка.СчетУчета = СчетПоТипуНалога;
		Объект.НастройкаСчетовУчета = НастройкаСчетовУчетаСервер.НоваяНастройкаСчетовУчета(
			НоваяНастройка, ЭтотОбъект);
	КонецЕсли;
	//-- НЕ УТ
	
КонецПроцедуры

&НаСервере
Процедура ПеречислениеВБюджетПриИзмененииСервер()
	
	Если Объект.ПеречислениеВБюджет Тогда
		
		МассивОпераций = ДенежныеСредстваСерверЛокализация.МассивОперацийПеречисленияВБюджет();
		
		Если ХозОперацияУП = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет Тогда
			Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.НалоговыйПлатеж;
		ИначеЕсли ХозОперацияУП = Перечисления.ХозяйственныеОперации.ПеречислениеТаможне Тогда
			Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.ТаможенныйПлатеж;
		ИначеЕсли МассивОпераций.Найти(ХозОперацияУП) <> Неопределено Тогда
			Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.ИнойПлатеж;
		КонецЕсли;
		УстановитьЗначенияПоказателейПлатежаВБюджетПоВиду();
		
		Если ПустаяСтрока(Объект.КодОКАТО) Тогда
			Реквизиты = Справочники.Организации.ПолучитьРеквизитыОрганизации(Объект.Организация);
			Если ПрименениеПриказа107н Тогда
				Объект.КодОКАТО = Реквизиты.КодПоОКТМО;
			Иначе
				Объект.КодОКАТО = Реквизиты.КодПоОКАТО;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	УправлениеПоказателямиПлатежаВБюджет();
	
КонецПроцедуры

&НаСервере
Процедура НДФЛПоВедомостямПриИзмененииСервер()
	
	Если Объект.НДФЛПоВедомостям Тогда
		Объект.ТипНалога = Справочники.ВидыНалоговВзносов.НДФЛ;
	КонецЕсли;
	
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗначенияПоказателейПлатежаВБюджетПоВиду()
	
	Если Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.НалоговыйПлатеж Тогда
		
		Объект.СтатусСоставителя 	= "01";
		Объект.ПоказательОснования 	= "";
		Объект.ПоказательПериода 	= "";
		Объект.ПоказательТипа 		= "";
		
	ИначеЕсли Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.ТаможенныйПлатеж Тогда
		
		Объект.СтатусСоставителя 	= "06";
		Объект.ПоказательОснования 	= "";
		Объект.ПоказательПериода 	= "";
		Объект.ПоказательТипа 		= "";
		
	ИначеЕсли Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.ИнойПлатеж Тогда
		
		Объект.СтатусСоставителя 	= "08";
		Объект.ПоказательОснования 	= "0";
		Объект.ПоказательПериода 	= "0";
		Объект.ПоказательНомера 	= "0";
		Объект.ПоказательДаты 		= "0";
		Объект.ПоказательТипа 		= ?(ПрименениеПриказа126н, "", "0");
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УправлениеПоказателямиПлатежаВБюджет()
	
	// См. СписаниеБезналичныхДенежныхСредствЛокализация.ЗаполнитьНастройкиПолейФормы().
	
	ЭтоПеречислениеНалога = (ХозОперацияУП = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет);
	ОплатаЧерезБанк 	  = (Объект.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные);
	
	ОперацииПеречисленияВБюджет = ДенежныеСредстваСерверЛокализация.МассивОперацийПеречисленияВБюджет();

	Элементы.ЗаполнитьПоПредыдущемуПлатежу.Видимость 	= ЭтоПеречислениеНалога;
	Элементы.ТипНалога.Видимость 					 	= ЭтоПеречислениеНалога;
	
	// Перечисление в бюджет.
	ВидимостьПеречислениеВБюджет = ОплатаЧерезБанк И ОперацииПеречисленияВБюджет.Найти(ХозОперацияУП) <> Неопределено;
	Элементы.ПеречислениеВБюджет.Видимость = ВидимостьПеречислениеВБюджет;
	
	// Идентификатор платежа.
	Если ВидимостьПеречислениеВБюджет Тогда		
		Если Объект.ПеречислениеВБюджет Тогда
			Элементы.ИдентификаторПлатежа.Заголовок = НСтр("ru='УИН';en='UIN'");
			Элементы.ИдентификаторПлатежа.Подсказка = НСтр("ru='Уникальный идентификатор начисления указывается, если предоставлен получателем (администратором) платежа.';
														   |en='The unique charging identifier indicated if provided by the recipient (administrator) payment.'");
		Иначе
			Элементы.ИдентификаторПлатежа.Заголовок = НСтр("ru='УИП';en='UIP'");
			Элементы.ИдентификаторПлатежа.Подсказка = НСтр("ru='Уникальный идентификатор платежа указывается, если это предусмотрено договором с получателем платежа.';
														   |en='Unique identifier of payment is specified, if it is stipulated in the contract with the beneficiary.'");
		КонецЕсли;
	КонецЕсли;
	Элементы.ИдентификаторПлатежа.Видимость = ОплатаЧерезБанк;
	
	// Надпись "Реквизиты платежа в бюджет".
	Элементы.НадписьРеквизитыПлатежаВБюджет.Видимость = ВидимостьПеречислениеВБюджет И Объект.ПеречислениеВБюджет;
	Если Элементы.НадписьРеквизитыПлатежаВБюджет.Видимость Тогда
		ПлатежиВБюджет.УстановитьНадписьРеквизитовПлатежаВБюджет(ЭтотОбъект);
		ПроверитьРеквизитыБюджетаНаСервере();
	КонецЕсли;
	
	Элементы.ВидПлатежа.Видимость 		  = ОплатаЧерезБанк;
	Элементы.ОчередностьПлатежа.Видимость = ОплатаЧерезБанк;
	
	// Код вида дохода.	
	ТекущаяДата		  = ?(ЗначениеЗаполнено(Объект.ДатаПлан), Объект.ДатаПлан, Объект.Дата);
	ВозможноВзыскание = ВозможноВзысканиеСПеречисленияФизлицу(ТекущаяДата, ХозОперацияУП, Неопределено);
	
	Элементы.КодВидаДохода.Видимость = ОплатаЧерезБанк;
	
	// Код выплат.
	Элементы.КодВыплат.Видимость = ОплатаЧерезБанк;
	
	Если Объект.ПеречислениеВБюджет Тогда
		// Оставим информацию об КБК и ОКТМО.
		РеквизитыПлатежа = СтрРазделить(НадписьРеквизитыПлатежаВБюджет,";");
		Если РеквизитыПлатежа.Количество() <> 0 Тогда
			Индекс = РеквизитыПлатежа.ВГраница();
			Пока Индекс > 1 Цикл
				РеквизитыПлатежа.Удалить(Индекс);
				Индекс = Индекс - 1;
			КонецЦикла;
			ТекстСообщения = СтрСоединить(РеквизитыПлатежа, ";"); 
			ТекстСообщения = НСтр("ru='Перечисление в бюджет: ';en='Transfer to the budget:'") + ТекстСообщения;
		Иначе
			ТекстСообщения = НСтр("ru='Перечисление в бюджет';en='Taxes and Dues Transfer'");
		КонецЕсли; 
	Иначе	
		ТекстСообщения = НСтр("ru='Перечисление в бюджет';en='Taxes and Dues Transfer'");
	КонецЕсли;
	
	УстановитьЗаголовокГруппы(ЭтотОбъект, "ГруппаНалоги", ТекстСообщения);
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьРеквизитыБюджетаНаСервере()
	
	НомерСчетаКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.БанковскийСчетПолучателя, "НомерСчета");
	Ошибка = ПлатежиВБюджетКлиентСервер.ПроверитьУИН(Объект.ИдентификаторПлатежа,
		ПлатежиВБюджетКлиентСервер.АдминистраторНачисленияФедеральныйОрганГосударственнойВласти(НомерСчетаКонтрагента));
		
	Если Не ПустаяСтрока(Ошибка) Тогда
		ШаблонТекста = НСтр("ru='%1 
								|Если УИН достоверно не известен, не указывайте его (очистите поле).';
							|en='%1
								|If UIN not reliably known, do not enter it (clear field).'");
		Ошибка = СтрШаблон(ШаблонТекста, Ошибка);
		ОбщегоНазначения.СообщитьПользователю(Ошибка, , "ИдентификаторПлатежа", "Объект");
	КонецЕсли;
	
	// Проверяем дубли УИН.
	ДублиУИН = Документы.бит_кзн_ПлатежнаяПозиция.ПроверитьДублиУИН(Объект.ИдентификаторПлатежа, Объект.Ссылка);
	
	Если ДублиУИН.Количество() > 0 Тогда
		// Информацию о дублях УИН выводим отдельно.
		Для Каждого ОписаниеОшибки Из ДублиУИН Цикл
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки.ТекстОшибки,, 
				"ИдентификаторПлатежа", "Объект");
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоРанееСовершенномуПлатежу(РезультатВыбора)
	
	Объект.ПеречислениеВБюджет = Истина;
	
	Если Не ЗначениеЗаполнено(Объект.ТипНалога) Тогда
		Объект.ТипНалога = РезультатВыбора.АналитикаАктивовПассивов;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Объект, РезультатВыбора,, "БанковскийСчет");
	
	//++ НЕ УТ
	Если Не ОплатаНДСВБюджетПоОтдельнымОперациям Тогда
		НоваяНастройка = НастройкаСчетовУчетаКлиентСервер.СоставНастройкиСчетовУчета();
		ЗаполнитьЗначенияСвойств(НоваяНастройка, РезультатВыбора, "СчетУчета, Субконто1, Субконто2, Субконто3");
		Объект.НастройкаСчетовУчета = НастройкаСчетовУчетаСервер.НоваяНастройкаСчетовУчета(НоваяНастройка, ЭтотОбъект);
										НастроитьСчетаУчета();
										
		ПараметрыНастройки = Документы.бит_кзн_ПлатежнаяПозиция.ПараметрыНастройкиСчетовУчета(
							Объект.ХозяйственнаяОперация, Объект.ТипНалога);
		НастройкаСчетовУчетаСервер.ПриИзмененииПараметровНастройки(ЭтотОбъект, ПараметрыНастройки);
	КонецЕсли;
	//-- НЕ УТ
	
	УправлениеПоказателямиПлатежаВБюджет();
	УстановитьНадписьРеквизитыПлательщика();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоказателиПлатежаВБюджетПоУмолчаниюСервер(МожноИзменятьПеречислениеВБюджет)
	
	Если МожноИзменятьПеречислениеВБюджет Тогда
		
		ОперацийПеречисленияВБюджет = ДенежныеСредстваСерверЛокализация.МассивОперацийПеречисленияВБюджет();
		
		Если ХозОперацияУП = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет Тогда
			
			Объект.ПеречислениеВБюджет = Истина;
			Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.НалоговыйПлатеж;
			
			Периодичность = "МС";
			НомерПериода = Месяц(ТекущаяДата);
			ГодПериода = Год(ТекущаяДата);
			Объект.ПоказательПериода = Периодичность
						+ "." 
						+ ?(СтрДлина(СокрЛП(НомерПериода)) = 1, "0" + НомерПериода, НомерПериода)
						+ "." 
						+ СтрЗаменить(Строка(ГодПериода), Символы.НПП, "");
					
		ИначеЕсли ХозОперацияУП = Перечисления.ХозяйственныеОперации.ПеречислениеТаможне Тогда
			
			Объект.ПеречислениеВБюджет = Истина;
			Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.ТаможенныйПлатеж;
			Объект.ПоказательПериода = "";
			
		ИначеЕсли ОперацийПеречисленияВБюджет.Найти(ХозОперацияУП) <> Неопределено Тогда
			
			Объект.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.ИнойПлатеж;
			Объект.ПеречислениеВБюджет    = Ложь;
			
		Иначе
			Объект.ПеречислениеВБюджет = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	УстановитьЗначенияПоказателейПлатежаВБюджетПоВиду();
	
КонецПроцедуры

&НаСервере 
Процедура БанковскийСчетПолучателяПриИзмененииСервер()
	
	УстановитьПараметрыВыбораДоговораСЗаказчиком(Истина);
	Если Объект.ПлатежиПо275ФЗ Тогда
		ПроверитьЗаполнитьТипПлатежа275ФЗ();
		УправлениеЭлементамиОплатыЗасчетСредствГОЗ();
	КонецЕсли;
	ПриИзмененииПоставляемыхРеквизитов(Объект.БанковскийСчетПолучателя);
	
КонецПроцедуры
 
&НаСервере
Процедура ПроверитьЗаполнитьТипПлатежа275ФЗ()
	
	Если Не ЗначениеЗаполнено(Объект.ТипПлатежаФЗ275) Тогда
		ПараметрыПлатежа = Новый Структура;
		ПараметрыПлатежа.Вставить("ПлатежиПо275ФЗ", Объект.ПлатежиПо275ФЗ);
		ПараметрыПлатежа.Вставить("ХозяйственнаяОперация", ХозОперацияУП);
		ПараметрыПлатежа.Вставить("ДоговорСУчастникомГОЗ", Объект.ДоговорСУчастникомГОЗ);
		ПараметрыПлатежа.Вставить("ОплатаРасходовПоТарифамСГосрегулированием", ОплатаРасходовПоТарифамСГосрегулированием);
		ПараметрыПлатежа.Вставить("ИностранныйИсполнительВУтвержденномПеречнеГОЗ", ИностранныйИсполнительВУтвержденномПеречнеГОЗ);
		ПараметрыПлатежа.Вставить("БанковскийСчет", Объект.БанковскийСчетПолучателя);
	
		ДоступныеТипыПлатежа275ФЗ = Справочники.ТипыПлатежейФЗ275.ДоступныеТипыПлатежа275ФЗ(ПараметрыПлатежа);
		Если ДоступныеТипыПлатежа275ФЗ.Количество() Тогда
			Объект.ТипПлатежаФЗ275 = ДоступныеТипыПлатежа275ФЗ[0];
			ЗаполнитьПодтверждающиеДокументыНаСервере();
		Иначе
			Объект.ТипПлатежаФЗ275 = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область КонтрольБюджетаИВзаиморасчетов

&НаКлиенте
Процедура ОтобразитьБюджетСПаузой()
	
	ОтключитьОбработчикОжидания("ОтобразитьБюжет");
	ПодключитьОбработчикОжидания("ОтобразитьБюжет", 0.5, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьБюжет()
	
	Если НЕ ОтображатьБюджет Тогда
		Возврат;
	КонецЕсли;
	
	ОтобразитьБюджетНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьБюджетНаСервере()
	
	ВыводитьСведенияОЛимитах = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
								"ВыводитьСведенияОЛимитахДляЗаявки");
	ВывестиСведенияОЛимитах(ВыводитьСведенияОЛимитах);
	
	ВыводитьСведенияОВзаиморасчетах = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
										"ВыводитьСведенияОВзаиморасчетахДляЗаявки");
	ВывестиСведенияОВзаиморасчетах(ВыводитьСведенияОВзаиморасчетах);
	
	Если НЕ ВыводитьСведенияОЛимитах И НЕ ВыводитьСведенияОВзаиморасчетах Тогда
		ТекстСообщения = НСтр("ru='Вывод сведений о лимитах и взаиморасчетах отключен в настройках пользователя'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		ОтображатьБюджет = Ложь;
		Если ОтображатьБюджетПриОткрытии Тогда
			УстановитьОтображениеБюджетаПриОткрытии(ЭтотОбъект, Ложь);	
		КонецЕсли;
		УправлениеФормой();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиСведенияОЛимитах(ВыводитьСведенияОЛимитах)
	
	Если НЕ ВыводитьСведенияОЛимитах Тогда
		Элементы.ГруппаБюджет.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Если НЕ ПроверитьВозможностьРасчетаБюджета() Тогда
		Элементы.ДекорацияОшибкаРасчетаБюджета.Видимость = Истина;
		Элементы.ГруппаБюджетШапка.Видимость             = Ложь;
		Элементы.ГруппаБюджетОсновнойРаздел.Видимость    = Ложь;
		Возврат;
	Иначе
		Элементы.ДекорацияОшибкаРасчетаБюджета.Видимость = Ложь;
		Элементы.ГруппаБюджетШапка.Видимость             = Истина;
		Элементы.ГруппаБюджетОсновнойРаздел.Видимость    = Истина;
	КонецЕсли;
	
	Если НЕ Модифицированность
		И НЕ Объект.Ссылка.Пустая() Тогда
		ПараметрыРасчетаБюджета = Документы.бит_кзн_ПлатежнаяПозиция.ПодготовитьПараметрыПроведения(Объект.Ссылка, Ложь);
	Иначе
		ПараметрыРасчетаБюджета = Документы.бит_кзн_ПлатежнаяПозиция.ПодготовитьПараметрыПроведения(
									РеквизитФормыВЗначение("Объект"), Ложь);
	КонецЕсли;
	
	СтрокаОстатка   = Неопределено;
	ПериодыКонтроля = Новый Массив;
	Если ПараметрыРасчетаБюджета.ИсполнениеБюджета.Количество() > 0 Тогда
		СтрокаИсполнения           = ПараметрыРасчетаБюджета.ИсполнениеБюджета[0];
		БюджетСуммаЗаявкиПоСтатье  = СтрокаИсполнения.Сумма;
		
		ИсполнениеБюджетаПоСтатье  = ПараметрыРасчетаБюджета.ИсполнениеБюджета.СкопироватьКолонки();
		ЗаполнитьЗначенияСвойств(ИсполнениеБюджетаПоСтатье.Добавить(), СтрокаИсполнения);
		
		ИнформацияОбОстатках       = бит_КонтрольИсполненияБюджета.ПрогнозИсполненияБюджета(
										ИсполнениеБюджетаПоСтатье,
										ПараметрыРасчетаБюджета.ИсполнениеБюджетаРеквизиты);
		ПериодыКонтроля            = ИнформацияОбОстатках.ПериодыКонтроля;
		ОстаткиКонтрольныхЗначений = ИнформацияОбОстатках.ОстаткиКонтрольныхЗначений;
		Если ОстаткиКонтрольныхЗначений.Количество() > 0 Тогда
			СтрокаОстатка = ОстаткиКонтрольныхЗначений[0];
		КонецЕсли;
	КонецЕсли;
	
	НачалоПериодаКонтроля    = Неопределено;
	ОкончаниеПериодаКонтроля = Неопределено;
	
	Если СтрокаОстатка <> Неопределено Тогда 
		СтрокаОстатка                = ОстаткиКонтрольныхЗначений[0];
		БюджетСуммаБюджетаБезЗаявки  = Макс(СтрокаОстатка.Сумма, 0);
		БюджетСуммаБюджетаПоСтатье   = Макс(СтрокаОстатка.СуммаКонтроль, 0);
		БюджетСуммаИсполненныхЗаявок = Макс(СтрокаОстатка.СуммаИсполнение, 0);
		БюджетСуммаСверхЛимита       = Макс(СтрокаОстатка.СуммаСверхЛимита, 0);
		
		ПрогнозИсполненияБюджета = ИнформацияОбОстатках.ПрогнозИсполненияБюджета;
		Если ПрогнозИсполненияБюджета.Количество() > 0 Тогда  
			БюджетОстатокБюджетаПоСтатье = Макс(ПрогнозИсполненияБюджета[0].СуммаКонОстаток, 0);
		Иначе
			БюджетОстатокБюджетаПоСтатье = Макс(СтрокаОстатка.Сумма, 0);
		КонецЕсли;
		
		Для каждого ЭлементПериода Из ПериодыКонтроля Цикл
			Если СтрокаОстатка.Период >= ЭлементПериода.НачалоПериода
				И СтрокаОстатка.Период <= ЭлементПериода.КонецПериода Тогда
				НачалоПериодаКонтроля    = ЭлементПериода.НачалоПериода;
				ОкончаниеПериодаКонтроля = ЭлементПериода.КонецПериода;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НачалоПериодаКонтроля = Неопределено ИЛИ ОкончаниеПериодаКонтроля = Неопределено Тогда
			ПериодичностьКонтроля = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаОстатка.Сценарий,
										"ПериодичностьКонтроля");
			ПараметрыПериода      = Перечисления.бит_ПериодичностьПланирования.ПараметрыДатыПоПериодичности(
										СтрокаОстатка.Период, ПериодичностьКонтроля);
			НачалоПериодаКонтроля    = ПараметрыПериода.ДатаНачала;
			ОкончаниеПериодаКонтроля = ПараметрыПериода.ДатаОкончания;
		КонецЕсли;
		ПредставлениеПериодаПрогноза = ПредставлениеПериода(НачалоПериодаКонтроля,
															ОкончаниеПериодаКонтроля);
		ШаблонЗаголовкаБюджета = НСтр("ru='Бюджет на %1:'");
		ЗаголовокБюджета       = СтрШаблон(ШаблонЗаголовкаБюджета, ПредставлениеПериодаПрогноза);
	Иначе
		БюджетСуммаБюджетаБезЗаявки  = 0;
		БюджетСуммаБюджетаПоСтатье   = 0;
		БюджетСуммаИсполненныхЗаявок = 0;
		БюджетОстатокБюджетаПоСтатье = 0;
		БюджетСуммаСверхЛимита       = 0;
		
		ЗаголовокБюджета             = НСтр("ru='Бюджет:'");
	КонецЕсли;
	
	Элементы.ДекорацияЗаголовокСуммаБюджетаПоСтатье.Заголовок = ЗаголовокБюджета;
	Элементы.ДекорацияБюджетСуммаБюджетаПоСтатье.Заголовок    = Формат(БюджетСуммаБюджетаПоСтатье, "ЧДЦ=2; ЧН=");
	Элементы.ДекорацияСуммаБюджетаБезЗаявки.Заголовок         = Формат(БюджетСуммаБюджетаБезЗаявки, "ЧДЦ=2; ЧН=");
	
	ЕстьСвехЛимит = (БюджетСуммаСверхЛимита > 0);
	Элементы.ДекорацияСуммаСверхЛимита.Видимость = ЕстьСвехЛимит;
	Элементы.БюджетСуммаСверхЛимита.Видимость    = ЕстьСвехЛимит;
	
	ПостроитьДиаграммуБюджета();
		
КонецПроцедуры

&НаСервере
Процедура ПостроитьДиаграммуБюджета()
	
	ДиаграммаБюджета.Очистить();
	ДиаграммаБюджета.ОбластьЛегенды.Расположение = РасположениеЛегендыДиаграммы.Нет;
	ДиаграммаБюджета.ОбластьПостроения.ЦветФона  = ЦветаСтиля.бит_ЦветФонаПодсказки;
	ДиаграммаБюджета.АвтоТранспонирование = Ложь;
	ДиаграммаБюджета.Обновление = Ложь;
	
	Точка = ДиаграммаБюджета.УстановитьТочку(Неопределено);
	
	Серия = ДиаграммаБюджета.Серии.Добавить("СуммаЗаявки");
	Серия.Текст      = НСтр("ru='Сумма заявки'");
	Серия.Цвет       = ЦветаСтиля.бит_ЦветТочекАлгоритма;
	Серия.Раздвигать = Истина;
	ДиаграммаБюджета.УстановитьЗначение(Точка, Серия, БюджетСуммаЗаявкиПоСтатье);
	
	Серия            = ДиаграммаБюджета.Серии.Добавить("Исполнено");
	Серия.Текст      = НСтр("ru='Исполнено'");
	Серия.Цвет       = ЦветаСтиля.бит_ЦветНедоступногоПоля;
	Серия.Раздвигать = Ложь;
	ДиаграммаБюджета.УстановитьЗначение(Точка, Серия, БюджетСуммаИсполненныхЗаявок);
	
	Серия            = ДиаграммаБюджета.Серии.Добавить("ОстатокБюджета");
	Серия.Текст      = НСтр("ru='Остаток бюджета'");
	Серия.Цвет       = ЦветаСтиля.бит_ЦветЗаголовкаСтатуса;
	Серия.Раздвигать = Ложь;
	ДиаграммаБюджета.УстановитьЗначение(Точка, Серия, БюджетОстатокБюджетаПоСтатье);
	
	Если БюджетСуммаСверхЛимита > 0 Тогда
		Серия            = ДиаграммаБюджета.Серии.Добавить("СверхЛимита");
		Серия.Текст      = НСтр("ru='Сверх лимита'");
		Серия.Цвет       = ЦветаСтиля.ЦветОтрицательногоЧисла;
		Серия.Раздвигать = Ложь;
		ДиаграммаБюджета.УстановитьЗначение(Точка, Серия, БюджетСуммаСверхЛимита);
	КонецЕсли;
	
	ДиаграммаБюджета.АвтоТранспонирование = Истина;
	ДиаграммаБюджета.Обновление = Истина;
	
КонецПроцедуры

&НаСервере
Функция ПроверитьВозможностьРасчетаБюджета()
	
	ИдентификаторОшибкиРасшифровкиБюджета = "";
	Элементы.ДекорацияОшибкаРасчетаБюджета.Заголовок = "";
	
	СтатьяОборотов = Объект.СтатьяОборотов;
	Если НЕ ЗначениеЗаполнено(СтатьяОборотов) Тогда
		ИдентификаторОшибкиРасшифровкиБюджета = "НеУказанаСтатьяОборотов";
		Элементы.ДекорацияОшибкаРасчетаБюджета.Заголовок = НСтр("ru = 'Не указана статья оборотов.'");
		Возврат Ложь;
	КонецЕсли;
	
	НеКонтролировать = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтатьяОборотов, "НеКонтролировать_Заявки");
	Если НеКонтролировать Тогда
		ИдентификаторОшибкиРасшифровкиБюджета = "ОтключенКонтрольПоСтатье";
		Элементы.ДекорацияОшибкаРасчетаБюджета.Заголовок = НСтр("ru = 'Не ведется контроль по статье.'");
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Процедура ВывестиСведенияОВзаиморасчетах(ВыводитьСведенияОВзаиморасчетах)
	
	Если НЕ ВыводитьСведенияОВзаиморасчетах Тогда
		Элементы.ГруппаВзаиморасчеты.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	СтруктураЗадолженности = бит_Договоры.ДанныеЗадолженности(Объект.Договор,
																	Объект.Контрагент,
																	Объект.Организация);
	ВзаиморасчетыДебиторскаяЗадолженность  = СтруктураЗадолженности.ДебиторскаяЗадолженность;
	ВзаиморасчетыКредиторскаяЗадолженность = СтруктураЗадолженности.КредиторскаяЗадолженность;
	
	Элементы.ВзаиморасчетыДебиторскаяЗадолженность.Видимость  = ВзаиморасчетыДебиторскаяЗадолженность <> 0;
	Элементы.ВзаиморасчетыКредиторскаяЗадолженность.Видимость = ВзаиморасчетыКредиторскаяЗадолженность <> 0;
	Элементы.ДекорацияВзаиморасчетыЗадолженностьОтсутствует.Видимость = (ВзаиморасчетыДебиторскаяЗадолженность = 0
																			И ВзаиморасчетыКредиторскаяЗадолженность = 0);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОтображениеДекорацииОтображенияБюджетаПриОткрытии(Форма)
	
	Элементы = Форма.Элементы;
	
	Если Форма.ОтображатьБюджетПриОткрытии Тогда
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Подсказка = НСтр("ru='Не отображать при открытии'");
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Картинка  = БиблиотекаКартинок.Закрепить;
	Иначе
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Подсказка = НСтр("ru='Отображать при открытии'");
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Картинка  = БиблиотекаКартинок.Открепить;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтображениеБюджетаПриОткрытии(Форма, НовоеЗначение)
	
	Форма.ОтображатьБюджетПриОткрытии = НовоеЗначение;
	ОбщегоНазначенияВызовСервера.ХранилищеОбщихНастроекСохранить("НастройкиПользователя",
																"ОтображатьБюджетПриОткрытии",
																НовоеЗначение);
	ОтображениеДекорацииОтображенияБюджетаПриОткрытии(Форма);
	
КонецПроцедуры

&НаКлиенте
Процедура РасшифровкаБюджета()
	
	Отбор = Новый Структура;
	Отбор.Вставить("РежимКонтроля"         , ПредопределенноеЗначение("Перечисление.бит_РежимыКонтроляПоБюджету.Заявки"));
	Отбор.Вставить("СценарийКонтролируемый", Объект.Сценарий);
	
	АналитикиОтбора = Новый Структура;
	АналитикиОтбора.Вставить("ЦФО"           , ПредопределенноеЗначение("Справочник.Подразделения.ПустаяСсылка"));
	АналитикиОтбора.Вставить("СтатьяОборотов", ПредопределенноеЗначение("Справочник.бит_СтатьиОборотов.ПустаяСсылка"));
	ШаблонАналитики = "Аналитика_%1";
	Для НомерАналитики = 1 По 12 Цикл
		АналитикиОтбора.Вставить(СтрШаблон(ШаблонАналитики, НомерАналитики), Неопределено);
	КонецЦикла;
	
	Для каждого Аналитика Из АналитикиОтбора Цикл
		ИмяАналитики = Аналитика.Ключ;
		Если ЗначениеЗаполнено(Объект[ИмяАналитики]) Тогда
			ЗначенияОтбора = Новый СписокЗначений;
			ЗначенияОтбора.Добавить(Объект[ИмяАналитики]);
			ЗначенияОтбора.Добавить(Аналитика.Значение);
			Отбор.Вставить(ИмяАналитики, ЗначенияОтбора);
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыОтчета = Новый Структура;
	ПараметрыОтчета.Вставить("Отбор",                     Отбор);
	ПараметрыОтчета.Вставить("СформироватьПриОткрытии",   Истина);
	ПараметрыОтчета.Вставить("Заголовок",                 НСтр("ru='Контрольные значения бюджета по заявкам'"));
	ДополнитьПараметрыРасшифровкиБюджета(ПараметрыОтчета, Отбор);
	
	ОткрытьФорму("Отчет.бит_КонтрольныеЗначенияБюджета.Форма", ПараметрыОтчета, ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьПараметрыРасшифровкиБюджета(ПараметрыОтчета, Отбор)
	
	КомпоновщикНастроек = Отчеты.бит_КонтрольныеЗначенияБюджета.Создать().КомпоновщикНастроек;
	Настройки           = КомпоновщикНастроек.Настройки;
	
	ПериодКонтроля   = Новый СтандартныйПериод(НачалоПериодаКонтроля, ОкончаниеПериодаКонтроля);
	
	ЭлементНастройки = Настройки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Период"));
	ЭлементНастройки.Значение = ПериодКонтроля;
	Если ЗначениеЗаполнено(ЭлементНастройки.ИдентификаторПользовательскойНастройки) Тогда
		ПользовательскийПараметр = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Найти(
									ЭлементНастройки.ИдентификаторПользовательскойНастройки);
		Если ТипЗнч(ПользовательскийПараметр) = Тип("ЗначениеПараметраНастроекКомпоновкиДанных") Тогда
			ПользовательскийПараметр.Значение = ЭлементНастройки.Значение;
		КонецЕсли;
	КонецЕсли;
	
	ОтборСотрудник = Новый ПолеКомпоновкиДанных("Сотрудник");
	Для каждого ЭлементНастройки Из Настройки.Отбор.Элементы Цикл
		ИмяПоляОтбора = Строка(ЭлементНастройки.ЛевоеЗначение);
		Если НЕ Отбор.Свойство(ИмяПоляОтбора) Тогда
			Продолжить;
		КонецЕсли;
		
		ЗначениеОтбора = Отбор[ИмяПоляОтбора];
		Если ТипЗнч(ЗначениеОтбора) = Тип("СписокЗначений") Тогда
			ЭлементНастройки.ВидСравнения   = ВидСравненияКомпоновкиДанных.ВСписке;
		Иначе
			ЭлементНастройки.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		КонецЕсли;
		ЭлементНастройки.ПравоеЗначение = ЗначениеОтбора;
		ЭлементНастройки.Использование  = Истина;
		
		Если ЗначениеЗаполнено(ЭлементНастройки.ИдентификаторПользовательскойНастройки) Тогда
			ПользовательскийПараметр = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Найти(
										ЭлементНастройки.ИдентификаторПользовательскойНастройки);
			Если ТипЗнч(ПользовательскийПараметр) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
				ПользовательскийПараметр.ВидСравнения   = ЭлементНастройки.ВидСравнения;
				ПользовательскийПараметр.ПравоеЗначение = ЭлементНастройки.ПравоеЗначение;
				ПользовательскийПараметр.Использование  = ЭлементНастройки.Использование;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыОтчета.Вставить("Вариант",                   Настройки);
	ПараметрыОтчета.Вставить("ПользовательскиеНастройки", КомпоновщикНастроек.ПользовательскиеНастройки);
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ДокументДолженБытьОформленБезНДС()

	ОперацияБезНДС = бит_Казначейство.ОперацияБезНДС(Объект.ХозяйственнаяОперация);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСостояниеДокумента()
	
	СостояниеДокумента = бит_ОбщегоНазначения.СостояниеДокумента(Объект);
	
КонецПроцедуры

&НаСервере
Функция ПараметрыОбъектаДляНазначенияПлатежа()
	
	РасшифровкаПлатежа.Очистить();
	НоваяСтрока = РасшифровкаПлатежа.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, Объект);
	НоваяСтрока.Сумма = Объект.СуммаДокумента;
	
	ПараметрыОбъекта = Документы.бит_кзн_ПлатежнаяПозиция.НовыеПараметрыОбъектаДляНазначенияПлатежа();
	ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект,, "Ссылка");
	
	ПараметрыОбъекта.ХозяйственнаяОперация 	 = ХозОперацияУП;
	ПараметрыОбъекта.ПодотчетноеЛицо		 = Объект.ФизЛицо;
	ПараметрыОбъекта.Валюта					 = Объект.ВалютаДокумента;
	ПараметрыОбъекта.ПодтверждающиеДокументы = Объект.ПодтверждающиеДокументы.Выгрузить();
	ПараметрыОбъекта.РасшифровкаПлатежа 	 = РасшифровкаПлатежа;

	Возврат ПараметрыОбъекта;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьНазначениеПлатежаСервер()

	ПараметрыОбъекта = ПараметрыОбъектаДляНазначенияПлатежа();
	ДенежныеСредстваСервер.ЗаполнитьТекстНазначенияПлатежа(ПараметрыОбъекта);
	
	Если Объект.НазначениеПлатежа <> ПараметрыОбъекта.НазначениеПлатежа Тогда
		Объект.НазначениеПлатежаУпр = ПараметрыОбъекта.НазначениеПлатежа;
	КонецЕсли;
	Объект.НазначениеПлатежа = ПараметрыОбъекта.НазначениеПлатежа;
	
КонецПроцедуры

&НаСервере
Процедура КодВидаДоходаПоУмолчанию()
	
	КонтрагентЮрФизЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Контрагент, "ЮрФизЛицо");
	бит_КазначействоКлиентСервер.КодВидаДоходаПоУмолчанию(Объект, ХозОперацияУП, КонтрагентЮрФизЛицо);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокКодовВидаДохода()
	
	Элементы.КодВидаДохода.СписокВыбора.Очистить();
	
	ВыплатаЗарплаты = (ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета
						Или ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыПоЗарплатномуПроекту);
	ДатаКодов = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса());
	СписокВыбора = ПлатежиВБюджетКлиентСервер.КодыВидовДохода(ДатаКодов, ВыплатаЗарплаты);
		
	Для каждого ЭлементСписка Из СписокВыбора Цикл
		Элементы.КодВидаДохода.СписокВыбора.Добавить(ЭлементСписка.Значение, ЭлементСписка.Представление);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьКорректностьЗаполненияПлатежаВБюджет()
	
	ТекущаяДата = ?(ЗначениеЗаполнено(Объект.ДатаПлан), Объект.ДатаПлан, ТекущаяДатаСеанса());
	
	// Модель формы для совместимости с ЕРП.
	СвойстваФормы = Новый Структура;
	СвойстваФормы.Вставить("ГруппаТипНалога",			Элементы.ГруппаТипНалога);
	СвойстваФормы.Вставить("ТипНалога",					Элементы.ТипНалога);
	СвойстваФормы.Вставить("Контрагент",				Элементы.Контрагент);
	СвойстваФормы.Вставить("БанковскийСчетКонтрагента", Элементы.БанковскийСчетПолучателя);

	СвойстваОбъекта = Новый Структура;
	СвойстваОбъекта.Вставить("Организация", 			  Объект.Организация);
	СвойстваОбъекта.Вставить("ТипНалога", 				  Объект.ТипНалога);
	СвойстваОбъекта.Вставить("Контрагент", 				  Объект.Контрагент);
	СвойстваОбъекта.Вставить("БанковскийСчетКонтрагента", Объект.БанковскийСчетПолучателя);
	
	Форма = Новый Структура("Элементы, Объект", СвойстваФормы, СвойстваОбъекта);
	ПлатежиВБюджет.ПроверитьКорректностьЗаполненияПлатежаВБюджет(Форма, ТекущаяДата);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ВозможноВзысканиеСПеречисленияФизлицу(Дата, ВидОперации, КонтрагентЮрФизЛицо)
	
	Возврат бит_КазначействоКлиентСервер.ВозможноВзысканиеСПеречисленияФизлицу(Дата, 
				ВидОперации, КонтрагентЮрФизЛицо);
	
КонецФункции
 
// Процедура является обработчиком ожидания, отслеживает окончание транзакции записи/проведения документа.
//
&НаКлиенте
Процедура ОжиданиеПроведенияДокумента()
	
	ОтключитьОбработчикОжидания("ОжиданиеПроведенияДокумента");
	
	УстановитьВидимостьКнопкиОплатитьЗаСчет();
	
КонецПроцедуры

//  Процедура выполняет окончательные действия процедуры "ОплатаЗаСчет".
//
&НаКлиенте
Процедура ОплатаЗаСчетЗавершение()

	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("ДокументОснование", 	Объект.ДокументПланирования);
	ДанныеЗаполнения.Вставить("Сценарий", 			Объект.Сценарий);
	ДанныеЗаполнения.Вставить("ВидКорректировки", 	ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет"));
	ДанныеЗаполнения.Вставить("АдресДанныхДляКорректировки", АдресДанныхДляКорректировки);
	
	ПараметрыФормы = Новый Структура("Основание", ДанныеЗаполнения);
	ОткрытьФорму("Документ.бит_КорректировкаКонтрольныхЗначений.ФормаОбъекта", ПараметрыФормы, 
		ЭтотОбъект,,,,,РежимОткрытияОкнаФормы.Независимый);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста 
Процедура ЗаполнитьКонтролируемыеРеквизиты(Форма)
	
	НаборРеквизитов = Новый Структура;
	НаборРеквизитов.Вставить("ДатаПлан");
	НаборРеквизитов.Вставить("ДатаПланКрайняя");
	НаборРеквизитов.Вставить("ВалютаДокумента");
	НаборРеквизитов.Вставить("ОбъектРасчетов");
	НаборРеквизитов.Вставить("Организация");
	НаборРеквизитов.Вставить("БанковскийСчет");
	НаборРеквизитов.Вставить("ФормаОплаты");
	НаборРеквизитов.Вставить("ХозяйственнаяОперация");
	НаборРеквизитов.Вставить("Контрагент");

	ЗаполнитьЗначенияСвойств(НаборРеквизитов, Форма.Объект);
	
	Форма.КонтролируемыеРеквизиты = Новый ФиксированнаяСтруктура(НаборРеквизитов);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста 
Процедура ОбновитьКонтролируемыеРеквизиты(ИмяРеквизита, Форма)
	
	НаборРеквизитов = Новый Структура;
	Для каждого КлючЗначение Из Форма.КонтролируемыеРеквизиты Цикл
		НаборРеквизитов.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла; 
	НаборРеквизитов.Вставить(ИмяРеквизита, Форма.Объект[ИмяРеквизита]);
	
	Форма.КонтролируемыеРеквизиты = Новый ФиксированнаяСтруктура(НаборРеквизитов);	
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовокФормыДокумента()
	
	НомерДата			 = "";
	ПредставлениеОбъекта = "";
	
	РеквизитыЗаявки = Новый Структура("Номер, Дата", "", '0001-01-01');
	Если ЗначениеЗаполнено(Объект.ДокументПланирования) Тогда
		РеквизитыЗаявки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.ДокументПланирования, "Номер, Дата");
	КонецЕсли;
	
	Если Объект.ВидПлана = ПредопределенноеЗначение("Перечисление.бит_кзн_ВидыПланов.Прогноз") Тогда 		
		Если ЭтоРежимЗаявки Тогда 			
			ПредставлениеОбъекта = НСтр("ru='Прогноз платежа%1';en='Payment Forecast%1'");
		Иначе	                                			
			ПредставлениеОбъекта = НСтр("ru='Платежная позиция%1';en='Payment Record%1'");			
		КонецЕсли; 
		НомерДата = НомерДата(Объект.Ссылка, Объект.Номер, Объект.Дата);
	ИначеЕсли Объект.ВидПлана = ПредопределенноеЗначение("Перечисление.бит_кзн_ВидыПланов.План") Тогда		
		Если ЭтоРежимЗаявки Тогда  			
			ПредставлениеОбъекта = НСтр("ru='Заявка на расходование средств%1';en='Request for Disbursement%1'"); 
			НомерДата = НомерДата(Объект.Ссылка, РеквизитыЗаявки.Номер, Объект.Дата);
		Иначе	   			
			ПредставлениеОбъекта = НСтр("ru='Платежная позиция%1';en='Payment Record%1'");
			НомерДата = НомерДата(Объект.Ссылка, Объект.Номер, Объект.Дата);
		КонецЕсли;            		
	ИначеЕсли ЭтоЗаявкаНаПеремещение Тогда  		
		ПредставлениеОбъекта =  НСтр("ru='Заявка на перемещение денежных средств%1';en='Application for the movement of funds%1'");
		НомерДата = НомерДата(Объект.Ссылка, РеквизитыЗаявки.Номер, Объект.Дата);
	ИначеЕсли ЭтоЗаявкаНаПереводСредств Тогда   		
		ПредставлениеОбъекта =  НСтр("ru='Заявка на перевод денежных средств в другую организацию%1';
								 |en='Application for transfer of funds to another organization%1'");
		НомерДата = НомерДата(Объект.Ссылка, РеквизитыЗаявки.Номер, Объект.Дата);
	КонецЕсли; 
	ПредставлениеОбъекта = СтрШаблон(ПредставлениеОбъекта, НомерДата);

	ПараметрыЗаголовка = Новый Структура;
	ПараметрыЗаголовка.Вставить("ПредставлениеОбъекта", ПредставлениеОбъекта);
	ПараметрыЗаголовка.Вставить("СтрокаВидаОперации"  , "");
	ПараметрыЗаголовка.Вставить("ЭтоНовый"			  , Объект.Ссылка.Пустая());
	ПараметрыЗаголовка.Вставить("ДокументПроведен"	  , Объект.Проведен);
	
	бит_РаботаСДиалогамиКлиентСервер.УстановитьЗаголовокФормыДокумента(ЭтотОбъект, ПараметрыЗаголовка);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьКнопкиОплатитьЗаСчет()
	
	ПоказатьОплатаЗаСчет = Ложь;
	
	Если ЭтоАдресВременногоХранилища(АдресДанныхДляКорректировки) Тогда
		Результат = ПолучитьИзВременногоХранилища(АдресДанныхДляКорректировки);
		Если ТипЗнч(Результат) = Тип("Структура") Тогда
			ЕстьДанныеКорректировки = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Результат, 
										"ЕстьДанныеКорректировки", Ложь);
			Если ЕстьДанныеКорректировки И НЕ Объект.СверхБюджета Тогда
				ПоказатьОплатаЗаСчет = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Элементы.ОплатаЗаСчет.Видимость = ПоказатьОплатаЗаСчет;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКэшЗначений()
	
	КэшЗначений = Новый Структура;
	КэшЗначений.Вставить("ИзмеренияДоп"      , бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Дополнительные","Синоним"));
	КэшЗначений.Вставить("НастройкиИзмерений", бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений"));
		
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция НомерДата(Ссылка, Номер, Дата)

	НомерДата = "";
	Если ЗначениеЗаполнено(Ссылка) Тогда
		НомерДата = " " + НСтр("ru = '%1 от %2'; en = '%1 from %2'");
		НомерДата = СтрШаблон(НомерДата, Номер, Дата);
	КонецЕсли;
	
	Возврат НомерДата;

КонецФункции

&НаСервере
Процедура УправлениеФормой()
	
	бит_НастройкиДоступностиЭлементовФормКлиентСервер.РазблокироватьЭлементы(ЭтотОбъект);

	ДокументВВалюте = Объект.ВалютаДокумента <> ВалютаРеглУчета;	
	ОплатаЧерезБанк = (Объект.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные);
	ХозОперация		= Объект.ХозяйственнаяОперация;

	// Платежи по 275-ФЗ
	Если ПоддержкаПлатежей275ФЗ И ЭтоРежимЗаявки Тогда		
		Элементы.ПлатежиПо275ФЗ.Видимость = Истина;
	Иначе	
		Элементы.ПлатежиПо275ФЗ.Видимость = Ложь;
	КонецЕсли; 
	
	Элементы.СтраницаОплатаЗаСчетСредств.Видимость	   = (Объект.ПлатежиПо275ФЗ И ЭтоРежимЗаявки);
	Элементы.СтраницаПодтверждающиеДокументы.Видимость = (Объект.ПлатежиПо275ФЗ И ЭтоРежимЗаявки);
	
	// Налоги.
	Элементы.ГруппаНалоги.Видимость = ЭтоЗаявкаНаРасходование;
	
	#Область НДС
	Элементы.СтавкаНДС.Видимость = НЕ ОперацияБезНДС;
	Элементы.СуммаНДС.Видимость	 = НЕ ОперацияБезНДС;
	Элементы.ВалютаНДС.Видимость = НЕ ОперацияБезНДС;
	
	Если НЕ ОперацияБезНДС Тогда
		Элементы.СтавкаНДС.Доступность = ЭтоЗаявкаНаРасходование;
		Элементы.СуммаНДС.Доступность  = ЭтоЗаявкаНаРасходование;
	КонецЕсли;
	#КонецОбласти 

	Элементы.НДФЛПоВедомостям.Видимость = (ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеВБюджет);
	
	ЭтоОперацияВыплатыЗП  = бит_КазначействоКлиентСервер.ЭтоОперацияВыплатыЗарплаты(ХозОперация);
	ЭтоВыдачаПодотчетнику = (ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствПодотчетнику);
	ЭтоПередачаДенег	  = бит_КазначействоКлиентСервер.ЭтоОперацияПередачиДенег(ХозОперация);
	
	ЭтоОперацияБезВалютыВзаиморасчетов = бит_КазначействоКлиентСервер.ЭтоОперацияБезВалютыВзаиморасчетов(ХозОперация);

	Элементы.ПериодАвансовогоОтчета.Видимость    = (ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствПодотчетнику);
	Элементы.ДатаАвансовогоОтчета.Видимость      = (ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствПодотчетнику);
	Элементы.ДатаАвансовогоОтчета.ТолькоПросмотр = НЕ ПериодАвансовогоОтчетаДата;
	
	Элементы.Ведомость.Видимость                       = (ЭтоОперацияВыплатыЗП И ИспользоватьНачислениеЗарплаты) ИЛИ Объект.НДФЛПоВедомостям;
	Элементы.НомерВедомостиНаВыплатуЗарплаты.Видимость = ЭтоОперацияВыплатыЗП И (НЕ ИспользоватьНачислениеЗарплаты);
	Элементы.ДатаВедомостиНаВыплатуЗарплаты.Видимость  = ЭтоОперацияВыплатыЗП И (НЕ ИспользоватьНачислениеЗарплаты);
									
	ПеречисленияГосОргану = Новый Массив;
	ПеречисленияГосОргану.Добавить(Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеВБюджет);
	ПеречисленияГосОргану.Добавить(Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеТаможне);
	ПеречисленияГосОргану.Добавить(Перечисления.бит_ВидыОперацийКазначейства.ПрочаяВыдачаДенежныхСредств);
	
	Элементы.НадписьРеквизитыПлательщика.Видимость = (ПеречисленияГосОргану.Найти(ХозОперация) <> Неопределено) И ОплатаЧерезБанк;
	
	#Область ГруппаПрочийРасход
	Элементы.ГруппаПрочийРасход.Видимость  = 
		(Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ПрочаяВыдачаДенежныхСредств);
	Если ТипЗнч(Объект.СтатьяРасходов) = Тип("ПланВидовХарактеристикСсылка.СтатьиАктивовПассивов") Тогда
		Элементы.АналитикаРасходов.Видимость 		= Ложь;
		Элементы.АналитикаАктивовПассивов.Видимость = Истина;
	Иначе
		Элементы.АналитикаРасходов.Видимость 		= Истина;
		Элементы.АналитикаАктивовПассивов.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.АналитикаРасходов.Доступность		  = ЗначениеЗаполнено(Объект.СтатьяРасходов);
	Элементы.АналитикаАктивовПассивов.Доступность = ЗначениеЗаполнено(Объект.СтатьяРасходов);

	Элементы.АналитикаРасходов.ОграничениеТипа = 
		Новый ОписаниеТипов(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ТипЗнч(Объект.АналитикаРасходов)));
	Элементы.АналитикаАктивовПассивов.ОграничениеТипа = 
		Новый ОписаниеТипов(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ТипЗнч(Объект.АналитикаАктивовПассивов)));
	#КонецОбласти 

	Элементы.ГруппаДекорацияПредупреждения.Видимость = ЗаявкаВключенаВРеестр;
	
	Если ЭтоЗаявкаНаРасходование Тогда
		
		ЭтоПрогноз     = Объект.ВидПлана = Перечисления.бит_кзн_ВидыПланов.Прогноз;
		ПарамВидимости = бит_Казначейство.ПодготовитьПараметрыВидимости(ХозОперация);
		
		ЕстьПравоНаСписание = ПравоДоступа("Редактирование", Метаданные.Документы.СписаниеБезналичныхДенежныхСредств)
			ИЛИ ПравоДоступа("Редактирование", Метаданные.Документы.РасходныйКассовыйОрдер);
		
		//Если ввод не списком, показываем номер заявки, а не позиции.
		Элементы.Номер.Видимость	   = НЕ ЭтоРежимЗаявки;
		Элементы.НомерЗаявки.Видимость = ЭтоРежимЗаявки;
		
		// Устанавливаем видимость команд группы СоздатьНаОсновании.
		Элементы.ФормаВвестиЗаявку.Видимость 			= ЭтоПрогноз;
		Элементы.ФормаВвестиПлатежныйДокумент.Видимость = НЕ ЭтоПрогноз И ЕстьПравоНаСписание;  
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, 
			"ФормаВозвратЛимита", "Видимость", НЕ ЭтоПрогноз);
		
		// Не даем возможность выбирать документ планирования.
		Элементы.ДокументПланирования.Видимость = НЕ ЭтоРежимЗаявки;
		
		Если Объект.ПлатежиПо275ФЗ И ЭтоРежимЗаявки Тогда
			Элементы.ФормаОплаты.ТолькоПросмотр = Истина;
		Иначе	
			Элементы.ФормаОплаты.ТолькоПросмотр = НЕ ЭтоРежимЗаявки;
		КонецЕсли;
		
		// Реквизиты, заполняемые в документе-основании.
		Элементы.Организация.ТолькоПросмотр       	  = НЕ ЭтоРежимЗаявки;
		Элементы.Контрагент.ТолькоПросмотр        	  = НЕ ЭтоРежимЗаявки;
		Элементы.Сценарий.ТолькоПросмотр          	  = НЕ ЭтоРежимЗаявки;
		Элементы.Важность.ТолькоПросмотр          	  = НЕ ЭтоРежимЗаявки;
		Элементы.Ответственный.ТолькоПросмотр     	  = НЕ ЭтоРежимЗаявки;
		Элементы.Инициатор.ТолькоПросмотр         	  = НЕ ЭтоРежимЗаявки;
		Элементы.ФизЛицо.ТолькоПросмотр       	  	  = НЕ ЭтоРежимЗаявки;
		Элементы.ХозяйственнаяОперация.ТолькоПросмотр = НЕ ЭтоРежимЗаявки;
		
		Элементы.СверхБюджета.ТолькоПросмотр 			= НЕ ЭтоРежимЗаявки;
		Элементы.СверхБюджета.ЦветТекстаЗаголовка		= ?(Объект.СверхБюджета, ЦветаСтиля.ЦветОсобогоТекста, Новый Цвет);
		Элементы.СверхБюджета.Видимость				    = НЕ ЭтоПрогноз;

		#Область Валюты
		ВалютыСовпадают 				   = Объект.ВалютаДокумента = Объект.ВалютаВзаиморасчетов;
		ЗаблокироватьВалюту 			   = Истина;
		ЗаблокироватьВалютуВзаиморасчетов  = Ложь;
		ИсточникВалютыВзаиморасчетовВыбран = ЗначениеЗаполнено(Объект.ОбъектРасчетов) 
										 ИЛИ ЗначениеЗаполнено(Объект.Договор);										 
		
		Если Объект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
			ЗаблокироватьВалюту = Истина;
		Иначе	
			Если НЕ ЭтоРежимЗаявки Тогда
				ЗаблокироватьВалюту = Истина;
			Иначе	
				ЗаблокироватьВалюту = ИсточникВалютыВзаиморасчетовВыбран;
			КонецЕсли;
		КонецЕсли;	
		
		Если Объект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов Тогда
			ЗаблокироватьВалютуВзаиморасчетов = Истина;	
		Иначе	
			ЗаблокироватьВалютуВзаиморасчетов = ИсточникВалютыВзаиморасчетовВыбран;
		КонецЕсли;		
		
		Элементы.СуммаВзаиморасчетов.ТолькоПросмотр    			= ВалютыСовпадают;
		Элементы.СуммаВзаиморасчетов.Видимость					= НЕ ЭтоОперацияБезВалютыВзаиморасчетов; 
		Элементы.Валюта.ТолькоПросмотр 							= ЗаблокироватьВалюту;
		Элементы.ВариантКурсаДоговора.Видимость 	   			= НЕ ВалютыСовпадают;
		Элементы.КурсЧислительВзаиморасчетов.Видимость 			= НЕ ВалютыСовпадают;
		Элементы.КурсЗнаменательВзаиморасчетовНадпись.Видимость = НЕ ВалютыСовпадают;
		Элементы.ДекорацияВалютыИКурсПлатежа.Видимость 			= НЕ ВалютыСовпадают;
		Элементы.ВалютаВзаиморасчетов.ТолькоПросмотр 			= ЗаблокироватьВалютуВзаиморасчетов;		
		Элементы.ВалютаВзаиморасчетов.Видимость		 			= НЕ ЭтоОперацияБезВалютыВзаиморасчетов;
		Элементы.ПланированиеСуммы.ТолькоПросмотр	 			= ЭтоОперацияБезВалютыВзаиморасчетов 
															  ИЛИ НЕ ЭтоРежимЗаявки;
		#КонецОбласти
		
		// Переход в список имеет смысл только если позиция открыта как псевдо-заявка.
		Элементы.ФормаКомандаСписок.Видимость = ЭтоРежимЗаявки;
		
		// Видимость Банк/Касса.
		Элементы.БанковскийСчет.Видимость = ОплатаЧерезБанк;
		Элементы.Касса.Видимость 		  = НЕ ОплатаЧерезБанк;
		
		Элементы.ОрганизацияПолучатель.Видимость 	= ЭтоПередачаДенег;
		Элементы.БанковскийСчетПолучатель.Видимость = ЭтоПередачаДенег И ОплатаЧерезБанк;
		Элементы.КассаПолучатель.Видимость 			= ЭтоПередачаДенег И НЕ ОплатаЧерезБанк;
		
		Если ЭтоПередачаДенег Тогда
			УстановитьПараметрыВыбораБанковскогоСчетаКассыПолучателя();
		КонецЕсли;

		// Видимость Контрагент/Договор/ФизЛицо.
		Элементы.Контрагент.Видимость	  = ПарамВидимости.ЕстьКонтрагент ИЛИ (ОплатаЧерезБанк И ПеречислениеСотрудникуЧерезБанк);
		Элементы.ОбъектРасчетов.Видимость = ПарамВидимости.ЕстьОбъектРасчетов;
		
		Элементы.Партнер.Видимость 	 = ИспользоватьПартнеровИКонтрагентов И ПарамВидимости.ЕстьПартнер;
		Элементы.Партнер.Доступность = НЕ (ЗначениеЗаполнено(Объект.ОбъектРасчетов)
										ИЛИ ЗначениеЗаполнено(Объект.ДоговорАренды)
										ИЛИ ЗначениеЗаполнено(Объект.ДоговорКредитаДепозита));		
		
		Если ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеНаДепозиты
			ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ОплатаПоКредитам
			ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеНаДепозиты   
			ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаЗаймов Тогда 			
			Элементы.ДоговорКредитаДепозита.Видимость = Истина;
			Элементы.ДоговорАренды.Видимость 	 	   = Ложь;	
			Элементы.ДоговорЭквайринга.Видимость 	   = Ложь;
		ИначеЕсли ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ОплатаАрендодателю Тогда			
			Элементы.ДоговорКредитаДепозита.Видимость = Ложь;
			Элементы.ДоговорАренды.Видимость		   = Истина;
			Элементы.ДоговорЭквайринга.Видимость 	   = Ложь;
		ИначеЕсли ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВозвратОплатыНаПлатежнуюКарту Тогда
			Элементы.ДоговорКредитаДепозита.Видимость = Ложь;
			Элементы.ДоговорАренды.Видимость		   = Ложь;
			Элементы.ДоговорЭквайринга.Видимость 	   = Истина;
		Иначе	
			Элементы.ДоговорКредитаДепозита.Видимость = Ложь;
			Элементы.ДоговорАренды.Видимость 		   = Ложь;
			Элементы.ДоговорЭквайринга.Видимость 	   = Ложь;
		КонецЕсли; 
		
		Элементы.ТипПлатежаПоАренде.Видимость = Элементы.ДоговорАренды.Видимость; 
		
		Если ИспользоватьПодразделения
			И (ЭтоВыдачаПодотчетнику
			ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыплатаЗарплатыПоЗарплатномуПроекту 
			ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыплатаЗарплатыНаЛицевыеСчета
			ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаЗаймаСотруднику 
			ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ПрочаяВыдачаДенежныхСредств) Тогда			
			Элементы.Подразделение.Видимость = Истина;			
		Иначе
			Элементы.Подразделение.Видимость = ИспользоватьПодразделения;
		КонецЕсли;	                                                      		
		
		Если ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаЗаймаСотруднику Тогда 			
			Элементы.ДоговорЗаймаСотруднику.Видимость = Истина;			
		Иначе
			Элементы.ДоговорЗаймаСотруднику.Видимость = Ложь;
		КонецЕсли;	
		
		// Видимость Банковский счет получателя.
		Если ОплатаЧерезБанк Тогда
			Если ПарамВидимости.ЕстьКонтрагент
			 ИЛИ ЭтоВыдачаПодотчетнику
			 ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыплатаЗарплатыНаЛицевыеСчета 
	 		 ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаЗаймаСотруднику Тогда
				Элементы.БанковскийСчетПолучателя.Видимость = Истина;
			Иначе
				Элементы.БанковскийСчетПолучателя.Видимость = Ложь;
			КонецЕсли;
		Иначе	
			Элементы.БанковскийСчетПолучателя.Видимость = Ложь;	
		КонецЕсли;
		
		Если ОплатаЧерезБанк И ПарамВидимости.ФизЛицо Тогда
			 Если ПеречислениеСотрудникуЧерезБанк Тогда
				 ЗаголовокКонтрагент = НСтр("ru = 'Банк-получатель'; en = 'Recipient Bank'");
			 Иначе	
				 ЗаголовокКонтрагент = НСтр("ru = 'Получатель'; en = 'Recipient'");
			 КонецЕсли;
		Иначе	
			ЗаголовокКонтрагент = НСтр("ru = 'Получатель'; en = 'Recipient'");
		КонецЕсли;
		Элементы.Контрагент.Заголовок = ЗаголовокКонтрагент;
				
		Если ЭтоВыдачаПодотчетнику Тогда
			ЗаголовокФизЛица = НСтр("ru = 'Подотчетное лицо'; en = 'Accountable person'");
		Иначе	
			ЗаголовокФизЛица = НСтр("ru = 'Работник'; en = 'Worker'");
		КонецЕсли;
		Элементы.ФизЛицо.Заголовок 		= ЗаголовокФизЛица;
		Элементы.ФизЛицо.Видимость 		= ПарамВидимости.ФизЛицо;
		Элементы.ФизЛицо.ТолькоПросмотр = Объект.СписокФизЛиц;
		
		Элементы.ЛицевыеСчетаСотрудников.Видимость 		= Объект.СписокФизЛиц;
		Элементы.СписокФизЛицОтключено.Видимость   		= ЭтоВыдачаПодотчетнику И ПеречислениеСотрудникуЧерезБанк;
		Элементы.СписокФизЛицВключено.Видимость	  		= ЭтоВыдачаПодотчетнику И ПеречислениеСотрудникуЧерезБанк;
		Элементы.ГруппаРеквизитыОбменаСБанком.Видимость	= Объект.СписокФизЛиц;
		ОтображениеЗаголовкаПоляПодотчетноеЛицо();
		
		Элементы.ПеречислениеСотрудникуЧерезБанк.Видимость 		= ПарамВидимости.ФизЛицо И ОплатаЧерезБанк;
		Элементы.ПеречислениеСотрудникуЧерезБанк.ТолькоПросмотр = Объект.СписокФизЛиц;
				
		Элементы.ФормаПровестиИЗакрыть.Видимость         = РазрешеноПроводить И ЭтоРежимЗаявки;
		Элементы.ФормаПровести.Видимость                 = РазрешеноПроводить И ЭтоРежимЗаявки;
		Элементы.ФормаПровестиИЗакрыть.КнопкаПоУмолчанию = РазрешеноПроводить И ЭтоРежимЗаявки;
		
		ТекстЗаголовка = ?(Объект.ОтправленНаСогласование, 
						   НСтр("ru='Отозвать';en='Revoke'"), НСтр("ru='На согласование';en='For Approval'"));
		
		Элементы.ФормаКомандаНаСогласование.Видимость         = НЕ РазрешеноПроводить И ЭтоРежимЗаявки;
		Элементы.ФормаКомандаНаСогласование.КнопкаПоУмолчанию = НЕ РазрешеноПроводить И ЭтоРежимЗаявки;
		Элементы.ФормаКомандаНаСогласование.Заголовок         = ТекстЗаголовка;
		Элементы.ФормаКомандаНаСогласование.Доступность       = НЕ Объект.Проведен;	

		// Управление доступностью команды создать на основании.
		Если ТипСтатуса <> Перечисления.бит_ТипыСтатусовОбъектов.Утвержден
			И ТипСтатуса <> Перечисления.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен 
			И ТипСтатуса <> Перечисления.бит_ТипыСтатусовОбъектов.ВРеестре Тогда
			Элементы.ФормаВвестиПлатежныйДокумент.Доступность = Ложь;
			Элементы.ФормаВвестиЗаявку.Доступность			  = Ложь;
		Иначе
			Элементы.ФормаВвестиПлатежныйДокумент.Доступность = Истина И НЕ ЭтоПрогноз;
			Элементы.ФормаВвестиЗаявку.Доступность			  = ЭтоПрогноз; 
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, 
				"ФормаВозвратЛимита", "Доступность", НЕ ЭтоПрогноз);
		КонецЕсли;
		
		// Проверка заполнения Банковского счета.
		ДоговорОбъектаРасчетов = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ОбъектРасчетов, "Договор");
		Элементы.БанковскийСчет.АвтоОтметкаНезаполненного = НЕ ЗначениеЗаполнено(ДоговорОбъектаРасчетов);
		Элементы.БанковскийСчет.ОтметкаНезаполненного     = НЕ ЗначениеЗаполнено(ДоговорОбъектаРасчетов);
				
		УправлениеПоказателямиПлатежаВБюджет();
		
	Иначе
		
		Элементы.БанковскийСчет.ТолькоПросмотр  =  Истина;
		Элементы.Касса.ТолькоПросмотр			=  Истина;
		
		Элементы.БанковскийСчет.Видимость = ОплатаЧерезБанк;
		Элементы.БанковскийСчет.Заголовок = НСтр("ru = 'Отправитель'");
		Элементы.Касса.Видимость 		  = НЕ ОплатаЧерезБанк;
		Элементы.Касса.Заголовок		  = НСтр("ru = 'Отправитель'");
		
		Элементы.БанковскийСчет.АвтоОтметкаНезаполненного = Истина;
		Элементы.Касса.АвтоОтметкаНезаполненного		  = Истина;
		
		Элементы.ОрганизацияПолучатель.Видимость 	= Ложь;
		Элементы.БанковскийСчетПолучатель.Видимость = Ложь;
		Элементы.КассаПолучатель.Видимость 			= Ложь;

		// Синхронизируемые реквизиты.
		Элементы.ДокументПланирования.ТолькоПросмотр  =  Истина;
		Элементы.ХозяйственнаяОперация.ТолькоПросмотр =  Истина;
		Элементы.Организация.ТолькоПросмотр			  =  Истина;
		Элементы.Важность.ТолькоПросмотр 			  =  Истина;
		
		Элементы.СуммаДокумента.ТолькоПросмотр		 			=  Истина;
		Элементы.СуммаВзаиморасчетов.Видимость    				= Ложь;
		Элементы.ВариантКурсаДоговора.Видимость 	   			= Ложь;
		Элементы.КурсЧислительВзаиморасчетов.Видимость 			= Ложь;
		Элементы.КурсЗнаменательВзаиморасчетовНадпись.Видимость = Ложь;
		Элементы.ДекорацияВалютыИКурсПлатежа.Видимость 			= Ложь;
		Элементы.ВалютаВзаиморасчетов.Видимость		 			= Ложь;
		Элементы.ПланированиеСуммы.Видимость	 				= Ложь;		
		Элементы.Валюта.ТолькоПросмотр	 						= Истина;	
		
		Элементы.ЦФО.ТолькоПросмотр					=  НЕ ЭтоЗаявкаНаПереводСредств;
		Элементы.ФормаОплаты.ТолькоПросмотр			= Истина;
		Элементы.Сценарий.Видимость 				= Ложь;
		Элементы.СверхБюджета.ТолькоПросмотр 		= Истина;
		Элементы.СписатьЛимиты.ТолькоПросмотр 		= Истина;
		Элементы.Контрагент.Видимость				= Ложь;
		Элементы.Партнер.Видимость					= Ложь;
		Элементы.БанковскийСчетПолучателя.Видимость = Ложь;
		Элементы.ОбъектРасчетов.Видимость 			= Ложь;
		Элементы.ТипПлатежа.Видимость 				= Ложь;
		Элементы.ФизЛицо.Видимость 					= Ложь;
		Элементы.ДоговорКредитаДепозита.Видимость 	= Ложь;
		Элементы.ДоговорАренды.Видимость 			= Ложь;
		Элементы.ТипПлатежаПоАренде.Видимость 		= Ложь;
		Элементы.ДоговорЭквайринга.Видимость		= Ложь;
		Элементы.Подразделение.Видимость 			= Ложь;
		
		Элементы.ПеречислениеСотрудникуЧерезБанк.Видимость 	 = Ложь;
		
		Элементы.СписокФизЛицОтключено.Видимость    	= ЭтоВыдачаПодотчетнику;
		Элементы.СписокФизЛицВключено.Видимость	    	= ЭтоВыдачаПодотчетнику;
		Элементы.ЛицевыеСчетаСотрудников.Видимость		= ЭтоВыдачаПодотчетнику;
		Элементы.ГруппаРеквизитыОбменаСБанком.Видимость	= Объект.СписокФизЛиц;

		// Скрываем команды.
		Элементы.ФормаКомандаСписок.Видимость 			  = Ложь;
		Элементы.ФормаРезультатПроведенияКнопка.Видимость = Ложь;
		Элементы.ФормаКомандаНаСогласование.Видимость 	  = Ложь;
		Элементы.ФормаВвестиЗаявку.Видимость			  = Ложь;
		Элементы.ФормаВвестиПлатежныйДокумент.Видимость   = Ложь;
		Элементы.ФормаВвестиЗаявку.Доступность			  = Ложь;
		
		Элементы.ФормаПровестиИЗакрыть.Видимость         = Ложь;
		Элементы.ФормаПровести.Видимость                 = Ложь;
		Элементы.ФормаПровестиИЗакрыть.КнопкаПоУмолчанию = Ложь;

		Если НЕ ЭтоВыдачаПодотчетнику Тогда
			Счетчик 		  = 12;
			ПоказатьАналитики = Ложь;
			Пока Счетчик >= 1 Цикл
				ИмяЭлемента = "Аналитика_" + Счетчик;
				ПоказатьАналитики = Макс(Элементы[ИмяЭлемента].Видимость, ПоказатьАналитики);	
				Счетчик = Счетчик - 1;
			КонецЦикла;
			Если ПоказатьАналитики Тогда
				Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.ЗакладкиСверху;
			Иначе	
				Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;
			КонецЕсли;
		Иначе
			Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.ЗакладкиСверху;
		КонецЕсли;
	КонецЕсли;
	
	Элементы.СписатьЛимиты.Видимость   		   = Элементы.СверхБюджета.Видимость И НеУчитыватьСверхБюджета;
	Элементы.СписатьЛимиты.Доступность 		   = Объект.СверхБюджета;
	Элементы.ТипСуммыКредитаДепозита.Видимость = (ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ОплатаПоКредитам);

	Если (ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВозвратДенежныхСредствВДругуюОрганизацию
		И ИспользоватьДоговорыМеждуОрганизациями 
	  ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ВозвратОплатыКлиенту 
		И ИспользоватьДоговорыСКлиентами 
  	  ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ОплатаПоставщику
		И ИспользоватьДоговорыСПоставщиками
	  ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ОплатаДенежныхСредствВДругуюОрганизацию
		И ИспользоватьДоговорыМеждуОрганизациями
	  ИЛИ ХозОперация = Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеТаможне
		И ИспользоватьДоговорыСПоставщиками) Тогда
		
		Элементы.Договор.Видимость		= Истина;
		Элементы.Договор.ТолькоПросмотр = ЗначениеЗаполнено(Объект.ОбъектРасчетов);	
	Иначе
		Элементы.Договор.Видимость = Ложь;
	КонецЕсли;
												  
	Элементы.ГруппаФинансовогоУчета.Видимость  = ИспользоватьГруппыФинансовогоУчета И Элементы.Договор.Видимость 
													И НЕ ЗначениеЗаполнено(Объект.ОбъектРасчетов);
	Элементы.НаправлениеДеятельности.Видимость = Элементы.Договор.Видимость И НЕ ЗначениеЗаполнено(Объект.ОбъектРасчетов);
												// И ИспользоватьУчетЗатратПоНаправлениямДеятельности;
	
	Элементы.ДокументОснование.Видимость = ЗначениеЗаполнено(Объект.ДокументОснование);
	
	Элементы.ГруппаПлатежныеДокументы.Видимость = ПравоДоступа("Просмотр", Метаданные.Документы.СписаниеБезналичныхДенежныхСредств)
		ИЛИ ПравоДоступа("Просмотр", Метаданные.Документы.РасходныйКассовыйОрдер);
		
	Если ОтображатьБюджет Тогда
		Элементы.ДекорацияОтобразитьБюджетКартинка.Картинка     = БиблиотекаКартинок.бит_ПерейтиВниз;
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Видимость = Истина;
		Элементы.ГруппаБюджетИВзаиморасчетыРазделы.Видимость    = Истина;
	Иначе
		Элементы.ДекорацияОтобразитьБюджетКартинка.Картинка     = БиблиотекаКартинок.бит_ПерейтиВправо;
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Видимость = Ложь;
		Элементы.ГруппаБюджетИВзаиморасчетыРазделы.Видимость    = Ложь;
	КонецЕсли;
	ОтображениеДекорацииОтображенияБюджетаПриОткрытии(ЭтотОбъект);
		
	бит_НастройкиДоступностиЭлементовФормКлиентСервер.ЗаблокироватьЭлементы(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗаголовокГруппы(Форма, НазваниеГруппы, ТекстЗаголовка)

	Форма.Элементы[НазваниеГруппы].ЗаголовокСвернутогоОтображения = ТекстЗаголовка;

КонецПроцедуры // УстановитьЗаголовокГруппы()
 
&НаСервере
Процедура ФормаОплатыПриИзмененииНаСервере()
	
	Если НЕ ЗначениеЗаполнено(Объект.ФормаОплаты) Тогда
		Объект.ФормаОплаты = КонтролируемыеРеквизиты.ФормаОплаты; 
	КонецЕсли; 

	Если КонтролируемыеРеквизиты.ФормаОплаты = Объект.ФормаОплаты Тогда
		Возврат;
	КонецЕсли; 

	УстановитьПараметрыВыбораВидаОперации(ЭтотОбъект);
		
	ДоступныеЗначения = ДоступныеЗначенияВидовОпераций();
	Если ДоступныеЗначения.НайтиПоЗначению(Объект.ХозяйственнаяОперация) = Неопределено Тогда
		Объект.ХозяйственнаяОперация = ДоступныеЗначения[0].Значение;
		ХозяйственнаяОперацияПриИзмененииНаСервере();
	Иначе
		УправлениеФормой();
	КонецЕсли; 

	ЗаполнитьКонтролируемыеРеквизиты(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ХозяйственнаяОперацияПриИзмененииНаСервере()

	ХозОперацияУП	= ХозяйственнаяОперацияУП();
	ОплатаЧерезБанк = (Объект.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные);
	
	ВзаиморасчетыСервер.ПриИзмененииПараметровМеханизма(ЭтотОбъект);
	
	Объект.Партнер = Неопределено;
	
	ПарамВидимости = бит_Казначейство.ПодготовитьПараметрыВидимости(Объект.ХозяйственнаяОперация);
	Если НЕ ПарамВидимости.ЕстьКонтрагент Тогда	
		Объект.Контрагент = Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли; 
	
	Если ПарамВидимости.ЕстьПартнер Тогда
		Объект.Партнер = ДенежныеСредстваСервер.ПолучитьПартнераПоКонтрагенту(Объект.Контрагент, ХозОперацияУП);	
	КонецЕсли;
	
	Если НЕ ПарамВидимости.ЕстьДоговор Тогда	
		Объект.Договор		  = Неопределено;
	КонецЕсли;
	
	Если НЕ ПарамВидимости.ЕстьОбъектРасчетов Тогда
		Объект.ОбъектРасчетов = Неопределено;
	КонецЕсли;
			
	Если НЕ ПарамВидимости.ФизЛицо Тогда	
		Объект.ФизЛицо = Справочники.ФизическиеЛица.ПустаяСсылка();
	КонецЕсли; 

	Если НЕ СчетСоответствуетВладельцу() Тогда
		Объект.БанковскийСчетПолучателя = Неопределено;
	КонецЕсли;
	
	ЭтоОперацияБезВалютыВзаиморасчетов = бит_КазначействоКлиентСервер.ЭтоОперацияБезВалютыВзаиморасчетов(Объект.ХозяйственнаяОперация);
	Если ЭтоОперацияБезВалютыВзаиморасчетов Тогда
		Объект.ПланированиеСуммы 		   	 = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа;	
		Объект.ВалютаВзаиморасчетов 	   	 = Объект.ВалютаДокумента;
		Объект.КурсЧислительВзаиморасчетов	 = 1;
		Объект.КурсЗнаменательВзаиморасчетов = 1;
		Объект.СуммаДокумента				 = Объект.СуммаВзаиморасчетов;

		ПланированиеСуммыПриИзмененииНаСервере();
	КонецЕсли;
	
	Объект.ОбъектРасчетов = Неопределено;
	ОбъектРасчетовПриИзмененииНаСервере();
	
	УстановитьПараметрыВыбораБанковскийСчетПолучателя();
	УстановитьПараметрыВыбораТипаНалогов();
	УстановитьПараметрыВыбораОрганизацииПолучателя();
	УстановитьПараметрыВыбораПартнера();
	УстановитьЗаголовокЭлементаПартнер();
	
	Объект.Подразделение = Справочники.СтруктураПредприятия.ПустаяСсылка();

	Если ХозОперацияУП <> Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет Тогда
		Объект.НДФЛПоВедомостям = Ложь;
	КонецЕсли;
	
	Если НЕ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ОплатаПоставщику
		И НЕ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ОплатаДенежныхСредствВДругуюОрганизацию Тогда
		Объект.ДоговорСУчастникомГОЗ = Ложь;
	КонецЕсли;
	
	Если ОплатаЧерезБанк Тогда
		Если НЕ (ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыПоЗарплатномуПроекту
			ИЛИ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета
			ИЛИ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствПодотчетнику
			ИЛИ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ОплатаПоставщику
			ИЛИ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ПрочаяВыдачаДенежныхСредств) Тогда
				Объект.КодВидаДохода = "";
		КонецЕсли;
	Иначе	
		Объект.КодВидаДохода = "";
	КонецЕсли;

	Если НЕ (ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыПоЗарплатномуПроекту
		ИЛИ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета) Тогда
		Объект.КодВыплат = "";
	КонецЕсли;
		
	Если ХозОперацияУП <> Перечисления.ХозяйственныеОперации.ПрочаяВыдачаДенежныхСредств Тогда
		Объект.СтатьяРасходов 			= Неопределено;
		Объект.АналитикаРасходов 		= Неопределено;
		Объект.АналитикаАктивовПассивов = Неопределено;
	КонецЕсли;
	
	Объект.СписокФизЛиц = Ложь;
	СписокФизЛиц 		= 0;

	УстановитьВидимостьАналитик();
	
	ЗаполнитьРеквизитыПлательщика();
	УстановитьНадписьРеквизитыПлательщика();
	
	ЗаполнитьПоказателиПлатежаВБюджетПоУмолчаниюСервер(Истина);
	
	ДокументДолженБытьОформленБезНДС();
	ЗаполнитьСписокКодовВидаДохода();
	КодВидаДоходаПоУмолчанию();
    УправлениеФормой();
	
	Если НЕ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ОплатаПоставщику
		И НЕ ХозОперацияУП = Перечисления.ХозяйственныеОперации.ОплатаДенежныхСредствВДругуюОрганизацию Тогда
		Объект.ДоговорСУчастникомГОЗ = Ложь;
	КонецЕсли;
	
	ПроверитьЗаполнитьТипПлатежа275ФЗ();
	
	ПараметрыОбъекта = ПараметрыУстановитьСтавкуНДС();
	ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект);
	ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, ЭтотОбъект);
	УстановитьСтавкуНДС(ПараметрыОбъекта);
	Объект.СтавкаНДС = ПараметрыОбъекта.СтавкаНДС;
	РассчитатьСуммуНДС();
	
	ПроверитьИОчиститьОрганизациюПолучатель();

	НастроитьСчетаУчета();
	ОбновитьКонтролируемыеРеквизиты("ХозяйственнаяОперация", ЭтотОбъект);
	ОбновитьКонтролируемыеРеквизиты("ОбъектРасчетов", ЭтотОбъект);
	
КонецПроцедуры
 
&НаСервере
Функция ДоступныеЗначенияВидовОпераций()
	
	Модуль = Перечисления.бит_ВидыОперацийКазначейства;
	ПараметрыПередачи = Новый Структура; 
	ПараметрыПередачи.Вставить("ФормаОплаты", Объект.ФормаОплаты);
	ПараметрыПередачи.Вставить("ТипДокумента", ТипЗнч(Объект.ДокументПланирования));
	
	Возврат Модуль.ПолучитьДоступныеЗначения(ПараметрыПередачи).ДоступныеЗначения;
	
КонецФункции

&НаСервере
Функция ПараметрыУстановитьСтавкуНДС()

	ПараметрыУстановки = Новый Структура;
	ПараметрыУстановки.Вставить("СтавкаНДС", 			  Неопределено);
	ПараметрыУстановки.Вставить("СтатьяОборотов", 		  Неопределено);
	ПараметрыУстановки.Вставить("СтавкаНДСДоговора", 	  Неопределено);
	ПараметрыУстановки.Вставить("ОперацияБезНДС", 		  Ложь);
	ПараметрыУстановки.Вставить("ПричинаИзмененияСтатья", Ложь);
	
	Возврат ПараметрыУстановки; 

КонецФункции

&НаСервере
Процедура УстановитьСтавкуНДС(ПараметрыОбъекта)
	
	Если ПараметрыОбъекта.ОперацияБезНДС Тогда
		ПараметрыОбъекта.СтавкаНДС = Справочники.СтавкиНДС.БезНДС;
	Иначе	
		Если ЗначениеЗаполнено(ПараметрыОбъекта.СтатьяОборотов) И ПараметрыОбъекта.ПричинаИзмененияСтатья Тогда
			ПараметрыОбъекта.СтавкаНДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыОбъекта.СтатьяОборотов, "СтавкаНДС");
		КонецЕсли; 
		Если ЗначениеЗаполнено(ПараметрыОбъекта.СтавкаНДСДоговора) Тогда
			ПараметрыОбъекта.СтавкаНДС = ПараметрыОбъекта.СтавкаНДСДоговора;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РассчитатьСуммуНДС()
	
	ЗначениеСтавки  = бит_БухгалтерскийУчет.ПолучитьСтавкуНДС(Объект.СтавкаНДС);
	Объект.СуммаНДС = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(Объект.СуммаДокумента, 
						Истина, Истина, ЗначениеСтавки);

КонецПроцедуры

&НаСервере
Процедура СтатьяОборотовПриИзмененииНаСервере(ИзменитьСтавкуНДС = Истина)

	УстановитьВидимостьАналитик();
	
	РеквизитыОбъекта = РеквизитыОбъектаДляПодстановкиВАналитики();
	Для каждого Значение Из РеквизитыОбъекта Цикл
		ПриИзмененииПоставляемыхРеквизитов(Значение);
	КонецЦикла;
	ПриИзмененииПоставляемыхРеквизитов(Объект.СтатьяОборотов);
	
	Если ИзменитьСтавкуНДС Тогда
		ПараметрыОбъекта = ПараметрыУстановитьСтавкуНДС();
		ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект);
		ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, ЭтотОбъект);
		ПараметрыОбъекта.ПричинаИзмененияСтатья = ИзменитьСтавкуНДС;
		УстановитьСтавкуНДС(ПараметрыОбъекта);
		Объект.СтавкаНДС = ПараметрыОбъекта.СтавкаНДС;
		РассчитатьСуммуНДС();
	КонецЕсли;

КонецПроцедуры

