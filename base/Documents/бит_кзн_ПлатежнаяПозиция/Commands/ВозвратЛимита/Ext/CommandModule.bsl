
#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ПараметрыВыполнения = ПараметрыВыполнения(ПараметрКоманды);
	Если ПараметрыВыполнения.Поддерживается Тогда
		ДанныеЗаполнения = Новый Структура;
		ДанныеЗаполнения.Вставить("ДокументОснование", ПараметрыВыполнения.ДокументОснование);
		ДанныеЗаполнения.Вставить("Сценарий", 		   ПараметрыВыполнения.Сценарий);
		ДанныеЗаполнения.Вставить("АдресДанныхДляКорректировки", 
			ПараметрыВыполнения.АдресДанныхДляКорректировки);
		ДанныеЗаполнения.Вставить("ВидКорректировки",  
			ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ВозвратЛимита"));
		
		ПараметрыФормы = Новый Структура; 
		ПараметрыФормы.Вставить("Основание", ДанныеЗаполнения);
		
		ОткрытьФорму("Документ.бит_КорректировкаКонтрольныхЗначений.ФормаОбъекта", ПараметрыФормы);
	Иначе
		ВызватьИсключение ПараметрыВыполнения.ТекстСообщения;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПараметрыВыполнения(ДокументСсылка)

	СтатусОбъекта  		= бит_ВизированиеСервер.ТекущийСтатус(ДокументСсылка);
	ТипСтатуса          = Справочники.бит_СтатусыОбъектов.ТипСтатусаОбъкта(СтатусОбъекта);
	Поддерживается 		= Истина;
	ТекстСообщения 		= "";
	КонтрольныеЗначения = Новый ТаблицаЗначений(); 
	
	Если НЕ ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Проведен") Тогда
		ТекстСообщения = НСтр("ru='Вводится на основании проведенного документа.';en='Introduced on the basis of this document.'");
		Поддерживается = Ложь;
	КонецЕсли; 
	
	Если ТипСтатуса <> ПредопределенноеЗначение("Перечисление.бит_ТипыСтатусовОбъектов.Утвержден") 
		И ТипСтатуса <> ПредопределенноеЗначение("Перечисление.бит_ТипыСтатусовОбъектов.Исполнен") Тогда
		ТекстСообщения = НСтр("ru='Вводится на основании утвержденного или оплаченного документа.';
							  |en='Introduced on the basis of the approved or paid for the document.'");
		Поддерживается = Ложь;
	КонецЕсли; 
	
	Если Поддерживается Тогда
		КонтрольныеЗначения = Документы.бит_кзн_ПлатежнаяПозиция.КонтрольныеЗначенияВозвратаЛимита(ДокументСсылка);
	КонецЕсли;
	
	РезультатПоиска = Новый Структура; 
	РезультатПоиска.Вставить("ЕстьДанныеКорректировки", ЗначениеЗаполнено(КонтрольныеЗначения));
	РезультатПоиска.Вставить("АдресКорректировки", ПоместитьВоВременноеХранилище(КонтрольныеЗначения, 
			Новый УникальныйИдентификатор()));
			
	АдресДанныхДляКорректировки = ПоместитьВоВременноеХранилище(РезультатПоиска,
									Новый УникальныйИдентификатор());
	
	ИменаРеквизитовСсылки = Новый Структура;
	ИменаРеквизитовСсылки.Вставить("Сценарий", "Сценарий");
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция") Тогда
		ИменаРеквизитовСсылки.Вставить("ДокументОснование", "ДокументПланирования");
	Иначе
		ИменаРеквизитовСсылки.Вставить("ДокументОснование", "Ссылка");
	КонецЕсли;	
	
	РеквизитыСсылки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументСсылка, 
						Новый ФиксированнаяСтруктура(ИменаРеквизитовСсылки));
	
	Результат = Новый Структура;
	Результат.Вставить("ДокументОснование", 		  РеквизитыСсылки.ДокументОснование);
	Результат.Вставить("Сценарий", 					  РеквизитыСсылки.Сценарий);
	Результат.Вставить("Поддерживается", 			  Поддерживается); 
	Результат.Вставить("ТекстСообщения", 			  ТекстСообщения); 
	Результат.Вставить("АдресДанныхДляКорректировки", АдресДанныхДляКорректировки);

	Возврат Результат;

КонецФункции
 
#КонецОбласти