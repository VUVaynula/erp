// Функция получает неоплаченный остаток по позиции поступления.
//
// Параметры:
//   Позиция - ДокументСсылка.бит_кзн_ПлатежнаяПозиция
//
// Возвращаемое значение:
//  СтрОплата - Структура.
//
Функция ПолучитьОстаток(Позиция) Экспорт

	СтрОплата = Новый Структура("План, Факт, Остаток",Позиция.СуммаДокумента, 0, Позиция.СуммаДокумента);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидПлана"            , Позиция.ВидПлана);
	Запрос.УстановитьПараметр("ДокументПланирования", Позиция.ДокументПланирования);
	Запрос.УстановитьПараметр("Организация"         , Позиция.Организация);
	Запрос.УстановитьПараметр("Позиция"             , Позиция);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаКонечныйОстаток, 0)) КАК СуммаОстаток,
	|	СУММА(ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаПриход, 0)) КАК СуммаПлан,
	|	СУММА(ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаРасход, 0)) КАК СуммаФакт
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.ОстаткиИОбороты(
	|			,
	|			,
	|			,
	|			,
	|			ВидПлана = &ВидПлана
	|				И ДокументПланирования = &ДокументПланирования
	|				И Организация = &Организация
	|				И Позиция = &Позиция) КАК ПлРасходОстаткиИОбороты";
				   
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
	
		СтрОплата.План    = Выборка.СуммаПлан;
		СтрОплата.Факт    = Выборка.СуммаФакт;
		СтрОплата.Остаток = Выборка.СуммаОстаток;
	
	КонецЕсли; 

	Возврат СтрОплата;
	
КонецФункции // ПолучитьОстаток()

// Функция получает плановую и фактическую сумму оплат по платежным позициям.
// 
// Параметры:
//  ПлатежныеПозиции - ДокументСсылка.бит_кзн_ПлатежнаяПозиция, Массив.
// 
// Возвращаемое значение:
//   Соответствие.
//
Функция ОплатаПоПлатежнымПозициям(ПлатежныеПозиции) Экспорт
	
	Если ТипЗнч(ПлатежныеПозиции) = Тип("Массив") Тогда
		Позиции = ПлатежныеПозиции;
	Иначе
		Позиции = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПлатежныеПозиции);
	КонецЕсли;
	
	ОплатыПоПозициям = Новый Соответствие;
	Для каждого Элемент Из Позиции Цикл
		ОстаткиИОбороты = Новый Структура;
		ОстаткиИОбороты.Вставить("СуммаПлан",    0);
		ОстаткиИОбороты.Вставить("СуммаФакт",    0);
		ОстаткиИОбороты.Вставить("СуммаОстаток", 0);
		ОплатыПоПозициям.Вставить(Элемент, ОстаткиИОбороты);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПлатежнаяПозиция.Ссылка КАК Позиция,
	|	ПлатежнаяПозиция.ВидПлана КАК ВидПлана,
	|	ПлатежнаяПозиция.ДокументПланирования КАК ДокументПланирования,
	|	ПлатежнаяПозиция.Организация КАК Организация
	|ПОМЕСТИТЬ ПлатежныеПозиции
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПозиция
	|ГДЕ
	|	ПлатежнаяПозиция.Ссылка В(&Позиции)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПланируемыйРасходДС.Позиция КАК Позиция,
	|	СУММА(ЕСТЬNULL(ПланируемыйРасходДС.СуммаКонечныйОстаток, 0)) КАК СуммаОстаток,
	|	СУММА(ЕСТЬNULL(ПланируемыйРасходДС.СуммаПриход, 0)) КАК СуммаПлан,
	|	СУММА(ЕСТЬNULL(ПланируемыйРасходДС.СуммаРасход, 0)) КАК СуммаФакт
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.ОстаткиИОбороты(
	|			,
	|			,
	|			,
	|			,
	|			(ВидПлана, ДокументПланирования, Организация, Позиция) В
	|				(ВЫБРАТЬ
	|					ПлатежныеПозиции.ВидПлана,
	|					ПлатежныеПозиции.ДокументПланирования,
	|					ПлатежныеПозиции.Организация,
	|					ПлатежныеПозиции.Позиция
	|				ИЗ
	|					ПлатежныеПозиции КАК ПлатежныеПозиции)) КАК ПланируемыйРасходДС
	|
	|СГРУППИРОВАТЬ ПО
	|	ПланируемыйРасходДС.Позиция";
	Запрос.УстановитьПараметр("Позиции", Позиции);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ОплатыПоПозициям[Выборка.Позиция], Выборка);
	КонецЦикла;
	
	Возврат ОплатыПоПозициям;
	
КонецФункции

Процедура ОбновитьСтатусыСвязанныхРеестров(Ссылка) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РеестрПлатежей.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.бит_кзн_РеестрПлатежей.ТаблицаПлатежи КАК РеестрПлатежей
	|ГДЕ
	|	РеестрПлатежей.ПлатежнаяПозиция = &ПлатежнаяПозиция";
	Запрос.УстановитьПараметр("ПлатежнаяПозиция", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ОбъектРеестр = Выборка.Ссылка.ПолучитьОбъект();
		бит_ВизированиеСервер.УстановитьСтатус(ОбъектРеестр);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Функция возвращает массив документ оплаты по позиции.
//
Функция НайтиДокументыОплатыПоПозиции(Позиция) Экспорт
	
	ДокументыОплаты = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	бит_ОтражениеФактаДДС.ДокументОснование КАК ДокументОплаты
	|ИЗ
	|	Документ.бит_ОтражениеФактаДДС КАК бит_ОтражениеФактаДДС
	|ГДЕ
	|	бит_ОтражениеФактаДДС.ФактическиеДанные.Позиция = &Позиция
	|	И бит_ОтражениеФактаДДС.ФактическиеДанные.Позиция <> ЗНАЧЕНИЕ(Документ.бит_кзн_ПозицияПоступления.ПустаяСсылка)
	|	И НЕ бит_ОтражениеФактаДДС.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Позиция", Позиция);

	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();

	Пока Выборка.Следующий() Цикл
		ДокументыОплаты.Добавить(Выборка.ДокументОплаты);
	КонецЦикла;

	Возврат ДокументыОплаты;
	
КонецФункции	

// Функция находит аналитики тип которых совпадает с типом реквизитов позиции.
//
// Параметры: МетаОбъект - ОбъектМетаданных
//
//
// Возвращаемое значение:
//  СовпадающиеАналитики - Соответствие.
//
Функция НайтиАналитикиСовпадающиеСРеквизитами(МетаОбъект) Экспорт 

	СовпадающиеАналитики = Новый Соответствие;
	
	МассивТипов = Новый Массив;
	
	Для каждого Реквизит Из МетаОбъект.Реквизиты Цикл
	
		Если СтрНайти(Реквизит.Имя, "Аналитика") = 0 И СтрНайти(Реквизит.Имя, "Субконто") = 0 Тогда
		
			Для каждого ТипРек Из Реквизит.Тип.Типы() Цикл
			
				Если НЕ ТипРек = Тип("Булево")
					И НЕ ТипРек = Тип("Дата")
					И НЕ ТипРек = Тип("Строка")
					И НЕ ТипРек = Тип("Число") Тогда
					
					СтрРекв = Новый Структура("Имя, Тип", Реквизит.Имя, ТипРек);
					МассивТипов.Добавить(СтрРекв);
				
				КонецЕсли; 
			
			КонецЦикла; 
		
		КонецЕсли; 
	
	КонецЦикла; 
	
	Настройки = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	
	Для каждого Настройка Из Настройки Цикл
		Если НЕ Настройка.Значение.ЭтоСоставнойТип Тогда 
			Для каждого СтрРекв Из МассивТипов Цикл
				ТипРек = СтрРекв.Тип;
				Если Настройка.Значение.ТипЗначения.СодержитТип(ТипРек) Тогда 
					СовпадающиеАналитики.Вставить(Настройка.Ключ, СтрРекв.Имя);
					Прервать;
				КонецЕсли;
			КонецЦикла; 
		КонецЕсли;	
	КонецЦикла; 
	
	Возврат СовпадающиеАналитики;
	
КонецФункции // НайтиАналитикиСовпадающиеСРеквизитами()

// Функция определяет новый статус объекта в зависимости от режима записи документа
//и предыдущего статуса. Механизм определения статусов может быть переопределен алгоритмами.
//
// Параметры:
//  ТекущийОбъект - ДокументОбъект.бит_кзн_ПлатежнаяПозиция.
//  ПараметрыУстановкиСтатуса - Структура - состав полей см. в функции бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса.
//
// Возвращаемое значение:
//   НовыйСтатус - СправочникСсылка.бит_СтатусыОбъектов.
//
Функция НовыйСтатусОбъекта(ТекущийОбъект, ПараметрыУстановкиСтатуса) Экспорт
	
	Если ПараметрыУстановкиСтатуса.ПараметрыОплаты = Неопределено Тогда
		СтруктураОплаты = Документы.бит_кзн_ПлатежнаяПозиция.ПолучитьОстаток(ТекущийОбъект.Ссылка);
	Иначе	
		СтруктураОплаты = ПараметрыУстановкиСтатуса.ПараметрыОплаты;
	КонецЕсли;
	
	СсылкаНаОбъект       = ТекущийОбъект.Ссылка;
	ДокументПланирования = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаОбъект, "ДокументПланирования");
	ВизированиеОтключено = бит_ВизированиеСервер.МеханизмВизированияОтключен(ДокументПланирования);
	
	ПроводитьПослеУтверждения = ОбщегоНазначения.ЕстьРеквизитОбъекта("ОтправленНаСогласование", ТекущийОбъект.Метаданные())
									И ПолучитьФункциональнуюОпцию("бит_ПроводитьДокументыПослеУтверждения")
									И НЕ ВизированиеОтключено;
									
	РежимЗаписи = ПараметрыУстановкиСтатуса.РежимЗаписи;
									
	Если ПроводитьПослеУтверждения Тогда
		Если НЕ ТекущийОбъект.ОтправленНаСогласование Тогда
			Возврат Справочники.бит_СтатусыОбъектов.Черновик;
		КонецЕсли;
	ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
		ИЛИ (РежимЗаписи = РежимЗаписиДокумента.Запись И НЕ ТекущийОбъект.Проведен И НЕ ТекущийОбъект.ОтправленНаСогласование) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Черновик;
	КонецЕсли;
	
	Если бит_ВизированиеСервер.ЕстьБлокирующиеРешения(ДокументПланирования) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Отклонен;
	ИначеЕсли СтруктураОплаты.Остаток <= 0.01 И СтруктураОплаты.Факт > 0 Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Оплачен;
	ИначеЕсли СтруктураОплаты.Факт > 0 Тогда
		Возврат Справочники.бит_СтатусыОбъектов.ЧастичноОплачен;
	ИначеЕсли РегистрыСведений.бит_РеестрыПлатежей.ПозицияВключенаВРеестр(СсылкаНаОбъект) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Заявка_ВРеестре;
	ИначеЕсли ВизированиеОтключено Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Рабочий;
	ИначеЕсли бит_ВизированиеСервер.ВсеВизыСогласованы(ДокументПланирования) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Утвержден;
	КонецЕсли;
	
	Возврат Справочники.бит_СтатусыОбъектов.НаСогласовании;
	
КонецФункции

// Фукнция выполняет поиск значения Подразденеия из доступных дополнительных измерений с соответствующим типом.
//
// Параметры:
//  ПлатежнаяПозиция - ДокументСсылка.бит_кзн_ПлатежнаяПозиция.
//
// Возвращаемое значение:
//   СправочникСсылка.СтруктураПредприятия.
//
Функция ПодразделениеДополнительныеИзмерения(ПлатежнаяПозиция) Экспорт
	
	Подразделение = Справочники.СтруктураПредприятия.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПлатежнаяПозиция.Аналитика_1 КАК Аналитика_1,
	|	ПлатежнаяПозиция.Аналитика_2 КАК Аналитика_2,
	|	ПлатежнаяПозиция.Аналитика_3 КАК Аналитика_3,
	|	ПлатежнаяПозиция.Аналитика_4 КАК Аналитика_4,
	|	ПлатежнаяПозиция.Аналитика_5 КАК Аналитика_5,
	|	ПлатежнаяПозиция.Аналитика_6 КАК Аналитика_6,
	|	ПлатежнаяПозиция.Аналитика_7 КАК Аналитика_7,
	|	ПлатежнаяПозиция.Аналитика_8 КАК Аналитика_8,
	|	ПлатежнаяПозиция.Аналитика_9 КАК Аналитика_9,
	|	ПлатежнаяПозиция.Аналитика_10 КАК Аналитика_10,
	|	ПлатежнаяПозиция.Аналитика_11 КАК Аналитика_11,
	|	ПлатежнаяПозиция.Аналитика_12 КАК Аналитика_12
	|ПОМЕСТИТЬ ДополнительныеИзмерения
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПозиция
	|ГДЕ
	|	ПлатежнаяПозиция.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НазначениеДопИзмерений.ИмяИзмерения КАК ИмяИзмерения
	|ПОМЕСТИТЬ ИмяИзмеренияПодраздение
	|ИЗ
	|	РегистрСведений.бит_НазначениеДополнительныхИзмерений КАК НазначениеДопИзмерений
	|ГДЕ
	|	НазначениеДопИзмерений.Синоним = ""Подразделение""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДополнительныеИзмерения.Аналитика_1 КАК ЗначениеИзмерения,
	|	ВЫБОР
	|		КОГДА ИмяИзмеренияПодраздение.ИмяИзмерения ЕСТЬ NULL
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ПриоритетЗаписей
	|ИЗ
	|	ДополнительныеИзмерения КАК ДополнительныеИзмерения
	|		ЛЕВОЕ СОЕДИНЕНИЕ ИмяИзмеренияПодраздение КАК ИмяИзмеренияПодраздение
	|		ПО (ИмяИзмеренияПодраздение.ИмяИзмерения = ""Аналитика_1"")
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(ДополнительныеИзмерения.Аналитика_1) = ТИП(Справочник.СтруктураПредприятия)
