#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

#Область Проведение

// Описывает учетные механизмы используемые в документе для регистрации в механизме проведения.
//
// Параметры:
//  МеханизмыДокумента - Массив - список имен учетных механизмов, для которых будет выполнена
//              регистрация в механизме проведения.
//
Процедура ЗарегистрироватьУчетныеМеханизмы(МеханизмыДокумента) Экспорт
	
КонецПроцедуры

#КонецОбласти

#Область ОбновлениеИнформационнойБазы

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьКОбработкеДокументыБезНДС(Параметры) Экспорт

	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Дата УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Дата УБЫВ");
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	
	ОперацииБезНДС = Новый Массив;
	Для каждого ВидОперации Из Перечисления.бит_ВидыОперацийКазначейства Цикл
		Если бит_КазначействоКлиентСервер.ОперацияБезНДС(ВидОперации) Тогда
			ОперацииБезНДС.Добавить(ВидОперации);	
		КонецЕсли;	
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ОперацииБезНДС", ОперацииБезНДС);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Реквизиты.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК Реквизиты
	|ГДЕ
	|	(Реквизиты.СтавкаНДС <> ЗНАЧЕНИЕ(Справочник.СтавкиНДС.БезНДС)
	|			ИЛИ Реквизиты.СуммаНДС <> 0)
	|	И Реквизиты.ХозяйственнаяОперация В(&ОперацииБезНДС)";
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));	

КонецПроцедуры

// Обработчик обновления.
// 
// Параметры:
//  Параметры - Структура - параметры.
//
Процедура ОбработатьДокументыБезНДСОтложенно(Параметры) Экспорт
	
	ПолноеИмяОбъекта  = ПустаяСсылка().Метаданные().ПолноеИмя();
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Для Каждого Документ Из ОбновляемыеДанные Цикл
		
		НачатьТранзакцию();
		
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Документ.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			Блокировка.Заблокировать();
			
			ДокументОбъект = Документ.Ссылка.ПолучитьОбъект(); // ДокументОбъект
			
			ОбъектИзменен = Ложь;
			
			Если ДокументОбъект <> Неопределено Тогда
				Если ДокументОбъект.СтавкаНДС <> Справочники.СтавкиНДС.БезНДС
				 ИЛИ ДокументОбъект.СуммаНДС <> 0 Тогда
					ДокументОбъект.СтавкаНДС = Справочники.СтавкиНДС.БезНДС;
					ДокументОбъект.СуммаНДС  = 0;
					ОбъектИзменен = Истина;	
				КонецЕсли;					
			КонецЕсли;
			
			Если ОбъектИзменен ИЛИ ДокументОбъект <> Неопределено И ДокументОбъект.Модифицированность() Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
			Иначе
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Документ.Ссылка);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			бит_ОбновлениеИнформационнойБазыБФ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Документ.Ссылка);
		КонецПопытки;
	КонецЦикла;
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта);

КонецПроцедуры

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьКОбработкеДокументыБезПланированияСуммы(Параметры) Экспорт

	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Дата УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Дата УБЫВ");
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК Реквизиты
	|ГДЕ
	|	Реквизиты.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ПустаяСсылка)";
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));	

КонецПроцедуры

// Обработчик обновления.
// 
// Параметры:
//  Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке.
//
Процедура ОбработатьДокументыБезПланированияСуммыОтложенно(Параметры) Экспорт
		
	МетаданныеОбъекта = ПустаяСсылка().Метаданные();
	ПолноеИмяОбъекта  = МетаданныеОбъекта.ПолноеИмя();
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если НЕ ЗначениеЗаполнено(ОбновляемыеДанные) Тогда
		Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
											Параметры.Очередь, ПолноеИмяОбъекта);
		Возврат;
	КонецЕсли;
	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылки", ОбновляемыеДанные.ВыгрузитьКолонку("Ссылка"));
	Запрос.Текст = 
	
	// ВНИМАНИЕ. Текст запроса разбит маркерами.
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка,
	|	Реквизиты.ВалютаДокумента КАК ВалютаДокумента,
	|	Реквизиты.УдалитьКратностьДокумента КАК УдалитьКратностьДокумента,
	|	Реквизиты.УдалитьКурсДокумента КАК УдалитьКурсДокумента,
	|	Реквизиты.СуммаДокумента КАК СуммаДокумента,
	|	Реквизиты.ФормаОплаты КАК ФормаОплаты,
	|	ВЫБОР
	|		КОГДА Реквизиты.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа)
	|			ТОГДА Реквизиты.ВалютаДокумента
	|		ИНАЧЕ ВЫБОР
	|				КОГДА Реквизиты.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|					ТОГДА Реквизиты.БанковскийСчет.ВалютаДенежныхСредств
	|				ИНАЧЕ Реквизиты.БанковскийСчет.ВалютаДенежныхСредств
	|			КОНЕЦ
	|	КОНЕЦ КАК ВалютаДенежныхСредств,
	|	ВЫБОР
	|		КОГДА НЕ ОбъектыРасчетов.Ссылка ЕСТЬ NULL
	|			ТОГДА ОбъектыРасчетов.ВалютаВзаиморасчетов
	|		КОГДА НЕ ДоговорыКонтрагентов.Ссылка ЕСТЬ NULL
	|			ТОГДА ДоговорыКонтрагентов.ВалютаВзаиморасчетов
	// ++ НЕ УТ
	|		КОГДА НЕ ДоговорыАренды.Ссылка ЕСТЬ NULL
	|			ТОГДА ДоговорыАренды.ВалютаВзаиморасчетов
	// -- НЕ УТ
	|		ИНАЧЕ Реквизиты.ВалютаДокумента
	|	КОНЕЦ КАК ВалютаВзаиморасчетов,
	|	Реквизиты.ДатаПлан КАК Период,
	|	Реквизиты.ОбъектРасчетов КАК ОбъектРасчетов,
	|	Реквизиты.Договор КАК Договор
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК Реквизиты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
	|		ПО Реквизиты.ОбъектРасчетов = ОбъектыРасчетов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО Реквизиты.Договор = ДоговорыКонтрагентов.Ссылка
	// ++ НЕ УТ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыАренды КАК ДоговорыАренды
	|		ПО Реквизиты.ДоговорАренды = ДоговорыАренды.Ссылка
	// -- НЕ УТ
	|ГДЕ
	|	Реквизиты.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ПустаяСсылка)
	|	И Реквизиты.Ссылка В(&Ссылки)";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка 		 = РезультатЗапроса.Выбрать();
	
	ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();

	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			Блокировка.Заблокировать();
			
			ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			Если Выборка.ВалютаДокумента = Выборка.ВалютаВзаиморасчетов Тогда
				ДокументОбъект.ПланированиеСуммы 	= Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов;
				ДокументОбъект.ВалютаВзаиморасчетов = Выборка.ВалютаВзаиморасчетов;
				ДокументОбъект.КурсЧислительВзаиморасчетов   = 1;
				ДокументОбъект.КурсЗнаменательВзаиморасчетов = 1;
				ДокументОбъект.СуммаВзаиморасчетов		   	 = Выборка.СуммаДокумента;
			Иначе
				ДокументОбъект.ПланированиеСуммы 	= Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа;
				ДокументОбъект.ВалютаВзаиморасчетов = Выборка.ВалютаВзаиморасчетов;
				
				// Заполним курс взаиморасчетов.
				ПараметрыЗаполнения = ДенежныеСредстваСервер.ПараметрыЗаполненияКурсаИКратности();
				
				ПараметрыЗаполнения.Валюта 				 = Выборка.ВалютаДокумента;
				ПараметрыЗаполнения.ОбъектРасчетов		 = Выборка.ОбъектРасчетов;
				ПараметрыЗаполнения.Договор				 = Выборка.Договор;
				ПараметрыЗаполнения.ВалютаВзаиморасчетов = Выборка.ВалютаВзаиморасчетов;
				
				ПараметрыЗаполнения.ВалютаРегламентированногоУчета = ВалютаРеглУчета;
				ПараметрыЗаполнения.Дата						   = Выборка.Период;
				
				Данные = Новый Структура;
				Данные.Вставить("КурсЧислительВзаиморасчетов",  0);
				Данные.Вставить("КурсЗнаменательВзаиморасчетов",0);
				Данные.Вставить("ВариантКурсаДоговора", 		Перечисления.ВариантыКурсаДоговора.ПустаяСсылка());
				Данные.Вставить("ТипОбъектаРасчетов", 			Перечисления.ТипыОбъектовРасчетов.ПустаяСсылка());
				
				ДенежныеСредстваСервер.ЗаполнитьКурсИКратностьВСтрокеРасшифровки(Данные, ПараметрыЗаполнения);
				
				ЗаполнитьЗначенияСвойств(ДокументОбъект, Данные);

				// Рассчитаем Сумму взаиморасчетов.
				Данные = Новый Структура;
				Данные.Вставить("Сумма", 						 ДокументОбъект.СуммаДокумента);
				Данные.Вставить("КурсЧислительВзаиморасчетов",	 ДокументОбъект.КурсЧислительВзаиморасчетов);
				Данные.Вставить("КурсЗнаменательВзаиморасчетов", ДокументОбъект.КурсЗнаменательВзаиморасчетов);
				Данные.Вставить("СуммаВзаиморасчетов",			 ДокументОбъект.СуммаВзаиморасчетов);
				
				ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
					Данные, ДокументОбъект.ВалютаДокумента, Константы.ВалютаРегламентированногоУчета.Получить());
				
				ДокументОбъект.СуммаВзаиморасчетов = Данные.СуммаВзаиморасчетов; 		

			КонецЕсли;
			
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			
			ОбъектовОбработано = ОбъектовОбработано + 1;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			бит_ОбновлениеИнформационнойБазыБФ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Выборка.Ссылка);
		КонецПопытки;		
	КонецЦикла;
	
	Если ОбъектовОбработано = 0 И ПроблемныхОбъектов <> 0 Тогда
		ШаблонСообщения = НСтр("ru = 'Не удалось обработать некоторые документы ""Платежная позиция"" (пропущены): %1'; 
								|en = 'Some documents ""Payment record"" could not be processed (skipped): %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ПроблемныхОбъектов);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация, МетаданныеОбъекта,, ТекстСообщения);
	Иначе
		ШаблонСообщения = НСтр("ru = 'Обработана очередная порция документов ""Платежная позиция"": %1';
								|en = 'The next batch of documents ""Payment record"" has been processed: %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ОбъектовОбработано);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация,
			МетаданныеОбъекта,, ТекстСообщения);
	КонецЕсли;
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
		Параметры.Очередь, ПолноеИмяОбъекта);

КонецПроцедуры

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьКОбработкеДокументыБезПартнера(Параметры) Экспорт
	
	ВидыОпераций = ВидыОперацийДляОбновитьДокументыБезПартнера();
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ПлатежныеПозиции.Ссылка КАК Ссылка,
	|	ПлатежныеПозиции.ОбъектРасчетов КАК ОбъектРасчетов,
	|	ПлатежныеПозиции.Контрагент КАК Контрагент,
	|	ПлатежныеПозиции.Договор КАК Договор
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|ГДЕ
	|	ПлатежныеПозиции.ХозяйственнаяОперация В(&ВидыОпераций)
	|	И (ПлатежныеПозиции.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|			ИЛИ ПлатежныеПозиции.ОбъектРасчетов <> ЗНАЧЕНИЕ(Справочник.ОбъектыРасчетов.ПустаяСсылка)
	|			ИЛИ (ПлатежныеПозиции.Договор <> НЕОПРЕДЕЛЕНО
	|				И ПлатежныеПозиции.Договор ССЫЛКА Справочник.ДоговорыКонтрагентов
	|				И ПлатежныеПозиции.Договор <> ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)))
	|	И ПлатежныеПозиции.Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|	И Ссылка > &Ссылка
	|УПОРЯДОЧИТЬ ПО Ссылка";
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Дата УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Дата УБЫВ");
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	
	ОтработаныВсеДокументы = Ложь;
	Ссылка 				   = "";    
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса; 
	Запрос.УстановитьПараметр("ВидыОпераций", ВидыОпераций.ВыгрузитьКолонку("ВидОперации"));

	Пока НЕ ОтработаныВсеДокументы Цикл
		
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		ДокументыДляОбработки = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
		
		ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, ДокументыДляОбработки);
		
		КоличествоСсылок = ДокументыДляОбработки.Количество();
		Если КоличествоСсылок < 1000 Тогда
			ОтработаныВсеДокументы = Истина;
		КонецЕсли;
		
		Если КоличествоСсылок > 0 Тогда
			Ссылка = ДокументыДляОбработки[КоличествоСсылок - 1];
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

// Обработчик обновления.
// 
// Параметры:
//  Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке.
//
Процедура ОбработатьДокументыБезПартнераОтложенно(Параметры) Экспорт
			
	МетаданныеОбъекта = ПустаяСсылка().Метаданные();
	ПолноеИмяОбъекта  = МетаданныеОбъекта.ПолноеИмя();
	ВыбранныеДанные   = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если НЕ ЗначениеЗаполнено(ВыбранныеДанные) Тогда
		Параметры.ОбработкаЗавершена = Истина;
		Возврат;
	КонецЕсли;                                            
		
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;

	ИспользоватьПартнеровИКонтрагентов = ПолучитьФункциональнуюОпцию("ИспользоватьПартнеровИКонтрагентов");
	
	Если ИспользоватьПартнеровИКонтрагентов Тогда
	
		ВидыОпераций = ВидыОперацийДляОбновитьДокументыБезПартнера();
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Ссылки", ВыбранныеДанные.ВыгрузитьКолонку("Ссылка"));
		Запрос.УстановитьПараметр("ВидыОпераций", ВидыОпераций);
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ВидыОпераций.ВидОперации КАК ВидОперации,
		|	ВидыОпераций.ХозОперацияУП КАК ХозОперацияУП
		|ПОМЕСТИТЬ ВидыОпераций
		|ИЗ
		|	&ВидыОпераций КАК ВидыОпераций
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПлатежныеПозиции.Ссылка КАК Ссылка,
		|	ПлатежныеПозиции.ОбъектРасчетов КАК ОбъектРасчетов,
		|	ПлатежныеПозиции.Контрагент КАК Контрагент,
		|	ПлатежныеПозиции.Договор КАК Договор,
		|	ПлатежныеПозиции.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	ВидыОпераций.ХозОперацияУП КАК ХозОперацияУП
		|ИЗ
		|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВидыОпераций КАК ВидыОпераций
		|		ПО ПлатежныеПозиции.ХозяйственнаяОперация = ВидыОпераций.ВидОперации
		|ГДЕ
		|	ПлатежныеПозиции.Ссылка В(&Ссылки)";
		
		РезультатЗапроса = Запрос.Выполнить();
		Выборка 		 = РезультатЗапроса.Выбрать();
	    
		Пока Выборка.Следующий() Цикл
			
			НачатьТранзакцию();
			
			Попытка
				
				Блокировка = Новый БлокировкаДанных;
				
				ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
				ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
				ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
				
				Блокировка.Заблокировать();
				
				Если ЗначениеЗаполнено(Выборка.ХозОперацияУП) Тогда
					ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
					
					Если ЗначениеЗаполнено(Выборка.Контрагент) Тогда
						ДокументОбъект.Партнер = ДенежныеСредстваСервер.ПолучитьПартнераПоКонтрагенту(ДокументОбъект.Контрагент, Выборка.ХозОперацияУП);	
					КонецЕсли;
					
					Если НЕ ЗначениеЗаполнено(ДокументОбъект.Партнер) И ЗначениеЗаполнено(Выборка.ОбъектРасчетов) Тогда
						ДокументОбъект.Партнер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Выборка.ОбъектРасчетов, "Партнер");	
					КонецЕсли; 
		
					Если НЕ ЗначениеЗаполнено(ДокументОбъект.Партнер) И ЗначениеЗаполнено(Выборка.Договор) Тогда
						ДокументОбъект.Партнер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Выборка.Договор, "Партнер");	
					КонецЕсли;

					ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);				
				КонецЕсли;
				
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
				
				ОбъектовОбработано = ОбъектовОбработано + 1;
				
				ЗафиксироватьТранзакцию();
				
			Исключение
				
				ОтменитьТранзакцию();
				ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
				бит_ОбновлениеИнформационнойБазыБФ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Выборка.Ссылка);
			КонецПопытки;		
		КонецЦикла;
	
	Иначе
        Для каждого СтрокаТаблицы Из ВыбранныеДанные Цикл
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(СтрокаТаблицы.Ссылка);		
			ОбъектовОбработано = ОбъектовОбработано + 1;		
		КонецЦикла;
	КонецЕсли;

	Если ОбъектовОбработано = 0 И ПроблемныхОбъектов <> 0 Тогда
		ШаблонСообщения = НСтр("ru = 'Не удалось обработать некоторые документы ""Платежная позиция"" (пропущены): %1'; 
								|en = 'Some documents ""Payment record"" could not be processed (skipped): %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ПроблемныхОбъектов);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация, МетаданныеОбъекта,, ТекстСообщения);
	Иначе
		ШаблонСообщения = НСтр("ru = 'Обработана очередная порция документов ""Платежная позиция"": %1';
								|en = 'The next batch of documents ""Payment record"" has been processed: %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ОбъектовОбработано);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация,
			МетаданныеОбъекта,, ТекстСообщения);
	КонецЕсли;
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
										Параметры.Очередь, ПолноеИмяОбъекта);
	
КонецПроцедуры

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьКОбработкеДокументыДляИзмененияНалога(Параметры) Экспорт
	
	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.СпособВыборки 		 = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Дата УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Дата УБЫВ");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ДанныеДокумента
	|ГДЕ
	|	ДанныеДокумента.ТипНалога = ЗНАЧЕНИЕ(Справочник.ВидыНалоговВзносов.ПустаяСсылка)
	|	И НЕ ДанныеДокумента.УдалитьТипНалога = Значение(Перечисление.УдалитьТипыНалогов.ПустаяСсылка)";
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
	
КонецПроцедуры

// Обработчик обновления
// 
// Параметры:
// 	Параметры - См. ОбновлениеИнформационнойБазы.ДополнительныеПараметрыВыборкиДанныхДляМногопоточнойОбработки 
//
Процедура ОбработатьДокументыДляИзмененияНалогаОтложенно(Параметры) Экспорт
	
	Параметры.ОбработкаЗавершена = Ложь;
	
	МетаданныеОбъекта = ПустаяСсылка().Метаданные();
	ПолноеИмяОбъекта  = МетаданныеОбъекта.ПолноеИмя();
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если ОбновляемыеДанные.Количество() = 0 Тогда
		Параметры.ОбработкаЗавершена =
			ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта);
		Возврат;
	КонецЕсли;
	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;
	ИсключенияПриОбновлении = Новый Массив;
			
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДанныеДляОбновления", ОбновляемыеДанные);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДанныеДляОбновления.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ТаблицаДокументов
	|ИЗ
	|	&ДанныеДляОбновления КАК ДанныеДляОбновления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаДокументов.Ссылка КАК Ссылка,
	|	ДанныеДокумента.ВерсияДанных КАК ВерсияДанных
	|ИЗ
	|	ТаблицаДокументов КАК ТаблицаДокументов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК ДанныеДокумента
	|		ПО ТаблицаДокументов.Ссылка = ДанныеДокумента.Ссылка
	|";	
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ПричинаИсключения = 0;
		Рекомендация = "";
		
		НачатьТранзакцию();
		
		Попытка
			
			ПричинаИсключения = 1; // Блокировка
			
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			
			Блокировка.Заблокировать();
			
			ПредставлениеСсылки = Строка(Выборка.Ссылка);
			ДокументОбъект	    = Выборка.Ссылка.ПолучитьОбъект();
			
			Если ДокументОбъект = Неопределено Тогда
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			ИначеЕсли ДокументОбъект.ВерсияДанных <> Выборка.ВерсияДанных Тогда
				ДокументОбъект = Неопределено;
			КонецЕсли;	
							
			ОбъектИзменен = Ложь;
			
			Если ДокументОбъект <> Неопределено Тогда
				
				Перечисления.УдалитьТипыНалогов.ЗаполнитьРеквизитТипНалога(ДокументОбъект,"УдалитьТипНалога","ТипНалога");

				Если ДокументОбъект.Модифицированность() Тогда
					ОбъектИзменен = Истина;
				КонецЕсли;				
			КонецЕсли;
			
			Если ОбъектИзменен Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
			Иначе
				ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			КонецЕсли;
			
			ОбъектовОбработано = ОбъектовОбработано + 1;
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			ОбновлениеИнформационнойБазы.ЗаписатьОшибкуВЖурналРегистрации(Выборка.Ссылка, ПредставлениеСсылки, 
				ИнформацияОбОшибке());			
		КонецПопытки;
	КонецЦикла;
	
	Параметры.ОбработкаЗавершена =
		ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(Параметры.Очередь, ПолноеИмяОбъекта);
		
	ИмяПроцедуры = "ОбработатьДокументыДляИзмененияНалогаОтложенно";
	Если ОбъектовОбработано = 0 И ПроблемныхОбъектов <> 0 Тогда
		ШаблонСообщения = НСтр("ru = 'Процедуре ""%1"" не удалось обработать некоторые документы ""Платежная позиция"" (пропущены): %2'; 
								|en = '""%1"": some documents ""Payment record"" could not be processed (skipped): %2'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ИмяПроцедуры, ПроблемныхОбъектов);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация, МетаданныеОбъекта,, ТекстСообщения);
	Иначе
		ШаблонСообщения = НСтр("ru = 'Обработана очередная порция документов ""Платежная позиция"": %1';
								|en = 'The next batch of documents ""Payment record"" has been processed: %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ОбъектовОбработано);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация,
			МетаданныеОбъекта,, ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти // ОбновлениеИнформационнойБазы

// СтандартныеПодсистемы.ВерсионированиеОбъектов
// Определяет настройки объекта для подсистемы ВерсионированиеОбъектов.
//
// Параметры:
// Настройки - Структура - настройки подсистемы.
Процедура ПриОпределенииНастроекВерсионированияОбъектов(Настройки) Экспорт
	
КонецПроцедуры
// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

// СтандартныеПодсистемы.ВариантыОтчетов
// Определяет список команд отчетов.
//
// Параметры:
//   КомандыОтчетов - ТаблицаЗначений - Таблица с командами отчетов. Для изменения.
//       См. описание 1 параметра процедуры ВариантыОтчетовПереопределяемый.ПередДобавлениемКомандОтчетов().
//   Параметры - Структура - Вспомогательные параметры. Для чтения.
//       См. описание 2 параметра процедуры ВариантыОтчетовПереопределяемый.ПередДобавлениемКомандОтчетов().
//
Процедура ДобавитьКомандыОтчетов(КомандыОтчетов, Параметры) Экспорт
	
	ИнтеграцияИСПереопределяемый.ДобавитьКомандуСтруктураПодчиненности(КомандыОтчетов);
	
	Если ПравоДоступа("Просмотр", Метаданные.Отчеты.бит_ЗаявкиВключенныеВРеестрПлатежей) Тогда
        Команда = КомандыОтчетов.Добавить();
        Команда.Представление      = НСтр("ru = 'Заявки в реестре платежей'");
        Команда.МножественныйВыбор = Истина;
        Команда.ИмяПараметраФормы  = "Отбор.ПлатежнаяПозиция";
        Команда.КлючВарианта       = "ЗаявкиВключенныеВРеестрПлатежей";
        Команда.Менеджер           = "Отчет.бит_ЗаявкиВключенныеВРеестрПлатежей";
		
		ПодключаемыеКоманды.ДобавитьУсловиеВидимостиКоманды(Команда, "ВидПлана", Перечисления.бит_кзн_ВидыПланов.План);
	КонецЕсли;

	Если ПравоДоступа("Просмотр", Метаданные.Отчеты.бит_ПлатежныеДокументы) Тогда
        Команда = КомандыОтчетов.Добавить();
        Команда.Представление      = НСтр("ru = 'Документы оплаты'");
        Команда.МножественныйВыбор = Истина;
        Команда.ИмяПараметраФормы  = "Отбор.Позиция";
        Команда.КлючВарианта       = "ПлатежныеДокументы";
        Команда.Менеджер           = "Отчет.бит_ПлатежныеДокументы";
		
		ПодключаемыеКоманды.ДобавитьУсловиеВидимостиКоманды(Команда, "ВидПлана", Перечисления.бит_кзн_ВидыПланов.План);
	КонецЕсли;

КонецПроцедуры
// Конец СтандартныеПодсистемы.ВариантыОтчетов

// СтандартныеПодсистемы.Печать

// Переопределяет настройки печати для объекта.
//
// Параметры:
//  Настройки - см. УправлениеПечатью.НастройкиПечатиОбъекта.
//
Процедура ПриОпределенииНастроекПечати(Настройки) Экспорт
	
	Настройки.ПриДобавленииКомандПечати = Истина;
		
КонецПроцедуры

// Заполняет список команд печати.
//
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	// Заявка на оплату.
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.Идентификатор = "ПечатьЗаявкаНаОплату";
	КомандаПечати.Представление = НСтр("ru='Заявка на оплату';en='Request for Payment'");
	Если НЕ бит_ОбщегоНазначения.ЭтоУТ() Тогда
		КомандаПечати.Обработчик = "УправлениеПечатьюБПКлиент.ВыполнитьКомандуПечати";
	КонецЕсли;
	КомандаПечати.Порядок = 10;	
	
КонецПроцедуры

// Формирует печатные формы.
//
// Параметры:
//  МассивОбъектов  - Массив    - ссылки на объекты, которые нужно распечатать;
//  ПараметрыПечати - Структура - дополнительные настройки печати;
//  КоллекцияПечатныхФорм - ТаблицаЗначений - сформированные табличные документы (выходной параметр)
//  ОбъектыПечати         - СписокЗначений  - значение - ссылка на объект;
//                                            представление - имя области в которой был выведен объект (выходной параметр);
//  ПараметрыВывода       - Структура       - дополнительные параметры сформированных табличных документов (выходной параметр).
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Ссылки", МассивОбъектов);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПлатежнаяПозиция.ДокументПланирования КАК ДокументПланирования
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПозиция
	|ГДЕ
	|	ПлатежнаяПозиция.Ссылка В(&Ссылки)
	|	И ПлатежнаяПозиция.ДокументПланирования ССЫЛКА Документ.бит_кзн_ЗаявкаНаРасходованиеСредств
	|	И ПлатежнаяПозиция.ДокументПланирования <> ЗНАЧЕНИЕ(Документ.бит_кзн_ЗаявкаНаРасходованиеСредств.ПустаяСсылка)
	|	И НЕ ПлатежнаяПозиция.ПометкаУдаления";
	
	Результат = Запрос.Выполнить();
	МассивОбъектов = Результат.Выгрузить().ВыгрузитьКолонку("ДокументПланирования");
	
	Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода);
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.Печать

// Формирует описание реквизитов объекта, заполняемых по статистике их использования.
//
// Параметры:
//  ОписаниеРеквизитов - Структура - описание реквизитов, для которых необходимо получить значения по статистике
//
//
Процедура ЗадатьОписаниеЗаполняемыхРеквизитовПоСтатистике(ОписаниеРеквизитов) Экспорт
	
	Параметры = ЗаполнениеОбъектовПоСтатистике.ПараметрыЗаполняемыхРеквизитов();
	Параметры.РазрезыСбораСтатистики.ИспользоватьТолькоЗаполненные = "Организация, Подразделение";
	ЗаполнениеОбъектовПоСтатистике.ДобавитьОписаниеЗаполняемыхРеквизитов(
		ОписаниеРеквизитов, "Ответственный", Параметры);
	
КонецПроцедуры

// ++ НЕ УТ
// Возвращает параметры настройки счетов учета в документе.
// 
// Параметры:
// 	ВидОперации - ПеречислениеСсылка.бит_ВидыОперацийКазначейства - Хозяйственная операция документа.
// 	
// Возвращаемое значение:
// 	Массив - Массив параметров настройки счетов учета (См. НастройкаСчетовУчетаСервер.ПараметрыНастройкиСчетаУчетаОперации).
//
Функция ПараметрыНастройкиСчетовУчета(ВидОперации, ТипНалога) Экспорт
	
	МассивПараметров = Новый Массив();
	
	ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияУП(ВидОперации);
	
	ПараметрыНастройки = НастройкаСчетовУчетаСервер.ПараметрыНастройки();
	ПараметрыНастройки.ПутьКДанным = "Объект";
	ПараметрыНастройки.ДоступностьПоОперации =
		ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет;
	
	ПараметрыНастройки.СтатьяАктивовПассивов = "";
	ПараметрыНастройки.АналитикаАктивовПассивов = "";
	ПараметрыНастройки.Представление = "ПредставлениеОтраженияВРеглУчете";
	
	ПараметрыНастройки.Организация = "Объект.Организация";
	
	ПараметрыНастройки.ЭлементыФормы.Добавить("ПредставлениеОтраженияВРеглУчете");
	
	МассивПараметров.Добавить(ПараметрыНастройки);

	Возврат МассивПараметров;
	
КонецФункции // -- НЕ УТ

// Возвращает параметры механизма взаиморасчетов.
//
// Параметры:
// 	ДанныеЗаполнения - ДокументОбъект, СправочникОбъект, Структура, ДанныеФормыСтруктура - Объект или коллекция для
//              расчета параметров взаиморасчетов.
//
// Возвращаемое значение:
// 	Структура - Структура параметров функций механизма взаиморасчетов (См. ВзаиморасчетыСервер.ПараметрыМеханизма)
//
Функция ПараметрыВзаиморасчеты(ДанныеЗаполнения = Неопределено) Экспорт
	
	Если ДанныеЗаполнения = Неопределено Тогда
		ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
	Иначе	
		ФормаОплаты = ДанныеЗаполнения.ФормаОплаты;
	КонецЕсли;

	ОплатаЧерезБанк = (ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные);
	
	Если ДанныеЗаполнения = Неопределено Тогда
		ХозяйственнаяОперация = Неопределено;
		Контрагент			  = Неопределено;
	Иначе
		Если ОбщегоНазначения.ЗначениеСсылочногоТипа(ДанныеЗаполнения) Тогда
			РеквизитыОбъекта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеЗаполнения, 
									"ХозяйственнаяОперация, Контрагент"); 
		Иначе
			РеквизитыОбъекта = Новый Структура("ХозяйственнаяОперация, Контрагент");
			ЗаполнитьЗначенияСвойств(РеквизитыОбъекта, ДанныеЗаполнения);
		КонецЕсли;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияУП(РеквизитыОбъекта.ХозяйственнаяОперация);
		Контрагент			  = РеквизитыОбъекта.Контрагент;
	КонецЕсли;

	СтруктураПараметров = ВзаиморасчетыСервер.ПараметрыМеханизма();
	
	Если ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту
		ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствВДругуюОрганизацию Тогда
		СтруктураПараметров.ТипРасчетов                      = Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом;
	ИначеЕсли ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаПоставщику
		ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаДенежныхСредствВДругуюОрганизацию
		ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПеречислениеТаможне Тогда
		СтруктураПараметров.ТипРасчетов                      = Перечисления.ТипыРасчетовСПартнерами.РасчетыСПоставщиком;
	КонецЕсли;
	
	СтруктураПараметров.ИзменяетПланОплаты = ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту
		ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствВДругуюОрганизацию
		ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаПоставщику
		ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаДенежныхСредствВДругуюОрганизацию
		ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПеречислениеТаможне;
	
	СтруктураПараметров.ИзменяетПланОтгрузкиПоставки = Ложь;
	
	Если Контрагент = Неопределено Тогда
		СтруктураПараметров.Партнер = "";
	Иначе	
		СтруктураПараметров.Партнер = "Объект.Партнер";
	КонецЕсли;
									
	Если ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствВДругуюОрганизацию
		ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаДенежныхСредствВДругуюОрганизацию Тогда
		СтруктураПараметров.Контрагент = "Объект.ОрганизацияПолучатель";
		СтруктураПараметров.Партнер    = Справочники.Партнеры.НашеПредприятие;
	Иначе
		СтруктураПараметров.Контрагент = "Объект.Контрагент";
		СтруктураПараметров.Партнер	   = "Объект.Партнер";
	КонецЕсли;
	
	СтруктураПараметров.ВалютаДокумента			  = "Объект.ВалютаДокумента";
	СтруктураПараметров.ВалютаВзаиморасчетов	  = "Объект.ВалютаВзаиморасчетов";
	СтруктураПараметров.КурсЧислитель             = "";
	СтруктураПараметров.КурсЗнаменатель           = "";
	СтруктураПараметров.ПорядокРасчетов           = "";
	
	СтруктураПараметров.ФормаОплаты               = ?(ОплатаЧерезБанк, Перечисления.ФормыОплаты.Безналичная, Перечисления.ФормыОплаты.Наличная);
	СтруктураПараметров.ОплатаВВалюте             = "";
	
	СтруктураПараметров.Организация               = "Объект.Организация";
	СтруктураПараметров.Соглашение                = "";
	СтруктураПараметров.Договор                   = "Объект.Договор";
	СтруктураПараметров.БанковскийСчетОрганизации = ?(ОплатаЧерезБанк, "Объект.БанковскийСчет", "");
	СтруктураПараметров.БанковскийСчетКонтрагента = "";
	СтруктураПараметров.Касса                     = ?(ОплатаЧерезБанк, "", "Объект.Касса");
	СтруктураПараметров.Дата                      = "Объект.Дата";
	СтруктураПараметров.ИдентификаторПлатежа      = "";
	
	СтруктураПараметров.НомерВходящегоДокумента   = "";
	СтруктураПараметров.ДатаВходящегоДокумента    = "";
	СтруктураПараметров.НалогообложениеНДС        = "";
	СтруктураПараметров.НаправлениеДеятельности   = "";
	СтруктураПараметров.ПлатежиПо275ФЗ			  = "Объект.ПлатежиПо275ФЗ";
	
	// Инициализация своего ключа.
	СтруктураПараметров.ЭлементыФормы.Вставить("ОбъектРасчетов", "ОбъектРасчетов");
	
	СтруктураПараметров.ПартнерПрочиеОтношения = ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПеречислениеТаможне;
	
	СтруктураПараметров.ПодборТолькоБезусловнойЗадолженности = ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту
		ИЛИ ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствВДругуюОрганизацию;
	
	Возврат СтруктураПараметров;
	
КонецФункции
 
#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область ВводНаОсновании

Функция ДанныеЗаполненияИзОснования(Основание) Экспорт
	
	// См. бит_КазначействоКлиент.СоздатьЗаявкуНаРасходованиеСредств()
	
	ДанныеЗаполения = Новый Структура;

	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
		Результат = ДанныеЗаполненияПоПоПоступлениюТоваров(Основание, ДанныеЗаполения);
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		Результат = ДанныеЗаполненияПоЗаказуПоставщику(Основание, ДанныеЗаполения);
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
		Результат = ДанныеЗаполненияИзЗаявкиНаРасходование(Основание);
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.ПриобретениеУслугПрочихАктивов") Тогда
		Результат = ДанныеЗаполненияПоПоступлениюУслугИВнеоборотныхАктивов(Основание, ДанныеЗаполения);
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда	
		Результат = ДанныеЗаполненияПоЗаявкеНаПеремещение(Основание);
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.АвансовыйОтчет") Тогда
		Результат = ДанныеЗаполненияПоАвансовомуОтчету(Основание, ДанныеЗаполения);
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаявкаНаВозвратТоваровОтКлиента") Тогда
		Результат = ДанныеЗаполненияПоЗаявкеНаВозвратТоваровОтКлиента(Основание, ДанныеЗаполения);	
	// ++ НЕ УТ 
	ИначеЕсли НЕ бит_ОбщегоНазначения.ЭтоУТ() И ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПереработчику2_5") Тогда
		Результат = ДанныеЗаполненияПоЗаказуПереработчику2_5(Основание, ДанныеЗаполения);
	ИначеЕсли НЕ бит_ОбщегоНазначения.ЭтоУТ() И ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПереработчику") Тогда
		Результат = ДанныеЗаполненияПоЗаказуПереработчику(Основание, ДанныеЗаполения);
	ИначеЕсли НЕ бит_ОбщегоНазначения.ЭтоУТ() И ТипЗнч(Основание) = Тип("СправочникСсылка.ДоговорыАренды") Тогда
		Результат = ДанныеЗаполненияПоДоговоруАренды(Основание, ДанныеЗаполения);		
	// -- НЕ УТ 
	Иначе
		Если ТипЗнч(Основание) = Тип("Массив") Тогда
			Результат = Основание;
		Иначе	
			Результат = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Основание);
		КонецЕсли;
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

Функция РеквизитыОбъектаДляПодстановкиВАналитики(Объект) Экспорт
	
	Результат = Новый Массив;
	Результат.Добавить(Объект.ГруппаФинансовогоУчета);
	Результат.Добавить(Объект.Подразделение);
	Результат.Добавить(Объект.Касса);
	Результат.Добавить(Объект.БанковскийСчет);
	Результат.Добавить(Объект.ФизЛицо);
	Результат.Добавить(Объект.БанковскийСчетПолучателя);
	Результат.Добавить(Объект.ОбъектРасчетов);
	Результат.Добавить(Объект.Контрагент);
	Результат.Добавить(Объект.Договор);
	Результат.Добавить(Объект.НаправлениеДеятельности);
	Результат.Добавить(Объект.ЦФО);	
	Результат.Добавить(Объект.Организация);
	Результат.Добавить(Объект.СтатьяОборотов);
	
	Если ЗначениеЗаполнено(Объект.Договор) Тогда
		Проект = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "бит_Проект");
		Результат.Добавить(Проект);
	КонецЕсли;
	
	Возврат Результат;	

КонецФункции

#КонецОбласти

#Область Проведение

Функция ПодготовитьПараметрыПроведения(ПлатежнаяПозиция, Отказ) Экспорт

	ПараметрыПроведения = Новый Структура;
	ПараметрыПроведения.Вставить("ПланируемыйРасходСписаниеРеквизиты",	 Новый ТаблицаЗначений);
	ПараметрыПроведения.Вставить("ПланируемыйРасходСписание",			 Новый ТаблицаЗначений);
	ПараметрыПроведения.Вставить("ПланируемыйРасходСписаниеСАналитиками",Новый ТаблицаЗначений);
	ПараметрыПроведения.Вставить("ИсполнениеБюджетаРеквизиты", 
		бит_КонтрольИсполненияБюджета.ПустаяТаблицаИсполнениеБюджетаРеквизиты());
	ПараметрыПроведения.Вставить("ИсполнениеБюджета",
		бит_КонтрольИсполненияБюджета.ПустаяТаблицаИсполнениеБюджетаДляЦелейКонтроля());

	Реквизиты = РеквизитыПлатежнойПозиции(ПлатежнаяПозиция);
		
	Если НЕ бит_ОбщегоНазначения.ВалютаУпрУчетаУстановлена(Истина, ПлатежнаяПозиция) Тогда
		Отказ = Истина;
		Возврат ПараметрыПроведения;
	КонецЕсли;
	
	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("Организация", Реквизиты.Организация);
	ПараметрыНастройки.Вставить("ЦФО",		   Реквизиты.ЦФО);
	
	Если Реквизиты.ОтключитьКонтрольЗаявокПоЛимитам Тогда
		КонтролироватьБюджет = Ложь;
	Иначе	
		КонтролироватьБюджет = бит_НастройкиПрограммы.КонтролироватьЗаявкуПоБюджету(ПараметрыНастройки, Реквизиты.Период);
	КонецЕсли;	
	
	НеУчитыватьСверхБюджета = бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеЗаявкиПриКонтролеПоБюджету(ПараметрыНастройки, 
									Реквизиты.Период);
									
	ОтразитьИсполнениеБюджета = Реквизиты.ВидПлана <> Перечисления.бит_кзн_ВидыПланов.Прогноз;
	
	СписатьПрогноз = ЗначениеЗаполнено(Реквизиты.Прогноз) 
	   			   И ТипЗнч(Реквизиты.ДокументОснование) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция");
		
	Реквизиты.Вставить("СписатьПрогноз", СписатьПрогноз);
	Реквизиты.Вставить("ВалютаРегламентированногоУчета", Константы.ВалютаРегламентированногоУчета.Получить());	
	
	ОбъектРасчетов = ?(ЗначениеЗаполнено(Реквизиты.ОбъектРасчетов), Реквизиты.ОбъектРасчетов, Реквизиты.Договор);
	
	Коэффициенты = бит_Казначейство.ПолучитьКоэффициентыПересчетаВалюты(Реквизиты.Валюта,
					Реквизиты.ВалютаДенежныхСредств, Реквизиты.Период, Реквизиты.Организация,,, 
					ОбъектРасчетов);

	КоэффициентыСценария = бит_Казначейство.ПолучитьКоэффициентыПересчетаВалюты(Реквизиты.Валюта,
					Реквизиты.ВалютаСценария, Реквизиты.Период, Реквизиты.Организация,,, 
					ОбъектРасчетов);
													
	Реквизиты.Вставить("КоэффициентПересчетаВВалютуУпр",             Коэффициенты.КоэффициентПересчетаВВалютуУпр);
	Реквизиты.Вставить("КоэффициентПересчетаВВалютуРегл",            Коэффициенты.КоэффициентПересчетаВВалютуРегл);
	Реквизиты.Вставить("КоэффициентПересчетаВВалютуДенежныхСредств", Коэффициенты.КоэффициентПересчетаВВалютуВзаиморасчетов);
	Реквизиты.Вставить("КоэффициентПересчетаВВалютуСценария", 	 	 КоэффициентыСценария.КоэффициентПересчетаВВалютуВзаиморасчетов);
			
	ПараметрыПроведения.Вставить("Реквизиты", Реквизиты);

	ЭтоСсылка = (ТипЗнч(ПлатежнаяПозиция) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция"));
	Если ЭтоСсылка Тогда 
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Ссылка",                  ПлатежнаяПозиция);
		Запрос.УстановитьПараметр("Прогноз", 				 Реквизиты.Прогноз);
		Запрос.УстановитьПараметр("СуммаДокумента", 		 Реквизиты.СуммаДокумента); // Что бы отразить прогноз на сумму плана.
		Запрос.УстановитьПараметр("КонтролироватьБюджет", 	 КонтролироватьБюджет);
		Запрос.УстановитьПараметр("НеУчитыватьСверхБюджета", НеУчитыватьСверхБюджета);

		НомераТаблиц = Новый Структура;
		Запрос.Текст = ТекстЗапросаПланируемыйРасходСписание(НомераТаблиц, СписатьПрогноз)
					 + ТекстЗапросаПланируемыйРасходПоступление(НомераТаблиц)
					 + ТекстЗапросаКонтрольИсполненияБюджета(НомераТаблиц, ОтразитьИсполнениеБюджета);

		Результат = Запрос.ВыполнитьПакет();
		Для каждого НомерТаблицы Из НомераТаблиц Цикл
			ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
		КонецЦикла;
	Иначе
		ИсполнениеБюджетаРеквизиты = ПараметрыПроведения.ИсполнениеБюджетаРеквизиты;
		СтрокаРеквизитов           = ИсполнениеБюджетаРеквизиты.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаРеквизитов, Реквизиты);
		СтрокаРеквизитов.КонтролироватьБюджет    = КонтролироватьБюджет;
		СтрокаРеквизитов.НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета;
		СтрокаРеквизитов.РежимКонтроля           = Перечисления.бит_РежимыКонтроляПоБюджету.Заявки;
		СтрокаРеквизитов.СценарийКонтролируемый  = Реквизиты.Сценарий;
		
		ИсполнениеБюджета = ПараметрыПроведения.ИсполнениеБюджета;
		СтрокаИсполенения = ИсполнениеБюджета.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаИсполенения, Реквизиты);
		СтрокаИсполенения.КонтролироватьСумму    = Истина;
		
		КонтролироватьПоСтатье = Ложь;
		Если ЗначениеЗаполнено(Реквизиты.СтатьяОборотов) Тогда
			КонтролироватьПоСтатье = НЕ ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Реквизиты.СтатьяОборотов,
																					"НеКонтролировать_Заявки");
		КонецЕсли;
		СтрокаИсполенения.КонтролироватьПоСтатье = КонтролироватьПоСтатье;
	КонецЕсли;
	
	ПодготовитьРеквизитыПрогноза(ПараметрыПроведения, Реквизиты, Отказ);
	ПодготовитьТаблицыРасчетыВВалюте(ПараметрыПроведения, Реквизиты);
	
	Если ОтразитьИсполнениеБюджета Тогда
		
		// Синоним списка нужен для вывода сообщения об ощибке.
		// Если списка нет, синоним заполнять не надо. В таком случае сообщение будет выведено около поля шапки.
		Если ПараметрыПроведения.ИсполнениеБюджета.Количество() = 1 Тогда
			СинонимСписка = "";
		Иначе	
			СинонимСписка = НСтр("ru = 'Распределение'; en = 'List'"); 
		КонецЕсли;
		
		ПараметрыПроведения.ИсполнениеБюджета.ЗаполнитьЗначения(СинонимСписка, "СинонимСписка");

		Для каждого СтрокаДокумента Из ПараметрыПроведения.ИсполнениеБюджета Цикл
			СтрокаДокумента.Сумма = СтрокаДокумента.Сумма * Реквизиты.КоэффициентПересчетаВВалютуСценария;
		КонецЦикла;
	КонецЕсли;

	Возврат ПараметрыПроведения;
	
КонецФункции

Процедура СформироватьПланируемыйРасходДенежныхСредств(ТаблицаПланируемыйРасход, Движения, Отказ) Экспорт

	Если ТаблицаПланируемыйРасход.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 	

	НаборЗаписей = Движения.бит_кзн_ПланируемыйРасходДенежныхСредств;
	НаборЗаписей.Записывать = Истина;
	
	Для каждого СтрокаТаблицы Из ТаблицаПланируемыйРасход Цикл
		Проводка = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(Проводка, СтрокаТаблицы);
	КонецЦикла;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

Процедура СформироватьПланируемыйРасходДенежныхСредствСАналитиками(ТаблицаПланируемыйРасход, Движения, Отказ) Экспорт

	Если ТаблицаПланируемыйРасход.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 	

	НаборЗаписей = Движения.бит_кзн_ПланируемыйРасходДенежныхСредствАналитика;
	НаборЗаписей.Записывать = Истина;
	
	Для каждого СтрокаТаблицы Из ТаблицаПланируемыйРасход Цикл
		Проводка = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(Проводка, СтрокаТаблицы);
	КонецЦикла;
	
КонецПроцедуры

Процедура СформироватьКонтрольныеЗначенияБюджетов(ТаблицаКонтрольныеЗначения, Реквизиты, Движения, Отказ) Экспорт

	Если ТаблицаКонтрольныеЗначения.Количество() = 0 Тогда
		Возврат;	
	КонецЕсли;
	
	НаборЗаписей = Движения.бит_КонтрольныеЗначенияБюджетов;
	НаборЗаписей.Записывать = Истина;
	
	Для каждого СтрокаТаблицы Из ТаблицаКонтрольныеЗначения Цикл
		Проводка = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(Проводка, СтрокаТаблицы);
		ЗаполнитьЗначенияСвойств(Проводка, Реквизиты, "Регистратор");
	КонецЦикла;

КонецПроцедуры
	
#КонецОбласти

// Добавляет команду создания документа "Заявка на расходование денежных средств (БИТ)".
//
// Параметры:
//   КомандыСозданияНаОсновании - ТаблицаЗначений - Таблица с командами создания на основании. Для изменения.
//       См. описание 1 параметра процедуры СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании().
//
Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании) Экспорт
	
	Если ПравоДоступа("Добавление", Метаданные.Документы.бит_кзн_ПлатежнаяПозиция) Тогда
		КомандаСоздатьНаОсновании = КомандыСозданияНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Обработчик = "бит_КазначействоКлиент.СоздатьЗаявкуНаРасходованиеСредств";
		КомандаСоздатьНаОсновании.Идентификатор = "СоздатьЗаявкуНаРасходованиеСредств";
		КомандаСоздатьНаОсновании.Представление = НСтр("ru='Заявка на расходование ДС (БИТ)';
													   |en='Application for spending DS (BIT)'");
		КомандаСоздатьНаОсновании.РежимЗаписи = "Проводить";		
		Возврат КомандаСоздатьНаОсновании;		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция КонтрольныеЗначенияВозвратаЛимита(ДокументСсылка) Экспорт
	
	Запрос = Новый Запрос;
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
		РезультатПоиска = НайтиПозициюПоОснованию(ДокументСсылка);
		Запрос.УстановитьПараметр("Регистратор", РезультатПоиска.МассивПозиций);
	Иначе
		Запрос.УстановитьПараметр("Регистратор", ДокументСсылка);
	КонецЕсли;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КонтрольныеЗначения.Период КАК Период,
	|	ЗНАЧЕНИЕ(Перечисление.бит_ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	КонтрольныеЗначения.Сценарий КАК Сценарий,
	|	КонтрольныеЗначения.ЦФО КАК ЦФО,
	|	КонтрольныеЗначения.СтатьяОборотов КАК СтатьяОборотов,
	|	КонтрольныеЗначения.Аналитика_1 КАК Аналитика_1,
	|	КонтрольныеЗначения.Аналитика_2 КАК Аналитика_2,
	|	КонтрольныеЗначения.Аналитика_3 КАК Аналитика_3,
	|	КонтрольныеЗначения.Аналитика_4 КАК Аналитика_4,
	|	КонтрольныеЗначения.Аналитика_5 КАК Аналитика_5,
	|	КонтрольныеЗначения.Аналитика_6 КАК Аналитика_6,
	|	КонтрольныеЗначения.Аналитика_7 КАК Аналитика_7,
	|	КонтрольныеЗначения.Аналитика_8 КАК Аналитика_8,
	|	КонтрольныеЗначения.Аналитика_9 КАК Аналитика_9,
	|	КонтрольныеЗначения.Аналитика_10 КАК Аналитика_10,
	|	КонтрольныеЗначения.Аналитика_11 КАК Аналитика_11,
	|	КонтрольныеЗначения.Аналитика_12 КАК Аналитика_12,
	|	СУММА(КонтрольныеЗначения.СуммаСценарийИсполнение) + СУММА(КонтрольныеЗначения.СуммаСценарийСверхЛимита) КАК Сумма,
	|	СУММА(КонтрольныеЗначения.КоличествоСценарийИсполнение) + СУММА(КонтрольныеЗначения.КоличествоСценарийСверхЛимита) КАК Количество
	|ИЗ
	|	РегистрНакопления.бит_КонтрольныеЗначенияБюджетов КАК КонтрольныеЗначения
	|ГДЕ
	|	КонтрольныеЗначения.Регистратор В(&Регистратор)
	|
	|СГРУППИРОВАТЬ ПО
	|	КонтрольныеЗначения.Период,
	|	КонтрольныеЗначения.Сценарий,
	|	КонтрольныеЗначения.ЦФО,
	|	КонтрольныеЗначения.СтатьяОборотов,
	|	КонтрольныеЗначения.Аналитика_1,
	|	КонтрольныеЗначения.Аналитика_2,
	|	КонтрольныеЗначения.Аналитика_3,
	|	КонтрольныеЗначения.Аналитика_4,
	|	КонтрольныеЗначения.Аналитика_5,
	|	КонтрольныеЗначения.Аналитика_6,
	|	КонтрольныеЗначения.Аналитика_7,
	|	КонтрольныеЗначения.Аналитика_8,
	|	КонтрольныеЗначения.Аналитика_9,
	|	КонтрольныеЗначения.Аналитика_10,
	|	КонтрольныеЗначения.Аналитика_11,
	|	КонтрольныеЗначения.Аналитика_12";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат РезультатЗапроса;

КонецФункции
	
Функция НайтиПозициюПоОснованию(ДокументПланирования, БезПомеченныхНаУдаление = Истина) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументПланирования);
	Запрос.УстановитьПараметр("ВсеДокументы", 		  Истина);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПлатежнаяПозиция.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПозиция
	|ГДЕ
	|	ПлатежнаяПозиция.ДокументПланирования = &ДокументПланирования
	|	И &ВсеДокументы";
	
	Если БезПомеченныхНаУдаление Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ВсеДокументы", "НЕ ПометкаУдаления");	
	КонецЕсли; 
	
	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	СвязанныеДокументы = Новый Массив;
	Пока Выборка.Следующий() Цикл
		СвязанныеДокументы.Добавить(Выборка.Ссылка);
	КонецЦикла; 
	
	РезультатПоиска = Новый Структура;
	РезультатПоиска.Вставить("КоличествоПозиций", СвязанныеДокументы.Количество());
	РезультатПоиска.Вставить("МассивПозиций", 	  СвязанныеДокументы);
	РезультатПоиска.Вставить("Позиция", 	  	  Документы.бит_кзн_ПлатежнаяПозиция.ПустаяСсылка());
	
	Если ЗначениеЗаполнено(СвязанныеДокументы) Тогда
		РезультатПоиска.Позиция = СвязанныеДокументы[0];
	КонецЕсли;
	
	Возврат РезультатПоиска;
	
КонецФункции

// Функция возвращает перечень синхронизируемых реквизитов позиции и заявки.
//
// Возвращаемое значение:
//  Имена - Массив.
//
Функция СинхронизируемыеРеквизиты() Экспорт

	Имена = Новый Массив;
	
	Имена.Добавить("ВидПлана");
	Имена.Добавить("Организация");
	Имена.Добавить("Контрагент");
	Имена.Добавить("ХозяйственнаяОперация");	
