Функция ОбъектРасчетовПоИсточнику(ИсточникОбъектаРасчетов) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ИсточникОбъектаРасчетов) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоСсылке(ИсточникОбъектаРасчетов);
		ПараметрыВзаиморасчеты = МенеджерОбъекта.ПараметрыВзаиморасчеты();
		Если ТипЗнч(ПараметрыВзаиморасчеты) = Тип("Массив") Тогда
			СтруктураВзаиморасчетов = ПараметрыВзаиморасчеты[0];
		Иначе
			СтруктураВзаиморасчетов = ПараметрыВзаиморасчеты;
		КонецЕсли;
		РеквизитыОбъекта       = ОбъектыРасчетовСервер.РеквизитыОбъектаРасчетовПоСтруктуре(
									ИсточникОбъектаРасчетов.ПолучитьОбъект(),
									ИсточникОбъектаРасчетов,
									СтруктураВзаиморасчетов,
									РежимЗаписиДокумента.Запись);

		Если ЗначениеЗаполнено(РеквизитыОбъекта.Организация)
			И ТипЗнч(РеквизитыОбъекта.Организация) <> Тип("СправочникСсылка.Организации") Тогда
			РеквизитыОбъекта.Организация = Справочники.Организации.ПустаяСсылка();
		КонецЕсли;
		Если ЗначениеЗаполнено(РеквизитыОбъекта.Контрагент)
			И ТипЗнч(РеквизитыОбъекта.Контрагент) <> Тип("СправочникСсылка.Организации")
			И ТипЗнч(РеквизитыОбъекта.Контрагент) <> Тип("СправочникСсылка.Контрагенты") Тогда
			РеквизитыОбъекта.Контрагент = Неопределено;
		КонецЕсли;
		Если ЗначениеЗаполнено(РеквизитыОбъекта.Партнер)
			И ТипЗнч(РеквизитыОбъекта.Партнер) <> Тип("СправочникСсылка.Партнеры") Тогда
			РеквизитыОбъекта.Партнер = Справочники.Партнеры.ПустаяСсылка();
		КонецЕсли;									
									
		ОбъектРасчетов = ОбъектыРасчетовСервер.ПроверитьСоздатьОбъектРасчетов(РеквизитыОбъекта);
	Исключение
		ОбъектРасчетов = Неопределено;
	КонецПопытки;
	
	Возврат ОбъектРасчетов;
	
КонецФункции

Процедура ЗаполнитьДанныеДокументовКазначейства(Документ) Экспорт
	
	ИспользоватьДоговорыСПоставщиками	   = ПолучитьФункциональнуюОпцию("ИспользоватьДоговорыСПоставщиками");
	ИспользоватьДоговорыМеждуОрганизациями = ПолучитьФункциональнуюОпцию("ИспользоватьДоговорыМеждуОрганизациями");
	ИспользоватьДоговорыСКлиентами		   = ПолучитьФункциональнуюОпцию("ИспользоватьДоговорыСКлиентами");

	Запрос = Новый Запрос;	
	Запрос.УстановитьПараметр("Ссылка", 								Документ);
	Запрос.УстановитьПараметр("ИспользоватьДоговорыСПоставщиками", 		ИспользоватьДоговорыСПоставщиками);
	Запрос.УстановитьПараметр("ИспользоватьДоговорыМеждуОрганизациями", ИспользоватьДоговорыМеждуОрганизациями);
	Запрос.УстановитьПараметр("ИспользоватьДоговорыСКлиентами", 		ИспользоватьДоговорыСКлиентами);

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка,
	|	Реквизиты.ДокументПланирования КАК ДокументПланирования,
	|	Реквизиты.ДокументПланирования КАК Документ,
	|	Реквизиты.ЦФО КАК ЦФО,
	|	Реквизиты.СтатьяОборотов КАК СтатьяОборотов,
	|	Реквизиты.Аналитика_1 КАК Аналитика_1,
	|	Реквизиты.Аналитика_2 КАК Аналитика_2,
	|	Реквизиты.Аналитика_3 КАК Аналитика_3,
	|	Реквизиты.Аналитика_4 КАК Аналитика_4,
	|	Реквизиты.Аналитика_5 КАК Аналитика_5,
	|	Реквизиты.Аналитика_6 КАК Аналитика_6,
	|	Реквизиты.Аналитика_7 КАК Аналитика_7,
	|	Реквизиты.Аналитика_8 КАК Аналитика_8,
	|	Реквизиты.Аналитика_9 КАК Аналитика_9,
	|	Реквизиты.Аналитика_10 КАК Аналитика_10,
	|	Реквизиты.Аналитика_11 КАК Аналитика_11,
	|	Реквизиты.Аналитика_12 КАК Аналитика_12,
	|	Реквизиты.ДатаПлан КАК ДатаПлан,
	|	Реквизиты.ПометкаУдаления КАК ПометкаУдаления,
	|	Реквизиты.СуммаДокумента КАК Сумма,
	|	Реквизиты.СуммаНДС КАК НДС,
	|	ВЫБОР
	|		КОГДА Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ПеречислениеНаДепозиты)
	|				ИЛИ Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ОплатаПоКредитам)
	|				ИЛИ Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ПеречислениеНаДепозиты)
	|				ИЛИ Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ВыдачаЗаймов)
	|			ТОГДА Реквизиты.ДоговорКредитаДепозита
	|		КОГДА Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ОплатаПоКредитам)
	|			ТОГДА Реквизиты.ДоговорАренды
	|		КОГДА Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ВозвратДенежныхСредствВДругуюОрганизацию)
	|					И &ИспользоватьДоговорыМеждуОрганизациями
	|				ИЛИ Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ВозвратОплатыКлиенту)
	|					И &ИспользоватьДоговорыСКлиентами
	|				ИЛИ Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ОплатаПоставщику)
	|					И &ИспользоватьДоговорыСПоставщиками
	|				ИЛИ Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ОплатаДенежныхСредствВДругуюОрганизацию)
	|					И &ИспользоватьДоговорыМеждуОрганизациями
	|				ИЛИ Реквизиты.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ПеречислениеТаможне)
	|					И &ИспользоватьДоговорыСПоставщиками
	|			ТОГДА Реквизиты.Договор
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Договор,
	|	ВЫБОР
	|		КОГДА Реквизиты.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Наличные)
	|			ТОГДА Реквизиты.Касса
	|		ИНАЧЕ Реквизиты.БанковскийСчет
	|	КОНЕЦ КАК МестоХраненияДенежныхСредств,
	|	Реквизиты.Подразделение КАК Подразделение
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка
	|	И ТИПЗНАЧЕНИЯ(Реквизиты.ДокументПланирования) = ТИП(Документ.бит_кзн_ЗаявкаНаРасходованиеСредств)";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Если НЕ ЗначениеЗаполнено(РезультатЗапроса) Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты = РезультатЗапроса[0];
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", Реквизиты.ДокументПланирования);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПлатежнаяПозиция.ДокументПланирования КАК ДокументПланирования,
	|	СУММА(ПлатежнаяПозиция.СуммаНДС) КАК НДС,
	|	СУММА(ПлатежнаяПозиция.СуммаДокумента) КАК Сумма
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПозиция
	|ГДЕ
	|	ПлатежнаяПозиция.ДокументПланирования = &ДокументПланирования
	|	И НЕ ПлатежнаяПозиция.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	ПлатежнаяПозиция.ДокументПланирования";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Если ЗначениеЗаполнено(РезультатЗапроса) Тогда
		// Если запрос пустой, значит все документы помечены на удаление.
		Реквизиты.Сумма = РезультатЗапроса[0].Сумма;
		Реквизиты.НДС   = РезультатЗапроса[0].НДС;
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.бит_ДанныеДокументовКазначейства.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Документ.Установить(Реквизиты.ДокументПланирования);
	ЗаполнитьЗначенияСвойств(НаборЗаписей.Добавить(), Реквизиты);
	НаборЗаписей.Записать();
	
КонецПроцедуры

