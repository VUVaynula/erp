Функция ДанныеЗаполненияПоРезультатуЗапроса(ДокументОснование, РезультатЗапроса, ДанныеЗаполнения, 
		ЗаполнениеПоДоговору = Ложь, СуммаКОплате = Неопределено) Экспорт
		
	// См.Документы.ЗаявкаНаРасходованиеДенежныхСредств.ЗаполнитьРеквизитыПоРезультатуЗапроса(). 
	РасшифровкаПлатежа = НоваяРасшифровкаПлатежа();
	
	Если РезультатЗапроса.Пустой() Тогда
		Если ЗаполнениеПоДоговору Тогда
			Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не требуется вводить Заявку на расходование ДС на основании договора %1';
					|en = 'Entering payment request on basis of contract %1 is not required'"),
				ДокументОснование);
		Иначе
			Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не требуется вводить Заявку на расходование ДС на основании документа %1';
					|en = 'Entering payment request on basis of document %1 is not required'"),
				ДокументОснование);
		КонецЕсли;
		ВызватьИсключение Текст;
	Иначе
		ДанныеЗаполнения = НовыеДанныеЗаполнения();
		Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
			ДанныеЗаполнения.Вставить(Колонка.Имя);
		КонецЦикла;
		
		ДанныеЗаполнения.Вставить("ЖелательнаяДатаПлатежа", ТекущаяДатаСеанса());
				
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка);
		
		Если ДанныеЗаполнения.ВалютаПлатежа = ДанныеЗаполнения.ВалютаДокумента Тогда
			ДанныеЗаполнения.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа;
		Иначе	
			ДанныеЗаполнения.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов;
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(ДанныеЗаполнения.ФормаОплаты) Тогда
			ДанныеЗаполнения.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
		КонецЕсли;
		
		ДенежныеСредстваСервер.ЗаполнитьРеквизитыДокументаПоФормеОплаты(ДанныеЗаполнения.ФормаОплатыЗаявки,
			ДанныеЗаполнения, ДанныеЗаполнения.ВалютаПлатежа);
		
		Если ЗначениеЗаполнено(ДанныеЗаполнения.ФизЛицо) Тогда
			ВладелецСчета = ДанныеЗаполнения.ФизЛицо;
		Иначе
			ВладелецСчета = ДанныеЗаполнения.Контрагент;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ДанныеЗаполнения.БанковскийСчетПолучателя) Тогда
			Если ЗначениеЗаполнено(ДанныеЗаполнения.Валюта) Тогда
				ДанныеЗаполнения.БанковскийСчетПолучателя = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьБанковскийСчетПоУмолчанию(
												ВладелецСчета, ДанныеЗаполнения.Валюта);
			Иначе
				ДанныеЗаполнения.БанковскийСчетПолучателя = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьБанковскийСчетПоУмолчанию(
					ДанныеЗаполнения.Контрагент);
			КонецЕсли;
		КонецЕсли;    
		
		РеквизитыСчета = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьРеквизитыБанковскогоСчета(
							ДанныеЗаполнения.БанковскийСчетПолучателя); 
							
		ДанныеЗаполнения.НазначениеПлатежа = РеквизитыСчета.ТекстНазначения;
		
		ЗаказыПоставщику = ДокументОснование;
		
		Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
			
			Запрос = Новый Запрос("
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ТаблицаТовары.ЗаказПоставщику КАК ЗаказПоставщику
			|ИЗ
			|	Документ.ПриобретениеТоваровУслуг.Товары КАК ТаблицаТовары
			|ГДЕ
			|	ТаблицаТовары.Ссылка = &Ссылка
			|	И ТаблицаТовары.Ссылка.ПоступлениеПоЗаказам
			|	И ТаблицаТовары.Ссылка.ПорядокРасчетов <> ЗНАЧЕНИЕ(Перечисление.ПорядокРасчетов.ПоЗаказамНакладным)
			|	И ТаблицаТовары.Ссылка.ПорядокРасчетов <> ЗНАЧЕНИЕ(Перечисление.ПорядокРасчетов.ПоДоговорамНакладным)
			|");
			Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
			
			РезультатЗапросаПоЗаказам = Запрос.Выполнить();
			Если НЕ РезультатЗапросаПоЗаказам.Пустой() Тогда
				ЗаказыПоставщику = РезультатЗапросаПоЗаказам.Выгрузить().ВыгрузитьКолонку("ЗаказПоставщику");
				ЗаказыПоставщику.Добавить(ДокументОснование);
			КонецЕсли;
		ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ОтчетПереработчика2_5") Тогда
			
			Запрос = Новый Запрос("
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ТаблицаТовары.ЗаказПереработчику КАК ЗаказПереработчику
			|ИЗ
			|	Документ.ОтчетПереработчика2_5.ВыходныеИзделия КАК ТаблицаТовары
			|ГДЕ
			|	ТаблицаТовары.Ссылка = &Ссылка
			|	И ТаблицаТовары.Ссылка.ПоЗаказам
			|	И ТаблицаТовары.Ссылка.ПорядокРасчетов <> ЗНАЧЕНИЕ(Перечисление.ПорядокРасчетов.ПоЗаказамНакладным)
			|	И ТаблицаТовары.Ссылка.ПорядокРасчетов <> ЗНАЧЕНИЕ(Перечисление.ПорядокРасчетов.ПоДоговорамНакладным)
			|");
			Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
			
			РезультатЗапросаПоЗаказам = Запрос.Выполнить();
			Если НЕ РезультатЗапросаПоЗаказам.Пустой() Тогда
				ЗаказыПоставщику = РезультатЗапросаПоЗаказам.Выгрузить().ВыгрузитьКолонку("ЗаказПереработчику");
				ЗаказыПоставщику.Добавить(ДокументОснование);
			КонецЕсли;	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеЗаполнения.Договор) И ТипЗнч(ДанныеЗаполнения.Договор) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
			ГрафикИсполненияДоговора = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения.Договор,"ГрафикИсполненияДоговора");
			
			Если ЗначениеЗаполнено(ГрафикИсполненияДоговора) Тогда
				ЗаказыПоставщику = ДанныеЗаполнения.Договор;
			КонецЕсли;
			
		Иначе
			ГрафикИсполненияДоговора = Неопределено;
		КонецЕсли;

		Если ЗаполнениеПоДоговору И НЕ ЗначениеЗаполнено(ГрафикИсполненияДоговора) Тогда
			Если ДанныеЗаполнения.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов 
				ИЛИ ДанныеЗаполнения.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамНакладным Тогда
				ВзаиморасчетыСервер.ЗаполнитьРасшифровкуПлатежаПоДоговоруСПоставщиком(
					ДокументОснование, ДанныеЗаполнения.Валюта, РасшифровкаПлатежа, ДанныеЗаполнения.Организация);
			Иначе
				СтрокаРасшифровки = РасшифровкаПлатежа.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаРасшифровки, ДанныеЗаполнения);
			КонецЕсли;
			
		// ++ НЕ УТ
		ИначеЕсли ТипЗнч(ДанныеЗаполнения.Договор) = Тип("СправочникСсылка.ДоговорыАренды") Тогда
			ЗаполнитьЗначенияСвойств(РасшифровкаПлатежа.Добавить(), ДанныеЗаполнения);
		// -- НЕ УТ
		ИначеЕсли ТипЗнч(ДанныеЗаполнения.ДокументОснование) = Тип("ДокументСсылка.АвансовыйОтчет") Тогда
			
			ЗаполнитьЗначенияСвойств(РасшифровкаПлатежа.Добавить(), ДанныеЗаполнения);  
			
		ИначеЕсли ТипЗнч(ДанныеЗаполнения.ДокументОснование) = Тип("ДокументСсылка.ЗаявкаНаВозвратТоваровОтКлиента") Тогда	
		
			Документы.ЗаявкаНаВозвратТоваровОтКлиента.ПроверитьВозможностьВводаНаОсновании(
				ДанныеЗаполнения.ДокументОснование, Выборка.СтатусДокумента, Выборка.ЕстьОшибкиПроведен,  Истина);
			
			Если Выборка.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоЗаказам Тогда
				
				ОбъектыРасчетов = Новый Массив;
				ОбъектыРасчетов.Добавить(ДокументОснование);
				
				ВзаиморасчетыСервер.ЗаполнитьРасшифровкуПлатежаПоВозвратуТоваровОтКлиента(
					ОбъектыРасчетов, ДанныеЗаполнения.Организация, ДанныеЗаполнения.Валюта, ДанныеЗаполнения.Сумма,
					ДанныеЗаполнения.Партнер, РасшифровкаПлатежа);
			Иначе
				ЗаполнитьЗначенияСвойств(РасшифровкаПлатежа.Добавить(), Выборка);
			КонецЕсли;
	
		Иначе
			
			СуммаИзДанныхЗаполнения = ?(ДанныеЗаполнения.Свойство("Сумма"), ДанныеЗаполнения.Сумма, 0);
			СуммаКОплатеПостащику	= ?(СуммаКОплате = Неопределено, СуммаИзДанныхЗаполнения, СуммаКОплате);
				
			ВзаиморасчетыСервер.ЗаполнитьРасшифровкуПлатежаПоЗаказуПоставщику(
				ЗаказыПоставщику, Выборка.Договор, ДанныеЗаполнения.Валюта, СуммаКОплатеПостащику, РасшифровкаПлатежа,
				ДанныеЗаполнения.ЖелательнаяДатаПлатежа);
	
		КонецЕсли;
	КонецЕсли;
	
	// Данные из доп. аналитик основания.
	ДополнительныеАналитики = бит_МеханизмДопИзмерений.ЗначенияДополнительныхАналитик(ДокументОснование,
										"ЦФО, СтатьяОборотов"); 
	ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, ДополнительныеАналитики);  
	
	Если ЗначениеЗаполнено(ДанныеЗаполнения.СтатьяОборотов) Тогда
		ТипСтатьи = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения.СтатьяОборотов, "ТипСтатьи");
	    Если ТипСтатьи <> Перечисления.бит_ТипыСтатейОборотов.БДДС Тогда
			ДанныеЗаполнения.СтатьяОборотов = СтатьиОборотовБДРДляСтатьиОборотовБДДС(ДанныеЗаполнения.СтатьяОборотов, 
													ТекущаяДатаСеанса());	
		КонецЕсли;
	КонецЕсли;	
		
	ДанныеЗаполненияИзОснования = Новый Массив;
	Для каждого СтрокаТаблицы Из РасшифровкаПлатежа Цикл			
		
		Экземпляр = ОбщегоНазначенияКлиентСервер.СкопироватьРекурсивно(ДанныеЗаполнения);
		Исключения = Новый Массив;
		Если ЗначениеЗаполнено(Экземпляр.Организация) Тогда
			Исключения.Добавить("Организация");		
		КонецЕсли;
		Если ЗначениеЗаполнено(Экземпляр.Подразделение) Тогда
			Исключения.Добавить("Подразделение");		
		КонецЕсли;
		Если ЗначениеЗаполнено(Экземпляр.Контрагент) Тогда
			Исключения.Добавить("Контрагент");		
		КонецЕсли;
		Если ЗначениеЗаполнено(Экземпляр.Партнер) Тогда
			Исключения.Добавить("Партнер");		
		КонецЕсли;
		Если ЗначениеЗаполнено(Исключения) Тогда
			ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТаблицы,, СтрСоединить(Исключения, ","));
		Иначе
			ЗаполнитьЗначенияСвойств(Экземпляр, СтрокаТаблицы);
		КонецЕсли;	
		Экземпляр.СуммаДокумента = СтрокаТаблицы.Сумма;
		
		ДанныеЗаполненияИзОснования.Добавить(Экземпляр);
	КонецЦикла;
	
	Возврат ДанныеЗаполненияИзОснования;

КонецФункции

Функция ДанныеЗаполненияИзЗаявкиНаРасходование(Основание)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", Основание);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Позиции.Ссылка КАК Позиция,
	|	Позиции.ВидПлана КАК ВидПлана
	|ПОМЕСТИТЬ ВТ_Позиции
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК Позиции
	|ГДЕ
	|	Позиции.ДокументПланирования = &ДокументПланирования
	|	И Позиции.ВидПлана = ЗНАЧЕНИЕ(Перечисление.бит_кзн_ВидыПланов.Прогноз)
	|	И НЕ Позиции.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПланируемыйРасход.Позиция КАК Позиция,
	|	ПланируемыйРасход.СуммаОстаток КАК Сумма
	|ПОМЕСТИТЬ ВТ_ПланируемыйРасход
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.Остатки(
	|			,
	|			Позиция В
	|				(ВЫБРАТЬ
	|					ВТ_Позиции.Позиция КАК Позиция
	|				ИЗ
	|					ВТ_Позиции КАК ВТ_Позиции)) КАК ПланируемыйРасход
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Позиции.Позиция КАК Позиция,
	|	ЕСТЬNULL(ВТ_ПланируемыйРасход.Сумма, 0) КАК Сумма
	|ИЗ
	|	ВТ_Позиции КАК ВТ_Позиции
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПланируемыйРасход КАК ВТ_ПланируемыйРасход
	|		ПО ВТ_Позиции.Позиция = ВТ_ПланируемыйРасход.Позиция
	|ГДЕ
	|	ЕСТЬNULL(ВТ_ПланируемыйРасход.Сумма, 0) > 0";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка			 = РезультатЗапроса.Выбрать();
	ВсеПозиции 		 = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Позиция");
	
	ПозицииПоступления = Новый Массив;
	РеквизитыПозиций = РеквизитыДокумента(ВсеПозиции);
	
	Исключения = Новый Структура;
	Исключения.Вставить("Cсылка", 				   Неопределено);
	Исключения.Вставить("Дата", 				   '0001-01-01');
	Исключения.Вставить("Номер", 				   "");
	Исключения.Вставить("Проведен", 			   Ложь);
	Исключения.Вставить("ПометкаУдаления", 		   Ложь);
	Исключения.Вставить("ОтправленНаСогласование", Ложь);

	Пока Выборка.Следующий() Цикл
		СтрокаТаблицы	   = РеквизитыПозиций.Найти(Выборка.Позиция, "Позиция"); 
		ЗначенияЗаполнения = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(СтрокаТаблицы);
		
		ЗначенияЗаполнения.ВидПлана			 	= Перечисления.бит_кзн_ВидыПланов.План;
		ЗначенияЗаполнения.СуммаДокумента	 	= Выборка.Сумма;
		ЗначенияЗаполнения.ДокументОснование	= Выборка.Позиция;
		ЗначенияЗаполнения.ДокументПланирования = Неопределено;
		ЗаполнитьЗначенияСвойств(ЗначенияЗаполнения, Исключения);
		
		ПозицииПоступления.Добавить(ЗначенияЗаполнения);
	КонецЦикла;

	Возврат ПозицииПоступления;
	
КонецФункции

Функция ДанныеЗаполненияПоПоПоступлениюТоваров(Знач ДокументОснование, ДанныеЗаполнения)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	Запрос.УстановитьПараметр("ХозОперацииЗакупкаУПоставщика",
		ЗакупкиСервер.ХозяйственныеОперацииПоОсновной(Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика));
	Запрос.УстановитьПараметр("ХозОперацииЗакупкаПоИмпорту",
		ЗакупкиСервер.ХозяйственныеОперацииПоОсновной(Перечисления.ХозяйственныеОперации.ЗакупкаПоИмпорту));
	Запрос.УстановитьПараметр("ХозОперацииЗакупкаВСтранахЕАЭС",
		ЗакупкиСервер.ХозяйственныеОперацииПоОсновной(Перечисления.ХозяйственныеОперации.ЗакупкаВСтранахЕАЭС));

	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.БанковскийСчетОрганизации <> ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.БанковскийСчетОрганизации.Владелец
	|		ИНАЧЕ ДанныеДокумента.Организация
	|	КОНЕЦ КАК Организация,
	|	ДанныеДокумента.Подразделение КАК Подразделение,
	|	ДанныеДокумента.Контрагент КАК Контрагент,
	|	ДанныеДокумента.Договор КАК Договор,
	|	ЕСТЬNULL(ДанныеДокумента.Договор.ПлатежиПо275ФЗ, ЛОЖЬ) КАК ПлатежиПо275ФЗ,
	|	ЕСТЬNULL(ДанныеДокумента.Договор.ДоговорСУчастникомГОЗ, ЛОЖЬ) КАК ДоговорСУчастникомГОЗ,
	|	ЕСТЬNULL(ДанныеДокумента.Договор.ОплатаРасходовПоТарифамСГосрегулированием, ЛОЖЬ) КАК ОплатаРасходовПоТарифамСГосрегулированием,
	|	ДанныеДокумента.БанковскийСчетОрганизации КАК БанковскийСчет,
	|	ДанныеДокумента.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	ДанныеДокумента.БанковскийСчетКонтрагента КАК БанковскийСчетПолучателя,
	|	НЕОПРЕДЕЛЕНО КАК Касса,
	|	ЕСТЬNULL(ОбъектыРасчетов.Ссылка, ЗНАЧЕНИЕ(Справочник.ОбъектыРасчетов.ПустаяСсылка)) КАК ОбъектРасчетов,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.БанковскийСчетОрганизации <> ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.БанковскийСчетОрганизации.ВалютаДенежныхСредств
	|		ИНАЧЕ ДанныеДокумента.Валюта
	|	КОНЕЦ КАК ВалютаПлатежа,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.БанковскийСчетОрганизации <> ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|			ТОГДА ДанныеДокумента.БанковскийСчетОрганизации.ВалютаДенежныхСредств
	|		ИНАЧЕ ДанныеДокумента.Валюта
	|	КОНЕЦ КАК Валюта,
	|	ДанныеДокумента.Валюта КАК ВалютаДокумента,
	|	ДанныеДокумента.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	ДанныеДокумента.СуммаВзаиморасчетов КАК СуммаВзаиморасчетов,
	|	ДанныеДокумента.СуммаДокумента КАК СуммаДокумента,
	|	ДанныеДокумента.СуммаДокумента КАК Сумма,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.ФормыОплаты.Наличная)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ФормаОплатыНаличная,
	|	ВЫБОР
	|		КОГДА ДанныеДокумента.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.ФормыОплаты.Безналичная)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ФормаОплатыБезналичная,
	|	ДанныеДокумента.ФормаОплаты КАК ФормаОплатыЗаявки,
	|	ЗНАЧЕНИЕ(Перечисление.бит_ВидыОперацийКазначейства.ОплатаПоставщику) КАК ХозяйственнаяОперация,
	|	ДанныеДокумента.ОперацияССамозанятым КАК ОперацияССамозанятым,
	|	&Ссылка КАК ДокументОснование,
	|	ДанныеДокумента.Партнер КАК Партнер,
	|	ДанныеДокумента.Соглашение КАК Соглашение
	|ИЗ
	|	Документ.ПриобретениеТоваровУслуг КАК ДанныеДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
	|		ПО (ВЫБОР
	|				КОГДА ДанныеДокумента.ЗаказПоставщику = ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
	|					ТОГДА &Ссылка
	|				ИНАЧЕ ДанныеДокумента.ЗаказПоставщику
	|			КОНЕЦ = ОбъектыРасчетов.Объект)
	|ГДЕ
	|	ДанныеДокумента.Ссылка = &Ссылка
	|	И (ДанныеДокумента.ХозяйственнаяОперация В (&ХозОперацииЗакупкаУПоставщика)
	|			ИЛИ ДанныеДокумента.ХозяйственнаяОперация В (&ХозОперацииЗакупкаПоИмпорту)
