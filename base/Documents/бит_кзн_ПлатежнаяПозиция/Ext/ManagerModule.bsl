Функция ТекстЗапросаКонтрольИсполненияБюджета(НомераТаблиц, ОтразитьИсполнениеБюджета)

	Если НЕ ОтразитьИсполнениеБюджета Тогда
		Возврат "";	
	КонецЕсли;
	
	НомераТаблиц.Вставить("ИсполнениеБюджетаРеквизиты", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ИсполнениеБюджета", НомераТаблиц.Количество());
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.ДатаПлан КАК Период,
	|	Реквизиты.ВалютаДокумента КАК Валюта,
	|	Реквизиты.ЦФО КАК ЦФО,
	|	Реквизиты.Сценарий КАК Сценарий,
	|	Реквизиты.Сценарий КАК СценарийКонтролируемый,
	|	Реквизиты.СтатьяОборотов КАК СтатьяОборотов,
	|	0 КАК Курс,
	|	0 КАК Кратность,
	|	Реквизиты.Сценарий.Валюта КАК ВалютаСценария,
	|	ЗНАЧЕНИЕ(Перечисление.бит_РежимыКонтроляПоБюджету.Заявки) КАК РежимКонтроля,
	|	&КонтролироватьБюджет КАК КонтролироватьБюджет,
	|	&НеУчитыватьСверхБюджета КАК НеУчитыватьСверхБюджета,
	|	Реквизиты.СверхБюджета КАК СверхБюджета,
	|	Реквизиты.СписатьЛимиты КАК СписатьЛимиты
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка
	|	И Реквизиты.ВидПлана <> ЗНАЧЕНИЕ(Перечисление.бит_кзн_ВидыПланов.Прогноз)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	""Распределение"" КАК ИмяСписка,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(25)) КАК СинонимСписка,
	|	1 КАК НомерСтроки,
	|	Реквизиты.ДатаПлан КАК Период,
	|	Реквизиты.ЦФО КАК ЦФО,
	|	Реквизиты.СтатьяОборотов КАК СтатьяОборотов,
	|	Реквизиты.Аналитика_1 КАК Аналитика_1,
	|	Реквизиты.Аналитика_2 КАК Аналитика_2,
	|	Реквизиты.Аналитика_3 КАК Аналитика_3,
	|	Реквизиты.Аналитика_4 КАК Аналитика_4,
	|	Реквизиты.Аналитика_5 КАК Аналитика_5,
	|	Реквизиты.Аналитика_6 КАК Аналитика_6,
	|	Реквизиты.Аналитика_7 КАК Аналитика_7,
	|	Реквизиты.Аналитика_8 КАК Аналитика_8,
	|	Реквизиты.Аналитика_9 КАК Аналитика_9,
	|	Реквизиты.Аналитика_10 КАК Аналитика_10,
	|	Реквизиты.Аналитика_11 КАК Аналитика_11,
	|	Реквизиты.Аналитика_12 КАК Аналитика_12,
	|	Реквизиты.СуммаДокумента КАК Сумма,
	|	0 КАК Количество,
	|	ИСТИНА КАК КонтролироватьСумму,
	|	ЛОЖЬ КАК КонтролироватьКоличество,
	|	НЕ Реквизиты.СтатьяОборотов.НеКонтролировать_Заявки КАК КонтролироватьПоСтатье
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка
	|	И Реквизиты.ВидПлана <> ЗНАЧЕНИЕ(Перечисление.бит_кзн_ВидыПланов.Прогноз)";
	
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции
 
Процедура ПодготовитьРеквизитыПрогноза(ПараметрыПроведения, Реквизиты, Отказ)

	Если ПараметрыПроведения.ПланируемыйРасходСписаниеРеквизиты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	РеквизитыПрогноза = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(
							ПараметрыПроведения.ПланируемыйРасходСписаниеРеквизиты[0]);
								
	ОбъектРасчетов = ?(ЗначениеЗаполнено(РеквизитыПрогноза.ОбъектРасчетов), РеквизитыПрогноза.ОбъектРасчетов, РеквизитыПрогноза.Договор);
	
	
	Коэффициенты = бит_Казначейство.ПолучитьКоэффициентыПересчетаВалюты(РеквизитыПрогноза.Валюта,
					РеквизитыПрогноза.ВалютаДенежныхСредств, Реквизиты.Период, Реквизиты.Организация,,, 
					ОбъектРасчетов);
																
	РеквизитыПрогноза.Вставить("КоэффициентПересчетаВВалютуУпр",             Коэффициенты.КоэффициентПересчетаВВалютуУпр);
	РеквизитыПрогноза.Вставить("КоэффициентПересчетаВВалютуРегл",            Коэффициенты.КоэффициентПересчетаВВалютуРегл);
	РеквизитыПрогноза.Вставить("КоэффициентПересчетаВВалютуДенежныхСредств", Коэффициенты.КоэффициентПересчетаВВалютуВзаиморасчетов);

	КоэффициентыПрогнозПлан = бит_Казначейство.ПолучитьКоэффициентыПересчетаВалюты(Реквизиты.Валюта,
					РеквизитыПрогноза.Валюта, Реквизиты.Период, Реквизиты.Организация,,, 
					ОбъектРасчетов);
						
	РеквизитыПрогноза.Вставить("КоэффициентПересчетаПрогнозПланВВалютуУпр",             КоэффициентыПрогнозПлан.КоэффициентПересчетаВВалютуУпр);
	РеквизитыПрогноза.Вставить("КоэффициентПересчетаПрогнозПланВВалютуРегл",            КоэффициентыПрогнозПлан.КоэффициентПересчетаВВалютуРегл);
	РеквизитыПрогноза.Вставить("КоэффициентПересчетаПрогнозПланВВалютуДенежныхСредств", КоэффициентыПрогнозПлан.КоэффициентПересчетаВВалютуВзаиморасчетов);
	
	ПараметрыПроведения.Вставить("РеквизитыПрогноза", РеквизитыПрогноза);

КонецПроцедуры
 
Процедура ПодготовитьТаблицыРасчетыВВалюте(ПараметрыПроведения, Реквизиты)
	
	Если НЕ ПараметрыПроведения.Свойство("ПланируемыйРасходПоступлениеСАналитиками") Тогда
		Возврат;
	КонецЕсли;
	
	// Таб. ПланируемыйРасходПоступлениеСАналитиками.	
	Для каждого СтрокаТаблицы Из ПараметрыПроведения.ПланируемыйРасходПоступлениеСАналитиками Цикл
		СтрокаТаблицы.СуммаОплаты = СтрокаТаблицы.Сумма * Реквизиты.КоэффициентПересчетаВВалютуДенежныхСредств;
		СтрокаТаблицы.СуммаРегл   = СтрокаТаблицы.Сумма * Реквизиты.КоэффициентПересчетаВВалютуРегл;
		СтрокаТаблицы.СуммаУпр    = СтрокаТаблицы.Сумма * Реквизиты.КоэффициентПересчетаВВалютуУпр;
	КонецЦикла; 

	// Подготовка сторно движений прогноза.
	// Таб. ПланируемыйРасходСписание.
	Если ПараметрыПроведения.ПланируемыйРасходСписание.Количество() > 0 Тогда
		РеквизитыПрогноза = ПараметрыПроведения.РеквизитыПрогноза;
		Для каждого СтрокаТаблицы Из ПараметрыПроведения.ПланируемыйРасходСписание Цикл
			СтрокаТаблицы.Сумма = СтрокаТаблицы.Сумма * РеквизитыПрогноза.КоэффициентПересчетаПрогнозПланВВалютуДенежныхСредств;
		КонецЦикла; 

		// Таб. ПланируемыйРасходСписаниеСАналитиками
		Для каждого СтрокаТаблицы Из ПараметрыПроведения.ПланируемыйРасходСписаниеСАналитиками Цикл
			
			Сумма = СтрокаТаблицы.Сумма * РеквизитыПрогноза.КоэффициентПересчетаПрогнозПланВВалютуДенежныхСредств;
			
			СтрокаТаблицы.СуммаОплаты = Сумма * РеквизитыПрогноза.КоэффициентПересчетаВВалютуДенежныхСредств;
			СтрокаТаблицы.СуммаРегл   = Сумма * РеквизитыПрогноза.КоэффициентПересчетаВВалютуРегл;
			СтрокаТаблицы.СуммаУпр    = Сумма * РеквизитыПрогноза.КоэффициентПересчетаВВалютуУпр;
		КонецЦикла; 
	КонецЕсли;
	
КонецПроцедуры
	
#КонецОбласти

// См. ПлатежиВБюджет.ДублиУИН()
Функция ДублиУИН(ИдентификаторПлатежа, Ссылка)
	
	Дубли = Новый СписокЗначений;
	
	Если Не ПлатежиВБюджетКлиентСервер.РеквизитЗаполнен(ИдентификаторПлатежа) Тогда
		Возврат Дубли;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИдентификаторПлатежа", ИдентификаторПлатежа);
	Запрос.УстановитьПараметр("Ссылка",               Ссылка);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПлатежнаяПозиция.Ссылка КАК Ссылка,
	|	ПлатежнаяПозиция.Дата КАК Дата,
	|	ПлатежнаяПозиция.Представление КАК Представление
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПозиция
	|ГДЕ
	|	ПлатежнаяПозиция.ИдентификаторПлатежа = &ИдентификаторПлатежа
	|	И ПлатежнаяПозиция.Ссылка <> &Ссылка
	|	И ПлатежнаяПозиция.ПеречислениеВБюджет
	|	И НЕ ПлатежнаяПозиция.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ,
	|	Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Дубли.Добавить(Выборка.Ссылка, Выборка.Представление);
	КонецЦикла;
	
	Возврат Дубли;
	
КонецФункции

Функция РеквизитыПлатежнойПозиции(ПлатежнаяПозиция)
	
	ПоляИсточника = Новый Массив;
	
	КоллекцияРеквизитов = Метаданные.Документы.бит_кзн_ПлатежнаяПозиция.Реквизиты;
	Для каждого РеквизитДокумента Из КоллекцияРеквизитов Цикл
		ПоляИсточника.Добавить(РеквизитДокумента.Имя);
	КонецЦикла;
	ПоляИсточника.Добавить("Ссылка");
	ПоляИсточника.Добавить("Дата");
	ИменаПолей = СтрСоединить(ПоляИсточника, ",");
	
	РеквизитыИсточника = Новый Структура(ИменаПолей);
	ЭтоСсылка          = (ТипЗнч(ПлатежнаяПозиция) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция"));
	
	Если ЭтоСсылка Тогда
		РеквизитыИсточника = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПлатежнаяПозиция, ИменаПолей);
	Иначе
		ЗаполнитьЗначенияСвойств(РеквизитыИсточника, ПлатежнаяПозиция);
	КонецЕсли;
	
	РеквизитыИсточника.Вставить("Регистратор", РеквизитыИсточника.Ссылка);
	РеквизитыИсточника.Вставить("Период",      РеквизитыИсточника.ДатаПлан);
	РеквизитыИсточника.Вставить("Прогноз",     РеквизитыИсточника.ДокументОснование);
	РеквизитыИсточника.Вставить("Валюта",      РеквизитыИсточника.ВалютаДокумента);
	РеквизитыИсточника.Вставить("Сумма",       РеквизитыИсточника.СуммаДокумента);
	
	ДанныеСценария = Новый Структура;
	ДанныеСценария.Вставить("ВалютаСценария",					Справочники.Валюты.ПустаяСсылка());
	ДанныеСценария.Вставить("ОтключитьКонтрольЗаявокПоЛимитам", Ложь);
	
	Если ЗначениеЗаполнено(РеквизитыИсточника.Сценарий) Тогда
		РеквизитыСценария = Новый Структура("ВалютаСценария, ОтключитьКонтрольЗаявокПоЛимитам", "Валюта", "ОтключитьКонтрольЗаявокПоЛимитам");
		ДанныеСценария 	  = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(РеквизитыИсточника.Сценарий,
								РеквизитыСценария);	
	КонецЕсли;
	
	РеквизитыИсточника.Вставить("ВалютаСценария", 					ДанныеСценария.ВалютаСценария);
	РеквизитыИсточника.Вставить("ОтключитьКонтрольЗаявокПоЛимитам", ДанныеСценария.ОтключитьКонтрольЗаявокПоЛимитам);
	
	ВалютаДенежныхСредств = Справочники.Валюты.ПустаяСсылка();
	Если РеквизитыИсточника.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
		ВалютаДенежныхСредств = РеквизитыИсточника.ВалютаДокумента;
	Иначе
		ИсточникВалютыДС = Неопределено;
		Если РеквизитыИсточника.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
			ИсточникВалютыДС = РеквизитыИсточника.БанковскийСчет;
		Иначе
			ИсточникВалютыДС = РеквизитыИсточника.Касса;
		КонецЕсли;
		Если ЗначениеЗаполнено(ИсточникВалютыДС) Тогда
			ВалютаДенежныхСредств = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИсточникВалютыДС, "ВалютаДенежныхСредств");
		КонецЕсли;
	КонецЕсли;
	РеквизитыИсточника.Вставить("ВалютаДенежныхСредств", ВалютаДенежныхСредств);
	
	Возврат РеквизитыИсточника;
	
КонецФункции

Функция ВидыОперацийДляОбновитьДокументыБезПартнера()

	ВидыОпераций = Новый ТаблицаЗначений;	
	ВидыОпераций.Колонки.Добавить("ВидОперации", Новый ОписаниеТипов("ПеречислениеСсылка.бит_ВидыОперацийКазначейства"));
	ВидыОпераций.Колонки.Добавить("ХозОперацияУП", Новый ОписаниеТипов("ПеречислениеСсылка.ХозяйственныеОперации"));

	Для каждого Значение Из Перечисления.бит_ВидыОперацийКазначейства Цикл
				
		ПарамВидимости = бит_Казначейство.ПодготовитьПараметрыВидимости(Значение);
		Если НЕ ПарамВидимости.ЕстьПартнер Тогда
			Продолжить;		
		КонецЕсли;

		НоваяСтрока = ВидыОпераций.Добавить();	
		НоваяСтрока.ВидОперации   = Значение;
	    НоваяСтрока.ХозОперацияУП = бит_КазначействоКлиентСервер.ХозяйственнаяОперацияУП(Значение);
	КонецЦикла;
	
	Возврат ВидыОпераций;
	
КонецФункции

Функция СтатьиОборотовБДРДляСтатьиОборотовБДДС(Статья, Период)
	
	Модуль		    = РегистрыСведений.бит_СоответствияАналитик;
	ВидСоответствия = Справочники.бит_ВидыСоответствийАналитик.СтатьиОборотовБДР_СтатьиОборотовБДДС;
	Результат 		= Модуль.ПолучитьПравуюАналитику(ВидСоответствия, Статья, Период);
	
	Возврат Результат;

КонецФункции

