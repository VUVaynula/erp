	|		НомерСтроки КАК НомерСтроки,
	|		ФизическоеЛицо КАК ФизическоеЛицо,
	|		ЛицевойСчет КАК ЛицевойСчет,
	|		Сумма КАК Сумма
	|	) КАК ТаблицаЛицевыеСчетаСотрудников
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка В(&ПлатежныеПозиции)";
	
	
	Результат = Запрос.Выполнить().Выгрузить();
	Результат.Колонки.Добавить("ЛицевыеСчетаСотрудников");
	
	// Преобразование в массив структур, для использования данных на клиенте. 
	Для каждого СтрокаТаблицы  Из Результат Цикл
		СтрокаТаблицы.ЛицевыеСчетаСотрудников = ОбщегоНазначения.ТаблицаЗначенийВМассив(
													СтрокаТаблицы.ТаблицаЛицевыеСчетаСотрудников); 
	КонецЦикла;
	Результат.Колонки.Удалить(Результат.Колонки.ТаблицаЛицевыеСчетаСотрудников);
	
	Возврат Результат;

КонецФункции

// См. ПлатежиВБюджет.ПроверитьДублиУИН()
Функция ПроверитьДублиУИН(ИдентификаторПлатежа, Ссылка) Экспорт
	
	Результат = Новый Массив;	
	Дубли = ДублиУИН(ИдентификаторПлатежа, Ссылка);
	Если Дубли.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ШаблонТекста = НСтр("ru = 'Возможно, уникальный идентификатор платежа указан ошибочно.
    	|
        |[ГдеЕщеУказанЭтотИдентификатор]
        |
        |Одинаковые идентификаторы следует указывать только при частичной оплате.';
        |en = 'Unique ID of payment may be specified incorrectly.
        |
        |[ГдеЕщеУказанЭтотИдентификатор]
        |
        |You should specify the same IDs only for partial payment.'");
						
	
	Если Дубли.Количество() = 1 Тогда
			
		ГдеЕщеУказанЭтотИдентификатор = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Этот же идентификатор платежа указан в другом документе:
				|%1.';
				|en = 'The same payment ID is specified in another document:
				|%1.'"),
			Дубли[0]);
			
	ИначеЕсли Дубли.Количество() = 2 Тогда
			
		ГдеЕщеУказанЭтотИдентификатор = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Этот же идентификатор платежа указан в других документах:
				|- %1
				|- %2.';
				|en = 'The same payment ID is specified in other documents:
				|- %1
				|- %2.'"), 
			Дубли[0], 
			Дубли[1]);
			
	ИначеЕсли Дубли.Количество() = 3 Тогда
		
		ГдеЕщеУказанЭтотИдентификатор = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Этот же идентификатор платежа указан в других документах:
				|- %1
				|- %2
				|- %3.';
				|en = 'The same payment ID is specified in other documents:
				|- %1
				|- %2
				|- %3.'"),
			Дубли[0], 
			Дубли[1], 
			Дубли[2]);
			
	Иначе
		
		ТекстЕщеДокументов = СтроковыеФункцииКлиентСервер.ЧислоЦифрамиПредметИсчисленияПрописью(
			Дубли.Количество() - 2, 
			НСтр("ru = 'более ранний документ, более ранних документа, более ранних документов';
				|en = 'an earlier document, earlier documents, earlier documents'"));
			
		ГдеЕщеУказанЭтотИдентификатор = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Этот же идентификатор платежа указан в других документах:
				|- %1
				|- %2
				|  и еще %3.';
				|en = 'The same payment ID is specified in other documents:
				|- %1
				|- %2
				| and %3.'"),
			Дубли[0], 
			Дубли[1],
			ТекстЕщеДокументов);
			
	КонецЕсли;
	
	ПараметрыТекста = Новый Структура;
	ПараметрыТекста.Вставить("ГдеЕщеУказанЭтотИдентификатор", ГдеЕщеУказанЭтотИдентификатор);
	
	ТекстОшибки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(ШаблонТекста, ПараметрыТекста);
	
	ОписаниеОшибки = Новый Структура;
	ОписаниеОшибки.Вставить("ТекстОшибки", ТекстОшибки);
	ОписаниеОшибки.Вставить("ИмяПоля",     "ИдентификаторПлатежа");
	
	Результат.Добавить(ОписаниеОшибки);
	
	Возврат Результат;
	
КонецФункции

Функция ПараметрыФормыПриКопировании(ДокументПланирования) Экспорт

	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения, КоличествоПозиций", Новый Структура, 0);

	РезультатПоиска = НайтиПозициюПоОснованию(ДокументПланирования);	
	Если РезультатПоиска.КоличествоПозиций = 1 Тогда
		РеквизитыДокумента = РеквизитыДокумента(РезультатПоиска.МассивПозиций[0]);
		ЗначенияЗаполнения = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(РеквизитыДокумента[0]);

		Исключения = Новый Структура;
		Исключения.Вставить("Cсылка", 				   Неопределено);
		Исключения.Вставить("Дата", 				   '0001-01-01');
		Исключения.Вставить("Номер", 				   "");
		Исключения.Вставить("Проведен", 			   Ложь);
		Исключения.Вставить("ПометкаУдаления", 		   Ложь);
		Исключения.Вставить("ДокументОснование", 	   Неопределено);
		Исключения.Вставить("ДокументПланирования",    Неопределено);
		Исключения.Вставить("ОтправленНаСогласование", Ложь);
		Исключения.Вставить("СверхБюджета", 		   Ложь); // Не копируем этот флаг.
		ЗаполнитьЗначенияСвойств(ЗначенияЗаполнения, Исключения);
		
		ПараметрыФормы.ЗначенияЗаполнения = ЗначенияЗаполнения;
	КонецЕсли;
	
	ПараметрыФормы.КоличествоПозиций = РезультатПоиска.КоличествоПозиций;
	
	Возврат ПараметрыФормы;
	
