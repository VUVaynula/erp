#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	Основание 			= ДанныеЗаполнения;

	Если ЗначениеЗаполнено(ДанныеЗаполнения) И ТипДанныхЗаполнения <> Тип("Структура")
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеЗаполнения, "Проведен")
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "Проведен") = Ложь 
		И НЕ ТипДанныхЗаполнения = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда
			ТекстСообщения = НСтр("ru='Необходимо провести документ перед созданием заявки.';
								|en='It is necessary to hold the document before creating the application.'");
			ВызватьИсключение ТекстСообщения;		
	КонецЕсли;
		
	// В отдельных случаях данные заполнения и документы формируются отдельно:
	// 1. На клиенте для открытия формы см. бит_КазначействоКлиент.СоздатьЗаявкуНаРасходованиеСредств().
	// 2. Если требуется получить записанный результат - позицию (заявку с позициями), тогда
	//	  Результат = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.ДокументПоДаннымЗаполнения(Основание);	
	
	Если ТипДанныхЗаполнения = Тип("Структура") Тогда
		ОжидаемыеДанные = Новый Структура("ДокументПланирования, ДокументОснование");
		ЗаполнитьЗначенияСвойств(ОжидаемыеДанные, ДанныеЗаполнения);
		ДокументПланирования = ОжидаемыеДанные.ДокументПланирования;
		ДокументОснование 	 = ОжидаемыеДанные.ДокументОснование;
		
		Если ЗначениеЗаполнено(ДокументПланирования) 
		   И ТипЗнч(ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
			 ЗаполнитьНаОснованииЗаявкиНаРасходованиеСредств(ДокументПланирования);
		ИначеЕсли ЗначениеЗаполнено(ДокументОснование) Тогда
			ТипДанныхЗаполнения = ТипЗнч(ДокументОснование);
			Основание 			= ДокументОснование;
		КонецЕсли;
		бит_ОбщегоНазначения.ЗаполнитьПоСтруктуре(ЭтотОбъект, ДанныеЗаполнения);
		ЛицевыеСчета = Неопределено;
		Если ДанныеЗаполнения.Свойство("ЛицевыеСчетаСотрудников", ЛицевыеСчета) И ЗначениеЗаполнено(ЛицевыеСчета) Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ЛицевыеСчета, ЛицевыеСчетаСотрудников);	
		КонецЕсли;
	КонецЕсли;
		
	Если ТипДанныхЗаполнения = Тип("ДокументСсылка.АвансовыйОтчет") Тогда 
		ЗаполнитьНаОснованииАвансовогоОтчета(Основание);
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.ЗаявкаНаВозвратТоваровОтКлиента") Тогда	
		ЗаполнитьНаОснованииЗаявкиНаВозвратТоваровОтКлиента(Основание);
	// ++ НЕ УТ
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыВБанк")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыВКассу")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыПеречислением")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыРаздатчиком")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ВедомостьПрочихДоходовВБанк")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ВедомостьПрочихДоходовВКассу")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ВедомостьПрочихДоходовПеречислением")
	// -- НЕ УТ
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ВозвратТоваровМеждуОрганизациями")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ВозвратТоваровОтКлиента")
	// ++ НЕ УТ
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ВыкупПринятыхНаХранениеТоваров")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ДоговорЗаймаСотруднику")
	// -- НЕ УТ
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ЗаявлениеОВвозеТоваров")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ОперацияПоЯндексКассе")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ОтчетКомиссионера")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ОтчетКомитентуОСписании")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ОтчетПоКомиссииМеждуОрганизациями")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ОтчетПоКомиссииМеждуОрганизациямиОСписании")
	// ++ НЕ УТ
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ОтчетПереработчика")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ОтчетПереработчика2_5")
	// -- НЕ УТ
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ПередачаТоваровМеждуОрганизациями")
	// ++ НЕ УТ
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ПоступлениеДенежныхДокументов")
	// -- НЕ УТ
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ОтчетОСписанииТоваровСХранения")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.СчетФактураНалоговыйАгент")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.ТаможеннаяДекларацияИмпорт")
	ИЛИ ТипДанныхЗаполнения = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция")
	ИЛИ ТипДанныхЗаполнения = Тип("СправочникСсылка.ДоговорыКонтрагентов")
	ИЛИ ТипДанныхЗаполнения = Тип("СправочникСсылка.ДоговорыКредитовИДепозитов") Тогда
		ЗаполнитьПоОснованию(Основание);
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.ПриобретениеУслугПрочихАктивов") Тогда
		ЗаполнитьНаОснованииПоступленияУслугИВнеоборотныхАктивов(Основание);
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.ОтчетКомитенту") Тогда
		ЗаполнитьНаОснованииОтчетаКомитенту(Основание);
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		ЗаполнитьНаОснованииЗаказаПоставщику(Основание)
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.бит_пз_ЗаявкаНаЗатраты") Тогда
		ЗаполнитьНаОснованииЗаявкиНаЗатраты(Основание);
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.бит_пз_СводнаяЗаявкаНаЗатраты") Тогда
		ЗаполнитьНаОснованииСводнойЗаявкиНаЗатраты(Основание);
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
		ЗаполнитьНаОснованииПриобретенияТоваровУслуг(Основание);
	// ++ НЕ УТ
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.ЗаказПереработчику2_5") Тогда
		ЗаполнитьНаОснованииЗаказаПереработчику2_5(Основание);
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.ЗаказПереработчику") Тогда
		ЗаполнитьНаОснованииЗаказаПереработчику(Основание);
	ИначеЕсли ТипДанныхЗаполнения = Тип("СправочникСсылка.ДоговорыАренды") Тогда
		ЗаполнитьНаОснованииДоговораАренды(Основание);		
	// -- НЕ УТ
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда
		ЗаполнитьНаОснованииЗаявкиНаПеремещения(Основание);
	КонецЕсли;
		
	ИнициализироватьДокумент(ДанныеЗаполнения);
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
		
	Если ЗначениеЗаполнено(ОбъектКопирования.ДокументПланирования) Тогда
		Если ТипЗнч(ОбъектКопирования.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда		
			ТекстСообщения = НСтр("ru='В заявке на перемещение платежную позицию копировать запрещено.';
								|en='The proposal to move the position of the copy prohibited payment.'");
			ВызватьИсключение ТекстСообщения;			
		ИначеЕсли ТипЗнч(ОбъектКопирования.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда		
			ТекстСообщения = НСтр("ru='В заявке на перевод средств платежную позицию копировать запрещено.';
								|en='In the application for the transfer of funds payment position copy prohibited.'");
			ВызватьИсключение ТекстСообщения;		
		КонецЕсли;  
	КонецЕсли;

	// Важно!!!
	// Флаг "СверхБюджета" копируется при добавлении позиции (копированием)
	// в форме "многострочной" заявки.
	// СверхБюджета = Ложь;

	Дата 					= ТекущаяДатаСеанса();
	ДатаПлан          		= Макс(Дата, ДатаПлан);
	ДатаПланКрайняя   		= ?(ЗначениеЗаполнено(ДатаПланКрайняя), Макс(Дата, ДатаПланКрайняя), ДатаПланКрайняя);
	СписатьЛимиты			= Ложь;
	ОтправленНаСогласование = Ложь;	
	Ответственный 			= Пользователи.ТекущийПользователь();
		
	Если ЗначениеЗаполнено(СтавкаНДС) Тогда
		Если бит_Казначейство.ОперацияБезНДС(ХозяйственнаяОперация) Тогда
			СтавкаНДС = Неопределено;
			СуммаНДС  = 0;
		КонецЕсли;
	КонецЕсли;
	
	ДействовалФЗ = СписаниеБезналичныхДенежныхСредствЛокализация.ДействуетФедеральныйЗакон345ФЗ(ОбъектКопирования.Дата);
	ДействуетФЗ  = СписаниеБезналичныхДенежныхСредствЛокализация.ДействуетФедеральныйЗакон345ФЗ(ТекущаяДатаСеанса());
	Если ДействовалФЗ <> ДействуетФЗ Тогда
		Если ОбъектКопирования.ОчередностьПлатежа = 6 ИЛИ ОбъектКопирования.ОчередностьПлатежа = 0 Тогда
			ОчередностьПлатежа = 5;
		Иначе
			ОчередностьПлатежа = 0;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Перем Ошибки;
	
	НепроверяемыеРеквизиты = Новый Массив;
	
	Если ЗначениеЗаполнено(ДатаПлан) Тогда
		ПараметрыПроверки = бит_КазначействоКлиентСервер.НовыеПараметрыПериодЗаданКорректно();
		ПараметрыПроверки.ПоляОбъекта.ДатаНачала	= "Дата";
		ПараметрыПроверки.ПоляОбъекта.ДатаОкончания = "ДатаПлан";
		
		ПараметрыПроверки.ПоляФормы.ДатаНачала	  = НСтр("ru = 'Дата'; en = 'Date'");
		ПараметрыПроверки.ПоляФормы.ДатаОкончания = НСтр("ru = 'Дата платежа'; en = 'Payment Date'");
		
		ПериодЗаданКорректно = бит_КазначействоКлиентСервер.ПериодЗаданКорректно(ЭтотОбъект, ПараметрыПроверки);
		Если НЕ ПериодЗаданКорректно Тогда
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаПлан) И ЗначениеЗаполнено(ДатаПланКрайняя) Тогда
		ПараметрыПроверки = бит_КазначействоКлиентСервер.НовыеПараметрыПериодЗаданКорректно();
		ПараметрыПроверки.ПоляОбъекта.ДатаНачала	= "ДатаПлан";
		ПараметрыПроверки.ПоляОбъекта.ДатаОкончания = "ДатаПланКрайняя";
		
		ПараметрыПроверки.ПоляФормы.ДатаНачала	  = НСтр("ru = 'Дата платежа'; en = 'Payment Date'");
		ПараметрыПроверки.ПоляФормы.ДатаОкончания = НСтр("ru = 'Не позднее'; en = 'on or before'");
		
		ПериодЗаданКорректно = бит_КазначействоКлиентСервер.ПериодЗаданКорректно(ЭтотОбъект, ПараметрыПроверки);
		Если НЕ ПериодЗаданКорректно Тогда
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если Планирование = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов И ВалютаДокумента <> ВалютаВзаиморасчетов Тогда
		ТекстУточнения = НСтр("ru = 'Валюта взаиморасчетов не соответствует валюте документа %1'");
		ТекстУточнения = СтрШаблон(ТекстУточнения, ВалютаДокумента);
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("ПОЛЕ", "Корректность", 
							НСтр("ru = 'Валюта взаиморасчетов'; en = 'AR/AP currency'"),,, ТекстУточнения);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "ВалютаВзаиморасчетов", ,Отказ);
	КонецЕсли;
	
	Если ХозяйственнаяОперация <>  Перечисления.бит_ВидыОперацийКазначейства.ОплатаПоКредитам Тогда
		НепроверяемыеРеквизиты.Добавить("ТипСуммыКредитаДепозита");
	КонецЕсли;
	
	Если ХозяйственнаяОперация <> Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеВБюджет Тогда
		НепроверяемыеРеквизиты.Добавить("ТипНалога"); 		
	КонецЕсли; 
	
	Если ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Наличные Тогда 		
		НепроверяемыеРеквизиты.Добавить("ОчередностьПлатежа"); 		
	КонецЕсли;    			
	
	Если ТипЗнч(ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда 
	
		Если ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда 		
			НепроверяемыеРеквизиты.Добавить("Касса"); 			
		Иначе    			
			НепроверяемыеРеквизиты.Добавить("БанковскийСчет"); 		
		КонецЕсли; 
		
		НепроверяемыеРеквизиты.Добавить("ЦФО"); 
		НепроверяемыеРеквизиты.Добавить("СтавкаНДС");
		НепроверяемыеРеквизиты.Добавить("Сценарий");
	ИначеЕсли ТипЗнч(ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда 
	
		Если ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда 		
			НепроверяемыеРеквизиты.Добавить("Касса"); 			
		Иначе    			
			НепроверяемыеРеквизиты.Добавить("БанковскийСчет"); 		
		КонецЕсли; 
		НепроверяемыеРеквизиты.Добавить("СтавкаНДС");
		НепроверяемыеРеквизиты.Добавить("Сценарий");
	Иначе
		
		Если ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Наличные Тогда
			НепроверяемыеРеквизиты.Добавить("БанковскийСчет");
		Иначе
			НепроверяемыеРеквизиты.Добавить("Касса"); 
			Если ЗначениеЗаполнено(Договор) Тогда
				НепроверяемыеРеквизиты.Добавить("БанковскийСчет");
			КонецЕсли;
		КонецЕсли;
		
		Если бит_Казначейство.ОперацияБезНДС(ХозяйственнаяОперация) Тогда
			НепроверяемыеРеквизиты.Добавить("СтавкаНДС");
		КонецЕсли;
		
		РезультатПоиска = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(ДокументПланирования);
		Если РезультатПоиска.КоличествоПозиций > 1 Тогда
			КоличествоПозиций = 0;
			РеквизитыОбъектов = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(РезультатПоиска.МассивПозиций, "ПометкаУдаления");
			Для каждого КлючЗначение Из РеквизитыОбъектов Цикл
				Если КлючЗначение.Ключ = Ссылка Тогда
					КоличествоПозиций = КоличествоПозиций + 1;
				ИначеЕсли НЕ КлючЗначение.Значение.ПометкаУдаления Тогда 
					КоличествоПозиций = КоличествоПозиций + 1;
				КонецЕсли; 
			КонецЦикла; 
		Иначе
			КоличествоПозиций = 1;
		КонецЕсли; 
		Если КоличествоПозиций > 1 Тогда
			Пояснение = НСтр("ru = 'Не совпадает валютой документа планирования.'; 
							|en = 'The currency of the planning document does not match'");
			Если ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов Тогда
				Если ВалютаВзаиморасчетов <> ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументПланирования, "ВалютаДокумента") Тогда						
					ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("ПОЛЕ", 
										"Корректность", Нстр("ru = 'Валюта взаиморасчетов'; en = 'AR/AP currency'"),,,Пояснение);	
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "ВалютаВзаиморасчетов", ,Отказ);
				КонецЕсли;		
			КонецЕсли;
			Если ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
				Если ВалютаДокумента <> ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументПланирования, "ВалютаДокумента") Тогда						
					ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("ПОЛЕ", 
										"Корректность", Нстр("ru = 'Валюта'; en = 'Currency'"),,,Пояснение);	
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "ВалютаДокумента", ,Отказ);
				КонецЕсли;		
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ СписокФизЛиц Тогда
		НепроверяемыеРеквизиты.Добавить("ЛицевыеСчетаСотрудников");
		НепроверяемыеРеквизиты.Добавить("ЛицевыеСчетаСотрудников.ФизическоеЛицо");
		НепроверяемыеРеквизиты.Добавить("ЛицевыеСчетаСотрудников.ЛицевойСчет");
		НепроверяемыеРеквизиты.Добавить("ЛицевыеСчетаСотрудников.Сумма");
	КонецЕсли;

	Если НЕ ПеречислениеВБюджет Тогда
		НепроверяемыеРеквизиты.Добавить("КодБК"); 
		НепроверяемыеРеквизиты.Добавить("КодОКАТО");
		НепроверяемыеРеквизиты.Добавить("ПоказательОснования");
		НепроверяемыеРеквизиты.Добавить("ПоказательПериода");
		НепроверяемыеРеквизиты.Добавить("ПоказательНомера");
		НепроверяемыеРеквизиты.Добавить("ПоказательДаты");
		НепроверяемыеРеквизиты.Добавить("СтатусСоставителя");
	КонецЕсли; 
			
	//++ НЕ УТ
	Если ПлатежиПо275ФЗ Тогда
		
		Если ДоговорСУчастникомГОЗ И ЗначениеЗаполнено(БанковскийСчетПолучателя) Тогда
			ОтдельныйСчетГОЗ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БанковскийСчетПолучателя, "ОтдельныйСчетГОЗ");
			Если Не ОтдельныйСчетГОЗ Тогда
				ТекстСообщения = НСтр("ru='Должен быть выбран отдельный банковский счет ГОЗ';
						 |en='Separate SDO bank account must be selected'");
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "БанковскийСчетПолучателя",, Отказ);
			КонецЕсли;
		КонецЕсли;

		Если ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ПрочаяВыдачаДенежныхСредств Тогда
			
			НепроверяемыеРеквизиты.Добавить("ПодтверждающиеДокументы.ВидДокумента");
			НепроверяемыеРеквизиты.Добавить("ПодтверждающиеДокументы.Файл");
			
		Иначе
			// См. ДенежныеСредстваСерверЛокализация.ОбработкаПроверкиЗаполненияПодтверждающиеДокументы().
			Документы.бит_кзн_ПлатежнаяПозиция.ОбработкаПроверкиЗаполненияПодтверждающиеДокументы(ЭтотОбъект,
				Отказ, ПроверяемыеРеквизиты, Ошибки);
		КонецЕсли;
				
		// См. ДенежныеСредстваСерверЛокализация.ПроверитьЗаполнениеРеквизитовПлатежаГОЗ().
		Документы.бит_кзн_ПлатежнаяПозиция.ПроверитьЗаполнениеРеквизитовПлатежаГОЗ(ЭтотОбъект, Отказ);
		
		РасшифровкаБезРазбиения = Истина;
		// См. ЗаявкаНаРасходованиеДенежныхСредствЛокализация.ПроверитьЗаполнениеДоговоровГОЗ().
		Документы.бит_кзн_ПлатежнаяПозиция.ПроверитьЗаполнениеДоговоровГОЗ(ЭтотОбъект, Отказ, РасшифровкаБезРазбиения);
		
		// См. ЗаявкаНаРасходованиеДенежныхСредствЛокализация.ПроверитьЗаполнениеТипаСуммыКредитаДепозита().
		Документы.бит_кзн_ПлатежнаяПозиция.ПроверитьЗаполнениеТипаСуммыКредитаДепозита(ЭтотОбъект, Отказ, РасшифровкаБезРазбиения);
	Иначе
	//-- НЕ УТ
		НепроверяемыеРеквизиты.Добавить("ПодтверждающиеДокументы");
		НепроверяемыеРеквизиты.Добавить("ДоговорСУчастникомГОЗ");
		НепроверяемыеРеквизиты.Добавить("ТипПлатежаФЗ275");
		НепроверяемыеРеквизиты.Добавить("ПредметОплаты");
		НепроверяемыеРеквизиты.Добавить("ВариантОплаты");
		НепроверяемыеРеквизиты.Добавить("ПодтверждающиеДокументы.ВидДокумента");
		НепроверяемыеРеквизиты.Добавить("ПодтверждающиеДокументы.Файл");
	//++ НЕ УТ
	КонецЕсли;


	ЭтоПередачаДенег = бит_КазначействоКлиентСервер.ЭтоОперацияПередачиДенег(ХозяйственнаяОперация);
	Если ЭтоПередачаДенег Тогда
		Если ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда 		
			НепроверяемыеРеквизиты.Добавить("КассаПолучатель"); 			
		Иначе    			
			НепроверяемыеРеквизиты.Добавить("БанковскийСчетПолучатель"); 		
		КонецЕсли; 
	Иначе
		НепроверяемыеРеквизиты.Добавить("ОрганизацияПолучатель");
		НепроверяемыеРеквизиты.Добавить("БанковскийСчетПолучатель");
		НепроверяемыеРеквизиты.Добавить("КассаПолучатель");
	КонецЕсли;

	ЭтоОперацияСПартнером = бит_КазначействоКлиентСервер.ЭтоОперацияСПартнером(ХозяйственнаяОперация);
	Если НЕ ЭтоОперацияСПартнером ИЛИ НЕ ПолучитьФункциональнуюОпцию("ИспользоватьПартнеровИКонтрагентов") Тогда
		НепроверяемыеРеквизиты.Добавить("Партнер");
	КонецЕсли;
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	
	бит_НастройкиДоступностиЭлементовФорм.ЗаполнитьПроверяемыеРеквизиты(ЭтотОбъект, ПроверяемыеРеквизиты);
	
	ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю(Ошибки);
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли; 
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	
	бит_ОбщегоНазначенияПереопределяемый.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	
	ДополнительныеСвойства.Вставить("УстановкаПометкиУдаления", ПометкаУдаления <> Ссылка.ПометкаУдаления);

	Если НЕ ДополнительныеСвойства.УстановкаПометкиУдаления И НЕ ДополнительныеСвойства.ЭтоНовый Тогда
		Если ПолучитьФункциональнуюОпцию("бит_ЗапретитьИзменениеЗаявкиВключеннойВРеестр") Тогда
			ЗаявкаВключенаВРеестр = РегистрыСведений.бит_РеестрыПлатежей.ПозицияВключенаВРеестр(Ссылка);
		Иначе
			ЗаявкаВключенаВРеестр = Ложь;
		КонецЕсли;

		Если ЗаявкаВключенаВРеестр Тогда
			ТекстСообщения = НСтр("ru = 'Не удалось записать %1. Документ включен в реестр платежей.';
								|en = 'Failed to write to %1. The document is included in the payment register.'") ;
			ТекстСообщения = СтрШаблон(ТекстСообщения, Ссылка);
			ВызватьИсключение ТекстСообщения;		
		КонецЕсли;	
	КонецЕсли;

	ИзмененаДатаПлатежа = Ложь;
	Если НЕ ЭтоНовый()
		И ПолучитьФункциональнуюОпцию("бит_ИспользоватьМеханизмОповещений") Тогда
		ПредыдущаяДатаРасхода = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ДатаПлан");
		ИзмененаДатаПлатежа   = ПредыдущаяДатаРасхода <> ДатаПлан;
	КонецЕсли;
	ДополнительныеСвойства.Вставить("ИзмененаДатаПлатежа", ИзмененаДатаПлатежа);
	
	Реквизиты = Новый Структура("Организация"); 
	ЗаполнитьЗначенияСвойств(Реквизиты, ЭтотОбъект);

	бит_Казначейство.ЗаполнитьДопАналитикуПоДаннымДокумента(ЭтотОбъект, Реквизиты);
	
	ОчиститьНеиспользуемыеРеквизиты();
	
	ПроверитьСоответствиеФизЛицаИВедомости(РежимЗаписи, Отказ);
	
	// ++ НЕ УТ
	//Настройка счетов учета
	НастройкаСчетовУчетаСервер.ПередЗаписью(ЭтотОбъект,
		Документы.бит_кзн_ПлатежнаяПозиция.ПараметрыНастройкиСчетовУчета(ХозяйственнаяОперация, ТипНалога));
	// -- НЕ УТ
	
	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("Организация", Организация);
	ПараметрыНастройки.Вставить("ЦФО",		   ЦФО);
								
	ОтражатьСверхБюджета = НЕ бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеЗаявкиПриКонтролеПоБюджету(
									ПараметрыНастройки, Дата);
									
	Если ОтражатьСверхБюджета ИЛИ НЕ СверхБюджета Тогда
		СписатьЛимиты = Ложь;	
	КонецЕсли;	

	Если ПометкаУдаления <> Ссылка.ПометкаУдаления Тогда
		Возврат;
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ДатаПлан) Тогда
		ПредставлениеПоля = Метаданные().Реквизиты.ДатаПлан.Представление();
		ТекстСообщения	  = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,,ПредставлениеПоля);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "ДатаПлан", ,Отказ);
	КонецЕсли; 
	
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		ОтправленНаСогласование = Ложь;
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ДокументПланирования) Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		
		// Если создание начинается с платежной позиции - при записи создаем заявку.
		НовыйДокумент = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.СоздатьДокумент();
		ЗаполнитьЗначенияСвойств(НовыйДокумент, ЭтотОбъект);
		НовыйДокумент.Дата = ТекущаяДатаСеанса();
		НовыйДокумент.УстановитьНовыйНомер();
		
		Если ЗначениеЗаполнено(ДокументОснование) Тогда		
			Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция") Тогда			
				НовыйДокумент.ДокументОснование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОснование, "ДокументПланирования");
			КонецЕсли;		
		КонецЕсли; 

		Результат = бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(НовыйДокумент, РежимЗаписиДокумента.Запись, "", "Ошибки");
		
		Если Результат Тогда
			ДокументПланирования = НовыйДокумент.Ссылка;
		Иначе
			Отказ = Истина;
		КонецЕсли; 
		
		УстановитьПривилегированныйРежим(Ложь);		
	КонецЕсли; 
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда	
		Возврат; 	
	КонецЕсли; 
	
	РежимЗаписи = ДополнительныеСвойства.РежимЗаписи;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение 
	 ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		ПроверитьПравоПроведения(Отказ);
	КонецЕсли; 	
	
	Если Отказ Тогда	
		Возврат;  	
	КонецЕсли; 
	
	ВыполнитьСинхронизацию(РежимЗаписи);
	Документы.бит_кзн_ПлатежнаяПозиция.ЗаполнитьДанныеДокументовКазначейства(Ссылка);
		
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	ПроверитьПравоПроведения(Отказ);
	
	ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(Ссылка);
	бит_Казначейство.ПроверитьВозможностьПроведения(Ссылка, ТекущийСтатус, Отказ);
	
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаПроведенияНачало(ЭтотОбъект, Ложь);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыПроведения = Документы.бит_кзн_ПлатежнаяПозиция.ПодготовитьПараметрыПроведения(Ссылка, Отказ);
	
	Если Отказ Тогда
		Возврат;	
	КонецЕсли; 
	
	АдресВХранилище = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
							ДополнительныеСвойства, "АдресДанныхДляКорректировки", "");
		
	ТаблицаИсполнениеБюджета = бит_КонтрольИсполненияБюджета.ПодготовитьТаблицуИсполнениеБюджета(
									ПараметрыПроведения.ИсполнениеБюджета,
									ПараметрыПроведения.ИсполнениеБюджетаРеквизиты,
									Отказ, АдресВХранилище);

	Реквизиты = ПараметрыПроведения.Реквизиты;
	
	Отбор = Новый Структура;
	Отбор.Вставить("Организация", Реквизиты.Организация);
	Отбор.Вставить("ЦФО", 		  Реквизиты.ЦФО); 	
	
	КакКонтролироватьОстатки = бит_НастройкиПрограммы.КонтролироватьОстаткиПоПрогнозуПлатежа(Отбор, Реквизиты.Дата);
	Контролировать			 = КакКонтролироватьОстатки <> Перечисления.бит_ВидыКонтроля.НеКонтролировать;
	
	ПропуститьКонтрольПоПрогнозу = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства, 
											"ПропуститьКонтрольПоПрогнозу", Ложь);
	
	Если НЕ ПропуститьКонтрольПоПрогнозу И Контролировать 
	   И ЗначениеЗаполнено(ПараметрыПроведения.ПланируемыйРасходСписание) Тогда
		РеквизитыПрогноза = ПараметрыПроведения.ПланируемыйРасходСписаниеРеквизиты[0];
		КонтрольОстатковПоПрогнозу(Реквизиты, РеквизитыПрогноза, КакКонтролироватьОстатки, Отказ);
	КонецЕсли; 
	
	Если Отказ Тогда
		Возврат;	
	КонецЕсли;  
	
	Документы.бит_кзн_ПлатежнаяПозиция.СформироватьПланируемыйРасходДенежныхСредств(
		ПараметрыПроведения.ПланируемыйРасходСписание, Движения, Отказ);
		
	Документы.бит_кзн_ПлатежнаяПозиция.СформироватьПланируемыйРасходДенежныхСредств(
		ПараметрыПроведения.ПланируемыйРасходПоступление, Движения, Отказ);	
		
	Документы.бит_кзн_ПлатежнаяПозиция.СформироватьПланируемыйРасходДенежныхСредствСАналитиками(
		ПараметрыПроведения.ПланируемыйРасходПоступлениеСАналитиками, Движения, Отказ);	
		
	Документы.бит_кзн_ПлатежнаяПозиция.СформироватьПланируемыйРасходДенежныхСредствСАналитиками(
		ПараметрыПроведения.ПланируемыйРасходСписаниеСАналитиками, Движения, Отказ);	
		
	бит_КонтрольИсполненияБюджета.СформироватьДвиженияКонтрольныеЗначенияБюджетов(
		ТаблицаИсполнениеБюджета, Движения);
		
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаПроведенияЗавершение(ЭтотОбъект, Отказ);
		
    Если ЗначениеЗаполнено(ДокументОснование)
		И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция") Тогда
	
		ДокПрогноз = ДокументОснование.ПолучитьОбъект();
		бит_ВизированиеСервер.УстановитьСтатус(ДокПрогноз);
		
		ЗаявкаПрогноза = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОснование, "ДокументПланирования");
		Если ЗначениеЗаполнено(ЗаявкаПрогноза) Тогда
			ДокЗаявки      = ЗаявкаПрогноза.ПолучитьОбъект();
			бит_ВизированиеСервер.УстановитьСтатус(ДокЗаявки);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства,
				"УстановитьСтатусДокументаПланированияПриПроведении", Ложь) Тогда
		ДокПланирования = ДокументПланирования.ПолучитьОбъект();
		Для каждого ДопСвойство Из ДополнительныеСвойства.ДополнительныеСвойстваДокументаПланирования Цикл
			Если ДопСвойство.Ключ = "НеУстанавливатьСтатусПриЗаписи" Тогда
				Продолжить;
			КонецЕсли;
			ДокПланирования.ДополнительныеСвойства.Вставить(ДопСвойство.Ключ, ДопСвойство.Значение);
		КонецЦикла;
		бит_ВизированиеСервер.бит_ПередЗаписьюДокументаДляУстановкиСтатуса(ДокПланирования,
																			Отказ,
																			РежимЗаписиДокумента.Проведение,
																			РежимПроведения);
		бит_ВизированиеСервер.бит_ПриЗаписиДляУстановкиСтатуса(ДокПланирования, Отказ);
		ДополнительныеСвойства.УстановитьСтатусДокументаПланированияПриПроведении = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ПроверитьПравоПроведения(Отказ);
	ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(Ссылка);
	бит_Казначейство.ПроверитьВозможностьПроведения(Ссылка, ТекущийСтатус, Отказ);

	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
	
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаУдаленияПроведения(ЭтотОбъект, Отказ);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ЗаполнитьСценарий() Экспорт 

	Перем СценарийКандидат;
	
	Отборы = Новый Структура;
	Отборы.Вставить("ЦФО", ЦФО);
	Отборы.Вставить("Организация", Организация);
	
	Период = ?(ЗначениеЗаполнено(Дата), Дата, НачалоДня(ТекущаяДатаСеанса()));
	
	// Сценарий из настроек пользователя.
	СценарийКандидат = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
							ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнойСценарий);
		
	Если НЕ ЗначениеЗаполнено(СценарийКандидат) Тогда
		КонтролироватьЗаявку = бит_НастройкиПрограммы.КонтролироватьЗаявкуПоБюджету(Отборы, Период);
		Если КонтролироватьЗаявку Тогда
			Если НЕ ЗначениеЗаполнено(СценарийКандидат) Тогда
				// Сценарий из настроек программы.
				СценарийКандидат = бит_НастройкиПрограммы.КазначействоСценарийКонтроляПоБюджету(Отборы, Период);
			КонецЕсли; 
		КонецЕсли;
	КонецЕсли;
												
	Если НЕ ЗначениеЗаполнено(СценарийКандидат) И ЗначениеЗаполнено(Сценарий) Тогда
		СценарийКандидат = Сценарий;
	КонецЕсли;
								
	Возврат СценарийКандидат;
	
КонецФункции

#КонецОбласти

