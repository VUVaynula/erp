		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(
									Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту);
		ОбъектРасчетов        = Документы.бит_кзн_ПлатежнаяПозиция.ОбъектРасчетовПоИсточнику(Основание);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ОтчетКомитентуОСписании") Тогда
		ФормаОплаты           = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(
									Перечисления.ХозяйственныеОперации.ОплатаПоставщику);
		ОбъектРасчетов        = Документы.бит_кзн_ПлатежнаяПозиция.ОбъектРасчетовПоИсточнику(Основание);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.АвансовыйОтчет") Тогда
		ФормаОплаты           = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(
									Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствПодотчетнику);
		ОбъектРасчетов        = Документы.бит_кзн_ПлатежнаяПозиция.ОбъектРасчетовПоИсточнику(Основание);
		
		СуммаДокумента = Основание.СуммаИзрасходовано;
		ФизЛицо = Основание.ПодотчетноеЛицо;
		ВалютаДокумента = Основание.Валюта;
		
		Если Основание.Мультивалютный Тогда
			ТекстСообщения = НСтр("ru = 'Ввод на основании мультивалютного документа не поддерживается.'"); 
			ВызватьИсключение ТекстСообщения;
		КонецЕсли;
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ДоговорЗаймаСотруднику") Тогда
		ФормаОплаты				= Перечисления.бит_ВидыДенежныхСредств.Безналичные;
		ВидОперации				= Перечисления.ХозяйственныеОперации.ВыдачаЗаймаСотруднику;
		ХозяйственнаяОперация	= бит_Казначейство.ХозяйственнаяОперацияБФ(
									Перечисления.ХозяйственныеОперации.ВыдачаЗаймаСотруднику);
		ОбъектРасчетов			= Документы.бит_кзн_ПлатежнаяПозиция.ОбъектРасчетовПоИсточнику(Основание);
		ДоговорЗаймаСотруднику	= Основание;
		
		СуммаДокумента = Основание.Сумма;
		ФизЛицо = Основание.ФизическоеЛицо;
	// ++ НЕ УТ
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ОтчетПереработчика") 
		  ИЛИ ТипОснования = Тип("ДокументСсылка.ОтчетПереработчика2_5") Тогда
		ФормаОплаты           = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(
									Перечисления.ХозяйственныеОперации.ОплатаПоставщику);
		ОбъектРасчетов        = Документы.бит_кзн_ПлатежнаяПозиция.ОбъектРасчетовПоИсточнику(Основание);
		
		РеквизитыОснования = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Основание, "Организация, Контрагент, Договор, СуммаДокумента");
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, РеквизитыОснования);
	// -- НЕ УТ
	КонецЕсли;
	
	ЗначениеСтавки = бит_БухгалтерскийУчет.ПолучитьСтавкуНДС(СтавкаНДС);
	СуммаНДС       = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(СуммаДокумента,Истина,
																			Истина,ЗначениеСтавки);

КонецПроцедуры

Процедура ЗаполнитьНаОснованииЗаявкиНаРасходованиеСредств(ДанныеЗаполнения)
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДанныеЗаполнения);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаявкаНаРасходованиеСредств.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ЗаявкаНаРасходованиеСредств.ФормаОплаты КАК ФормаОплаты,
	|	ЗаявкаНаРасходованиеСредств.Организация КАК Организация,
	|	ЗаявкаНаРасходованиеСредств.Контрагент КАК Контрагент,
	|	ЗаявкаНаРасходованиеСредств.Сценарий КАК Сценарий,
	|	ЗаявкаНаРасходованиеСредств.СверхБюджета КАК СверхБюджета,
	|	ЗаявкаНаРасходованиеСредств.СписатьЛимиты КАК СписатьЛимиты,
	|	ЗаявкаНаРасходованиеСредств.ДокументОснование КАК ДокументОснование,
	|	ЗаявкаНаРасходованиеСредств.ВидПлана КАК ВидПлана,
	|	ЗаявкаНаРасходованиеСредств.Важность КАК Важность,
	|	ЗаявкаНаРасходованиеСредств.Ссылка КАК ДокументПланирования,
	|	ЗаявкаНаРасходованиеСредств.Инициатор КАК Инициатор,
	|	ЗаявкаНаРасходованиеСредств.НазначениеПлатежаУпр КАК НазначениеПлатежаУпр,
	|	ЗаявкаНаРасходованиеСредств.НазначениеПлатежа КАК НазначениеПлатежа,
	|	ЗаявкаНаРасходованиеСредств.ФизЛицо КАК ФизЛицо,
	|	ЗаявкаНаРасходованиеСредств.ПлатежиПо275ФЗ КАК ПлатежиПо275ФЗ,
	|	ЗаявкаНаРасходованиеСредств.ДоговорСЗаказчиком КАК ДоговорСЗаказчиком,
	|	ЗаявкаНаРасходованиеСредств.ПредметОплаты КАК ПредметОплаты,
	|	ЗаявкаНаРасходованиеСредств.ПунктКонтрактаПредмета КАК ПунктКонтрактаПредмета,
	|	ЗаявкаНаРасходованиеСредств.ПунктКонтрактаОплаты КАК ПунктКонтрактаОплаты,
	|	ЗаявкаНаРасходованиеСредств.ВариантОплаты КАК ВариантОплаты,
	|	ЗаявкаНаРасходованиеСредств.ТипПлатежаФЗ275 КАК ТипПлатежаФЗ275,
	|	ЗаявкаНаРасходованиеСредств.ДоговорСУчастникомГОЗ КАК ДоговорСУчастникомГОЗ,
	|	ЗаявкаНаРасходованиеСредств.ПодтверждающиеДокументы.(
	|		Ссылка КАК Ссылка,
	|		НомерСтроки КАК НомерСтроки,
	|		ВидДокумента КАК ВидДокумента,
	|		Номер КАК Номер,
	|		Дата КАК Дата,
	|		Сумма КАК Сумма,
	|		Файл КАК Файл
	|	) КАК ПодтверждающиеДокументы,
	|	ЗаявкаНаРасходованиеСредств.ПометкаУдаления КАК ПометкаУдаления
	|ИЗ
	|	Документ.бит_кзн_ЗаявкаНаРасходованиеСредств КАК ЗаявкаНаРасходованиеСредств
	|ГДЕ
	|	ЗаявкаНаРасходованиеСредств.Ссылка = &Ссылка";
	
	РезультатЗапроса 	   = Запрос.Выполнить();
	ВыборкаРеквизиты = РезультатЗапроса.Выбрать();
	ВыборкаРеквизиты.Следующий();
	
	Если ВыборкаРеквизиты.ПометкаУдаления Тогда
		ТекстСообщения = НСтр("ru = 'Выполнить не могу. По причине: Заявка помеченна на удаление.';
								|en = 'I can''t do it. For the reason: The application is marked for deletion.'");
		ВызватьИсключение ТекстСообщения;	
	КонецЕсли;	
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ВыборкаРеквизиты);
	Если ЗначениеЗаполнено(ВыборкаРеквизиты.ПодтверждающиеДокументы) Тогда
		ПодтверждающиеДокументы.Загрузить(ВыборкаРеквизиты.ПодтверждающиеДокументы.Выгрузить());
	КонецЕсли; 
	
КонецПроцедуры

Процедура ЗаполнитьНаОснованииОтчетаКомитенту(ДанныеЗаполнения)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДанныеЗаполнения", ДанныеЗаполнения);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Перечисление.бит_кзн_ВидыПланов.План) КАК ВидПлана,
	|	Реквизиты.Ссылка КАК ДокументОснование,
	|	Реквизиты.Контрагент КАК Контрагент,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.СуммаДокумента КАК СуммаДокумента,
	|	Реквизиты.Валюта КАК ВалютаДокумента,
	|	Реквизиты.ДатаПлатежа КАК ДатаПлатежа
	|ИЗ
	|	Документ.ОтчетКомитенту КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &ДанныеЗаполнения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ТЧДокумента.СуммаНДС) КАК СуммаНДС,
	|	МАКСИМУМ(ТЧДокумента.СтавкаНДС) КАК СтавкаНДС
	|ИЗ
	|	Документ.ОтчетКомитенту.Товары КАК ТЧДокумента
	|ГДЕ
	|	ТЧДокумента.Ссылка = &ДанныеЗаполнения";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаРеквизиты = РезультатЗапроса[0].Выбрать();
	ВыборкаРеквизиты.Следующий();
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ВыборкаРеквизиты);
	
	ВыборкаНДС = РезультатЗапроса[1].Выбрать();
	Если ВыборкаНДС.Следующий() Тогда
		СуммаНДС = ВыборкаНДС.СуммаНДС; 
		СтавкаНДС = ВыборкаНДС.СтавкаНДС;
	КонецЕсли;
	
