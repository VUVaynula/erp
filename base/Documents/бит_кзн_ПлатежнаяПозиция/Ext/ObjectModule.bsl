Процедура ЗаполнитьПоОснованию(Основание)

	ИсключаемыеСвойства = "Дата,Номер,Проведен,ПометкаУдаления,ДокументОснование,ДокументПланирования,ВидПлана,ОтправленНаСогласование";
	ЗначенияИсключаемыхСвойств = Новый Структура(ИсключаемыеСвойства);
	ЗаполнитьЗначенияСвойств(ЗначенияИсключаемыхСвойств, ЭтотОбъект);
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Основание);
	// Восстановим незаполняемые реквизиты.
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ЗначенияИсключаемыхСвойств);
	
	ДокументОснование = Основание;
	ТипОснования      = ТипЗнч(Основание);
	Если ТипОснования = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция")  Тогда
		Если ВидПлана = Перечисления.бит_кзн_ВидыПланов.Прогноз Тогда
			ДокументОснование = Неопределено;	
		КонецЕсли;
		СтрОплата = Документы.бит_кзн_ПлатежнаяПозиция.ПолучитьОстаток(Основание);
		СуммаДокумента = СтрОплата.Остаток;
	// ++ НЕ УТ
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыВБанк") Тогда
		ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
		Если НДФЛПоВедомостям Тогда
			ВидОперации    = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет;
			ТипНалога      = Справочники.ВидыНалоговВзносов.НДФЛ;
			СуммаДокумента = СуммаНДФЛОснования(Основание);
		Иначе
			ВидОперации    = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыПоЗарплатномуПроекту;
			СуммаДокумента = Основание.СуммаПоДокументу;
		КонецЕсли;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(ВидОперации);
		Ведомость	  = Основание;
		КодВидаДохода = ИнтеграцияБЗК.ПолучитьКодВидаДохода(Основание.ВидДоходаИсполнительногоПроизводства);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыПеречислением") Тогда
		ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
		Если НДФЛПоВедомостям Тогда
			ВидОперации    = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет;
			ТипНалога      = Справочники.ВидыНалоговВзносов.НДФЛ;
			СуммаДокумента = СуммаНДФЛОснования(Основание);
		Иначе
			ВидОперации    = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета;
			СуммаДокумента = Основание.СуммаПоДокументу;
		КонецЕсли;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(ВидОперации);
		Ведомость	          = Основание;	
		КодВидаДохода         = ИнтеграцияБЗК.ПолучитьКодВидаДохода(Основание.ВидДоходаИсполнительногоПроизводства);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыВКассу") Тогда
		Касса = Основание.Касса;
		Если НДФЛПоВедомостям Тогда
			ФормаОплаты    = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
			ВидОперации    = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет;
			ТипНалога      = Справочники.ВидыНалоговВзносов.НДФЛ;
			СуммаДокумента = СуммаНДФЛОснования(Основание);
		Иначе
			ФормаОплаты    = Перечисления.бит_ВидыДенежныхСредств.Наличные;
			ВидОперации    = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыЧерезКассу;
			СуммаДокумента = Основание.СуммаПоДокументу;
		КонецЕсли;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(ВидОперации);
		Ведомость	          = Основание;
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыРаздатчиком") Тогда
		Если НДФЛПоВедомостям Тогда
			ФормаОплаты    = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
			ВидОперации    = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет;
			ТипНалога      = Справочники.ВидыНалоговВзносов.НДФЛ;
			СуммаДокумента = СуммаНДФЛОснования(Основание);
		Иначе
			ФормаОплаты    = Перечисления.бит_ВидыДенежныхСредств.Наличные;
			ВидОперации    = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыРаздатчиком;
			СуммаДокумента = Основание.СуммаПоДокументу;
		КонецЕсли;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(ВидОперации);
		ФизЛицо               = Основание.Раздатчик;
		Ведомость	          = Основание;
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ВедомостьПрочихДоходовВБанк") Тогда
		Если НДФЛПоВедомостям Тогда
			ФормаОплаты    = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
			ВидОперации    = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет;
			ТипНалога      = Справочники.ВидыНалоговВзносов.НДФЛ;
			СуммаДокумента = СуммаНДФЛОснования(Основание);
		Иначе
			ФормаОплаты    = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
			ВидОперации    = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыПоЗарплатномуПроекту;
			СуммаДокумента = Основание.СуммаПоДокументу;
		КонецЕсли;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(ВидОперации);
		Ведомость	          = Основание;
		КодВидаДохода         = ИнтеграцияБЗК.ПолучитьКодВидаДохода(Основание.ВидДоходаИсполнительногоПроизводства);
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ВедомостьПрочихДоходовВКассу") Тогда
		Если НДФЛПоВедомостям Тогда
			ФормаОплаты    = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
			ВидОперации    = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет;
			ТипНалога      = Справочники.ВидыНалоговВзносов.НДФЛ;
			СуммаДокумента = СуммаНДФЛОснования(Основание);
		Иначе
			ФормаОплаты    = Перечисления.бит_ВидыДенежныхСредств.Наличные;
			ВидОперации    = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыЧерезКассу;
			СуммаДокумента = Основание.СуммаПоДокументу;
		КонецЕсли;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(ВидОперации);
		Ведомость	          = Основание;
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ВедомостьПрочихДоходовПеречислением") Тогда
		Если НДФЛПоВедомостям Тогда
			ФормаОплаты    = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
			ВидОперации    = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет;
			ТипНалога      = Справочники.ВидыНалоговВзносов.НДФЛ;
			СуммаДокумента = СуммаНДФЛОснования(Основание);
		Иначе
			ФормаОплаты    = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
			ВидОперации    = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета;
			СуммаДокумента = Основание.СуммаПоДокументу;
		КонецЕсли;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(ВидОперации);
		Ведомость	          = Основание;
		КодВидаДохода         = ИнтеграцияБЗК.ПолучитьКодВидаДохода(Основание.ВидДоходаИсполнительногоПроизводства);
	// -- НЕ УТ
	ИначеЕсли ТипОснования = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		ФормаОплаты           = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
		ХозяйственнаяОперация = бит_Казначейство.ХозяйственнаяОперацияБФ(
									Перечисления.ХозяйственныеОперации.ОплатаПоставщику);
		ПорядокРасчетов       = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Основание, "ПорядокРасчетов");
