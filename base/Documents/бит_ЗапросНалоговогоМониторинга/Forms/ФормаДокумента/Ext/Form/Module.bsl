
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ПодготовитьФормуНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
    ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
    // Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	Если Параметры.Ключ.Пустая() Тогда
		ПодготовитьФормуНаСервере();
	КонецЕсли;
		
	Элементы.ПолеВыбораПериодичность.СписокВыбора.Добавить(Перечисления.Периодичность.Месяц,   "Ежемесячно");
	Элементы.ПолеВыбораПериодичность.СписокВыбора.Добавить(Перечисления.Периодичность.Квартал, "Ежеквартально");
	Элементы.ПолеВыбораПериодичность.СписокВыбора.Добавить("Произвольный", "Произвольный");
	
	УправлениеЭлементамиФормы(ЭтотОбъект);
	
	ПоказатьПериод();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	УстановитьСостояниеДокумента();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "Запись_ОтветНаЗапросНалоговогоМониторинга"
		И ТипЗнч(Параметр) = Тип("Структура") И Параметр.Свойство("ДокументОснования") И Параметр.ДокументОснования = Объект.Ссылка Тогда
				
		ДанныеНадписи = Параметр.РеквизитыОтветаНаЗапрос;
		ОформитьДанныеОтветНаЗапрос(ЭтотОбъект, ДанныеНадписи);
		УправлениеЭлементамиФормы(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТипЗапросаПриИзменении(Элемент)
	СрокВыполненияДней = СрокВыполненияЗапроса(Объект.ТипЗапроса);
	Объект.СрокВыполненияЗапроса = Объект.Дата + СрокВыполненияДней * 24 * 3600;
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	Объект.СрокВыполненияЗапроса = Объект.Дата + СрокВыполненияДней * 24 * 3600;
КонецПроцедуры

&НаКлиенте
Процедура ПолеВыбораПериодичностьПриИзменении(Элемент)
	
	ОперацииПриСменеПериодичности();

КонецПроцедуры

&НаКлиенте
Процедура ДокументОтветНаЗапросНадписьНажатие(Элемент, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(ДокументОтветНаЗапрос) Тогда
		СтандартнаяОбработка = Ложь;
	    ПоказатьЗначение(, ДокументОтветНаЗапрос);
	КонецЕсли; 
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

#Область СтандартныеПодсистемыОбработчикиКоманд

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
    ПодключаемыеКомандыКлиент.НачатьВыполнениеКоманды(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПродолжитьВыполнениеКомандыНаСервере(ПараметрыВыполнения, ДополнительныеПараметры) Экспорт
    ВыполнитьКомандуНаСервере(ПараметрыВыполнения);
КонецПроцедуры

&НаСервере
Процедура ВыполнитьКомандуНаСервере(Знач ПараметрыВыполнения)
    ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, ПараметрыВыполнения, Объект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
    ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

&НаКлиенте
Процедура НастроитьПериод(Команда)
			
	Диалог = Новый ДиалогРедактированияСтандартногоПериода();
	
	Диалог.Период.ДатаНачала    = Объект.ДатаНачалаПериода;
	Диалог.Период.ДатаОкончания = Объект.ДатаКонцаПериода;
	ОписаниеОповещения = Новый ОписаниеОповещения("НастроитьПериодЗавершение", ЭтотОбъект);
	Диалог.Показать(ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьПериодЗавершение(Период, ДополнительныеПараметры) Экспорт
	
	Если Период <> Неопределено Тогда
		
		Объект.ДатаНачалаПериода = Период.ДатаНачала;
		Объект.ДатаКонцаПериода  = Период.ДатаОкончания;
				
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура УстановитьПредыдущийПериод(Команда)
	ИзменитьПериод(-1);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСледующийПериод(Команда)
	ИзменитьПериод(1);
КонецПроцедуры

&НаКлиенте
Процедура КомандаСоздатьОтветНаЗапрос(Команда)
	
	ПараметрыСоздания = Новый Структура;
	ПараметрыСоздания.Вставить("Основание", Объект.Ссылка);
	
	ОткрытьФорму("Документ.бит_ОтветНаЗапросНалоговогоМониторинга.ФормаОбъекта", ПараметрыСоздания, ЭтотОбъект);	
		
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеЭлементамиФормы(Форма)
	
	Элементы = Форма.Элементы;
	Объект   = Форма.Объект;
	
	Если Объект.Периодичность = ПредопределенноеЗначение("Перечисление.Периодичность.Квартал") Тогда  // ежеквартально
						
		Элементы.ГруппаСтраницыПериод.ТекущаяСтраница = Элементы.ГруппаСтраницыПериод.ПодчиненныеЭлементы["ГруппаСтандартныйПериод"];

	ИначеЕсли Объект.Периодичность = ПредопределенноеЗначение("Перечисление.Периодичность.Месяц") Тогда  // ежеквартально

		Элементы.ГруппаСтраницыПериод.ТекущаяСтраница = Элементы.ГруппаСтраницыПериод.ПодчиненныеЭлементы["ГруппаСтандартныйПериод"];
		
	ИначеЕсли ЗначениеЗаполнено(Объект.Периодичность) Тогда
			
		Элементы.ГруппаСтраницыПериод.ТекущаяСтраница = Элементы.ГруппаСтраницыПериод.ПодчиненныеЭлементы["ГруппаПроизвольныйПериод"];
			
	Иначе
			
		Элементы.ГруппаСтраницыПериод.ТекущаяСтраница.Доступность = Ложь;
					
	КонецЕсли;

	Элементы.КомандаСоздатьОтветНаЗапрос.Видимость = Не ЗначениеЗаполнено(Форма.ДокументОтветНаЗапрос);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СрокВыполненияЗапроса(Знач ТипЗапроса)
		
	Возврат Документы.бит_ЗапросНалоговогоМониторинга.СрокВыполненияЗапроса(ТипЗапроса);
	
КонецФункции

&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	УстановитьСостояниеДокумента();	
	СрокВыполненияДней = СрокВыполненияЗапроса(Объект.ТипЗапроса);
	ЗаполнитьДанныеОбОтвете(ЭтотОбъект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьДанныеОбОтвете(Форма)
	
	Объект = Форма.Объект;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ОтветНаЗапросНалоговогоМониторинга.Ссылка КАК ОтветНаЗапрос
		|ИЗ
		|	Документ.бит_ОтветНаЗапросНалоговогоМониторинга КАК ОтветНаЗапросНалоговогоМониторинга
		|ГДЕ
		|	ОтветНаЗапросНалоговогоМониторинга.ЗапросОснование = &ЗапросОснование";
	
	Запрос.УстановитьПараметр("ЗапросОснование", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		ОформитьДанныеОтветНаЗапрос(Форма, Неопределено);
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
        Выборка.Следующий();
		РеквизитыОтвета = Документы.бит_ОтветНаЗапросНалоговогоМониторинга.РеквизитыОтветаНаЗапрос(Выборка.ОтветНаЗапрос);
		ОформитьДанныеОтветНаЗапрос(Форма, РеквизитыОтвета);
	КонецЕсли; 	

КонецПроцедуры

&НаСервере
Процедура УстановитьСостояниеДокумента()
	
	СостояниеДокумента = бит_ОбщегоНазначения.СостояниеДокумента(Объект);
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьПериод(Знач Шаг)

	Если Объект.Периодичность = Перечисления.Периодичность.Квартал Тогда  // ежеквартально
		Объект.ДатаКонцаПериода  = КонецМесяца(ДобавитьМесяц(Объект.ДатаКонцаПериода, 3*Шаг)); 
		Объект.ДатаНачалаПериода = НачалоКвартала(Объект.ДатаКонцаПериода);
	Иначе
		Объект.ДатаКонцаПериода  = КонецМесяца(ДобавитьМесяц(Объект.ДатаКонцаПериода, Шаг)); 
		Объект.ДатаНачалаПериода = НачалоМесяца(Объект.ДатаКонцаПериода);
	КонецЕсли;

	ПоказатьПериод();
	
КонецПроцедуры

&НаСервере
Процедура ПоказатьПериод()

	СтрПериодОтчета = ПредставлениеПериода( НачалоДня(Объект.ДатаНачалаПериода), КонецДня(Объект.ДатаКонцаПериода), "ФП = Истина" );

	// Покажем период в диалоге
	Элементы.НадписьПериодСоставленияОтчета.Заголовок = СтрПериодОтчета;

КонецПроцедуры

&НаСервере
Процедура ОперацииПриСменеПериодичности()
		
	Если Объект.Периодичность = Перечисления.Периодичность.Квартал Тогда  // ежеквартально
		
		Объект.ДатаКонцаПериода  = КонецМесяца(ДобавитьМесяц(КонецКвартала(ТекущаяДатаСеанса()), -3));
		Объект.ДатаНачалаПериода = НачалоКвартала(Объект.ДатаКонцаПериода);
				
		Элементы.ГруппаСтраницыПериод.ТекущаяСтраница = Элементы.ГруппаСтраницыПериод.ПодчиненныеЭлементы["ГруппаСтандартныйПериод"];

	ИначеЕсли Объект.Периодичность = Перечисления.Периодичность.Месяц Тогда  // ежеквартально

		Объект.ДатаКонцаПериода  = КонецМесяца(Объект.ДатаКонцаПериода);
		Объект.ДатаНачалаПериода = НачалоМесяца(Объект.ДатаКонцаПериода);

		Элементы.ГруппаСтраницыПериод.ТекущаяСтраница = Элементы.ГруппаСтраницыПериод.ПодчиненныеЭлементы["ГруппаСтандартныйПериод"];
		
	ИначеЕсли ЗначениеЗаполнено(Объект.Периодичность) Тогда
			
		Элементы.ГруппаСтраницыПериод.ТекущаяСтраница = Элементы.ГруппаСтраницыПериод.ПодчиненныеЭлементы["ГруппаПроизвольныйПериод"];
			
	Иначе
			
		Элементы.ГруппаСтраницыПериод.ТекущаяСтраница.Доступность = Ложь;
			
		Возврат;
		
	КонецЕсли;
	
	Элементы.ГруппаСтраницыПериод.ТекущаяСтраница.Доступность = Истина;

	ИзменитьПериод(0);
	ПоказатьПериод();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОформитьДанныеОтветНаЗапрос(Форма, ДанныеНадписи)

	Если ДанныеНадписи = Неопределено Тогда
		Форма.ДокументОтветНаЗапросНадпись = НСтр("ru = 'Ответ не найден'; en = 'Answer not found'");
		
	Иначе
	 
		СтатусПроведения = "";
		Если Не ДанныеНадписи.ОтветНаЗапрос = Неопределено Тогда
			
			Форма.ДокументОтветНаЗапрос = ДанныеНадписи.ОтветНаЗапрос;
			Если НЕ ЗначениеЗаполнено(ДанныеНадписи.Проведен) Тогда 
				// если не заполнено ничего не делаем
			ИначеЕсли Не ДанныеНадписи.Проведен Тогда
				СтатусПроведения = НСтр("ru = '(не проведен)'; en = '(not completed)'");
				Форма.Элементы.ДокументОтветНаЗапросНадпись.ЦветТекста = Новый Цвет(178,34,34);
			Иначе
				Форма.Элементы.ДокументОтветНаЗапросНадпись.ЦветТекста = Новый Цвет;
			КонецЕсли;
			
		КонецЕсли;
		
		Форма.ДокументОтветНаЗапросНадпись = ДанныеНадписи.КраткоеПредставление + " " + СтатусПроведения;
	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти


