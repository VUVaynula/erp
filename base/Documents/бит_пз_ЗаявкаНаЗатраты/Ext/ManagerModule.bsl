Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт

	ПараметрыПроведения = Новый Структура;
	ПараметрыПроведения.Вставить("ИсполнениеБюджетаРеквизиты", Новый ТаблицаЗначений);
	ПараметрыПроведения.Вставить("ИсполнениеБюджета", 		   Новый ТаблицаЗначений);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.Дата КАК Период,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.ЦФО КАК ЦФО,
	|	Реквизиты.Сценарий КАК Сценарий,
	|	Реквизиты.Сценарий.Валюта КАК ВалютаСценария,
	|	Реквизиты.ВалютаДокумента КАК Валюта,
	|	Реквизиты.КурсДокумента КАК Курс,
	|	Реквизиты.КратностьДокумента КАК Кратность,
	|	Реквизиты.СписатьЛимиты КАК СписатьЛимиты
	|ИЗ
	|	Документ.бит_пз_ЗаявкаНаЗатраты КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";
	
	Результат    	 = Запрос.Выполнить();
	ТаблицаРеквизиты = Результат.Выгрузить();
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ТаблицаРеквизиты[0]);
		
	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("Организация", Реквизиты.Организация);
	ПараметрыНастройки.Вставить("ЦФО",		   Реквизиты.ЦФО);
								
	КонтролироватьБюджет 	= бит_НастройкиПрограммы.КонтролироватьЗаявкуНаЗатратыПоБюджету(ПараметрыНастройки, Реквизиты.Период);
	НеУчитыватьСверхБюджета = бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеЗаявкиНаЗатратыПриКонтролеПоБюджету(ПараметрыНастройки,
								Реквизиты.Период);
								
	Запрос.УстановитьПараметр("КонтролироватьБюджет", 	 КонтролироватьБюджет);
	Запрос.УстановитьПараметр("НеУчитыватьСверхБюджета", НеУчитыватьСверхБюджета);		
	
	ЗатратыПланируютсяСНДС = Константы.бит_пз_ЗатратыПланируютсяСНДС.Получить();
	Запрос.УстановитьПараметр("ЗатратыПланируютсяСНДС", ЗатратыПланируютсяСНДС);
	
	НомераТаблиц = Новый Структура;
	Запрос.Текст = ТекстЗапросаПланируемыеЗатраты(НомераТаблиц)
				 + ТекстЗапросаПланируемыеЗатратыАналитика(НомераТаблиц)
				 + ТекстЗапросаКонтрольИсполненияБюджета(НомераТаблиц);

	Результат = Запрос.ВыполнитьПакет();
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла;

	КурсыВалют = бит_Бюджетирование.КурсыВалютСценария(Реквизиты.Регистратор, Реквизиты.Период,
					Новый Структура("Документ, Регл, Сценарий"));
						
	Реквизиты.Вставить("КурсыВалют", КурсыВалют);
	ПараметрыПроведения.Вставить("Реквизиты", Реквизиты);
	
	ПодготовитьТаблицыРасчетыВВалюте(ПараметрыПроведения, КурсыВалют);

	Для каждого СтрокаДокумента Из ПараметрыПроведения.ИсполнениеБюджета Цикл
		СтрокаДокумента.Сумма = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(
									СтрокаДокумента.Сумма, КурсыВалют.Документ, КурсыВалют.Сценарий);
	КонецЦикла;

	Возврат ПараметрыПроведения;
	
КонецФункции

Функция ПараметрыРасчетаБюджета(Источник) Экспорт
	
	ПоляИсточника = Новый Массив;
	ПоляИсточника.Добавить("Аналитика_1");
	ПоляИсточника.Добавить("Аналитика_2");
	ПоляИсточника.Добавить("Аналитика_3");
	ПоляИсточника.Добавить("Аналитика_4");
	ПоляИсточника.Добавить("Аналитика_5");
	ПоляИсточника.Добавить("Аналитика_6");
	ПоляИсточника.Добавить("Аналитика_7");
	ПоляИсточника.Добавить("Аналитика_8");
	ПоляИсточника.Добавить("Аналитика_9");
	ПоляИсточника.Добавить("Аналитика_10");
	ПоляИсточника.Добавить("Аналитика_11");
	ПоляИсточника.Добавить("Аналитика_12");
	ПоляИсточника.Добавить("ВалютаДокумента");
	ПоляИсточника.Добавить("Дата");
	ПоляИсточника.Добавить("ЖелаемаяДатаПоступления");
	ПоляИсточника.Добавить("Договор");
	ПоляИсточника.Добавить("Контрагент");
	ПоляИсточника.Добавить("КратностьДокумента");
	ПоляИсточника.Добавить("КурсДокумента");
	ПоляИсточника.Добавить("Организация");
	ПоляИсточника.Добавить("СверхБюджета");
	ПоляИсточника.Добавить("СписатьЛимиты");
	ПоляИсточника.Добавить("Ссылка");
	ПоляИсточника.Добавить("СтатьяОборотов");
	ПоляИсточника.Добавить("Сумма");
	ПоляИсточника.Добавить("Сценарий");
	ПоляИсточника.Добавить("ЦФО");
	ИменаПолей = СтрСоединить(ПоляИсточника, ",");
	
	РеквизитыИсточника = Новый Структура(ИменаПолей);
	ЭтоСсылка          = (ТипЗнч(Источник) = Тип("ДокументСсылка.бит_пз_ЗаявкаНаЗатраты"));
	
	Если ЭтоСсылка Тогда
		РеквизитыИсточника = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Источник, ИменаПолей);
	Иначе
		ЗаполнитьЗначенияСвойств(РеквизитыИсточника, Источник);
	КонецЕсли;
	
	ОтключитьКонтрольЗаявокПоЛимитам = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РеквизитыИсточника.Сценарий, 
																"ОтключитьКонтрольЗаявокПоЛимитам");
	
	РеквизитыИсточника.Вставить("ОтключитьКонтрольЗаявокПоЛимитам", ОтключитьКонтрольЗаявокПоЛимитам);
	
	ПараметрыРасчета = Новый Структура;
	ПараметрыРасчета.Вставить("ИсполнениеБюджетаРеквизиты", 
		бит_КонтрольИсполненияБюджета.ПустаяТаблицаИсполнениеБюджетаРеквизиты());
	ПараметрыРасчета.Вставить("ИсполнениеБюджета",
		бит_КонтрольИсполненияБюджета.ПустаяТаблицаИсполнениеБюджетаДляЦелейКонтроля());
		
	Если РеквизитыИсточника.ОтключитьКонтрольЗаявокПоЛимитам Тогда
		КонтролироватьБюджет = Ложь;
	Иначе	
		КонтролироватьБюджет = бит_НастройкиПрограммы.КонтролироватьЗаявкуПоБюджету(РеквизитыИсточника, РеквизитыИсточника.Дата);
	КонецЕсли;	
	
	НеУчитыватьСверхБюджета = бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеЗаявкиПриКонтролеПоБюджету(РеквизитыИсточника, 
									РеквизитыИсточника.Дата);
									
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",                  РеквизитыИсточника.Ссылка);
	Запрос.УстановитьПараметр("КонтролироватьБюджет", 	 КонтролироватьБюджет);
	Запрос.УстановитьПараметр("НеУчитыватьСверхБюджета", НеУчитыватьСверхБюджета);
	Запрос.УстановитьПараметр("СинонимСписка", 			 НСтр("ru = 'Потребности'; en = 'Requirements'"));
	ЗатратыПланируютсяСНДС = Константы.бит_пз_ЗатратыПланируютсяСНДС.Получить();
	Запрос.УстановитьПараметр("ЗатратыПланируютсяСНДС",  ЗатратыПланируютсяСНДС);
	
	ВалютаСценария = РеквизитыИсточника.ВалютаДокумента;
	Если ЗначениеЗаполнено(РеквизитыИсточника.Сценарий) Тогда
		ВалютаСценария = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РеквизитыИсточника.Сценарий, "Валюта");
	КонецЕсли;
	
	Если ЭтоСсылка Тогда
		НомераТаблиц = Новый Структура;
		Запрос.Текст = ТекстЗапросаКонтрольИсполненияБюджета(НомераТаблиц);
		Результат    = Запрос.ВыполнитьПакет();
		Для каждого НомерТаблицы Из НомераТаблиц Цикл
			ПараметрыРасчета.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
		КонецЦикла;	
	Иначе
		ИсполнениеБюджетаРеквизиты = ПараметрыРасчета.ИсполнениеБюджетаРеквизиты;
		СтрокаРеквизитов           = ИсполнениеБюджетаРеквизиты.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаРеквизитов, РеквизитыИсточника);
		СтрокаРеквизитов.ВалютаСценария          = ВалютаСценария;
		СтрокаРеквизитов.КонтролироватьБюджет    = КонтролироватьБюджет;
		СтрокаРеквизитов.НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета;
		СтрокаРеквизитов.Регистратор             = РеквизитыИсточника.Ссылка;
		СтрокаРеквизитов.РежимКонтроля           = Перечисления.бит_РежимыКонтроляПоБюджету.Заявки;
		СтрокаРеквизитов.СценарийКонтролируемый  = РеквизитыИсточника.Сценарий;
		
		ИсполнениеБюджета = ПараметрыРасчета.ИсполнениеБюджета;
		СтрокаИсполенения = ИсполнениеБюджета.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаИсполенения, РеквизитыИсточника);
		СтрокаИсполенения.Период                 = РеквизитыИсточника.ЖелаемаяДатаПоступления;
		СтрокаИсполенения.КонтролироватьСумму    = Истина;
		
		КонтролироватьПоСтатье = Ложь;
		Если ЗначениеЗаполнено(РеквизитыИсточника.СтатьяОборотов) Тогда
			КонтролироватьПоСтатье = НЕ ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РеквизитыИсточника.СтатьяОборотов,
																					"НеКонтролировать_Заявки");
		КонецЕсли;
		СтрокаИсполенения.КонтролироватьПоСтатье = КонтролироватьПоСтатье;
	КонецЕсли;
	
	КурсДокумента = Новый Структура;
	КурсДокумента.Вставить("Курс"     , РеквизитыИсточника.КурсДокумента);
	КурсДокумента.Вставить("Кратность", РеквизитыИсточника.КратностьДокумента);
	КурсДокумента.Вставить("Валюта"   , РеквизитыИсточника.ВалютаДокумента);
	КурсВалютыСценария = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ВалютаСценария, РеквизитыИсточника.Дата);

	Для каждого СтрокаДокумента Из ПараметрыРасчета.ИсполнениеБюджета Цикл
		СтрокаДокумента.Сумма = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(
									СтрокаДокумента.Сумма, КурсДокумента, КурсВалютыСценария);
	КонецЦикла;

	Возврат ПараметрыРасчета;
	
КонецФункции

// Функция получает структуру остатков документа для установки статуса.
//
// Параметры:
//   ЗаявкаНаЗатраты - ДокументСсылка.бит_пз_ЗаявкаНаЗатраты
//
// Возвращаемое значение:
//  СтрОплата - Структура.
//
Функция ПолучитьОстаткиДляУстановкиСтатуса(ЗаявкаНаЗатраты) Экспорт

	СтрОплата = Новый Структура("КоличествоПлан, КоличествоФакт, КоличествоОстаток",0, 0, 0);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЗаявкаНаЗатраты"     , ЗаявкаНаЗатраты);
	Запрос.УстановитьПараметр("МоментВремени"     	, ТекущаяДатаСеанса());
	
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СУММА(ЕСТЬNULL(ПланируемыеЗатратыОбороты.КоличествоПриход, 0)) КАК КоличествоПлан,
	               |	СУММА(ЕСТЬNULL(ПланируемыеЗатратыОбороты.СуммаПриход, 0)) КАК СуммаПлан,
	               |	СУММА(0) КАК КоличествоФакт,
	               |	СУММА(0) КАК СуммаФакт
	               |ПОМЕСТИТЬ Заявка
	               |ИЗ
	               |	РегистрНакопления.бит_пз_ПланируемыеЗатраты.Обороты(, , Авто, ЗаявкаНаЗатраты = &ЗаявкаНаЗатраты) КАК ПланируемыеЗатратыОбороты
	               |ГДЕ
	               |	ТИПЗНАЧЕНИЯ(ПланируемыеЗатратыОбороты.Регистратор) = ТИП(Документ.бит_пз_ЗаявкаНаЗатраты)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СУММА(0) КАК КоличествоПлан,
	               |	СУММА(0) КАК СуммаПлан,
	               |	СУММА(ЕСТЬNULL(ПланируемыеЗатратыОбороты.КоличествоРасход, 0)) КАК КоличествоФакт,
	               |	СУММА(ЕСТЬNULL(ПланируемыеЗатратыОбороты.СуммаРасход, 0)) КАК СуммаФакт
	               |ПОМЕСТИТЬ ОтражениеФакта
	               |ИЗ
	               |	РегистрНакопления.бит_пз_ПланируемыеЗатраты.Обороты(, , Авто, ЗаявкаНаЗатраты = &ЗаявкаНаЗатраты) КАК ПланируемыеЗатратыОбороты
	               |ГДЕ
	               |	ТИПЗНАЧЕНИЯ(ПланируемыеЗатратыОбороты.Регистратор) = ТИП(Документ.бит_пз_ОтражениеФактаЗатрат)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	СУММА(ЕСТЬNULL(Заявка.КоличествоПлан, 0) + ЕСТЬNULL(ОтражениеФакта.КоличествоПлан, 0)) КАК КоличествоПлан,
	               |	СУММА(ЕСТЬNULL(Заявка.КоличествоФакт, 0) + ЕСТЬNULL(ОтражениеФакта.КоличествоФакт, 0)) КАК КоличествоФакт,
	               |	СУММА(ЕСТЬNULL(Заявка.КоличествоПлан, 0) + ЕСТЬNULL(ОтражениеФакта.КоличествоПлан, 0) - (ЕСТЬNULL(Заявка.КоличествоФакт, 0) + ЕСТЬNULL(ОтражениеФакта.КоличествоФакт, 0))) КАК КоличествоОстаток,
	               |	СУММА(ЕСТЬNULL(Заявка.СуммаПлан, 0) + ЕСТЬNULL(ОтражениеФакта.СуммаПлан, 0)) КАК СуммаПлан,
	               |	СУММА(ЕСТЬNULL(Заявка.СуммаФакт, 0) + ЕСТЬNULL(ОтражениеФакта.СуммаФакт, 0)) КАК СуммаФакт,
	               |	СУММА(ЕСТЬNULL(Заявка.СуммаПлан, 0) + ЕСТЬNULL(ОтражениеФакта.СуммаПлан, 0) - (ЕСТЬNULL(Заявка.СуммаФакт, 0) + ЕСТЬNULL(ОтражениеФакта.СуммаФакт, 0))) КАК СуммаОстаток
	               |ИЗ
	               |	Заявка КАК Заявка,
	               |	ОтражениеФакта КАК ОтражениеФакта";
				   
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ЗаполнитьЗначенияСвойств(СтрОплата, Выборка);
		
	КонецЕсли; 
	
	Возврат СтрОплата;
	
КонецФункции // ПолучитьОстаткиДляУстановкиСтатуса()

// Функция получает структуру остатков документа.
//
// Параметры:
//   ЗаявкаНаЗатраты - ДокументСсылка.бит_пз_ЗаявкаНаЗатраты
//
// Возвращаемое значение:
//  СтрОплата - Структура.
//
Функция ПолучитьОстатки(ЗаявкаНаЗатраты) Экспорт

	СтрОплата = Новый Структура("КоличествоПлан, КоличествоФакт, КоличествоОстаток",0, 0, 0);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", ЗаявкаНаЗатраты);
	Запрос.УстановитьПараметр("Организация"         , ЗаявкаНаЗатраты.Организация);
	Запрос.УстановитьПараметр("ЗаявкаНаЗатраты"     , ЗаявкаНаЗатраты);
	
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СУММА(ЕСТЬNULL(ПланируемыеЗатраты.КоличествоКонечныйОстаток, 0)) КАК КоличествоОстаток,
	               |	СУММА(ЕСТЬNULL(ПланируемыеЗатраты.КоличествоПриход, 0)) КАК КоличествоПлан,
	               |	СУММА(ЕСТЬNULL(ПланируемыеЗатраты.КоличествоРасход, 0)) КАК КоличествоФакт
	               |ИЗ
	               |	РегистрНакопления.бит_пз_ПланируемыеЗатраты.ОстаткиИОбороты(
	               |			,
	               |			,
	               |			,
	               |			,
	               |			ДокументПланирования = &ДокументПланирования
	               |				И Организация = &Организация
	               |				И ЗаявкаНаЗатраты = &ЗаявкаНаЗатраты) КАК ПланируемыеЗатраты";
				   
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		СтрОплата.КоличествоПлан 	= ?(ЗначениеЗаполнено(Выборка.КоличествоПлан)	, Выборка.КоличествоПлан, 0);
		СтрОплата.КоличествоФакт 	= ?(ЗначениеЗаполнено(Выборка.КоличествоФакт)	, Выборка.КоличествоФакт, 0);
		СтрОплата.КоличествоОстаток = ?(ЗначениеЗаполнено(Выборка.КоличествоОстаток), Выборка.КоличествоОстаток, 0);
		
	КонецЕсли; 

	Возврат СтрОплата;
	
КонецФункции // ПолучитьОстатки()

// Функция получает остатки номенклатуры из регистра Планируемые затраты.
//
// Параметры:
//   ЗаявкаНаЗатраты - ДокументСсылка.бит_пз_ЗаявкаНаЗатраты
//
// Возвращаемое значение:
//  СтрОплата - Структура.
//
Функция ПолучитьОстаткиНоменклатуры(ЗаявкаНаЗатраты) Экспорт

	СтрОплата = Новый Структура("КоличествоПлан, КоличествоФакт, КоличествоОстаток",0, 0, 0);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", ЗаявкаНаЗатраты);
	Запрос.УстановитьПараметр("Организация"         , ЗаявкаНаЗатраты.Организация);
	Запрос.УстановитьПараметр("ЗаявкаНаЗатраты"     , ЗаявкаНаЗатраты);
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПланируемыеЗатратыОстатки.Номенклатура,
	               |	ПланируемыеЗатратыОстатки.Организация,
	               |	ПланируемыеЗатратыОстатки.ЗаявкаНаЗатраты,
	               |	ЕСТЬNULL(ПланируемыеЗатратыОстатки.КоличествоОстаток, 0) КАК Количество,
	               |	ПланируемыеЗатратыАналитика.Контрагент,
	               |	ПланируемыеЗатратыАналитика.Договор,
	               |	ПланируемыеЗатратыАналитика.ВалютаДокумента,
	               |	ПланируемыеЗатратыАналитика.Сценарий,
	               |	ПланируемыеЗатратыАналитика.Важность,
	               |	ПланируемыеЗатратыАналитика.Склад,
	               |	ПланируемыеЗатратыАналитика.СтатьяОборотов,
	               |	ПланируемыеЗатратыАналитика.ЦФО,
	               |	ПланируемыеЗатратыАналитика.Аналитика_1,
	               |	ПланируемыеЗатратыАналитика.Аналитика_2,
	               |	ПланируемыеЗатратыАналитика.Аналитика_3,
	               |	ПланируемыеЗатратыАналитика.Аналитика_4,
	               |	ПланируемыеЗатратыАналитика.Аналитика_5,
	               |	ПланируемыеЗатратыАналитика.Аналитика_6,
	               |	ПланируемыеЗатратыАналитика.Аналитика_7,
	               |	ПланируемыеЗатратыАналитика.Аналитика_8,
	               |	ПланируемыеЗатратыАналитика.Аналитика_9,
	               |	ПланируемыеЗатратыАналитика.Аналитика_10,
	               |	ПланируемыеЗатратыАналитика.Аналитика_11,
	               |	ПланируемыеЗатратыАналитика.Аналитика_12,
	               |	ПланируемыеЗатратыАналитика.Ответственный,
	               |	ПланируемыеЗатратыАналитика.Инициатор,
	               |	ПланируемыеЗатратыАналитика.НоменклатураПоставщика,
	               |	ПланируемыеЗатратыАналитика.Упаковка,
	               |	ПланируемыеЗатратыАналитика.ВидОперации,
	               |	ПланируемыеЗатратыАналитика.СтавкаНДС,
	               |	ЕСТЬNULL(ПланируемыеЗатратыАналитика.Цена, 0) КАК Цена,
	               |	ЕСТЬNULL(ПланируемыеЗатратыАналитика.Сумма, 0) * ЕСТЬNULL(ПланируемыеЗатратыОстатки.КоличествоОстаток, 0) / ЕСТЬNULL(ПланируемыеЗатратыАналитика.Количество, 0) КАК Сумма,
	               |	ПланируемыеЗатратыАналитика.Содержание,
	               |	ПланируемыеЗатратыАналитика.Комментарий,
	               |	ПланируемыеЗатратыОстатки.Характеристика
	               |ИЗ
	               |	РегистрНакопления.бит_пз_ПланируемыеЗатраты.Остатки({(&КонецПериода)}, ТИПЗНАЧЕНИЯ(ДокументПланирования) = ТИП(Документ.бит_пз_ЗаявкаНаЗатраты)) КАК ПланируемыеЗатратыОстатки
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.бит_пз_ПланируемыеЗатратыАналитика КАК ПланируемыеЗатратыАналитика
	               |		ПО ПланируемыеЗатратыОстатки.ЗаявкаНаЗатраты = ПланируемыеЗатратыАналитика.ЗаявкаНаЗатраты
	               |			И ПланируемыеЗатратыОстатки.Организация = ПланируемыеЗатратыАналитика.Организация
	               |			И ПланируемыеЗатратыОстатки.ДокументПланирования = ПланируемыеЗатратыАналитика.ДокументПланирования
	               |			И ПланируемыеЗатратыОстатки.Номенклатура = ПланируемыеЗатратыАналитика.Номенклатура
	               |			И ПланируемыеЗатратыОстатки.Характеристика = ПланируемыеЗатратыАналитика.Характеристика
	               |ГДЕ
	               |	ПланируемыеЗатратыОстатки.ЗаявкаНаЗатраты = &ЗаявкаНаЗатраты
	               |	И ПланируемыеЗатратыОстатки.ДокументПланирования = &ДокументПланирования
	               |	И ПланируемыеЗатратыОстатки.Организация = &Организация";
				   
	Результат = Запрос.Выполнить().Выгрузить();

	Возврат Результат;
	
КонецФункции // ПолучитьОстаткиНоменклатуры()

// Функция находит аналитики тип которых совпадает с типом реквизитов документа.
//
// Параметры: 
//   МетаОбъект - ОбъектМетаданных
//
// Возвращаемое значение:
//   СовпадающиеАналитики - Соответствие.
//
Функция НайтиАналитикиСовпадающиеСРеквизитами(МетаОбъект) Экспорт 

	СовпадающиеАналитики = Новый Соответствие;
	
	МассивТипов = Новый Массив;
	
	Для каждого Реквизит Из МетаОбъект.Реквизиты Цикл
	
		Если Найти(Реквизит.Имя, "Аналитика")=0 Тогда
		
			Для каждого ТипРек Из Реквизит.Тип.Типы() Цикл
			
				Если НЕ ТипРек = Тип("Булево")
					И НЕ ТипРек = Тип("Дата")
					И НЕ ТипРек = Тип("Строка")
					И НЕ ТипРек = Тип("Число") Тогда
					
					СтрРекв = Новый Структура("Имя, Тип", Реквизит.Имя, ТипРек);
					МассивТипов.Добавить(СтрРекв);
				
				КонецЕсли; 
			
			КонецЦикла; 
		
		КонецЕсли; 
	
	КонецЦикла; 
	
	Настр = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	
	Для каждого Аналит Из Настр Цикл
		
		Если НЕ Аналит.Значение.ЭтоСоставнойТип Тогда 
		
			Для каждого СтрРекв Из МассивТипов Цикл
				
				ТипРек = СтрРекв.Тип;
				Если Аналит.Значение.ТипЗначения.СодержитТип(ТипРек) Тогда 
					СовпадающиеАналитики.Вставить(Аналит.Ключ, СтрРекв.Имя);
					Прервать;
				КонецЕсли;
			
			КонецЦикла; 
			
		КонецЕсли;	
			
	КонецЦикла; 
	
	Возврат СовпадающиеАналитики;
	
КонецФункции // НайтиАналитикиСовпадающиеСРеквизитами()

// Функция выполняет поиск сводной заявки по заявке на затраты.
//
// Параметры: 
//   ЗаявкаНаЗатраты - ДокументСсылка.бит_пз_ЗаявкаНаЗатраты.
//
Функция НайтиСводнуюЗаявкуНаЗатраты(ЗаявкаНаЗатраты) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЗаявкаНаЗатраты", ЗаявкаНаЗатраты);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	СводнаяЗаявкаНаЗатраты.Ссылка
	               |ИЗ
	               |	Документ.бит_пз_СводнаяЗаявкаНаЗатраты.ЗаявкиНаЗатраты КАК СводнаяЗаявкаНаЗатраты
	               |ГДЕ
	               |	СводнаяЗаявкаНаЗатраты.ЗаявкаНаЗатраты = &ЗаявкаНаЗатраты
	               |	И СводнаяЗаявкаНаЗатраты.Ссылка.Проведен = ИСТИНА";
	
	Результат = Запрос.Выполнить();
	
	Возврат НЕ Результат.Пустой();
	
КонецФункции // НайтиСводнуюЗаявкуНаЗатраты()

Функция ДоступностьХарактеристики(Номенклатура) Экспорт 

	ДоступностьХарактеристики = Истина;
	
	Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	ВидНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Номенклатура, "ВидНоменклатуры");
	Если НЕ ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИспользованиеХарактеристик = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидНоменклатуры, "ИспользованиеХарактеристик");
	Если ИспользованиеХарактеристик = Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать Тогда
		ДоступностьХарактеристики = Ложь;
	КонецЕсли; 
	
	Возврат ДоступностьХарактеристики;
	
КонецФункции

// Функция определяет новый статус объекта в зависимости от режима записи документа
//и предыдущего статуса. Механизм определения статусов может быть переопределен алгоритмами.
//
// Параметры:
//  ТекущийОбъект - ДокументОбъект.бит_пз_ЗаявкаНаЗатраты.
//  ПараметрыУстановкиСтатуса - Структура - состав полей см. в функции бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса.
//
// Возвращаемое значение:
//   НовыйСтатус - СправочникСсылка.бит_СтатусыОбъектов.
//
Функция НовыйСтатусОбъекта(ТекущийОбъект, ПараметрыУстановкиСтатуса) Экспорт
	
	Если Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(ПараметрыУстановкиСтатуса.ТекущийСтатус,
			Перечисления.бит_ТипыСтатусовОбъектов.Закрыт) Тогда
		Возврат ПараметрыУстановкиСтатуса.ТекущийСтатус;
	КонецЕсли;
		
	Если ПараметрыУстановкиСтатуса.ПараметрыОплаты = Неопределено Тогда
		СтруктураОплаты = ПолучитьОстаткиДляУстановкиСтатуса(ТекущийОбъект.Ссылка);
	Иначе	
		СтруктураОплаты = ПараметрыУстановкиСтатуса.ПараметрыОплаты;
	КонецЕсли;
	
	РежимЗаписи = ПараметрыУстановкиСтатуса.РежимЗаписи;
	
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
		ИЛИ (РежимЗаписи = РежимЗаписиДокумента.Запись И НЕ ТекущийОбъект.Проведен) Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Черновик;
	КонецЕсли;
	
	СсылкаНаОбъект = ТекущийОбъект.Ссылка;
	
	ОтменаСводнойЗаявки = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ТекущийОбъект.ДополнительныеСвойства, "ОтменаСводнойЗаявки", Ложь);
	
	Если бит_ВизированиеСервер.ЕстьБлокирующиеРешения(СсылкаНаОбъект) Тогда
		
		Возврат Справочники.бит_СтатусыОбъектов.Отклонен;
		
	ИначеЕсли СтруктураОплаты.КоличествоОстаток <= 0.01 И СтруктураОплаты.КоличествоФакт > 0 Тогда
		
		Возврат Справочники.бит_СтатусыОбъектов.ЗаявкаНаЗатраты_Исполнена;
		
	ИначеЕсли СтруктураОплаты.КоличествоФакт > 0 Тогда
		
		Возврат Справочники.бит_СтатусыОбъектов.ЗаявкаНаЗатраты_ЧастичноИсполнена;
		
	ИначеЕсли Документы.бит_пз_ЗаявкаНаЗатраты.НайтиСводнуюЗаявкуНаЗатраты(СсылкаНаОбъект)
				И НЕ ОтменаСводнойЗаявки Тогда
				
		Возврат Справочники.бит_СтатусыОбъектов.ЗаявкаНаЗатраты_ВключенаВСводнуюЗаявку;
		
	ИначеЕсли бит_ВизированиеСервер.ВсеВизыСогласованы(СсылкаНаОбъект) Тогда
		
		Возврат Справочники.бит_СтатусыОбъектов.Утвержден;
		
	КонецЕсли;
	
	Возврат Справочники.бит_СтатусыОбъектов.НаСогласовании;
	
КонецФункции

Процедура СформироватьПланируемыеЗатраты(ПланируемыеЗатраты, ТаблицаРеквизиты, Движения, Отказ) Экспорт

	Если НЕ ЗначениеЗаполнено(ПланируемыеЗатраты) ИЛИ НЕ ЗначениеЗаполнено(ПланируемыеЗатраты) Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты = ТаблицаРеквизиты[0];
	
	Для каждого СтрокаТаблицы Из ПланируемыеЗатраты Цикл
		НоваяСтрока = Движения.бит_пз_ПланируемыеЗатраты.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизиты);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
	КонецЦикла; 
	Движения.бит_пз_ПланируемыеЗатраты.Записывать = Истина;
	
КонецПроцедуры

Процедура СформироватьПланируемыеЗатратыАналитика(ПланируемыеЗатраты, ТаблицаРеквизиты, Движения, Отказ) Экспорт

	Если НЕ ЗначениеЗаполнено(ПланируемыеЗатраты) ИЛИ НЕ ЗначениеЗаполнено(ПланируемыеЗатраты) Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты = ТаблицаРеквизиты[0];
	
	Для каждого СтрокаТаблицы Из ПланируемыеЗатраты Цикл
		НоваяСтрока = Движения.бит_пз_ПланируемыеЗатратыАналитика.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Реквизиты);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
	КонецЦикла; 
	Движения.бит_пз_ПланируемыеЗатратыАналитика.Записывать = Истина;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаПланируемыеЗатраты(НомераТаблиц)
	
	НомераТаблиц.Вставить("ПланируемыеЗатратыРеквизиты", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ПланируемыеЗатраты", НомераТаблиц.Количество());

	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.Ссылка КАК ДокументПланирования,
	|	Реквизиты.Ссылка КАК ЗаявкаНаЗатраты,
	|	Реквизиты.Организация КАК Организация,
