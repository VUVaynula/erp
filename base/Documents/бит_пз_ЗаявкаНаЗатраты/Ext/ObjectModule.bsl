#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;			
	КонецЕсли;
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	
	Если ВидОперации = Перечисления.бит_пз_ВидыОперацийЗаявокНаЗатраты.Товары Тогда
		Сумма 	   = Товары.Итог("Сумма");
		СуммаНДС   = Товары.Итог("СуммаНДС");
		Количество = Товары.Итог("Количество");
	Иначе
		Количество = ?(Количество = 0, 1, Количество);
	КонецЕсли; 
	
	бит_ОбщегоНазначенияПереопределяемый.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	
	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("Организация", Организация);
	ПараметрыНастройки.Вставить("ЦФО",		   ЦФО);
								
	ОтражатьСверхБюджета = НЕ бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеЗаявкиПриКонтролеПоБюджету(
									ПараметрыНастройки, Дата);
									
	Если ОтражатьСверхБюджета ИЛИ НЕ СверхБюджета Тогда
		СписатьЛимиты = Ложь;	
	КонецЕсли;

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаПроведенияНачало(ЭтотОбъект, Ложь);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	// Проверим допустимость проведения 
	ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(Ссылка);
	ТипСтатуса    = Справочники.бит_СтатусыОбъектов.ТипСтатусаОбъкта(ТекущийСтатус);
	Если ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.Закрыт
		ИЛИ ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.Исполнен
		ИЛИ ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен Тогда
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Документ в статусе ""%1"". Проведение невозможно.';
								   	    |en = 'Документ в статусе ""%1"". Проведение невозможно.'"), 
								   ТекущийСтатус);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, , ,Отказ); 		                          		
	КонецЕсли; 
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
	
	ПараметрыПроведения = Документы.бит_пз_ЗаявкаНаЗатраты.ПодготовитьПараметрыПроведения(Ссылка, Отказ);
	
	Если Отказ Тогда
		Возврат;	
	КонецЕсли; 
		
	ТаблицаИсполнениеБюджета = бит_КонтрольИсполненияБюджета.ПодготовитьТаблицуИсполнениеБюджета(
									ПараметрыПроведения.ИсполнениеБюджета,
									ПараметрыПроведения.ИсполнениеБюджетаРеквизиты,
									Отказ);
	Если Отказ Тогда
		Возврат;	
	КонецЕсли;
	
	бит_КонтрольИсполненияБюджета.СформироватьДвиженияКонтрольныеЗначенияБюджетов(
		ТаблицаИсполнениеБюджета, Движения);

	Документы.бит_пз_ЗаявкаНаЗатраты.СформироватьПланируемыеЗатраты(
		ПараметрыПроведения.ПланируемыеЗатраты, ПараметрыПроведения.ПланируемыеЗатратыРеквизиты, 
		Движения, Отказ);
		
	Документы.бит_пз_ЗаявкаНаЗатраты.СформироватьПланируемыеЗатратыАналитика(
		ПараметрыПроведения.ПланируемыеЗатратыАналитика, ПараметрыПроведения.ПланируемыеЗатратыАналитикаРеквизиты, 
		Движения, Отказ);	
	
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаПроведенияЗавершение(ЭтотОбъект, Отказ); 
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	// Проверим допустимость отмены проведения 
	ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(Ссылка);
	ТипСтатуса    = Справочники.бит_СтатусыОбъектов.ТипСтатусаОбъкта(ТекущийСтатус);
	Если ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.Закрыт
		ИЛИ ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.Исполнен
		ИЛИ ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен Тогда
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Документ в статусе ""%1"". Отмена проведения невозможна.';
								   	    |en = 'Документ в статусе ""%1"". Отмена проведения невозможна.'") , 
								   ТекущийСтатус);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, , ,Отказ); 
	КонецЕсли;
	
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаУдаленияПроведения(ЭтотОбъект, Отказ);
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если ВидОперации = Перечисления.бит_пз_ВидыОперацийЗаявокНаЗатраты.Услуги Тогда
		ПроверяемыеРеквизиты.Добавить("Содержание");
		ПроверяемыеРеквизиты.Добавить("Цена");
		ПроверяемыеРеквизиты.Добавить("Сумма");
		ПроверяемыеРеквизиты.Добавить("СтавкаНДС");
	Иначе	
		ПроверяемыеРеквизиты.Добавить("Товары.Номенклатура");
		ПроверяемыеРеквизиты.Добавить("Товары.Упаковка");
		ПроверяемыеРеквизиты.Добавить("Товары.Количество");
		ПроверяемыеРеквизиты.Добавить("Товары.Цена");
		ПроверяемыеРеквизиты.Добавить("Товары.Сумма");
		ПроверяемыеРеквизиты.Добавить("Товары.СтавкаНДС");
		ПроверяемыеРеквизиты.Добавить("Товары");
	КонецЕсли; 
	
	Для каждого СтокаТовары Из Товары Цикл
		Если Документы.бит_пз_ЗаявкаНаЗатраты.ДоступностьХарактеристики(СтокаТовары.Номенклатура)
			И НЕ ЗначениеЗаполнено(СтокаТовары.Характеристика) Тогда
			ТекстОшибки = НСтр("ru='В строке %1 не заполнено поле Характеристика.';
							   |en='In line%% NomerStroki not filled Field Characteristics.'");
			ТекстОшибки = СтрШаблон(ТекстОшибки, СтокаТовары.НомерСтроки);
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, ЭтотОбъект, "Товары.Характеристика", ,Отказ); 
		КонецЕсли; 
	КонецЦикла; 
	
	// Желаемая дата поступления в шапке должна быть не меньше даты документа
	Если ЗначениеЗаполнено(ЖелаемаяДатаПоступления) 
		И ЖелаемаяДатаПоступления < НачалоДня(Дата) Тогда
		
		ТекстОшибки = НСтр("ru='Желаемая дата поступления должна быть не меньше даты документа %1';
						   |en='Desired arrival date should not be less than the date of the document %1'");
		ТекстОшибки = СтрШаблон(ТекстОшибки, Формат(Дата,"ДЛФ=DD"));
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, ЭтотОбъект, "ЖелаемаяДатаПоступления",, Отказ);
	КонецЕсли;
	
	бит_НастройкиДоступностиЭлементовФорм.ЗаполнитьПроверяемыеРеквизиты(ЭтотОбъект, ПроверяемыеРеквизиты);
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	ЗаполнитьШапкуДокумента();
	
	// Инициатор
	Инициатор = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
					ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнойИнициаторКазначейства);
	
	Если НЕ ЗначениеЗаполнено(Инициатор) Тогда
		Инициатор = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	Ответственный = Пользователи.ТекущийПользователь();
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	СверхБюджета = Ложь;
	СписатьЛимиты = Ложь;
	Инициатор = Пользователи.ТекущийПользователь();
	Ответственный = Пользователи.ТекущийПользователь();
	ЖелаемаяДатаПоступления = ТекущаяДатаСеанса();
	
КонецПроцедуры

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции

Процедура ИзменениеВалютыМодуль() Экспорт

	КурсВалюты = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ВалютаДокумента,Дата);
	КурсДокумента      = КурсВалюты.Курс;
	КратностьДокумента = КурсВалюты.Кратность;

КонецПроцедуры // ИзменениеВалютыМодуль()

//  Процедура заполняет шапку документа.
// 
Процедура ЗаполнитьШапкуДокумента()
	
	Если Не ЗначениеЗаполнено(ВалютаДокумента) Тогда
		ВалютаДокумента    = Константы.ВалютаРегламентированногоУчета.Получить();
		КурсДокумента      = 1;
		КратностьДокумента = 1;			
	КонецЕсли; 
	
	Важность = Перечисления.бит_Важность.Средняя;
	
	ИзмеренияДоп       = бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Дополнительные","Синоним");
	НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");

	// Заполнить реквизиты значениями по умолчанию.
	бит_ОбщегоНазначения.ЗаполнитьШапкуДокумента(ЭтотОбъект,Пользователи.ТекущийПользователь());
												
	// Инициализируем значения доп. измерений.
	бит_МеханизмДопИзмерений.ИнициализироватьЗначенияДопИзмерений(ЭтотОбъект, ИзмеренияДоп, НастройкиИзмерений);
	
	Если НЕ ЗначениеЗаполнено(ЖелаемаяДатаПоступления) Тогда
		ЖелаемаяДатаПоступления = ТекущаяДатаСеанса();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли