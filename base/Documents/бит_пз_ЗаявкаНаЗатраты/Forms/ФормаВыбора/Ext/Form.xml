			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ТабДокумент.Ссылка КАК Ссылка,
	ТабДокумент.ПометкаУдаления КАК ПометкаУдаления,
	ТабДокумент.Номер КАК Номер,
	ТабДокумент.Дата КАК Дата,
	ТабДокумент.Проведен КАК Проведен,
	ТабДокумент.ВидОперации КАК ВидОперации,
	ТабДокумент.Организация КАК Организация,
	ТабДокумент.Контрагент КАК Контрагент,
	ТабДокумент.Договор КАК Договор,
	ТабДокумент.Сценарий КАК Сценарий,
	ТабДокумент.Важность КАК Важность,
	ТабДокумент.Склад КАК Склад,
	ТабДокумент.СтатьяОборотов КАК СтатьяОборотов,
	ТабДокумент.ЦФО КАК ЦФО,
	ТабДокумент.ЖелаемаяДатаПоступления КАК ЖелаемаяДатаПоступления,
	ТабСтатусы.Статус КАК Статус,
	ТабСтатусы.ДатаИзмененияСтатуса КАК ДатаИзмененияСтатуса,
	ВЫБОР
		КОГДА ТабДокумент.РучнаяКорректировка = ИСТИНА
			ТОГДА ВЫБОР
					КОГДА ТабДокумент.ПометкаУдаления = ИСТИНА
						ТОГДА 10
					КОГДА ТабДокумент.Проведен = ЛОЖЬ
						ТОГДА 9
					ИНАЧЕ 8
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА ТабДокумент.ПометкаУдаления = ИСТИНА
					ТОГДА 2
				КОГДА ТабДокумент.Проведен = ИСТИНА
					ТОГДА 1
				ИНАЧЕ 0
			КОНЕЦ
	КОНЕЦ КАК СостояниеДокумента
ИЗ
	Документ.бит_пз_ЗаявкаНаЗатраты КАК ТабДокумент
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_СтатусыОбъектов КАК ТабСтатусы
		ПО ТабДокумент.Ссылка = ТабСтатусы.Объект
			И (ТабСтатусы.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))</QueryText>
				<MainTable>Document.бит_пз_ЗаявкаНаЗатраты</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
					<dcsset:itemsViewMode>Normal</dcsset:itemsViewMode>
					<dcsset:itemsUserSettingID>911b6018-f537-43e8-a417-da56b22f9aec</dcsset:itemsUserSettingID>
				</ListSettings>
			</Settings>
