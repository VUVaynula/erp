&НаКлиенте
Процедура СуммаПриИзменении(Элемент)
	
	Объект.СуммаНДС = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(Объект.Сумма,
		Истина, Ложь, бит_БухгалтерияВызовСервера.ПолучитьСтавкуНДС(Объект.СтавкаНДС));
										
	РассчитатьСуммуВсего(Объект.СуммаСНДС, Объект.Сумма, Объект.СуммаНДС);	
	
	ОтобразитьБюджетСПаузой();
	
КонецПроцедуры

&НаКлиенте
Процедура СтавкаНДСПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.СтавкаНДС) Тогда
		
		Объект.СуммаНДС = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(Объект.Сумма,
			Истина, Ложь, бит_БухгалтерияВызовСервера.ПолучитьСтавкуНДС(Объект.СтавкаНДС));
																
		РассчитатьСуммуВсего(Объект.СуммаСНДС, Объект.Сумма, Объект.СуммаНДС);
		
	КонецЕсли;
	
КонецПроцедуры

