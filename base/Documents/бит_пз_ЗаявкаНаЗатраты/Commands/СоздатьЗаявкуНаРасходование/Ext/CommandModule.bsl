
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	Успех = ПроверкаВозможностиСозданияЗаявки(ПараметрКоманды);
	
	Если Не Успех Тогда		
		ТекстСообщения = НСтр("ru='Создание Заявки на расходование ДС возможно только в статусах Утверждена, Частично исполнена, Исполнена и Включена в сводную заявку.';
							  |en='Creating Applications for expenditure of the DS is only possible in the status of Approved, partially executed, performed and included in the consolidated application.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;	
	КонецЕсли; 
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("Основание", ПараметрКоманды);
	
	ОткрытьФорму("Документ.бит_кзн_ПлатежнаяПозиция.ФормаОбъекта", ПараметрыФормы, 
		ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно);
	
КонецПроцедуры

//  Функция проверки возможности создания Заявки на расходование ДС. 
// 
&НаСервере
Функция ПроверкаВозможностиСозданияЗаявки(ПараметрКоманды)

	Разрешено = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РегистрСтатусыОбъектов.Статус КАК Статус,
	|	РегистрСтатусыОбъектов.Объект КАК Заявка,
	|	СправочникСтатусыОбъектов.ТипСтатуса КАК ТипСтатуса
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК РегистрСтатусыОбъектов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_СтатусыОбъектов КАК СправочникСтатусыОбъектов
	|		ПО РегистрСтатусыОбъектов.Статус = СправочникСтатусыОбъектов.Ссылка
	|			И (РегистрСтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))
	|			И (РегистрСтатусыОбъектов.Объект = &МассивЗаявок)";
	
	Запрос.УстановитьПараметр("МассивЗаявок", ПараметрКоманды);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.Утвержден
			ИЛИ Выборка.ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен
			ИЛИ Выборка.ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.Исполнен
			ИЛИ Выборка.Статус = Справочники.бит_СтатусыОбъектов.ЗаявкаНаЗатраты_ВключенаВСводнуюЗаявку Тогда
		
			Разрешено = Истина;
		
		КонецЕсли; 
	
	КонецЦикла;

	Возврат Разрешено;
	
КонецФункции // СоздатьПлатежныеДокументы()
