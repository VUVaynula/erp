	|	Документ.бит_ДополнительныеУсловияПоДоговору.ГрафикВыдачиТраншей КАК бит_ДополнительныеУсловияПоДоговоруГрафикВыдачиТраншей
	|ГДЕ
	|	бит_ДополнительныеУсловияПоДоговоруГрафикВыдачиТраншей.Ссылка = &Ссылка";
	
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();

КонецФункции

Функция ТекстЗапросаКонтрольИсполненияБюджета(НомераТаблиц, Реквизиты)

	Если Реквизиты.НеКонтролироватьПоБюджету Тогда
		Возврат "";
	КонецЕсли;
	
	НомераТаблиц.Вставить("ИсполнениеБюджетаРеквизиты", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ИсполнениеБюджета", НомераТаблиц.Количество());
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.Дата КАК Дата,
	|	Реквизиты.Сценарий КАК Сценарий,
	|	Реквизиты.Сценарий.Валюта КАК ВалютаСценария,
	|	Реквизиты.Сценарий.ИспользоватьКурсыСценария КАК ИспользоватьКурсыСценария,
	|	&КонтролироватьБюджет КАК КонтролироватьБюджет,
	|	ЗНАЧЕНИЕ(Перечисление.бит_РежимыКонтроляПоБюджету.ГрафикиДоговоров) КАК РежимКонтроля,
	|	Реквизиты.Сценарий КАК СценарийКонтролируемый,
	|	ЛОЖЬ КАК НеУчитыватьСверхБюджета,
	|	Реквизиты.ВалютаДокумента КАК ВалютаДокумента,
	|	Реквизиты.КурсДокумента КАК КурсДокумента,
	|	Реквизиты.КратностьДокумента КАК КратностьДокумента,
	|	Реквизиты.СверхБюджета КАК СверхБюджета,
	|	ЛОЖЬ КАК СписатьЛимиты
	|ИЗ
	|	Документ.бит_ДополнительныеУсловияПоДоговору КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	""ГрафикПлатежей"" КАК ИмяСписка,
	|	&СинонимГрафикПлатежей КАК СинонимСписка,
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.Период КАК Период,
	|	Таблица.ЦФО КАК ЦФО,
	|	Таблица.СтатьяОборотов КАК СтатьяОборотов,
	|	Таблица.Аналитика_1 КАК Аналитика_1,
	|	Таблица.Аналитика_2 КАК Аналитика_2,
	|	Таблица.Аналитика_3 КАК Аналитика_3,
	|	Таблица.Аналитика_4 КАК Аналитика_4,
	|	Таблица.Аналитика_5 КАК Аналитика_5,
	|	Таблица.Аналитика_6 КАК Аналитика_6,
	|	Таблица.Аналитика_7 КАК Аналитика_7,
	|	Таблица.Аналитика_8 КАК Аналитика_8,
	|	Таблица.Аналитика_9 КАК Аналитика_9,
	|	Таблица.Аналитика_10 КАК Аналитика_10,
	|	Таблица.Аналитика_11 КАК Аналитика_11,
	|	Таблица.Аналитика_12 КАК Аналитика_12,
	|	Таблица.Сумма КАК Сумма,
	|	0 КАК Количество,
	|	ИСТИНА КАК КонтролироватьСумму,
	|	ЛОЖЬ КАК КонтролироватьКоличество,
	|	НЕ Таблица.СтатьяОборотов.НеКонтролировать_Графики КАК КонтролироватьПоСтатье
	|ИЗ
	|	Документ.бит_ДополнительныеУсловияПоДоговору.ГрафикПлатежей КАК Таблица
	|ГДЕ
	|	Таблица.Ссылка = &Ссылка
	|	И Таблица.СтатьяОборотов.РасходДоход = ЗНАЧЕНИЕ(Перечисление.бит_РасходДоход.Расходование)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
