	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
		
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();

КонецФункции

Процедура ПодготовитьТаблицуПоГрафикамДоговоровРасчетыВВалюте(ТаблицаГрафиковДоговоров, Реквизиты)
	
	Если НЕ Реквизиты.ИспользоватьКурсыСценария Тогда
		Возврат;
	КонецЕсли;
	
	ВидыКурсов = Новый Структура;
	ВидыКурсов.Вставить("Документ");
	ВидыКурсов.Вставить("Регл");
	ВидыКурсов.Вставить("Упр");
	ВидыКурсов.Вставить("Сценарий");
	КурсыВалют = бит_Бюджетирование.КурсыВалютСценария(Реквизиты.Регистратор, Реквизиты.Период, ВидыКурсов);
	
	КурсыПоПериодам = Неопределено;
	
	Если Реквизиты.ИспользоватьКурсыСценария Тогда
		ТаблицаПериодов = ТаблицаГрафиковДоговоров.Скопировать(, "Период");
		ТаблицаПериодов.Свернуть("Период");		
		ПараметрыКурсов = бит_Бюджетирование.ЗаполнитьСтруктуруПараметровПолученияКурсовПоПериодам(Реквизиты.Сценарий, Реквизиты.ВалютаДокумента);
		КурсыПоПериодам = бит_КурсыВалют.ПолучитьКурсыВалютПоПериодам(ТаблицаПериодов, ПараметрыКурсов, Реквизиты.Сценарий);
	КонецЕсли;
	
	бит_Бюджетирование.ВыполнитьПересчетыВТаблицеОборотов(ТаблицаГрафиковДоговоров, КурсыПоПериодам, 
		КурсыВалют, "СуммаБезНДС");
	
КонецПроцедуры

Процедура ПодготовитьТаблицуИсполнениеБюджетаРасчетыВВалюте(ИсполнениеБюджета, ИсполнениеБюджетаРеквизиты)

	Если НЕ ЗначениеЗаполнено(ИсполнениеБюджета) ИЛИ НЕ ЗначениеЗаполнено(ИсполнениеБюджетаРеквизиты) Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты = ИсполнениеБюджетаРеквизиты[0];
	
	Если Реквизиты.ИспользоватьКурсыСценария Тогда
		Для каждого СтрокаТаблицы Из ИсполнениеБюджета Цикл			
			КурсВалютыСценария 	= бит_КурсыВалют.ПолучитьКурсВалюты(Реквизиты.ВалютаСценария, 
									СтрокаТаблицы.Период, "бит_КурсыСценариевПланирования", Реквизиты.Сценарий);			
			КурсВалютыДокумента = бит_КурсыВалют.ПолучитьКурсВалюты(Реквизиты.ВалютаДокумента, 
									СтрокаТаблицы.Период, "бит_КурсыСценариевПланирования", Реквизиты.Сценарий);
			
			СтрокаТаблицы.Сумма = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(
										СтрокаТаблицы.Сумма, КурсВалютыДокумента, КурсВалютыСценария);		
		КонецЦикла; 
	Иначе
		КурсВалютыДокумента = Новый Структура;
		КурсВалютыДокумента.Вставить("Валюта", 	 Реквизиты.ВалютаДокумента);
		КурсВалютыДокумента.Вставить("Курс", 	 Реквизиты.КурсДокумента);
		КурсВалютыДокумента.Вставить("Кратность", Реквизиты.КратностьДокумента);
		
		КурсВалютыСценария = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Реквизиты.ВалютаСценария, Реквизиты.Дата);
		
		Для каждого СтрокаТаблицы Из ИсполнениеБюджета Цикл
			СтрокаТаблицы.Сумма = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(
										СтрокаТаблицы.Сумма, КурсВалютыДокумента, КурсВалютыСценария);
		КонецЦикла;																	
	КонецЕсли;							

КонецПроцедуры
 
#КонецОбласти	

#КонецЕсли