// Обработка оповещения закрытия формы заполнения статей оборотов для формирования графика. 
//
// Параметры:
//  ПараметрыЗакрытия - Структура.
//
&НаКлиенте
Процедура ЗакрытиеЗаполнитьПоДоговоруКредитовДепозитов(ПараметрыЗакрытия, ДопПараметры) Экспорт

	Если ТипЗнч(ПараметрыЗакрытия) = Тип("Структура") Тогда
		
		Если ПараметрыЗакрытия.ЗагрузитьДобавить = "Загрузить" 
			И (Объект.ГрафикПлатежей.Количество() > 0 ИЛИ Объект.ГрафикНачислений.Количество() > 0) Тогда			
			ВопросПользователю = НСтр("ru='График платежей и график начислений будут очищены. Продолжить?';
									  |en='Payment schedule and the schedule of charges will be cleared. Proceed?'");
			ОповещениеВопрос = Новый ОписаниеОповещения("ВопросЗаполнитьПоДоговоруКредитовДепозитов", ЭтотОбъект, ПараметрыЗакрытия);			
			ПоказатьВопрос(ОповещениеВопрос, ВопросПользователю, РежимДиалогаВопрос.ДаНет, 30);			
		Иначе			
			СтруктураПараметров = ПараметрыЗакрытия;			
			ЗаполнитьПоДоговоруКредитовДепозитовСервер(СтруктураПараметров);			
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры // ЗакрытиеЗаполнитьПоДоговоруКредитовДепозитов()

// Обработка оповещения вопроса пользователю 
