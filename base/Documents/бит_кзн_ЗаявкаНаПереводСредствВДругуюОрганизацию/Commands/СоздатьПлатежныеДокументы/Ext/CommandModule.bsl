
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	СоздатьПлатежныеДокументы(ПараметрКоманды);	
	
КонецПроцедуры

//  Процедура создает документы оплаты по заявкам на перемещение
//
&НаСервере
Процедура СоздатьПлатежныеДокументы(МассивЗаявокНаПереводСредств)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РегистрСтатусыОбъектов.Статус КАК Статус,
	|	РегистрСтатусыОбъектов.Объект КАК ЗаявкаНаПереводСредств,
	|	СправочникСтатусыОбъектов.ТипСтатуса КАК ТипСтатуса
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК РегистрСтатусыОбъектов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_СтатусыОбъектов КАК СправочникСтатусыОбъектов
	|		ПО РегистрСтатусыОбъектов.Статус = СправочникСтатусыОбъектов.Ссылка
	|			И (РегистрСтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))
	|			И (РегистрСтатусыОбъектов.Объект В (&МассивЗаявокНаПереводСредств))";
	
	Запрос.УстановитьПараметр("МассивЗаявокНаПереводСредств", МассивЗаявокНаПереводСредств);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.Утвержден
			ИЛИ Выборка.ТипСтатуса = Перечисления.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен Тогда
		
			ПараметрыДокумента = бит_Казначейство.НовыеПараметрыСозданияПлатежногоДокумента();
			ПараметрыДокумента.ДокументОснование = Выборка.ЗаявкаНаПереводСредств;
			ПараметрыДокумента.ДатаДокумента     = ТекущаяДатаСеанса();
			
			ПлатежныйДокумент = Документы.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию.СоздатьПлатежныйДокументНаОсновании(ПараметрыДокумента);
			
		КонецЕсли; 
	
	КонецЦикла;

КонецПроцедуры // СоздатьПлатежныеДокументы()
