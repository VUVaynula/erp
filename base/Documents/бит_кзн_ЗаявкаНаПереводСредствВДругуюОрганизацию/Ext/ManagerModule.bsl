Функция ЗаполнитьПодразделениеСтатьяДДС(Основание, ДанныеПозиции, ДанныеЗаполнения)
	
	ОпределитьСтатьюДДС(ДанныеЗаполнения, ДанныеПозиции, Основание);
	
	Если ТипЗнч(ДанныеПозиции.Позиция) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция") Тогда
		Подразделение = Документы.бит_кзн_ПлатежнаяПозиция.ПодразделениеДополнительныеИзмерения(ДанныеПозиции.Позиция);
	Иначе
		Подразделение = Документы.бит_кзн_ПозицияПоступления.ПодразделениеДополнительныеИзмерения(ДанныеПозиции.Позиция);
	КонецЕсли;
	Если ЗначениеЗаполнено(Подразделение) Тогда
		ДанныеЗаполнения.Подразделение = Подразделение;
	КонецЕсли;
	
КонецФункции

Процедура ИнициализироватьРасшифровкуПлатежа(Объект, Основание)

	Если Объект.РасшифровкаПлатежа.Количество() = 0 Тогда
		НоваяСтрока = Объект.РасшифровкаПлатежа.Добавить();
		НоваяСтрока.СтатьяДвиженияДенежныхСредств = Объект.СтатьяДвиженияДенежныхСредств;
		НоваяСтрока.Сумма = Объект.СуммаДокумента;
		НоваяСтрока.ВалютаВзаиморасчетов = Объект.Валюта;
		НоваяСтрока.КурсЧислительВзаиморасчетов = 1;
		НоваяСтрока.КурсЗнаменательВзаиморасчетов = 1;
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Основание, "ОбъектРасчетов, СтавкаНДС, СуммаНДС");
		Если ЗначениеЗаполнено(НоваяСтрока.СтавкаНДС) Тогда
			СтавкаНДС = бит_СтавкиНДС.ЗначениеСтавкиНДС(НоваяСтрока.СтавкаНДС);
			НоваяСтрока.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(НоваяСтрока.Сумма, СтавкаНДС, Истина);
		Иначе
			Объект.СуммаНДС  = 0;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОпределитьСтатьюДДС(Контейнер, ДанныеПозиции, ДокументОснование)
	
	СтатьяОборотов = ДанныеПозиции.СтатьяОборотов;
	ОбъектРасчетов = ДокументОснование.ОбъектРасчетов;
	
	ДоговорКонтрагента = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	Если ЗначениеЗаполнено(ОбъектРасчетов) Тогда
		ДоговорКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектРасчетов, "Договор");
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(ДоговорКонтрагента) Тогда
		СтатьяДДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДоговорКонтрагента, "СтатьяДвиженияДенежныхСредств");
		Если ЗначениеЗаполнено(СтатьяДДС) Тогда
			Контейнер.СтатьяДвиженияДенежныхСредств = СтатьяДДС;
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтатьяОборотов) Тогда
		СтатьяДДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтатьяОборотов, "ОсновнаяСтатьяДДС");
		Если ЗначениеЗаполнено(СтатьяДДС) Тогда
			Контейнер.СтатьяДвиженияДенежныхСредств = СтатьяДДС;
			Возврат;
		КонецЕсли;
	КонецЕсли;

	СтатьиДДС = РегистрыСведений.бит_СоответствияАналитик.ПолучитьЛевуюАналитику(
						Справочники.бит_ВидыСоответствийАналитик.СтатьиДДС_СтатьиОборотов, 
						СтатьяОборотов, ТекущаяДатаСеанса());
																
	Если СтатьиДДС.Количество() > 0 Тогда
		Контейнер.СтатьяДвиженияДенежныхСредств = СтатьиДДС[0];
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(Контейнер.СтатьяДвиженияДенежныхСредств) Тогда
		ВидОперации	   = бит_Казначейство.ХозяйственнаяОперацияУП(ДокументОснование.ХозяйственнаяОперация);
		СтатьяКандидат = Справочники.СтатьиДвиженияДенежныхСредств.СтатьяДвиженияДенежныхСредствПоХозяйственнойОперации(ВидОперации);
		
		Если ЗначениеЗаполнено(СтатьяКандидат) Тогда
			Контейнер.СтатьяДвиженияДенежныхСредств = СтатьяКандидат;
		КонецЕсли;	
	КонецЕсли; 

КонецПроцедуры

Процедура ЗаполнитьОтражениеФактаДДС(ДокументПланирования, ДокументСсылка, ДанныеПозиций, РежимЗаполнения, СуммаКОплате)

	УстановитьПривилегированныйРежим(Истина);
	
	ЗаполнятьВсе = Ложь;
	ЗаполнятьПервую = Ложь;
	ЗаполнятьВторую = Ложь;
	
	Если РежимЗаполнения = "Обе" Тогда
		ЗаполнятьВсе = Истина;
		н = 1;
	ИначеЕсли РежимЗаполнения = "Первая" Тогда  
		ЗаполнятьПервую = Истина;
	ИначеЕсли РежимЗаполнения = "Вторая" Тогда  
		ЗаполнятьВторую = Истина;
		н = 0;
	КонецЕсли; 
	
	ПлатежнаяПозиция   = ДанныеПозиций.ПлатежнаяПозиция.Позиция;
	ПозицияПоступления = ДанныеПозиций.ПозицияПоступления.Позиция;

	ОтражениеФакта		 = Документы.бит_ОтражениеФактаДДС.НайтиДокументОтражение(ДокументСсылка);
	ОтражениеФактаОбъект = ОтражениеФакта.ПолучитьОбъект();
	ОтражениеФактаОбъект.НеСинхронизировать = Истина;
	
	Если ЗаполнятьВсе ИЛИ ЗаполнятьПервую Тогда	
		//Заполнение строки расходования
		СтрокаТаблицы = ОтражениеФактаОбъект.ФактическиеДанные[0];
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ПлатежнаяПозиция);
		
		Если СуммаКОплате <> 0 Тогда
			СтрокаТаблицы.Сумма = СуммаКОплате;
		Иначе
			Остатки = ПолучитьОстатокРасход(ДокументПланирования);
			СтрокаТаблицы.Сумма = Остатки.Остаток;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗаполнятьВсе ИЛИ ЗаполнятьВторую Тогда
		//Заполнение строки поступления
		СтрокаТаблицы = ОтражениеФактаОбъект.ФактическиеДанные[н];
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ПозицияПоступления);
		
		Если СуммаКОплате <> 0 Тогда
			СтрокаТаблицы.Сумма = СуммаКОплате;
		Иначе
			Остатки = ПолучитьОстатокПоступление(ДокументПланирования);
			СтрокаТаблицы.Сумма = Остатки.Остаток;
		КонецЕсли;
	КонецЕсли; 
	
	бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ОтражениеФактаОбъект, РежимЗаписиДокумента.Запись, "", "Ошибки");

	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

#КонецОбласти // ЗаполнениеПлатежныхДокументов


