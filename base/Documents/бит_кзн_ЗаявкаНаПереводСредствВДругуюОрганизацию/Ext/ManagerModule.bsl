Функция ДанныеПозиций(ДокументОснование)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПлатежнаяПозиция.БанковскийСчет КАК БанковскийСчет,
	|	ПлатежнаяПозиция.Касса КАК Касса,
	|	ПлатежнаяПозиция.Ссылка КАК Позиция,
	|	ПлатежнаяПозиция.НазначениеПлатежа КАК НазначениеПлатежа,
	|	ПлатежнаяПозиция.СтатьяОборотов КАК СтатьяОборотов
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПозиция
	|ГДЕ
	|	ПлатежнаяПозиция.ДокументПланирования = &ДокументПланирования
	|	И НЕ ПлатежнаяПозиция.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПозицияПоступления.БанковскийСчет КАК БанковскийСчет,
	|	ПозицияПоступления.Касса КАК Касса,
	|	ПозицияПоступления.Ссылка КАК Позиция,
	|	ПозицияПоступления.НазначениеПлатежа КАК НазначениеПлатежа,
	|	ПозицияПоступления.СтатьяОборотов КАК СтатьяОборотов
	|ИЗ
	|	Документ.бит_кзн_ПозицияПоступления КАК ПозицияПоступления
	|ГДЕ
	|	ПозицияПоступления.ДокументПланирования = &ДокументПланирования
	|	И НЕ ПозицияПоступления.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументОснование);
	
	Результат = Запрос.ВыполнитьПакет();
	ВыборкаРасход = Результат[0].Выбрать();
	ВыборкаПриход = Результат[1].Выбрать();
	
	
	Имена = "БанковскийСчет, Касса, Позиция, НазначениеПлатежа, СтатьяОборотов";
	ПлатежнаяПозиция   = Новый Структура(Имена);
	ПозицияПоступления = Новый Структура(Имена);
	
	Пока ВыборкаРасход.Следующий() Цикл	
		ЗаполнитьЗначенияСвойств(ПлатежнаяПозиция, ВыборкаРасход);
	КонецЦикла;
	
	Пока ВыборкаПриход.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ПозицияПоступления, ВыборкаПриход);
	КонецЦикла;
	
	ДанныеПозиций = Новый Структура;
	ДанныеПозиций.Вставить("ПлатежнаяПозиция",	 ПлатежнаяПозиция);
	ДанныеПозиций.Вставить("ПозицияПоступления", ПозицияПоступления);
	
	Возврат ДанныеПозиций;
	
КонецФункции

Процедура ЗаполнитьВнутреннююПередачуДенежныхСредствЧерезКассу(РеквизитыОснования, ПараметрыЗаполнения, ПлатежныеДокументы)
		
	ДокументОснование = РеквизитыОснования.Ссылка;
	ДанныеПозиций	  = ДанныеПозиций(ДокументОснование);
	ДатаДокумента	  = ПараметрыЗаполнения.ДатаДокумента;
	ФактическаяСумма  = ПараметрыЗаполнения.ФактическаяСумма;
	
	// Расшифровка платежа не требуется.
	ДанныеЗаполнения = ДанныеЗаполненияСписаниеЧерезКассу(РеквизитыОснования, ДанныеПозиций, ПараметрыЗаполнения, 
							Перечисления.ХозяйственныеОперации.ВнутренняяПередачаДенежныхСредств);
								
	ДокументОбъект = Документы.РасходныйКассовыйОрдер.СоздатьДокумент();
	ДокументОбъект.Дата = ДатаДокумента;		
	ДокументОбъект.Заполнить(ДанныеЗаполнения);
	ДокументОбъект.Записать();
	
	ПлатежныеДокументы.Добавить(ДокументОбъект.Ссылка);
	ЗаполнитьОтражениеФактаДДС(ДокументОснование, ДокументОбъект.Ссылка, ДанныеПозиций, "Первая", ФактическаяСумма);
	
	ДанныеЗаполнения = ДанныеЗаполненияПоступлениеЧерезКассу(РеквизитыОснования, ДанныеПозиций, ПараметрыЗаполнения,
							Перечисления.ХозяйственныеОперации.ВнутренняяПередачаДенежныхСредств);
		
	ДокументОбъект = Документы.ПриходныйКассовыйОрдер.СоздатьДокумент();
	ДокументОбъект.Дата = ДатаДокумента;		
	ДокументОбъект.Заполнить(ДанныеЗаполнения);
	ДокументОбъект.Записать();
	
	ПлатежныеДокументы.Добавить(ДокументОбъект.Ссылка);
	ЗаполнитьОтражениеФактаДДС(ДокументОснование, ДокументОбъект.Ссылка, ДанныеПозиций, "Вторая", ФактическаяСумма);

КонецПроцедуры

Процедура ЗаполнитьВнутреннююПередачуДенежныхСредствЧерезБанк(РеквизитыОснования, ПараметрыЗаполнения, ПлатежныеДокументы)
		
	ДокументОснование 	 = РеквизитыОснования.Ссылка;
	ДанныеПозиций	  	 = ДанныеПозиций(ДокументОснование);
	СоздаватьПоступления = ПараметрыЗаполнения.СоздаватьПоступления;
	ДатаДокумента		 = ПараметрыЗаполнения.ДатаДокумента;
	
	СуммаДокумента	 = ПараметрыЗаполнения.СуммаДокумента;
	ФактическаяСумма = ПараметрыЗаполнения.ФактическаяСумма;
	
	ДанныеЗаполнения = ДанныеЗаполненияСписаниеЧерезБанк(РеквизитыОснования, ДанныеПозиций, ПараметрыЗаполнения, 
							Перечисления.ХозяйственныеОперации.ВнутренняяПередачаДенежныхСредств);
								
	ДокументОбъект = Документы.СписаниеБезналичныхДенежныхСредств.СоздатьДокумент();
	// Расшифровка платежа не требуется.
	//бит_Казначейство.ДополнитьНазначениеПлатежаСуммой(ДокументОбъект);
	ДокументОбъект.Дата = ДатаДокумента;		
	ДокументОбъект.Заполнить(ДанныеЗаполнения);
	ДокументОбъект.Записать();
	
	Списание = ДокументОбъект.Ссылка;
	ПлатежныеДокументы.Добавить(Списание);
	ЗаполнитьОтражениеФактаДДС(ДокументОснование, Списание, ДанныеПозиций, "Первая", ФактическаяСумма);
	
	Если СоздаватьПоступления Тогда
		
		ДанныеЗаполнения = ДанныеЗаполненияПоступлениеЧерезБанк(РеквизитыОснования, ДанныеПозиций, ПараметрыЗаполнения, 
								Перечисления.ХозяйственныеОперации.ВнутренняяПередачаДенежныхСредств);
											
		ДокументОбъект = Документы.ПоступлениеБезналичныхДенежныхСредств.СоздатьДокумент();
		//бит_Казначейство.ДополнитьНазначениеПлатежаСуммой(ДокументОбъект);
		ДокументОбъект.Дата = ДатаДокумента;
		РеквизитыВходящего 	= ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Списание, 
								"НомерВходящегоДокумента, ДатаВходящегоДокумента");
		ЗаполнитьЗначенияСвойств(ДокументОбъект, РеквизитыВходящего);
		ДокументОбъект.Заполнить(ДанныеЗаполнения);
		ДокументОбъект.Записать();
		
		ПлатежныеДокументы.Добавить(ДокументОбъект.Ссылка);
		ЗаполнитьОтражениеФактаДДС(ДокументОснование, ДокументОбъект.Ссылка, ДанныеПозиций, "Вторая", ФактическаяСумма);
	КонецЕсли;

КонецПроцедуры

