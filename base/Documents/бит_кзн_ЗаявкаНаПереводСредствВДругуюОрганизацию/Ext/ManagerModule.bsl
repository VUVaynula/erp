								"НомерВходящегоДокумента, ДатаВходящегоДокумента");
		ЗаполнитьЗначенияСвойств(ДокументОбъект, РеквизитыВходящего);
		ДокументОбъект.Заполнить(ДанныеЗаполнения);
		ИнициализироватьРасшифровкуПлатежа(ДокументОбъект, РеквизитыОснования);
		ДокументОбъект.Записать();
		
		ПлатежныеДокументы.Добавить(ДокументОбъект.Ссылка);
		ЗаполнитьОтражениеФактаДДС(ДокументОснование, ДокументОбъект.Ссылка, ДанныеПозиций, "Вторая", ФактическаяСумма);
