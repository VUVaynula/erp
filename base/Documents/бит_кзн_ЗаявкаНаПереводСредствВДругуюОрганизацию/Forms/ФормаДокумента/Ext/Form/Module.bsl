КонецПроцедуры

&НаКлиенте
Процедура ВалютаДокументаПриИзменении(Элемент)
	
	Оповещение = Новый ОписаниеОповещения("ИзменениеВалюты", ЭтотОбъект);
	ТекстВопроса = НСтр("ru='Изменена валюта документа. Пересчитать сумму в документе?';
						|en='Change Currency document. Calculate the amount of paper?'");
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 15, КодВозвратаДиалога.Нет);
	
КонецПроцедуры

&НаКлиенте 
Процедура ИзменениеВалюты(Ответ, ДополнительныеДанные) Экспорт
	
	ЕстьПозиции = ИзменениеВалютыСервер();
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		Если ЗначениеЗаполнено(КонтролируемыеРеквизиты.ВалютаДокумента) Тогда
			ПараметрыТекущегоКурса = Новый Структура; 
			ПараметрыТекущегоКурса.Вставить("Валюта", 	КонтролируемыеРеквизиты.ВалютаДокумента);
			ПараметрыТекущегоКурса.Вставить("Курс",		КонтролируемыеРеквизиты.КурсДокумента);
			ПараметрыТекущегоКурса.Вставить("Кратность",КонтролируемыеРеквизиты.КратностьДокумента);
			
			ПараметрыНовогоКурса = Новый Структура; 
			ПараметрыНовогоКурса.Вставить("Валюта",	  Объект.ВалютаДокумента);
			ПараметрыНовогоКурса.Вставить("Курс",	  Объект.КурсДокумента);
			ПараметрыНовогоКурса.Вставить("Кратность",Объект.КратностьДокумента);
			
			Объект.СуммаДокумента = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(Объект.СуммаДокумента, 
										ПараметрыТекущегоКурса, ПараметрыНовогоКурса);
			
			Если ЕстьПозиции Тогда
				Записать();
			КонецЕсли; 																		  
		КонецЕсли; // пересчитать
	КонецЕсли; 
	
	УправлениеЭлементамиФормы();
	
	ОбновитьКонтролируемыеРеквизиты("ВалютаДокумента", ЭтотОбъект);
	ОбновитьКонтролируемыеРеквизиты("КратностьДокумента", ЭтотОбъект);
	ОбновитьКонтролируемыеРеквизиты("КурсДокумента", ЭтотОбъект);
	
КонецПроцедуры // ИзменениеВалюты

