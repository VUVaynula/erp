// Функция создает платежный документ на основании документа передачи ДС.
//
// Возвращаемое значение:
//  ПлатежныйДокумент - Массив.
//
&НаСервере
Функция СоздатьПлатежныйДокументСервер()
	
	ПараметрыДокумента = бит_Казначейство.НовыеПараметрыСозданияПлатежногоДокумента();
	ПараметрыДокумента.ДокументОснование = Объект.Ссылка;
	ПараметрыДокумента.ДатаДокумента     = ТекущаяДатаСеанса();
	
	ПлатежныйДокумент = Документы.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию.СоздатьПлатежныйДокументНаОсновании(ПараметрыДокумента);
	
	Возврат ПлатежныйДокумент;
	
КонецФункции // СоздатьПлатежныйДокументСервер()

// Процедура устанавливает отбор для организации получателя.
//
&НаСервере
Процедура УстановитьОтборыОрганизацииПолучателя()

	Если Объект.ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ВнутренняяПередачаДенежныхСредств Тогда
	
		НоваяСвязь = Новый СвязьПараметраВыбора("Отбор.ГоловнаяОрганизация", "Объект.Организация");
		НовыйМассив = Новый Массив();
		НовыйМассив.Добавить(НоваяСвязь);
		НовыеСвязи = Новый ФиксированныйМассив(НовыйМассив);
		Элементы.ОрганизацияПолучатель.СвязиПараметровВыбора = НовыеСвязи;
		
		НовыйПараметр = Новый ПараметрВыбора("Отбор.ОбособленноеПодразделение", ИСТИНА);
		НовыйМассив = Новый Массив();
		НовыйМассив.Добавить(НовыйПараметр);
		НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
		Элементы.ОрганизацияПолучатель.ПараметрыВыбора = НовыеПараметры;
		
	Иначе
		
		НовыеСвязи = Новый ФиксированныйМассив(Новый Массив());
		Элементы.ОрганизацияПолучатель.СвязиПараметровВыбора = НовыеСвязи;
		
		НовыеПараметры = Новый ФиксированныйМассив(Новый Массив());
		Элементы.ОрганизацияПолучатель.ПараметрыВыбора = НовыеПараметры;
		
	КонецЕсли; 

КонецПроцедуры // УстановитьОтборыОрганизацииПолучателя()

// Функция обрабатывает изменение валюты документа
//
// Возвращаемое значение
// 	Булево				
//
&НаСервере
Функция ИзменениеВалютыСервер()
	
	Документы.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию.ПриИзмененииВалютыДокумента(Объект, Объект.Дата);
	
	//ищем есть ли созданная позиция для документа
	ПлатежнаяПозиция = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(Объект.Ссылка);
	Если ЗначениеЗаполнено(ПлатежнаяПозиция.Позиция) Тогда
		Возврат Истина; 
	КонецЕсли; 
	
	Возврат Ложь;
	
КонецФункции // ИзменениеВалютыСервер()

// Процедура заполняет сценарий при изменении поля документа. 
// 
// Параметры: Имя - Строка
//
&НаСервере
Процедура ЗаполнитьСценарий(Имя)

	СтруктураПараметров = Новый Структура;
	Если Имя = "Организация" Тогда
		
		СтруктураПараметров.Вставить("Организация", Объект.Организация);
		
	ИначеЕсли Имя = "ЦФО" Тогда 	
		
		СтруктураПараметров.Вставить("ЦФО", Объект.ЦФО);
		
	КонецЕсли; 
	
	КонтролироватьЗаявку = бит_НастройкиПрограммы.КонтролироватьЗаявкуПоБюджету(СтруктураПараметров, Объект.Дата);
	Сценарий 			 = бит_НастройкиПрограммы.КазначействоСценарийКонтроляПоБюджету(СтруктураПараметров, Объект.Дата);

	Если ЗначениеЗаполнено(Сценарий) И КонтролироватьЗаявку Тогда
	
		Объект.Сценарий = Сценарий;
	
	КонецЕсли; 

КонецПроцедуры // ЗаполнитьСценарий()

//  Процедура обработчик-ожидания открытия формы. 
//
&НаКлиенте
Процедура ОжиданиеОткрытияФормы()
	
	Оповещение = Новый ОписаниеОповещения("ВыполнитьКопирование",ЭтотОбъект);
	ТекстВопроса =  НСтр("ru='Выполнить копирование и записать документ?';en='Make a copy and write the document?'");
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 30, КодВозвратаДиалога.Да);
	
КонецПроцедуры

&НаКлиенте 
Процедура ВыполнитьКопирование(Ответ, ДополнительныеДанные) Экспорт
	
	КопироватьПозиции = ?(Ответ = КодВозвратаДиалога.Да, Истина, Ложь);
	
	Если КопироватьПозиции Тогда
		Записать();
		КопироватьПозиции = Ложь;
	КонецЕсли;
	
КонецПроцедуры // ВыполнитьКопирование

&НаСервере
Функция ОперацияУчитываетНДС()
	
	Возврат НЕ бит_Казначейство.ОперацияБезНДС(Объект.ХозяйственнаяОперация);
	
КонецФункции

&НаСервере
Процедура ПересчитатьРеквизитыУчетаНДС(ИзменятьСтавку = Ложь)
	
	Если ОперацияУчитываетНДС()	Тогда
		Если ИзменятьСтавку И НЕ ЗначениеЗаполнено(Объект.СтавкаНДС) Тогда
			Объект.СтавкаНДС = бит_СтавкиНДС.СтавкаНДСПоПеречислению(Перечисления.СтавкиНДС.НДС20);
		КонецЕсли;
		СтавкаНДС = бит_СтавкиНДС.ЗначениеСтавкиНДС(Объект.СтавкаНДС);
		Объект.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(Объект.СуммаДокумента, СтавкаНДС, Истина);
	Иначе
		Объект.СтавкаНДС = бит_СтавкиНДС.СтавкаНДСПустая();
		Объект.СуммаНДС  = 0;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста 
Процедура УстановитьПараметрыВыбораВидаОперации(Форма)
	
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	НовыеПараметры = Новый Массив; 
	НовыеПараметры.Добавить(Новый ПараметрВыбора("Отбор.ФормаОплаты", Объект.ФормаОплаты));
	НовыеПараметры.Добавить(Новый ПараметрВыбора("Отбор.ТипДокумента", ТипЗнч(Объект.Ссылка)));
	
	Элементы.ХозяйственнаяОперация.ПараметрыВыбора = Новый ФиксированныйМассив(НовыеПараметры);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста 
Процедура ЗаполнитьКонтролируемыеРеквизиты(Форма)
	
	НаборРеквизитов = Новый Структура;
	НаборРеквизитов.Вставить("ВалютаДокумента");
	НаборРеквизитов.Вставить("КурсДокумента");
	НаборРеквизитов.Вставить("КратностьДокумента");
	//НаборРеквизитов.Вставить("ОбъектРасчетов");
	//НаборРеквизитов.Вставить("Организация");
	//НаборРеквизитов.Вставить("БанковскийСчет");
	НаборРеквизитов.Вставить("ФормаОплаты");
	НаборРеквизитов.Вставить("ХозяйственнаяОперация");

	ЗаполнитьЗначенияСвойств(НаборРеквизитов, Форма.Объект);
	
	Форма.КонтролируемыеРеквизиты = Новый ФиксированнаяСтруктура(НаборРеквизитов);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста 
Процедура ОбновитьКонтролируемыеРеквизиты(ИмяРеквизита, Форма)
	
	НаборРеквизитов = Новый Структура;
	Для каждого КлючЗначение Из Форма.КонтролируемыеРеквизиты Цикл
		НаборРеквизитов.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла; 
	НаборРеквизитов.Вставить(ИмяРеквизита, Форма.Объект[ИмяРеквизита]);
	
	Форма.КонтролируемыеРеквизиты = Новый ФиксированнаяСтруктура(НаборРеквизитов);	
	
КонецПроцедуры

&НаСервере
Процедура ФормаОплатыПриИзмененииНаСервере()
	
	Если НЕ ЗначениеЗаполнено(Объект.ФормаОплаты) Тогда
		Объект.ФормаОплаты = КонтролируемыеРеквизиты.ФормаОплаты; 
	КонецЕсли; 

	Если КонтролируемыеРеквизиты.ФормаОплаты = Объект.ФормаОплаты Тогда
		Возврат;
	КонецЕсли; 

	УстановитьПараметрыВыбораВидаОперации(ЭтотОбъект);
	
	ДоступныеЗначения = ДоступныеЗначенияВидовОпераций();
	Если ДоступныеЗначения.НайтиПоЗначению(Объект.ХозяйственнаяОперация) = Неопределено Тогда
		Объект.ХозяйственнаяОперация = ДоступныеЗначения[0].Значение;
		ХозяйственнаяОперацияПриИзмененииНаСервере();
	Иначе
		ЗаполнитьКонтролируемыеРеквизиты(ЭтотОбъект);
		УправлениеЭлементамиФормы();
	КонецЕсли; 
	
КонецПроцедуры
 
&НаСервере
Функция ДоступныеЗначенияВидовОпераций()
	
	Модуль = Перечисления.бит_ВидыОперацийКазначейства;
	ПараметрыПередачи = Новый Структура; 
	ПараметрыПередачи.Вставить("ФормаОплаты", Объект.ФормаОплаты);
	ПараметрыПередачи.Вставить("ТипДокумента", ТипЗнч(Объект.Ссылка));
	
	Возврат Модуль.ПолучитьДоступныеЗначения(ПараметрыПередачи).ДоступныеЗначения;
	
КонецФункции

&НаСервере
Процедура ХозяйственнаяОперацияПриИзмененииНаСервере()
	
	ХозОперацияУП = ХозяйственнаяОперацияУП();
	Если ХозОперацияУП = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВнутренняяПередачаДенежныхСредств") Тогда 
		Объект.ОбъектРасчетов = Неопределено;
	КонецЕсли;	
	
	ПересчитатьРеквизитыУчетаНДС(Истина);
	
	УстановитьОтборыОрганизацииПолучателя();
	УправлениеЭлементамиФормы();
	ОбновитьКонтролируемыеРеквизиты("ХозяйственнаяОперация", ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Функция ХозяйственнаяОперацияУП()

	Возврат бит_Казначейство.ХозяйственнаяОперацияУП(Объект.ХозяйственнаяОперация);
	
КонецФункции

&НаСервере
Процедура ПодготовитьФормуНаСервере(СтандартнаяОбработка = Ложь)

	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.Организация, Объект.ЦФО, Объект.Дата);
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ПолучитьФункциональнуюОпцию("бит_ЗапретитьИзменениеЗаявкиВключеннойВРеестр") Тогда
			ЗаявкаВключенаВРеестр = бит_Казначейство.ЗаявкаВключенаВРеестр(Объект.Ссылка);
		Иначе
			ЗаявкаВключенаВРеестр = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект, СтандартнаяОбработка);
	УстановитьСостояниеДокумента();
	УправлениеЭлементамиФормы();
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаОповещенияИзмененияСтатуса()
	
	Прочитать();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НеУчитыватьСверхБюджета(Организация, ЦФО, Период)

	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("Организация", Организация);
	ПараметрыНастройки.Вставить("ЦФО",		   ЦФО);
								
	НеУчитыватьСверхБюджета = бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеЗаявкиПриКонтролеПоБюджету(ПараметрыНастройки, 
									Период);
	Возврат НеУчитыватьСверхБюджета;
	
КонецФункции

