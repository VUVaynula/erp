Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт
	
	ПараметрыПроведения = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);

	НомераТаблиц = Новый Структура;
	Запрос.Текст = ТекстЗапросаНеснижаемыеОстатки(НомераТаблиц);

	Результат = Запрос.ВыполнитьПакет();
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла;
	
	Возврат ПараметрыПроведения;
	
КонецФункции 

Процедура СформироватНеснижаемыеОстатки(ТаблицаНеснижаемыеОстатки, ТаблицаРеквизиты, Движения, Отказ) Экспорт

	Если ТаблицаНеснижаемыеОстатки.Количество() = 0 Тогда
		Возврат;	
	КонецЕсли;
	
	Реквизиты 		   = ТаблицаРеквизиты[0];
	НеснижаемыеОстатки = Движения.бит_НеснижаемыеОстатки;
	НеснижаемыеОстатки.Записывать = Истина;
	
	Для каждого СтрокаТаблицы Из ТаблицаНеснижаемыеОстатки Цикл
		Проводка = НеснижаемыеОстатки.Добавить();
		ЗаполнитьЗначенияСвойств(Проводка, СтрокаТаблицы);
		ЗаполнитьЗначенияСвойств(Проводка, Реквизиты);
	КонецЦикла; 

КонецПроцедуры
 
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстЗапросаНеснижаемыеОстатки(НомераТаблиц)
	
	НомераТаблиц.Вставить("НеснижаемыеОстаткиРеквизиты", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("НеснижаемыеОстаткиТаблица", НомераТаблиц.Количество());
	
	ТекстЗапроса =  
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.Дата КАК Период,
	|	Реквизиты.Организация КАК Организация
	|ИЗ
	|	Документ.бит_УстановкаНеснижаемыхОстатков КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НеснижаемыеОстатки.БанковскийСчет КАК БанковскийСчет,
	|	НеснижаемыеОстатки.НомерСчета КАК НомерСчета,
	|	НеснижаемыеОстатки.Валюта КАК Валюта,
	|	НеснижаемыеОстатки.СчетУчета КАК СчетУчета,
	|	НеснижаемыеОстатки.Сумма КАК Сумма,
	|	НеснижаемыеОстатки.ДатаОкончания КАК ДатаОкончания
	|ИЗ
	|	Документ.бит_УстановкаНеснижаемыхОстатков.НеснижаемыеОстатки КАК НеснижаемыеОстатки
	|ГДЕ
	|	НеснижаемыеОстатки.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСчета";
					
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();

КонецФункции
	
#КонецОбласти

#КонецЕсли
