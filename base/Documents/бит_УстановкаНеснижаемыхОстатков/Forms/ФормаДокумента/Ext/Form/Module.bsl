// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПолучитьДанныеПоБанковскомуСчету(БанковскийСчет)

	Результат = Новый Структура("НомерСчета, ВалютаДенежныхСредств", "", Неопределено);
	Если ЗначениеЗаполнено(БанковскийСчет) Тогда
		Результат = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(БанковскийСчет, 
						"НомерСчета, ВалютаДенежныхСредств");
	КонецЕсли;

	Возврат Результат;
	
КонецФункции // ПолучитьДанныеПоБанковскомуСчету()

&НаСервере
Функция ПолучитьДанныеПоКассе(Касса)

	Результат = Новый Структура("ВалютаДенежныхСредств", Неопределено);	
	Если ЗначениеЗаполнено(Касса) Тогда
		Результат = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Касса, "ВалютаДенежныхСредств");	
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура УстановитьУсловноеОформление()

	УсловноеОформление.Элементы.Очистить();
	
	// НеснижаемыеОстаткиБанковскийСчет.
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НеснижаемыеОстаткиБанковскийСчет");
	// АПК:277-вкл
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Объект.НеснижаемыеОстатки.БанковскийСчет", ВидСравненияКомпоновкиДанных.НеЗаполнено, "");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"ЕстьСправочникКассы", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'Касса'"));

	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НеснижаемыеОстаткиБанковскийСчет");
	// АПК:277-вкл
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Объект.Организация", ВидСравненияКомпоновкиДанных.НеЗаполнено, "");
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);
	
	// НеснижаемыеОстаткиВалюта.
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НеснижаемыеОстаткиВалюта");
	// АПК:277-вкл
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"ЕстьСправочникКассы", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Объект.НеснижаемыеОстатки.НомерСчета", ВидСравненияКомпоновкиДанных.НеЗаполнено, "");
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Ложь);
	
КонецПроцедуры

#КонецОбласти
