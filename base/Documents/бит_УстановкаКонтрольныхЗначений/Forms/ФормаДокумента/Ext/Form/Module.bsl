
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаОбъектаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);

	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если Параметры.Ключ.Пустая() Тогда
		УстановитьСостояниеДокумента();
		Если ЗначениеЗаполнено(Параметры.ЗначениеКопирования) Тогда
			ВосстановитьНастройкиПостроителя(Параметры.ЗначениеКопирования);
		Иначе
			ВосстановитьНастройкиПостроителя(Объект.Ссылка);
		КонецЕсли;
	КонецЕсли; 
		
	ЗаполнитьДобавленныеКолонкиТаблиц();
	
	ТекущийВидКонтроля = Объект.ВидКонтроля;
	
	// Отображение разрезов бюджетирования в табличном поле "Настройки заполнения".
	ОтобразитьРазрезыБюджетирования();
		
	УправлениеФормой(ЭтотОбъект);
	
	УстановитьУсловноеОформление();
	
	бит_МеханизмПолученияДанных.УстановитьОформлениеТаблицыОтбор(УсловноеОформление);
		
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры // ПриОткрытии()

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	УстановитьРазрезыБюджетирования();
	
	// Сохранение отбора построителя
	СтруктураНастройки = Новый Структура;
	
	МассивОтбор = Новый Массив;
	Для каждого СтрокаОтбор Из ТаблицаОтбор Цикл
	
		 ЭлементОтбора = бит_МеханизмПолученияДанных.ЭлементОтбора();
		 
		 ЗаполнитьЗначенияСвойств(ЭлементОтбора, СтрокаОтбор);
		 МассивОтбор.Добавить(ЭлементОтбора);
		 
	КонецЦикла; 
	
	СтруктураНастройки.Вставить("Отбор", МассивОтбор);	
	
	ТекущийОбъект.СохранитьНастройкиПостроителя(СтруктураНастройки);

КонецПроцедуры // ПередЗаписьюНаСервере()

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ВыбратьПериодЗавершение" И Источник = УникальныйИдентификатор Тогда	
		
		РедактированиеПериодаЗавершение(Параметр.Результат, Неопределено);
		
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	УстановитьСостояниеДокумента();
	
	ВосстановитьНастройкиПостроителя(Объект.Ссылка);
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ЗаполнитьДобавленныеКолонкиТаблиц();
	УстановитьСостояниеДокумента();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
		
	Если ПараметрыЗаписи.РежимЗаписи = ПредопределенноеЗначение("РежимЗаписиДокумента.Проведение") Тогда
		// АПК:1036-выкл Не является синтаксической ошибкой.
		КлючеваяОперация = "Проведениебит_УстановкаКонтрольныхЗначений";
		// АПК:1036-вкл
		ОценкаПроизводительностиКлиент.ЗамерВремени(КлючеваяОперация);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

КонецПроцедуры
  
#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВидОтклоненияПриИзменении(Элемент)
	
	ИзменениеВидаОтклоненияСервер("ВидОтклонения", "ЗначениеОтклонения");
	
КонецПроцедуры

&НаКлиенте
Процедура ВидОтклоненияКоличествоПриИзменении(Элемент)
	
	ИзменениеВидаОтклоненияСервер("ВидОтклоненияКоличество", "ЗначениеОтклоненияКоличество");
	
КонецПроцедуры

&НаКлиенте
Процедура ВидКонтроляПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(Объект.ВидКонтроля) Тогда
		Объект.ВидКонтроля = ТекущийВидКонтроля
	КонецЕсли; 
	
	// Если операция не поменялась, то выходим.
	Если ТекущийВидКонтроля = Объект.ВидКонтроля Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийВидКонтроля = Объект.ВидКонтроля;

	ИзменениеВидаКонтроля();
	
КонецПроцедуры

&НаКлиенте
Процедура ПроизвольнаяПериодичностьКонтроляПриИзменении(Элемент)
	
	Если Объект.ПроизвольнаяПериодичностьКонтроля Тогда
		ДатаНачалаКонтроля = ?(ЗначениеЗаполнено(Объект.ДатаНачала), Объект.ДатаНачала, Объект.Дата);
		Объект.ДатаНачалаКонтроля	 = ДатаНачалаКонтроля;
		Объект.ДатаОкончанияКонтроля = Объект.ДатаОкончания;		
		Объект.ПериодичностьКонтроля = ПредопределенноеЗначение("Перечисление.бит_ПериодичностьПланирования.ПустаяСсылка");
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодичностьКонтроляПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(Объект.ДатаНачалаКонтроля) Тогда
		ДатаНачалаКонтроля = ?(ЗначениеЗаполнено(Объект.ДатаНачала), Объект.ДатаНачала, Объект.Дата);
		Объект.ДатаНачалаКонтроля 	 = ДатаНачалаКонтроля;
		Объект.ДатаОкончанияКонтроля = ДатаНачалаКонтроля;
	КонецЕсли;
	УстановитьГраницыКонтроля();
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаКонтроляПриИзменении(Элемент)
	
	Если Объект.ДатаНачалаКонтроля > Объект.ДатаОкончанияКонтроля Тогда
		Объект.ДатаОкончанияКонтроля = Объект.ДатаНачалаКонтроля;
	КонецЕсли;
	УстановитьГраницыКонтроля();
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаОкончанияКонтроляПриИзменении(Элемент)
	
	Если Объект.ДатаНачалаКонтроля > Объект.ДатаОкончанияКонтроля Тогда
		Объект.ДатаНачалаКонтроля = Объект.ДатаОкончанияКонтроля;
	КонецЕсли;
	УстановитьГраницыКонтроля();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыНастройкаЗаполнения

&НаКлиенте
Процедура НастройкаЗаполненияИспользоватьРазрезПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.НастройкаЗаполнения.ТекущиеДанные;
	Объект[ТекущиеДанные.ИмяРеквизита] = ТекущиеДанные.ИспользоватьРазрез; 
	
	НастройкаЗаполненияИспользоватьРазрезПриИзмененииНаСервере(ТекущиеДанные.ИмяРеквизита, ТекущиеДанные.ИспользоватьРазрез);
	
	Модифицированность = Истина;
	
КонецПроцедуры // НастройкаЗаполненияИспользоватьРазрезПриИзменении()

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаОтбор

&НаКлиенте
Процедура ТаблицаОтборПриИзменении(Элемент)
	
	ТаблицаОтборКоличество = КоличествоСтрокОтбора(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаОтборВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле = Элементы.ТаблицаОтборПредставление Тогда
	
		СтандартнаяОбработка = Ложь;
		
		ТекущиеДанные = Элементы.ТаблицаОтбор.ТекущиеДанные;	
		ТекущиеДанные.Использование  = Истина;  
		ТекущиеДанные.ВидСравнения   = ВидСравнения.Равно;

		СтрПар = Новый Структура("ТекстЗапроса", ТекстЗапросаПоНастройкам);
		бит_ПолучениеДанныхКлиент.ОткрытьФормуПолейПостроителя(ТекущиеДанные, "ТаблицаОтбор", "ПутьКДанным", "Отбор", "", СтрПар);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаОтборПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)

	ТекущиеДанные = Элементы.ТаблицаОтбор.ТекущиеДанные;
	Если НоваяСтрока И Не Копирование Тогда
		Если Копирование Тогда
			ТекущиеДанные.ПутьКДанным = "";
		Иначе
			ТекущиеДанные.Использование  = Истина;  
			ТекущиеДанные.ВидСравнения   = ВидСравнения.Равно; 
		КонецЕсли; 	

		СтрПар = Новый Структура("ТекстЗапроса", ТекстЗапросаПоНастройкам);
		бит_ПолучениеДанныхКлиент.ОткрытьФормуПолейПостроителя(ТекущиеДанные, "ТаблицаОтбор", "ПутьКДанным", "Отбор", "", СтрПар);
	Иначе
		УстановитьСвойствоВыборГруппИЭлементов(Элементы.ТаблицаОтборЗначение, ТекущиеДанные.ВидСравнения);
	КонецЕсли; 
	
КонецПроцедуры
   
&НаКлиенте
Процедура ТаблицаОтборВидСравненияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ТаблицаОтбор.ТекущиеДанные;
		
	СписокВидов = СписокВыбораВидаСравнения(ТекущиеДанные.ПолучитьИдентификатор());

	Элемент.СписокВыбора.Очистить();
	Для каждого Эл Из СписокВидов Цикл
		Элемент.СписокВыбора.Добавить(Эл.Значение, Эл.Представление);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаОтборВидСравненияОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущиеДанные = Элементы.ТаблицаОтбор.ТекущиеДанные;

	Если ВыбранноеЗначение <> Неопределено Тогда
		ТекущиеДанные.ВидСравнения = ВыбранноеЗначение;
	    ИзменениеВидаСравнения(ТекущиеДанные.ПолучитьИдентификатор());		
	КонецЕсли; 

КонецПроцедуры

&НаКлиенте
Процедура ТаблицаОтборВидСравненияПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ТаблицаОтбор.ТекущиеДанные;
	ИзменениеВидаСравнения(ТекущиеДанные.ПолучитьИдентификатор());
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаОтборЗначениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ТаблицаОтбор.ТекущиеДанные;	
	бит_ПолучениеДанныхКлиент.ТаблицаОтборЗначениеНачалоВыбора(ЭтотОбъект, 
		ТекущиеДанные, Элемент, ДанныеВыбора, СтандартнаяОбработка);
                                               	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаОтборЗначениеОчистка(Элемент, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ТаблицаОтбор.ТекущиеДанные;	
	бит_ПолучениеДанныхКлиент.ТаблицаОтборЗначениеОчистка(ТекущиеДанные, Элемент, СтандартнаяОбработка);
	
КонецПроцедуры

#КонецОбласти

