&НаСервере
Процедура УстановитьУсловноеОформление()

	УсловноеОформление.Элементы.Очистить();

	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	бит_ОтчетыБФКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НастройкаЗаполненияИзмерение");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"НастройкаЗаполнения.ИспользоватьРазрез", ВидСравненияКомпоновкиДанных.Равно, Истина);

	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.бит_ФонПодписьВерна);
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	бит_ОтчетыБФКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НастройкаЗаполненияИзмерение");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"НастройкаЗаполнения.ИмяРеквизита", ВидСравненияКомпоновкиДанных.Равно, "НЗ_БанковскийСчет");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.ВидКонтроля", ВидСравненияКомпоновкиДанных.НеРавно, 
		Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет);

	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", 	ЦветаСтиля.бит_ЦветНедоступногоПоля);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);
	
КонецПроцедуры

&НаСервере
Функция ТекстЗапросаПоНастройкам(ТекстЗапросаШаблон)
	
	РеквизитыДокумента = ""
	+ "НЗ_Аналитика_1,"
	+ "НЗ_Аналитика_2,"
	+ "НЗ_Аналитика_3,"
	+ "НЗ_Аналитика_4,"
	+ "НЗ_Аналитика_5,"
	+ "НЗ_Аналитика_6,"
	+ "НЗ_Аналитика_7,"
	// ++ ЕРП 
	+ "НЗ_Аналитика_8,"
	+ "НЗ_Аналитика_9,"
	+ "НЗ_Аналитика_10,"
	+ "НЗ_Аналитика_11,"
	+ "НЗ_Аналитика_12";
	// -- ЕРП 
	
	РеквизитыДокумента = Новый Структура(РеквизитыДокумента); 
	ЗаполнитьЗначенияСвойств(РеквизитыДокумента, Объект);
	
	ТекстЗапросаПоНастройкам = "";
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(СтрЗаменить(ТекстЗапросаШаблон, "{&Периодичность}", ""));
	Отборы = СхемаЗапроса.ПакетЗапросов[0].Операторы[0].ВыраженияОтбораКомпоновкиДанных;
	
	Для каждого Реквизит Из РеквизитыДокумента Цикл
		Если НЕ Реквизит.Значение Тогда
			Поле   = СтрЗаменить(Реквизит.Ключ, "НЗ_", "");
			Индекс = -1;
			Если СтрНачинаетсяС(Поле, "Аналитика_") Тогда
				Для каждого Отбор Из Отборы Цикл
					Если Отбор.Псевдоним = Поле Тогда
						Индекс = Отборы.Индекс(Отбор);
					КонецЕсли;
				КонецЦикла; 
			Иначе	
				Отбор  = Отборы.Найти(СтрШаблон("бит_ОборотыПоБюджетам.%1", СтрЗаменить(Реквизит.Ключ, "НЗ_", "")));
				Если Отбор <> Неопределено Тогда
					Индекс = Отборы.Индекс(Отбор);
				КонецЕсли;
			КонецЕсли;
			Если Индекс >= 0 Тогда
				Отборы.Удалить(Индекс);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла; 
	
	ТекстЗапросаПоНастройкам = СхемаЗапроса.ПолучитьТекстЗапроса();
	
	Возврат ТекстЗапросаПоНастройкам;
	
КонецФункции

&НаСервере
Процедура НастройкаЗаполненияИспользоватьРазрезПриИзмененииНаСервере(Знач ИмяРеквизита, Знач Использование)

	Если НЕ Использование Тогда
		Поле   = СтрЗаменить(ИмяРеквизита, "НЗ_", "");
		Индекс = ТаблицаОтбор.Количество() - 1;
		Пока Индекс >= 0 Цикл
			СтрокаТаблицы = ТаблицаОтбор.Получить(Индекс);
			ЧастиПути 	  = СтрРазделить(СтрокаТаблицы.ПутьКДанным,".");
			ПутьКДанным   = "";
			Если ЧастиПути.Количество() >= 1 Тогда
				ПутьКДанным = ЧастиПути[0];
			КонецЕсли;
			Если ПутьКДанным = Поле Тогда
				ТаблицаОтбор.Удалить(Индекс);
			КонецЕсли;
			Индекс = Индекс - 1;
		КонецЦикла; 
	КонецЕсли;
	
	ТекстЗапросаПоНастройкам = ТекстЗапросаПоНастройкам(ТекстЗапроса);
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьНастройкиПостроителяСообщитьОбОшибках()

	Индекс = 0;
	Для каждого СтрокаТаблицы Из ТаблицаОтбор Цикл
		ЧастиПути 	= СтрРазделить(СтрокаТаблицы.ПутьКДанным,".");
		ПутьКДанным = "";
		Если ЧастиПути.Количество() >= 1 Тогда
			ПутьКДанным = ЧастиПути[0];
		КонецЕсли;
		ПолеДанных 	   = "НЗ_" + ПутьКДанным;
		ЕстьПолеДанных = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, ПолеДанных);
		Если ЕстьПолеДанных И СтрокаТаблицы.Использование И НЕ Объект[ПолеДанных] Тогда
			ТекстПояснения = НСтр("ru = 'Отбор устанавливается только на измерения контроля';
								| en = 'The selection is set only for the management order'"); 
			
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(
								"Колонка","КОРРЕКТНОСТЬ", НСтр("ru = 'Поле'; en = 'Fild'"), Индекс + 1,
								НСтр("ru = 'Отборы'; en = 'Selections'") , ТекстПояснения);
								
			Поле = СтрШаблон("ТаблицаОтбор[%1].Представление", Формат(Индекс, "ЧН=0; ЧГ="));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,, Поле, , Ложь);
		КонецЕсли;
		Индекс = Индекс + 1;
	КонецЦикла;

КонецПроцедуры
 
#КонецОбласти
