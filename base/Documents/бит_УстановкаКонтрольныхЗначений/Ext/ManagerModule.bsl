// Функция подготавливает параметры проведения.
// 
// Параметры:
//  ДокументСсылка - ДокументСсылка.бит_КорректировкаКонтрольныхЗначений - ссылка на документ.
//  Отказ          - Булево - признак обнаружения ошибки и отказа от дальнейших действий.
//
// Возвращаемое значение:
//  Структура - структура параметров проведения.
//
Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт
	
	ПараметрыПроведения = Новый Структура(); 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);

	НомераТаблиц = Новый Структура(); 
	ТекстЗапроса = ТекстЗапросаВременныеТаблицыДокумента(НомераТаблиц)
				 + ТекстЗапросаРеквизитыДокумента(НомераТаблиц)
				 + ТекстЗапросаВременнаяТаблицаПереопределение(НомераТаблиц)
				 + ТекстЗапросаКонтрольныеЗначения(НомераТаблиц)
				 + ТекстЗапросаСрокиКонтроля(НомераТаблиц);
	
	Запрос.Текст = ТекстЗапроса;
	Результат 	 = Запрос.ВыполнитьПакет();
	
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла; 	
	
	КонтрольныеЗначения = КонтрольныеЗначенияБюджетов(ПараметрыПроведения.РеквизитыДокумента);
	СрокиКонтроля		= СрокиКонтроляПоБюджету(КонтрольныеЗначения, ПараметрыПроведения.СрокиКонтроляРеквизиты);
	
	ПараметрыПроведения.Вставить("КонтрольныеЗначения", КонтрольныеЗначения);
	ПараметрыПроведения.Вставить("СрокиКонтроля", СрокиКонтроля);
		
	Возврат ПараметрыПроведения;
	
КонецФункции 

// Параметры регламентного задания "бит_УстановкаКонтрольныхЗначений".
// 
// Возвращаемое значение:
//  Параметры - структура, ключи: Сценарий, ВидКонтроля, НачалоПериода.
//
Функция НовыеПараметрыУстановкиВФоне() Экспорт

	Параметры = Новый Структура; 
	Параметры.Вставить("Сценарий",Справочники.СценарииПланирования.ПустаяСсылка());
	Параметры.Вставить("ВидКонтроля", Перечисления.бит_РежимыКонтроляПоБюджету.ПустаяСсылка());
	Параметры.Вставить("НачалоПериода", '0001-01-01');

	Возврат Параметры;
	
КонецФункции

// Проведение документов по переданным параметрам.
//
// Параметры:
//  ПараметрыВыполнения	 - структура - см. НовыеПараметрыУстановкиВФоне().
//
Процедура ФоновоеПроведение(ПараметрыЗадания) Экспорт

	ПараметрыВыполнения = НовыеПараметрыУстановкиВФоне();
	Для каждого КлючЗначение Из ПараметрыВыполнения Цикл
		Значение = Неопределено;
		Если ПараметрыЗадания.Свойство(КлючЗначение.Ключ, Значение) Тогда
			ПараметрыВыполнения.Вставить(КлючЗначение.Ключ, Значение);
		КонецЕсли; 
	КонецЦикла; 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидКонтроля",   ПараметрыВыполнения.ВидКонтроля);
	Запрос.УстановитьПараметр("НачалоПериода", ПараметрыВыполнения.НачалоПериода);
	Запрос.УстановитьПараметр("Сценарий", 	   ПараметрыВыполнения.Сценарий);

	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	Таблица.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.бит_УстановкаКонтрольныхЗначений КАК Таблица
	|ГДЕ
	|	Таблица.Проведен
	|	И Таблица.Сценарий = &Сценарий
	|	И Таблица.ДатаНачала >= &НачалоПериода
	|	И Таблица.ВидКонтроля = &ВидКонтроля";
	
	Если НЕ ЗначениеЗаполнено(ПараметрыВыполнения.Сценарий) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И Таблица.Сценарий = &Сценарий", "");
	КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(ПараметрыВыполнения.ВидКонтроля) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И Таблица.ВидКонтроля = &ВидКонтроля", "");
	КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(ПараметрыВыполнения.НачалоПериода) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И Таблица.ДатаНачала >= &НачалоПериода", "");
	КонецЕсли; 
	
	Запрос.Текст 	 = ТекстЗапроса;
	РезультатЗапроса = Запрос.Выполнить();
	Выборка 		 = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ТекущийОбъект = Выборка.Ссылка.ПолучитьОбъект();
		Попытка
			ТекущийОбъект.Заблокировать();
		Исключение
			ТекстСообщения = НСтр("ru = 'Невозможно заблокировать документ.'; 
										|en = 'Can''t lock the document.'"); 
			ЗарегистрироватьОшибкуФоновогоПроведения(ТекущийОбъект, ТекстСообщения);
			Продолжить;
		КонецПопытки; 
		
		НачатьТранзакцию();
		Попытка			
			ТекущийОбъект.ДополнительныеСвойства.Вставить("Допроведение", Истина);
			ТекущийОбъект.Записать(РежимЗаписиДокумента.Проведение);
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ЗарегистрироватьОшибкуФоновогоПроведения(ТекущийОбъект, 
				КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));	
		КонецПопытки; 
	КонецЦикла;

КонецПроцедуры
 
Процедура ИнициализироватьПостроительОтчета(ПостроительОтчета, Реквизиты) Экспорт
	
	// Текст запроса переопределяется в коде.
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|   &ПоляВыборки, 
	|	&РежимКонтроля				 			КАК РежимКонтроля,
	|	бит_ОборотыПоБюджетам.Сценарий 			КАК Сценарий,
	|	&СценарийКонтролируемый 				КАК СценарийКонтролируемый,
	|	бит_ОборотыПоБюджетам.СтатьяОборотов 	КАК СтатьяОборотов,
	|	СУММА(бит_ОборотыПоБюджетам.СуммаСценарийОборот) КАК СуммаСценарийКонтроль,
	|	СУММА(бит_ОборотыПоБюджетам.КоличествоОборот) КАК КоличествоСценарийКонтроль,
	|	ВЫБОР &Периодичность  
	|		КОГДА 6 ТОГДА НАЧАЛОПЕРИОДА(Период, День)
	|		КОГДА 7 ТОГДА НАЧАЛОПЕРИОДА(Период, Неделя)
	|		КОГДА 8 ТОГДА НАЧАЛОПЕРИОДА(Период, Декада)
	|		КОГДА 9 ТОГДА НАЧАЛОПЕРИОДА(Период, Месяц)
	|		КОГДА 10 ТОГДА НАЧАЛОПЕРИОДА(Период, Квартал)
	|		КОГДА 11 ТОГДА НАЧАЛОПЕРИОДА(Период, Полугодие)
	|		КОГДА 12 ТОГДА НАЧАЛОПЕРИОДА(Период, Год)
	|		ИНАЧЕ &ДатаНачалаКонтроля 
	|	КОНЕЦ КАК Период
	|ПОМЕСТИТЬ ОборотыПоБюджетам	
	|ИЗ
	|	РегистрНакопления.бит_ОборотыПоБюджетам.Обороты(&ДатаНачала, &ДатаОкончания, ДЕНЬ {&Периодичность}, Сценарий = &Сценарий
	|			{(СтатьяОборотов.*)}) КАК бит_ОборотыПоБюджетам
	|{ГДЕ ИСТИНА КАК ПОЛЕ1
	|// УсловияНаФиксированныеИзмерения
	|// УсловияНаДополнительныеИзмерения
	|}
	|СГРУППИРОВАТЬ ПО
	|   &ПоляГруппировки, 	
	|	&РежимКонтроля,
	|	Сценарий,
	|	&СценарийКонтролируемый,
	|	СтатьяОборотов,
	|	ВЫБОР &Периодичность  
	|		КОГДА 6 ТОГДА НАЧАЛОПЕРИОДА(Период, День)
	|		КОГДА 7 ТОГДА НАЧАЛОПЕРИОДА(Период, Неделя)
	|		КОГДА 8 ТОГДА НАЧАЛОПЕРИОДА(Период, Декада)
	|		КОГДА 9 ТОГДА НАЧАЛОПЕРИОДА(Период, Месяц)
	|		КОГДА 10 ТОГДА НАЧАЛОПЕРИОДА(Период, Квартал)
	|		КОГДА 11 ТОГДА НАЧАЛОПЕРИОДА(Период, Полугодие)
	|		КОГДА 12 ТОГДА НАЧАЛОПЕРИОДА(Период, Год)
	|		ИНАЧЕ &ДатаНачалаКонтроля 
	|	КОНЕЦ
	|	;	
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&ПоляВременнойТаблицы,
	|	ОборотыПоБюджетам.РежимКонтроля КАК РежимКонтроля,
	|	ОборотыПоБюджетам.Сценарий КАК Сценарий,
	|	ОборотыПоБюджетам.СценарийКонтролируемый КАК СценарийКонтролируемый,
	|	ОборотыПоБюджетам.СтатьяОборотов КАК СтатьяОборотов,
	|	ОборотыПоБюджетам.Период КАК Период,
	|	ВЫБОР
	|		КОГДА &ВидОтклонения = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОтклоненийКонтрольныхЗначений.Процент)
	|			ТОГДА ОборотыПоБюджетам.СуммаСценарийКонтроль + ОборотыПоБюджетам.СуммаСценарийКонтроль * &ЗначениеОтклонения / 100
	|		КОГДА &ВидОтклонения = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОтклоненийКонтрольныхЗначений.Абсолютное)
	|			ТОГДА ОборотыПоБюджетам.СуммаСценарийКонтроль + &ЗначениеОтклонения
	|		ИНАЧЕ ОборотыПоБюджетам.СуммаСценарийКонтроль
	|	КОНЕЦ КАК СуммаСценарийКонтроль,
	|	ВЫБОР
	|		КОГДА &ВидОтклоненияКоличество = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОтклоненийКонтрольныхЗначений.Процент)
	|			ТОГДА ОборотыПоБюджетам.КоличествоСценарийКонтроль + ОборотыПоБюджетам.КоличествоСценарийКонтроль * &ЗначениеОтклоненияКоличество / 100
	|		КОГДА &ВидОтклоненияКоличество = ЗНАЧЕНИЕ(Перечисление.бит_ВидыОтклоненийКонтрольныхЗначений.Абсолютное)
	|			ТОГДА ОборотыПоБюджетам.КоличествоСценарийКонтроль + &ЗначениеОтклоненияКоличество
	|		ИНАЧЕ ОборотыПоБюджетам.КоличествоСценарийКонтроль
	|	КОНЕЦ КАК КоличествоСценарийКонтроль
	|ИЗ
	|	ОборотыПоБюджетам КАК ОборотыПоБюджетам";
	
	НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	
	ТекстыПолей   	  			= Новый Массив;
	ТекстыГруппировок 			= Новый Массив;
	ТекстыПолейВременнойТаблицы = Новый Массив;
	ПоляУсловий					= Новый Массив; 
	
	ШаблонПоля = 
	"
	|	ВЫБОР
	|		КОГДА &НЗ_%1
	|			ТОГДА бит_ОборотыПоБюджетам.%1
	|		ИНАЧЕ NULL
	|	КОНЕЦ КАК %1";
	
	ШаблонУсловия = "бит_ОборотыПоБюджетам.%1.*";
	
	ШаблонГруппировки = 
	"
	|	ВЫБОР
	|		КОГДА &НЗ_%1
	|			ТОГДА бит_ОборотыПоБюджетам.%1
	|		ИНАЧЕ NULL
	|	КОНЕЦ";
	
	ШаблонПоляВременнойТаблицы = 
	"
	|	ОборотыПоБюджетам.%1 КАК %1";
	
	Для каждого ТекИзмерение Из Метаданные.РегистрыНакопления.бит_ОборотыПоБюджетам.Измерения Цикл		
		
		ИмяИзмерения = ТекИзмерение.Имя;
		Если ИмяИзмерения = "Валюта" Или ИмяИзмерения = "Сценарий" Или ИмяИзмерения = "СтатьяОборотов" Тогда
			Продолжить;		
		КонецЕсли;
		
		ТекстыПолей.Добавить(СтрШаблон(ШаблонПоля, ИмяИзмерения));
		ТекстыГруппировок.Добавить(СтрШаблон(ШаблонГруппировки, ИмяИзмерения));
		ТекстыПолейВременнойТаблицы.Добавить(СтрШаблон(ШаблонПоляВременнойТаблицы, ИмяИзмерения));
		
		Если Лев(ИмяИзмерения, 10) <> "Аналитика_" Тогда
			ПоляУсловий.Добавить(СтрШаблон(ШаблонУсловия, ИмяИзмерения));
		КонецЕсли;					
	КонецЦикла;  

	СоответствиеИмен 	   = Новый Структура;
	ТекстОтбораПостроителя = "";
	
	Для Каждого ЭлементНастройки Из НастройкиИзмерений Цикл
		ТекстОтбораПостроителя = ТекстОтбораПостроителя 
								+ бит_МеханизмДопИзмерений.СформироватьТекстПоляОтбора("бит_ОборотыПоБюджетам", 
									ЭлементНастройки.Ключ, ЭлементНастройки.Значение);
								
		СоответствиеИмен.Вставить(ЭлементНастройки.Ключ, ЭлементНастройки.Значение.Синоним);						
	КонецЦикла;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ИСТИНА КАК ПОЛЕ1", ""); // Удаление технологического поля.
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляВыборки", СтрСоединить(ТекстыПолей, ","));
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "// УсловияНаФиксированныеИзмерения", СтрСоединить(ПоляУсловий, ","));
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "// УсловияНаДополнительныеИзмерения", ТекстОтбораПостроителя);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляГруппировки", СтрСоединить(ТекстыГруппировок, ","));
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляВременнойТаблицы", СтрСоединить(ТекстыПолейВременнойТаблицы, ","));
	
	ПостроительОтчета.Текст = ТекстЗапроса;
	СохраненнаяНастройка 	= Реквизиты.ХранилищеНастроекОтбора.Получить();								 

	Если ТипЗнч(СохраненнаяНастройка) = Тип("НастройкиПостроителяОтчета") Тогда
		
		ПостроительОтчета.УстановитьНастройки(СохраненнаяНастройка);	
		
	ИначеЕсли ТипЗнч(СохраненнаяНастройка) = Тип("Структура") Тогда	
		                       		
		Для каждого СтрокаОтбора Из СохраненнаяНастройка.Отбор Цикл
			Если ЗначениеЗаполнено(СтрокаОтбора.ПутьКДанным) Тогда
				ЭлементОтбора = ПостроительОтчета.Отбор.Добавить(СтрокаОтбора.ПутьКДанным);
				ЗаполнитьЗначенияСвойств(ЭлементОтбора, СтрокаОтбора);
			КонецЕсли;									
		КонецЦикла;			
	КонецЕсли;
	
	ПостроительОтчета.Параметры.Вставить("РежимКонтроля", 				 Реквизиты.РежимКонтроля);
	ПостроительОтчета.Параметры.Вставить("Сценарий", 					 Реквизиты.Сценарий);
	ПостроительОтчета.Параметры.Вставить("СценарийКонтролируемый",		 Реквизиты.СценарийКонтролируемый);	
	ПостроительОтчета.Параметры.Вставить("ДатаНачала", 					 Реквизиты.ДатаНачала);
	ПостроительОтчета.Параметры.Вставить("ДатаОкончания", 				 Реквизиты.ДатаОкончания);
	ПостроительОтчета.Параметры.Вставить("ВидОтклонения", 				 Реквизиты.ВидОтклонения);
	ПостроительОтчета.Параметры.Вставить("ЗначениеОтклонения", 			 Реквизиты.ЗначениеОтклонения);
	ПостроительОтчета.Параметры.Вставить("ВидОтклоненияКоличество", 	 Реквизиты.ВидОтклоненияКоличество);
	ПостроительОтчета.Параметры.Вставить("ЗначениеОтклоненияКоличество", Реквизиты.ЗначениеОтклоненияКоличество);
	Для каждого ТекИзмерение Из Метаданные.РегистрыНакопления.бит_ОборотыПоБюджетам.Измерения Цикл		
		ИмяИзмерения = ТекИзмерение.Имя;
		Если ИмяИзмерения = "Валюта" Или ИмяИзмерения = "Сценарий" Или ИмяИзмерения = "СтатьяОборотов" Тогда
			Продолжить;		
		КонецЕсли;
		ИмяПараметра = "НЗ_" + ИмяИзмерения;
		ПостроительОтчета.Параметры.Вставить(ИмяПараметра, Реквизиты[ИмяПараметра]);
	КонецЦикла;
	
	ПостроительОтчета.Параметры.Вставить("ДатаНачалаКонтроля", Реквизиты.ДатаНачалаКонтроля);
	
	Периодичность = Реквизиты.Периодичность;
	
	Менеджер = Перечисления.бит_ПериодичностьПланирования;
	Если Периодичность = Менеджер.День Тогда
		Значение = 6;
	ИначеЕсли Периодичность = Менеджер.Неделя Тогда 	
		Значение = 7;
	ИначеЕсли Периодичность = Менеджер.Декада Тогда 	
		Значение = 8;
	ИначеЕсли Периодичность = Менеджер.Месяц Тогда 	
		Значение = 9;
	ИначеЕсли Периодичность = Менеджер.Квартал Тогда 	
		Значение = 10;
	ИначеЕсли Периодичность = Менеджер.Полугодие Тогда 	
		Значение = 11;
	ИначеЕсли Периодичность = Менеджер.Год Тогда 	
		Значение = 12;
	Иначе 
		Значение = 0;
	КонецЕсли; 
	
	ПостроительОтчета.Параметры.Вставить("Периодичность", Значение);
	Если ЗначениеЗаполнено(Периодичность) Тогда
		ЭлементОтбора = ПостроительОтчета.Отбор.Добавить("Периодичность");
		ЭлементОтбора.ВидСравнения = ВидСравнения.Равно;
		ЭлементОтбора.Значение = Значение;
		ЭлементОтбора.Использование = Истина;
	КонецЕсли;
	
КонецПроцедуры

Функция РеквизитыДокумента(Ссылка) Экспорт

	ПараметрыПроведения = Новый Структура(); 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);

	НомераТаблиц = Новый Структура(); 
	ТекстЗапроса = ТекстЗапросаВременныеТаблицыДокумента(НомераТаблиц)
				 + ТекстЗапросаРеквизитыДокумента(НомераТаблиц);
	
	Запрос.Текст = ТекстЗапроса;
	Результат 	 = Запрос.ВыполнитьПакет();
	
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла;

	Возврат ПараметрыПроведения.РеквизитыДокумента;
	
КонецФункции

Процедура ВыполнитьКонтрольПересеченияНастроек(СрокиКонтроля, СрокиКонтроляРеквизиты, Отказ, Допроведение) Экспорт

	Запрос = Новый Запрос;
	Если СрокиКонтроляРеквизиты.Количество() = 0 ИЛИ Отказ Тогда 
		Возврат;
	КонецЕсли;
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(СрокиКонтроляРеквизиты[0]);
	
	Периодичность = бит_КонтрольИсполненияБюджета.ПериодичностьКонтроляСценария(Реквизиты.Сценарий);
	
	ИзмеренияКонтроля = Новый Структура; 
	Для каждого КлючЗначение Из Реквизиты Цикл
		Если СтрНачинаетсяС(КлючЗначение.Ключ, "Контроль") И КлючЗначение.Значение Тогда
			ИзмеренияКонтроля.Вставить(СтрЗаменить(КлючЗначение.Ключ, "Контроль", ""));
		КонецЕсли;
	КонецЦикла; 

	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Реквизиты", 				СрокиКонтроляРеквизиты);
	Запрос.УстановитьПараметр("СрокиКонтроля", 			СрокиКонтроля);
	Запрос.УстановитьПараметр("Периодичность", 	   		Периодичность);
	Запрос.УстановитьПараметр("СценарийКонтролируемый", Реквизиты.СценарийКонтролируемый);
	Запрос.УстановитьПараметр("Сценарий", 				Реквизиты.Сценарий);
	Запрос.УстановитьПараметр("РежимКонтроля", 	   		Реквизиты.РежимКонтроля);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Таблица.Регистратор КАК Регистратор,
	|	Таблица.КонтрольЦФО КАК КонтрольЦФО,
	|	Таблица.ДатаНачалаКонтроля КАК ДатаНачалаКонтроля,
	|	Таблица.ДатаОкончанияКонтроля КАК ДатаОкончанияКонтроля,
	|	Таблица.Периодичность КАК Периодичность,
	|	Таблица.НастройкаКонтроля КАК НастройкаКонтроля,
	|	Таблица.РежимКонтроля КАК РежимКонтроля,
	|	Таблица.Сценарий КАК Сценарий,
	|	Таблица.СценарийКонтролируемый КАК СценарийКонтролируемый,
	|	Таблица.КонтрольАналитика_1 КАК КонтрольАналитика_1,
	|	Таблица.КонтрольАналитика_2 КАК КонтрольАналитика_2,
	|	Таблица.КонтрольАналитика_3 КАК КонтрольАналитика_3,
	|	Таблица.КонтрольАналитика_4 КАК КонтрольАналитика_4,
	|	Таблица.КонтрольАналитика_5 КАК КонтрольАналитика_5,
	|	Таблица.КонтрольАналитика_6 КАК КонтрольАналитика_6,
	|	Таблица.КонтрольАналитика_7 КАК КонтрольАналитика_7,
	|	Таблица.КонтрольАналитика_8 КАК КонтрольАналитика_8,
	|	Таблица.КонтрольАналитика_9 КАК КонтрольАналитика_9,
	|	Таблица.КонтрольАналитика_10 КАК КонтрольАналитика_10,
	|	Таблица.КонтрольАналитика_11 КАК КонтрольАналитика_11,
	|	Таблица.КонтрольАналитика_12 КАК КонтрольАналитика_12
	|ПОМЕСТИТЬ ВременнаяТаблицаРеквизиты
	|ИЗ
	|	&Реквизиты КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Таблица.ИмяСписка КАК ИмяСписка,
	|	Таблица.СинонимСписка КАК СинонимСписка,
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.Период КАК Период,
	|	Таблица.ЦФО КАК ЦФО,
	|	Таблица.СтатьяОборотов КАК СтатьяОборотов,
	|	Таблица.НачалоПериода КАК НачалоПериода,
	|	Таблица.КонецПериода КАК КонецПериода,
	|	Таблица.Аналитика_1 КАК Аналитика_1,
	|	Таблица.Аналитика_2 КАК Аналитика_2,
	|	Таблица.Аналитика_3 КАК Аналитика_3,
	|	Таблица.Аналитика_4 КАК Аналитика_4,
	|	Таблица.Аналитика_5 КАК Аналитика_5,
	|	Таблица.Аналитика_6 КАК Аналитика_6,
	|	Таблица.Аналитика_7 КАК Аналитика_7,
	|	Таблица.Аналитика_8 КАК Аналитика_8,
	|	Таблица.Аналитика_9 КАК Аналитика_9,
	|	Таблица.Аналитика_10 КАК Аналитика_10,
	|	Таблица.Аналитика_11 КАК Аналитика_11,
	|	Таблица.Аналитика_12 КАК Аналитика_12
	|ПОМЕСТИТЬ ВременнаяТаблица
	|ИЗ
	|	&СрокиКонтроля КАК Таблица";

	Запрос.Выполнить();
	
	ВыполнитьКонтрольПересеченияНастроекЧ1(Запрос, ИзмеренияКонтроля, Отказ, Допроведение);
	ВыполнитьКонтрольПересеченияНастроекЧ2(Запрос, ИзмеренияКонтроля, Отказ, Допроведение);
	ВыполнитьКонтрольПересеченияНастроекЧ3(Запрос, ИзмеренияКонтроля, Отказ, Допроведение);
	
КонецПроцедуры
 
