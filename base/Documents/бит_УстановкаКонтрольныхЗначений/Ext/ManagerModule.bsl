Функция СрокиКонтроляПоБюджету(КонтрольныеЗначения, ТаблицаРеквизиты)

	ДанныеДокумента = КонтрольныеЗначения.Скопировать(); 
	ДанныеДокумента.Колонки.Добавить("НачалоПериода", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	ДанныеДокумента.Колонки.Добавить("КонецПериода",  ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));

	Если НЕ ЗначениеЗаполнено(КонтрольныеЗначения) Тогда
		Возврат ДанныеДокумента;	
	КонецЕсли;
	
	Реквизиты = ТаблицаРеквизиты[0];
	Для каждого СтрокаТаблицы Из ДанныеДокумента Цикл
		СтрокаТаблицы.НачалоПериода	= СтрокаТаблицы.Период;
		Если ЗначениеЗаполнено(Реквизиты.Периодичность) Тогда
			СтрокаТаблицы.КонецПериода = бит_ОбщегоНазначенияКлиентСервер.ПолучитьКонецПериода(
											СтрокаТаблицы.Период, Реквизиты.Периодичность);
		Иначе
			// Это не ошибка. Контроль за весь период.
			СтрокаТаблицы.КонецПериода = КонецДня(Реквизиты.ДатаОкончанияКонтроля);							
		КонецЕсли;
	КонецЦикла; 

	// Выполняется подбор настроек, для исключения повторной регистрации.
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Регистратор", 	   	 	Реквизиты.Регистратор);
	Запрос.УстановитьПараметр("Периодичность", 	   	 	Реквизиты.Периодичность);
	Запрос.УстановитьПараметр("РежимКонтроля", 	   	 	Реквизиты.РежимКонтроля);
	Запрос.УстановитьПараметр("СценарийКонтролируемый", Реквизиты.СценарийКонтролируемый);
	Запрос.УстановитьПараметр("ДанныеДокумента", 		ДанныеДокумента);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	&Периодичность КАК Периодичность,
	|	&РежимКонтроля КАК РежимКонтроля,
	|	&СценарийКонтролируемый КАК СценарийКонтролируемый,
	|	Таблица.Период КАК Период,
	|	Таблица.СтатьяОборотов КАК СтатьяОборотов,
	|	Таблица.ЦФО КАК ЦФО,
	|	Таблица.НачалоПериода КАК НачалоПериода,
	|	Таблица.КонецПериода КАК КонецПериода,
	|	Таблица.ИмяСписка КАК ИмяСписка,
	|	Таблица.СинонимСписка КАК СинонимСписка,
	|	Таблица.Аналитика_1 КАК Аналитика_1,
	|	Таблица.Аналитика_2 КАК Аналитика_2,
	|	Таблица.Аналитика_3 КАК Аналитика_3,
	|	Таблица.Аналитика_4 КАК Аналитика_4,
	|	Таблица.Аналитика_5 КАК Аналитика_5,
	|	Таблица.Аналитика_6 КАК Аналитика_6,
