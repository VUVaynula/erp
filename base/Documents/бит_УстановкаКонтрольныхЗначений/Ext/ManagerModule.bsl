Процедура ПодготовитьТаблицуРасчетыВВалюте(КонтрольныхЗначений, Реквизиты)
	
	// Приведем суммы к валюте контролируемого сценария.
	
	ТаблицаПериодов = КонтрольныхЗначений.Скопировать();
	ТаблицаПериодов.Свернуть("Период");
	
	// Установим настройки для получения курсов по периодам.
	КурсыВалют = Новый Структура;
	ВалютаСценария = Новый Структура;
	ВалютаСценария.Вставить("Валюта", Реквизиты.ВалютаСценария);
	КурсыВалют.Вставить("Сценарий", ВалютаСценария);
	
	ВалютаКонтролируемогоСценария = Новый Структура;
	ВалютаКонтролируемогоСценария.Вставить("Валюта", Реквизиты.ВалютаСценарияКонтролируемого);
	КурсыВалют.Вставить("СценарийКонтролируемый", ВалютаКонтролируемогоСценария);
	
	// Получим курсы по периодам
	КурсыПоПериодам = бит_КурсыВалют.ПолучитьКурсыВалютПоПериодам(ТаблицаПериодов, КурсыВалют, Реквизиты.Сценарий);
	
	Для каждого СтрокаТаблицы Из КонтрольныхЗначений Цикл
		КурсыПериода = КурсыПоПериодам[СтрокаТаблицы.Период];
		Если КурсыПериода <> Неопределено Тогда
			
			ПараметрыТекущегоКурса = Новый Структура("Валюта, Курс, Кратность");
			ЗаполнитьЗначенияСвойств(ПараметрыТекущегоКурса, КурсыПериода.Сценарий);
			
			ПараметрыНовогоКурса = Новый Структура("Валюта, Курс, Кратность");
			ЗаполнитьЗначенияСвойств(ПараметрыНовогоКурса, КурсыПериода.СценарийКонтролируемый);
			
			СтрокаТаблицы.СуммаСценарийКонтроль = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(
			СтрокаТаблицы.СуммаСценарийКонтроль, 
			ПараметрыТекущегоКурса, ПараметрыНовогоКурса);
		КонецЕсли; 
	КонецЦикла;

