Функция КонтрольныеЗначенияБюджетов(ТаблицаРеквизиты)
	
	Реквизиты = ТаблицаРеквизиты[0];
	ПостроительОтчета = Новый ПостроительОтчета;

	ИнициализироватьПостроительОтчета(ПостроительОтчета, Реквизиты);
	
	ПостроительОтчета.Выполнить(); 
	ПланБюджета = ПостроительОтчета.Результат.Выгрузить();
	
	Если Реквизиты.ВидКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
		ПодготовитьТаблицуРасчетыВВалюте(ПланБюджета, Реквизиты);
	КонецЕсли; 
	
	КонтрольныеЗначения = бит_КонтрольИсполненияБюджета.ПустаяТаблицаКонтрольныеЗначения();

	Для каждого СтрокаТаблицы Из ПланБюджета Цикл
		НоваяСтрока = КонтрольныеЗначения.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		НоваяСтрока.ИмяСписка     = "КонтрольныеЗначения";
		НоваяСтрока.СинонимСписка = НСтр("ru = 'Контрольные значения'; en = 'Reference value'");
		НоваяСтрока.НомерСтроки   = КонтрольныеЗначения.Количество();
	КонецЦикла; 
	
	// Удаление строк плана бюджета, которые уже использовались для установки лимитов.
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПланБюджета", КонтрольныеЗначения);
	Запрос.УстановитьПараметр("ИмяСписка",   "КонтрольныеЗначения");
	Запрос.УстановитьПараметр("Регистратор", Реквизиты.Ссылка);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПланБюджета.Период КАК Период,
	|	ПланБюджета.НомерСтроки КАК НомерСтроки,
	|	ПланБюджета.РежимКонтроля КАК РежимКонтроля,
	|	ПланБюджета.СценарийКонтролируемый КАК СценарийКонтролируемый,
	|	ПланБюджета.Сценарий КАК Сценарий,
	|	ПланБюджета.ЦФО КАК ЦФО,
	|	ПланБюджета.СтатьяОборотов КАК СтатьяОборотов,
	|	ПланБюджета.СуммаСценарийКонтроль КАК СуммаСценарийКонтроль,
	|	ПланБюджета.СуммаСценарийИсполнение КАК СуммаСценарийИсполнение,
	|	ПланБюджета.СуммаСценарийСверхЛимита КАК СуммаСценарийСверхЛимита,
	|	ПланБюджета.КоличествоСценарийКонтроль КАК КоличествоСценарийКонтроль,
	|	ПланБюджета.КоличествоСценарийИсполнение КАК КоличествоСценарийИсполнение,
	|	ПланБюджета.КоличествоСценарийСверхЛимита КАК КоличествоСценарийСверхЛимита,
	|	ПланБюджета.ДокументПланирования КАК ДокументПланирования,
	|	ПланБюджета.ИмяСписка КАК ИмяСписка,
	|	ПланБюджета.СинонимСписка КАК СинонимСписка,
	|	ПланБюджета.Аналитика_1 КАК Аналитика_1,
	|	ПланБюджета.Аналитика_2 КАК Аналитика_2,
	|	ПланБюджета.Аналитика_3 КАК Аналитика_3,
