#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	бит_ОбщегоНазначения.ЗаполнитьШапкуДокумента(ЭтотОбъект, 
			Пользователи.ТекущийПользователь(), Неопределено,, Ложь);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	бит_ОбщегоНазначенияПереопределяемый.ОбработкаПроведенияНачало(ЭтотОбъект, Ложь);
	Если РучнаяКорректировка Тогда
		Возврат;
	КонецЕсли;
	
	Допроведение		= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства, "Допроведение", Ложь);
	ПараметрыПроведения = Документы.бит_УстановкаКонтрольныхЗначений.ПодготовитьПараметрыПроведения(Ссылка, Отказ);
	
	ПроверитьМножественныйКонтроль(ПараметрыПроведения.КонтрольныеЗначения, Отказ, Допроведение);
	
	Документы.бит_УстановкаКонтрольныхЗначений.ВыполнитьКонтрольПересеченияНастроек(
		ПараметрыПроведения.СрокиКонтроля, 
		ПараметрыПроведения.СрокиКонтроляРеквизиты, 
		Отказ, Допроведение);
		
	Если Отказ Тогда
		Возврат;	
	КонецЕсли;
	
	бит_КонтрольИсполненияБюджета.СформироватьДвиженияПоСрокамКонтроля(
		ПараметрыПроведения.СрокиКонтроля,
		ПараметрыПроведения.СрокиКонтроляРеквизиты, 
		Движения);	
		
	бит_КонтрольИсполненияБюджета.СформироватьДвиженияКонтрольныеЗначенияБюджетов(
		ПараметрыПроведения.КонтрольныеЗначения, 
		Движения);
	
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаПроведенияЗавершение(ЭтотОбъект, Отказ);

КонецПроцедуры // ОбработкаПроведения()

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	НепроверяемыеРеквизиты = Новый Массив();
	
	Если ВидКонтроля <> Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
		НепроверяемыеРеквизиты.Добавить("СценарийКонтролируемый");
	КонецЕсли; 

	Если НЕ ПроизвольнаяПериодичностьКонтроля Тогда
		НепроверяемыеРеквизиты.Добавить("ДатаНачалаКонтроля");
		НепроверяемыеРеквизиты.Добавить("ДатаОкончанияКонтроля");
	Иначе
		Если ЗначениеЗаполнено(ПериодичностьКонтроля) Тогда
			НепроверяемыеРеквизиты.Добавить("ДатаНачалаКонтроля");
			НепроверяемыеРеквизиты.Добавить("ДатаОкончанияКонтроля");
		КонецЕсли;
	КонецЕсли;
	
	Если ВидОтклонения = Перечисления.бит_ВидыОтклоненийКонтрольныхЗначений.Процент
		И (ЗначениеОтклонения > 100 ИЛИ ЗначениеОтклонения < -100) Тогда
		ТекстПояснения = НСтр("ru = 'Значение отклонения выраженного в процентах располагается в диапазоне от -100 до 100.';
							  |en = 'The deviation value expressed as a percentage is in range from -100 to 100.'");
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(, "Корректность",
							НСтр("ru = 'Величина отклонения'; en = 'Variance Value'"),,, ТекстПояснения);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "ЗначениеОтклонения",, Отказ);
	КонецЕсли;
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты); 
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	бит_ОбщегоНазначенияПереопределяемый.ОбработкаУдаленияПроведения(ЭтотОбъект, Отказ);

КонецПроцедуры // ОбработкаУдаленияПроведения()

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;	
	КонецЕсли;

	бит_ОбщегоНазначенияПереопределяемый.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
		
	ПередЗаписьюЛокализация();
	
	Если НЕ ПроизвольнаяПериодичностьКонтроля Тогда
		Если ВидКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
			ПериодичностьКонтроля = бит_КонтрольИсполненияБюджета.ПериодичностьКонтроляСценария(СценарийКонтролируемый);
		Иначе
			ПериодичностьКонтроля = бит_КонтрольИсполненияБюджета.ПериодичностьКонтроляСценария(Сценарий);
		КонецЕсли; 
		ДатаНачалаКонтроля 	  = ДатаНачала;
		ДатаОкончанияКонтроля = ДатаОкончания;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПериодичностьКонтроля) Тогда
		ДатаНачалаКонтроля = бит_ОбщегоНазначенияКлиентСервер.ПолучитьНачалоПериода(
								ДатаНачалаКонтроля, ПериодичностьКонтроля);
		
		ДатаОкончанияКонтроля = бит_ОбщегоНазначенияКлиентСервер.ПолучитьКонецПериода(
									ДатаОкончанияКонтроля, ПериодичностьКонтроля);								
	КонецЕсли;
		
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	Ответственный = Пользователи.ТекущийПользователь();
	Комментарий   = "";
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура СохранитьНастройкиПостроителя(СтруктураНастроек)  Экспорт
	
	ХранилищеНастроекОтбора = Новый ХранилищеЗначения(СтруктураНастроек, Новый СжатиеДанных(9));
	
КонецПроцедуры // СохранитьНастройкиПостроителя()

Функция ПолучитьНастройкиПостроителя() Экспорт
	
	СтруктураНастроек = ХранилищеНастроекОтбора.Получить();
	
	Возврат СтруктураНастроек;
	
КонецФункции // ПолучитьНастройкиПостроителя()

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПроверитьМножественныйКонтроль(ТаблицаКонтрольныхЗначений, Отказ, Допроведение)
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.бит_КонтрольныеЗначенияБюджетов");
	ЭлементБлокировки.УстановитьЗначение("СценарийКонтролируемый", СценарийКонтролируемый);
	ЭлементБлокировки.УстановитьЗначение("Период", Новый Диапазон(ДатаНачала, ДатаОкончания));
	ЭлементБлокировки.ИсточникДанных = ТаблицаКонтрольныхЗначений;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("СтатьяОборотов", "СтатьяОборотов");
	Блокировка.Заблокировать();
	        	
	Если ВидКонтроля = Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
		
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ТаблицаДокумента.Период КАК Период,
		|	ТаблицаДокумента.Сценарий КАК Сценарий,
		|	ТаблицаДокумента.СтатьяОборотов КАК СтатьяОборотов
		|ПОМЕСТИТЬ ТаблицаДокумента
		|ИЗ
		|	&ТаблицаДокумента КАК ТаблицаДокумента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	&ДинамическийПериод КАК Период,
		|	КонтрольныеЗначенияБюджетов.Сценарий КАК Сценарий,
		|	КонтрольныеЗначенияБюджетов.СтатьяОборотов КАК СтатьяОборотов,
		|	КонтрольныеЗначенияБюджетов.СуммаСценарийКонтрольОборот КАК СуммаКонтроль,
		|	КонтрольныеЗначенияБюджетов.КоличествоСценарийКонтрольОборот КАК КоличествоКонтроль
		|ПОМЕСТИТЬ КонтрольныеЗначенияБюджетов
		|ИЗ
		|	РегистрНакопления.бит_КонтрольныеЗначенияБюджетов.Обороты(
		|			&НачалоПериода,
		|			&КонецПериода,
		|			Авто,
		|			СценарийКонтролируемый = &СценарийКонтролируемый
		|				И РежимКонтроля = &РежимКонтроля
		|				И СтатьяОборотов В
		|					(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|						ТаблицаДокумента.СтатьяОборотов КАК СтатьяОборотов
		|					ИЗ
		|						ТаблицаДокумента КАК ТаблицаДокумента)) КАК КонтрольныеЗначенияБюджетов
		|ГДЕ
		|	(КонтрольныеЗначенияБюджетов.СуммаСценарийКонтрольОборот <> 0
		|			ИЛИ КонтрольныеЗначенияБюджетов.КоличествоСценарийКонтрольОборот <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТаблицаДокумента.Период КАК Период,
		|	ТаблицаДокумента.Сценарий КАК Сценарий,
		|	ТаблицаДокумента.СтатьяОборотов КАК СтатьяОборотов
		|ПОМЕСТИТЬ ТаблицаКонтроля
		|ИЗ
		|	ТаблицаДокумента КАК ТаблицаДокумента
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	КонтрольныеЗначенияБюджетов.Период,
		|	КонтрольныеЗначенияБюджетов.Сценарий,
		|	КонтрольныеЗначенияБюджетов.СтатьяОборотов
		|ИЗ
		|	КонтрольныеЗначенияБюджетов КАК КонтрольныеЗначенияБюджетов
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Период,
		|	Сценарий,
		|	СтатьяОборотов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаКонтроля.Период КАК Период,
		|	ТаблицаКонтроля.СтатьяОборотов КАК СтатьяОборотов,
		|	ТаблицаКонтроля.Сценарий КАК Сценарий,
		|	ТаблицаКонтроляКопия.Сценарий КАК СценарийКопия
		|ИЗ
		|	ТаблицаКонтроля КАК ТаблицаКонтроля
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаКонтроля КАК ТаблицаКонтроляКопия
		|		ПО ТаблицаКонтроля.Период = ТаблицаКонтроляКопия.Период
		|			И ТаблицаКонтроля.СтатьяОборотов = ТаблицаКонтроляКопия.СтатьяОборотов
		|			И ТаблицаКонтроля.Сценарий <> ТаблицаКонтроляКопия.Сценарий
		|ГДЕ
		|	НЕ ТаблицаКонтроляКопия.Сценарий ЕСТЬ NULL
		|	И ТаблицаКонтроля.Сценарий <> &Сценарий";
		
		Если ПроизвольнаяПериодичностьКонтроля ИЛИ НЕ ЗначениеЗаполнено(ПериодичностьКонтроля) Тогда
			ДинамическийПериод = "&НачалоПериода";
		Иначе	
			РазворотОборотов   = бит_Бюджетирование.ПериодДляРазворотаТаблицыЗапроса(ПериодичностьКонтроля);	
			ДинамическийПериод = "Период" + РазворотОборотов;			
		КонецЕсли;
		
		ЧтоЗаменить   = "&ДинамическийПериод";
		НаЧтоЗаменить = ДинамическийПериод;
		ТекстЗапроса  = СтрЗаменить(ТекстЗапроса, ЧтоЗаменить, НаЧтоЗаменить);
		
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапроса;
		Запрос.УстановитьПараметр("НачалоПериода",		   ДатаНачала);
		Запрос.УстановитьПараметр("КонецПериода",		   ДатаОкончания);
		Запрос.УстановитьПараметр("СценарийКонтролируемый",СценарийКонтролируемый);
		Запрос.УстановитьПараметр("ТаблицаДокумента",      ТаблицаКонтрольныхЗначений);
		Запрос.УстановитьПараметр("Сценарий",    		   Сценарий);
		Запрос.УстановитьПараметр("РежимКонтроля",    	   Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет);
		
		Результат = Запрос.Выполнить();
		Выборка = Результат.Выбрать();
		
		// Вывод сообщений в случае множественного контроля.
		Пока Выборка.Следующий() Цикл
			Если ЗначениеЗаполнено(Выборка.Сценарий) Тогда				
				Если ЗначениеЗаполнено(ПериодичностьКонтроля) Тогда
					ПредставлениеПериода = бит_ОбщегоНазначения.СформироватьПредставлениеПериода(Выборка.Период, ПериодичностьКонтроля);				
					ТекстСообщения = НСтр("ru = 'В течение периода ""%1"" статья ""%2"" контролируется сценарием ""%3"" и сценарием ""%4"". Множественный контроль запрещен.';
										  |en = 'During ""%1"" period in article ""%2"" control in same time by ""%3"" and ""%4"" scenario. Multiple control is prohibited.'");
					ТекстСообщения = СтрШаблон(ТекстСообщения, ПредставлениеПериода, Выборка.СтатьяОборотов, Выборка.Сценарий, Выборка.СценарийКопия);				
				Иначе	
					ТекстСообщения = НСтр("ru = 'Начиная с ""%1"" статья ""%2"" контролируется сценарием ""%3"" и сценарием ""%4"". Множественный контроль запрещен.';
										  |en = 'During ""%1"" period in article ""%2"" control in same time by ""%3"" and ""%4"" scenario. Multiple control is prohibited.'");
					ТекстСообщения = СтрШаблон(ТекстСообщения, Формат(ДатаНачала, "ДЛФ=D"), Выборка.СтатьяОборотов, Выборка.Сценарий, Выборка.СценарийКопия);				
				КонецЕсли;
				Если Допроведение Тогда
					ВызватьИсключение ТекстСообщения; 
				Иначе	
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, , ,Отказ); 
				КонецЕсли;
			КонецЕсли; 
		КонецЦикла; 		
	КонецЕсли; 
	
КонецПроцедуры

Процедура ПередЗаписьюЛокализация()
	
	// ++ ЕРП 
	// Для графиков и заявок контроль:
	// 1. Сценарий контролируемый совпадает с базовым.
	Если ВидКонтроля <> Перечисления.бит_РежимыКонтроляПоБюджету.Бюджет Тогда
		СценарийКонтролируемый = Сценарий;
	КонецЕсли;
	// -- ЕРП 

КонецПроцедуры

#КонецОбласти

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли