//  Процедура заполняет кэш значений, необходимый при работе на клиенте.
// 
&НаСервере
Процедура ЗаполнитьКэшЗначений()
	
	КэшЗначений = Новый Структура;
	
	ДокументЗаявка = ДанныеФормыВЗначение(Объект, Тип("ДокументОбъект.бит_пз_ОтражениеФактаЗатрат"));
	
	КэшЗначений.Вставить("ИзмеренияДоп"      	, ДокументЗаявка.мИзмеренияДоп);
	КэшЗначений.Вставить("НастройкиИзмерений"	, ДокументЗаявка.мНастройкиИзмерений);
	КэшЗначений.Вставить("ВалютаРеглУчета"		, Константы.ВалютаРегламентированногоУчета.Получить());
	// Произвольные измерения
	КэшЗначений.Вставить("Измерения"			, бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Произвольные", "Синоним"));
	
	// Запишем параметр для формирования заголовка.
	КэшЗначений.Вставить("ПредставлениеОбъекта", Объект.Ссылка.Метаданные().ПредставлениеОбъекта);
	
	// Параметры, используемые для управления автовидимостью колонок.
	КэшЗначений.Вставить("МассивСтатей_ЗаявкиНаЗатраты", Новый Массив);
	КэшЗначений.Вставить("НастройкаВидимостиКолонок"	, Новый Структура);
	
КонецПроцедуры // ЗаполнитьКэшЗначений()

//  Процедура управляем видимостью-доступностью элементов формы. 
// 
&НаСервере
Процедура УправлениеЭлементамиФормы()

	Элементы.ГруппаИнфо.Видимость = НЕ ЗначениеЗаполнено(Объект.ДокументОснование);
	
	Если НЕ Объект.Проведен Тогда 
		
		УстановитьДоступностьЭлементов(Истина, Истина);
	
	Иначе 
		
		УстановитьДоступностьЭлементов(Ложь, Истина);
		
	КонецЕсли; 
	
КонецПроцедуры // УправлениеЭлементамиФормы()

//  Процедура обработчик ПриИзменении документа основания на сервере.
//
&НаСервере
Процедура ДокументОснованиеПриИзмененииСервер()

	Если НЕ ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
	
		Возврат;
	
	КонецЕсли; 
	
	Документы.бит_пз_ОтражениеФактаЗатрат.ЗаполнитьОтражениеФактаПоОснованию(Объект, Объект.ДокументОснование);
	
	ЗаполнитьКоличествоПредыдущее();
	РасчитатьСуммыТабличнойЧасти();
	
	ОФормитьТаблицу("ЗаявкиНаЗатраты");
	
	УправлениеЭлементамиФормы();
	
КонецПроцедуры // ДокументОснованиеПриИзмененииСервер()

//  Процедура устанавливает данные в строке табличной 
// части в зависимости от настроек статьи оборотов. 
//
// Параметры:
//  ТекущиеДанные - СтрокаТабличнойЧасти.
//
&НаСервере
Процедура УстановитьДанныеПоСтатье(ТекущиеДанные)

	НастройкиСтатьи = Справочники.бит_СтатьиОборотов.ПолучитьНастройки(ТекущиеДанные.СтатьяОборотов);
	
	бит_Бюджетирование.УстановитьИспользованиеАналитики(ТекущиеДанные, НастройкиСтатьи, КэшЗначений.Измерения);
	
КонецПроцедуры // УстановитьДанныеПоСтатье()

//  Процедура обрабатывает изменение реквизита "СтатьяОборотов" в табличной части "ЗаявкиНаЗатраты".
// 
// Параметры:
//  ТекИд - Число
// 
&НаСервере
Процедура ИзменениеСтатьиОборотовТабличнойЧасти(ТекИд)
	
	ТекущиеДанные = Объект.ЗаявкиНаЗатраты.НайтиПоИдентификатору(ТекИд);
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьДанныеПоСтатье(ТекущиеДанные);
	
	ОФормитьТаблицу("ЗаявкиНаЗатраты", ТекущиеДанные.СтатьяОборотов);		
	УстановитьАвтовидимостьКолонок();
	
КонецПроцедуры // ИзменениеСтатьиОборотовТабличнойЧасти()

