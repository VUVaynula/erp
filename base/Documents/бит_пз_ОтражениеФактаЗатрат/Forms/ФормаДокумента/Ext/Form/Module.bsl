//  Процедура устанавливает автоматически видимость колонок таблицы БДДС.
// 
// Параметры:
//  ОбновлятьБезусловно - Булево (по умолчанию = Ложь)
// 
&НаСервере
Процедура УстановитьАвтовидимостьКолонок(ОбновлятьБезусловно = Ложь)
	
	ИмяТабличнойЧасти = "ЗаявкиНаЗатраты";
	ИмяМассива = "МассивСтатей_" + ИмяТабличнойЧасти;
	
	ТаблРез = Объект[ИмяТабличнойЧасти].Выгрузить();
	МассивСтатей = ТаблРез.ВыгрузитьКолонку("СтатьяОборотов");
	НеобходимоИзменение = бит_РаботаСДиалогамиСервер.НужноИзменитьВидимостьКолонокБюджета(МассивСтатей
																	, КэшЗначений[ИмяМассива]
																	, КэшЗначений.НастройкаВидимостиКолонок);
	
	Если НеобходимоИзменение Тогда
		
		бит_РаботаСДиалогамиСервер.УправлениеВидимостьюКолонокТабличногоПоля(Элементы
										 				, КэшЗначений.НастройкаВидимостиКолонок
										 				, ИмяТабличнойЧасти);
					
	КонецЕсли; 
		
КонецПроцедуры // УстановитьАвтовидимостьКолонок()

//  Процедура при изменении валюты на сервере. 
//
&НаСервере
Процедура ВалютаДокументаПриИзмененииСервер()

	Объект.ЗаявкиНаЗатраты.Очистить();
	
	ДокументЗаявка = ДанныеФормыВЗначение(Объект, Тип("ДокументОбъект.бит_пз_ОтражениеФактаЗатрат"));
	ДокументЗаявка.ИзменениеВалютыМодуль();
	
	ЗначениеВДанныеФормы(ДокументЗаявка, Объект);

КонецПроцедуры // ВалютаДокументаПриИзмененииСервер()

//  Процедура заполняет у таблицы Заявки предыдущее количество.
//
&НаСервере
Процедура ЗаполнитьКоличествоПредыдущее()

	Для каждого СтрокаТабличнойЧасти Из Объект.ЗаявкиНаЗатраты Цикл
	
		СтрокаТабличнойЧасти.КоличествоПредыдущее = СтрокаТабличнойЧасти.Количество;
	
	КонецЦикла; 

КонецПроцедуры // ЗаполнитьКоличествоПредыдущее()

//  Процедура расчитывает недостающие суммы после загрузки из документа основание.
//
&НаСервере
Процедура РасчитатьСуммыТабличнойЧасти()

	Для каждого СтрокаТабличнойЧасти Из Объект.ЗаявкиНаЗатраты Цикл
	
		Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтавкаНДС) Тогда
			СтрокаТабличнойЧасти.СуммаНДС = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(СтрокаТабличнойЧасти.Сумма,
				Истина, Ложь, бит_БухгалтерскийУчет.ПолучитьСтавкуНДС(СтрокаТабличнойЧасти.СтавкаНДС));
		КонецЕсли;
		
		РассчитатьСуммуВсего(СтрокаТабличнойЧасти.СуммаСНДС, СтрокаТабличнойЧасти.Сумма, СтрокаТабличнойЧасти.СуммаНДС);									
	
	КонецЦикла; 

КонецПроцедуры // РасчитатьСуммыТабличнойЧасти()

//  Процедура устанавливает доступность элементам формы.
// 
// Параметры:
//  Доступность - Булево.
// 
&НаСервере
Процедура УстановитьДоступностьЭлементов(Доступность, ИспользоватьИсключения)

	Исключения = Новый Массив;
	Если ИспользоватьИсключения Тогда
		
		Исключения.Добавить(ВРег("ЗаявкиНаЗатратыЗаявкаНаЗатраты"));
	
	КонецЕсли;
	
	Для каждого Элемент Из Элементы Цикл
		
		Если ТипЗнч(Элемент) = Тип("ПолеФормы") 
			 И Исключения.Найти(ВРег(Элемент.Имя)) = Неопределено Тогда  
			
			Элемент.ТолькоПросмотр = НЕ Доступность;
			
		КонецЕсли; 
		
	КонецЦикла;

КонецПроцедуры // УстановитьДоступностьЭлементов()

//  Процедура пересчитывает суммы табличной части при изменении цены или количества.
// 
&НаКлиентеНаСервереБезКонтекста
Процедура ПриИзмененииКоличествоЦена(Сумма, Количество, Цена, СуммаНДС, Всего, СтавкаНДС)

	Сумма = Цена * Количество;
	
	СуммаНДС = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(Сумма,
					Истина, Ложь, бит_БухгалтерияВызовСервера.ПолучитьСтавкуНДС(СтавкаНДС));
	
	Всего = Сумма + СуммаНДС;

КонецПроцедуры // ПриИзмененииКоличествоЦена()

//  Процедура пересчитывает суммы табличной части при суммы.
// 
&НаКлиентеНаСервереБезКонтекста
Процедура ПриИзмененииСумма(Сумма, СуммаНДС, Всего, СтавкаНДС)

	СуммаНДС = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(Сумма,
					Истина, Ложь, бит_БухгалтерияВызовСервера.ПолучитьСтавкуНДС(СтавкаНДС));
										
	Всего = Сумма + СуммаНДС;									

КонецПроцедуры // ПриИзмененииСумма()

//  Процедура обработка "ПриИзменении" поля СтавкаНДС на сервере. 
//
&НаСервере
Процедура ТоварыСтавкаНДСПриИзмененииСервер(ИД)

	СтрокаТабличнойЧасти = Объект.ЗаявкиНаЗатраты.НайтиПоИдентификатору(ИД);
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтавкаНДС) Тогда
		СтрокаТабличнойЧасти.СуммаНДС = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(СтрокаТабличнойЧасти.Сумма,
			Истина, Ложь, бит_БухгалтерскийУчет.ПолучитьСтавкуНДС(СтрокаТабличнойЧасти.СтавкаНДС));
	КонецЕсли;
	
	РассчитатьСуммуВсего(СтрокаТабличнойЧасти.СуммаСНДС, СтрокаТабличнойЧасти.Сумма, СтрокаТабличнойЧасти.СуммаНДС);									
	
КонецПроцедуры // ТоварыСтавкаНДСПриИзмененииСервер()

//  Процедура считает общую сумму. 
//
&НаКлиентеНаСервереБезКонтекста
Процедура РассчитатьСуммуВсего(Всего, Сумма, СуммаНДС)

	Всего = Сумма + СуммаНДС;

КонецПроцедуры // РассчитатьСуммуВсего()

#КонецОбласти 
