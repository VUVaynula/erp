// Процедура заполняет отражение факта по основанию. 
//
// Параметры:
//  Параметр1 - Строка.
//
&НаСервере
Процедура ЗаполнитьОтражениеФактаПоОснованию(Объект, ДокументОснование) Экспорт 

	Объект.ВидОперации 	= ДокументОснование.ВидОперации;
	
	// Подставим сценарий из настроек.
	СтруктураПараметров = Новый Структура;
	Если бит_РаботаСМетаданными.ЕстьРеквизит("Организация", Объект.Ссылка.Метаданные())  Тогда
	 	СтруктураПараметров.Вставить("Организация",ДокументОснование.Организация);
	КонецЕсли;	
	Если НЕ ЗначениеЗаполнено(Объект.Дата) Тогда
		
		ДатаДляНастроек = ТекущаяДата();
		
	Иначе	
		ДатаДляНастроек = Объект.Дата;
	КонецЕсли; 

	СценарийБюджетирования  = бит_НастройкиПрограммы.СценарийОтраженияФактаБДДС(СтруктураПараметров, ДатаДляНастроек);
	Если НЕ ЗначениеЗаполнено(СценарийБюджетирования) Тогда
	
		СценарийБюджетирования = Справочники.СценарииПланирования.ФАКТ;
	
	КонецЕсли; 
	Если НЕ ЗначениеЗаполнено(Объект.Сценарий) Тогда
	
		Объект.Сценарий = СценарийБюджетирования;
	
	КонецЕсли; 
	
	Объект.ЗаявкиНаЗатраты.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ПланируемыеЗатратыОстатки.Номенклатура,
	               |	ПланируемыеЗатратыОстатки.ЗаявкаНаЗатраты,
	               |	СУММА(ЕСТЬNULL(ПланируемыеЗатратыОстатки.КоличествоОстаток, 0)) КАК Количество,
	               |	ПланируемыеЗатратыАналитика.Содержание,
	               |	ПланируемыеЗатратыАналитика.СтатьяОборотов,
	               |	ПланируемыеЗатратыАналитика.ЦФО,
	               |	ПланируемыеЗатратыАналитика.Аналитика_1,
	               |	ПланируемыеЗатратыАналитика.Аналитика_2,
	               |	ПланируемыеЗатратыАналитика.Аналитика_3,
	               |	ПланируемыеЗатратыАналитика.Аналитика_4,
	               |	ПланируемыеЗатратыАналитика.Аналитика_5,
	               |	ПланируемыеЗатратыАналитика.Аналитика_6,
	               |	ПланируемыеЗатратыАналитика.Аналитика_7,
	               |	ПланируемыеЗатратыАналитика.Аналитика_8,
	               |	ПланируемыеЗатратыАналитика.Аналитика_9,
	               |	ПланируемыеЗатратыАналитика.Аналитика_10,
	               |	ПланируемыеЗатратыАналитика.Аналитика_11,
	               |	ПланируемыеЗатратыАналитика.Аналитика_12,
	               |	ВЫБОР
	               |		КОГДА ЕСТЬNULL(ПланируемыеЗатратыАналитика.Количество, 0) = 0
	               |			ТОГДА 0
	               |		ИНАЧЕ ЕСТЬNULL(ПланируемыеЗатратыАналитика.Сумма, 0) * ЕСТЬNULL(ПланируемыеЗатратыОстатки.КоличествоОстаток, 0) / ЕСТЬNULL(ПланируемыеЗатратыАналитика.Количество, 0)
	               |	КОНЕЦ КАК Сумма,
	               |	ПланируемыеЗатратыАналитика.СтавкаНДС,
	               |	ЕСТЬNULL(ПланируемыеЗатратыАналитика.Цена, 0) КАК Цена,
	               |	ПланируемыеЗатратыОстатки.Характеристика
	               |ИЗ
	               |	РегистрНакопления.бит_пз_ПланируемыеЗатраты.Остатки(, ДокументПланирования = &ДокПланирования) КАК ПланируемыеЗатратыОстатки
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.бит_пз_ПланируемыеЗатратыАналитика КАК ПланируемыеЗатратыАналитика
	               |		ПО ПланируемыеЗатратыОстатки.ДокументПланирования = ПланируемыеЗатратыАналитика.ДокументПланирования
	               |			И ПланируемыеЗатратыОстатки.Номенклатура = ПланируемыеЗатратыАналитика.Номенклатура
	               |			И ПланируемыеЗатратыОстатки.Организация = ПланируемыеЗатратыАналитика.Организация
	               |			И ПланируемыеЗатратыОстатки.ЗаявкаНаЗатраты = ПланируемыеЗатратыАналитика.ЗаявкаНаЗатраты
	               |			И ПланируемыеЗатратыОстатки.Характеристика = ПланируемыеЗатратыАналитика.Характеристика
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПланируемыеЗатратыАналитика.Аналитика_4,
	               |	ПланируемыеЗатратыАналитика.Аналитика_9,
	               |	ПланируемыеЗатратыАналитика.Аналитика_1,
	               |	ПланируемыеЗатратыАналитика.Содержание,
	               |	ПланируемыеЗатратыАналитика.Аналитика_7,
	               |	ПланируемыеЗатратыАналитика.ЦФО,
	               |	ПланируемыеЗатратыАналитика.Аналитика_8,
	               |	ПланируемыеЗатратыАналитика.Аналитика_12,
	               |	ПланируемыеЗатратыАналитика.СтатьяОборотов,
	               |	ПланируемыеЗатратыАналитика.Аналитика_3,
	               |	ПланируемыеЗатратыОстатки.Номенклатура,
	               |	ПланируемыеЗатратыАналитика.Аналитика_2,
	               |	ПланируемыеЗатратыАналитика.Аналитика_10,
	               |	ПланируемыеЗатратыАналитика.Аналитика_11,
	               |	ПланируемыеЗатратыАналитика.Аналитика_6,
	               |	ПланируемыеЗатратыОстатки.ЗаявкаНаЗатраты,
	               |	ПланируемыеЗатратыАналитика.Аналитика_5,
	               |	ПланируемыеЗатратыАналитика.СтавкаНДС,
	               |	ЕСТЬNULL(ПланируемыеЗатратыАналитика.Цена, 0),
	               |	ВЫБОР
	               |		КОГДА ЕСТЬNULL(ПланируемыеЗатратыАналитика.Количество, 0) = 0
	               |			ТОГДА 0
	               |		ИНАЧЕ ЕСТЬNULL(ПланируемыеЗатратыАналитика.Сумма, 0) * ЕСТЬNULL(ПланируемыеЗатратыОстатки.КоличествоОстаток, 0) / ЕСТЬNULL(ПланируемыеЗатратыАналитика.Количество, 0)
	               |	КОНЕЦ,
	               |	ПланируемыеЗатратыОстатки.Характеристика";
	
	Запрос.УстановитьПараметр("ДокПланирования", ДокументОснование);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
	
		НоваяСтрока = Объект.ЗаявкиНаЗатраты.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
	
	КонецЦикла;

КонецПроцедуры // ЗаполнитьОтражениеФактаПоОснованию()

Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт
	
	ПараметрыПроведения = Новый Структура;
	ПараметрыПроведения.Вставить("ОборотыПоБюджетам", 		   Новый ТаблицаЗначений);
	ПараметрыПроведения.Вставить("ОборотыПоБюджетамРеквизиты", Новый ТаблицаЗначений);	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Дата КАК Дата,
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.Сценарий КАК Сценарий,
	|	Реквизиты.ВалютаДокумента КАК Валюта,
	|	Реквизиты.КратностьДокумента КАК Кратность,
	|	Реквизиты.КурсДокумента КАК Курс,
	|	Реквизиты.РучнаяКорректировка КАК РучнаяКорректировка,
	|	Реквизиты.Сценарий.ИспользоватьКурсыСценария КАК ИспользоватьКурсыСценария,
	|	Реквизиты.Сценарий.Валюта КАК ВалютаСценария,
	|	Реквизиты.ДокументОснование КАК ДокументОснование
	|ИЗ
	|	Документ.бит_пз_ОтражениеФактаЗатрат КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";
	
	Результат = Запрос.Выполнить().Выгрузить();
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Результат[0]);
	
	Если НЕ бит_ОбщегоНазначения.ВалютаУпрУчетаУстановлена(Истина, ДокументСсылка) Тогда
		Отказ = Истина;
		Возврат ПараметрыПроведения;
	КонецЕсли;
	
	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("Организация",Реквизиты.Организация);		
	
	ОтразитьФакт = бит_НастройкиПрограммы.ФормироватьДвиженияПоФактуБюджетаЗакупок(
								ПараметрыНастройки, Реквизиты.Дата);
								
	ФормироватьЗависимыеОбороты  = бит_НастройкиПрограммы.ФормироватьЗависимыеОборотыПоФактуБюджетаЗакупок(
										ПараметрыНастройки, Реквизиты.Дата);
										
	ЗатратыПланируютсяСНДС = бит_ОбщегоНазначенияПовтИсп.ЗначениеПеременной("бит_пз_ЗатратыПланируютсяСНДС");

	Запрос.УстановитьПараметр("ЗатратыПланируютсяСНДС", 	 ЗатратыПланируютсяСНДС);
	Запрос.УстановитьПараметр("ФормироватьЗависимыеОбороты", ФормироватьЗависимыеОбороты);
	
	НомераТаблиц = Новый Структура;
	Запрос.Текст = ТекстЗапросаПланируемыеЗатраты(НомераТаблиц)
				 + ТекстЗапросаТаблицаОборотыПоБюджетам(НомераТаблиц, ОтразитьФакт);

	Результат = Запрос.ВыполнитьПакет();
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла;
	
	ПараметрыПроведения.Вставить("Реквизиты", Реквизиты);
	ПодготовитьТаблицыДокументаРасчетыВВалюте(ПараметрыПроведения, Реквизиты);
			
	Возврат ПараметрыПроведения;
	
КонецФункции

Функция СвязанныеДокументы(ДокументСсылка) Экспорт

	Запрос = НОвый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПланируемыеЗатраты.ЗаявкаНаЗатраты КАК СвязанныйДокумент
	|ПОМЕСТИТЬ СвязанныеДокументы
	|ИЗ
	|	Документ.бит_пз_ОтражениеФактаЗатрат.ЗаявкиНаЗатраты КАК ПланируемыеЗатраты
	|ГДЕ
	|	ПланируемыеЗатраты.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Реквизиты.ДокументОснование
	|ИЗ
	|	Документ.бит_пз_ОтражениеФактаЗатрат КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СвязанныеДокументы.СвязанныйДокумент КАК СвязанныйДокумент
	|ИЗ
	|	СвязанныеДокументы КАК СвязанныеДокументы";
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура ОбновитьСтатусСвязанныхДокументов(СвязанныеДокументы) Экспорт

	Если НЕ ЗначениеЗаполнено(СвязанныеДокументы) Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого СтрокаТаблицы Из СвязанныеДокументы Цикл
		ТекущийОбъект = СтрокаТаблицы.СвязанныйДокумент.ПолучитьОбъект();
		бит_ВизированиеСервер.УстановитьСтатус(ТекущийОбъект);	
	КонецЦикла;	

КонецПроцедуры

Процедура СформироватьДвиженияПланируемыеЗатраты(ТаблицаПланируемыеЗатраты, Реквизиты, Движения) Экспорт

	Если НЕ ЗначениеЗаполнено(ТаблицаПланируемыеЗатраты) ИЛИ НЕ ЗначениеЗаполнено(Реквизиты) Тогда
		Возврат;
	КонецЕсли;	

	НаборЗаписей = Движения.бит_пз_ПланируемыеЗатраты;
	НаборЗаписей.Записывать = Истина;
	
	Для каждого СтрокаТаблицы Из ТаблицаПланируемыеЗатраты Цикл
		Проводка = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(Проводка, СтрокаТаблицы);
		ЗаполнитьЗначенияСвойств(Проводка, Реквизиты[0]);
	КонецЦикла;

КонецПроцедуры

Процедура СформироватьДвиженияОборотыПоБюджетам(ТаблицаОборотыПоБюджетам, ТаблицаРеквизиты, Движения) Экспорт

	Если НЕ ЗначениеЗаполнено(ТаблицаОборотыПоБюджетам) ИЛИ НЕ ЗначениеЗаполнено(ТаблицаРеквизиты) Тогда
		Возврат;
	КонецЕсли;	

	НаборЗаписей = Движения.бит_ОборотыПоБюджетам;
	НаборЗаписей.Записывать = Истина;
	
	Реквизиты = ТаблицаРеквизиты[0];
	Для каждого СтрокаТаблицы Из ТаблицаОборотыПоБюджетам Цикл
		Проводка = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(Проводка, СтрокаТаблицы);
		ЗаполнитьЗначенияСвойств(Проводка, Реквизиты);
	КонецЦикла;

	Если Реквизиты.ФормироватьЗависимыеОбороты Тогда
		бит_Бюджетирование.СформироватьЗависимыеОборотыПоНаборуЗаписей(Реквизиты.Регистратор, 
			Движения.бит_ОборотыПоБюджетам);
	КонецЕсли;
		
КонецПроцедуры

Процедура СформироватьДвиженияБюджетирование(ТаблицаОборотыПоБюджетам, ТаблицаРеквизиты, Движения) Экспорт

	Если НЕ ЗначениеЗаполнено(ТаблицаОборотыПоБюджетам) ИЛИ НЕ ЗначениеЗаполнено(ТаблицаРеквизиты) Тогда
		Возврат;
	КонецЕсли;	

	НаборЗаписей = Движения.бит_Бюджетирование;
	НаборЗаписей.Записывать = Истина;
		
	бит_Бюджетирование.СформироватьПроводкиБюджетирования(ТаблицаОборотыПоБюджетам, 
		Движения.бит_Бюджетирование);
	
КонецПроцедуры
	
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПодготовитьТаблицыДокументаРасчетыВВалюте(ПараметрыПроведения, Реквизиты)

	Если НЕ ЗначениеЗаполнено(Реквизиты) Тогда
		Возврат;
	КонецЕсли;

	КурсыВалют = бит_КурсыВалют.КурсыВалютДокумента(Реквизиты.Регистратор, 
					Реквизиты.Дата, Новый Структура("Документ, Регл, Упр, Сценарий"));
	
	Реквизиты.Вставить("КурсыВалют", КурсыВалют);
	
	Ресурсы = Новый Массив;
	Ресурсы.Добавить("Сумма");

	Для каждого СтрокаТаблицы Из ПараметрыПроведения.ОборотыПоБюджетам Цикл
		бит_КурсыВалют.ВыполнитьПересчетыДляОбъекта(СтрокаТаблицы, 
			Ресурсы, КурсыВалют, КурсыВалют.Документ);
	КонецЦикла;
	
КонецПроцедуры

