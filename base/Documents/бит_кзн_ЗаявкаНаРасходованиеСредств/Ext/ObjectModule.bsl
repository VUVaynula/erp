#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ОписаниеПеременных

// Опеределяет выполнение пометки на удаление из графика платежей
Перем мПометкаИзГрафикаПлатажей Экспорт;
// адрес хранилища, где хранится массив строк превышающих лимиты
Перем мАдресХранилищаСтрокПревышения Экспорт;

#КонецОбласти

#Область ПрограммныйИнтерфейс
	
// Заполняет наборы значений доступа.
// Параметры:
//  Таблица - ТаблицаЗначений - передает в этот параметр подготовленные наборы значений
//            доступа. Описание колонок см. в функции УправлениеДоступом.ТаблицаНаборыЗначенийДоступа.
//
Процедура ЗаполнитьНаборыЗначенийДоступа(Таблица) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	ДобавитьСтрокуВНаборЗначенийДоступа(Организация, Таблица);
	ДобавитьСтрокуВНаборЗначенийДоступа(Ответственный, Таблица);
	
	ТаблицаДанных = бит_УправлениеДоступомБФСлужебный.ДанныеПозицийПоЗаявке(Ссылка);
	
	Для каждого СтрокаТаблицы Из ТаблицаДанных Цикл
		КлючДоступаЦФОСтатьяОборотов = Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.КлючиЦФОСтатьяОборотовДокумента(
			СтрокаТаблицы.ЦФО, СтрокаТаблицы.СтатьяОборотов);
		ДобавитьСтрокуВНаборЗначенийДоступа(КлючДоступаЦФОСтатьяОборотов, Таблица);
	КонецЦикла; 
			
	// Удалим дубли
	ПоляГруппировки = "";
	Для каждого Колонка Из Таблица.Колонки Цикл
		ПоляГруппировки = "," + Колонка.Имя + ПоляГруппировки;
	КонецЦикла; 
	
	ПоляГруппировки = Сред(ПоляГруппировки, 2);
	Таблица.Свернуть(ПоляГруппировки);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий
 
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
		
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	Если ТипДанныхЗаполнения = Тип("Структура") Тогда
		бит_ОбщегоНазначения.ЗаполнитьПоСтруктуре(ЭтотОбъект, ДанныеЗаполнения);
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
		ЗаполнитьПоОснованию(ДанныеЗаполнения);		
	КонецЕсли;
	
	ИнициализироватьДокумент();
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	ОтправленНаСогласование = Ложь;
	СверхБюджета 			= Ложь;
	СписатьЛимиты 			= Ложь;
	Ответственный 			= Пользователи.ТекущийПользователь();
	Дата					= ТекущаяДатаСеанса();
	ДокументОснование		= Неопределено;
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли; 
	
	Если НЕ СверхБюджета Тогда
		СписатьЛимиты = Ложь;	
	КонецЕсли;
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	
	бит_ОбщегоНазначенияПереопределяемый.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	ДополнительныеСвойства.Вставить("УстановкаПометкиУдаления", ПометкаУдаления <> Ссылка.ПометкаУдаления);

	ЭтоОперацияБезВалютыВзаиморасчетов = бит_КазначействоКлиентСервер.ЭтоОперацияБезВалютыВзаиморасчетов(ХозяйственнаяОперация);
	Если ЭтоОперацияБезВалютыВзаиморасчетов Тогда
		ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа;	
	КонецЕсли;	
	
	Если НЕ ДополнительныеСвойства.УстановкаПометкиУдаления И НЕ ДополнительныеСвойства.ЭтоНовый Тогда
		Если ПолучитьФункциональнуюОпцию("бит_ЗапретитьИзменениеЗаявкиВключеннойВРеестр") Тогда
			ЗаявкаВключенаВРеестр = бит_Казначейство.ЗаявкаВключенаВРеестр(Ссылка);
		Иначе
			ЗаявкаВключенаВРеестр = Ложь;
		КонецЕсли;

		Если ЗаявкаВключенаВРеестр Тогда
			ТекстСообщения = НСтр("ru = 'Не удалось записать %1. Документ включен в реестр платежей.';
								|en = 'Failed to write to %1. The document is included in the payment register.'") ;
			ТекстСообщения = СтрШаблон(ТекстСообщения, Ссылка);
			ВызватьИсключение ТекстСообщения;		
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли; 
	
	РежимЗаписи = ДополнительныеСвойства.РежимЗаписи;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение 
		ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		ПроверитьПравоПроведения(Отказ);
	КонецЕсли; 
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
	
	ВыполнитьСинхронизацию(Отказ);
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	ПроверитьПравоПроведения(Отказ);
	
	ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(Ссылка);
	бит_Казначейство.ПроверитьВозможностьПроведения(Ссылка, ТекущийСтатус, Отказ);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументОснование)
		И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
		
		ДокПрогноз = ДокументОснование.ПолучитьОбъект();
		бит_ВизированиеСервер.УстановитьСтатус(ДокПрогноз);
		
	КонецЕсли; 
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ПроверитьПравоПроведения(Отказ);
	
	ТекущийСтатус = бит_ВизированиеСервер.ТекущийСтатус(Ссылка);
	бит_Казначейство.ПроверитьВозможностьПроведения(Ссылка, ТекущийСтатус, Отказ);

	Если ЗначениеЗаполнено(ДокументОснование)
		И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
	
		ДокПрогноз = ДокументОснование.ПолучитьОбъект();
		бит_ВизированиеСервер.УстановитьСтатус(ДокПрогноз);
		
	КонецЕсли; 
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	НепроверяемыеРеквизиты = Новый Массив;
	
	Если НЕ ПлатежиПо275ФЗ Тогда
		НепроверяемыеРеквизиты.Добавить("ТипПлатежаФЗ275");
		НепроверяемыеРеквизиты.Добавить("ДоговорСЗаказчиком");
		НепроверяемыеРеквизиты.Добавить("ДоговорСУчастникомГОЗ");
		НепроверяемыеРеквизиты.Добавить("ПредметОплаты");
		НепроверяемыеРеквизиты.Добавить("ПодтверждающиеДокументы");
	КонецЕсли;
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	
	бит_НастройкиДоступностиЭлементовФорм.ЗаполнитьПроверяемыеРеквизиты(ЭтотОбъект, ПроверяемыеРеквизиты);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Процедура выполняет заполнение документа по основанию. 
//
// Параметры:
//  Основание - ДокументСсылка, ДокументОбъект.
//
Процедура ЗаполнитьПоОснованию(Основание) Экспорт

	МетаОснование = Основание.Метаданные();
	
	Если Основание.Метаданные() = Метаданные.Документы.бит_кзн_ЗаявкаНаРасходованиеСредств Тогда
		
		 Исключения = "Дата,Номер,Проведен,ПометкаУдаления,ДокументОснование,ВидПлана";
		 ЗаполнитьЗначенияСвойств(ЭтотОбъект, Основание,,Исключения);
		 ДокументОснование = Основание.Ссылка;
	
	КонецЕсли; 

КонецПроцедуры // ЗаполнитьПоОснованию()

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ИнициализацияИЗаполнение

Процедура ИнициализироватьДокумент()
	
	Если НЕ ЗначениеЗаполнено(Дата) Тогда
		Дата = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ХозяйственнаяОперация) Тогда
		ХозяйственнаяОперация = Перечисления.бит_ВидыОперацийКазначейства.ОплатаПоставщику;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ФормаОплаты) Тогда
		ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВидПлана) Тогда
		ВидПлана = Перечисления.бит_кзн_ВидыПланов.План;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		Организация = ЗначениеНастроекПовтИсп.ПолучитьОрганизациюПоУмолчанию(Организация);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Сценарий) Тогда
		Сценарий = ЗаполнитьСценарий();
	КонецЕсли;
				
	Ответственный = Пользователи.ТекущийПользователь();
	
	Инициатор = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
					ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнойИнициаторКазначейства);
	
	Если НЕ ЗначениеЗаполнено(Инициатор) Тогда
		Инициатор = Ответственный;
	КонецЕсли;
			
КонецПроцедуры	

Функция ЗаполнитьСценарий() 

	Перем СценарийКандидат;
	
	Отборы = Новый Структура;
	Отборы.Вставить("Организация", Организация);
	
	Период = ?(ЗначениеЗаполнено(Дата), Дата, НачалоДня(ТекущаяДатаСеанса()));
	
	// Сценарий из настроек пользователя.
	СценарийКандидат = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
							ПланыВидовХарактеристик.бит_НастройкиПользователей.ОсновнойСценарий);
		
	Если НЕ ЗначениеЗаполнено(СценарийКандидат) Тогда
		КонтролироватьЗаявку = бит_НастройкиПрограммы.КонтролироватьЗаявкуПоБюджету(Отборы, Период);
		Если КонтролироватьЗаявку Тогда
			Если НЕ ЗначениеЗаполнено(СценарийКандидат) Тогда
				// Сценарий из настроек программы.
				СценарийКандидат = бит_НастройкиПрограммы.КазначействоСценарийКонтроляПоБюджету(Отборы, Период);
			КонецЕсли; 
		КонецЕсли;
	КонецЕсли;
												
	Если НЕ ЗначениеЗаполнено(СценарийКандидат) И ЗначениеЗаполнено(Сценарий) Тогда
		СценарийКандидат = Сценарий;
	КонецЕсли;
								
	Возврат СценарийКандидат;
	
КонецФункции
	
#КонецОбласти

Процедура ДобавитьСтрокуВНаборЗначенийДоступа(ЗначениеДоступа, Таблица)
	
	СтрокаТаб = Таблица.Добавить();
	СтрокаТаб.ЗначениеДоступа = ЗначениеДоступа;

КонецПроцедуры

Процедура ВыполнитьСинхронизацию(Отказ)

	МассивСтрокПревышения = Новый Массив;

	Синхронизировать = Истина;
	Если ДополнительныеСвойства.Свойство("НеСинхронизировать") 
		 И ДополнительныеСвойства.НеСинхронизировать = Истина Тогда
	     Возврат;
	КонецЕсли; 	
	
	// Синхронизируем реквизиты заявки и позиций.
	БезПомеченныхНаУдаление = Истина;
	Если ДополнительныеСвойства.УстановкаПометкиУдаления Тогда
		БезПомеченныхНаУдаление = Ложь;	
	ИначеЕсли ПометкаУдаления Тогда	
		БезПомеченныхНаУдаление = Ложь;
	КонецЕсли;
	
	РезультатПоиска = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(Ссылка, БезПомеченныхНаУдаление);
	
	ИменаРеквизитов       = Документы.бит_кзн_ПлатежнаяПозиция.СинхронизируемыеРеквизиты();
	НастройкиДопИзмерений = бит_МеханизмДопИзмерений.ПолучитьНастройкиДополнительныхИзмерений();
	СовпадающиеАналитики  = Документы.бит_кзн_ПлатежнаяПозиция.НайтиАналитикиСовпадающиеСРеквизитами(
								Метаданные.Документы.бит_кзн_ПлатежнаяПозиция);
	
	// Если заявка списком, тогда у каждой позиции остается свой комментарий.
	Если РезультатПоиска.МассивПозиций.Количество() > 1 Тогда
		Индекс = ИменаРеквизитов.Найти("Комментарий");
		Если Индекс <> Неопределено Тогда
			ИменаРеквизитов.Удалить(Индекс);			
		КонецЕсли;
	КонецЕсли;
	
	ДанныеКорректировки = Новый ТаблицаЗначений;
	АдресВХранилище		= ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
									ДополнительныеСвойства, "АдресДанныхДляКорректировки", "");
									
	ИнтерактивноеПроведение = ЭтоАдресВременногоХранилища(АдресВХранилище);
	
	РеквизитыПозицийДоИзменения = Документы.бит_кзн_ПлатежнаяПозиция.РеквизитыДокумента(РезультатПоиска.МассивПозиций);
	
	Для каждого Позиция Из РезультатПоиска.МассивПозиций Цикл
		
		РеквизитыДоИзменения = РеквизитыПозицийДоИзменения.Найти(Позиция, "Ссылка");
		
		ПозицияОбъект = Позиция.ПолучитьОбъект();
		ЛокальныйАдресВХранилище = "";
		
		// Признак того, что дальнейшая синхронизация не нужна, необходимо, чтобы не было циклических синхронизаций.
		ПозицияОбъект.ДополнительныеСвойства.Вставить("НеСинхронизировать", Истина);
		Если ИнтерактивноеПроведение Тогда
			ЛокальныйАдресВХранилище = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор());
			ПозицияОбъект.ДополнительныеСвойства.Вставить("АдресДанныхДляКорректировки", ЛокальныйАдресВХранилище);
		КонецЕсли;
		
		// Синхронизация пометки удаления.
		Если ПометкаУдаления <> ПозицияОбъект.ПометкаУдаления Тогда
			ПозицияОбъект.УстановитьПометкуУдаления(ПометкаУдаления);
		КонецЕсли; 
		
		ТекущаяВалютаДокумента 		= РеквизитыДоИзменения.ВалютаДокумента;
		ТекущаяВалютаВзаиморасчетов = РеквизитыДоИзменения.ВалютаВзаиморасчетов;
		ТекущееПланированиеСуммы	= РеквизитыДоИзменения.ПланированиеСуммы;
		
		// Синхронизация реквизитов
		Для каждого Имя Из ИменаРеквизитов Цикл
			Если Имя = "ПодтверждающиеДокументы" Тогда
				ПозицияОбъект.ПодтверждающиеДокументы.Загрузить(ПодтверждающиеДокументы.Выгрузить());
			Иначе
				Если ЭтотОбъект[Имя] <> ПозицияОбъект[Имя] Тогда
					
					Если (Врег(Имя) = ВРег("НазначениеПлатежаУпр") ИЛИ Врег(Имя) = ВРег("НазначениеПлатежа"))
						И ЗначениеЗаполнено(ПозицияОбъект[Имя]) Тогда
						Продолжить;
					КонецЕсли;
					
					ПозицияОбъект[Имя] = ЭтотОбъект[Имя];			
					
					Если Врег(Имя) = ВРег("Организация") Тогда
						ПозицияОбъект.БанковскийСчет = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
						ПозицияОбъект.Касса 				  = Справочники.Кассы.ПустаяСсылка();
						ПозицияОбъект.Подразделение 		  = Неопределено;
						ПозицияОбъект.ДоговорЗаймаСотруднику  = Неопределено;
						ПозицияОбъект.ОбъектРасчетов		  = Неопределено;
						ПозицияОбъект.ДоговорКредитаДепозита = Неопределено;
						ПозицияОбъект.ДоговорАренды		  = Неопределено;
						ПозицияОбъект.Договор 				  = Неопределено;
					ИначеЕсли Врег(Имя) = ВРег("Контрагент") Тогда
						ПозицияОбъект.БанковскийСчетПолучателя = Справочники.БанковскиеСчетаКонтрагентов.ПустаяСсылка();
						ПозицияОбъект.ОбъектРасчетов 		   = Неопределено;
						ПозицияОбъект.ДоговорКредитаДепозита  = Неопределено;
						ПозицияОбъект.ДоговорАренды 		   = Неопределено;
						ПозицияОбъект.Договор 				   = Неопределено;
					КонецЕсли; 
					
					// Сихронизируем совпадающие аналитики.
					Для каждого Соотв Из СовпадающиеАналитики Цикл
						Если Соотв.Значение = Имя Тогда
							ТекущаяНастройка = НастройкиДопИзмерений[Соотв.Ключ];
							Если ТекущаяНастройка <> Неопределено И ЗначениеЗаполнено(ПозицияОбъект[Соотв.Ключ])
								И НЕ ТекущаяНастройка.Предопределенная Тогда
								Продолжить;
							КонецЕсли;
							ПозицияОбъект[Соотв.Ключ] = ЭтотОбъект[Имя];
						КонецЕсли; 
					КонецЦикла; 
				КонецЕсли; 
			КонецЕсли;
		КонецЦикла;
				
		Если ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеВзаиморасчетов Тогда			
			ПозицияОбъект.ВалютаВзаиморасчетов 			 = ВалютаДокумента;
			ПозицияОбъект.ВалютаДокумента	   			 = ВалютаДокумента; 
			ПозицияОбъект.КурсЧислительВзаиморасчетов 	 = 1;
			ПозицияОбъект.КурсЗнаменательВзаиморасчетов  = 1;
			ПозицияОбъект.СуммаДокумента 				 = ПозицияОбъект.СуммаВзаиморасчетов;
		КонецЕсли;
		
		ПоменялосьПланированиеСуммы = ТекущееПланированиеСуммы <> ПозицияОбъект.ПланированиеСуммы;
		
		Если ТекущаяВалютаДокумента <> ПозицияОбъект.ВалютаДокумента 
			И ПозицияОбъект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
			
			ПозицияОбъект.БанковскийСчет = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
			ПозицияОбъект.Касса 		 = Справочники.Кассы.ПустаяСсылка();
		КонецЕсли;

		Если ТекущаяВалютаВзаиморасчетов <> ПозицияОбъект.ВалютаВзаиморасчетов Тогда
			ПозицияОбъект.ОбъектРасчетов		 = Неопределено;
			ПозицияОбъект.ДоговорКредитаДепозита = Неопределено;
			ПозицияОбъект.ДоговорАренды		  	 = Неопределено;
			ПозицияОбъект.Договор 				 = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
		КонецЕсли;
		
		// Перезаполним доп. аналитики по данным документа.
		ИменаРеквизитовДляСравнения = Новый Массив;
		ИменаРеквизитовДляСравнения.Добавить("БанковскийСчет");
		ИменаРеквизитовДляСравнения.Добавить("Касса");
		ИменаРеквизитовДляСравнения.Добавить("БанковскийСчетПолучателя");
		ИменаРеквизитовДляСравнения.Добавить("СтатьяОборотов");
		ИменаРеквизитовДляСравнения.Добавить("ЦФО");
		ИменаРеквизитовДляСравнения.Добавить("Договор");
		ИменаРеквизитовДляСравнения.Добавить("Контрагент");
		ИменаРеквизитовДляСравнения.Добавить("ОбъектРасчетов");
		ИменаРеквизитовДляСравнения.Добавить("ФизЛицо");
		Для каждого Элемент Из ИменаРеквизитовДляСравнения Цикл
			Если РеквизитыДоИзменения[Элемент] <> ПозицияОбъект[Элемент] Тогда
				
				ПараметрыУстановки = бит_МеханизмДопИзмеренийКлиентСервер.ПараметрыУстановкиСвойствАналитикПоШаблону(
								"Аналитика_", "Аналитика_", "СтатьяОборотов");				
				ПараметрыУстановки.ДопРеквизиты.Вставить("Организация",ПозицияОбъект.Организация);
	
				бит_МеханизмДопИзмерений.ЗаполнитьДопАналитикуПоДаннымДокумента(ПозицияОбъект, 
					ПозицияОбъект[Элемент], ПараметрыУстановки);
			КонецЕсли;
		КонецЦикла;			
	
		Если Проведен И НЕ ПозицияОбъект.Проведен Тогда	
			Если ПозицияОбъект.ПроверитьЗаполнение() Тогда
				Выполнено = бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ПозицияОбъект, РежимЗаписиДокумента.Проведение, "", "Ошибки");
				Если НЕ Выполнено Тогда
					Отказ = Истина;
				КонецЕсли;
			Иначе
				ВызватьИсключение СтрШаблон(НСтр("ru = 'Не удалось записать %1. Документ заполнен с ошибками.'"), Позиция);
			КонецЕсли;
			Если ИнтерактивноеПроведение Тогда
				ПараметрыУстановки = ПолучитьИзВременногоХранилища(ЛокальныйАдресВХранилище);
				Если ТипЗнч(ПараметрыУстановки) = Тип("Структура") Тогда
					ЕстьДанныеКорректировки = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыУстановки, 
												"ЕстьДанныеКорректировки", Ложь);
					Если ЕстьДанныеКорректировки Тогда
						ЛокальныеДанныеКорректировки = ПолучитьИзВременногоХранилища(ПараметрыУстановки.АдресКорректировки);
						Если ДанныеКорректировки.Колонки.Количество() = 0 Тогда
							ДанныеКорректировки = ЛокальныеДанныеКорректировки.Скопировать();
						Иначе	
							ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ЛокальныеДанныеКорректировки, ДанныеКорректировки);
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли НЕ Проведен И ПозицияОбъект.Проведен Тогда 
			бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ПозицияОбъект, РежимЗаписиДокумента.ОтменаПроведения, "", "Ошибки");
		Иначе
			ПозицияОбъект.Записать(РежимЗаписиДокумента.Запись);			
		КонецЕсли;
		Если Отказ Тогда
			Прервать;		
		КонецЕсли;
	КонецЦикла; 
	
	Если ИнтерактивноеПроведение  Тогда
		ПараметрыУстановки = Новый Структура; 
		ПараметрыУстановки.Вставить("ЕстьДанныеКорректировки", ДанныеКорректировки.Количество() > 0);
		ПараметрыУстановки.Вставить("АдресКорректировки", ПоместитьВоВременноеХранилище(ДанныеКорректировки, 
			Новый УникальныйИдентификатор()));
		ПоместитьВоВременноеХранилище(ПараметрыУстановки, АдресВХранилище);
	КонецЕсли; 
	
КонецПроцедуры

// Процедура проверяет наличие у пользователя права проводить заявки
//
// Параметры:
//  Отказ - Булево.
//
Процедура ПроверитьПравоПроведения(Отказ)
	
	ТекущийПользователь = Пользователи.ТекущийПользователь();
	МожноПроводить 		= бит_ПраваДоступа.ПолучитьЗначениеДопПраваПользователя(ТекущийПользователь, 
							ПланыВидовХарактеристик.бит_ДополнительныеПраваПользователей.РазрешеноПроводитьЗаявкиНаРасходованиеДС);
	
	Если НЕ МожноПроводить Тогда		
		ТекстСообщения = НСтр("ru='У пользователя отсутствует дополнительное право на проведение заявок.';
							  |en='The user has no additional right to host applications.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
	КонецЕсли; 
	
КонецПроцедуры

Процедура ЗачестьЧастичнуюОплатуВГрафике(ГрафикОплаты, Знач СуммаОтклонения)
	
	Для каждого СтрокаОплаты Из ГрафикОплаты Цикл
		СуммаПлатежа = СтрокаОплаты.СуммаПлатежа;
		СуммаЗачета  = Мин(СтрокаОплаты.СуммаПлатежа, СуммаОтклонения);
		
		СтрокаОплаты.СуммаПлатежа = СуммаПлатежа - СуммаЗачета;
		
		СуммаОтклонения = СуммаОтклонения - СуммаЗачета;
		Если СуммаОтклонения = 0 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

