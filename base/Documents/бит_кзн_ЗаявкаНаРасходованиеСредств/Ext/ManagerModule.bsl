// Функция определяет новый статус объекта в зависимости от режима записи документа
//и предыдущего статуса. Механизм определения статусов может быть переопределен алгоритмами.
//
// Параметры:
//  ТекущийОбъект - ДокументОбъект.бит_кзн_ЗаявкаНаРасходованиеСредств.
//  ПараметрыУстановкиСтатуса - Структура - состав полей см. в функции бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса.
//
// Возвращаемое значение:
//   НовыйСтатус - СправочникСсылка.бит_СтатусыОбъектов.
//
Функция НовыйСтатусОбъекта(ТекущийОбъект, ПараметрыУстановкиСтатуса) Экспорт
	
	Если ПараметрыУстановкиСтатуса.ПараметрыОплаты = Неопределено Тогда
		СтруктураОплаты = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.ПолучитьОстаток(ТекущийОбъект.Ссылка);
	Иначе	
		СтруктураОплаты = ПараметрыУстановкиСтатуса.ПараметрыОплаты;
	КонецЕсли;
	
	Если СтруктураОплаты.Остаток <= 0.01 И СтруктураОплаты.Факт > 0 Тогда
		Возврат Справочники.бит_СтатусыОбъектов.Оплачен;
	ИначеЕсли СтруктураОплаты.Факт > 0 Тогда
		Возврат Справочники.бит_СтатусыОбъектов.ЧастичноОплачен;
	КонецЕсли;
		
	НовыйСтатус = бит_ВизированиеСервер.НовыйСтатусПоСтандартномуАлгоритму(ТекущийОбъект, ПараметрыУстановкиСтатуса);
	Если Справочники.бит_СтатусыОбъектов.ПроверитьТипСтатуса(НовыйСтатус,
			Перечисления.бит_ТипыСтатусовОбъектов.Утвержден)
			И РегистрыСведений.бит_РеестрыПлатежей.ЗаявкаВключенаВРеестр(ТекущийОбъект.Ссылка) Тогда
		НовыйСтатус = Справочники.бит_СтатусыОбъектов.Заявка_ВРеестре;
	КонецЕсли;
	
	Возврат НовыйСтатус;
	
КонецФункции

#КонецОбласти

