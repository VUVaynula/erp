#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// СтандартныеПодсистемы.ВерсионированиеОбъектов
// Определяет настройки объекта для подсистемы ВерсионированиеОбъектов.
//
// Параметры:
// Настройки - Структура - настройки подсистемы.
Процедура ПриОпределенииНастроекВерсионированияОбъектов(Настройки) Экспорт
	
КонецПроцедуры
// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

// СтандартныеПодсистемы.ВариантыОтчетов
// Определяет список команд отчетов.
//
// Параметры:
//   КомандыОтчетов - ТаблицаЗначений - Таблица с командами отчетов. Для изменения.
//       См. описание 1 параметра процедуры ВариантыОтчетовПереопределяемый.ПередДобавлениемКомандОтчетов().
//   Параметры - Структура - Вспомогательные параметры. Для чтения.
//       См. описание 2 параметра процедуры ВариантыОтчетовПереопределяемый.ПередДобавлениемКомандОтчетов().
//
Процедура ДобавитьКомандыОтчетов(КомандыОтчетов, Параметры) Экспорт
	
	ИнтеграцияИСПереопределяемый.ДобавитьКомандуСтруктураПодчиненности(КомандыОтчетов);
		
	Если ПравоДоступа("Просмотр", Метаданные.Отчеты.бит_ПлатежныеДокументы) Тогда
        Команда = КомандыОтчетов.Добавить();
        Команда.Представление      = НСтр("ru = 'Документы оплаты'");
        Команда.МножественныйВыбор = Истина;
        Команда.ИмяПараметраФормы  = "Отбор.ДокументПланирования";
        Команда.КлючВарианта       = "ПлатежныеДокументы";
        Команда.Менеджер           = "Отчет.бит_ПлатежныеДокументы";
		
		ПодключаемыеКоманды.ДобавитьУсловиеВидимостиКоманды(Команда, "ВидПлана", Перечисления.бит_кзн_ВидыПланов.План);
	КонецЕсли;

	Если ПравоДоступа("Просмотр", Метаданные.Отчеты.бит_ЗаявкиВключенныеВРеестрПлатежей) Тогда
        Команда = КомандыОтчетов.Добавить();
        Команда.Представление      = НСтр("ru = 'Заявки в реестре платежей'");
        Команда.МножественныйВыбор = Истина;
        Команда.ИмяПараметраФормы  = "Отбор.ЗаявкаНаРасходованиеДС";
        Команда.КлючВарианта       = "ЗаявкиВключенныеВРеестрПлатежей";
        Команда.Менеджер           = "Отчет.бит_ЗаявкиВключенныеВРеестрПлатежей";
		
		ПодключаемыеКоманды.ДобавитьУсловиеВидимостиКоманды(Команда, "ВидПлана", Перечисления.бит_кзн_ВидыПланов.План);
	КонецЕсли;
	
КонецПроцедуры
// Конец СтандартныеПодсистемы.ВариантыОтчетов

// СтандартныеПодсистемы.Печать

// Переопределяет настройки печати для объекта.
//
// Параметры:
//  Настройки - см. УправлениеПечатью.НастройкиПечатиОбъекта.
//
Процедура ПриОпределенииНастроекПечати(Настройки) Экспорт
	
	Настройки.ПриДобавленииКомандПечати = Истина;
		
КонецПроцедуры

// Заполняет список команд печати.
//
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	// Заявка на оплату.
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.Идентификатор = "ПечатьЗаявкаНаОплату";
	КомандаПечати.Представление = НСтр("ru='Заявка на оплату';en='Request for Payment'");
	Если НЕ бит_ОбщегоНазначения.ЭтоУТ() Тогда
		КомандаПечати.Обработчик = "УправлениеПечатьюБПКлиент.ВыполнитьКомандуПечати";
	КонецЕсли;
	КомандаПечати.Порядок       = 10;
	
КонецПроцедуры

// Формирует печатные формы.
//
// Параметры:
//  МассивОбъектов  - Массив    - ссылки на объекты, которые нужно распечатать;
//  ПараметрыПечати - Структура - дополнительные настройки печати;
//  КоллекцияПечатныхФорм - ТаблицаЗначений - сформированные табличные документы (выходной параметр)
//  ОбъектыПечати         - СписокЗначений  - значение - ссылка на объект;
//                                            представление - имя области в которой был выведен объект (выходной параметр);
//  ПараметрыВывода       - Структура       - дополнительные параметры сформированных табличных документов (выходной параметр).
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПечатьЗаявкаНаОплату") Тогда
		// Формируем табличный документ и добавляем его в коллекцию печатных форм.
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,
			"ПечатьЗаявкаНаОплату",
			"Заявка на оплату",
			СформироватьПечатнуюФормуЗаявкиНаОплату(МассивОбъектов));
	КонецЕсли;
	
	ОбщегоНазначенияБП.ЗаполнитьДополнительныеПараметрыПечати(МассивОбъектов, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода);	
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.Печать

#Область ОбновлениеИнформационнойБазы

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьКОбработкеДокументыБезПланированияСуммы(Параметры) Экспорт

	ПараметрыВыборки = Параметры.ПараметрыВыборки;
	ПараметрыВыборки.ПолныеИменаОбъектов = ПустаяСсылка().Метаданные().ПолноеИмя();
	ПараметрыВыборки.ПоляУпорядочиванияПриРаботеПользователей.Добавить("Дата УБЫВ");
	ПараметрыВыборки.ПоляУпорядочиванияПриОбработкеДанных.Добавить("Дата УБЫВ");
	ПараметрыВыборки.СпособВыборки = ОбновлениеИнформационнойБазы.СпособВыборкиСсылки();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка,
	|	Реквизиты.Дата КАК Дата
	|ИЗ
	|	Документ.бит_кзн_ЗаявкаНаРасходованиеСредств КАК Реквизиты
	|ГДЕ
	|	Реквизиты.ПланированиеСуммы = ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ПустаяСсылка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ";
	
	ОбновлениеИнформационнойБазы.ОтметитьКОбработке(Параметры, Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));	

КонецПроцедуры

// Обработчик обновления.
// 
// Параметры:
//  Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ОбработатьДокументыБезПланированияСуммыОтложенно(Параметры) Экспорт
		
	МетаданныеОбъекта = ПустаяСсылка().Метаданные();
	ПолноеИмяОбъекта  = МетаданныеОбъекта.ПолноеИмя();
	ОбновляемыеДанные = ОбновлениеИнформационнойБазы.ДанныеДляОбновленияВМногопоточномОбработчике(Параметры);
	
	Если НЕ ЗначениеЗаполнено(ОбновляемыеДанные) Тогда
		Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
											Параметры.Очередь, ПолноеИмяОбъекта);
		Возврат;
	КонецЕсли;
	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылки", ОбновляемыеДанные.ВыгрузитьКолонку("Ссылка"));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	МАКСИМУМ(ПлатежныеПозиции.Ссылка) КАК Позиция,
	|	ПлатежныеПозиции.ДокументПланирования КАК ДокументПланирования
	|ПОМЕСТИТЬ ВТ_ПлатежныеПозиции
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|ГДЕ
	|	ПлатежныеПозиции.ДокументПланирования В(&Ссылки)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПлатежныеПозиции.ДокументПланирования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаявкиНаРасходованиеСредств.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(ВТ_ПлатежныеПозиции.Позиция.ПланированиеСуммы, ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа)) КАК ПланированиеСуммы
	|ИЗ
	|	Документ.бит_кзн_ЗаявкаНаРасходованиеСредств КАК ЗаявкиНаРасходованиеСредств
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПлатежныеПозиции КАК ВТ_ПлатежныеПозиции
	|		ПО ЗаявкиНаРасходованиеСредств.Ссылка = ВТ_ПлатежныеПозиции.ДокументПланирования
	|ГДЕ
	|	ЗаявкиНаРасходованиеСредств.Ссылка В(&Ссылки)
	|	И ЕСТЬNULL(ВТ_ПлатежныеПозиции.Позиция.ПланированиеСуммы, ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа)) <> ЗНАЧЕНИЕ(Перечисление.СпособыПланированияОплатыЗаявок.ПустаяСсылка)";
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка 		 = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		
		Попытка
			
			Блокировка = Новый БлокировкаДанных;
			
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
			Блокировка.Заблокировать();
			
			ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ДокументОбъект.ПланированиеСуммы = Выборка.ПланированиеСуммы;
			
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
			ОбновлениеИнформационнойБазы.ОтметитьВыполнениеОбработки(Выборка.Ссылка);
			
			ОбъектовОбработано = ОбъектовОбработано + 1;
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			бит_ОбновлениеИнформационнойБазыБФ.СообщитьОНеудачнойОбработке(ИнформацияОбОшибке(), Выборка.Ссылка);
		КонецПопытки;		
	КонецЦикла;
	
	Если ОбъектовОбработано = 0 И ПроблемныхОбъектов <> 0 Тогда
		ШаблонСообщения = НСтр("ru = 'Не удалось обработать некоторые документы ""Заявка на расходование денежных средств (БИТ)"" (пропущены): %1'; 
								|en = 'Some documents ""Application for payment"" could not be processed (skipped): %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ПроблемныхОбъектов);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация, МетаданныеОбъекта,, ТекстСообщения);
	Иначе
		ШаблонСообщения = НСтр("ru = 'Обработана очередная порция документов ""Заявка на расходование денежных средств (БИТ)"": %1';
								|en = 'The next batch of documents ""Application for payment"" has been processed: %1'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, ОбъектовОбработано);
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация,
			МетаданныеОбъекта,, ТекстСообщения);
	КонецЕсли;
	
	Параметры.ОбработкаЗавершена = ОбновлениеИнформационнойБазы.ОбработкаДанныхЗавершена(
		Параметры.Очередь, ПолноеИмяОбъекта);

КонецПроцедуры

// Параметры:
// 	Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ЗарегистрироватьКОтражениюВДанныеДокументовКазначейства(Параметры) Экспорт

	РегистрыСведений.бит_ДанныеДокументовКазначейства.ЗарегистрироватьКОтражениюВДанныеДокументовКазначейства(Параметры, 
		Документы.бит_кзн_ЗаявкаНаРасходованиеСредств);
	
КонецПроцедуры

// Обработчик обновления.
// 
// Параметры:
//  Параметры - см. ОбновлениеИнформационнойБазы.ОсновныеПараметрыОтметкиКОбработке
//
Процедура ОбработатьОтражениеВДанныеДокументовКазначейства(Параметры) Экспорт

	РегистрыСведений.бит_ДанныеДокументовКазначейства.ОбработатьОтражениеВДанныеДокументовКазначейства(Параметры, 
		Документы.бит_кзн_ЗаявкаНаРасходованиеСредств);	

КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		
		Режим = "";
		Параметры.Свойство("Режим", Режим);
		
		Если НЕ Режим = "ОткрытиеСпискаПозиций" И Параметры.Свойство("Ключ") Тогда
			// Форма открывается по ссылке.
			РезультатПоиска = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(Параметры.Ключ);
			Позиция		    = РезультатПоиска.Позиция;
			Если РезультатПоиска.КоличествоПозиций = 1 Тогда
				Параметры.Ключ = Позиция;
				ВыбраннаяФорма = Метаданные.Документы.бит_кзн_ПлатежнаяПозиция.ОсновнаяФормаОбъекта;
				СтандартнаяОбработка = Ложь;
			КонецЕсли; 
		КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры	

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	
	Поля.Добавить("Номер");
	Поля.Добавить("Дата");
	Поля.Добавить("ВидПлана");
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	Если Данные.ВидПлана = Перечисления.бит_кзн_ВидыПланов.Прогноз Тогда
	
		 СтандартнаяОбработка = Ложь;
		 Представление = НСтр("ru='Прогноз платежа %1 от %2';en='Prediction payment %1 from %2'");
		 Представление = СтрШаблон(Представление, Данные.Номер, Формат(Данные.Дата,"ДЛФ=DT"));
	
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти 

#Область СлужебныйПрограммныйИнтерфейс

#Область ВводНаОсновании

Функция ДокументПоДаннымЗаполнения(Основание) Экспорт

	ДанныеЗаполнения	 = Документы.бит_кзн_ПлатежнаяПозиция.ДанныеЗаполненияИзОснования(Основание);	
	ДокументПланирования = ДокументПоДаннымПлатежныхПозиций(ДанныеЗаполнения);
	Возврат ДокументПланирования;
	
КонецФункции

Функция ДокументПоДаннымПлатежныхПозиций(ДанныеЗаполнения) Экспорт
		
	Попытка
		НачатьТранзакцию();
		ДокументПланирования = Неопределено;
		Для каждого Элемент Из ДанныеЗаполнения Цикл			
			ПозицияОбъект = Документы.бит_кзн_ПлатежнаяПозиция.СоздатьДокумент();
			ПозицияОбъект.Заполнить(Элемент);
			ПозицияОбъект.ДокументПланирования = ДокументПланирования;
			ПозицияОбъект.Записать(РежимЗаписиДокумента.Запись);
			Если ДокументПланирования = Неопределено Тогда
				ДокументПланирования = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПозицияОбъект.Ссылка, "ДокументПланирования");
			КонецЕсли;
		КонецЦикла;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат ДокументПланирования;

КонецФункции

// Подключаемый, см. бит_КазначействоВызовСервера.ПараметрыФормыВводНаОсновании().
//
Функция ПараметрыФормыВводНаОсновании(Основание) Экспорт

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ИмяФормы", "Документ.бит_кзн_ЗаявкаНаРасходованиеСредств.ФормаОбъекта");
	ПараметрыФормы.Вставить("ПараметрыФормы", Новый Структура);
	ПараметрыФормы.Вставить("Отказ", Ложь);
	
	ДанныеЗаполнения = Документы.бит_кзн_ПлатежнаяПозиция.ДанныеЗаполненияИзОснования(Основание);
	Если ДанныеЗаполнения.Количество() = 0 Тогда 
		ТекстСообщения = НСтр("ru = 'Не требуется вводить заявку на расходование денежных средств на основании документа %1.';
								|en = 'You do not need to enter an application for spending money based on the document %1.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, Основание);
		ВызватьИсключение ТекстСообщения;
	ИначеЕсли ДанныеЗаполнения.Количество() = 1 Тогда
		// Ввод однострочной заявки.
		// Открываем новую Заявку. 
		ПараметрыФормы.ИмяФормы 	  = "Документ.бит_кзн_ПлатежнаяПозиция.ФормаОбъекта";
		ПараметрыФормы.ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ДанныеЗаполнения[0]);
	Иначе
		// Записываем Позиции поступления, связывая с одной заявкой.
		// Открываем Заявку.
		ДокументПланирования = ДокументПоДаннымПлатежныхПозиций(ДанныеЗаполнения);
		ПараметрыФормы.ИмяФормы		  = "Документ.бит_кзн_ЗаявкаНаРасходованиеСредств.ФормаОбъекта";
		ПараметрыФормы.ПараметрыФормы = Новый Структура("Ключ", ДокументПланирования);
	КонецЕсли;
	
	Возврат ПараметрыФормы;

КонецФункции

// Добавляет команду создания документа "Заявка на расходование денежных средств (БИТ)".
//
// Параметры:
//   КомандыСозданияНаОсновании - ТаблицаЗначений - Таблица с командами создания на основании. Для изменения.
//       См. описание 1 параметра процедуры СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании().
//
Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании) Экспорт
	
	Если ПравоДоступа("Добавление", Метаданные.Документы.бит_кзн_ПлатежнаяПозиция) Тогда
		КомандаСоздатьНаОсновании = КомандыСозданияНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Обработчик = "бит_КазначействоКлиент.СоздатьЗаявкуНаРасходованиеСредств";
		КомандаСоздатьНаОсновании.Идентификатор = "СоздатьЗаявкуНаРасходованиеСредств";
		КомандаСоздатьНаОсновании.Представление = ОбщегоНазначенияУТ.ПредставлениеОбъекта(
													Метаданные.Документы.бит_кзн_ЗаявкаНаРасходованиеСредств);
		КомандаСоздатьНаОсновании.РежимЗаписи = "Проводить";		
		Возврат КомандаСоздатьНаОсновании;		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

#КонецОбласти

// Функция формирует печатную форму заявки на оплату.
//
// Параметры:
//  МассивСсылок - Массив.
//
// Возвращаемое значение:
//  ТабличныйДокумент - ТабличныйДокумент.
// 
Функция СформироватьПечатнуюФормуЗаявкиНаОплату(МассивСсылок) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_бит_кзн_ЗаявкаНаРасходованиеСредств_ЗаявкаНаОплату";
	
	Для каждого ДокументПланирования Из МассивСсылок Цикл
		
		СтруктураДокумента = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(ДокументПланирования);
		
		Если СтруктураДокумента.КоличествоПозиций > 1 Тогда
		
			// Формируем запрос по заявкам.
			РезультатЗапроса = ПолучитьРезультатЗапросаПоЗаявке(ДокументПланирования);
			
			РезультатЗапросаЗаявка = РезультатЗапроса[1];
			РезультатЗапросаПозиции = РезультатЗапроса[2].Выгрузить();
			РезультатЗапросаВизы = РезультатЗапроса[3].Выгрузить();
			
			Если Не РезультатЗапросаЗаявка.Пустой() Тогда
				
				// Получаем макет и области.
				Макет = ПолучитьМакет("ЗаявкаНаОплатуДляСписка");
				//Получаем области
				ОбластьЗаявка 			 = Макет.ПолучитьОбласть("Заявка");
				ОбластьПозицииШапка	 	 = Макет.ПолучитьОбласть("ПозицииШапка");
				ОбластьПозицииТЧ		 = Макет.ПолучитьОбласть("ПозицииТЧ");
				ОбластьВизыШапка		 = Макет.ПолучитьОбласть("ВизыШапка");
				ОбластьВизыТЧ 			 = Макет.ПолучитьОбласть("ВизыТЧ");
				ОбластьПодвал 			 = Макет.ПолучитьОбласть("Подвал");
				
				//Вывод результатов
				ВыборкаИзЗапросаЗаявка = РезультатЗапросаЗаявка.Выбрать();
				
				Пока ВыборкаИзЗапросаЗаявка.Следующий() Цикл 
					
					ТекДокумент = ВыборкаИзЗапросаЗаявка.Ссылка;
					
					//Отбор для таблиц по текущему документу
					Отбор = Новый Структура;
					Отбор.Вставить("ДокументПланирования", ТекДокумент); 			
					
					ОбластьЗаявка.Параметры.Заполнить(ВыборкаИзЗапросаЗаявка);
					
					НомерДок = СокрЛП(ТекДокумент.Номер);
					
					Если ВыборкаИзЗапросаЗаявка.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Наличные Тогда
						ЗаявкаЗаголовок = НСтр("ru = 'ЗАЯВКА НА РАСХОДОВАНИЕ НАЛИЧНЫХ ДЕНЕЖНЫХ СРЕДСТВ №%1 от %2';
						  	  				   |en = 'APPLICATION FOR CASH FLOWS №%1 from %2'");					
					Иначе	
						ЗаявкаЗаголовок = НСтр("ru = 'ЗАЯВКА НА РАСХОДОВАНИЕ БЕЗНАЛИЧНЫХ ДЕНЕЖНЫХ СРЕДСТВ №%1 от %2';
						  	  				   |en = 'APPLICATION FOR CONSUMPTION OF CASH-FREE CASH №%1 from %2'");					
					КонецЕсли;
					ЗаявкаЗаголовок = СтрШаблон(ЗаявкаЗаголовок, НомерДок, Формат(ВыборкаИзЗапросаЗаявка.Дата, "ДФ=dd.MM.yyyy"));
					
					Если ВыборкаИзЗапросаЗаявка.СверхБюджета Тогда
						ТекстСверхБюджета = НСтр("ru = 'Да'; en = 'Yes'");
					Иначе
						ТекстСверхБюджета = НСтр("ru = 'Нет'; en = 'No'");
					КонецЕсли;
					
					ОбластьЗаявка.Параметры.Заголовок	 = ЗаявкаЗаголовок;
					ОбластьЗаявка.Параметры.СверхБюджета = ТекстСверхБюджета;
					
					ВидОперации = бит_Казначейство.ХозяйственнаяОперацияУП(ВыборкаИзЗапросаЗаявка.ХозяйственнаяОперация);
					Если ВидОперации = Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствПодотчетнику 
						ИЛИ ВидОперации = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыПоЗарплатномуПроекту
						ИЛИ ВидОперации = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыРаздатчиком
						ИЛИ ВидОперации = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета
						ИЛИ ВидОперации = Перечисления.ХозяйственныеОперации.ВыдачаЗаймаСотруднику
						ИЛИ ВидОперации = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыРаботнику Тогда
					
						ОбластьЗаявка.Параметры.Контрагент = ВыборкаИзЗапросаЗаявка.ФизЛицо;
					
					КонецЕсли; 
					
					ОбластьЗаявка.Параметры.СуммаПрописью = бит_ФормированиеПечатныхФорм.СформироватьСуммуПрописью(ОбластьЗаявка.Параметры.СуммаЗаявки
																											, ОбластьЗаявка.Параметры.ВалютаДокумента);
					
					ТабличныйДокумент.Вывести(ОбластьЗаявка);
					ТабличныйДокумент.Вывести(ОбластьПозицииШапка);
					
					// Заполняем и выводим в табличный документ строки по платежным позициям текущего документа.
					МассивСтрок = РезультатЗапросаПозиции.НайтиСтроки(Отбор);
					ц=1;
					Для Каждого ТекСтрока Из МассивСтрок Цикл
						ОбластьПозицииТЧ.Параметры.Заполнить(ТекСтрока);
						ОбластьПозицииТЧ.Параметры.ДатаПлатежа	= Формат(ТекСтрока.ДатаПлан, "ДФ = дд.ММ.гггг");
						ОбластьПозицииТЧ.Параметры.Номер = ц;
						
						Проект = ОпределитьПроект(ТекСтрока);
						ОбластьПозицииТЧ.Параметры.Проект = Проект;
						
						ц=ц+1;
						ТабличныйДокумент.Вывести(ОбластьПозицииТЧ);
					КонецЦикла;
					
					ТабличныйДокумент.Вывести(ОбластьВизыШапка);
					// Заполняем визы.
					МассивВиз = РезультатЗапросаВизы.НайтиСтроки(Отбор);
					Для Каждого вТекСтрока Из МассивВиз Цикл
						ОбластьВизыТЧ.Параметры.Заполнить(вТекСтрока);
						ТабличныйДокумент.Вывести(ОбластьВизыТЧ);
					КонецЦикла;
					
					// Выводим область "Подвал" в табличный документ.
					ОбластьПодвал.Параметры.Заполнить(ВыборкаИзЗапросаЗаявка);
					ТабличныйДокумент.Вывести(ОбластьПодвал);
					
				КонецЦикла;
				
			КонецЕсли;
		
		Иначе
			
			// Формируем запрос по заявкам.
			РезультатЗапроса = ПолучитьРезультатЗапросаПоЗаявкеБезСписка(ДокументПланирования);
			
			РезультатЗапросаЗаявка = РезультатЗапроса[0];
			РезультатЗапросаВизы = РезультатЗапроса[1].Выгрузить();
			
			Если Не РезультатЗапросаЗаявка.Пустой() Тогда
				
				// Получаем макет и области.
				Макет = ПолучитьМакет("ЗаявкаНаОплату");
				// Получаем области.
				ОбластьЗаявка 	 = Макет.ПолучитьОбласть("Заявка");
				ОбластьВизыШапка = Макет.ПолучитьОбласть("ВизыШапка");
				ОбластьВизыТЧ 	 = Макет.ПолучитьОбласть("ВизыТЧ");
				ОбластьПодвал 	 = Макет.ПолучитьОбласть("Подвал");
				
				// Вывод результатов.
				ВыборкаИзЗапросаЗаявка = РезультатЗапросаЗаявка.Выбрать();
				
				Пока ВыборкаИзЗапросаЗаявка.Следующий() Цикл 
					
					ТекДокумент = ВыборкаИзЗапросаЗаявка.Ссылка;
					
					// Отбор для таблиц по текущему документу.
					Отбор = Новый Структура;
					Отбор.Вставить("ДокументПланирования", ДокументПланирования); 			
					
					ОбластьЗаявка.Параметры.Заполнить(ВыборкаИзЗапросаЗаявка);
					
					НомерДок = СокрЛП(ДокументПланирования.Номер);
					
					Если ВыборкаИзЗапросаЗаявка.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Наличные Тогда
						ЗаявкаЗаголовок = НСтр("ru = 'ЗАЯВКА НА РАСХОДОВАНИЕ НАЛИЧНЫХ ДЕНЕЖНЫХ СРЕДСТВ №%1 от %2';
						  	  				   |en = 'APPLICATION FOR CASH FLOWS №%1 from %2'");					
					Иначе	
						ЗаявкаЗаголовок = НСтр("ru = 'ЗАЯВКА НА РАСХОДОВАНИЕ БЕЗНАЛИЧНЫХ ДЕНЕЖНЫХ СРЕДСТВ №%1 от %2';
						  	  				   |en = 'APPLICATION FOR CONSUMPTION OF CASH-FREE CASH №%1 from %2'");					
					КонецЕсли;
					ЗаявкаЗаголовок = СтрШаблон(ЗаявкаЗаголовок, НомерДок, Формат(ВыборкаИзЗапросаЗаявка.Дата, "ДФ=dd.MM.yyyy"));
					
					Если ВыборкаИзЗапросаЗаявка.СверхБюджета Тогда
						ТекстСверхБюджета = НСтр("ru = 'Да'; en = 'Yes'");
					Иначе
						ТекстСверхБюджета = НСтр("ru = 'Нет'; en = 'No'");
					КонецЕсли;
					
					ОбластьЗаявка.Параметры.Заголовок		= ЗаявкаЗаголовок;
					ОбластьЗаявка.Параметры.СверхБюджета	= ТекстСверхБюджета;
					ОбластьЗаявка.Параметры.ДатаПлатежа		= Формат(ВыборкаИзЗапросаЗаявка.ДатаПлан, "ДФ = дд.ММ.гггг");
					
					Если ВыборкаИзЗапросаЗаявка.ВидОперации = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаДенежныхСредствПодотчетнику 
						ИЛИ ВыборкаИзЗапросаЗаявка.ВидОперации = Перечисления.бит_ВидыОперацийКазначейства.ВыплатаЗарплатыПоЗарплатномуПроекту
						ИЛИ ВыборкаИзЗапросаЗаявка.ВидОперации = Перечисления.бит_ВидыОперацийКазначейства.ВыплатаЗарплатыРаздатчиком
						ИЛИ ВыборкаИзЗапросаЗаявка.ВидОперации = Перечисления.бит_ВидыОперацийКазначейства.ВыплатаЗарплатыНаЛицевыеСчета
						ИЛИ ВыборкаИзЗапросаЗаявка.ВидОперации = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаЗаймаСотруднику
						ИЛИ ВыборкаИзЗапросаЗаявка.ВидОперации = Перечисления.бит_ВидыОперацийКазначейства.ВыплатаЗарплатыРаботнику Тогда
					
						ОбластьЗаявка.Параметры.Контрагент = ВыборкаИзЗапросаЗаявка.ФизЛицо;
					
					КонецЕсли;	
					
					Проект = ОпределитьПроект(ВыборкаИзЗапросаЗаявка);
					ОбластьЗаявка.Параметры.Проект = Проект;
					
					ОбластьЗаявка.Параметры.СуммаПрописью = бит_ФормированиеПечатныхФорм.СформироватьСуммуПрописью(ОбластьЗаявка.Параметры.СуммаДокумента
																											, ОбластьЗаявка.Параметры.ВалютаДокумента);
					
					ТабличныйДокумент.Вывести(ОбластьЗаявка);
					
					ТабличныйДокумент.Вывести(ОбластьВизыШапка);
					// Заполняем визы
					МассивВиз = РезультатЗапросаВизы.НайтиСтроки(Отбор);
					Для Каждого вТекСтрока Из МассивВиз Цикл
						ОбластьВизыТЧ.Параметры.Заполнить(вТекСтрока);
						ТабличныйДокумент.Вывести(ОбластьВизыТЧ);
					КонецЦикла;
					
					// Выводим область "Подвал" в табличный документ.
					ОбластьПодвал.Параметры.Заполнить(ВыборкаИзЗапросаЗаявка);
					ТабличныйДокумент.Вывести(ОбластьПодвал);
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли; 
		
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
	
	КонецЦикла; 
	
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуЗаявкиНаОплату()

Функция НовыеПараметрыДокументаСоздатьПлатежныеДокументы() Экспорт

	Позиции = Новый ТаблицаЗначений;
	Позиции.Колонки.Добавить("Позиция", 			Новый ОписаниеТипов("ДокументСсылка.бит_кзн_ПлатежнаяПозиция"));
	Позиции.Колонки.Добавить("Сумма", 				ОбщегоНазначения.ОписаниеТипаЧисло(15, 2));
	Позиции.Колонки.Добавить("ИдентификаторСтроки", ОбщегоНазначения.ОписаниеТипаСтрока(36));
	
	НовыеПараметры = Новый Структура;
	НовыеПараметры.Вставить("Дата", 					'0001-01-01');
	НовыеПараметры.Вставить("БанковскийСчетКасса", 		Неопределено);
	НовыеПараметры.Вставить("БанковскийСчетПолучателя", Неопределено);
	НовыеПараметры.Вставить("Позиции", 					Позиции);

	НовыеПараметры.Вставить("ВызовИзРеестра", 				Ложь);
	НовыеПараметры.Вставить("ОбъединятьНазначениеПлатежа",	Истина);
	НовыеПараметры.Вставить("РежимЗаписи", 					Перечисления.бит_РежимыЗаписиДокумента.Запись);
	
	Возврат НовыеПараметры;

КонецФункции

// Создает платежные документы.
//
// Параметры:
//  ДокументОснование	 - Произвольный	 - основание для документа оплаты.
//  ПараметрыДокументов	 - Массив - элемены массива - структура. См. НовыеПараметрыДокументаСоздатьПлатежныеДокументы(). 
// 
// Возвращаемое значение:
//  Результат - таблица значений
//		*	ДокументОплаты - Произвольный - документ оплаты.
//		*	Позиция		   - ДокументСсылка.бит_кзн_ПлатежнаяПозиция.
//
Функция СоздатьПлатежныеДокументы(ДокументОснование, ПараметрыДокументов) Экспорт 
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ДокументОплаты");
	Результат.Колонки.Добавить("Позиция");
	
	Если НЕ ЗначениеЗаполнено(ПараметрыДокументов) Тогда
		Возврат Результат;
	КонецЕсли;

	Настройка = ПараметрыДокументов[0];
	Отказ	  = Ложь;
	бит_Казначейство.ПроверитьПлатежныеПозицииИзРеестраПоИсточникуВызова(Настройка.Позиции, Настройка, Отказ);
	Если Отказ Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	Реквизиты.ФизЛицо КАК ФизЛицо,
	|	Реквизиты.Контрагент КАК Контрагент,
	|	Реквизиты.ПлатежиПо275ФЗ КАК ПлатежиПо275ФЗ,
	|	Реквизиты.ТипПлатежаФЗ275 КАК ТипПлатежаФЗ275,
	|	Реквизиты.ДоговорСЗаказчиком КАК ДоговорСЗаказчиком,
	|	Реквизиты.ДоговорСУчастникомГОЗ КАК ДоговорСУчастникомГОЗ,
	|	Реквизиты.ФормаОплаты КАК ФормаОплаты
	|ИЗ
	|	Документ.бит_кзн_ЗаявкаНаРасходованиеСредств КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";
	
	РезультатЗапроса   = Запрос.Выполнить().Выгрузить();
	РеквизитыОснования = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(РезультатЗапроса[0]);
									
	// определим фактическией сценарий
	ПараметрыНастроек  = Новый Структура("Организация", РеквизитыОснования.Организация);
    СценарийФакт 	   = бит_НастройкиПрограммы.СценарийОтраженияФактаБДДС(ПараметрыНастроек, ТекущаяДатаСеанса());	
							
    Если НЕ ЗначениеЗаполнено(СценарийФакт) Тогда
		СценарийФакт = Справочники.СценарииПланирования.ФАКТ;
	КонецЕсли; 
	
	ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	ВидОперации 	= бит_Казначейство.ХозяйственнаяОперацияУП(РеквизитыОснования.ХозяйственнаяОперация);
	
	Если РеквизитыОснования.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
		МенеджерПлатежногоДокумента   = Документы.СписаниеБезналичныхДенежныхСредств;
		МетаданныеПлатежногоДокумента = Метаданные.Документы.СписаниеБезналичныхДенежныхСредств;
		Безналичные 		  		= Истина;
		ВедомостьВСписке			= Истина;
	ИначеЕсли РеквизитыОснования.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Наличные Тогда
		МенеджерПлатежногоДокумента   = Документы.РасходныйКассовыйОрдер;
		МетаданныеПлатежногоДокумента = Метаданные.Документы.РасходныйКассовыйОрдер;
		Безналичные 				= Ложь;
		ВедомостьВСписке			= Ложь;
	КонецЕсли;
	
	ЕстьНазначениеПлатежа 	   = ОбщегоНазначения.ЕстьРеквизитОбъекта("НазначениеПлатежа", МетаданныеПлатежногоДокумента);
	ЕстьТипПлатежногоДокумента = ОбщегоНазначения.ЕстьРеквизитОбъекта("ТипПлатежногоДокумента", МетаданныеПлатежногоДокумента);
	ЕстьПодразделение		   = ОбщегоНазначения.ЕстьРеквизитОбъекта("Подразделение", МетаданныеПлатежногоДокумента);
	ЕстьДоговорЭквайринга	   = ОбщегоНазначения.ЕстьРеквизитОбъекта("ДоговорЭквайринга", МетаданныеПлатежногоДокумента);
	ЕстьДоговорЭквайринга	   = ОбщегоНазначения.ЕстьРеквизитОбъекта("ДоговорЭквайринга", МетаданныеПлатежногоДокумента);
		
	Для каждого ТекущиеПараметры Из ПараметрыДокументов Цикл
 		
		ПараметрыЗаполнения = Новый Структура;
		ПараметрыЗаполнения.Вставить("Безналичные",                  Безналичные);
		ПараметрыЗаполнения.Вставить("ВедомостьВСписке",             ВедомостьВСписке);
		ПараметрыЗаполнения.Вставить("ВидОперации",                  ВидОперации);
		ПараметрыЗаполнения.Вставить("ЕстьНазначениеПлатежа",        ЕстьНазначениеПлатежа);
		ПараметрыЗаполнения.Вставить("ЕстьПодразделение",            ЕстьПодразделение);
		ПараметрыЗаполнения.Вставить("ЕстьТипПлатежногоДокумента",   ЕстьТипПлатежногоДокумента);
		ПараметрыЗаполнения.Вставить("МенеджерПлатежногоДокумента",  МенеджерПлатежногоДокумента);
		ПараметрыЗаполнения.Вставить("ОбъединятьНазначениеПлатежа",  ТекущиеПараметры.ОбъединятьНазначениеПлатежа);
		ПараметрыЗаполнения.Вставить("РеквизитыОснования",           РеквизитыОснования);
		ПараметрыЗаполнения.Вставить("СценарийФакт",                 СценарийФакт);
		ПараметрыЗаполнения.Вставить("ЕстьДоговорЭквайринга",	   	 ЕстьДоговорЭквайринга);
		ПараметрыЗаполнения.Вставить("ВалютаРеглУчета",			   	 ВалютаРеглУчета);
		ПараметрыЗаполнения.Вставить("РежимЗаписиПлатДокумента",     ТекущиеПараметры.РежимЗаписи);
		ПараметрыЗаполнения.Вставить("ДатаДокумента", 				 '0001-01-01');
		ПараметрыЗаполнения.Вставить("ЭтоОперацияСПартнером", 		 Ложь);
		
		ДокументПозиция = ТекущиеПараметры.Позиции[0].Позиция;
		
		ЗначениеРеквизитовПозиции = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументПозиция, "Ведомость, НДФЛПоВедомостям, ДатаПлан");
		Ведомость                 = ЗначениеРеквизитовПозиции.Ведомость;
		ПараметрыЗаполнения.Вставить("Ведомость",        Ведомость);
		ПараметрыЗаполнения.Вставить("НДФЛПоВедомостям", ЗначениеРеквизитовПозиции.НДФЛПоВедомостям);
		ПараметрыЗаполнения.Вставить("ПерваяПозиция",    ДокументПозиция);
		
		Если НЕ ЗначениеЗаполнено(ТекущиеПараметры.Дата) Тогда
			ПараметрыЗаполнения.ДатаДокумента = ЗначениеРеквизитовПозиции.ДатаПлан;
		Иначе			
			ПараметрыЗаполнения.ДатаДокумента = ТекущиеПараметры.Дата;
		КонецЕсли;

		ТипДокументаВедомость = ТипЗнч(Ведомость);
		Если ВидОперации = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыНаЛицевыеСчета
			И ЗначениеЗаполнено(Ведомость)
			И (ТипДокументаВедомость = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыПеречислением")
				ИЛИ ТипДокументаВедомость = Тип("ДокументСсылка.ВедомостьПрочихДоходовВБанк")
				ИЛИ ТипДокументаВедомость = Тип("ДокументСсылка.ВедомостьПрочихДоходовПеречислением")) Тогда
			
			ФизЛицоЗаявки = РеквизитыОснования.ФизЛицо;
			
			Запрос = Новый Запрос;
			Запрос.Текст = ТекстЗапросаВыплатыПоВедомости(ТипДокументаВедомость);
			Запрос.УстановитьПараметр("Ведомость", Ведомость);
			СтрокаВедомости = Запрос.Выполнить().Выбрать();
		
			Пока СтрокаВедомости.Следующий() Цикл
				Если ЗначениеЗаполнено(ФизЛицоЗаявки) И ФизЛицоЗаявки <> СтрокаВедомости.ФизическоеЛицо Тогда
					Продолжить;
				КонецЕсли;
				
				РеквизитыОснования.ФизЛицо = СтрокаВедомости.ФизическоеЛицо;
				
				Для каждого СтрокаПозиции Из ТекущиеПараметры.Позиции Цикл
					СтрокаПозиции.Сумма = СтрокаВедомости.КВыплате;
				КонецЦикла;
				
				ПараметрыЗаполнения.Вставить("БанковскийСчетКонтрагента", СтрокаВедомости.БанковскийСчет);
				ПараметрыЗаполнения.Вставить("СуммыКОплате", ТекущиеПараметры);
				СоздатьПлатежныйДокумент(ПараметрыЗаполнения, Результат);
			КонецЦикла;
		Иначе
			ПараметрыЗаполнения.Вставить("СуммыКОплате", ТекущиеПараметры);
			СоздатьПлатежныйДокумент(ПараметрыЗаполнения, Результат); 
		КонецЕсли;
	КонецЦикла; 
	
	Возврат Результат;
	
КонецФункции

// Устарела. Следует использовать СоздатьДокументыНаОсновеВыделенных().
Функция СоздатьДокументыНаОсновеЗаявки(ДокументОснование) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументОснование);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПлатежныеПозиции.ДатаПлан КАК Дата,
	|	ВЫБОР
	|		КОГДА ПлатежныеПозиции.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|			ТОГДА ПлатежныеПозиции.БанковскийСчет
	|		ИНАЧЕ ПлатежныеПозиции.Касса
	|	КОНЕЦ КАК БанковскийСчетКасса,
	|	ПлатежныеПозиции.БанковскийСчетПолучателя КАК БанковскийСчетПолучателя,
	|	ПлатежныеПозиции.Ссылка КАК Позиция,
	|	ПлатежныеПозиции.Подразделение КАК Подразделение,
	|	ЗаявкиНаРасходованиеСредств.НеОбъединятьПозицииПриОплате КАК НеОбъединятьПозицииПриОплате
	|ПОМЕСТИТЬ ВТ_ПлатежныеПозиции
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_ЗаявкаНаРасходованиеСредств КАК ЗаявкиНаРасходованиеСредств
	|		ПО ПлатежныеПозиции.ДокументПланирования = ЗаявкиНаРасходованиеСредств.Ссылка
	|ГДЕ
	|	ПлатежныеПозиции.ДокументПланирования = &ДокументПланирования
	|	И НЕ ПлатежныеПозиции.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОстаткиПланируемогоРасхода.СуммаОстаток КАК Сумма,
	|	ОстаткиПланируемогоРасхода.Позиция КАК Позиция
	|ПОМЕСТИТЬ ВТ_ОстаткиПланируемогоРасхода
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.Остатки(
	|			,
	|			Позиция В
	|				(ВЫБРАТЬ
	|					ВТ_ПлатежныеПозиции.Позиция КАК Позиция
	|				ИЗ
	|					ВТ_ПлатежныеПозиции КАК ВТ_ПлатежныеПозиции)) КАК ОстаткиПланируемогоРасхода
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПлатежныеПозиции.Дата КАК Дата,
	|	ВТ_ПлатежныеПозиции.БанковскийСчетКасса КАК БанковскийСчетКасса,
	|	ВТ_ПлатежныеПозиции.БанковскийСчетПолучателя КАК БанковскийСчетПолучателя,
	|	ВТ_ПлатежныеПозиции.Позиция КАК Позиция,
	|	ЕСТЬNULL(ВТ_ОстаткиПланируемогоРасхода.Сумма, 0) КАК Сумма,
	|	ВТ_ПлатежныеПозиции.Подразделение КАК Подразделение
	|ИЗ
	|	ВТ_ПлатежныеПозиции КАК ВТ_ПлатежныеПозиции
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОстаткиПланируемогоРасхода КАК ВТ_ОстаткиПланируемогоРасхода
	|		ПО ВТ_ПлатежныеПозиции.Позиция = ВТ_ОстаткиПланируемогоРасхода.Позиция
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	БанковскийСчетКасса,
	|	БанковскийСчетПолучателя,
	|	Подразделение";
	
	Результат = Запрос.Выполнить();                             
	Выборка = Результат.Выбрать();

	ПараметрыДокументов = Новый Массив;

	Пока Выборка.СледующийПоЗначениюПоля("Дата") Цикл
		Пока Выборка.СледующийПоЗначениюПоля("БанковскийСчетКасса") Цикл
			Пока Выборка.СледующийПоЗначениюПоля("БанковскийСчетПолучателя") Цикл
				Пока Выборка.СледующийПоЗначениюПоля("Подразделение") Цикл
					ДанныеЗаполнения = НовыеПараметрыДокументаСоздатьПлатежныеДокументы();
					ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка);
					
					Пока Выборка.Следующий() Цикл
						Если Выборка.Сумма = 0 Тогда
							ТекстСообщения = НСтр("ru = 'Недостаточно запланированных средств по %1. Документ пропущен.'");
							ТекстСообщения = СтрШаблон(ТекстСообщения, Выборка.Позиция);
							ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Выборка.Позиция);
						Иначе	
							ЗаполнитьЗначенияСвойств(ДанныеЗаполнения.Позиции.Добавить(), Выборка)
						КонецЕсли;
					КонецЦикла;
					
					Если ЗначениеЗаполнено(ДанныеЗаполнения.Позиции) Тогда
						ПараметрыДокументов.Добавить(ДанныеЗаполнения);
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	НовыеДокументы = Новый ТаблицаЗначений;
	Если ЗначениеЗаполнено(ПараметрыДокументов) Тогда
		НовыеДокументы = СоздатьПлатежныеДокументы(ДокументОснование, ПараметрыДокументов);
	КонецЕсли;
	
	Возврат НовыеДокументы;

КонецФункции

// Функция создает документы оплаты на основании выделенных позиций из Заявки на расходование ДС.
//
Функция СоздатьДокументыНаОсновеВыделенных(ДокументОснование, ПараметрыВыделенных) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВыделенныеСтроки", ПараметрыВыделенных.Позиции);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВыделенныеСтроки.Позиция КАК Позиция,
	|	ВыделенныеСтроки.Сумма КАК Сумма
	|ПОМЕСТИТЬ ВыделенныеСтроки
	|ИЗ
	|	&ВыделенныеСтроки КАК ВыделенныеСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОстаткиПланируемогоРасхода.Позиция КАК Позиция,
	|	ЕСТЬNULL(ОстаткиПланируемогоРасхода.СуммаОстаток, 0) КАК Сумма
	|ПОМЕСТИТЬ ВТ_ОстаткиПланируемогоРасхода
	|ИЗ
	|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.Остатки(
	|			,
	|			Позиция В
	|				(ВЫБРАТЬ
	|					ВыделенныеСтроки.Позиция КАК Позиция
	|				ИЗ
	|					ВыделенныеСтроки КАК ВыделенныеСтроки)) КАК ОстаткиПланируемогоРасхода
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВыделенныеСтроки.Позиция КАК Позиция,
	|	ВЫБОР
	|		КОГДА ВыделенныеСтроки.Сумма = 0
	|			ТОГДА ЕСТЬNULL(ОстаткиПланируемогоРасхода.Сумма, 0)
	|		ИНАЧЕ ВыделенныеСтроки.Сумма
	|	КОНЕЦ КАК Сумма,
	|	ПлатежныеПозиции.ДатаПлан КАК Дата,
	|	ВЫБОР
	|		КОГДА ПлатежныеПозиции.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
	|			ТОГДА ПлатежныеПозиции.БанковскийСчет
	|		ИНАЧЕ ПлатежныеПозиции.Касса
	|	КОНЕЦ КАК БанковскийСчетКасса,
	|	ПлатежныеПозиции.БанковскийСчетПолучателя КАК БанковскийСчетПолучателя,
	|	ПлатежныеПозиции.Подразделение КАК Подразделение,
	|	ЗаявкиНаРасходованиеСредств.НеОбъединятьПозицииПриОплате КАК НеОбъединятьПозицииПриОплате
	|ИЗ
	|	ВыделенныеСтроки КАК ВыделенныеСтроки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ЗаявкаНаРасходованиеСредств КАК ЗаявкиНаРасходованиеСредств
	|			ПО ПлатежныеПозиции.ДокументПланирования = ЗаявкиНаРасходованиеСредств.Ссылка
	|		ПО ВыделенныеСтроки.Позиция = ПлатежныеПозиции.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОстаткиПланируемогоРасхода КАК ОстаткиПланируемогоРасхода
	|		ПО ВыделенныеСтроки.Позиция = ОстаткиПланируемогоРасхода.Позиция
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	БанковскийСчетКасса,
	|	БанковскийСчетПолучателя,
	|	Подразделение,
	|	Позиция";
	
	Результат = Запрос.Выполнить();                             
	Выборка = Результат.Выбрать();

	ПараметрыДокументов = Новый Массив;

	Пока Выборка.СледующийПоЗначениюПоля("Дата") Цикл
		Пока Выборка.СледующийПоЗначениюПоля("БанковскийСчетКасса") Цикл
			Пока Выборка.СледующийПоЗначениюПоля("БанковскийСчетПолучателя") Цикл
				Пока Выборка.СледующийПоЗначениюПоля("Подразделение") Цикл
					
					Если Выборка.НеОбъединятьПозицииПриОплате Тогда
						
		 				Пока Выборка.СледующийПоЗначениюПоля("Позиция") Цикл
							ДанныеЗаполнения = НовыеПараметрыДокументаСоздатьПлатежныеДокументы();
							ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, ПараметрыВыделенных,, "Позиции");
							ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка,, "Дата");
							Если НЕ ЗначениеЗаполнено(ПараметрыВыделенных.Дата) Тогда
								ДанныеЗаполнения.Дата = Выборка.Дата;					
							КонецЕсли;

							Если Выборка.Сумма = 0 Тогда
								ТекстСообщения = НСтр("ru = 'Недостаточно запланированных средств по %1. Документ пропущен.'");
								ТекстСообщения = СтрШаблон(ТекстСообщения, Выборка.Позиция);
								ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Выборка.Позиция);
							Иначе	
								ЗаполнитьЗначенияСвойств(ДанныеЗаполнения.Позиции.Добавить(), Выборка)
							КонецЕсли;
							Если ЗначениеЗаполнено(ДанныеЗаполнения.Позиции) Тогда
								ПараметрыДокументов.Добавить(ДанныеЗаполнения);
							КонецЕсли;
						КонецЦикла;
					Иначе	
						ДанныеЗаполнения = НовыеПараметрыДокументаСоздатьПлатежныеДокументы();
						ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, ПараметрыВыделенных,, "Позиции");
						ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка,, "Дата");
						Если НЕ ЗначениеЗаполнено(ПараметрыВыделенных.Дата) Тогда
							ДанныеЗаполнения.Дата = Выборка.Дата;					
						КонецЕсли;
						
		 				Пока Выборка.СледующийПоЗначениюПоля("Позиция") Цикл
							Если Выборка.Сумма = 0 Тогда
								ТекстСообщения = НСтр("ru = 'Недостаточно запланированных средств по %1. Документ пропущен.'");
								ТекстСообщения = СтрШаблон(ТекстСообщения, Выборка.Позиция);
								ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Выборка.Позиция);
							Иначе	
								ЗаполнитьЗначенияСвойств(ДанныеЗаполнения.Позиции.Добавить(), Выборка)
							КонецЕсли;
						КонецЦикла;
						Если ЗначениеЗаполнено(ДанныеЗаполнения.Позиции) Тогда
							ПараметрыДокументов.Добавить(ДанныеЗаполнения);
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	НовыеДокументы = Новый ТаблицаЗначений;
	НовыеДокументы.Колонки.Добавить("ДокументОплаты");
	НовыеДокументы.Колонки.Добавить("Позиция");
	
	Если ЗначениеЗаполнено(ПараметрыДокументов) Тогда
		НовыеДокументы = СоздатьПлатежныеДокументы(ДокументОснование, ПараметрыДокументов);
	КонецЕсли;
	
	Возврат НовыеДокументы;
	
КонецФункции

// Функция получает неоплаченный остаток по планируемому поступлению.
//
// Параметры:
//   Позиция - ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств
//
// Возвращаемое значение:
//  СтрОплата - Структура.
//
Функция ПолучитьОстаток(ДокументПланирования) Экспорт
	
	СтрОплата = Новый Структура("План, Факт, Остаток",0, 0, 0);
	
	ВидПлана = ?(ТипЗнч(ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств"), ДокументПланирования.ВидПлана, Перечисления.бит_кзн_ВидыПланов.План);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидПлана"            , ВидПлана);
	Запрос.УстановитьПараметр("ДокументПланирования", ДокументПланирования);
	Запрос.УстановитьПараметр("Организация"         , ДокументПланирования.Организация);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаКонечныйОстаток, 0) КАК СуммаОстаток,
	               |	ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаПриход, 0) КАК СуммаПлан,
	               |	ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаРасход, 0) КАК СуммаФакт
	               |ИЗ
	               |	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.ОстаткиИОбороты(
	               |			,
	               |			,
	               |			,
	               |			,
	               |			ВидПлана = &ВидПлана
	               |				И ДокументПланирования = &ДокументПланирования
	               |				И Организация = &Организация) КАК ПлРасходОстаткиИОбороты";

	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		СтрОплата.План    = Выборка.СуммаПлан;
		СтрОплата.Факт    = Выборка.СуммаФакт;
		СтрОплата.Остаток = Выборка.СуммаОстаток;
	
	КонецЕсли; 

	Возврат СтрОплата;
	
КонецФункции // ПолучитьОстаток()

// Функция разбивает позицию на две одинаковые.
//
// Параметры:
//  Позиция - ДокументСсылка.бит_кзн_ПлатежнаяПозиция,ДокументСсылка.бит_кзн_ПозицияПоступления 
//  СуммаНач - Число
//  СуммаНов - Число.
//
Функция РазбитьПозицию(Позиция, СуммаНач, СуммаНов, ДатаПлатежа) Экспорт 
	
	ВыводСообщений	   = "Ошибки";
	РазбиениеВыполнено = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Позиция", Позиция);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бит_СтатусыОбъектов.Объект,
	|	бит_СтатусыОбъектов.Статус,
	|	бит_СтатусыОбъектов.Пользователь,
	|	бит_СтатусыОбъектов.ДатаИзмененияСтатуса,
	|	бит_СтатусыОбъектов.СтатусПредыдущий
	|ИЗ
	|	РегистрСведений.бит_СтатусыОбъектов КАК бит_СтатусыОбъектов
	|ГДЕ
	|	бит_СтатусыОбъектов.Объект = &Позиция
	|	И бит_СтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус)";
	
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
	
		Статус		 		 = Выборка.Статус;
		ПредыдущийСтатус	 = Выборка.СтатусПредыдущий;
		Пользователь 		 = Выборка.Пользователь;
	    ДатаИзмененияСтатуса = Выборка.ДатаИзмененияСтатуса;
		
	КонецЦикла;
	
	ДанныеСообщения = Неопределено;
	
	НачатьТранзакцию();
	Попытка	
		//Получаем текущую позицию и меняем в ней сумму на разницу между начальной суммой и новой
		Объект = Позиция.ПолучитьОбъект();
		
		РежимЗаписи = ?(Объект.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись);
		
		Объект.СуммаДокумента = СуммаНач - СуммаНов;
		Если Объект.ВалютаВзаиморасчетов <> Объект.ВалютаДокумента Тогда
			Объект.СуммаВзаиморасчетов = 0;
		Иначе
			Объект.СуммаВзаиморасчетов = Объект.СуммаДокумента;
		КонецЕсли;

		Если Объект.ВалютаДокумента = Объект.ВалютаВзаиморасчетов Тогда
			Объект.СуммаВзаиморасчетов = Объект.СуммаДокумента;
		Иначе
			Данные = Новый Структура;
			Данные.Вставить("Сумма", 						 Объект.СуммаДокумента);
			Данные.Вставить("КурсЧислительВзаиморасчетов",	 Объект.КурсЧислительВзаиморасчетов);
			Данные.Вставить("КурсЗнаменательВзаиморасчетов", Объект.КурсЗнаменательВзаиморасчетов);
			Данные.Вставить("СуммаВзаиморасчетов",			 Объект.СуммаВзаиморасчетов);
			
			ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
				Данные, Объект.ВалютаДокумента, Константы.ВалютаРегламентированногоУчета.Получить());
			
			Объект.СуммаВзаиморасчетов = Данные.СуммаВзаиморасчетов; 		
		КонецЕсли;
		
		Объект.СуммаНДС = РасчитатьСуммуНДС(Объект.СуммаДокумента, Объект.СтавкаНДС);
		
		Попытка
			Объект.Записать(РежимЗаписи);		
		Исключение
			ТекстСообщения  = НСтр("ru = 'Не удалось записать документ %1. По причине: %2.'");
			ТекстСообщения  = СтрШаблон(ТекстСообщения, Позиция, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ДанныеСообщения = Позиция;
			
			ВызватьИсключение ТекстСообщения;
		КонецПопытки;	
		
		НоваяПозиция = Позиция.Скопировать();
		НоваяПозиция.ДополнительныеСвойства.Вставить("НеСинхронизировать", Истина);

		НоваяПозиция.Дата			= Позиция.Дата;
		НоваяПозиция.СверхБюджета  	= Позиция.СверхБюджета;
		НоваяПозиция.СписатьЛимиты 	= Позиция.СписатьЛимиты;
		
		Если НЕ ЗначениеЗаполнено(ДатаПлатежа) Тогда
			НоваяПозиция.ДатаПлан		 = Позиция.ДатаПлан;
			НоваяПозиция.ДатаПланКрайняя = Позиция.ДатаПланКрайняя;
		Иначе 
			НоваяПозиция.ДатаПлан = ДатаПлатежа;
		КонецЕсли; 	
		
		НоваяПозиция.СуммаДокумента = СуммаНов;
		
		Если НоваяПозиция.ВалютаДокумента = НоваяПозиция.ВалютаВзаиморасчетов Тогда
			НоваяПозиция.СуммаВзаиморасчетов = НоваяПозиция.СуммаДокумента;
		Иначе
			Данные = Новый Структура;
			Данные.Вставить("Сумма", 						 НоваяПозиция.СуммаДокумента);
			Данные.Вставить("КурсЧислительВзаиморасчетов",	 НоваяПозиция.КурсЧислительВзаиморасчетов);
			Данные.Вставить("КурсЗнаменательВзаиморасчетов", НоваяПозиция.КурсЗнаменательВзаиморасчетов);
			Данные.Вставить("СуммаВзаиморасчетов",			 НоваяПозиция.СуммаВзаиморасчетов);
			
			ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
				Данные, НоваяПозиция.ВалютаДокумента, Константы.ВалютаРегламентированногоУчета.Получить());
			
			НоваяПозиция.СуммаВзаиморасчетов = НоваяПозиция.СуммаВзаиморасчетов; 		
		КонецЕсли;
			
		НоваяПозиция.СуммаНДС = РасчитатьСуммуНДС(НоваяПозиция.СуммаДокумента, НоваяПозиция.СтавкаНДС);
		
		НоваяПозиция.Записать(РежимЗаписиДокумента.Запись);
		
		Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
			Попытка
				НоваяПозиция.Записать(РежимЗаписиДокумента.Проведение);
				
				ПараметрыУстановкиСтатуса = бит_ВизированиеСервер.НовыеПараметрыУстановкиСтатуса();
				ПараметрыУстановкиСтатуса.Объект               = НоваяПозиция.Ссылка; 
				ПараметрыУстановкиСтатуса.Статус               = Статус;
				ПараметрыУстановкиСтатуса.СтатусПредыдущий     = ПредыдущийСтатус;
				ПараметрыУстановкиСтатуса.ДатаИзмененияСтатуса = ДатаИзмененияСтатуса;
				ПараметрыУстановкиСтатуса.Пользователь         = Пользователь;
			
				ДействиеВыполнено = бит_ВизированиеСервер.УстановитьСтатусОбъекта(ПараметрыУстановкиСтатуса);

			Исключение
				ТекстСообщения  = НСтр("ru = 'Не удалось провести документ %1. По причине: %2.'");
				ТекстСообщения  = СтрШаблон(ТекстСообщения, НоваяПозиция.Ссылка, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
				ДанныеСообщения = НоваяПозиция.Ссылка;
				
				ВызватьИсключение ТекстСообщения;
			КонецПопытки;
		КонецЕсли;
				
		РазбиениеВыполнено = Истина;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ДанныеСообщения, "Ссылка");
	КонецПопытки;	
	
	Возврат РазбиениеВыполнено;
	
КонецФункции

// Функция получает плановую и фактическую сумму оплат по заявке.
//
// Параметры:
//  Заявка			  - ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств, Массив.
//  ПлатежныйДокумент - Платежный документ ссылка. По умолчанию Неопределено.
//
// Возвращаемое значение:
//   РезСтруктура: 
// 		- 1. Структура 	- Заявка - ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств.
// 		- 2. Соответствие - Заявка - Массив.
//
Функция ПолучитьОплатыПоЗаявке(Заявка, ПлатежныйДокумент = Неопределено) Экспорт

	УказанМассивЗаявок = ?(ТипЗнч(Заявка) = Тип("Массив"), Истина, Ложь);
	
	Если УказанМассивЗаявок Тогда
		МассивЗаявок = Заявка;
	Иначе
		
		МассивЗаявок = Новый Массив;
		МассивЗаявок.Добавить(Заявка);
		
	КонецЕсли;
	
	РезСтруктураШаблон = Новый Структура;
	РезСтруктураШаблон.Вставить("СуммаПлан"				, 0);
	РезСтруктураШаблон.Вставить("СуммаОплата"			, 0);
	РезСтруктураШаблон.Вставить("СуммаЗакрыта"			, 0);
	РезСтруктураШаблон.Вставить("Разность"				, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаПлан"	, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаОплата"	, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаЗакрыта"	, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаРазность", 0);
	
	СтрОплата = РезСтруктураШаблон;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Заявка", Заявка);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаКонечныйОстаток, 0) КАК СуммаОстаток,
	               |	ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаПриход, 0) КАК СуммаПлан,
	               |	ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаРасход, 0) КАК СуммаФакт
	               |ИЗ
	               |	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.ОстаткиИОбороты(, , , , ДокументПланирования В (&Заявка)) КАК ПлРасходОстаткиИОбороты";

	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		СтрОплата.СуммаПлан    			= Выборка.СуммаПлан;
		СтрОплата.СуммаОплата    		= Выборка.СуммаФакт;
		СтрОплата.Разность 				= Выборка.СуммаОстаток;
		СтрОплата.СуммаДокументаПлан    = Выборка.СуммаПлан;
		СтрОплата.СуммаДокументаОплата  = Выборка.СуммаФакт;
		СтрОплата.СуммаДокументаРазность = Выборка.СуммаОстаток;
		
	КонецЕсли; 

	Возврат СтрОплата;
	
КонецФункции // ПолучитьОплатыПоЗаявке()

// Функция получает плановую и фактическую сумму оплат по позиции.
//
// Параметры:
//  Позиция			  - ДокументСсылка.бит_кзн_ПлатежнаяПозиция.
//
// Возвращаемое значение:
//   РезСтруктура: 	Структура.
//
Функция ПолучитьОплатыПоПозиции(Позиция) Экспорт

	
	РезСтруктураШаблон = Новый Структура;
	РезСтруктураШаблон.Вставить("СуммаПлан"				, 0);
	РезСтруктураШаблон.Вставить("СуммаОплата"			, 0);
	РезСтруктураШаблон.Вставить("СуммаЗакрыта"			, 0);
	РезСтруктураШаблон.Вставить("Разность"				, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаПлан"	, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаОплата"	, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаЗакрыта"	, 0);
	РезСтруктураШаблон.Вставить("СуммаДокументаРазность", 0);
	
	СтрОплата = РезСтруктураШаблон;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Позиция", Позиция);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаКонечныйОстаток, 0) КАК СуммаОстаток,
	               |	ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаПриход, 0) КАК СуммаПлан,
	               |	ЕСТЬNULL(ПлРасходОстаткиИОбороты.СуммаРасход, 0) КАК СуммаФакт
	               |ИЗ
	               |	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.ОстаткиИОбороты(, , , , Позиция = &Позиция) КАК ПлРасходОстаткиИОбороты";

	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		СтрОплата.СуммаПлан    			= Выборка.СуммаПлан;
		СтрОплата.СуммаОплата    		= Выборка.СуммаФакт;
		СтрОплата.Разность 				= Выборка.СуммаОстаток;
		СтрОплата.СуммаДокументаПлан    = Выборка.СуммаПлан;
		СтрОплата.СуммаДокументаОплата  = Выборка.СуммаФакт;
		СтрОплата.СуммаДокументаРазность = Выборка.СуммаОстаток;
		
	КонецЕсли; 

	Возврат СтрОплата;
	
КонецФункции // ПолучитьОплатыПоЗаявке()

