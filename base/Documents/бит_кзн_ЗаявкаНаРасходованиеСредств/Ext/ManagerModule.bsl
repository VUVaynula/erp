Функция ТекстЗапросаВыплатыПоВедомости(ТипДокументаВедомость)
	
	ТекстЗапроса = "";
	
	Если ТипДокументаВедомость = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыПеречислением") Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ВыплатыПоВедомости.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВыплатыПоВедомости.БанковскийСчет КАК БанковскийСчет,
		|	СУММА(ВыплатыПоВедомости.КВыплате) КАК КВыплате
		|ИЗ
		|	Документ.ВедомостьНаВыплатуЗарплатыПеречислением.Зарплата КАК ВыплатыПоВедомости
		|ГДЕ
		|	ВыплатыПоВедомости.Ссылка = &Ведомость
		|
		|СГРУППИРОВАТЬ ПО
		|	ВыплатыПоВедомости.ФизическоеЛицо,
		|	ВыплатыПоВедомости.БанковскийСчет";
	ИначеЕсли ТипДокументаВедомость = Тип("ДокументСсылка.ВедомостьПрочихДоходовВБанк") Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ВыплатыПоВедомости.ФизическоеЛицо КАК ФизическоеЛицо,
		|	NULL КАК БанковскийСчет,
		|	СУММА(ВыплатыПоВедомости.КВыплате) КАК КВыплате
		|ИЗ
		|	Документ.ВедомостьПрочихДоходовВБанк.Выплаты КАК ВыплатыПоВедомости
		|ГДЕ
		|	ВыплатыПоВедомости.Ссылка = &Ведомость
		|
		|СГРУППИРОВАТЬ ПО
		|	ВыплатыПоВедомости.ФизическоеЛицо";
	ИначеЕсли ТипДокументаВедомость = Тип("ДокументСсылка.ВедомостьПрочихДоходовПеречислением") Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ВыплатыПоВедомости.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВыплатыПоВедомости.БанковскийСчет КАК БанковскийСчет,
		|	СУММА(ВыплатыПоВедомости.КВыплате) КАК КВыплате
		|ИЗ
		|	Документ.ВедомостьПрочихДоходовПеречислением.Выплаты КАК ВыплатыПоВедомости
		|ГДЕ
		|	ВыплатыПоВедомости.Ссылка = &Ведомость
		|
		|СГРУППИРОВАТЬ ПО
		|	ВыплатыПоВедомости.ФизическоеЛицо,
		|	ВыплатыПоВедомости.БанковскийСчет";
