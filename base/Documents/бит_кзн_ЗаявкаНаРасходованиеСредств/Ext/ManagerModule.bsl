Процедура СоздатьПлатежныйДокумент(ПараметрыЗаполнения, Результат)
	
	Безналичные                 = ПараметрыЗаполнения.Безналичные;
	Ведомость                   = ПараметрыЗаполнения.Ведомость;
	ВедомостьВСписке            = ПараметрыЗаполнения.ВедомостьВСписке;
	ВидОперации                 = ПараметрыЗаполнения.ВидОперации;
	ДатаДокумента               = ПараметрыЗаполнения.ДатаДокумента;
	СуммыКОплате				= ПараметрыЗаполнения.СуммыКОплате;
	ЕстьНазначениеПлатежа       = ПараметрыЗаполнения.ЕстьНазначениеПлатежа;
	ЕстьПодразделение           = ПараметрыЗаполнения.ЕстьПодразделение;
	ЕстьТипПлатежногоДокумента  = ПараметрыЗаполнения.ЕстьТипПлатежногоДокумента;
	МенеджерПлатежногоДокумента = ПараметрыЗаполнения.МенеджерПлатежногоДокумента;
	ОбъединятьНазначениеПлатежа = ПараметрыЗаполнения.ОбъединятьНазначениеПлатежа;
	РеквизитыОснования          = ПараметрыЗаполнения.РеквизитыОснования;
	СценарийФакт                = ПараметрыЗаполнения.СценарийФакт;
	ЕстьДоговорЭквайринга 		= ПараметрыЗаполнения.ЕстьДоговорЭквайринга;
	ВалютаРеглУчета				= ПараметрыЗаполнения.ВалютаРеглУчета;

	Если ПараметрыЗаполнения.РежимЗаписиПлатДокумента = Перечисления.бит_РежимыЗаписиДокумента.Проведение Тогда
		РежимЗаписиПлатДокумента = РежимЗаписиДокумента.Проведение;
	Иначе
		РежимЗаписиПлатДокумента = РежимЗаписиДокумента.Запись;
	КонецЕсли;
	 
	ВсеПозиции 		 = СуммыКОплате.Позиции.ВыгрузитьКолонку("Позиция");
	РеквизитыПозиций = Документы.бит_кзн_ПлатежнаяПозиция.РеквизитыДокумента(ВсеПозиции);
	
	// Добавим колонку для 
	РеквизитыПозиций.Колонки.Добавить("СтатьяДвиженияДенежныхСредств");
	
	РезультатФормирования = Новый Структура("ОткрытьФорму, Ссылка, Позиции");
	ТекущийОбъект 		  = МенеджерПлатежногоДокумента.СоздатьДокумент();
	
	ЭтоПередачаДенег = ВидОперации = Перечисления.ХозяйственныеОперации.ВнутренняяПередачаДенежныхСредств 
				   ИЛИ ВидОперации = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствВДругуюОрганизацию
				   ИЛИ ВидОперации = Перечисления.ХозяйственныеОперации.ОплатаДенежныхСредствВДругуюОрганизацию;
	
	ТекущийОбъект.ХозяйственнаяОперация = ВидОперации;
	ТекущийОбъект.Дата					= ДатаДокумента;
			
	Если Безналичные Тогда                                                 
		Если РеквизитыОснования.ПлатежиПо275ФЗ Тогда
			Если ЗначениеЗаполнено(СуммыКОплате.БанковскийСчетКасса) Тогда
				ОтдельныйСчетГОЗ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СуммыКОплате.БанковскийСчетКасса, "ОтдельныйСчетГОЗ");
				Если ОтдельныйСчетГОЗ Тогда
					ТекущийОбъект.БанковскийСчет = СуммыКОплате.БанковскийСчетКасса;
				КонецЕсли; 
			КонецЕсли;
		Иначе
			ТекущийОбъект.БанковскийСчет = СуммыКОплате.БанковскийСчетКасса;
		КонецЕсли;

		Если ПараметрыЗаполнения.Свойство("БанковскийСчетКонтрагента") Тогда
			ТекущийОбъект.БанковскийСчетКонтрагента = ПараметрыЗаполнения.БанковскийСчетКонтрагента;
		ИначеЕсли РеквизитыОснования.ПлатежиПо275ФЗ Тогда
			Если ЗначениеЗаполнено(РеквизитыПозиций[0].БанковскийСчетПолучателя) Тогда
				ОтдельныйСчетГОЗ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РеквизитыПозиций[0].БанковскийСчетПолучателя, "ОтдельныйСчетГОЗ");
				Если ОтдельныйСчетГОЗ Тогда
					ТекущийОбъект.БанковскийСчетКонтрагента = РеквизитыПозиций[0].БанковскийСчетПолучателя;
				КонецЕсли; 
			КонецЕсли; 
		Иначе
			ТекущийОбъект.БанковскийСчетКонтрагента = РеквизитыПозиций[0].БанковскийСчетПолучателя;	
		КонецЕсли;
		
		ТекущийОбъект.СтатусСоставителя  = "01";
				
		СписокСвойств = Новый Массив;
		СписокСвойств.Добавить("ОчередностьПлатежа");
		СписокСвойств.Добавить("ВидПлатежа");
		СписокСвойств.Добавить("КодВыплат");	
		СписокСвойств.Добавить("ИННПлательщика");
		СписокСвойств.Добавить("КПППлательщика");
		СписокСвойств.Добавить("ТекстПлательщика");
		СписокСвойств.Добавить("ПеречислениеСотрудникуЧерезБанк");
		СписокСвойств.Добавить("СписокФизЛиц");
		СписокСвойств.Добавить("НомерДоговораСБанком");
		СписокСвойств.Добавить("ДатаДоговораСБанком");
		СписокСвойств.Добавить("ОтделениеБанка");
		СписокСвойств.Добавить("ФилиалОтделенияБанка");
		Если ЭтоПередачаДенег Тогда
			СписокСвойств.Добавить("БанковскийСчетПолучатель");		
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ТекущийОбъект, РеквизитыПозиций[0], СтрСоединить(СписокСвойств, ","));

		Для каждого Запись Из РеквизитыПозиций Цикл
			Если ЗначениеЗаполнено(Запись.ЛицевыеСчетаСотрудников) Тогда
				ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Запись.ЛицевыеСчетаСотрудников, 
					ТекущийОбъект.ЛицевыеСчетаСотрудников);			
			КонецЕсли;
		КонецЦикла;
	Иначе 
		ТекущийОбъект.Касса = СуммыКОплате.БанковскийСчетКасса;
		Если ЭтоПередачаДенег Тогда
			ТекущийОбъект.КассаПолучатель = РеквизитыПозиций[0].КассаПолучатель;
		КонецЕсли;
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("НДФЛПоВедомостям", ТекущийОбъект.Метаданные()) Тогда
		ТекущийОбъект.НДФЛПоВедомостям = ПараметрыЗаполнения.НДФЛПоВедомостям;
	КонецЕсли;
	
	бит_КазначействоПереопределяемый.ЗаполнитьПлатежныйДокумент(ТекущийОбъект, ПараметрыЗаполнения);

	Если ЕстьНазначениеПлатежа Тогда
		// ВАЖНО! "Назначение платежа" формируется окончательно перед записью документа.
		Если ОбъединятьНазначениеПлатежа Тогда
			НазначениеПлатежа = Новый Массив; 
			Для каждого Запись Из РеквизитыПозиций Цикл
				ТекстНазначение = Запись.НазначениеПлатежа;
				Если ПустаяСтрока(ТекстНазначение) И ЗначениеЗаполнено(ТекущийОбъект.БанковскийСчетКонтрагента) Тогда
					ТекстНазначение = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьРеквизитыБанковскогоСчета(
										ТекущийОбъект.БанковскийСчетКонтрагента).ТекстНазначения;
				КонецЕсли;
				Если ЗначениеЗаполнено(ТекстНазначение) Тогда
					ЧастиТекста = ЧастиТекстаНазначениеПлатежа(ТекстНазначение);
					НазначениеПлатежа.Добавить(ЧастиТекста.Назначение);
				КонецЕсли;
			КонецЦикла; 
			НазначениеПлатежа = ОбщегоНазначенияКлиентСервер.СвернутьМассив(НазначениеПлатежа);
			ТекущийОбъект.НазначениеПлатежа = СтрСоединить(НазначениеПлатежа, ", ");	
		Иначе
			ТекстНазначение = РеквизитыПозиций[0].НазначениеПлатежа;	
			Если ПустаяСтрока(ТекстНазначение) И ЗначениеЗаполнено(ТекущийОбъект.БанковскийСчетКонтрагента) Тогда
				ТекстНазначение = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьРеквизитыБанковскогоСчета(
									ТекущийОбъект.БанковскийСчетКонтрагента).ТекстНазначения;
			КонецЕсли;
			ЧастиТекста = ЧастиТекстаНазначениеПлатежа(ТекстНазначение);
			ТекущийОбъект.НазначениеПлатежа = ЧастиТекста.Назначение;
		КонецЕсли; 
	КонецЕсли; 
	
	РеквизитыПозиции = ЗначениеРеквизитовПозиции(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(РеквизитыПозиций[0]));
	ОпределитьСтатьюДДС(ТекущийОбъект, РеквизитыПозиции, ВидОперации, ТекущийОбъект.Дата);

	ИспользоватьПодразделения = ПолучитьФункциональнуюОпцию("ИспользоватьПодразделения");
	Если ЕстьПодразделение И ИспользоватьПодразделения Тогда
		ТекущийОбъект.Подразделение = РеквизитыПозиций[0].Подразделение;
	КонецЕсли;
	
	ВидОперацииБФ = бит_КазначействоКлиентСервер.ХозяйственнаяОперацияБФ(ВидОперации);
	ЕстьРасшифровкаПлатежа = НЕ бит_КазначействоКлиентСервер.ЭтоОперацияБезРасшифровкиПлатежа(ВидОперацииБФ);
	
	Если бит_КазначействоКлиентСервер.ЭтоРасчетыСФизЛицами(ВидОперацииБФ) Тогда
		ТекущийОбъект.ПодотчетноеЛицо = РеквизитыОснования.ФизЛицо;
	КонецЕсли; 
	
	ОперацияВыплатыЗарплаты = бит_КазначействоКлиентСервер.ЭтоОперацияВыплатыЗарплаты(ВидОперацииБФ);
	ЗаполнятьВедомость      = ОперацияВыплатыЗарплаты ИЛИ ПараметрыЗаполнения.НДФЛПоВедомостям;
	
	Если ЗаполнятьВедомость И НЕ ВедомостьВСписке Тогда
		ТекущийОбъект.Ведомость = Ведомость;	
	КонецЕсли;
	
	ИспользоватьПартнеровИКонтрагентов = ПолучитьФункциональнуюОпцию("ИспользоватьПартнеровИКонтрагентов");
	
	ТекущийОбъект.Организация = РеквизитыОснования.Организация;
	ТекущийОбъект.Контрагент  = РеквизитыОснования.Контрагент;
	
	Если ЕстьТипПлатежногоДокумента Тогда
		ТекущийОбъект.ТипПлатежногоДокумента = Перечисления.ТипыПлатежныхДокументов.ПлатежноеПоручение;
	КонецЕсли; 
	
	// Шапку документа из позиций.
	ПлатежнаяПозиция = РеквизитыПозиций[0]; 
	
	ТекущийОбъект.Валюта		  = ПлатежнаяПозиция.ВалютаДенежныхСредств;
	ТекущийОбъект.КурсКонвертации = ПлатежнаяПозиция.КурсЧислительВзаиморасчетов;
	
	Если ЕстьДоговорЭквайринга Тогда
		ТекущийОбъект.ДоговорЭквайринга = ПлатежнаяПозиция.ДоговорЭквайринга;
	КонецЕсли;
	
	Партнер = ДенежныеСредстваСервер.ПолучитьПартнераПоКонтрагенту(ТекущийОбъект.Контрагент, 
									ТекущийОбъект.ХозяйственнаяОперация);

	Дополнительно = Новый Структура;
	Дополнительно.Вставить("ЕстьПодразделение", 				 ЕстьПодразделение);
	Дополнительно.Вставить("ИспользоватьПодразделения", 		 ИспользоватьПодразделения);
	Дополнительно.Вставить("ВедомостьВСписке", 					 ВедомостьВСписке);
	Дополнительно.Вставить("ЗаполнятьВедомость", 				 ЗаполнятьВедомость);
	Дополнительно.Вставить("ВалютаРеглУчета", 	 				 ВалютаРеглУчета);
	Дополнительно.Вставить("ИспользоватьПартнеровИКонтрагентов", ИспользоватьПартнеровИКонтрагентов);
	Дополнительно.Вставить("Партнер",							 Партнер);
	
	ПодготовитьРасшифровкуПлатежа(РеквизитыПозиций, СуммыКОплате, ТекущийОбъект, Дополнительно);
		
	ТекущийОбъект.СуммаДокумента = ТекущийОбъект.РасшифровкаПлатежа.Итог("Сумма");
	
	Если НЕ ЕстьРасшифровкаПлатежа Тогда
		ТекущийОбъект.РасшифровкаПлатежа.Очистить();
	КонецЕсли;
			
	// Платежи по 275-ФЗ
	Если РеквизитыОснования.ПлатежиПо275ФЗ Тогда
		ТекущийОбъект.ПлатежиПо275ФЗ	= Истина;
		ТекущийОбъект.ТипПлатежаФЗ275	= РеквизитыОснования.ТипПлатежаФЗ275;
		ТекущийОбъект.ДоговорСЗаказчиком= РеквизитыОснования.ДоговорСЗаказчиком;
		ТекущийОбъект.Договор			= РеквизитыОснования.ДоговорСЗаказчиком;
	Иначе
		Если НЕ ЗначениеЗаполнено(ПлатежнаяПозиция.ОбъектРасчетов) Тогда
			ТекущийОбъект.Договор				  = ПлатежнаяПозиция.Договор;
			ТекущийОбъект.ГруппаФинансовогоУчета  = ПлатежнаяПозиция.ГруппаФинансовогоУчета;
			ТекущийОбъект.НаправлениеДеятельности = ПлатежнаяПозиция.НаправлениеДеятельности;
		КонецЕсли;
	КонецЕсли; 
	
	ЗаполнитьЗначенияСвойств(ТекущийОбъект, РеквизитыПозиций[0], 
		"НомерВедомостиНаВыплатуЗарплаты, ДатаВедомостиНаВыплатуЗарплаты");
	
	// Налоговые реквизиты
	Если Безналичные Тогда
		
		ЗаполнитьЗначенияСвойств(ТекущийОбъект, РеквизитыПозиций[0], 
			"ИдентификаторПлатежа, КодВидаДохода, ДатаАвансовогоОтчета");
		
		Если РеквизитыПозиций[0].ПеречислениеВБюджет Тогда
			ИменаРеквизитов = "ВидПеречисленияВБюджет, НастройкаСчетовУчета, КодБК, КодОКАТО,"
						  "ПоказательОснования, ПоказательПериода, ПоказательНомера, ПоказательДаты, ПоказательТипа,"
						  "СтатусСоставителя, ПеречислениеВБюджет, ТипНалога, ИдентификаторПлатежа, КодВидаДохода,"
						  "ДатаАвансовогоОтчета";
			ЗаполнитьЗначенияСвойств(ТекущийОбъект, РеквизитыПозиций[0], ИменаРеквизитов);
		КонецЕсли; 
		
		Если ВидОперации = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет Тогда
			ТекущийОбъект.ТипНалога = РеквизитыПозиций[0].ТипНалога;
			Если Не бит_ОбщегоНазначения.ЭтоУТ() Тогда
				МодульНастройкаСчетовУчетаСервер   = ОбщегоНазначения.ОбщийМодуль("НастройкаСчетовУчетаСервер");
				ТекущийОбъект.НастройкаСчетовУчета = МодульНастройкаСчетовУчетаСервер.КопияНастройкиСчетовУчета(РеквизитыПозиций[0].НастройкаСчетовУчета);
			КонецЕсли;
		КонецЕсли; 
		
		Если ТекущийОбъект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет Тогда
			РеквизитыПлательщика = ДенежныеСредстваСерверЛокализация.РеквизитыПлательщика(ТекущийОбъект);
			Если НЕ ЗначениеЗаполнено(ТекущийОбъект.ИННПлательщика) Тогда
				ТекущийОбъект.ИННПлательщика = РеквизитыПлательщика.ИННПлательщика;
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(ТекущийОбъект.КПППлательщика) Тогда
				ТекущийОбъект.КПППлательщика = РеквизитыПлательщика.КПППлательщика;
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(ТекущийОбъект.ТекстПлательщика) Тогда
				ТекущийОбъект.ТекстПлательщика = РеквизитыПлательщика.ТекстПлательщика;
			КонецЕсли;
		КонецЕсли;

	КонецЕсли; 
	
	Если ЕстьНазначениеПлатежа И ЕстьРасшифровкаПлатежа Тогда
		ДобавитьСуммуДокумента = РеквизитыПозиций.Количество() > 1 И ОбъединятьНазначениеПлатежа;
		ТекстСумма = "";							 
		Если НЕ ЗначениеЗаполнено(ТекущийОбъект.НазначениеПлатежа) ИЛИ ДобавитьСуммуДокумента Тогда
			ТекстСумма  = СтрШаблон(НСтр("ru = 'Сумма %1'; en = 'Amount %1'") , 
								Формат(ТекущийОбъект.СуммаДокумента, "ЧДЦ=2; ЧРД=-; ЧН=0-00; ЧГ="));
			ТекстСумма = Символы.ПС + ТекстСумма;					
		КонецЕсли;
		ТекстСуммаНДС = ДенежныеСредстваСервер.ТекстСуммаНДСПлатежа(ТекущийОбъект.Организация, ТекущийОбъект.Валюта, ТекущийОбъект.РасшифровкаПлатежа, Истина);
		ТекущийОбъект.НазначениеПлатежа = ТекущийОбъект.НазначениеПлатежа + ТекстСумма + Символы.ПС + ТекстСуммаНДС;
	КонецЕсли; 
	
	// Если сумма по всем позициям этого документа нулевая то не открываем форму.
	РезультатФормирования.ОткрытьФорму = ТекущийОбъект.СуммаДокумента <> 0;
	
	РежимСообщений = "Ошибки";
	
	Если ТекущийОбъект.СуммаДокумента = 0 Тогда
		Успешно = Ложь;
	Иначе	
		Успешно = бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ТекущийОбъект, РежимЗаписиДокумента.Запись,, РежимСообщений);		
	КонецЕсли;
	
	Если Успешно Тогда
		
		Документы.бит_ОтражениеФактаДДС.ЗаполнитьОтражениеФактаПоДокументамПланирования(ТекущийОбъект, СуммыКОплате.Позиции, СценарийФакт);
		
		Для каждого СтрокаТаблицы Из СуммыКОплате.Позиции Цикл
			НоваяСтрока = Результат.Добавить(); 			
			НоваяСтрока.Позиция		   = СтрокаТаблицы.Позиция;
			НоваяСтрока.ДокументОплаты = ТекущийОбъект.Ссылка;
		КонецЦикла;
		
		Если РежимЗаписиПлатДокумента = РежимЗаписиДокумента.Проведение
			И бит_Казначейство.ПроверитьЗаполнениеПлатежногоДокумента(ТекущийОбъект, РежимЗаписиПлатДокумента, Ложь) Тогда 				
			бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ТекущийОбъект, РежимЗаписиДокумента.Проведение);			
		КонецЕсли; 
	КонецЕсли;
	
КонецПроцедуры

Процедура ПодготовитьРасшифровкуПлатежа(ДанныеПозиций, СуммыКОплате, ТекущийОбъект, Дополнительно)
	
	ЕстьПодразделение		  = Дополнительно.ЕстьПодразделение;
	ИспользоватьПодразделения = Дополнительно.ИспользоватьПодразделения;
	ВедомостьВСписке 		  = Дополнительно.ВедомостьВСписке;
	ЗаполнятьВедомость		  = Дополнительно.ЗаполнятьВедомость;
	ВалютаРеглУчета			  = Дополнительно.ВалютаРеглУчета;

	РасшифровкаПлатежа = ТекущийОбъект.РасшифровкаПлатежа.Выгрузить();
	РасшифровкаПлатежа.Колонки.Добавить("Позиция");
	
	Для каждого ПлатежнаяПозиция Из ДанныеПозиций Цикл

		ОбъектРасчетов = ?(ЗначениеЗаполнено(ПлатежнаяПозиция.ОбъектРасчетов), ПлатежнаяПозиция.ОбъектРасчетов, ПлатежнаяПозиция.Договор);	
		СуммаКОплате   = СуммыКОплате.Позиции.Найти(ПлатежнаяПозиция.Ссылка, "Позиция").Сумма;
		
		Если ПлатежнаяПозиция.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа Тогда
			
			Коэффициенты = бит_Казначейство.ПолучитьКоэффициентыПересчетаВалюты(ПлатежнаяПозиция.ВалютаДокумента,
								ПлатежнаяПозиция.ВалютаВзаиморасчетов, ТекущийОбъект.Дата, ПлатежнаяПозиция.Организация,,, ОбъектРасчетов);
								
			Сумма				= СуммаКОплате;
			СуммаВзаиморасчетов = Сумма * Коэффициенты.КоэффициентПересчетаВВалютуВзаиморасчетов;
			СуммаНДС			= ПлатежнаяПозиция.СуммаНДС;
		Иначе
			
			Коэффициенты = бит_Казначейство.ПолучитьКоэффициентыПересчетаВалюты(ПлатежнаяПозиция.ВалютаДокумента,
							ПлатежнаяПозиция.ВалютаДенежныхСредств, ТекущийОбъект.Дата, ПлатежнаяПозиция.Организация,,, ОбъектРасчетов);
			
			СуммаВзаиморасчетов = СуммаКОплате;
			Сумма				= СуммаВзаиморасчетов * Коэффициенты.КоэффициентПересчетаВВалютуВзаиморасчетов;
			СуммаНДС 			= РасчитатьСуммуНДС(Сумма, ПлатежнаяПозиция.СтавкаНДС);
			
		КонецЕсли;
			
		НоваяСтрока = РасшифровкаПлатежа.Добавить();
		
		НоваяСтрока.ВалютаВзаиморасчетов 		  = ПлатежнаяПозиция.ВалютаВзаиморасчетов;
		НоваяСтрока.СуммаВзаиморасчетов  		  = СуммаВзаиморасчетов;
		НоваяСтрока.Сумма 						  = Сумма;
				
		НоваяСтрока.СтавкаНДС = ПлатежнаяПозиция.СтавкаНДС;
		НоваяСтрока.СуммаНДС  = СуммаНДС;
		
		РеквизитыПозиции = ЗначениеРеквизитовПозиции(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ПлатежнаяПозиция));
		ОпределитьСтатьюДДС(НоваяСтрока, РеквизитыПозиции, ТекущийОбъект.ХозяйственнаяОперация, ТекущийОбъект.Дата);
		
		Если ЕстьПодразделение И ИспользоватьПодразделения Тогда
			НоваяСтрока.Подразделение = ПлатежнаяПозиция.Подразделение;
		КонецЕсли;
		
		Если ВедомостьВСписке И ЗаполнятьВедомость Тогда
			НоваяСтрока.Ведомость = ПлатежнаяПозиция.Ведомость;
		КонецЕсли;
		
		Если ТекущийОбъект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыдачаЗаймаСотруднику Тогда
			НоваяСтрока.ДоговорЗаймаСотруднику = ПлатежнаяПозиция.ДоговорЗаймаСотруднику;
		КонецЕсли; 
		
		НоваяСтрока.ДоговорКредитаДепозита	 = ПлатежнаяПозиция.ДоговорКредитаДепозита;
		НоваяСтрока.ДоговорАренды 			 = ПлатежнаяПозиция.ДоговорАренды;
		НоваяСтрока.ТипПлатежаПоАренде 	 	 = ПлатежнаяПозиция.ТипПлатежаПоАренде;
		НоваяСтрока.СтатьяРасходов 	  		 = ПлатежнаяПозиция.СтатьяРасходов;
		НоваяСтрока.АналитикаРасходов 		 = ПлатежнаяПозиция.АналитикаРасходов;
		НоваяСтрока.АналитикаАктивовПассивов = ПлатежнаяПозиция.АналитикаАктивовПассивов;
		НоваяСтрока.ОбъектРасчетов 			 = ПлатежнаяПозиция.ОбъектРасчетов; 
		
		Если Дополнительно.ИспользоватьПартнеровИКонтрагентов Тогда
			НоваяСтрока.Партнер	= ПлатежнаяПозиция.Партнер;
		Иначе	
			НоваяСтрока.Партнер	= Дополнительно.Партнер;
		КонецЕсли;
		
		Если ТекущийОбъект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПрочаяВыдачаДенежныхСредств Тогда  
			НоваяСтрока.Подразделение = ПлатежнаяПозиция.Подразделение;
		КонецЕсли;
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(НоваяСтрока, "ТипСуммыКредитаДепозита") Тогда
			НоваяСтрока.ТипСуммыКредитаДепозита = ПлатежнаяПозиция.ТипСуммыКредитаДепозита;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НоваяСтрока.ДоговорАренды) Тогда
			РеквизитыДоговораАренды = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(НоваяСтрока.ДоговорАренды, 
										"СтатьяДвиженияДенежныхСредств");
			НоваяСтрока.СтатьяДвиженияДенежныхСредств = РеквизитыДоговораАренды.СтатьяДвиженияДенежныхСредств;
			НоваяСтрока.ТипПлатежаПоАренде			  = Перечисления.ТипыПлатежейПоАренде.УслугаПоАренде;
		КонецЕсли;

		КурсИКратность = ДенежныеСредстваСервер.КурсЧислительИКурсЗнаменательВзаиморасчетов(
							ТекущийОбъект.Валюта, НоваяСтрока.ВалютаВзаиморасчетов, ВалютаРеглУчета, 
							ТекущийОбъект.Дата, НоваяСтрока.ОбъектРасчетов, ПлатежнаяПозиция.Договор);
			
		НоваяСтрока.КурсЧислительВзаиморасчетов   = КурсИКратность.КурсЧислитель;
		НоваяСтрока.КурсЗнаменательВзаиморасчетов = КурсИКратность.КурсЗнаменатель;
		
		НоваяСтрока.Позиция = ПлатежнаяПозиция.Ссылка;
	КонецЦикла; 

	КолонкиГруппировок = ГруппировкиДляРасшифровкиПлатежа(РасшифровкаПлатежа);
	КолонкиРесурсов	   = "СуммаВзаиморасчетов, Сумма, СуммаНДС";
	
	ИтоговаяРасшифровкаПлатежа = РасшифровкаПлатежа.Скопировать();
	ИтоговаяРасшифровкаПлатежа.ЗаполнитьЗначения(0, "СуммаВзаиморасчетов");
	ИтоговаяРасшифровкаПлатежа.ЗаполнитьЗначения(0, "Сумма");
	ИтоговаяРасшифровкаПлатежа.ЗаполнитьЗначения(0, "СуммаНДС");
	
	ИтоговаяРасшифровкаПлатежа.Свернуть(СтрСоединить(КолонкиГруппировок, ",") + ", ИдентификаторСтроки", КолонкиРесурсов);
	
	Для каждого СтрокаТаблицы Из ИтоговаяРасшифровкаПлатежа Цикл
		
		ПараметрыПоиска = Новый Структура(СтрСоединить(КолонкиГруппировок, ","));
		ЗаполнитьЗначенияСвойств(ПараметрыПоиска, СтрокаТаблицы);
		РезультатПоиска  = РасшифровкаПлатежа.НайтиСтроки(ПараметрыПоиска);
		
		СвязанныеПозиции = Новый Массив;
		Для каждого Запись Из РезультатПоиска Цикл
			СтрокаТаблицы.СуммаВзаиморасчетов = СтрокаТаблицы.СуммаВзаиморасчетов + Запись.СуммаВзаиморасчетов;
			СтрокаТаблицы.Сумма				  = СтрокаТаблицы.Сумма + Запись.Сумма;
			СтрокаТаблицы.СуммаНДС			  = СтрокаТаблицы.СуммаНДС + Запись.СуммаНДС;
			СвязанныеПозиции.Добавить(Запись.Позиция);
		КонецЦикла;
		СтрокаТаблицы.ИдентификаторСтроки = Новый УникальныйИдентификатор();
		Для каждого Позиция Из СвязанныеПозиции Цикл
			РезультатПоискаПозиций = СуммыКОплате.Позиции.Найти(Позиция, "Позиция");
			РезультатПоискаПозиций.ИдентификаторСтроки = СтрокаТаблицы.ИдентификаторСтроки;
		КонецЦикла;
	КонецЦикла;
	
	ТекущийОбъект.РасшифровкаПлатежа.Загрузить(ИтоговаяРасшифровкаПлатежа);
		
КонецПроцедуры

Функция ГруппировкиДляРасшифровкиПлатежа(РасшифровкаПлатежа)
	
	// Весь набор.
	Группировки = Новый Массив;
	Группировки.Добавить("ВалютаВзаиморасчетов");
	Группировки.Добавить("СтавкаНДС");
	Группировки.Добавить("Ведомость");
	Группировки.Добавить("ДоговорЗаймаСотруднику");
	Группировки.Добавить("ДоговорКредитаДепозита");
	Группировки.Добавить("ДоговорАренды");
	Группировки.Добавить("ТипПлатежаПоАренде");
	Группировки.Добавить("СтатьяРасходов");
	Группировки.Добавить("АналитикаРасходов");
	Группировки.Добавить("АналитикаАктивовПассивов");
	Группировки.Добавить("ОбъектРасчетов");
	Группировки.Добавить("Партнер");
	Группировки.Добавить("Подразделение");
	Группировки.Добавить("ТипСуммыКредитаДепозита");
	
	Группировки.Добавить("СтатьяДвиженияДенежныхСредств");
	Группировки.Добавить("КурсЧислительВзаиморасчетов");
	Группировки.Добавить("КурсЗнаменательВзаиморасчетов");
	
	// У некоторых документов колонки отсутствуют.
	Индекс = Группировки.ВГраница();
	Пока Индекс >= 0 Цикл
	    ИмяКолонки = Группировки.Получить(Индекс);
		Если РасшифровкаПлатежа.Колонки.Найти(ИмяКолонки) = Неопределено Тогда
			Группировки.Удалить(Индекс);		
		КонецЕсли;                      		
	 	Индекс = Индекс - 1;
	КонецЦикла;             
	
	Возврат Группировки;
	
КонецФункции

// Функция определяет есть ли в аналитиках проект.
//
Функция ОпределитьПроект(Выборка)

	н=0;
	Для н=н+1 По 7 Цикл
		
		Аналитика = Выборка["Аналитика_"+н];
		Если ТипЗнч(Аналитика) = Тип("СправочникСсылка.Проекты") Тогда
		
			Проект = Аналитика;
		
		КонецЕсли; 
	
	КонецЦикла; 
	
	Возврат Проект;
	
КонецФункции // ОпределитьПроект()

Функция РасчитатьСуммуНДС(Сумма, СтавкаНДС)

	ЗначениеСтавки = бит_БухгалтерскийУчет.ПолучитьСтавкуНДС(СтавкаНДС);
	СуммаНДС 	   = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(Сумма,
							Истина, Истина, ЗначениеСтавки);
	Возврат СуммаНДС;
	
КонецФункции

Процедура ОпределитьСтатьюДДС(ДанныеЗаполнения, РеквизитыПозиции, ВидОперации, ДатаДокумента)

	ДоговорКонтрагента = РеквизитыПозиции.ДоговорКонтрагента;
	Если ЗначениеЗаполнено(ДоговорКонтрагента) Тогда
		СтатьяДДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДоговорКонтрагента, "СтатьяДвиженияДенежныхСредств");
		Если ЗначениеЗаполнено(СтатьяДДС) Тогда
			ДанныеЗаполнения.СтатьяДвиженияДенежныхСредств = СтатьяДДС;
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	СтатьяОборотов = РеквизитыПозиции.СтатьяОборотов;
	Если ЗначениеЗаполнено(СтатьяОборотов) Тогда
		СтатьяДДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтатьяОборотов, "ОсновнаяСтатьяДДС");
		Если ЗначениеЗаполнено(СтатьяДДС) Тогда
			ДанныеЗаполнения.СтатьяДвиженияДенежныхСредств = СтатьяДДС;
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	СтатьиДДС = РегистрыСведений.бит_СоответствияАналитик.ПолучитьЛевуюАналитику(
						ПредопределенноеЗначение("Справочник.бит_ВидыСоответствийАналитик.СтатьиДДС_СтатьиОборотов"),
						СтатьяОборотов, ДатаДокумента);

	Если ЗначениеЗаполнено(СтатьиДДС) Тогда
		ДанныеЗаполнения.СтатьяДвиженияДенежныхСредств = СтатьиДДС[0];
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(ДанныеЗаполнения.СтатьяДвиженияДенежныхСредств) Тогда
		Кандидат = Справочники.СтатьиДвиженияДенежныхСредств.СтатьяДвиженияДенежныхСредствПоХозяйственнойОперации(ВидОперации);
		Если ЗначениеЗаполнено(Кандидат) Тогда
			ДанныеЗаполнения.СтатьяДвиженияДенежныхСредств = Кандидат;
		КонецЕсли;	
	КонецЕсли; 

КонецПроцедуры

Функция ЗначениеРеквизитовПозиции(ПлатежнаяПозиция)
	
	Если ТипЗнч(ПлатежнаяПозиция) = Тип("Структура") Тогда
		ДокументПозиции = ПлатежнаяПозиция.Позиция;
	Иначе
		ДокументПозиции = ПлатежнаяПозиция;
	КонецЕсли;
	
	РеквизитыПозиции = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументПозиции, "СтатьяОборотов, ЦФО, ОбъектРасчетов, Договор");
	
	ОбъектРасчетов = РеквизитыПозиции.ОбъектРасчетов;
	
	ДоговорКонтрагента = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	Если ТипЗнч(ОбъектРасчетов) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		ДоговорКонтрагента = ОбъектРасчетов;
	ИначеЕсли ЗначениеЗаполнено(ОбъектРасчетов) Тогда
		МетаданныеОбъектаРасчетов = ОбъектРасчетов.Метаданные();
		Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ДоговорКонтрагента", МетаданныеОбъектаРасчетов) Тогда
			ДоговорКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектРасчетов, "ДоговорКонтрагента");
		ИначеЕсли ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор", МетаданныеОбъектаРасчетов) Тогда
			ДоговорКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектРасчетов, "Договор");
		КонецЕсли;
	Иначе
		ДоговорКонтрагента = РеквизитыПозиции.Договор;
	КонецЕсли;
	РеквизитыПозиции.Вставить("ДоговорКонтрагента", ДоговорКонтрагента);
	
	Возврат РеквизитыПозиции;
	
КонецФункции

// Разбивает текст назначения платежа на части.
//
// Параметры:
//  НазначениеПлатежа	 - Строка - назначения платежа для обработки.
// 
// Возвращаемое значение:
// 	ЧастиТекста  - Структура. 
//					* Назначение - строка - описательнрая часть.
//					* Суммы		 - строка - сумма и сумма НДС.
//
Функция ЧастиТекстаНазначениеПлатежа(НазначениеПлатежа)
	
	ТекстНазначение = "";
	ТекстСуммы		= "";
	
	Если НЕ ПустаяСтрока(НазначениеПлатежа) Тогда
		// Решено для экспремента отказаться от поиска слова "сумма" потому, что
		// назначение платежа, введенное руками начинают с этого слова.
		// ПозицияСумма = СтрНайти(НазначениеПлатежа, "Сумма");
		ПозицияСумма = 0;
		
		Если ПозицияСумма = 0 Тогда // для совместимости, при редактировании старых платежек
			ПозицияСумма = СтрНайти(НазначениеПлатежа, "В т.ч. НДС");
			Если ПозицияСумма = 0 Тогда
				ПозицияСумма = СтрНайти(НазначениеПлатежа, "Без налога (НДС)");
			КонецЕсли;
			Если ПозицияСумма = 0 Тогда
				ПозицияСумма = СтрНайти(НазначениеПлатежа, "НДС не облагается");
			КонецЕсли;
		КонецЕсли;
		
		ТекстНазначение = ?(ПозицияСумма = 0, НазначениеПлатежа, Лев(НазначениеПлатежа, ПозицияСумма - 1));
		Если Прав(ТекстНазначение, 1) = Символы.ПС Тогда
			ТекстНазначение = Лев(ТекстНазначение, СтрДлина(ТекстНазначение) - 1);
		КонецЕсли;
		ТекстСуммы = СтрЗаменить(НазначениеПлатежа, ТекстНазначение, "");
		Если Лев(ТекстСуммы, 1) = Символы.ПС Тогда
			ТекстСуммы = Сред(ТекстСуммы, 2);
		КонецЕсли;
	КонецЕсли;

	ЧастиТекста = Новый Структура; 
	ЧастиТекста.Вставить("Назначение", ТекстНазначение);
	ЧастиТекста.Вставить("Суммы", ТекстСуммы);
	
	Возврат ЧастиТекста;

КонецФункции

