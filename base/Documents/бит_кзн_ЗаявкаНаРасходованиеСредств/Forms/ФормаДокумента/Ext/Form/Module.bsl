&НаКлиенте
Процедура ОплатаЗаСчет(Команда)
	
	Если НЕ ЭтоАдресВременногоХранилища(АдресДанныхДляКорректировки) Тогда
		Возврат;
	КонецЕсли;
	
	Если Модифицированность Тогда
		Оповещение = Новый ОписаниеОповещения("ОплатаЗаСчетПродолжение", ЭтотОбъект); 
		ТекстВопроса = НСтр("ru = 'Операция возможна только после записи документа. Записать?'; 
							  |en = 'This operation is only possible after writing the document. Write it down?'");
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);			
	Иначе
		ОплатаЗаСчетЗавершение();
	КонецЕсли;	
		
КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте 
Процедура ОплатаЗаСчетПродолжение(Результат, ДополнительныеДанные) Экспорт
		
	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли; 
	
	Если ПроверитьЗаполнение() Тогда
		Попытка
			Записать();		
		Исключение
			ВызватьИсключение ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки; 
	КонецЕсли; 
	
	ОплатаЗаСчетЗавершение();
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаНаСогласование(Команда)
	
	Объект.ОтправленНаСогласование = НЕ Объект.ОтправленНаСогласование;
	Отказ = Ложь;
	Попытка
		Записать();
	Исключение
		Отказ = Истина;
		ТекстСообщения = НСтр("ru = 'Не удалось записать документ по причине: %1.'; 
							|en = 'The document could not be recorded due to:'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ПоказатьПредупреждение(, ТекстСообщения);
	КонецПопытки;
	
	Если Отказ Тогда
		Объект.ОтправленНаСогласование = НЕ Объект.ОтправленНаСогласование;
	Иначе
		Если НЕ Объект.ОтправленНаСогласование  Тогда
			ОчиститьВсеВизы();
		КонецЕсли; 
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ВвестиПлатежныеДокументы(Команда)
	
	Если Модифицированность Тогда
		Записать();
	КонецЕсли;

	НовыеДокументы = СоздатьПлатежныеДокументы();
	
	Для каждого Документ Из НовыеДокументы Цикл
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(Документ));
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВвестиПлатежныеДокументыВыделенные(Команда)
	
	Если ЭтотОбъект.Модифицированность Тогда
		Записать();
	КонецЕсли;

	ВыделенныеСтроки = Элементы.ТаблицаПлатежи.ВыделенныеСтроки;
	НовыеДокументы   = СоздатьПлатежныеДокументыВыделенные(ВыделенныеСтроки);
	
	Для каждого Документ Из НовыеДокументы Цикл
		ПерейтиПоНавигационнойСсылке(ПолучитьНавигационнуюСсылку(Документ));
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаУдалитьПозицию(Команда)
	
	ТекущиеДанные = Элементы.ТаблицаПлатежи.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекстСообщения = НСтр("ru='Удалить документ?';en='Delete a document?'");
	Оповещение 	   = Новый ОписаниеОповещения("КомандаУдалитьПозициюЗавершение", ЭтотОбъект); 
	ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет)
	
КонецПроцедуры

