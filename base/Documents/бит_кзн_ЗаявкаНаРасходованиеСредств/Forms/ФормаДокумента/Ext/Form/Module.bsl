&НаСервере
Процедура ЗаполнитьПодтверждающиеДокументыНаСервере()
	
	бит_КазначействоПереопределяемый.ЗаполнитьПодтверждающиеДокументы(Объект, УникальныйИдентификатор);
	
КонецПроцедуры

//  Процедура при изменении флага ПлатежиПо275ФЗ на сервере. 
//
&НаСервере
Процедура ПлатежиПо275ФЗПриИзмененииНаСервере()

	Если ЭтоУТ Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.ПлатежиПо275ФЗ Тогда
		Объект.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
	КонецЕсли; 
	
	УстановитьПараметрыВыбораДоговораСЗаказчиком(Истина);
	
	Если Объект.ПлатежиПо275ФЗ И ЗначениеЗаполнено(Объект.ДоговорСЗаказчиком)
		И ТипЗнч(Объект.ДоговорСЗаказчиком) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.ДоговорСЗаказчиком,
			"ДоговорСУчастникомГОЗ, ОплатаРасходовПоТарифамСГосрегулированием,
			|ГосударственныйКонтракт, ИностранныйИсполнительВУтвержденномПеречнеГОЗ");
		ЗаполнитьЗначенияСвойств(Объект, ЗначенияРеквизитов, "ДоговорСУчастникомГОЗ");
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ЗначенияРеквизитов,
			"ОплатаРасходовПоТарифамСГосрегулированием, ИностранныйИсполнительВУтвержденномПеречнеГОЗ, ГосударственныйКонтракт");
	КонецЕсли;
	
	ПроверитьЗаполнитьТипПлатежа275ФЗ();
	ЗаполнитьПредметыОплаты();	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПредметыОплаты()
	
	бит_КазначействоПереопределяемый.ЗаполнитьПредметыОплаты(Элементы.ПредметОплаты,
		Объект.ТипПлатежаФЗ275, ТоварыРаботыУслугиСТарифнымРегулированием);
	
КонецПроцедуры

//  Процедура получает реквизиты объекта подтверждающего документа. 
//
&НаСервере
Функция РеквизитыПодтверждающегоДокумента(ПодтверждающийДокумент)
	
	РеквизитыОбъекта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПодтверждающийДокумент, "Зашифрован, Редактирует");
	
	ФайлРедактируется = ЗначениеЗаполнено(РеквизитыОбъекта.Редактирует)
		И РеквизитыОбъекта.Редактирует = Пользователи.ТекущийПользователь();
	РеквизитыОбъекта.Вставить("ФайлРедактируется", ФайлРедактируется);
	
	Возврат РеквизитыОбъекта;
	
КонецФункции

//  Процедура получает данные файла в подтвеждающем документе.
//
&НаСервереБезКонтекста
Функция ПолучитьДанныеФайла(Знач ПрисоединенныйФайл,
                            Знач ИдентификаторФормы = Неопределено,
                            Знач ПолучатьСсылкуНаДвоичныеДанные = Истина)
	
	Возврат РаботаСФайламиСлужебныйВызовСервера.ПолучитьДанныеФайла(
		ПрисоединенныйФайл, ИдентификаторФормы, ПолучатьСсылкуНаДвоичныеДанные);
	
КонецФункции

&НаСервере
Процедура ДоговорСЗаказчикомПриИзмененииНаСервере()
	
	Если Объект.ПлатежиПо275ФЗ
		И ТипЗнч(Объект.ДоговорСЗаказчиком) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.ДоговорСЗаказчиком,
			"ДоговорСУчастникомГОЗ, ОплатаРасходовПоТарифамСГосрегулированием,
			|ГосударственныйКонтракт, ИностранныйИсполнительВУтвержденномПеречнеГОЗ");
		ЗаполнитьЗначенияСвойств(Объект, ЗначенияРеквизитов, "ДоговорСУчастникомГОЗ");
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ЗначенияРеквизитов,
			"ОплатаРасходовПоТарифамСГосрегулированием, ИностранныйИсполнительВУтвержденномПеречнеГОЗ, ГосударственныйКонтракт");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗаполнитьТипПлатежа275ФЗ()
	
	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("ОплатаРасходовПоТарифамСГосрегулированием", ОплатаРасходовПоТарифамСГосрегулированием);
	ПараметрыЗаполнения.Вставить("ИностранныйИсполнительВУтвержденномПеречнеГОЗ",
									ИностранныйИсполнительВУтвержденномПеречнеГОЗ);
	ПараметрыЗаполнения.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
	бит_КазначействоПереопределяемый.ПроверитьЗаполнитьТипПлатежа275ФЗ(Объект, ПараметрыЗаполнения);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораДоговораСЗаказчиком(СброситьЗначение = Ложь)
	
	ВидОперации = Объект.ХозяйственнаяОперация;
	МассивПараметров = Новый Массив;
	НовыеПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
	Если Объект.ПлатежиПо275ФЗ Тогда
		Если ВидОперации = Перечисления.бит_ВидыОперацийКазначейства.ОплатаПоКредитам
			ИЛИ ВидОперации = Перечисления.бит_ВидыОперацийКазначейства.ПеречислениеНаДепозиты
			ИЛИ ВидОперации = Перечисления.бит_ВидыОперацийКазначейства.ВыдачаЗаймов Тогда
			
			ТекстСообщения = НСтр("ru = 'Для заявок списком, платеж за счет средств ГОЗ не поддерживается для операций по кредитам и депозитам.
									|Используйте обычный режим.';
									|en = 'For applications by list, payment of 275-FZ not supported for operations on loans and deposits.
									|Use normal mode.'");
			ВызватьИсключение ТекстСообщения;
		КонецЕсли;
		
		Если СброситьЗначение Тогда
			Объект.ДоговорСЗаказчиком = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
		КонецЕсли;
		
		Если НЕ Объект.Организация.Пустая() Тогда
			МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.Организация", Объект.Организация));
		КонецЕсли;
		
		МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.Статус", Перечисления.СтатусыДоговоровКонтрагентов.Действует));
		МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.ДоговорСУчастникомГОЗ",Истина));
		МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.ПометкаУдаления",Ложь));
		
		Если НЕ Объект.Контрагент.Пустая() Тогда
			МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.Контрагент", Объект.Контрагент));
		КонецЕсли;
		НовыеПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
		
		Элементы.ДоговорСЗаказчиком.ПараметрыВыбора = НовыеПараметрыВыбора;
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокВладельцевПодтверждающихДокументов()
	
	ОбновитьСписокВладельцевПодтверждающихДокументовНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСписокВладельцевПодтверждающихДокументовНаСервере()

	ОбъектОбъектаРасчетов = Неопределено;
	
	ВладельцыПодтверждающихДокументов.Очистить();
	
	РезультатПоиска    = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(Объект.Ссылка);
	СвязанныеДокументы = РезультатПоиска.МассивПозиций;
	РеквизитыПозиций   = Документы.бит_кзн_ПлатежнаяПозиция.РеквизитыДокумента(СвязанныеДокументы);
	
	ОбъектыРасшифровкиПлатежа = ОбъектыРасшифровкиПлатежа(РеквизитыПозиций);
	
	Для каждого СтрокаРасшифровки Из РеквизитыПозиций Цикл
		Если ЗначениеЗаполнено(СтрокаРасшифровки.ДоговорКредитаДепозита) Тогда
			ВладельцыПодтверждающихДокументов.Добавить(СтрокаРасшифровки.ДоговорКредитаДепозита);
		ИначеЕсли ЗначениеЗаполнено(СтрокаРасшифровки.ОбъектРасчетов) Тогда
			
			ОбъектРасчетов = ОбъектыРасшифровкиПлатежа.Получить(СтрокаРасшифровки.ОбъектРасчетов);
			
			Если (ТипЗнч(ОбъектРасчетов) = Тип("СправочникСсылка.ДоговорыКонтрагентов")
				Или ТипЗнч(ОбъектРасчетов) = Тип("СправочникСсылка.ДоговорыМеждуОрганизациями")) Тогда
				
				ВладельцыПодтверждающихДокументов.Добавить(ОбъектРасчетов);
				
			ИначеЕсли ЗначениеЗаполнено(СтрокаРасшифровки.Договор) Тогда
				
				ВладельцыПодтверждающихДокументов.Добавить(СтрокаРасшифровки.Договор);
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	// ++ НЕ УТ
	Если Объект.ТипПлатежаФЗ275 = ПредопределенноеЗначение("Справочник.ТипыПлатежейФЗ275.ПеречислениеПрибылиГоловномуИсполнителю")
	 ИЛИ Объект.ТипПлатежаФЗ275 = ПредопределенноеЗначение("Справочник.ТипыПлатежейФЗ275.ПеречисленияПрибылиИсполнителю")
	 ИЛИ Объект.ТипПлатежаФЗ275 = ПредопределенноеЗначение("Справочник.ТипыПлатежейФЗ275.СписаниеНаВозмещениеЗатратЗаСчетСобственныхСредств") Тогда
		
		Если ЗначениеЗаполнено(Объект.ДоговорСЗаказчиком) Тогда
			ВладельцыПодтверждающихДокументов.Добавить(Объект.ДоговорСЗаказчиком);
		КонецЕсли;
	КонецЕсли;
	// -- НЕ УТ

	Если ВладельцыПодтверждающихДокументов.Количество() > 1 Тогда
		УникальныеСсылки = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ВладельцыПодтверждающихДокументов.ВыгрузитьЗначения());
		ВладельцыПодтверждающихДокументов.ЗагрузитьЗначения(УникальныеСсылки);
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Функция ОбъектыРасшифровкиПлатежа(РасшифровкаПлатежа)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОбъектыРасчетов.Объект КАК Объект,
	|	ОбъектыРасчетов.Ссылка КАК ОбъектРасчетов
	|ИЗ 
	|	Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
	|ГДЕ
	|	ОбъектыРасчетов.Ссылка В (&МассивОбъектовРасчетов)
	|	И НЕ ОбъектыРасчетов.ПометкаУдаления";
	Запрос.УстановитьПараметр("МассивОбъектовРасчетов", РасшифровкаПлатежа.ВыгрузитьКолонку("ОбъектРасчетов"));
	Выборка = Запрос.Выполнить().Выбрать();
	
	Результат = Новый Соответствие;
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.ОбъектРасчетов,Выборка.Объект);
	КонецЦикла;
	
	Возврат Результат;	

КонецФункции

