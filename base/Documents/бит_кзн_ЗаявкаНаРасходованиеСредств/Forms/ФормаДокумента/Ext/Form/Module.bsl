#Область ОтображениеСтатистикиБюджета

&НаКлиенте
Процедура ОтобразитьБюджетСПаузой()
	
	ОтключитьОбработчикОжидания("ОтобразитьБюжет");
	ПодключитьОбработчикОжидания("ОтобразитьБюжет", 0.5, Истина);
	          	
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьБюжет()
	
	Если НЕ ОтображатьБюджет Тогда
		Возврат;
	КонецЕсли;
	
	ОтобразитьБюджетНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьБюджетНаСервере()
	
	ВыводитьСведенияОЛимитах = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
								"ВыводитьСведенияОЛимитахДляЗаявки");
	ВывестиСведенияОЛимитах(ВыводитьСведенияОЛимитах);
	
	ВыводитьСведенияОВзаиморасчетах = бит_УправлениеПользователямиСервер.ПолучитьЗначениеПоУмолчанию(
										"ВыводитьСведенияОВзаиморасчетахДляЗаявки");
	ВывестиСведенияОВзаиморасчетах(ВыводитьСведенияОВзаиморасчетах);
	
	Если НЕ ВыводитьСведенияОЛимитах И НЕ ВыводитьСведенияОВзаиморасчетах Тогда
		ТекстСообщения = НСтр("ru='Вывод сведений о лимитах и взаиморасчетах отключен в настройках пользователя'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		ОтображатьБюджет = Ложь;
		Если ОтображатьБюджетПриОткрытии Тогда
			УстановитьОтображениеБюджетаПриОткрытии(ЭтотОбъект, Ложь);	
		КонецЕсли;
		УправлениеФормой(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиСведенияОЛимитах(ВыводитьСведенияОЛимитах)
	
	Если НЕ ВыводитьСведенияОЛимитах
		ИЛИ НЕ ЗначениеЗаполнено(ИдентификаторТекущейСтрокиТабличнойЧасти) Тогда
		Элементы.ГруппаБюджет.Видимость = Ложь;
		Возврат;
	Иначе
		Элементы.ГруппаБюджет.Видимость = Истина;
	КонецЕсли;
	
	Если НЕ ПроверитьВозможностьРасчетаБюджета() Тогда
		Элементы.ДекорацияОшибкаРасчетаБюджета.Видимость = Истина;
		Элементы.ГруппаБюджетШапка.Видимость             = Ложь;
		Элементы.ГруппаБюджетОсновнойРаздел.Видимость    = Ложь;
		Возврат;
	Иначе
		Элементы.ДекорацияОшибкаРасчетаБюджета.Видимость = Ложь;
		Элементы.ГруппаБюджетШапка.Видимость             = Истина;
		Элементы.ГруппаБюджетОсновнойРаздел.Видимость    = Истина;
	КонецЕсли;
	
	ПлатежнаяПозиция        = ИдентификаторТекущейСтрокиТабличнойЧасти;
	ПараметрыРасчетаБюджета = Документы.бит_кзн_ПлатежнаяПозиция.ПодготовитьПараметрыПроведения(ПлатежнаяПозиция, Ложь);
	
	СтрокаОстатка   = Неопределено;
	ПериодыКонтроля = Новый Массив;
	Если ПараметрыРасчетаБюджета.ИсполнениеБюджета.Количество() > 0 Тогда
		СтрокаИсполнения           = ПараметрыРасчетаБюджета.ИсполнениеБюджета[0];
		БюджетСуммаЗаявкиПоСтатье  = СтрокаИсполнения.Сумма;
		
		ИсполнениеБюджетаПоСтатье  = ПараметрыРасчетаБюджета.ИсполнениеБюджета.СкопироватьКолонки();
		ЗаполнитьЗначенияСвойств(ИсполнениеБюджетаПоСтатье.Добавить(), СтрокаИсполнения);
		
		ИнформацияОбОстатках       = бит_КонтрольИсполненияБюджета.ПрогнозИсполненияБюджета(
										ИсполнениеБюджетаПоСтатье,
										ПараметрыРасчетаБюджета.ИсполнениеБюджетаРеквизиты);
		ПериодыКонтроля            = ИнформацияОбОстатках.ПериодыКонтроля;
		ОстаткиКонтрольныхЗначений = ИнформацияОбОстатках.ОстаткиКонтрольныхЗначений;
		Если ОстаткиКонтрольныхЗначений.Количество() > 0 Тогда
			СтрокаОстатка = ОстаткиКонтрольныхЗначений[0];
		КонецЕсли;
	КонецЕсли;
	
	НачалоПериодаКонтроля    = Неопределено;
	ОкончаниеПериодаКонтроля = Неопределено;
	
	Если СтрокаОстатка <> Неопределено Тогда 
		СтрокаОстатка                = ОстаткиКонтрольныхЗначений[0];
		БюджетСуммаБюджетаБезЗаявки  = Макс(СтрокаОстатка.Сумма, 0);
		БюджетСуммаБюджетаПоСтатье   = Макс(СтрокаОстатка.СуммаКонтроль, 0);
		БюджетСуммаИсполненныхЗаявок = Макс(СтрокаОстатка.СуммаИсполнение, 0);
		БюджетСуммаСверхЛимита       = Макс(СтрокаОстатка.СуммаСверхЛимита, 0);
		
		ПрогнозИсполненияБюджета = ИнформацияОбОстатках.ПрогнозИсполненияБюджета;
		Если ПрогнозИсполненияБюджета.Количество() > 0 Тогда  
			БюджетОстатокБюджетаПоСтатье = Макс(ПрогнозИсполненияБюджета[0].СуммаКонОстаток, 0);
		Иначе
			БюджетОстатокБюджетаПоСтатье = Макс(СтрокаОстатка.Сумма, 0);
		КонецЕсли;
		
		Для каждого ЭлементПериода Из ПериодыКонтроля Цикл
			Если СтрокаОстатка.Период >= ЭлементПериода.НачалоПериода
				И СтрокаОстатка.Период <= ЭлементПериода.КонецПериода Тогда
				НачалоПериодаКонтроля    = ЭлементПериода.НачалоПериода;
				ОкончаниеПериодаКонтроля = ЭлементПериода.КонецПериода;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НачалоПериодаКонтроля = Неопределено ИЛИ ОкончаниеПериодаКонтроля = Неопределено Тогда
			ПериодичностьКонтроля = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаОстатка.Сценарий,
										"ПериодичностьКонтроля");
			ПараметрыПериода      = Перечисления.бит_ПериодичностьПланирования.ПараметрыДатыПоПериодичности(
										СтрокаОстатка.Период, ПериодичностьКонтроля);
			НачалоПериодаКонтроля    = ПараметрыПериода.ДатаНачала;
			ОкончаниеПериодаКонтроля = ПараметрыПериода.ДатаОкончания;
		КонецЕсли;
		ПредставлениеПериодаПрогноза = ПредставлениеПериода(НачалоПериодаКонтроля,
															ОкончаниеПериодаКонтроля);
		ШаблонЗаголовкаБюджета = НСтр("ru='Бюджет на %1:'");
		ЗаголовокБюджета       = СтрШаблон(ШаблонЗаголовкаБюджета, ПредставлениеПериодаПрогноза);
	Иначе
		БюджетСуммаБюджетаБезЗаявки  = 0;
		БюджетСуммаБюджетаПоСтатье   = 0;
		БюджетСуммаИсполненныхЗаявок = 0;
		БюджетОстатокБюджетаПоСтатье = 0;
		БюджетСуммаСверхЛимита       = 0;
		
		ЗаголовокБюджета             = НСтр("ru='Бюджет:'");
	КонецЕсли;
	
	Элементы.ДекорацияЗаголовокСуммаБюджетаПоСтатье.Заголовок = ЗаголовокБюджета;
	Элементы.ДекорацияБюджетСуммаБюджетаПоСтатье.Заголовок    = Формат(БюджетСуммаБюджетаПоСтатье, "ЧДЦ=2; ЧН=");
	Элементы.ДекорацияСуммаБюджетаБезЗаявки.Заголовок         = Формат(БюджетСуммаБюджетаБезЗаявки, "ЧДЦ=2; ЧН=");
	
	ЕстьСвехЛимит = (БюджетСуммаСверхЛимита > 0);
	Элементы.ДекорацияСуммаСверхЛимита.Видимость = ЕстьСвехЛимит;
	Элементы.БюджетСуммаСверхЛимита.Видимость    = ЕстьСвехЛимит;
	
	ПостроитьДиаграммуБюджета();
		
КонецПроцедуры

&НаСервере
Процедура ПостроитьДиаграммуБюджета()
	
	ДиаграммаБюджета.Очистить();
	ДиаграммаБюджета.ОбластьЛегенды.Расположение = РасположениеЛегендыДиаграммы.Нет;
	ДиаграммаБюджета.ОбластьПостроения.ЦветФона  = ЦветаСтиля.бит_ЦветФонаПодсказки;
	ДиаграммаБюджета.АвтоТранспонирование = Ложь;
	ДиаграммаБюджета.Обновление = Ложь;
	
	Точка = ДиаграммаБюджета.УстановитьТочку(Неопределено);
	
	Серия = ДиаграммаБюджета.Серии.Добавить("СуммаЗаявки");
	Серия.Текст      = НСтр("ru='Сумма заявки'");
	Серия.Цвет       = ЦветаСтиля.бит_ЦветТочекАлгоритма;
	Серия.Раздвигать = Истина;
	ДиаграммаБюджета.УстановитьЗначение(Точка, Серия, БюджетСуммаЗаявкиПоСтатье);
	
	Серия            = ДиаграммаБюджета.Серии.Добавить("Исполнено");
	Серия.Текст      = НСтр("ru='Исполнено'");
	Серия.Цвет       = ЦветаСтиля.бит_ЦветНедоступногоПоля;
	Серия.Раздвигать = Ложь;
	ДиаграммаБюджета.УстановитьЗначение(Точка, Серия, БюджетСуммаИсполненныхЗаявок);
	
	Серия            = ДиаграммаБюджета.Серии.Добавить("ОстатокБюджета");
	Серия.Текст      = НСтр("ru='Остаток бюджета'");
	Серия.Цвет       = ЦветаСтиля.бит_ЦветЗаголовкаСтатуса;
	Серия.Раздвигать = Ложь;
	ДиаграммаБюджета.УстановитьЗначение(Точка, Серия, БюджетОстатокБюджетаПоСтатье);
	
	Если БюджетСуммаСверхЛимита > 0 Тогда
		Серия            = ДиаграммаБюджета.Серии.Добавить("СверхЛимита");
		Серия.Текст      = НСтр("ru='Сверх лимита'");
		Серия.Цвет       = ЦветаСтиля.ЦветОтрицательногоЧисла;
		Серия.Раздвигать = Ложь;
		ДиаграммаБюджета.УстановитьЗначение(Точка, Серия, БюджетСуммаСверхЛимита);
	КонецЕсли;
	
	ДиаграммаБюджета.АвтоТранспонирование = Истина;
	ДиаграммаБюджета.Обновление = Истина;
	
КонецПроцедуры

&НаСервере
Функция ПроверитьВозможностьРасчетаБюджета()
	
	ИдентификаторОшибкиРасшифровкиБюджета = "";
	Элементы.ДекорацияОшибкаРасчетаБюджета.Заголовок = "";
	
	СтрокаТабличнойЧасти = ДанныеТекущейСтрокиТабличнойЧасти();
	Если СтрокаТабличнойЧасти = Неопределено Тогда
		ИдентификаторОшибкиРасшифровкиБюджета = "НеВыбранаСтрокаТабличнойЧасти";
		Элементы.ДекорацияОшибкаРасчетаБюджета.Заголовок = НСтр("ru = 'Выберите строку табличной части.'");
		Возврат Ложь;
	КонецЕсли;
	
	СтатьяОборотов = СтрокаТабличнойЧасти.СтатьяОборотов;
	Если НЕ ЗначениеЗаполнено(СтатьяОборотов) Тогда
		ИдентификаторОшибкиРасшифровкиБюджета = "НеУказанаСтатьяОборотов";
		Элементы.ДекорацияОшибкаРасчетаБюджета.Заголовок = НСтр("ru = 'Не указана статья оборотов.'");
		Возврат Ложь;
	КонецЕсли;
	
	НеКонтролировать = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтатьяОборотов, "НеКонтролировать_Заявки");
	Если НеКонтролировать Тогда
		ИдентификаторОшибкиРасшифровкиБюджета = "ОтключенКонтрольПоСтатье";
		Элементы.ДекорацияОшибкаРасчетаБюджета.Заголовок = НСтр("ru = 'Не ведется контроль по статье.'");
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ДанныеТекущейСтрокиТабличнойЧасти()
	
	ИдентификаторТекущейСтроки = Элементы.ТаблицаПлатежи.ТекущаяСтрока;
	Если НЕ ЗначениеЗаполнено(ИдентификаторТекущейСтроки) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ИменаРеквизитов = Новый Массив;
	ИменаРеквизитов.Добавить("ЦФО");
	ИменаРеквизитов.Добавить("СтатьяОборотов");
	
	ШаблонАналитики    = "Аналитика_%1";
	КоличествоАналитик = 12;
	Для НомерАналитики = 1 По КоличествоАналитик Цикл
		ИменаРеквизитов.Добавить(СтрШаблон(ШаблонАналитики, НомерАналитики));
	КонецЦикла;
	
	ИменаРеквизитовСтрокой = СтрСоединить(ИменаРеквизитов, ",");
	
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ИдентификаторТекущейСтроки, ИменаРеквизитовСтрокой);
	
КонецФункции

&НаСервере
Процедура ВывестиСведенияОВзаиморасчетах(ВыводитьСведенияОВзаиморасчетах)
	
	Если НЕ ВыводитьСведенияОВзаиморасчетах
		ИЛИ бит_ОбщегоНазначения.ЭтоУТ() Тогда
		Элементы.ГруппаВзаиморасчеты.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	СтруктураЗадолженности = бит_Договоры.ДанныеЗадолженности(, Объект.Контрагент, Объект.Организация);
	ВзаиморасчетыДебиторскаяЗадолженность  = СтруктураЗадолженности.ДебиторскаяЗадолженность;
	ВзаиморасчетыКредиторскаяЗадолженность = СтруктураЗадолженности.КредиторскаяЗадолженность;
	
	Элементы.ВзаиморасчетыДебиторскаяЗадолженность.Видимость  = ВзаиморасчетыДебиторскаяЗадолженность <> 0;
	Элементы.ВзаиморасчетыКредиторскаяЗадолженность.Видимость = ВзаиморасчетыКредиторскаяЗадолженность <> 0;
	Элементы.ДекорацияВзаиморасчетыЗадолженностьОтсутствует.Видимость = (ВзаиморасчетыДебиторскаяЗадолженность = 0
																			И ВзаиморасчетыКредиторскаяЗадолженность = 0);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтображениеБюджетаПриОткрытии(Форма, НовоеЗначение)
	
	Форма.ОтображатьБюджетПриОткрытии = НовоеЗначение;
	ОбщегоНазначенияВызовСервера.ХранилищеОбщихНастроекСохранить("НастройкиПользователя",
																"ОтображатьБюджетПриОткрытии",
																НовоеЗначение);
	ОтображениеДекорацииОтображенияБюджетаПриОткрытии(Форма);
	
КонецПроцедуры

&НаКлиенте
Процедура РасшифровкаБюджета()
	
	СтрокаТабличнойЧасти = ДанныеТекущейСтрокиТабличнойЧасти();
	Если СтрокаТабличнойЧасти = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Отбор = Новый Структура;
	Отбор.Вставить("РежимКонтроля"         , ПредопределенноеЗначение("Перечисление.бит_РежимыКонтроляПоБюджету.Заявки"));
	Отбор.Вставить("СценарийКонтролируемый", Объект.Сценарий);
	
	ИменаАналитик = Новый Массив;
	ИменаАналитик.Добавить("ЦФО");
	ИменаАналитик.Добавить("СтатьяОборотов");
	
	ШаблонАналитики    = "Аналитика_%1";
	КоличествоАналитик = 12;
	Для НомерАналитики = 1 По КоличествоАналитик Цикл
		ИменаАналитик.Добавить(СтрШаблон(ШаблонАналитики, НомерАналитики));
	КонецЦикла;
	
	ИменаАналитикСтрокой = СтрСоединить(ИменаАналитик, ",");
	АналитикиОтбора = Новый Структура(ИменаАналитикСтрокой);
	ЗаполнитьЗначенияСвойств(АналитикиОтбора, СтрокаТабличнойЧасти);
	
	ПараметрыОтчета = Новый Структура;
	ПараметрыОтчета.Вставить("Отбор",                     Отбор);
	ПараметрыОтчета.Вставить("СформироватьПриОткрытии",   Истина);
	ПараметрыОтчета.Вставить("Заголовок",                 НСтр("ru='Контрольные значения бюджета по заявкам'"));
	ДополнитьПараметрыРасшифровкиБюджета(ПараметрыОтчета, Отбор);
	
	ОткрытьФорму("Отчет.бит_КонтрольныеЗначенияБюджета.Форма", ПараметрыОтчета, ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьПараметрыРасшифровкиБюджета(ПараметрыОтчета, Отбор)
	
	КомпоновщикНастроек = Отчеты.бит_КонтрольныеЗначенияБюджета.Создать().КомпоновщикНастроек;
	Настройки           = КомпоновщикНастроек.Настройки;
	
	ПериодКонтроля   = Новый СтандартныйПериод(НачалоПериодаКонтроля, ОкончаниеПериодаКонтроля);
	
	ЭлементНастройки = Настройки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Период"));
	ЭлементНастройки.Значение = ПериодКонтроля;
	Если ЗначениеЗаполнено(ЭлементНастройки.ИдентификаторПользовательскойНастройки) Тогда
		ПользовательскийПараметр = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Найти(
									ЭлементНастройки.ИдентификаторПользовательскойНастройки);
		Если ТипЗнч(ПользовательскийПараметр) = Тип("ЗначениеПараметраНастроекКомпоновкиДанных") Тогда
			ПользовательскийПараметр.Значение = ЭлементНастройки.Значение;
		КонецЕсли;
	КонецЕсли;
	
	ОтборСотрудник = Новый ПолеКомпоновкиДанных("Сотрудник");
	Для каждого ЭлементНастройки Из Настройки.Отбор.Элементы Цикл
		ИмяПоляОтбора = Строка(ЭлементНастройки.ЛевоеЗначение);
		Если НЕ Отбор.Свойство(ИмяПоляОтбора) Тогда
			Продолжить;
		КонецЕсли;
		
		ЗначениеОтбора = Отбор[ИмяПоляОтбора];
		Если ТипЗнч(ЗначениеОтбора) = Тип("СписокЗначений") Тогда
			ЭлементНастройки.ВидСравнения   = ВидСравненияКомпоновкиДанных.ВСписке;
		Иначе
			ЭлементНастройки.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		КонецЕсли;
		ЭлементНастройки.ПравоеЗначение = ЗначениеОтбора;
		ЭлементНастройки.Использование  = Истина;
		
		Если ЗначениеЗаполнено(ЭлементНастройки.ИдентификаторПользовательскойНастройки) Тогда
			ПользовательскийПараметр = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Найти(
										ЭлементНастройки.ИдентификаторПользовательскойНастройки);
			Если ТипЗнч(ПользовательскийПараметр) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
				ПользовательскийПараметр.ВидСравнения   = ЭлементНастройки.ВидСравнения;
				ПользовательскийПараметр.ПравоеЗначение = ЭлементНастройки.ПравоеЗначение;
				ПользовательскийПараметр.Использование  = ЭлементНастройки.Использование;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыОтчета.Вставить("Вариант",                   Настройки);
	ПараметрыОтчета.Вставить("ПользовательскиеНастройки", КомпоновщикНастроек.ПользовательскиеНастройки);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОтображениеДекорацииОтображенияБюджетаПриОткрытии(Форма)
	
	Элементы = Форма.Элементы;
	
	Если Форма.ОтображатьБюджетПриОткрытии Тогда
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Подсказка = НСтр("ru='Не отображать при открытии'");
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Картинка  = БиблиотекаКартинок.Закрепить;
	Иначе
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Подсказка = НСтр("ru='Отображать при открытии'");
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Картинка  = БиблиотекаКартинок.Открепить;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Функция ХозяйственнаяОперацияУП()

	Возврат бит_КазначействоКлиентСервер.ХозяйственнаяОперацияУП(Объект.ХозяйственнаяОперация);
	
КонецФункции

&НаСервере
Функция ПараметрыОбъектаДляНазначенияПлатежа()
	
	РезультатПоиска  = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(Объект.Ссылка);
	РеквизитыПозиций = Документы.бит_кзн_ПлатежнаяПозиция.РеквизитыДокумента(РезультатПоиска.МассивПозиций);
	
	РасшифровкаПлатежа.Очистить();
	Для каждого СтрокаТаблицы Из РеквизитыПозиций Цикл
		НоваяСтрока = РасшифровкаПлатежа.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		НоваяСтрока.Сумма = СтрокаТаблицы.СуммаДокумента;
	КонецЦикла;
	
	ПараметрыОбъекта = Документы.бит_кзн_ПлатежнаяПозиция.НовыеПараметрыОбъектаДляНазначенияПлатежа();
	ЗаполнитьЗначенияСвойств(ПараметрыОбъекта, Объект,, "Ссылка");
	
	ПараметрыОбъекта.ПодотчетноеЛицо 		 = Объект.ФизЛицо;
	ПараметрыОбъекта.ХозяйственнаяОперация	 = ХозОперацияУП;
	ПараметрыОбъекта.ПодтверждающиеДокументы = Объект.ПодтверждающиеДокументы;
	ПараметрыОбъекта.Валюта 				 = Объект.ВалютаДокумента;
	ПараметрыОбъекта.СуммаДокумента			 = РасшифровкаПлатежа.Итог("Сумма");
	ПараметрыОбъекта.РасшифровкаПлатежа 	 = РасшифровкаПлатежа;

	Возврат ПараметрыОбъекта;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьНазначениеПлатежаСервер()

	ПараметрыОбъекта = ПараметрыОбъектаДляНазначенияПлатежа();
	ДенежныеСредстваСервер.ЗаполнитьТекстНазначенияПлатежа(ПараметрыОбъекта);
	
	Если Объект.НазначениеПлатежа <> ПараметрыОбъекта.НазначениеПлатежа Тогда
		Объект.НазначениеПлатежаУпр = ПараметрыОбъекта.НазначениеПлатежа;
	КонецЕсли;
	Объект.НазначениеПлатежа = ПараметрыОбъекта.НазначениеПлатежа;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста 
Процедура УстановитьПараметрыВыбораВидаОперации(Форма)
	
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	НовыеПараметры = Новый Массив; 
	НовыеПараметры.Добавить(Новый ПараметрВыбора("Отбор.ФормаОплаты", Объект.ФормаОплаты));
	НовыеПараметры.Добавить(Новый ПараметрВыбора("Отбор.ТипДокумента", ТипЗнч(Объект.Ссылка)));
	
	Элементы.ХозяйственнаяОперация.ПараметрыВыбора = Новый ФиксированныйМассив(НовыеПараметры);
	
КонецПроцедуры
 
&НаСервереБезКонтекста
Функция ДоступныеЗначенияВидовОпераций(ФормаОплаты)
	
	Модуль = Перечисления.бит_ВидыОперацийКазначейства;
	ПараметрыПередачи = Новый Структура; 
	ПараметрыПередачи.Вставить("ФормаОплаты", ФормаОплаты);
	ПараметрыПередачи.Вставить("ТипДокумента", Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств"));
	
	Возврат Модуль.ПолучитьДоступныеЗначения(ПараметрыПередачи).ДоступныеЗначения;
	
КонецФункции

&НаСервере
Процедура ПодготовитьФормуНаСервере()

	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.Организация, Неопределено, Объект.Дата);
	
	ТекущаяФормаОплаты 			   = Объект.ФормаОплаты;
	ТекущаяХозяйственнаяОперация   = Объект.ХозяйственнаяОперация;
	ВключенаПоддержкаГосконтрактов = ПолучитьФункциональнуюОпцию("ПоддержкаБанковскогоИКазначейскогоСопровожденияГосконтрактов");
	
	ЕстьПравоНаСписание = ПравоДоступа("Редактирование", Метаданные.Документы.СписаниеБезналичныхДенежныхСредств)
							ИЛИ ПравоДоступа("Редактирование", Метаданные.Документы.РасходныйКассовыйОрдер);
			
	ХозОперацияУП = ХозяйственнаяОперацияУП();
	
	УстановитьПараметрыВыбораВидаОперации(ЭтотОбъект);
	УстановитьСостояниеДокумента();
	УстановитьОтборПлатежей();
	
	ЭтоОперацияБезВалютыВзаиморасчетов = бит_КазначействоКлиентСервер.ЭтоОперацияБезВалютыВзаиморасчетов(Объект.ХозяйственнаяОперация);
	ЦветОсобогоТекста				   = ЦветаСтиля.ЦветОсобогоТекста;
	
	ОбновитьИтоги();

	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ПолучитьФункциональнуюОпцию("бит_ЗапретитьИзменениеЗаявкиВключеннойВРеестр") Тогда
			ЗаявкаВключенаВРеестр = бит_Казначейство.ЗаявкаВключенаВРеестр(Объект.Ссылка);
		Иначе
			ЗаявкаВключенаВРеестр = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Элементы.ГруппаБюджетИВзаиморасчеты.Видимость = ВидимостьПанелиКонтроля();
		
КонецПроцедуры
 
&НаКлиенте
Процедура ОплатаЗаСчетЗавершение()

	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("ДокументОснование", 	Объект.Ссылка);
	ДанныеЗаполнения.Вставить("Сценарий", 			Объект.Сценарий);
	ДанныеЗаполнения.Вставить("ВидКорректировки", 	ПредопределенноеЗначение("Перечисление.бит_ВидыКорректировокКонтрольныхЗначений.ЗаСчет"));
	ДанныеЗаполнения.Вставить("АдресДанныхДляКорректировки", АдресДанныхДляКорректировки);
	
	ПараметрыФормы = Новый Структура("Основание", ДанныеЗаполнения);
	ОткрытьФорму("Документ.бит_КорректировкаКонтрольныхЗначений.ФормаОбъекта", ПараметрыФормы, 
		ЭтотОбъект,,,,,РежимОткрытияОкнаФормы.Независимый);

КонецПроцедуры

// Процедура управляет видимостью кнопки ОплатитьЗаСчет
//
// Параметры:
//	нет
//
&НаКлиенте
Процедура УстановитьВидимостьКнопкиОплатитьЗаСчет()
	
	ПоказатьОплатаЗаСчет = Ложь;
	
	Если ЭтоАдресВременногоХранилища(АдресДанныхДляКорректировки) Тогда
		Результат = ПолучитьИзВременногоХранилища(АдресДанныхДляКорректировки);
		Если ТипЗнч(Результат) = Тип("Структура") Тогда
			ЕстьДанныеКорректировки = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Результат, 
										"ЕстьДанныеКорректировки", Ложь);
			Если ЕстьДанныеКорректировки И НЕ Объект.СверхБюджета Тогда
				ПоказатьОплатаЗаСчет = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Элементы.ОплатаЗаСчет.Видимость = ПоказатьОплатаЗаСчет;
	
КонецПроцедуры

&НаКлиенте
Процедура ОжиданиеПроведенияДокумента()
	
	ОтключитьОбработчикОжидания("ОжиданиеПроведенияДокумента");
	
	УстановитьВидимостьКнопкиОплатитьЗаСчет();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗаголовокФормыДокумента(Форма)
	
	Объект = Форма.Объект;
	
	ПредставлениеОбъекта = "";
	Если Объект.ВидПлана = ПредопределенноеЗначение("Перечисление.бит_кзн_ВидыПланов.Прогноз") Тогда		
		ПредставлениеОбъекта =  НСтр("ru='Прогноз платежа%1';en='Payment Forecast%1'");		
	Иначе
		ПредставлениеОбъекта =  НСтр("ru='Заявка на расходование денежных средств%1';en='Request for Disbursement%1'");		
	КонецЕсли; 
	
	ПредставлениеОбъекта = СтрШаблон(ПредставлениеОбъекта, НомерДата(Объект.Ссылка, Объект.Номер, Объект.Дата));

	СтруктураЗаголовка = Новый Структура;
	СтруктураЗаголовка.Вставить("ПредставлениеОбъекта", ПредставлениеОбъекта);
	СтруктураЗаголовка.Вставить("СтрокаВидаОперации"  , "");
	СтруктураЗаголовка.Вставить("ЭтоНовый"			  , Объект.Ссылка.Пустая());
	СтруктураЗаголовка.Вставить("ДокументПроведен"	  , Объект.Проведен);
	
	бит_РаботаСДиалогамиКлиентСервер.УстановитьЗаголовокФормыДокумента(Форма, СтруктураЗаголовка);
	
КонецПроцедуры

//  Процедура обработчик-ожидания открытия формы. 
//
&НаКлиенте
Процедура ОжиданиеОткрытияФормы()
	
	Оповещение = Новый ОписаниеОповещения("ОжиданиеОткрытияФормыЗавершение",ЭтотОбъект);
	ТекстВопроса =  НСтр("ru='Выполнить копирование и записать документ?';en='Make a copy and write the document?'");
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 30, КодВозвратаДиалога.Да);
	
КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте 
Процедура ОжиданиеОткрытияФормыЗавершение(Ответ, ДополнительныеДанные) Экспорт
	
	КопироватьПозиции = ?(Ответ = КодВозвратаДиалога.Да, Истина, Ложь);
	
	Если КопироватьПозиции Тогда
		ОчиститьПолеДокументОснование();
		Записать();
		КопироватьПозиции = Ложь;
	КонецЕсли;
	
	ОтобразитьБюджетСПаузой();
	
КонецПроцедуры

//  Функция создает платежные документы на основании этого документа 
//
&НаСервере
Функция  СоздатьПлатежныеДокументы()
	
	СвязанныеДокументы = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(Объект.Ссылка);
	ДанныеЗаполнения   = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.НовыеПараметрыДокументаСоздатьПлатежныеДокументы();
	Для каждого Позиция Из СвязанныеДокументы.МассивПозиций Цикл
		НоваяСтрока = ДанныеЗаполнения.Позиции.Добавить();
		НоваяСтрока.Позиция = Позиция;
	КонецЦикла;
	
	Результат = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.СоздатьДокументыНаОсновеВыделенных(Объект.Ссылка, ДанныеЗаполнения);
	НовыеДокументы = Результат.ВыгрузитьКолонку("ДокументОплаты");
	
	Возврат НовыеДокументы;
	
КонецФункции // СоздатьПлатежныеДокументы()

&НаСервере
Функция СоздатьПлатежныеДокументыВыделенные(ВыделенныеСтроки)

	ДанныеЗаполнения = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.НовыеПараметрыДокументаСоздатьПлатежныеДокументы(); 
	
	Для каждого Элемент Из ВыделенныеСтроки Цикл
		НоваяСтрока = ДанныеЗаполнения.Позиции.Добавить();
		НоваяСтрока.Позиция = Элемент.Ссылка;
		НоваяСтрока.Сумма	= Элемент.СуммаДокумента;
	КонецЦикла;

	НовыеДокументы = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.СоздатьДокументыНаОсновеВыделенных(
						Объект.Ссылка, ДанныеЗаполнения);

	Возврат НовыеДокументы.ВыгрузитьКолонку("ДокументОплаты");
	
КонецФункции

// Процедура заполняет кэш значений, необходимый при работе на клиенте.
//
&НаСервере
Процедура ЗаполнитьКэшЗначений()
	
	КэшЗначений = Новый Структура;
	
	КэшЗначений.Вставить("ИзмеренияДоп"      , бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Дополнительные","Синоним"));
	КэшЗначений.Вставить("НастройкиИзмерений", бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений"));
	КэшЗначений.Вставить("ВалютаРеглУчета"	  , Константы.ВалютаРегламентированногоУчета.Получить());
	КэшЗначений.Вставить("Подразделения"	  , Константы.ИспользоватьПодразделения.Получить());
			
	ТекПользователь	   = Пользователи.ТекущийПользователь();
	РазрешеноПроводить = бит_ПраваДоступа.ПолучитьЗначениеДопПраваПользователя(ТекПользователь, 
							ПланыВидовХарактеристик.бит_ДополнительныеПраваПользователей.РазрешеноПроводитьЗаявкиНаРасходованиеДС);	
							
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция НомерДата(Ссылка, Номер, Дата)

	НомерДата = "";
	Если ЗначениеЗаполнено(Ссылка) Тогда
		НомерДата = " " + НСтр("ru = '%1 от %2'");
		НомерДата = СтрШаблон(НомерДата, Номер, Дата);
	КонецЕсли;
	
	Возврат НомерДата;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)

	бит_НастройкиДоступностиЭлементовФормКлиентСервер.РазблокироватьЭлементы(Форма);
	
	Элементы		   = Форма.Элементы;
	Объект 			   = Форма.Объект;
	РазрешеноПроводить = Форма.РазрешеноПроводить;
	
	// Платежи по 275-ФЗ.
	Элементы.ПлатежиПо275ФЗ.Видимость = Форма.ВключенаПоддержкаГосконтрактов;
	
	Элементы.СтраницаОплатаЗаСчетСредств.Видимость	   = Объект.ПлатежиПо275ФЗ;
	Элементы.СтраницаПодтверждающиеДокументы.Видимость = Объект.ПлатежиПо275ФЗ;
	Элементы.ФормаОплаты.ТолькоПросмотр 			   = Объект.ПлатежиПо275ФЗ;	
	
	ЭтоНовый	   = ?(НЕ ЗначениеЗаполнено(Объект.Ссылка), Истина, Ложь);
	ЭтоПрогноз	   = ?(Объект.ВидПлана = ПредопределенноеЗначение("Перечисление.бит_кзн_ВидыПланов.Прогноз"), Истина, Ложь);
	ПарамВидимости = бит_КазначействоКлиентСервер.ПодготовитьПараметрыВидимости(Объект.ХозяйственнаяОперация);
				
	Элементы.СверхБюджета.Видимость		 	  = НЕ ЭтоПрогноз;
	Элементы.СверхБюджета.ЦветТекстаЗаголовка = ?(Объект.СверхБюджета, Форма.ЦветОсобогоТекста, Новый Цвет);
	Элементы.СписатьЛимиты.Видимость	      = Элементы.СверхБюджета.Видимость И Форма.НеУчитыватьСверхБюджета;
	Элементы.СписатьЛимиты.Доступность		  = Объект.СверхБюджета;

	Элементы.ТаблицаПлатежи.Доступность		  = НЕ ЭтоНовый;

	ЭтоНал = ?(Объект.ФормаОплаты = ПредопределенноеЗначение("Перечисление.бит_ВидыДенежныхСредств.Наличные"), Истина, Ложь);
	Элементы.ТаблицаПлатежиБанковскийСчет.Видимость = НЕ ЭтоНал;
	Элементы.ТаблицаПлатежиКасса.Видимость			= ЭтоНал;
	
	// видимость Контрагент/Договор/ФизЛицо
	Элементы.Контрагент.Видимость = ПарамВидимости.ЕстьКонтрагент;
	Элементы.ФизЛицо.Видимость    = ПарамВидимости.ФизЛицо;
		
	// кнопки провести/на согласование
	Элементы.ФормаПровестиИЗакрыть.Видимость         = РазрешеноПроводить;
	Элементы.ФормаПровести.Видимость                 = РазрешеноПроводить;
	Элементы.ФормаПровестиИЗакрыть.КнопкаПоУмолчанию = РазрешеноПроводить;
	
	ТекстЗаголовка = ?(Объект.ОтправленНаСогласование, 
					   НСтр("ru='Отозвать';en='Revoke'"), НСтр("ru='На согласование';en='For Approval'"));
	
	Элементы.ФормаКомандаНаСогласование.Видимость         = НЕ РазрешеноПроводить;
	Элементы.ФормаКомандаНаСогласование.КнопкаПоУмолчанию = НЕ РазрешеноПроводить;
	Элементы.ФормаКомандаНаСогласование.Заголовок         = ТекстЗаголовка;
	Элементы.ФормаКомандаНаСогласование.Доступность       = НЕ Объект.Проведен;
	
	Если Объект.ПлатежиПо275ФЗ Тогда
		Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.ЗакладкиСверху;
	Иначе
		Элементы.ГруппаСтраницы.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;	
	КонецЕсли;
	
	Элементы.ПланированиеСуммы.ТолькоПросмотр 			  = Форма.ЭтоОперацияБезВалютыВзаиморасчетов;
	Элементы.ТаблицаПлатежиСуммаВзаиморасчетов.Видимость  = НЕ Форма.ЭтоОперацияБезВалютыВзаиморасчетов;
	Элементы.ТаблицаПлатежиВалютаВзаиморасчетов.Видимость = НЕ Форма.ЭтоОперацияБезВалютыВзаиморасчетов;	
	
	Элементы.ДокументОснование.Видимость = ЗначениеЗаполнено(Объект.ДокументОснование);
		
	// Управление доступностью команды создать на основании.
	Если Форма.ТипСтатуса <> ПредопределенноеЗначение("Перечисление.бит_ТипыСтатусовОбъектов.Утвержден")
		И Форма.ТипСтатуса <> ПредопределенноеЗначение("Перечисление.бит_ТипыСтатусовОбъектов.ЧастичноИсполнен") Тогда
		Элементы.ФормаВвестиПлатежныеДокументы.Доступность = Ложь;
		Элементы.ТаблицаПлатежиВвестиПлатежныеДокументыВыделенные.Доступность = Ложь;
		Элементы.ФормаВвестиЗаявку.Доступность = Ложь;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, 
			"ФормаВозвратЛимита", "Доступность", Ложь);
	Иначе
		Элементы.ФормаВвестиПлатежныеДокументы.Доступность					  = НЕ ЭтоПрогноз И Форма.ЕстьПравоНаСписание;
		Элементы.ТаблицаПлатежиВвестиПлатежныеДокументыВыделенные.Доступность = НЕ ЭтоПрогноз;
		Элементы.ФормаВвестиЗаявку.Доступность 								  = ЭтоПрогноз;	
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, 
			"ФормаВозвратЛимита", "Доступность", НЕ ЭтоПрогноз);
	КонецЕсли;
	
	Элементы.ГруппаДекорацияПредупреждения.Видимость = Форма.ЗаявкаВключенаВРеестр;
	
	Если Форма.ОтображатьБюджет Тогда
		Элементы.ДекорацияОтобразитьБюджетКартинка.Картинка     = БиблиотекаКартинок.бит_ПерейтиВниз;
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Видимость = Истина;
		Элементы.ГруппаБюджетИВзаиморасчетыРазделы.Видимость    = Истина;
	Иначе
		Элементы.ДекорацияОтобразитьБюджетКартинка.Картинка     = БиблиотекаКартинок.бит_ПерейтиВправо;
		Элементы.ДекорацияОтображатьБюджетПриОткрытии.Видимость = Ложь;
		Элементы.ГруппаБюджетИВзаиморасчетыРазделы.Видимость    = Ложь;
	КонецЕсли;
	ОтображениеДекорацииОтображенияБюджетаПриОткрытии(Форма);
	
	бит_НастройкиДоступностиЭлементовФормКлиентСервер.ЗаблокироватьЭлементы(Форма);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборПлатежей()

	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ТаблицаПлатежи, "ДокументПланирования", 
		Объект.Ссылка, ВидСравненияКомпоновкиДанных.Равно,, Истина, 
		РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный); 
		
	СкрытьПомеченныеНаУдаление = НЕ Объект.ПометкаУдаления;
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ТаблицаПлатежи, "ПометкаУдаления", 
		Ложь, ВидСравненияКомпоновкиДанных.Равно,, СкрытьПомеченныеНаУдаление, 
		РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный);
		
КонецПроцедуры

&НаСервере
Процедура УстановитьСостояниеДокумента()
	
	СостояниеДокумента = бит_ОбщегоНазначения.СостояниеДокумента(Объект);
	
КонецПроцедуры

&НаСервере
Процедура СкопироватьПозицииПриЗаписи(ДокументПланирования, Отказ)
	
	Если НЕ ЗначениеЗаполнено(ЗначениеКопирования) Тогда
		Возврат;
	КонецЕсли;	
		
	РезультатПоиска = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(ЗначениеКопирования, Ложь);
	
	НачатьТранзакцию();
	Попытка
		Для каждого Позиция Из РезультатПоиска.МассивПозиций Цикл
			ПозицияПриемник = Позиция.Скопировать();
			ПозицияПриемник.ДокументОснование 	 = Неопределено;
			ПозицияПриемник.ДокументПланирования = ДокументПланирования;
			ПозицияПриемник.ДополнительныеСвойства.Вставить("НеСинхронизировать", Истина);
			ПозицияПриемник.СверхБюджета		 = Объект.СверхБюджета;  
			ПозицияПриемник.ПометкаУдаления 	 = Объект.ПометкаУдаления;
			бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ПозицияПриемник, РежимЗаписиДокумента.Запись, , "Ошибки");
		КонецЦикла; 
		ЗначениеКопирования = Неопределено;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ФормаОплатыПриИзмененииНаСервере()
	
	Если НЕ ЗначениеЗаполнено(Объект.ФормаОплаты) Тогда
		Объект.ФормаОплаты = ТекущаяФормаОплаты; 
	КонецЕсли; 

	Если ТекущаяФормаОплаты = Объект.ФормаОплаты Тогда
		Возврат;
	КонецЕсли; 

	УстановитьПараметрыВыбораВидаОперации(ЭтотОбъект);
	
	ДоступныеЗначения = ДоступныеЗначенияВидовОпераций(Объект.ФормаОплаты);
	Если ДоступныеЗначения.НайтиПоЗначению(Объект.ХозяйственнаяОперация) = Неопределено Тогда
		Объект.ХозяйственнаяОперация = ДоступныеЗначения[0].Значение;
		ХозяйственнаяОперацияПриИзмененииНаСервере();
		УстановитьПараметрыВыбораДоговораСЗаказчиком(Истина);
	Иначе
		ТекущаяФормаОплаты = Объект.ФормаОплаты;
		УправлениеФормой(ЭтотОбъект);
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ХозяйственнаяОперацияПриИзмененииНаСервере()

	ПарамВидимости = бит_КазначействоКлиентСервер.ПодготовитьПараметрыВидимости(Объект.ХозяйственнаяОперация);
	Если НЕ ПарамВидимости.ЕстьКонтрагент Тогда
		Объект.Контрагент = Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли; 
	
	ХозОперацияУП = ХозяйственнаяОперацияУП();
	
	ЭтоОперацияБезВалютыВзаиморасчетов = бит_КазначействоКлиентСервер.ЭтоОперацияБезВалютыВзаиморасчетов(Объект.ХозяйственнаяОперация);
	Если ЭтоОперацияБезВалютыВзаиморасчетов Тогда
		Объект.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа;	
	КонецЕсли;	

    УправлениеФормой(ЭтотОбъект);
	
	ВидОперации = Объект.ХозяйственнаяОперация;
	Если НЕ ВидОперации = Перечисления.бит_ВидыОперацийКазначейства.ОплатаПоставщику
		И НЕ ВидОперации = Перечисления.бит_ВидыОперацийКазначейства.ОплатаДенежныхСредствВДругуюОрганизацию Тогда
		Объект.ДоговорСУчастникомГОЗ = Ложь;
	КонецЕсли;
	УстановитьПараметрыВыбораДоговораСЗаказчиком(Истина);
	ПроверитьЗаполнитьТипПлатежа275ФЗ();
	
	ТекущаяФормаОплаты 			 = Объект.ФормаОплаты;
	ТекущаяХозяйственнаяОперация = Объект.ХозяйственнаяОперация;
	
КонецПроцедуры
 
&НаСервере
Процедура ОчиститьВсеВизы()
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		бит_ВизированиеСервер.ОчиститьВсеВизыБезусловно(Объект.Ссылка);
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИтоги()

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументПланирования", Объект.Ссылка);
	Запрос.УстановитьПараметр("ПометкаУдаления", 	  Объект.ПометкаУдаления);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СУММА(Таблица.СуммаДокумента) КАК Сумма,
	|	СУММА(Таблица.СуммаНДС) КАК СуммаНДС
	|ИЗ
	|	Документ.бит_кзн_ПлатежнаяПозиция КАК Таблица
	|ГДЕ
	|	Таблица.ДокументПланирования = &ДокументПланирования
	|	И Таблица.ПометкаУдаления = &ПометкаУдаления";
				   
	Результат = Запрос.Выполнить();
	Выборка	  = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Выборка);
	КонецЦикла; 
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьПолеДокументОснование()

	Если ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") 
		 И НЕ Объект.ДокументОснование.ВидПлана = Перечисления.бит_кзн_ВидыПланов.Прогноз Тогда
	
		Объект.ДокументОснование = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.ПустаяСсылка();
	
	КонецЕсли; 

КонецПроцедуры

&НаСервере
Функция ПолучитьСтатусНаСервере()

	РезСтруктура = бит_ВизированиеСервер.СтатусыОбъекта(Объект.Ссылка);
	
	Возврат РезСтруктура;
	
КонецФункции // ПолучитьСтатусНаСервере()

&НаСервере
Процедура КомандаУдалитьПозициюНаСервере(Позиция)
	
	УстановитьПривилегированныйРежим(Истина);
	
	РезПоиска = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(Объект.Ссылка);
	
	Если РезПоиска.КоличествоПозиций > 1 Тогда
		ПозицияОбъект = Позиция.ПолучитьОбъект();
		ПозицияОбъект.УстановитьПометкуУдаления(Истина); 
	Иначе
		ТекстСообщения = НСтр("ru = 'Единственную позицию нельзя удалить. Закройте документ и установите пометку удаления в списке.';
							  |en = 'A single position cannot be deleted. Close the document and select the delete option in the list.'"); 
		ВызватьИсключение ТекстСообщения;
	КонецЕсли; 
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаСервере
Процедура ОрганизацияПриИзмененииНаСервере()
	
	УстановитьПараметрыВыбораДоговораСЗаказчиком(Истина);
	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.Организация, Неопределено, Объект.Дата); 
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура КонтрагентПриИзмененииНаСервере()
	
	УстановитьПараметрыВыбораДоговораСЗаказчиком(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещенияИзмененияСтатуса()
	
	Прочитать();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НеУчитыватьСверхБюджета(Организация, ЦФО, Период)

	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("Организация", Организация);
	ПараметрыНастройки.Вставить("ЦФО",		   ЦФО);
								
	НеУчитыватьСверхБюджета = бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеЗаявкиПриКонтролеПоБюджету(ПараметрыНастройки, 
									Период);
	Возврат НеУчитыватьСверхБюджета;
	
КонецФункции

&НаСервере
Процедура ДатаПриИзмененииНаСервере()

	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.Организация, Неопределено, Объект.Дата);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредложитьЗаписатьДокумент(ПредставлениеДействия, ДополнительныеДанные)

	ЧастиВопроса = Новый Массив;

	ТекстВопроса = НСтр("ru = 'Данные еще не записаны.'; en = 'The data has not been recorded yet.'");
	ЧастиВопроса.Добавить(ТекстВопроса);
	
	ТекстВопроса = НСтр("ru = 'Выполнение действия ""%1"" возможно только после записи данных.'; 
						|en = 'The ""%1"" action can only be performed after data is written.'");
	ТекстВопроса = СтрШаблон(ТекстВопроса, ПредставлениеДействия);
	ЧастиВопроса.Добавить(ТекстВопроса);
	
	ТекстВопроса = НСтр("ru = 'Записать документ?'; en = 'Write down a document?'");
	ЧастиВопроса.Добавить(ТекстВопроса);
	
	ТекстСообщения = СтрСоединить(ЧастиВопроса, Символы.ПС);
	
	Оповещение = Новый ОписаниеОповещения("ПредложитьЗаписатьДокументЗавершение", ЭтотОбъект, ДополнительныеДанные);

	ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет,);

КонецПроцедуры

// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура ПредложитьЗаписатьДокументЗавершение(Результат, ДополнительныеДанные) Экспорт

	Если НЕ Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;	

	Попытка
		Записать();		
	Исключение
		ВызватьИсключение ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки; 
	
	ЗакрытьЭтуФорму = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеДанные, "ЗакрытьЭтуФорму", Ложь);

	Ссылка		   = Элементы.ТаблицаПлатежи.ТекущаяСтрока;
	ПараметрыФормы = Новый Структура("Ключ", Ссылка);
	Если ЗакрытьЭтуФорму Тогда
		ОткрытьФормуПозиции(Неопределено);
		Закрыть();
	Иначе	
		ОткрытьФормуПозиции(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция МожноСделатьБезРазбиения()

	МожноСделать = Истина;
	
	РезультатПоиска = Документы.бит_кзн_ПлатежнаяПозиция.НайтиПозициюПоОснованию(Объект.Ссылка);
	Если РезультатПоиска.КоличествоПозиций > 1 Тогда
		ТекстСообщения = НСтр("ru = 'Переключение в режим без разбиения невозможно, если в введено более одной позиции поступления.'; 
							|en = 'Switching to the  no-split mode is not possible if more than one entry position is entered.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		МожноСделать = Ложь;
	КонецЕсли;
	
	Возврат МожноСделать;
	
КонецФункции

&НаКлиенте
Процедура ОткрытьФормуПозиции(ФормаВладелец)
	
	Ссылка = Элементы.ТаблицаПлатежи.ТекущаяСтрока;
	Если Ссылка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("Ключ", Ссылка);
	Если ФормаВладелец <> Неопределено Тогда
		ОткрытьФорму("Документ.бит_кзн_ПлатежнаяПозиция.ФормаОбъекта", ПараметрыФормы, ФормаВладелец, Ссылка);
	Иначе	
		ОткрытьФорму("Документ.бит_кзн_ПлатежнаяПозиция.ФормаОбъекта", ПараметрыФормы,, Ссылка);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ВидимостьПанелиКонтроля()
	
	Если Объект.ВидПлана = Перечисления.бит_кзн_ВидыПланов.Прогноз Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти
