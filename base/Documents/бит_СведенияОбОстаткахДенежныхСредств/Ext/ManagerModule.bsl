Функция ТекстЗапросаВременнаяТаблицаДокумента(НомераТаблиц)

	НомераТаблиц.Вставить("ВременнаяТаблицаДокумента", НомераТаблиц.Количество());
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	СведенияОБанковскихСчетах.НомерСтроки КАК НомерСтроки,
	|	""СведенияОБанковскихСчетах"" КАК ИмяСписка,
	|	СведенияОБанковскихСчетах.БанковскийСчет КАК БанковскийСчет,
	|	СведенияОБанковскихСчетах.БанковскийСчет.ВалютаДенежныхСредств КАК Валюта,
	|	ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные) КАК ВидДенежныхСредств,
	|	СведенияОБанковскихСчетах.СуммаНач КАК СуммаНач,
	|	СведенияОБанковскихСчетах.СуммаКон КАК СуммаКон,
	|	СведенияОБанковскихСчетах.СуммаПриход КАК СуммаПриход,
	|	СведенияОБанковскихСчетах.СуммаРасход КАК СуммаРасход
	|ПОМЕСТИТЬ ВременнаяТаблицаДокумента
	|ИЗ
	|	Документ.бит_СведенияОбОстаткахДенежныхСредств.СведенияОБанковскихСчетах КАК СведенияОБанковскихСчетах
	|ГДЕ
	|	СведенияОБанковскихСчетах.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СведенияОНаличных.НомерСтроки,
	|	""СведенияОНаличных"",
	|	СведенияОНаличных.Касса,
	|	СведенияОНаличных.Валюта,
	|	ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Наличные),
	|	СведенияОНаличных.СуммаНач,
	|	СведенияОНаличных.СуммаКон,
	|	СведенияОНаличных.СуммаПриход,
	|	СведенияОНаличных.СуммаРасход
	|ИЗ
	|	Документ.бит_СведенияОбОстаткахДенежныхСредств.СведенияОНаличных КАК СведенияОНаличных
	|ГДЕ
	|	СведенияОНаличных.Ссылка = &Ссылка";

	Если Метаданные.Справочники.Найти("Кассы") <> Неопределено Тогда
		// Переопределим источник валюты наличных.
		ЧтоЗаменить   = "СведенияОНаличных.Валюта";
		НаЧтоЗаменить = "СведенияОНаличных.Касса.ВалютаДенежныхСредств";
		ТекстЗапроса  = СтрЗаменить(ТекстЗапроса, ЧтоЗаменить, НаЧтоЗаменить);	
	КонецЕсли;

	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции

Функция ТекстЗапросаКурсыВалют(НомераТаблиц)

	НомераТаблиц.Вставить("КурсыВалют", НомераТаблиц.Количество());

	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицыДокумента.Валюта КАК Валюта,
	|	ЕСТЬNULL(КурсыВалютСрезПоследних.Курс, 0) КАК Курс,
	|	ЕСТЬNULL(КурсыВалютСрезПоследних.Кратность, 1) КАК Кратность
	|ИЗ
	|	ВременнаяТаблицаДокумента КАК ТаблицыДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(
	|				&Период,
	|				Валюта В
	|					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|						ВременнаяТаблицаДокумента.Валюта КАК Валюта
	|					ИЗ
	|						ВременнаяТаблицаДокумента КАК ВременнаяТаблицаДокумента)) КАК КурсыВалютСрезПоследних
	|		ПО ТаблицыДокумента.Валюта = КурсыВалютСрезПоследних.Валюта";

	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции
 
Функция ТекстЗапросаСведенияОбОстаткахДенежныхСредств(НомераТаблиц)

	НомераТаблиц.Вставить("СведенияОбОстаткахДенежныхСредств", НомераТаблиц.Количество());
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.БанковскийСчет КАК БанковскийСчет,
	|	Таблица.Валюта КАК Валюта,
	|	Таблица.ВидДенежныхСредств КАК ВидДенежныхСредств,
	|	ВЫБОР
	|		КОГДА Таблица.СуммаНач > Таблица.СуммаКон
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	КОНЕЦ КАК ВидДвижения,
	|	ВЫБОР
	|		КОГДА Таблица.СуммаНач > Таблица.СуммаКон
	|			ТОГДА Таблица.СуммаНач - Таблица.СуммаКон
	|		КОГДА Таблица.СуммаНач < Таблица.СуммаКон
	|			ТОГДА Таблица.СуммаКон - Таблица.СуммаНач
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Сумма
	|ИЗ
	|	ВременнаяТаблицаДокумента КАК Таблица";

	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции

Функция ТекстЗапросаСведенияОДвиженииДенежныхСредств(НомераТаблиц)

	НомераТаблиц.Вставить("СведенияОДвиженииДенежныхСредств", НомераТаблиц.Количество());
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.БанковскийСчет КАК БанковскийСчет,
	|	Таблица.Валюта КАК Валюта,
	|	Таблица.ВидДенежныхСредств КАК ВидДенежныхСредств,
	|	ВЫБОР
	|		КОГДА Таблица.СуммаНач > Таблица.СуммаКон
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_ВидДвиженияНакопления.Расход)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.бит_ВидДвиженияНакопления.Приход)
	|	КОНЕЦ КАК ПриходРасход,
	|	ВЫБОР
	|		КОГДА Таблица.СуммаНач > Таблица.СуммаКон
	|			ТОГДА Таблица.СуммаНач - Таблица.СуммаКон
	|		КОГДА Таблица.СуммаНач < Таблица.СуммаКон
	|			ТОГДА Таблица.СуммаКон - Таблица.СуммаНач
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Сумма,
	|	ВЫБОР
	|		КОГДА Таблица.СуммаНач > Таблица.СуммаКон
	|			ТОГДА Таблица.СуммаНач - Таблица.СуммаКон
	|		КОГДА Таблица.СуммаНач < Таблица.СуммаКон
	|			ТОГДА Таблица.СуммаКон - Таблица.СуммаНач
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК СуммаРегл
	|ИЗ
	|	ВременнаяТаблицаДокумента КАК Таблица";

	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции

Процедура ПодготовитьТаблицыДокументаРасчетыВВалюте(ПараметрыПроведения, Реквизиты)

	ПараметрыНовогоКурса = Новый Структура;
	ПараметрыНовогоКурса.Вставить("Валюта",    Константы.ВалютаРегламентированногоУчета.Получить());
	ПараметрыНовогоКурса.Вставить("Курс",	   1);
	ПараметрыНовогоКурса.Вставить("Кратность", 1);
	
	ПараметрыТекущегоКурса = Новый Структура("Валюта, Курс, Кратность"); 
	
	КурсыВалют 		  = ПараметрыПроведения.КурсыВалют;
