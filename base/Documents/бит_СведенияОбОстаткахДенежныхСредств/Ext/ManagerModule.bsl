// Функция подготавливает параметры проведения.
// 
// Параметры:
//  ДокументСсылка - ДокументСсылка.бит_СведенияОбОстаткахДенежныхСредств - ссылка на документ.
//  Отказ          - Булево - признак обнаружения ошибки и отказа от дальнейших действий.
//
// Возвращаемое значение:
//  Структура - структура параметров проведения.
//
Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт
	
	ПараметрыПроведения = Новый Структура(); 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст = 	
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.Дата КАК Период,
	|	Реквизиты.Организация КАК Организация
	|ИЗ
	|	Документ.бит_СведенияОбОстаткахДенежныхСредств КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";
	
	Результат = Запрос.Выполнить().Выгрузить();
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Результат[0]);
	
	НомераТаблиц = Новый Структура(); 
	ТекстЗапроса = ТекстЗапросаВременнаяТаблицаДокумента(НомераТаблиц)
				 + ТекстЗапросаКурсыВалют(НомераТаблиц)
				 + ТекстЗапросаСведенияОбОстаткахДенежныхСредств(НомераТаблиц)
				 + ТекстЗапросаСведенияОДвиженииДенежныхСредств(НомераТаблиц);
				 
	Запрос = Новый Запрос(); 
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("Период", Реквизиты.Период);
	
	Запрос.Текст = ТекстЗапроса;
	Результат	 = Запрос.ВыполнитьПакет();
	
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла; 	
	ПараметрыПроведения.Вставить("Реквизиты", Реквизиты);
	
	ПодготовитьТаблицыДокументаРасчетыВВалюте(ПараметрыПроведения, Реквизиты);	

	Возврат ПараметрыПроведения;
	
КонецФункции 

&НаСервере 
Функция НачальныеОстатки(СчетаКассы) Экспорт
	
	НачальныеОстатки = Новый Соответствие; 
	Для каждого Элемент Из СчетаКассы Цикл
		НачальныеОстатки.Вставить(Элемент, 0);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СчетаКассы", СчетаКассы);

	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СведенияОбОстатках.БанковскийСчет КАК БанковскийСчет,
	|	СУММА(СведенияОбОстатках.СуммаОстаток) КАК Сумма
	|ИЗ
	|	РегистрНакопления.бит_СведенияОбОстаткахДенежныхСредств.Остатки(, БанковскийСчет В (&СчетаКассы)) КАК СведенияОбОстатках
	|
	|СГРУППИРОВАТЬ ПО
	|	СведенияОбОстатках.БанковскийСчет";
	
	Результат = Запрос.Выполнить();
	Выборка   = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		НачальныеОстатки.Вставить(Выборка.БанковскийСчет, Выборка.Сумма);
	КонецЦикла;
	
	Возврат НачальныеОстатки;
	
КонецФункции

Функция ДанныеБухгалтерскогоУчета(ПараметрыОбора) Экспорт
    	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", ПараметрыОбора.Организация);
	Запрос.УстановитьПараметр("Период",  	 НачалоДня(ПараметрыОбора.Дата));
	
	Если ПараметрыОбора.ИмяСписка = "СведенияОБанковскихСчетах" Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	""СведенияОБанковскихСчетах"" КАК ИмяСписка,
		|	ДенежныеСредства.БанковскийСчет КАК БанковскийСчет,
		|	ЕСТЬNULL(ДенежныеСредства.СуммаОстаток, 0) КАК СуммаНач,
		|	ЕСТЬNULL(ДенежныеСредства.СуммаОстаток, 0) КАК СуммаКон
		|ИЗ
		|	РегистрНакопления.ДенежныеСредстваБезналичные.Остатки(&Период, Организация = &Организация) КАК ДенежныеСредства
		|
		|УПОРЯДОЧИТЬ ПО
		|	БанковскийСчет";
	Иначе	
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	""СведенияОНаличных"" КАК ИмяСписка,
		|	ДенежныеСредства.Касса КАК Касса,
		|	ЕСТЬNULL(ДенежныеСредства.СуммаОстаток, 0) КАК СуммаНач,
		|	ЕСТЬNULL(ДенежныеСредства.СуммаОстаток, 0) КАК СуммаКон
		|ИЗ
		|	РегистрНакопления.ДенежныеСредстваНаличные.Остатки(&Период, Организация = &Организация) КАК ДенежныеСредства
		|
		|УПОРЯДОЧИТЬ ПО
		|	Касса";
	КонецЕсли;
		
	Результат = Запрос.Выполнить();
	
	ДанныеУчета = Новый Структура;
	ДанныеУчета.Вставить("ИмяСписка", ПараметрыОбора.ИмяСписка);
	ДанныеУчета.Вставить("Результат", Результат.Выгрузить());
	
	Возврат ДанныеУчета;
	
КонецФункции

Функция ДанныеУправленческогоУчета(ПараметрыОбора) Экспорт

	Если ПараметрыОбора.ИмяСписка = "СведенияОБанковскихСчетах" Тогда
		ВидДенежныхСредств = Перечисления.бит_ВидыДенежныхСредств.Безналичные;
	Иначе
		ВидДенежныхСредств = Перечисления.бит_ВидыДенежныхСредств.Наличные;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидДенежныхСредств", ВидДенежныхСредств);
	Запрос.УстановитьПараметр("Организация", 		ПараметрыОбора.Организация);
	Запрос.УстановитьПараметр("Период", 			НачалоДня(ПараметрыОбора.Дата));

	Если ПараметрыОбора.ИмяСписка = "СведенияОБанковскихСчетах" Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	""СведенияОБанковскихСчетах"" КАК ИмяСписка,
		|	ДенежныеСредства.БанковскийСчет КАК БанковскийСчет,
		|	ЕСТЬNULL(ДенежныеСредства.СуммаОстаток, 0) КАК СуммаНач,
		|	ЕСТЬNULL(ДенежныеСредства.СуммаОстаток, 0) КАК СуммаКон
		|ИЗ
		|	РегистрНакопления.бит_СведенияОбОстаткахДенежныхСредств.Остатки(
		|			&Период,
		|			Организация = &Организация
		|				И ВидДенежныхСредств = &ВидДенежныхСредств) КАК ДенежныеСредства
		|
		|УПОРЯДОЧИТЬ ПО
		|	БанковскийСчет";
	Иначе	
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	""СведенияОНаличных"" КАК ИмяСписка,
		|	ДенежныеСредства.БанковскийСчет КАК Касса,
		|	ЕСТЬNULL(ДенежныеСредства.СуммаОстаток, 0) КАК СуммаНач,
		|	ЕСТЬNULL(ДенежныеСредства.СуммаОстаток, 0) КАК СуммаКон
		|ИЗ
		|	РегистрНакопления.бит_СведенияОбОстаткахДенежныхСредств.Остатки(
		|			&Период,
		|			Организация = &Организация
		|				И ВидДенежныхСредств = &ВидДенежныхСредств) КАК ДенежныеСредства
		|
		|УПОРЯДОЧИТЬ ПО
		|	Касса";
	КонецЕсли;	
	
	Результат = Запрос.Выполнить();
	
	ДанныеУчета = Новый Структура;
	ДанныеУчета.Вставить("ИмяСписка", ПараметрыОбора.ИмяСписка);
	ДанныеУчета.Вставить("Результат", Результат.Выгрузить());

	Возврат ДанныеУчета;

КонецФункции

