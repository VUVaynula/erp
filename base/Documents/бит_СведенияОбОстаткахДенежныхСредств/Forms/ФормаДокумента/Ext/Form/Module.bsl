
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.ОбновлениеВерсииИБ
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ОбновлениеВерсииИБ

	// Cтандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаОбъектаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);

	Если Параметры.Ключ.Пустая() Тогда
		УстановитьСостояниеДокумента();
	КонецЕсли; 
	
	ЕстьСправочникКассы = Метаданные.Справочники.Найти("Кассы") <> Неопределено;
	ТекущаяОрганизация  = Объект.Организация;
	ВалютаРеглУчета		= Константы.ВалютаРегламентированногоУчета.Получить();
	
	Если ЕстьСправочникКассы Тогда
		// Добавить поле Касса.Валюта
		НовыйЭлемент = Элементы.Добавить("СведенияОНаличныхКассаВалютаДенежныхСредств", Тип("ПолеФормы"), Элементы.СведенияОНаличных);
		НовыйЭлемент.Вид					  = ВидПоляФормы.ПолеНадписи;
		НовыйЭлемент.ПутьКДанным 			  = "Объект.СведенияОНаличных.Касса.ВалютаДенежныхСредств";
		НовыйЭлемент.Ширина 	 			  = 8;
		НовыйЭлемент.Заголовок   			  = НСтр("ru = 'Валюта'; en = 'Currency'");
		НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
		Элементы.Переместить(НовыйЭлемент, Элементы.СведенияОНаличных, Элементы.СведенияОНаличныхСуммаНач);
	КонецЕсли;
	
	УправлениеЭлементамиФормы(ЭтотОбъект);
	УстановитьУсловноеОформление();
		
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	УстановитьСостояниеДокумента();
	
КонецПроцедуры

