#Область ЗаполнениеПоДаннымУчета

&НаКлиенте
Процедура НачатьЗаполнениеПоДаннымУчета(ИмяСписка, ВидУчета)
	
	ДлительнаяОперация = НачатьЗаполнениеПоДаннымУчетаНаСервере(ИмяСписка, ВидУчета);
	Оповещение		   = Новый ОписаниеОповещения("ЗаполнитьПоДаннымУчетаЗавершение", ЭтотОбъект);
	ПараметрыОжидания  = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
 
КонецПроцедуры

&НаСервере
Функция НачатьЗаполнениеПоДаннымУчетаНаСервере(Знач ИмяСписка, Знач ВидУчета)
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	
	Если ВидУчета = "БУ" Тогда
		ИмяФункции = "Документы.бит_СведенияОбОстаткахДенежныхСредств.ДанныеБухгалтерскогоУчета";
	Иначе	
		ИмяФункции = "Документы.бит_СведенияОбОстаткахДенежныхСредств.ДанныеУправленческогоУчета";
	КонецЕсли;
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("Организация", Объект.Организация);
	ПараметрыОтбора.Вставить("Дата", 		НачалоДня(Объект.Дата));
	ПараметрыОтбора.Вставить("ИмяСписка",	ИмяСписка);

	Результат = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ИмяФункции, ПараметрыОтбора);
	
	Возврат Результат;
	
КонецФункции

// Обработчик завершения длительной операции НачатьЗаполнениеПоДаннымУчета.
//  См. Синтакс-помощник: Новый ОписаниеОповещения().
//
&НаКлиенте
Процедура ЗаполнитьПоДаннымУчетаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда // Пользователь отменил задание.
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ВызватьИсключение Результат.КраткоеПредставлениеОшибки;
	КонецЕсли;
	
	ЗаполнитьПоДаннымУчетаЗавершениеНаСервере(Результат.АдресРезультата);
 
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоДаннымУчетаЗавершениеНаСервере(Знач АдресРезультата)

	ДанныеУчета = ПолучитьИзВременногоХранилища(АдресРезультата);
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	Объект[ДанныеУчета.ИмяСписка].Загрузить(ДанныеУчета.Результат);
	Модифицированность = Истина;
	
КонецПроцедуры
	
#КонецОбласти
 
&НаКлиенте
Процедура ПроверитьЗаполнениеОрганизации(Отказ)

	Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("ПОЛЕ" , 
							"Заполнение", НСтр("ru = 'Организация'"));
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "Организация", "Объект", Отказ);
	КонецЕсли;	

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОчиститьСписки(Форма)

	Объект = Форма.Объект;
	Объект.СведенияОБанковскихСчетах.Очистить();
	Если Форма.ЕстьСправочникКассы Тогда
		Объект.СведенияОНаличных.Очистить();		
	КонецЕсли;

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеЭлементамиФормы(Форма)
	
	Элементы = Форма.Элементы;
	Объект   = Форма.Объект;
	
	Элементы.СведенияОНаличныхВалюта.Видимость = НЕ Форма.ЕстьСправочникКассы;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьКурсКратностьВалюты(Знач Валюта)
	
	КурсВалюты = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Валюта, Объект.Дата);
	
	Возврат КурсВалюты;
	
КонецФункции

&НаКлиенте
Процедура РассчитатьСуммуКонечныйОстатокВСтроке(ТекущиеДанные)
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.СуммаКон = ТекущиеДанные.СуммаНач + ТекущиеДанные.СуммаПриход - ТекущиеДанные.СуммаРасход;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменениеВалютыВСтроке(ТекущиеДанные) 

	// Спросим, а не пересчитать ли суммы
	Если ТекущаяВалютаВСтроке <> ТекущиеДанные.Валюта
		И (ТекущиеДанные.СуммаНач <> 0
		ИЛИ ТекущиеДанные.СуммаПриход <> 0
		ИЛИ ТекущиеДанные.СуммаРасход <> 0
		ИЛИ ТекущиеДанные.СуммаКон <> 0) Тогда
		
		ТекстВопроса = НСтр("ru = 'Изменилась валюта в строке табличной части. Пересчитать суммы в строке?'; 
							|en = 'The currency in the table part row has changed. Recalculate the amounts in a row?'") ;
		ОповещениеВопрос = Новый ОписаниеОповещения("ВопросИзменениеВалютыВСтроке", ЭтотОбъект, ТекущиеДанные);
		ПоказатьВопрос(ОповещениеВопрос, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 60, КодВозвратаДиалога.Нет);
	Иначе
		ТекущаяВалютаВСтроке = ТекущиеДанные.Валюта;
	КонецЕсли; 
		
КонецПроцедуры // ИзменениеВалютыВФорме()

// Обработка оповещения вопроса пользователю. 
// 
// Параметры:
//  Ответ - Строка.
//  ТекущиеДанные - ТаблицаЗначений.
// 
&НаКлиенте
Процедура ВопросИзменениеВалютыВСтроке(Ответ, ТекущиеДанные) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда    
			
		СтруктураКурсаТекущейВалюты = ПолучитьКурсКратностьВалюты(ТекущаяВалютаВСтроке);
		СтруктураКурсаНовойВалюты   = ПолучитьКурсКратностьВалюты(ТекущиеДанные.Валюта);
		
		ТекущиеДанные.СуммаНач = бит_КурсыВалютКлиентСервер.ПересчитатьИзВалютыВВалюту(ТекущиеДанные.СуммаНач
																,ТекущаяВалютаВСтроке
																,ТекущиеДанные.Валюта
																,СтруктураКурсаТекущейВалюты.Курс
																,СтруктураКурсаНовойВалюты.Курс
																,СтруктураКурсаТекущейВалюты.Кратность
																,СтруктураКурсаНовойВалюты.Кратность);
		
		ТекущиеДанные.СуммаПриход = бит_КурсыВалютКлиентСервер.ПересчитатьИзВалютыВВалюту(ТекущиеДанные.СуммаПриход
																,ТекущаяВалютаВСтроке
																,ТекущиеДанные.Валюта
																,СтруктураКурсаТекущейВалюты.Курс
																,СтруктураКурсаНовойВалюты.Курс
																,СтруктураКурсаТекущейВалюты.Кратность
																,СтруктураКурсаНовойВалюты.Кратность);
		
		ТекущиеДанные.СуммаРасход = бит_КурсыВалютКлиентСервер.ПересчитатьИзВалютыВВалюту(ТекущиеДанные.СуммаРасход
																,ТекущаяВалютаВСтроке
																,ТекущиеДанные.Валюта
																,СтруктураКурсаТекущейВалюты.Курс
																,СтруктураКурсаНовойВалюты.Курс
																,СтруктураКурсаТекущейВалюты.Кратность
																,СтруктураКурсаНовойВалюты.Кратность);
		
		ТекущиеДанные.СуммаКон = бит_КурсыВалютКлиентСервер.ПересчитатьИзВалютыВВалюту(ТекущиеДанные.СуммаКон
																,ТекущаяВалютаВСтроке
																,ТекущиеДанные.Валюта
																,СтруктураКурсаТекущейВалюты.Курс
																,СтруктураКурсаНовойВалюты.Курс
																,СтруктураКурсаТекущейВалюты.Кратность
																,СтруктураКурсаНовойВалюты.Кратность);														
																
		

	КонецЕсли;
		
	ТекущаяВалютаВСтроке = ТекущиеДанные.Валюта;
		
КонецПроцедуры
 
&НаКлиенте
Процедура РассчитатьОбортыПриИзмененииКонечногоОстатка(ТекущиеДанные)

	Дельта = ТекущиеДанные.СуммаКон - ТекущиеДанные.СуммаНач
		   - ТекущиеДанные.СуммаПриход + ТекущиеДанные.СуммаРасход;	
	Если Дельта > 0 Тогда
		ТекущиеДанные.СуммаПриход = ТекущиеДанные.СуммаПриход + Дельта;
	ИначеЕсли Дельта < 0 Тогда	
		ТекущиеДанные.СуммаРасход = ТекущиеДанные.СуммаРасход - Дельта;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСостояниеДокумента()
	
	СостояниеДокумента = бит_ОбщегоНазначения.СостояниеДокумента(Объект);
	
КонецПроцедуры

