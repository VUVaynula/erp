	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'Касса'"));
		
	// СведенияОНаличных.Касса
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	// АПК:277-выкл Проектное решение вызвать функционал другой подсистемы.
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "СведенияОНаличныхКасса");
	// АПК:277-вкл
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.СведенияОНаличных.Валюта", ВидСравненияКомпоновкиДанных.НеРавно, ВалютаРеглУчета);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.СведенияОНаличных.Валюта", ВидСравненияКомпоновкиДанных.Заполнено, "");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		Новый ПолеКомпоновкиДанных("ЕстьСправочникКассы"), ВидСравненияКомпоновкиДанных.Равно, Ложь);

	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Текст",		   НСтр("ru = 'Касса (в валюте)'"));
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);

КонецПроцедуры

