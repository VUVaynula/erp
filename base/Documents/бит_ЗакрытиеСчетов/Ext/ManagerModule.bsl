Функция ТекстЗапросаНастройкаЗакрытия(НомераТаблиц)
	
	НомераТаблиц.Вставить("НастройкаЗакрытия", НомераТаблиц.Количество());
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ИменаРесурсов.ИмяРесурса КАК ИмяРесурса,
	|	ИменаРесурсов.ИмяРеквизита КАК ИмяРеквизита
	|ИЗ
	|	Справочник.бит_НастройкиЗакрытия.ИменаРесурсов КАК ИменаРесурсов
	|ГДЕ
	|	ИменаРесурсов.Ссылка = &НастройкаЗакрытия";

	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции
 
Процедура ДобавитьПроводку(Проводка, Реквизиты,  Данные, СторонаПроводки, ИменаРесурсов)
	
	Проводка.Период = Реквизиты.Период;	
	ЗаполнитьЗначенияСвойств(Проводка, Реквизиты);
	ЗаполнитьЗначенияСвойств(Проводка, Данные);
	
	// Заполним сторону проводки для счета.
	ЗаполнитьСторонуПроводкиДляСчета("Счет", Проводка, Данные, СторонаПроводки);
	
	СторонаПроводки = ?(СторонаПроводки = "Дт", "Кт", "Дт");
	
	// Заполним сторону проводки для счета закрытия.
	ЗаполнитьСторонуПроводкиДляСчета("СчетЗакрытия", Проводка, Данные, СторонаПроводки);
	
	// Заполним суммы.
    МетаРегРесурсы = Метаданные.РегистрыБухгалтерии[Реквизиты.ИмяРегистра].Ресурсы;
    Для Каждого ТекИмя Из ИменаРесурсов Цикл
        
        ТекИмяРесурса = ТекИмя.ИмяРесурса;
        МетаРесурса   = МетаРегРесурсы.Найти(ТекИмяРесурса);
        
        Если МетаРесурса <> Неопределено Тогда
            Если МетаРесурса.Балансовый Тогда
                Проводка[ТекИмяРесурса] = Данные[ТекИмя.ИмяРеквизита];
            Иначе
                Если Реквизиты.ИмяРегистра = "Хозрасчетный" 
                    И (ТекИмяРесурса = "СуммаНУ" ИЛИ ТекИмяРесурса = "СуммаПР" ИЛИ ТекИмяРесурса = "СуммаВР") Тогда
                    СвойстваСчетаДт = бит_БухгалтерскийУчетВызовСервераПовтИсп.ПолучитьСвойстваСчета(Проводка.СчетДт);
                    СвойстваСчетаКт = бит_БухгалтерскийУчетВызовСервераПовтИсп.ПолучитьСвойстваСчета(Проводка.СчетКт);
                    Если СвойстваСчетаДт.НалоговыйУчет Тогда
                        Проводка[ТекИмяРесурса + "Дт"] = Данные[ТекИмя.ИмяРеквизита];
                    КонецЕсли;
                    Если СвойстваСчетаКт.НалоговыйУчет Тогда
                        Проводка[ТекИмяРесурса + "Кт"] = Данные[ТекИмя.ИмяРеквизита];
                    КонецЕсли;
                Иначе	
                    Проводка[ТекИмяРесурса + "Дт"] = Данные[ТекИмя.ИмяРеквизита];
                    Проводка[ТекИмяРесурса + "Кт"] = Данные[ТекИмя.ИмяРеквизита];
                КонецЕсли;                
            КонецЕсли;
        Иначе
            Проводка[ТекИмяРесурса] = Данные[ТекИмя.ИмяРеквизита];
        КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСторонуПроводкиДляСчета(ИмяРеквизитаСчет, Проводка, Данные, СторонаПроводки)
	
	ИмяСчета = "Счет" + СторонаПроводки;
    Проводка[ИмяСчета] = Данные[ИмяРеквизитаСчет];
    
    Счет		  = Проводка[ИмяСчета];
    СвойстваСчета = бит_БухгалтерскийУчетВызовСервераПовтИсп.ПолучитьСвойстваСчета(Счет);
		
	НачИмяСубконто = ?(ИмяРеквизитаСчет = "Счет", "Субконто", "СубконтоЗакрытия");
	
	Для Ном = 1 По СвойстваСчета.КоличествоСубконто Цикл
		бит_БухгалтерскийУчет.УстановитьСубконто(Счет, Проводка["Субконто" + СторонаПроводки], Ном, Данные[НачИмяСубконто + Ном]);
	КонецЦикла;	
	
	Если СвойстваСчета.УчетПоПодразделениям Тогда
		ИмяПодразделения = ?(ИмяРеквизитаСчет = "Счет", "Подразделение", "ПодразделениеЗакрытия"); 
		Проводка["Подразделение" + СторонаПроводки] = Данные[ИмяПодразделения];
	КонецЕсли; 
	
	Если СвойстваСчета.Количественный Тогда
		Проводка["Количество" + СторонаПроводки] = Данные.Количество;
	КонецЕсли;
            
	Если СвойстваСчета.Валютный Тогда
		Проводка["Валюта"		 + СторонаПроводки] = Данные.Валюта;
		Проводка["ВалютнаяСумма" + СторонаПроводки] = Данные.ВалютнаяСумма;
	КонецЕсли; 
	
КонецПроцедуры

Процедура ЗаполнитьСодержаниеПроводки(ТаблицаЗакрытия, Сторно)

	Для каждого СтрокаТаблицы Из ТаблицаЗакрытия Цикл
		Если ПустаяСтрока(СтрокаТаблицы.Содержание) Тогда
			СтрокаТаблицы.Содержание = СтрШаблон(НСтр("ru='Закрытие счета %1';en='Closing an account %1'"), СтрокаТаблицы.СчетПредставление);
		КонецЕсли; 
		
		Если Сторно Тогда
			СтрокаТаблицы.Содержание = НСтр("ru = 'Сторно:'") +  СтрокаТаблицы.Содержание;	
		КонецЕсли;
	КонецЦикла; 
	
КонецПроцедуры
 
#КонецОбласти 

#КонецЕсли
