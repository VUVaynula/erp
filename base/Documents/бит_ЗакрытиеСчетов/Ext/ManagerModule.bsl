Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт
	
	ПараметрыПроведения = Новый Структура;
	ПараметрыПроведения.Вставить("СторноЗакрытиеСчетов", 		Новый ТаблицаЗначений);
	ПараметрыПроведения.Вставить("СторноЗакрытиеСчетовТаблица", Новый ТаблицаЗначений);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.Дата КАК Период,
	|	Реквизиты.Сторно КАК Сторно,
	|	Реквизиты.РегистрБухгалтерии КАК РегистрБухгалтерии,
	|	Реквизиты.НастройкаЗакрытия КАК НастройкаЗакрытия
	|ИЗ
	|	Документ.бит_ЗакрытиеСчетов КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка";
	
	Результат    	 = Запрос.Выполнить();
	ТаблицаРеквизиты = Результат.Выгрузить();
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ТаблицаРеквизиты[0]);

	НомераТаблиц = Новый Структура;
	Запрос.Текст = ТекстЗапросаЗакрытиеСчетов(НомераТаблиц, Реквизиты)
				 + ТекстЗапросаНастройкаЗакрытия(НомераТаблиц);
	
	Запрос.УстановитьПараметр("НастройкаЗакрытия", Реквизиты.НастройкаЗакрытия);
	
	ПараметрыРегистра = бит_РегламентныеЗакрытия.ПараметрыРегистраБухгалтерии(Реквизиты.РегистрБухгалтерии);
	Для каждого КлючЗначение Из ПараметрыРегистра Цикл
		Запрос.УстановитьПараметр(КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла; 

	Результат = Запрос.ВыполнитьПакет();
	Для каждого НомерТаблицы Из НомераТаблиц Цикл
		ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
	КонецЦикла;
	
	ЗаполнитьСодержаниеПроводки(ПараметрыПроведения.ЗакрытиеСчетовТаблица, Ложь);
	ЗаполнитьСодержаниеПроводки(ПараметрыПроведения.СторноЗакрытиеСчетовТаблица, Истина);
	
	Возврат ПараметрыПроведения;
	
КонецФункции 

Процедура СформироватьПроводки(ТаблицаЗакрытиеСчетов, ТаблицаРеквизиты, НастройкаЗакрытия, Движения, Отказ) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ТаблицаЗакрытиеСчетов) ИЛИ НЕ ЗначениеЗаполнено(ТаблицаРеквизиты) Тогда
		Возврат;
	КонецЕсли;

	Реквизиты = ТаблицаРеквизиты[0];
	
	НаборЗаписей = Движения[Реквизиты.ИмяРегистра];
	НаборЗаписей.Записывать = Истина;
	
	Для каждого СтрокаТаблицы Из ТаблицаЗакрытиеСчетов Цикл
		Если ЗначениеЗаполнено(СтрокаТаблицы.ДтКт) Тогда
			СторонаПроводки = ?(СтрокаТаблицы.ДтКт = Перечисления.бит_ДтКт.Дт, "Кт", "Дт");
		Иначе	
			СвойстваСчета = бит_БухгалтерскийУчетВызовСервераПовтИсп.ПолучитьСвойстваСчета(СтрокаТаблицы.Счет);
			СторонаПроводки = ?(СвойстваСчета.Вид = ВидСчета.Активный 
								ИЛИ СвойстваСчета.Вид = ВидСчета.АктивноПассивный, "Кт", "Дт");
		КонецЕсли; 
							
		Проводка = НаборЗаписей.Добавить();
		ДобавитьПроводку(Проводка, Реквизиты, СтрокаТаблицы, СторонаПроводки, НастройкаЗакрытия);
	КонецЦикла;

КонецПроцедуры

