Функция ИменаРесурсов() Экспорт
	
	СписокИмен = Новый СписокЗначений;
	СписокИмен.Добавить("Сумма1");
	СписокИмен.Добавить("Сумма2");
	СписокИмен.Добавить("Сумма3");
	СписокИмен.Добавить("Сумма4");

	Возврат СписокИмен;
	
