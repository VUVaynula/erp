мКоличествоСубконтоМУ 			= 4;
мПроводки 			  			= Неопределено;
СтруктураДляПротоколаПроведения = Неопределено;

#КонецОбласти

#Иначе
  ВызватьИсключение НСтр("ru='Недопустимый вызов объекта на клиенте.';en='Invalid object call on client'");
#КонецЕсли