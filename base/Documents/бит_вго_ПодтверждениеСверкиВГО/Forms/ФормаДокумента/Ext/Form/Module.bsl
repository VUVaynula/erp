&НаСервере
Процедура ПодготовитьФормуНаСервере(СтандартнаяОбработка = Ложь)

	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект, СтандартнаяОбработка);
	УстановитьСостояниеДокумента();
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура УправлениеФормой()
	
	бит_НастройкиДоступностиЭлементовФорм.РазблокироватьЭлементы(ЭтотОбъект);
	
	бит_НастройкиДоступностиЭлементовФорм.ЗаблокироватьЭлементы(ЭтотОбъект);

КонецПроцедуры

// Процедура заполняет кэш значений, необходимый при работе на клиенте.
// 
// Параметры:
//  Нет.
// 
&НаСервере
Процедура ЗаполнитьКэшЗначений()

	КэшЗначений = Новый Структура;
	
	МетаданныеОбъекта = Метаданные.Документы.бит_вго_ПодтверждениеСверкиВГО;
	КэшЗначений.Вставить("ПредставлениеОбъекта", МетаданныеОбъекта.ПредставлениеОбъекта);
	КэшЗначений.Вставить("ИмяТипаОбъекта", "ДокументОбъект." + МетаданныеОбъекта.Имя);
	
	КэшЗначений.Вставить("ПустойКонтрагент", Справочники.Контрагенты.ПустаяСсылка());
	
	КэшЗначений.Вставить("ВидОбъектаРегистрБухгалтерии" , Перечисления.бит_ВидыОбъектовСистемы.РегистрБухгалтерии);
	КэшЗначений.Вставить("СписокДоступныхРегистров", бит_вго_Сервер.СформироватьСписокДоступныхРегистровБухгалтерииДляСверкиВГО());
 	
КонецПроцедуры

// Процедура устанавлиант видимость доступность элементов формы.
// 
// Параметры:
//  Нет
// 
&НаСервере
Процедура УстановитьВидимостьДоступностьПоРегБух()
	
	ЭтоРегистрБюдж = Объект.РегистрБухгалтерии.ИмяОбъекта = "бит_Бюджетирование";
	Элементы.Сценарий.Видимость = ЭтоРегистрБюдж;
                 	
КонецПроцедуры

&НаСервере
Функция РассчитатьРасхождениеСервер(Знач ЭтоПроведение = Ложь)
	
	Отказ = Ложь;
	ДокументОбъект = ДанныеФормыВЗначение(Объект, Тип(КэшЗначений.ИмяТипаОбъекта));	
	ДокументОбъект.ПолучитьДанныеДляПроверкиЗавершенияСверки(Отказ, ЭтоПроведение, Ложь, Модифицированность);
	ЗначениеВДанныеФормы(ДокументОбъект, Объект);
	Возврат Отказ;
	
КонецФункции

#КонецОбласти

#Область ПроцедурыИФункцииОбщегоНазначения

// Процедура выполняет действие, необходимые перед выбором контрагента.
// 
&НаКлиенте
Процедура НачалоВыбораКонтрагента(ТекущаяОрганизация, ДанныеВыбора, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(ТекущаяОрганизация) Тогда
		
		СтандартнаяОбработка = Ложь;
		СобственныеКонтрагенты = бит_ОбщегоНазначенияВызовСервера.СобственныеКонтрагентыПоОрганизации(ТекущаяОрганизация);
		
		ДанныеВыбора = СобственныеКонтрагенты;
		
	КонецЕсли;
	
КонецПроцедуры // НачалоВыбораКонтрагента()

&НаСервере
Процедура УстановитьСостояниеДокумента()
	
	СостояниеДокумента = бит_ОбщегоНазначения.СостояниеДокумента(Объект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеИнтервалаВГО(Знач ДатаНачала)
	
	Возврат бит_вго_Сервер.ДанныеИнтервалаВГО(ДатаНачала);
		
КонецФункции
  
&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьДанныеИнтервала(ДатаНачала, ДатаОкончания, ПериодичностьСверки, ПредставлениеПериода)
	
	ДанныеИнтервала = ДанныеИнтервалаВГО(ДатаНачала);
	ДатаНачала 			 = ДанныеИнтервала.ДатаНачала;
	ДатаОкончания 		 = ДанныеИнтервала.ДатаОкончания;
	ПериодичностьСверки  = ДанныеИнтервала.ПериодичностьСверкиВГО;
	ПредставлениеПериода = ДанныеИнтервала.ПредставлениеПериодаСверкиВГО;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

