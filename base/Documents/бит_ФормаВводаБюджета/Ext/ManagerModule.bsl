	СтрокаИзмерений = "";
	МассивСтрокИзмерений = Новый ТаблицаЗначений;
	
	Для Каждого ИмяИзмерения Из МассивИзмеренийРазворачивать Цикл
		
		СтрокаИзмерений = СтрокаИзмерений + ИмяИзмерения + ",";
		
