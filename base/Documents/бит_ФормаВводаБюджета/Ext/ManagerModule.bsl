Функция ТекстЗапросаКонтрольИсполненияБюджета(НомераТаблиц)
	
	НомераТаблиц.Вставить("ИсполнениеБюджетаРеквизиты", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ИсполнениеБюджета", НомераТаблиц.Количество());
    НомераТаблиц.Вставить("ВозвратЛимита", НомераТаблиц.Количество());
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Регистратор,
	|	Реквизиты.Дата КАК Дата,
	|	Реквизиты.ВалютаДокумента КАК Валюта,
	|	Реквизиты.СверхБюджета КАК СверхБюджета,
	|	Реквизиты.КурсДокумента КАК Курс,
	|	Реквизиты.КратностьДокумента КАК Кратность,
	|	Реквизиты.Сценарий.Валюта КАК ВалютаСценария,
	|	Реквизиты.Сценарий КАК Сценарий,
	|	Реквизиты.Сценарий КАК СценарийКонтролируемый,
	|	ЗНАЧЕНИЕ(Перечисление.бит_РежимыКонтроляПоБюджету.Бюджет) КАК РежимКонтроля,
	|	ИСТИНА КАК КонтролироватьБюджет,
	|	&НеУчитыватьСверхБюджета КАК НеУчитыватьСверхБюджета,
	|	Реквизиты.СписатьЛимиты КАК СписатьЛимиты,
	|	ЛОЖЬ КАК КонтролироватьВозвратЛимита
	|ИЗ
	|	Документ.бит_ФормаВводаБюджета КАК Реквизиты
	|ГДЕ
	|	Реквизиты.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВременнаяТаблицаДокумента.ИмяСписка КАК ИмяСписка,
	|	ВременнаяТаблицаДокумента.СинонимСписка КАК СинонимСписка,
	|	ВременнаяТаблицаДокумента.НомерТаблицы КАК НомерТаблицы,
	|	ВременнаяТаблицаДокумента.НомерСтроки КАК НомерСтроки,
	|	ВременнаяТаблицаДокумента.Период КАК Период,
	|	ВременнаяТаблицаДокумента.Сценарий КАК Сценарий,
	|	ВременнаяТаблицаДокумента.Валюта КАК Валюта,
	|	ВременнаяТаблицаДокумента.ЦФО КАК ЦФО,
	|	ВременнаяТаблицаДокумента.СтатьяОборотов КАК СтатьяОборотов,
	|	ВременнаяТаблицаДокумента.ЭтоКоэффициент КАК ЭтоКоэффициент,
	|	ВременнаяТаблицаДокумента.Количество КАК Количество,
	|	ВременнаяТаблицаДокумента.Сумма КАК Сумма,
	|	НЕ ВременнаяТаблицаДокумента.СтатьяОборотов.НеКонтролировать_Сумма КАК КонтролироватьСумму,
	|	НЕ ВременнаяТаблицаДокумента.СтатьяОборотов.НеКонтролировать_Количество КАК КонтролироватьКоличество,
	|	НЕ ВременнаяТаблицаДокумента.СтатьяОборотов.НеКонтролировать_Бюджеты КАК КонтролироватьПоСтатье,
	|	ВременнаяТаблицаДокумента.Аналитика_1 КАК Аналитика_1,
	|	ВременнаяТаблицаДокумента.Аналитика_2 КАК Аналитика_2,
	|	ВременнаяТаблицаДокумента.Аналитика_3 КАК Аналитика_3,
	|	ВременнаяТаблицаДокумента.Аналитика_4 КАК Аналитика_4,
	|	ВременнаяТаблицаДокумента.Аналитика_5 КАК Аналитика_5,
	|	ВременнаяТаблицаДокумента.Аналитика_6 КАК Аналитика_6,
	|	ВременнаяТаблицаДокумента.Аналитика_7 КАК Аналитика_7,
	// ++ ЕРП
	|	ВременнаяТаблицаДокумента.Аналитика_8 КАК Аналитика_8,
	|	ВременнаяТаблицаДокумента.Аналитика_9 КАК Аналитика_9,
	|	ВременнаяТаблицаДокумента.Аналитика_10 КАК Аналитика_10,
	|	ВременнаяТаблицаДокумента.Аналитика_11 КАК Аналитика_11,
	|	ВременнаяТаблицаДокумента.Аналитика_12 КАК Аналитика_12
	// -- ЕРП
	|ИЗ
	|	ВременнаяТаблицаДокумента КАК ВременнаяТаблицаДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_НастройкаКонтроляПоСценариям КАК НастройкаКонтроляПоСценариям
	|		ПО (НастройкаКонтроляПоСценариям.Сценарий = &Сценарий)
	|			И ВременнаяТаблицаДокумента.Период >= НастройкаКонтроляПоСценариям.Период
	|			И (ВременнаяТаблицаДокумента.Период <= НастройкаКонтроляПоСценариям.ДатаОкончания
	|				ИЛИ НастройкаКонтроляПоСценариям.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1))   
	|ГДЕ
	|	ВременнаяТаблицаДокумента.Сумма > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерТаблицы,
	|	НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВременнаяТаблицаДокумента.ИмяСписка КАК ИмяСписка,
	|	ВременнаяТаблицаДокумента.СинонимСписка КАК СинонимСписка,
	|	ВременнаяТаблицаДокумента.НомерТаблицы КАК НомерТаблицы,
	|	ВременнаяТаблицаДокумента.НомерСтроки КАК НомерСтроки,
	|	ВременнаяТаблицаДокумента.Период КАК Период,
	|	ВременнаяТаблицаДокумента.Сценарий КАК Сценарий,
	|	ВременнаяТаблицаДокумента.Валюта КАК Валюта,
	|	ВременнаяТаблицаДокумента.ЦФО КАК ЦФО,
	|	ВременнаяТаблицаДокумента.СтатьяОборотов КАК СтатьяОборотов,
	|	ВременнаяТаблицаДокумента.ЭтоКоэффициент КАК ЭтоКоэффициент,
	|	- ВременнаяТаблицаДокумента.Количество КАК Количество,
	|	- ВременнаяТаблицаДокумента.Сумма КАК Сумма,
	|	НЕ ВременнаяТаблицаДокумента.СтатьяОборотов.НеКонтролировать_Сумма КАК КонтролироватьСумму,
	|	НЕ ВременнаяТаблицаДокумента.СтатьяОборотов.НеКонтролировать_Количество КАК КонтролироватьКоличество,
	|	НЕ ВременнаяТаблицаДокумента.СтатьяОборотов.НеКонтролировать_Бюджеты КАК КонтролироватьПоСтатье,
	|	ВременнаяТаблицаДокумента.Аналитика_1 КАК Аналитика_1,
	|	ВременнаяТаблицаДокумента.Аналитика_2 КАК Аналитика_2,
	|	ВременнаяТаблицаДокумента.Аналитика_3 КАК Аналитика_3,
	|	ВременнаяТаблицаДокумента.Аналитика_4 КАК Аналитика_4,
	|	ВременнаяТаблицаДокумента.Аналитика_5 КАК Аналитика_5,
	|	ВременнаяТаблицаДокумента.Аналитика_6 КАК Аналитика_6,
	|	ВременнаяТаблицаДокумента.Аналитика_7 КАК Аналитика_7,
	// ++ ЕРП
	|	ВременнаяТаблицаДокумента.Аналитика_8 КАК Аналитика_8,
	|	ВременнаяТаблицаДокумента.Аналитика_9 КАК Аналитика_9,
	|	ВременнаяТаблицаДокумента.Аналитика_10 КАК Аналитика_10,
	|	ВременнаяТаблицаДокумента.Аналитика_11 КАК Аналитика_11,
	|	ВременнаяТаблицаДокумента.Аналитика_12 КАК Аналитика_12
	// -- ЕРП
	|ИЗ
	|	ВременнаяТаблицаДокумента КАК ВременнаяТаблицаДокумента 
	|ГДЕ
	|	ВременнаяТаблицаДокумента.Сумма < 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерТаблицы,
	|	НомерСтроки";
	
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции

Процедура ПодготовитьТаблицуИсполнениеБюджетаРасчетыВВалюте(ИсполнениеБюджета, ИсполнениеБюджетаРеквизиты)

	Если НЕ ЗначениеЗаполнено(ИсполнениеБюджета) ИЛИ НЕ ЗначениеЗаполнено(ИсполнениеБюджетаРеквизиты) Тогда
		Возврат;
	КонецЕсли;
	
	Реквизиты = ИсполнениеБюджетаРеквизиты[0];
	
	КурсВалютыДокумента = Новый Структура;
	КурсВалютыДокумента.Вставить("Валюта", 	  Реквизиты.Валюта);
	КурсВалютыДокумента.Вставить("Курс", 	  Реквизиты.Курс);
	КурсВалютыДокумента.Вставить("Кратность", Реквизиты.Кратность);
	
	КурсВалютыСценария = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Реквизиты.ВалютаСценария, Реквизиты.Дата);
	
	Для каждого СтрокаТаблицы Из ИсполнениеБюджета Цикл
		СтрокаТаблицы.Сумма = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(
								СтрокаТаблицы.Сумма, КурсВалютыДокумента, КурсВалютыСценария);
	КонецЦикла;																	

КонецПроцедуры

Процедура ПодготовитьТаблицыДокументаРасчетыВВалюте(ПараметрыПроведения, Реквизиты)

	Если ПараметрыПроведения.ТаблицаОборотыПоБюджетам.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Сценарии		  = ПараметрыПроведения.Сценарии;
	ТаблицаПериодов	  = ПараметрыПроведения.ТаблицаПериодов;
	ОборотыПоБюджетам = ПараметрыПроведения.ТаблицаОборотыПоБюджетам;
	КурсыПоПериодам	  = Неопределено;
	
	Если ТаблицаПериодов.Количество() >= 1000 Тогда
		ТаблицаПериодов.Индексы.Добавить("Сценарий");
	КонецЕсли; 
	
	Если ОборотыПоБюджетам.Количество() >= 1000 Тогда
		ОборотыПоБюджетам.Индексы.Добавить("Сценарий");
	КонецЕсли;
	
	Если Реквизиты.ИспользоватьКурсыСценария Тогда
		Для каждого СтрокаТаблицы Из Сценарии Цикл
			
			Отбор	= Новый Структура("Сценарий", СтрокаТаблицы.Сценарий);
			Периоды = ТаблицаПериодов.Скопировать(Отбор);
			Валюты  =  бит_Бюджетирование.ЗаполнитьСтруктуруПараметровПолученияКурсовПоПериодам(СтрокаТаблицы.Сценарий, Реквизиты.ВалютаДокумента);
		
			КурсыПоПериодам = бит_КурсыВалют.ПолучитьКурсыВалютПоПериодам(Периоды, Валюты, СтрокаТаблицы.Сценарий);
			
			НайденныСтроки = ОборотыПоБюджетам.НайтиСтроки(Отбор);
			бит_Бюджетирование.ВыполнитьПересчетыВТаблицеОборотов(НайденныСтроки, 
								КурсыПоПериодам, Реквизиты.КурсыВалют);

		КонецЦикла; 
	Иначе
		
		бит_Бюджетирование.ВыполнитьПересчетыВТаблицеОборотов(ОборотыПоБюджетам, 
								Неопределено, Реквизиты.КурсыВалют);
	КонецЕсли;
							
КонецПроцедуры

Функция НовыеПараметрыШапки()
	
	ПараметрыШапки = Новый Структура;
	ПараметрыШапки.Вставить("Периодичность");
	ПараметрыШапки.Вставить("ПродолжительностьИнтервала");
	ПараметрыШапки.Вставить("ДатаНачалаПланирования");
	ПараметрыШапки.Вставить("ДатаОкончанияПланирования");
	ПараметрыШапки.Вставить("ДанныеТЧВРегистре");
	
	Возврат ПараметрыШапки;
	
КонецФункции

Процедура ИнициализироватьКлючиАналитик(Реквизиты)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Регистратор", Реквизиты.Регистратор);
	Запрос.УстановитьПараметр("Сценарий", 	 Реквизиты.Сценарий);

	Если Реквизиты.ДанныеТЧВРегистре Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ФормаВводаБюджетаБДДС.ЦФО КАК ЦФО,
		|	&Сценарий КАК Сценарий
		|ПОМЕСТИТЬ ДанныеБюджета
		|ИЗ
		|	РегистрСведений.бит_ФормаВводаБюджетаБДДС КАК ФормаВводаБюджетаБДДС
		|ГДЕ
		|	ФормаВводаБюджетаБДДС.ДокументВладелец = &Регистратор
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ФормаВводаБюджетаЗависимыеОбороты.ЦФО,
		|	&Сценарий
		|ИЗ
		|	РегистрСведений.бит_ФормаВводаБюджетаЗависимыеОбороты КАК ФормаВводаБюджетаЗависимыеОбороты
		|ГДЕ
		|	ФормаВводаБюджетаЗависимыеОбороты.ДокументВладелец = &Регистратор";
	Иначе
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ДанныеБюджета.ЦФО КАК ЦФО,
		|	&Сценарий КАК Сценарий
		|ПОМЕСТИТЬ ДанныеБюджета
		|ИЗ
		|	Документ.бит_ФормаВводаБюджета.БДДС КАК ДанныеБюджета
		|ГДЕ
		|	ДанныеБюджета.Ссылка = &Регистратор
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗависимыеОбороты.ЦФО,
		|	&Сценарий
		|ИЗ
		|	Документ.бит_ФормаВводаБюджета.ЗависимыеОбороты КАК ЗависимыеОбороты
		|ГДЕ
		|	ЗависимыеОбороты.Ссылка = &Регистратор";
	КонецЕсли;
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	ТекстЗапроса = ТекстЗапроса +
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДанныеБюджета.Сценарий КАК Сценарий,
	|	ДанныеБюджета.ЦФО КАК ЦФО
	|ПОМЕСТИТЬ УникальныеДанныеБюджета
	|ИЗ
	|	ДанныеБюджета КАК ДанныеБюджета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УникальныеДанныеБюджета.Сценарий КАК Сценарий,
	|	УникальныеДанныеБюджета.ЦФО КАК ЦФО,
	|	АналитикаСценарийЦФО.КлючАналитики КАК КлючАналитики
	|ИЗ
	|	УникальныеДанныеБюджета КАК УникальныеДанныеБюджета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_АналитикаСценарийЦФО КАК АналитикаСценарийЦФО
	|		ПО УникальныеДанныеБюджета.Сценарий = АналитикаСценарийЦФО.Сценарий
	|			И УникальныеДанныеБюджета.ЦФО = АналитикаСценарийЦФО.ЦФО
	|ГДЕ
	|	АналитикаСценарийЦФО.КлючАналитики ЕСТЬ NULL";
	
	Запрос.Текст = ТекстЗапроса;
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Справочники.бит_КлючиСценарийЦФО.КлючиСценарийЦФОДокумента(Выборка);
	КонецЦикла;

КонецПроцедуры

#КонецОбласти 

#КонецЕсли