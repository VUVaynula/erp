	|	ДанныеТабличнойЧасти.Аналитика_7 КАК Аналитика_7,
	|	ДанныеТабличнойЧасти.Количество КАК Количество,
	|	ДанныеТабличнойЧасти.Норма КАК Норма,
	|	ДанныеТабличнойЧасти.Сумма КАК Сумма,
	|	ДанныеТабличнойЧасти.Измерение КАК Измерение,
	|	ДанныеТабличнойЧасти.Расчетная КАК Расчетная,
	|	ДанныеТабличнойЧасти.Комментарий КАК Комментарий,
	|	ДанныеТабличнойЧасти.КомментарийРасчета КАК КомментарийРасчета,
	|	КлючиАналитик.КлючДоступаЦФОСтатьиОборотов КАК КлючДоступаЦФОСтатьиОборотов,
	|	ВЫБОР
	|		КОГДА КлючиАналитик.КлючДоступаЦФОСтатьиОборотов = ЗНАЧЕНИЕ(Справочник.бит_КлючиДоступаЦФОСтатьиОборотов.ПустаяСсылка)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК СоздатьКлюч
	|ИЗ
	|	ДанныеТабличнойЧасти КАК ДанныеТабличнойЧасти
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ КлючиАналитик КАК КлючиАналитик
	|		ПО ДанныеТабличнойЧасти.ЦФО = КлючиАналитик.ЦФО
	|			И ДанныеТабличнойЧасти.СтатьяОборотов = КлючиАналитик.СтатьяОборотов
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтрокиДокумента";
	ВыборкаСтрокТЧ = Запрос.Выполнить().Выбрать();
	Пока ВыборкаСтрокТЧ.Следующий() Цикл
		Запись = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, ВыборкаСтрокТЧ);
		Если ВыборкаСтрокТЧ.СоздатьКлюч Тогда
			Запись.КлючДоступаЦФОСтатьиОборотов = Справочники.бит_КлючиДоступаЦФОСтатьиОборотов.КлючиЦФОСтатьяОборотовДокумента(
										ВыборкаСтрокТЧ.ЦФО, ВыборкаСтрокТЧ.СтатьяОборотов);
		КонецЕсли;
	КонецЦикла;
	НаборЗаписей.Записать();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	БДДС.Очистить();
	ЗависимыеОбороты.Очистить();
	
КонецПроцедуры

Процедура ОчиститьЗаписиРегистров()
	
	ДанныеТЧВРегистре = Ложь;
	
	Если ЭтоНовый() Тогда
		Возврат;
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.бит_ФормаВводаБюджетаБДДС.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ДокументВладелец.Установить(Ссылка);
	НаборЗаписей.Записать();
	
	НаборЗаписей = РегистрыСведений.бит_ФормаВводаБюджетаЗависимыеОбороты.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ДокументВладелец.Установить(Ссылка);
	НаборЗаписей.Записать();
	
КонецПроцедуры

#Область ФормированиеДерева

// Устарела. Следует использовать Документы.бит_ФормаВводаБюджета.ПреобразоватьПериод(). 
