	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ДокументВладелец",     СсылкаНаДокумент);
	Запрос.УстановитьПараметр("ДанныеТабличнойЧасти", БДДС);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДанныеТабличнойЧасти.НомерСтроки КАК НомерСтрокиДокумента,
