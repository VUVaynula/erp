	СтрВрем = НСтр("ru='Выполнено ручное редактирование. Пользователь ""%1"", время ""%2""';
				   |en='Achieved manual editing. User ""%1"", while ""%2""'");
	СтрВрем = СтрШаблон(СтрВрем, Строка(фКэшЗначений.ТекущийПользователь), 
					Формат(ОбщегоНазначенияКлиент.ДатаСеанса(),"ДЛФ=D"));
	ТекущаяСтрока.КомментарийРасчета = ТекущаяСтрока.КомментарийРасчета + "<p>" + СтрВрем + "</p>";
	
