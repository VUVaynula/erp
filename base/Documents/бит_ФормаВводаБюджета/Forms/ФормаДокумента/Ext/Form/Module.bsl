&НаКлиентеНаСервереБезКонтекста
Функция ПараметрыРасчетаЦен(Форма)
	
	Объект = Форма.Объект;
	КэшЗначений = Форма.фКэшЗначений;
	ИспользоватьНормы = Форма.фИспользоватьНормы;
	
	ПараметрыРасчетаЦен = Новый Структура;
	ПараметрыРасчетаЦен.Вставить("ЗаполнитьПоТипуЦен", Ложь);
	ПараметрыРасчетаЦен.Вставить("ЗаполнитьПоНорме"  , Ложь);
	ПараметрыРасчетаЦен.Вставить("ТипЦен"); 
	ПараметрыРасчетаЦен.Вставить("АналитикаНоменклатуры");
	ПараметрыРасчетаЦен.Вставить("СтруктураКурсаДокумента");
	ПараметрыРасчетаЦен.Вставить("ДатаДокумента");
	ПараметрыРасчетаЦен.Вставить("ТолькоНулевыеСуммы", Ложь);
	ПараметрыРасчетаЦен.Вставить("ПараметрНорм"); 
	ПараметрыРасчетаЦен.Вставить("ИменаПараметраНорм");
	
	Если Объект.ЗаполнятьПоЦенамНоменклатуры И ЗначениеЗаполнено(Объект.ТипЦен) Тогда
		ПараметрыРасчетаЦен.ТипЦен  = Объект.ТипЦен;
		
		ТипНоменклатура = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
		Для каждого НастройкаИзмерения Из КэшЗначений.НастройкиИзмерений Цикл
			Если ТипЗнч(НастройкаИзмерения.Значение) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			
			Если НастройкаИзмерения.Значение.ТипЗначения = ТипНоменклатура Тогда
				ПараметрыРасчетаЦен.АналитикаНоменклатуры = НастройкаИзмерения.Ключ;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ ЗначениеЗаполнено(ПараметрыРасчетаЦен.АналитикаНоменклатуры) Тогда
			ТекстСообщения = НСтр("ru = 'Не удалось определить аналитики для расчета цен.';
								  |en = 'Cant find match dimensions for price count.'");
			#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			#Иначе
				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			#КонецЕсли 
		Иначе
			ПараметрыРасчетаЦен.ЗаполнитьПоТипуЦен = Истина;
		КонецЕсли;
	ИначеЕсли НЕ Объект.ЗаполнятьПоЦенамНоменклатуры И ЗначениеЗаполнено(Объект.ПараметрНорм) И ИспользоватьНормы Тогда
		ПараметрыРасчетаЦен.ПараметрНорм       = Объект.ПараметрНорм;
		ПараметрыРасчетаЦен.ЗаполнитьПоНорме   = Истина;
		ПараметрыРасчетаЦен.ИменаПараметраНорм = ИменаПараметраНорм(Объект.ПараметрНорм);
	КонецЕсли;
		
	СтруктураКурсаДокумента     = Новый Структура("Валюта, Курс, Кратность",
									Объект.ВалютаДокумента, Объект.КурсДокумента, Объект.КратностьДокумента);
	ПараметрыРасчетаЦен.СтруктураКурсаДокумента = СтруктураКурсаДокумента;
	ПараметрыРасчетаЦен.ДатаДокумента           = Объект.Дата;
	
	Возврат ПараметрыРасчетаЦен;
	
КонецФункции

&НаСервереБезКонтекста
Функция ИменаПараметраНорм(ПараметрНорм)
	
	Результат = ПланыВидовХарактеристик.бит_ВидыПроизвольныхПараметров.ПодготовитьСтруктурыСвязи(ПараметрНорм);
	Возврат Результат;	
	
КонецФункции

&НаСервере
Процедура ОбработкаОповещенияИзмененияСтатуса()
	
	Прочитать();
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьФормуНаСервере(ИсточникЗаполнения = Неопределено, СтандартнаяОбработка = Ложь)
	
	бит_НастройкиДоступностиЭлементовФорм.ПодготовитьФорму(ЭтотОбъект, Объект, СтандартнаяОбработка);
	
	Если НЕ ЗначениеЗаполнено(ИсточникЗаполнения) Тогда
		ИсточникЗаполнения = Объект.Ссылка;
	КонецЕсли;
	ЗагрузитьДанныеТЧ(ИсточникЗаполнения);
	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.ЦФО, Объект.Дата);
	
	бит_ВизированиеСервер.ЗаполнитьРеквизитыСтатусаВФорме(ЭтотОбъект, Объект);
	УстановитьСостояниеДокумента();	
	
	АвтовидимостьКолонок = Истина;
	
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьДанныеТЧ(Ссылка)
	
	Если Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ДанныеТЧВРегистре") Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументВладелец", Ссылка);
	
	Объект.БДДС.Очистить();
	Запрос.Текст =
	"ВЫБРАТЬ
	|	БДДС.ИД КАК ИД,
	|	БДДС.ПериодСтрокиДокумента КАК Период,
	|	БДДС.ЦФО КАК ЦФО,
	|	БДДС.СтатьяОборотов КАК СтатьяОборотов,
	// ++ ЕРП
	|	БДДС.Аналитика_8 КАК Аналитика_8,
	|	БДДС.Аналитика_9 КАК Аналитика_9,
	|	БДДС.Аналитика_10 КАК Аналитика_10,
	|	БДДС.Аналитика_11 КАК Аналитика_11,
	|	БДДС.Аналитика_12 КАК Аналитика_12,
	// -- ЕРП
	|	БДДС.Аналитика_1 КАК Аналитика_1,
	|	БДДС.Аналитика_2 КАК Аналитика_2,
	|	БДДС.Аналитика_3 КАК Аналитика_3,
	|	БДДС.Аналитика_4 КАК Аналитика_4,
	|	БДДС.Аналитика_5 КАК Аналитика_5,
	|	БДДС.Аналитика_6 КАК Аналитика_6,
	|	БДДС.Аналитика_7 КАК Аналитика_7,
	|	БДДС.Количество КАК Количество,
	|	БДДС.Норма КАК Норма,
	|	БДДС.Сумма КАК Сумма,
	|	БДДС.Измерение КАК Измерение,
	|	БДДС.Расчетная КАК Расчетная,
	|	БДДС.Комментарий КАК Комментарий
	|ИЗ
	|	РегистрСведений.бит_ФормаВводаБюджетаБДДС КАК БДДС
	|ГДЕ
	|	БДДС.ДокументВладелец = &ДокументВладелец
	|
	|УПОРЯДОЧИТЬ ПО
	|	БДДС.НомерСтрокиДокумента";
	ВыборкаСтрок = Запрос.Выполнить().Выбрать();
	Пока ВыборкаСтрок.Следующий() Цикл
		НоваяСтрока = Объект.БДДС.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаСтрок);
	КонецЦикла;
	
	Объект.ЗависимыеОбороты.Очистить();
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗависимыеОбороты.ИД КАК ИД,
	|	ЗависимыеОбороты.ИД_Родитель КАК ИД_Родитель,
	|	ЗависимыеОбороты.ПериодСтрокиДокумента КАК Период,
	|	ЗависимыеОбороты.ЦФО КАК ЦФО,
	|	ЗависимыеОбороты.СтатьяОборотов КАК СтатьяОборотов,
	// ++ ЕРП
	|	ЗависимыеОбороты.Аналитика_8 КАК Аналитика_8,
	|	ЗависимыеОбороты.Аналитика_9 КАК Аналитика_9,
	|	ЗависимыеОбороты.Аналитика_10 КАК Аналитика_10,
	|	ЗависимыеОбороты.Аналитика_11 КАК Аналитика_11,
	|	ЗависимыеОбороты.Аналитика_12 КАК Аналитика_12,
	// -- ЕРП
	|	ЗависимыеОбороты.Аналитика_1 КАК Аналитика_1,
	|	ЗависимыеОбороты.Аналитика_2 КАК Аналитика_2,
	|	ЗависимыеОбороты.Аналитика_3 КАК Аналитика_3,
	|	ЗависимыеОбороты.Аналитика_4 КАК Аналитика_4,
	|	ЗависимыеОбороты.Аналитика_5 КАК Аналитика_5,
	|	ЗависимыеОбороты.Аналитика_6 КАК Аналитика_6,
	|	ЗависимыеОбороты.Аналитика_7 КАК Аналитика_7,
	|	ЗависимыеОбороты.Количество КАК Количество,
	|	ЗависимыеОбороты.Норма КАК Норма,
	|	ЗависимыеОбороты.Сумма КАК Сумма,
	|	ЗависимыеОбороты.Измерение КАК Измерение,
	|	ЗависимыеОбороты.Комментарий КАК Комментарий,
	|	ЗависимыеОбороты.КомментарийРасчета КАК КомментарийРасчета,
	|	ЗависимыеОбороты.Расчетная КАК Расчетная
	|ИЗ
	|	РегистрСведений.бит_ФормаВводаБюджетаЗависимыеОбороты КАК ЗависимыеОбороты
	|ГДЕ
	|	ЗависимыеОбороты.ДокументВладелец = &ДокументВладелец";
	ВыборкаСтрок = Запрос.Выполнить().Выбрать();
	Пока ВыборкаСтрок.Следующий() Цикл
		НоваяСтрока = Объект.ЗависимыеОбороты.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаСтрок);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	ПостроенИндексПоиска = Ложь;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НеУчитыватьСверхБюджета(ЦФО, Период)

	ПараметрыНастройки = Новый Структура;
	ПараметрыНастройки.Вставить("ЦФО", ЦФО);
								
	НеУчитыватьСверхБюджета = бит_НастройкиПрограммы.НеУчитыватьСверхБюджетныеОперацииПриКонтролеПоБюджету(
								ПараметрыНастройки, Период);
								
	Возврат НеУчитыватьСверхБюджета;							

КонецФункции

&НаСервере
Процедура ДатаПриИзмененииНаСервере()
	
	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.ЦФО, Объект.Дата);

КонецПроцедуры

&НаСервере
Процедура ЦФОПриИзмененииНаСервере()
	
	НеУчитыватьСверхБюджета = НеУчитыватьСверхБюджета(Объект.ЦФО, Объект.Дата);
	УправлениеФормой();
	
КонецПроцедуры

&НаСервере
Процедура ПеренестиПроектВШапкуФормы()
	
	ПолеПроект = Элементы.ГруппаДопАналитики.ПодчиненныеЭлементы.Найти("Проект");
	Если ПолеПроект = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.Переместить(ПолеПроект, Элементы.ГруппаЗначенияПоУмолчанию);
	
КонецПроцедуры

&НаКлиенте
Процедура СкопироватьВБуфер()

	Если ТабДокДанные.ВыделенныеОбласти.Количество() > 1 Тогда
		ТекстСообщения = НСтр("ru = 'Выполнить не могу, когда выделено несколько областей.'; 
							|en = 'I can''t do it when several areas are highlighted.'");
		Возврат;
	КонецЕсли;
	
	мБуфер = Неопределено;
	ТекущаяОбласть = ТабДокДанные.ТекущаяОбласть;
	
	Если НЕ бит_БюджетированиеКлиентСервер.ЭтоПрямоугольнаяОбласть(ТекущаяОбласть) Тогда
		ПредупредитьОВыделенииМногоугольнойОбласти();
		Возврат;	
	КонецЕсли;
	
	мБуфер = Новый Массив;		
	ДанныеОбластей = Новый Соответствие;

	// Необходимо определить координаты всех ячеек выделенной области
	// и обойти по отдельности эти ячейки.		
	ВерхнийИндексКолонки = ТекущаяОбласть.Право - ТекущаяОбласть.Лево;
	ВерхнийИндексСтроки  = ТекущаяОбласть.Низ   - ТекущаяОбласть.Верх;
	
	Для ИндексСтроки = 0 По ВерхнийИндексСтроки Цикл
		НомерСтроки = ТекущаяОбласть.Верх + ИндексСтроки;

		ДанныеОбластей = Новый Соответствие;
		ОбластиСтроки  = Новый Массив;
		
		Для ИндексКолонки = 0 По ВерхнийИндексКолонки Цикл	
			
			НомерКолонки = ТекущаяОбласть.Лево + ИндексКолонки;	
			Область 	 = ТабДокДанные.Область(НомерСтроки, НомерКолонки, НомерСтроки, НомерКолонки);
			
			// Если выделенная ячейка является ячейкой вида Значение - сохраним параметры, необходимые для копирования в буфер.
			Расшифровка = Область.Расшифровка;
			ЭтоРасшифровкаЯчейкиФормыВвода = бит_ОбщегоНазначенияКлиентСервер.ПроверитьИмяКласса(Расшифровка, "РасшифровкаЯчейкиФормыВвода");
			Если НЕ ЭтоРасшифровкаЯчейкиФормыВвода И Расшифровка.Вид = "Значение" Тогда
				Продолжить;		
			КонецЕсли;
				 
			// Принятый формат имени области "значение": Ресурс_Период_КонтрольнаяСумма.
			// ++ NB Сделать функцию 
			ИмяНабора  = Область.Имя;
			ЧастиИмени = СтрРазделить(ИмяНабора, "_");
			Если ЧастиИмени.Количество() = 3 Тогда
				ЧастиИмени.Удалить(0);
				ИмяНабора = СтрСоединить(ЧастиИмени, "_");
			КонецЕсли;
			
			ДанныеОбласти = ДанныеОбластей.Получить(ИмяНабора);
			Если ДанныеОбласти = Неопределено Тогда
				Фильтры = бит_БюджетированиеКлиентСервер.СформироватьОтборСтрок(Расшифровка);
				// ++ NB Вызов сервера
				ДанныеТаблицы = Объект.БДДС.НайтиСтроки(Фильтры);
				
				ДанныеОбласти = Новый Структура;
				ДанныеОбласти.Вставить("ДанныеТаблицы", ДанныеТаблицы);
				ДанныеОбласти.Вставить("ИменаРесурсов", Новый Массив);
				
				ДанныеОбластей.Вставить(ИмяНабора, ДанныеОбласти);
			КонецЕсли; 
			
			ДанныеОбласти.ИменаРесурсов.Добавить(Расшифровка.ИмяРесурса);
		КонецЦикла;
		
		Для каждого КлючЗначение Из ДанныеОбластей Цикл
			ДанныеОбласти = КлючЗначение.Значение;	
			ОбластиСтроки.Добавить(ДанныеОбласти);
		КонецЦикла;
		мБуфер.Добавить(ОбластиСтроки);
	КонецЦикла; 

КонецПроцедуры

&НаКлиенте
Процедура ВставитьИзБуфера(Буфер, ПараметрыВставки, СтрокиДляЗависимых)
	
	КоличествоСкопированных = Буфер.Количество();
	Если КоличествоСкопированных = 0 Тогда
		Возврат;	
	КонецЕсли;
	
	Верх  = ПараметрыВставки.Верх;
	Лево  = ПараметрыВставки.Лево;
	ПраваяГараница = ПараметрыВставки.Право;
		
	СуммовойУчет	   = фКэшЗначений.НастройкиФормы.УчетСумма;
	КоличественныйУчет = фКэшЗначений.НастройкиФормы.УчетКоличество;

	ИсключаемыеСтвойства = Новый Массив;
	ИсключаемыеСтвойства.Добавить("Норма");
	
	Если СуммовойУчет Тогда
		ИсключаемыеСтвойства.Добавить("Сумма"); 
	КонецЕсли;
	Если КоличественныйУчет Тогда
		ИсключаемыеСтвойства.Добавить("Количество");
	КонецЕсли;
	ИсключаемыеСтвойства = СтрСоединить(ИсключаемыеСтвойства,",");
	
	ДобавленыеСтроки = Новый Соответствие;
	НомерСтроки = Верх;
	
	Для каждого ОбластиСтроки Из Буфер Цикл
		Для каждого ДанныеОбласти Из ОбластиСтроки Цикл

			ИменаРесурсов = ДанныеОбласти.ИменаРесурсов;
			ДанныеТаблицы = ДанныеОбласти.ДанныеТаблицы;
			
			НомерКолонки = Лево;
			Пока НомерКолонки <= ПраваяГараница Цикл
				
				ОбработаныеРесурсы  = 0;
				ТекущаяОбласть	    = Неопределено;
				НомерТекущийКолонки = НомерКолонки; 
				
				Для каждого ИмяРесурса Из ИменаРесурсов Цикл		
					
					ТекущаяОбласть = ТабДокДанные.Область(НомерСтроки, НомерКолонки, НомерСтроки, НомерКолонки);
					
					Расшифровка = ТекущаяОбласть.Расшифровка;
					ЭтоРасшифровкаЯчейкиФормыВвода = бит_ОбщегоНазначенияКлиентСервер.ПроверитьИмяКласса(Расшифровка, "РасшифровкаЯчейкиФормыВвода");
					Если НЕ (ЭтоРасшифровкаЯчейкиФормыВвода И Расшифровка.Вид = "Значение") Тогда
						ТекущаяОбласть = Неопределено;
						Продолжить;			
					КонецЕсли;
					
					Если Расшифровка.ИмяРесурса <> ИмяРесурса Тогда
						ТекущаяОбласть = Неопределено;
						Продолжить;					
					КонецЕсли;
					
					НомерКолонки = НомерКолонки + 1;
					Если ЗначениеЗаполнено(ТекущаяОбласть.Значение) Тогда
						Продолжить;				
					КонецЕсли;
					
					Фильтры = бит_БюджетированиеКлиентСервер.СформироватьОтборСтрок(Расшифровка);
					
					ИмяНабора  = ТекущаяОбласть.Имя;
					ЧастиИмени = СтрРазделить(ИмяНабора, "_");
					Если ЧастиИмени.Количество() = 3 Тогда
						ЧастиИмени.Удалить(0);
						ИмяНабора = СтрСоединить(ЧастиИмени, "_");
					КонецЕсли;
					
					НовыеСтроки = ДобавленыеСтроки.Получить(ИмяНабора);
					Если НовыеСтроки = Неопределено Тогда
						НовыеСтроки = Новый Массив;
						ДобавленыеСтроки.Вставить(ИмяНабора, НовыеСтроки);
					КонецЕсли;
					
					Если НовыеСтроки.Количество() = 0 Тогда
						Для каждого СтрокаТаблицы Из ДанныеТаблицы Цикл
							НоваяСтрока = Объект.БДДС.Добавить();	
							ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы,, ИсключаемыеСтвойства);
							ЗаполнитьЗначенияСвойств(НоваяСтрока, Фильтры);
							НоваяСтрока[ИмяРесурса] = СтрокаТаблицы[ИмяРесурса];
							УстановитьИД_БДДС_Клиент(НоваяСтрока);
							НовыеСтроки.Добавить(НоваяСтрока);
						КонецЦикла;
					Иначе	
						Индекс = 0;
						Для каждого СтрокаТаблицы Из ДанныеТаблицы Цикл
							НоваяСтрока = НовыеСтроки.Получить(Индекс);
							НоваяСтрока[ИмяРесурса] = СтрокаТаблицы[ИмяРесурса];
							Индекс = Индекс + 1;
						КонецЦикла;
					КонецЕсли;
					ОбработаныеРесурсы = ОбработаныеРесурсы + 1;
					ОбновитьЗначениеЯчейкиДерева(ТекущаяОбласть, ТекущаяОбласть.Расшифровка, СтрокиДляЗависимых);
				КонецЦикла;
				
				Если НомерКолонки = НомерТекущийКолонки Тогда
					// Ни один ресурс не подошел. Сдвигаемся на одну колонку.
					НомерКолонки = НомерКолонки + 1;
				КонецЕсли;
				
				Если ТекущаяОбласть <> Неопределено И ОбработаныеРесурсы <> ИменаРесурсов.Количество() Тогда
					ОбновитьПарнуюЯчейки(ТекущаяОбласть, СтрокиДляЗависимых);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		НомерСтроки = НомерСтроки + 1;	
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПредупредитьОВыделенииМногоугольнойОбласти()

	ТекстСообщения = НСтр("ru = 'Выполнить не могу. 
							|Выделите прямоугольную область.'; 		
							|en = 'I can''t do it. 
							|Select a rectangular area.'");
	ПоказатьПредупреждение(, ТекстСообщения);

КонецПроцедуры

#КонецОбласти