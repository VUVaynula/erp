&НаКлиенте
Процедура КомандаВставитьДанные(Команда)

	Если ТипЗнч(мБуфер) <> Тип("Массив") Тогда
		Возврат;	
	КонецЕсли;
		
	СтрокиДляЗависимых = Новый Массив();
	Для каждого ТекущаяОбласть Из ТабДокДанные.ВыделенныеОбласти Цикл
		Если НЕ бит_БюджетированиеКлиентСервер.ЭтоПрямоугольнаяОбласть(ТекущаяОбласть) Тогда
			Продолжить;	
		КонецЕсли;
		
		ВерхнийИндексКолонки = ТекущаяОбласть.Право - ТекущаяОбласть.Лево;
		ВерхнийИндексСтроки  = ТекущаяОбласть.Низ   - ТекущаяОбласть.Верх;//6 строк - 5
		
		ВерхнийИндексСтрокВБуфере = мБуфер.Вграница();
		ИндексСтрокиВБуфере 	  = 0;
		
		Если ВерхнийИндексСтроки < ВерхнийИндексСтрокВБуфере Тогда
			Продолжить;		
		КонецЕсли;
		
		Для ИндексСтроки = 0 По ВерхнийИндексСтроки Цикл
			НомерСтроки = ТекущаяОбласть.Верх + ИндексСтроки;
			
			Если ИндексСтрокиВБуфере > ВерхнийИндексСтрокВБуфере Тогда
				ИндексСтрокиВБуфере = 0;
				ОсталосьВставить = Макс(ВерхнийИндексСтроки - ИндексСтроки, 0);
				Если ОсталосьВставить < ВерхнийИндексСтрокВБуфере Тогда
					// Выделенные области некратны скопированным.
					// Скопированные польностью не вставятся. Прерываем.
					Прервать;
				КонецЕсли;
			КонецЕсли;
			 
			Буфер = Новый Массив;
			Буфер.Добавить(мБуфер.Получить(ИндексСтрокиВБуфере));
			ИндексСтрокиВБуфере = ИндексСтрокиВБуфере + 1;
			
			Для ИндексКолонки = 0 По ВерхнийИндексКолонки Цикл
				НомерКолонки = ТекущаяОбласть.Лево + ИндексКолонки;
				Область		 = ТабДокДанные.Область(НомерСтроки, НомерКолонки, НомерСтроки, НомерКолонки);
				
				ПараметрыВставки = НовыеПараметрыВставкиИзБуфера();
				ЗаполнитьЗначенияСвойств(ПараметрыВставки, Область);
				
				ВставитьИзБуфера(Буфер, ПараметрыВставки, СтрокиДляЗависимых);
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Если СтрокиДляЗависимых.Количество() > 0 Тогда
		ЗаполнитьЗависимыеОборотыПоСтрокам(СтрокиДляЗависимых);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаОчиститьДанные(Команда)
	
	Если АктивнаРедактируемаяЯчейка() Тогда
		ИменаВыделенныхОбластей = ПолучитьИменаВыделенныхОбластей();
		ОбластиТД = ТабДокДанные.Области;	
		СтрокиДляЗависимых = Новый Массив();
		Для Каждого ИмяОбласти Из ИменаВыделенныхОбластей Цикл
			ОблМакета = ОбластиТД.Найти(ИмяОбласти);
			ОбластьР = ОблМакета.Расшифровка;
			Если ОбластьР = Неопределено ИЛИ ЭтоЗащищеннаяОбласть(ОблМакета) Тогда
			 	Продолжить;	
			КонецЕсли;
			Если ОбластьР.Вид = "Значение" Тогда
				// Поиск строк БДДС.
				СтрОтбор = бит_БюджетированиеКлиентСервер.СформироватьОтборСтрок(ОбластьР);
				НайденныеСтроки = Объект.БДДС.НайтиСтроки(СтрОтбор);
				Если НайденныеСтроки <> Неопределено Тогда
					ОблМакета.Значение = 0;  				
				КонецЕсли;
			КонецЕсли;
			ИзменениеСодержимогоОбласти(ОблМакета, СтрокиДляЗависимых);
		КонецЦикла;
		Если СтрокиДляЗависимых.Количество() > 0 Тогда
			ЗаполнитьЗависимыеОборотыПоСтрокам(СтрокиДляЗависимых);
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура КомандаЗаполнитьСтроку(Команда)
	
	Если ТипЗнч(мБуфер) <> Тип("Массив") Тогда
		Возврат;	
	КонецЕсли;
	
	СтрокиДляЗависимых = Новый Массив();
	Для каждого ВыделеннаяОбласть Из ТабДокДанные.ВыделенныеОбласти Цикл
		Если НЕ бит_БюджетированиеКлиентСервер.ЭтоПрямоугольнаяОбласть(ВыделеннаяОбласть) Тогда
			Продолжить;	
		КонецЕсли;
		
		ПараметрыВставки = НовыеПараметрыВставкиИзБуфера();
		ЗаполнитьЗначенияСвойств(ПараметрыВставки, ВыделеннаяОбласть);
		
		ПараметрыВставки.Лево  = ВыделеннаяОбласть.Право + 1;
		ПараметрыВставки.Право = ТабДокДанные.ШиринаТаблицы;
		
		ВставитьИзБуфера(мБуфер, ПараметрыВставки, СтрокиДляЗависимых);
	КонецЦикла;
	
	Если СтрокиДляЗависимых.Количество() > 0 Тогда
		ЗаполнитьЗависимыеОборотыПоСтрокам(СтрокиДляЗависимых);
	КонецЕсли;
		
КонецПроцедуры

