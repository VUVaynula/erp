&НаКлиенте
Процедура ОбновитьЗавершение(Результат, ДополнительныеПараметры)  Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		ОчиститьТаблицы(ЭтотОбъект);
		ДлительнаяОперация = НачатьОбновлениеДерева();
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ТекстСообщения = НСтр("ru='Выполняется построение дерева...';en='Creating a tree ...'"); 
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершитьОбновлениеДерева", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОписаниеОповещения, ПараметрыОжидания);
	КонецЕсли; 
	
КонецПроцедуры

// Обраборка оповещения процедуры "ОбновитьЗавершение".
//
// Параметры:
//  Результат				 - Структура - См. общий модуль ДлительныеОпрации.
//  ДополнительныеПараметры	 - Произвольный - произвольные данные, переданные в обработку оповещения. 
//
&НаКлиенте
Процедура ЗавершитьОбновлениеДерева(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		// Ничего не делать или обработать ошибку.
		ТекстСообщения = НСтр("ru = 'Ошибка при выполнении: %1'"); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрШаблон(ТекстСообщения, Результат.КраткоеПредставлениеОшибки));
	Иначе
		ТабДокДанные = Новый ТабличныйДокумент;
		ЗавершитьОбновлениеДереваНаСервере(Результат);
	КонецЕсли; 

	Если ЗначениеЗаполнено(Результат.Сообщения) Тогда
		Для каждого ТекущееСообщение Из Результат.Сообщения Цикл
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекущееСообщение.Текст);
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция НачатьОбновлениеДерева()
	
	РеквизитыСценария = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Сценарий, "бит_Периодичность, ПродолжительностьИнтервала");

	ПараметрыОбновления = Документы.бит_ФормаВводаБюджета.НовыеПараметрыДерева();
	ПараметрыОбновления.АдресКомпоновки				= АдресКомпоновки;
	ПараметрыОбновления.НастройкиКомпоновщика		= Компоновщик.ПолучитьНастройки();
	ПараметрыОбновления.ДатаНачалаПланирования 		= Объект.ДатаНачалаПланирования;
	ПараметрыОбновления.ДатаОкончанияПланирования 	= Объект.ДатаОкончанияПланирования;
	ПараметрыОбновления.Периодичность			    = РеквизитыСценария.бит_Периодичность;
	ПараметрыОбновления.ПродолжительностьИнтервала  = РеквизитыСценария.ПродолжительностьИнтервала;
	ПараметрыОбновления.СхемаКомпоновкиДанных 		= ПолучитьИзВременногоХранилища(АдресКомпоновки);
	
	ВыполняемыйМетод = "Документы.бит_ФормаВводаБюджета.ОбновитьДеревоДанныхВФоне";
	ПараметрыМетода = Новый Структура;
	ПараметрыМетода.Вставить("Настройка",			Объект.НастройкаФормы);
	ПараметрыМетода.Вставить("ТекстЗапроса",		ТекстЗапроса);
	ПараметрыМетода.Вставить("ПараметрыОбновления", ПараметрыОбновления);
	
	// Заполнение пераметов длительной операции.
	НаименованиеЗадания = НСтр("ru = 'Обновление макета формы ввода бюджета.'");
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(ВыполняемыйМетод, ПараметрыМетода, ПараметрыВыполнения);
	
КонецФункции

&НаСервере
Процедура ЗавершитьОбновлениеДереваНаСервере(РезультаОбновления)

	ТабДокДанные = ПолучитьИзВременногоХранилища(РезультаОбновления.АдресРезультата);
	
	Документы.бит_ФормаВводаБюджета.ЗаполнитьТаблицуДанных(ТабДокДанные, АдресХранилищаДанных);
	Документы.бит_ФормаВводаБюджета.ЗаполнитьСписокСмежности(ТабДокДанные, АдресХранилищаСпискаСмежности);
	
	МассивСтатей = ИзвлечьСтатьиИзДерева(ТабДокДанные);
	фКэшЗначений.НастройкиСтатей = Новый Соответствие;	
    бит_Бюджетирование.ПолучитьНастройкиСтатейОборотов(МассивСтатей, фКэшЗначений.НастройкиСтатей);
	
	ИменаТаблиц = Новый Массив;  
	ИменаТаблиц.Добавить("БДДС");
	ИменаТаблиц.Добавить("БДДС_Редактирование");
	ОФормитьТаблицу("БДДС", ИменаТаблиц, МассивСтатей);
	
	ИменаТаблиц = Новый Массив;  
	ИменаТаблиц.Добавить("ЗависимыеОбороты");
	ИменаТаблиц.Добавить("ЗависимыеОбороты_Редактирование");
	ОФормитьТаблицу("ЗависимыеОбороты", ИменаТаблиц, МассивСтатей);																		
	
	УправлениеВидимостьюКолонокТаблиц();

КонецПроцедуры

&НаКлиенте
Процедура КомандаВосстановить(Команда)
	
	Если ЗаполнениеДереваВозможно(Истина) Тогда
		Состояние(НСтр("ru='Выполняется обновление дерева...';en='Updating the tree ...'"));		
		ОчиститьСообщения();
		ВосстановитьДерево(Истина,Истина,Истина);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаСкопироватьСтрокуВЗависимые(Команда)
	
	Если ЗащищеннаяОбласть Тогда
		МассивСтрок = Новый Массив;
		МассивСтрок.Добавить(НСтр("ru = 'Выбранная область данных бюджета содержит защищенные ячейки.';
								  |en = 'The selected area of the budget data contains protected cells.'"));
		МассивСтрок.Добавить(НСтр("ru = 'Команда недоступна.';
								  |en = 'Command isn’t available.'"));
		ТекстОшибки = СтрСоединить(МассивСтрок, Символы.ПС);
		ВызватьИсключение ТекстОшибки;
	ИначеЕсли ВыделеноНесколькоЯчеек Тогда	
		МассивСтрок = Новый Массив;
		МассивСтрок.Добавить(НСтр("ru = 'Выбрано несколько ячеек данных бюджета.';
								  |en = 'Select multiple budget data cells.'"));
		МассивСтрок.Добавить(НСтр("ru = 'Команда недоступна.';
								  |en = 'Command isn’t available.'"));
		ТекстОшибки = СтрСоединить(МассивСтрок, Символы.ПС);
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	
	Если НЕ РазрешенРучнойВводЗависимыхОборотов(Объект.РежимЗависимыхОборотов) Тогда
		ТекстСообщения = НСтр("ru='Функция копирования доступна при ручном вводе зависимых оборотов.';
							  |en='Copy function is available when entering dependent turnovers manually'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли; 
	
	ТекущаяСтрока = Элементы.БДДС_Редактирование.ТекущиеДанные;
	Если ТекущаяСтрока <> Неопределено Тогда
