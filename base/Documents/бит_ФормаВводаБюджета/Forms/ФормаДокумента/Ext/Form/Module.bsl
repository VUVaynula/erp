	Иначе
		ТекстСообщения = НСтр("ru='Не выбрана текущая строка данных для копирования.';
							  |en='Current data line for copying isn’t selected'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

