		ПараметрыФормы.Вставить("Ключ", ШаблонСсылка);
		Форма = ПолучитьФорму("Справочник.бит_ШаблоныДвижений.ФормаОбъекта", ПараметрыФормы);
		Форма.Записать();
		Форма.Открыть();
		
