			//ИзменениеСчетаТекущейЗаписи(НоваяСтрока.ПолучитьИдентификатор(), НаправлениеСчета);
			//ИзменениеСчетаТекущейЗаписи(НоваяСтрока.ПолучитьИдентификатор(), НаправлениеДопСчета);
			
			// Добавление кода. Начало. 25.11.2016{{
