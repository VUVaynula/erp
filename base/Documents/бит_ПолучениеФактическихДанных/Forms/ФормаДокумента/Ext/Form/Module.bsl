&НаСервере
Функция ПоследствияИзмененияСценария(Знач СтарыйСценарий, Знач НовыйСценарий)

	РеквизитыСтарогоСценария = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтарыйСценарий, "бит_Периодичность, Валюта");
	РеквизитыНовогоСценария  = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(НовыйСценарий, "бит_Периодичность, Валюта");
	
	ИзменитсяВалюта = Ложь;
	Если РеквизитыНовогоСценария.Валюта <> Объект.ВалютаДокумента
	   И Объект.ФактическиеДанные.Количество() > 0 Тогда
	
		ИзменитсяВалюта = Истина;
	КонецЕсли; 
   	ИзменитсяПериодичность = РеквизитыСтарогоСценария.бит_Периодичность <> РеквизитыНовогоСценария.бит_Периодичность;
	
	Последствия = Новый Структура;
	Последствия.Вставить("СпроситьОНормах", 	   Ложь);
	Последствия.Вставить("ИзменитсяПериодичность", ИзменитсяПериодичность); 
	Последствия.Вставить("ИзменитсяВалюта", 	   ИзменитсяВалюта);
	
	Возврат Последствия;
	
КонецФункции

&НаСервере
Процедура ОбработатьИзменениеТабличнойЧастиНаСервере(Знач ПараметрыОповещения)

	ИмяТабличнойЧасти		  = ПараметрыОповещения.ИмяТабличнойЧасти;
	АдресВоВременномХранилище = ПараметрыОповещения.АдресВоВременномХранилище;
		
	Модифицированность = Истина;
	ДанныеЗаполнения   = ПолучитьИзВременногоХранилища(АдресВоВременномХранилище);
	
	Индекс = 0;
	Для каждого СтрокаТаблицы Из ДанныеЗаполнения Цикл
		ТекущиеДанные		  = Объект[ИмяТабличнойЧасти][Индекс];
		ТекущаяСтатьяОборотов = ТекущиеДанные.СтатьяОборотов;
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, СтрокаТаблицы);
		
		Если ТекущиеДанные.СтатьяОборотов <> ТекущаяСтатьяОборотов Тогда
			ИзменениеСтатьиОборотовТабличнойЧасти(ТекущиеДанные);
		КонецЕсли; 
		Индекс = Индекс + 1;
	КонецЦикла; 

КонецПроцедуры

&НаСервере
Процедура УстановитьДанныеПоСтатье(ТекущиеДанные)

	НастройкиСтатьи = Справочники.бит_СтатьиОборотов.ПолучитьНастройки(ТекущиеДанные.СтатьяОборотов);
	
	Если Не НастройкиСтатьи.Учет_Количество Тогда
		ТекущиеДанные.Количество = 0;
	КонецЕсли;
	
	Если Не НастройкиСтатьи.Учет_Сумма Тогда
		ТекущиеДанные.Сумма = 0;
	КонецЕсли;
	
	Для каждого КлючИЗначение Из фКэшЗначений.Измерения Цикл
		
		ИмяИзмерения = КлючИЗначение.Ключ;
		Настройки    = Неопределено;
		
		НастройкиСтатьи.Измерения.Свойство(ИмяИзмерения, Настройки);
		Если ТипЗнч(Настройки) = Тип("Структура") Тогда
			
			 Если ТипЗнч(Настройки.ТипПоУмолчанию) = Тип("ОписаниеТипов") Тогда
			 	 ТекущиеДанные[ИмяИзмерения] = Настройки.ТипПоУмолчанию.ПривестиЗначение(ТекущиеДанные[ИмяИзмерения]);
			 КонецЕсли; 
			
			 Если НЕ Настройки.Учет Тогда
			 	  ТекущиеДанные[ИмяИзмерения] = Неопределено;
			 КонецЕсли; 
		КонецЕсли; 
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеВидаПроформы(Знач ИмяПроформы)

	ДанныеВидаПроформы = Документы.бит_ФормаСбораДанных.ДанныеВидаПроформы(ИмяПроформы);
	
	Возврат ДанныеВидаПроформы;

КонецФункции

&НаСервере
Процедура ОбработатьЗагруженныеДанные(Знач КомплектДанных, Знач Режим)
	
	СпискиИсточники  = КомплектДанных.СпискиИсточники;
	ПсевдоМетаданные = КомплектДанных.ПсевдоМетаданные;
	МодельДокумента  = КомплектДанных.МодельДокумента;
	
	Если МодельДокумента.Количество() = 0 Тогда		
		ТекстСообщения = НСтр("ru='Нет данных для загрузки. Возможно, выбран файл, не соответствующий данному виду проформы.';
							  |en='No data to download. Perhaps the file is selected, this does not correspond to a pro forma mind.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;	
	КонецЕсли; 
	
	Документы.бит_ФормаСбораДанных.РаспознатьДанные(МодельДокумента, ПсевдоМетаданные, СпискиИсточники);
	
	ИмяТаблицыДанных = Документы.бит_ФормаСбораДанных.ИмяТаблицыДляЗагрузкиДанныхБюджета(ПсевдоМетаданные);
	
	// Проверка состава обязательных колонок таблицы.	
	МетаТаб = КомплектДанных.ПсевдоМетаданные.ТабличныеЧасти[ИмяТаблицыДанных]; 
	
	ИменаРеквизитовТЧ = Новый Массив;
	Для каждого ОписаниеРеквизита Из МетаТаб.Реквизиты Цикл
		Если ТипЗнч(ОписаниеРеквизита) = Тип("Структура") И ОписаниеРеквизита.Свойство("Имя") Тогда
			ИменаРеквизитовТЧ.Добавить(ОписаниеРеквизита.Имя);
		Иначе
			ИменаРеквизитовТЧ.Добавить(ОписаниеРеквизита);
		КонецЕсли;
	КонецЦикла;
	
	ИменаОбязательных = Новый Массив;
	ИменаОбязательных.Добавить("Период");
	ИменаОбязательных.Добавить("СтатьяОборотов");
	ИменаОбязательных.Добавить("ЦФО");
	ИменаОбязательных.Добавить("Сумма");
	
	ОтсутствуетПоле = Ложь;
	Для Каждого ИмяПоля Из ИменаОбязательных Цикл
		Если ИменаРеквизитовТЧ.Найти(ИмяПоля) = Неопределено Тогда
			ОтсутствуетПоле = Истина;
			Прервать;
		КонецЕсли; 
	КонецЦикла;
	
    Отказ = Ложь;    
	Если ОтсутствуетПоле Тогда
		ТекстСообщения = НСтр("ru='В шаблоне проформы отсутствуют обязательные поля: %1';
							  |en='The template proforma no mandatory fields: %1'");			 
		ТекстСообщения = СтрШаблон(ТекстСообщения, СтрСоединить(ИменаОбязательных, ", "));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,,Отказ); 
	КонецЕсли; 
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли; 
	
	Если Режим = "Загрузить" Тогда
		Объект.ФактическиеДанные.Очистить();
		Объект.ЗависимыеОбороты.Очистить();
	КонецЕсли; 
	
	ТаблицаДанныхБюджета = МодельДокумента[ИмяТаблицыДанных].ТаблицаДанных;
	
	// Проверим существование колонок.
	КолонкиПроверены = Новый Структура;
	
	МетаДок = Объект.Ссылка.Метаданные();
	Для каждого Колонка Из ТаблицаДанныхБюджета.Колонки Цикл
		Если бит_РаботаСМетаданными.ЕстьРеквизитТабЧасти(Колонка.Имя, МетаДок, "ФактическиеДанные") Тогда
			 КолонкиПроверены.Вставить(Колонка.Имя, Истина);
		КонецЕсли; 
	КонецЦикла; 
	
	Для каждого СтрокаТаблицы Из ТаблицаДанныхБюджета  Цикл
		НоваяСтрока = Объект.ФактическиеДанные.Добавить();
		Для каждого КиЗ Из КолонкиПроверены Цикл
			ИмяКолонки = КиЗ.Ключ;
			НоваяСтрока[ИмяКолонки] = СтрокаТаблицы[ИмяКолонки];
		КонецЦикла; 
		УстановитьДанныеПоСтатье(НоваяСтрока);
	КонецЦикла; 
	
	ОформитьТаблицу("ФактическиеДанные");	
	УстановитьАвтовидимостьКолонок();
		
КонецПроцедуры // ОбработатьЗагруженныеДанные()

&НаСервере
Процедура ВыполнитьРаспределение(Знач ВыбранныеСтроки, Знач НастройкиРаспределения)
	
	Для каждого ВыбраннаяСтрока Из ВыбранныеСтроки Цикл
		СтрокаИсточник = Объект.ФактическиеДанные.НайтиПоИдентификатору(ВыбраннаяСтрока);	
		Если СтрокаИсточник <> Неопределено Тогда
			// Распределение по профилю.
			МассивСтрок = бит_Бюджетирование.РаспределитьПоПрофилюАналитики(НастройкиРаспределения, 
							Объект.ФактическиеДанные, СтрокаИсточник);
			Модифицированность = Истина;
		КонецЕсли;
	КонецЦикла; // по ИД строк.
	
КонецПроцедуры

&НаКлиенте
Процедура ПанельОсновнаяПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	ЭтоЗависимые = ?(ТекущаяСтраница.Имя = "СтраницаЗависимыеОбороты", Истина, Ложь);
	
	Элементы.ЗависимыеОборотыИтогСумма.Видимость      = ЭтоЗависимые;
	Элементы.ЗависимыеОборотыИтогКоличество.Видимость = ЭтоЗависимые;
	
	Элементы.ФактическиеДанныеИтогКоличество.Видимость = НЕ ЭтоЗависимые;
	Элементы.ФактическиеДанныеИтогСумма.Видимость      = НЕ ЭтоЗависимые;

КонецПроцедуры

&НаКлиенте 
Процедура РедактированиеПериодаЗавершение(ПериодРезультат, ДополнительныеДанные)

	Если ПериодРезультат <> Неопределено Тогда
	
		Объект.ДатаНачала    = ПериодРезультат.ДатаНачала;
		Объект.ДатаОкончания = ПериодРезультат.ДатаОкончания;
		
		ЭтотОбъект.Модифицированность = Истина; 		
	КонецЕсли; 
	
КонецПроцедуры

