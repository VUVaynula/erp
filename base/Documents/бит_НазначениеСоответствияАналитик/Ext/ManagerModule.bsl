Функция ТекстЗапросаТаблицыДокумента(НомераТаблиц)

	НомераТаблиц.Вставить("ВременнаяТаблицаДокумента", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ТаблицаСоответствияАналитик", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("ТаблицаКонтрольУникальностиЗаписей", НомераТаблиц.Количество());
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	СписокАналитик.ЛеваяАналитика_1 КАК ЛеваяАналитика_1,
	|	СписокАналитик.ЛеваяАналитика_2 КАК ЛеваяАналитика_2,
	|	СписокАналитик.ЛеваяАналитика_3 КАК ЛеваяАналитика_3,
	|	СписокАналитик.ПраваяАналитика_1 КАК ПраваяАналитика_1,
	|	СписокАналитик.ПраваяАналитика_2 КАК ПраваяАналитика_2,
	|	СписокАналитик.ПраваяАналитика_3 КАК ПраваяАналитика_3,
	|	ВЫБОР
	|		КОГДА СписокАналитик.ДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА &Период
	|		ИНАЧЕ СписокАналитик.ДатаНачала
	|	КОНЕЦ КАК Период,
	|	ВЫБОР
	|		КОГДА СписокАналитик.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА &ДатаОкончания
	|		ИНАЧЕ СписокАналитик.ДатаОкончания
	|	КОНЕЦ КАК ДатаОкончания,
	|	СписокАналитик.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ВТ_СписокАналитик
	|ИЗ
	|	Документ.бит_НазначениеСоответствияАналитик.СписокАналитик КАК СписокАналитик
	|ГДЕ
	|	СписокАналитик.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_СписокАналитик.ЛеваяАналитика_1 КАК ЛеваяАналитика_1,
	|	ВТ_СписокАналитик.ЛеваяАналитика_2 КАК ЛеваяАналитика_2,
	|	ВТ_СписокАналитик.ЛеваяАналитика_3 КАК ЛеваяАналитика_3,
	|	ВТ_СписокАналитик.ПраваяАналитика_1 КАК ПраваяАналитика_1,
	|	ВТ_СписокАналитик.ПраваяАналитика_2 КАК ПраваяАналитика_2,
	|	ВТ_СписокАналитик.ПраваяАналитика_3 КАК ПраваяАналитика_3,
	|	ВТ_СписокАналитик.Период КАК Период,
	|	ИСТИНА КАК Используется
	|ИЗ
	|	ВТ_СписокАналитик КАК ВТ_СписокАналитик
	|ГДЕ
	|	ВТ_СписокАналитик.Период <> ДАТАВРЕМЯ(1, 1, 1)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_СписокАналитик.ЛеваяАналитика_1,
	|	ВТ_СписокАналитик.ЛеваяАналитика_2,
	|	ВТ_СписокАналитик.ЛеваяАналитика_3,
	|	ВТ_СписокАналитик.ПраваяАналитика_1,
	|	ВТ_СписокАналитик.ПраваяАналитика_2,
	|	ВТ_СписокАналитик.ПраваяАналитика_3,
	|	ВЫБОР
	|		КОГДА ВТ_СписокАналитик.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА КОНЕЦПЕРИОДА(ВТ_СписокАналитик.ДатаОкончания, ДЕНЬ)
	|		ИНАЧЕ ВТ_СписокАналитик.ДатаОкончания
	|	КОНЕЦ,
	|	ЛОЖЬ
	|ИЗ
	|	ВТ_СписокАналитик КАК ВТ_СписокАналитик
	|ГДЕ
	|	ВТ_СписокАналитик.ДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_СписокАналитик.ЛеваяАналитика_1 КАК ЛеваяАналитика_1,
	|	ВТ_СписокАналитик.ЛеваяАналитика_2 КАК ЛеваяАналитика_2,
	|	ВТ_СписокАналитик.ЛеваяАналитика_3 КАК ЛеваяАналитика_3,
	|	ВТ_СписокАналитик.ПраваяАналитика_1 КАК ПраваяАналитика_1,
	|	ВТ_СписокАналитик.ПраваяАналитика_2 КАК ПраваяАналитика_2,
	|	ВТ_СписокАналитик.ПраваяАналитика_3 КАК ПраваяАналитика_3,
	|	ВТ_СписокАналитик.Период КАК Период,
	|	ВЫБОР
	|		КОГДА ВТ_СписокАналитик.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ДАТАВРЕМЯ(2036, 12, 31)
	|	КОНЕЦ КАК ДатаОкончания,
	|	ВТ_СписокАналитик.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	ВТ_СписокАналитик КАК ВТ_СписокАналитик
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();

КонецФункции // ТекстЗапросаСоответствияАналитик()

