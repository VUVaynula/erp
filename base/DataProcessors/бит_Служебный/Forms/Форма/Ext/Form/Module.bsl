&НаСервере
Процедура УстановитьИнформациюОбОшибках(ТекЭлемент, ЕстьПроверка = Ложь, ЕстьОшибки = Ложь)

	ТекЭлемент.Видимость = ЕстьПроверка;
	Если ЕстьОшибки Тогда
		ТекЭлемент.Заголовок = НСтр("ru = 'Есть ошибки!'; en = 'There are mistakes!'");
		ТекЭлемент.ЦветТекста = WebЦвета.Красный;
	Иначе	
	    ТекЭлемент.Заголовок = НСтр("ru = 'Ошибок нет'; en = 'No errors'");
		ТекЭлемент.ЦветТекста = WebЦвета.Зеленый;
	КонецЕсли;  	

КонецПроцедуры // УстановитьИнформациюОбОшибках()

