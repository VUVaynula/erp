&НаСервереБезКонтекста
Процедура ВывестиПротоколТестаНаОткрытиеФорм(ДокументРезультат, Ошибки)

	Макет = Обработки.бит_Служебный.ПолучитьМакет("ОткрытиеФорм");
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	СтрокаОшибка = Макет.ПолучитьОбласть("СтрокаОшибка");
	СтрокаИтог 	 = Макет.ПолучитьОбласть("СтрокаИтог");
	
	ДокументРезультат.Очистить();
	ДокументРезультат.Вывести(ОбластьШапка);
	Для каждого Элемент Из Ошибки Цикл
		СтрокаОшибка.Параметры.Заполнить(Элемент);
		ДокументРезультат.Вывести(СтрокаОшибка);
	КонецЦикла; 
	
	Если Ошибки.Количество() = 0 Тогда
		ДокументРезультат.Вывести(СтрокаИтог);
	КонецЕсли; 

КонецПроцедуры
 
&НаКлиенте
Процедура ТестНаОткрытиеФорм(Команда)
	
	Перем Формы;
	Перем Объекты;

	ТестНаОткрытиеФормНачалоНаСервере(Объекты, Формы);
	
	Классы = Новый Соответствие;
	Классы.Вставить("Справочники", "Справочник");
	Классы.Вставить("Документы", "Документ");
	Классы.Вставить("Отчеты", "Отчет");
	Классы.Вставить("Обработки", "Обработка");
	Классы.Вставить("ПланыВидовХарактеристик", "ПланВидовХарактеристик");
	Классы.Вставить("ПланыСчетов", "ПланСчетов");
	Классы.Вставить("РегистрыСведений", "РегистрСведений");
	Классы.Вставить("РегистрыНакопления", "РегистрНакопления");
	Классы.Вставить("РегистрыБухгалтерии", "РегистрБухгалтерии");
	
	ИмяФормыШаблон       = НСтр("ru = '%1.%2.%3'; en = '%1.%2.%3'");
	Шаблонсообщения      = НСтр("ru = 'Открывается форма %1 из %2'; en = 'Form opens %1 from %2'");
	ШаблонПояснения      = НСтр("ru = 'Форма %1'; en = 'The form %1'");
	ШаблонОписанияОшибки = НСтр("ru = '!!!: Ошибка открытия формы ""%1"": %2'; 
								|en = '!!!: Error opening form ""%1"": %2'");
	
	ПараметрыПередачи = Новый Структура(); 
	ПараметрыПередачи.Вставить("АвтоТест",              РежимТестирования = 0); // АПК: 1339 Механизм тестирования открытия форм.
	ПараметрыПередачи.Вставить("АвтотестЛицензирование",НЕ РежимТестирования = 0);
	
	Ошибки = Новый Массив; 
	Для каждого ЭлементСписка Из СписокКоллекций Цикл
		
		Если НЕ ЭлементСписка.Пометка Тогда
			Продолжить;
		КонецЕсли;
		
		ТекИмяКоллекции           = ЭлементСписка.Значение;
		ТекстИмяДляПолученияФормы = Классы.Получить(ТекИмяКоллекции);
		
		МассивИменФорм     = Формы.Получить(ТекИмяКоллекции);
		МассивИменОбъектов = Объекты.Получить(ТекИмяКоллекции);
		
		Если ЗначениеЗаполнено(МассивИменОбъектов) Тогда
			
			Ном = 1;
			КолОбъектов = МассивИменОбъектов.КОличество();
			
			Для каждого ТекИмяОбъекта Из МассивИменОбъектов Цикл
				Если ТекИмяОбъекта = "бит_Служебный"
					ИЛИ ТекИмяОбъекта = "бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию"
					ИЛИ ТекИмяОбъекта = "бит_ОтражениеФактаДДС"
					ИЛИ СтрЗаканчиваетсяНа(ТекИмяОбъекта, "ПрисоединенныеФайлы") Тогда
					// Служебные и устаревшие объекты.
					Продолжить;
				КонецЕсли;
				
				Для каждого ТекИмяФормы Из МассивИменФорм Цикл
					ТекИмяФормы    = СтрШаблон(ИмяФормыШаблон, ТекстИмяДляПолученияФормы, ТекИмяОбъекта, ТекИмяФормы);
					ТекстСообщения = СтрШаблон(Шаблонсообщения, Ном, КолОбъектов);
					ТекстПояснения = СтрШаблон(ШаблонПояснения, ТекИмяФормы);

					Состояние(ТекстСообщения, Цел(Ном * 100 / КолОбъектов), ТекстПояснения);
					Попытка 
						ФормаОбъекта = ОткрытьФорму(ТекИмяФормы, ПараметрыПередачи);
						Если НЕ ФормаОбъекта = Неопределено И ФормаОбъекта.Открыта() Тогда
						     ФормаОбъекта.Закрыть(Неопределено);
						КонецЕсли; 
					Исключение						
						ПараметрыСтроки = Новый Структура;
						ПараметрыСтроки.Вставить("Форма", ТекИмяФормы);
						ПараметрыСтроки.Вставить("ОписаниеОшибки", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
						Ошибки.Добавить(ПараметрыСтроки);
					КонецПопытки;
				КонецЦикла;
				
				Ном = Ном + 1;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	ВывестиПротоколТестаНаОткрытиеФорм(ДокументРезультатОткрытиеФорм, Ошибки);
	
	Состояние("");	
	ПоказатьОповещениеПользователя(НСтр("ru='Проверка закончена';en='Verification completed'"));
	
КонецПроцедуры

