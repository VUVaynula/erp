	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьОтчетНаСервере()
	
	Если НЕ ЭтоАдресВременногоХранилища(АдресТаблицыДанных) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Необходимо считать данные конфигурации.'; 
						  	   |en = 'Необходимо считать данные конфигурации.'");
		Сообщение.Поле  = "ВыполнитьПроверку";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	Результат = Новый ТабличныйДокумент;
	
	Схема     = ПолучитьИзВременногоХранилища(СхемаКомпоновкиДанных);
	Настройки = Компоновщик.ПолучитьНастройки();
	
	// Формирование макета, с помощью компоновщика макета.
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	
	// Передача схемы, настроек и данных расшифровки в макет компоновки.
	МакетКомпоновки   = КомпоновщикМакета.Выполнить(Схема, Настройки);
	
	// Внешние наборы данных
	ТаблицаМетаданных = ПолучитьИзВременногоХранилища(АдресТаблицыДанных);
	ВнешниеНаборыДанных = Новый Структура;
	ВнешниеНаборыДанных.Вставить("ТаблицаМетаданных", ТаблицаМетаданных);
	
	// Выполнение компоновки с помощью процессора компоновки.
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных,, Истина);
                  
	// Вывод таблицы   	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.ОтображатьПроцентВывода = Истина;
	ПроцессорВывода.УстановитьДокумент(Результат); 	
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	ТекущийЭлемент = Элементы.Результат;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СводнаяТаблицаМетаданных(СтруктураТаблиц, МассивИД)
	
	Запрос   = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Для каждого ЭлементСтруктуры Из СтруктураТаблиц Цикл
		ИД            = ЭлементСтруктуры.Ключ;
		ТаблицаДанных = ЭлементСтруктуры.Значение;
		МассивИД.Добавить(ИД);
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ТаблицаДанных.ВладелецСвойства КАК ВладелецСвойства,
		|	ТаблицаДанных.Значение КАК Значение,
		|	ТаблицаДанных.Свойство КАК Свойство,
		|	ТаблицаДанных.ТипОбъекта КАК ТипОбъекта,
		|	ТаблицаДанных.ХешКлюча КАК ХешКлюча
		|ПОМЕСТИТЬ ТаблицаДанныхПриемник
		|ИЗ
		|	&ТаблицаДанных КАК ТаблицаДанных
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ХешКлюча";
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ТаблицаДанныхПриемник", ИД);
		Запрос.Текст = ТекстЗапроса;
		Запрос.УстановитьПараметр("ТаблицаДанных", ТаблицаДанных);
		Запрос.Выполнить();
		
	КонецЦикла;
	
	ПервыйЭлемент = Истина;
	Для каждого ИД Из МассивИД Цикл
		Если ПервыйЭлемент Тогда
			ТекстЗапроса =
			"ВЫБРАТЬ
			|	ТаблицаДанныхИсточник.ХешКлюча
			|ПОМЕСТИТЬ ДанныеКлючей
			|ИЗ
			|	ТаблицаДанныхИсточник КАК ТаблицаДанныхИсточник";
			ПервыйЭлемент = Ложь;
		Иначе
			ТекстЗапроса = ТекстЗапроса + "
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ТаблицаДанныхИсточник.ХешКлюча
			|ИЗ
			|	ТаблицаДанныхИсточник КАК ТаблицаДанныхИсточник";
		КонецЕсли;
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ТаблицаДанныхИсточник", ИД);
	КонецЦикла;
	ТекстЗапроса = ТекстЗапроса + "
			|
			|;
			|///////////////////////////////////////////////////
			|";
	ТекстЗапроса = ТекстЗапроса +
	"ВЫБРАТЬ
	|	ВЫБОР";
	Для каждого ИД Из МассивИД Цикл 
		ТекстЗапроса = ТекстЗапроса + "
		|		КОГДА НЕ " + ИД + ".ВладелецСвойства ЕСТЬ NULL
		|			ТОГДА " + ИД + ".ВладелецСвойства";
	КонецЦикла;
	ТекстЗапроса = ТекстЗапроса + "
	|	КОНЕЦ КАК ВладелецСвойства,
	|	ВЫБОР";
	Для каждого ИД Из МассивИД Цикл 
		ТекстЗапроса = ТекстЗапроса + "
		|		КОГДА НЕ " + ИД + ".Значение ЕСТЬ NULL
		|			ТОГДА " + ИД + ".Значение";
	КонецЦикла;
	ТекстЗапроса = ТекстЗапроса + "
	|	КОНЕЦ КАК Значение,
	|	ВЫБОР";
	Для каждого ИД Из МассивИД Цикл 
		ТекстЗапроса = ТекстЗапроса + "
		|		КОГДА НЕ " + ИД + ".Свойство ЕСТЬ NULL
		|			ТОГДА " + ИД + ".Свойство";
	КонецЦикла;
	ТекстЗапроса = ТекстЗапроса + "
	|	КОНЕЦ КАК Свойство,
	|	ВЫБОР";
	Для каждого ИД Из МассивИД Цикл 
		ТекстЗапроса = ТекстЗапроса + "
		|		КОГДА НЕ " + ИД + ".ТипОбъекта ЕСТЬ NULL
		|			ТОГДА " + ИД + ".ТипОбъекта";
	КонецЦикла;
	ТекстЗапроса = ТекстЗапроса + "
	|	КОНЕЦ КАК ТипОбъекта,";
	Для каждого ИД Из МассивИД Цикл
		ТекстЗапроса = ТекстЗапроса + "
		|	ВЫБОР
		|		КОГДА " + ИД + ".ХешКлюча ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК " + ПолеПризнакВхождения(ИД) + ",";
	КонецЦикла;
	ТекстЗапроса = ТекстЗапроса + "
	|	ДанныеКлючей.ХешКлюча КАК ХешКлюча
	|ИЗ
	|	ДанныеКлючей КАК ДанныеКлючей";
	Для каждого ИД Из МассивИД Цикл
		ТекстЗапроса = ТекстЗапроса + "
		|		ЛЕВОЕ СОЕДИНЕНИЕ " + ИД + " КАК " + ИД + "
		|		ПО ДанныеКлючей.ХешКлюча = " + ИД + ".ХешКлюча";
	КонецЦикла;
	
	Запрос.Текст     = ТекстЗапроса;
	ТаблицаРезультат = Запрос.Выполнить().Выгрузить();

	Возврат ТаблицаРезультат;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолеПризнакВхождения(ИД)
	
	Возврат "ПрисутствуетВ" + ИД;
	
КонецФункции

&НаСервере
Функция НаименованиеИБ(ИД)
	
	Для каждого СтрокаПодключения Из Объект.НастройкиПодключений Цикл
		Если СтрокаПодключения.ИД = ИД Тогда
			Возврат СтрокаПодключения.Наименование;
		КонецЕсли;
	КонецЦикла;
	
	Возврат "<База не найдена>";
	
КонецФункции

&НаСервере
Процедура ПроверитьАналитикиНаСервере()
	
	ПроверкаАналитик_Результат.Очистить();
	ЕстьРасхождения = Ложь;
	
	Для каждого МетаданныеДокумента Из Метаданные.Документы Цикл
				
		ИмяДокумента = МетаданныеДокумента.Имя;
		Если Лев(ИмяДокумента, 4) = "бит_" Тогда
			Продолжить;	
		КонецЕсли;
		
		ИмяТипаСсылка = СтрШаблон("ДокументСсылка.%1", МетаданныеДокумента.Имя);
		ДокументТипСсылка = Тип(ИмяТипаСсылка);
		ИмяТипаОбъект = СтрШаблон("ДокументОбъект.%1", МетаданныеДокумента.Имя);
		ДокументТипОбъект = Тип(ИмяТипаОбъект);
		
		ВладелецАналитик     = Метаданные.ОпределяемыеТипы.бит_ВладелецДополнительныхАналитик.Тип.СодержитТип(ДокументТипСсылка);
		ИсточникПередЗаписью = Метаданные.ПодпискиНаСобытия.бит_ПередЗаписьюДокументаСАналитиками.Источник.СодержитТип(ДокументТипОбъект);
		ИсточникПриЗаписи    = Метаданные.ПодпискиНаСобытия.бит_ПриЗаписиДокументаСАналитиками.Источник.СодержитТип(ДокументТипОбъект);
		
		// Обработка "бит_РедактированиеДополнительныхАналитик".
		ИмяОбработкиРедактирования = "бит_РедактированиеДополнительныхАналитик";			
		Если Метаданные.Обработки.Найти(ИмяОбработкиРедактирования) <> Неопределено Тогда
			РедактированиеАналитик = Метаданные.Обработки[ИмяОбработкиРедактирования].Команды.Аналитики.ТипПараметраКоманды.СодержитТип(ДокументТипСсылка);		
		Иначе
			РедактированиеАналитик = Ложь;	
		КонецЕсли;
		// Документ "бит_ОтражениеФактаДДС".
		ИмяОтраженияФакта = "бит_ОтражениеФактаДДС";			
		Если Метаданные.Документы.Найти(ИмяОтраженияФакта) <> Неопределено Тогда
			ОтражениеФакта = Метаданные.Документы[ИмяОтраженияФакта].Команды.ОтражениеДДС.ТипПараметраКоманды.СодержитТип(ДокументТипСсылка);		
		Иначе
			ОтражениеФакта = Ложь;	
		КонецЕсли;
		
		// Обработка "бит_РезультатПроведения".
		ИмяОбработкиРезультат = "бит_РезультатПроведения";			
		Если Метаданные.Обработки.Найти(ИмяОбработкиРедактирования) <> Неопределено Тогда
			РезультатПроведения = Метаданные.Обработки[ИмяОбработкиРезультат].Команды.РезультатПроведения.ТипПараметраКоманды.СодержитТип(ДокументТипСсылка);		
		Иначе
			РезультатПроведения = Ложь;	
		КонецЕсли;
		// Обработка "бит_ДвиженияДокумента".
		ИмяОтчетаДвижений = "бит_ДвиженияДокумента";			
		Если Метаданные.Отчеты.Найти(ИмяОтчетаДвижений) <> Неопределено Тогда
			ОтчетДвижений = Метаданные.Отчеты[ИмяОтчетаДвижений].Команды.ОтчетПоДвижениям.ТипПараметраКоманды.СодержитТип(ДокументТипСсылка);		
		Иначе
			ОтчетДвижений = Ложь;	
		КонецЕсли;
				
		// Движения.
		ДвСЗТ = Метаданные.Документы[ИмяДокумента].Движения.Содержит(Метаданные.РегистрыСведений.бит_СоответствиеЗаписейТрансляции);
		ДвОпБ = Метаданные.Документы[ИмяДокумента].Движения.Содержит(Метаданные.РегистрыНакопления.бит_ОборотыПоБюджетам);
		ДвОпТ = Метаданные.Документы[ИмяДокумента].Движения.Содержит(Метаданные.РегистрыНакопления.бит_ОборотыПоТипамПроводок);
		ДвСОТ = Метаданные.Документы[ИмяДокумента].Движения.Содержит(Метаданные.РегистрыНакопления.бит_СоответствиеОборотовТрансляции);
		ДвБю  = Метаданные.Документы[ИмяДокумента].Движения.Содержит(Метаданные.РегистрыБухгалтерии.бит_Бюджетирование);
		ДвД1  = Метаданные.Документы[ИмяДокумента].Движения.Содержит(Метаданные.РегистрыБухгалтерии.бит_Дополнительный_1);
		ДвД2  = Метаданные.Документы[ИмяДокумента].Движения.Содержит(Метаданные.РегистрыБухгалтерии.бит_Дополнительный_2);
		ДвД3  = Метаданные.Документы[ИмяДокумента].Движения.Содержит(Метаданные.РегистрыБухгалтерии.бит_Дополнительный_3);
		ДвД4  = Метаданные.Документы[ИмяДокумента].Движения.Содержит(Метаданные.РегистрыБухгалтерии.бит_Дополнительный_4);
		ДвД5  = Метаданные.Документы[ИмяДокумента].Движения.Содержит(Метаданные.РегистрыБухгалтерии.бит_Дополнительный_5);
		ЕстьДвижения = ДвСЗТ ИЛИ ДвОпБ ИЛИ ДвОпТ ИЛИ ДвСОТ ИЛИ ДвБю ИЛИ ДвД1 ИЛИ ДвД2 ИЛИ ДвД3 ИЛИ ДвД4 ИЛИ ДвД5;
		ЕстьВсеДвижения = ДвСЗТ И ДвОпБ И ДвОпТ И ДвСОТ И ДвБю И ДвД1 И ДвД2 И ДвД3 И ДвД4 И ДвД5;
	
		// Проверки.
		ЕстьОшибкиПоДокументу = Ложь;		
		Если ВладелецАналитик ИЛИ ИсточникПередЗаписью ИЛИ ИсточникПриЗаписи 
			ИЛИ РедактированиеАналитик ИЛИ ОтражениеФакта ИЛИ РезультатПроведения 
			ИЛИ (ОтчетДвиженияДокумента И ОтчетДвижений) 
			ИЛИ (ПроверкаАналитикДвижения И ЕстьДвижения) Тогда		
			
			Если НЕ ВладелецАналитик Тогда
				// Обязательный определяемый тип для владельцев дополнительных аналитик.
				ЕстьОшибкиПоДокументу = Истина;
			ИначеЕсли бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
				Если НЕ ИсточникПередЗаписью ИЛИ НЕ ИсточникПриЗаписи Тогда
					// Подписки в БП должны быть включены.
					ЕстьОшибкиПоДокументу = Истина;
				КонецЕсли;
			ИначеЕсли бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
				Если РедактированиеАналитик = ОтражениеФакта Тогда
					// Для некоторых документов вместо обработки редактирования используется документ отражения факта ДДС.
					ЕстьОшибкиПоДокументу = Истина;
				ИначеЕсли РедактированиеАналитик И (НЕ ИсточникПередЗаписью ИЛИ НЕ ИсточникПриЗаписи) Тогда
					// При использовании обработки должны быть включены подписки.
					ЕстьОшибкиПоДокументу = Истина;
				ИначеЕсли ОтражениеФакта И (ИсточникПередЗаписью ИЛИ ИсточникПриЗаписи) Тогда
					// При использовании документа подписки должны быть выключены.
					ЕстьОшибкиПоДокументу = Истина;					
				КонецЕсли;
			КонецЕсли;
			
			Если НЕ РезультатПроведения Тогда
				ЕстьОшибкиПоДокументу = Истина;
			КонецЕсли;			
			Если ОтчетДвиженияДокумента И НЕ ОтчетДвижений Тогда
				ЕстьОшибкиПоДокументу = Истина;
			КонецЕсли;
			
			// Движения.
			Если ПроверкаАналитикДвижения И НЕ ЕстьВсеДвижения Тогда
				ЕстьОшибкиПоДокументу = Истина;			
			КонецЕсли;
						
			Если ЕстьОшибкиПоДокументу ИЛИ НЕ ТолькоРасхождения Тогда
			
				НоваяСтрока = ПроверкаАналитик_Результат.Добавить(); 
				НоваяСтрока.ИмяДокумента   = ИмяДокумента;
				НоваяСтрока.Представление  = МетаданныеДокумента.Представление();
				НоваяСтрока.Владелец       = ВладелецАналитик;
				НоваяСтрока.ПередЗаписью   = ИсточникПередЗаписью;
				НоваяСтрока.ПриЗаписи      = ИсточникПриЗаписи;
				НоваяСтрока.Редактирование = РедактированиеАналитик;
				НоваяСтрока.ОтражениеФакта = ОтражениеФакта;
				НоваяСтрока.РезультатПроведения = РезультатПроведения;
				НоваяСтрока.ОтчетДвижений 		= ОтчетДвижений;
				// Движения.
				НоваяСтрока.ДвиженияРегистрСведенийСоответствияЗаписейТрансляции = ДвСЗТ;
				НоваяСтрока.ДвиженияРегистрНакопленияОборотыПоБюджетам = ДвОпБ;
				НоваяСтрока.ДвиженияРегистрНакопленияОборотыПоТипамПроводок = ДвОпТ;
				НоваяСтрока.ДвиженияРегистрНакопленияСоответствиеОборотовТрансляции = ДвСОТ;
				НоваяСтрока.ДвиженияРегистрБухгалтерииБюджетирование = ДвБю;
				НоваяСтрока.ДвиженияРегистрБухгалтерииДополнительный_1 = ДвД1;
				НоваяСтрока.ДвиженияРегистрБухгалтерииДополнительный_2 = ДвД2;
				НоваяСтрока.ДвиженияРегистрБухгалтерииДополнительный_3 = ДвД3;
				НоваяСтрока.ДвиженияРегистрБухгалтерииДополнительный_4 = ДвД4;
				НоваяСтрока.ДвиженияРегистрБухгалтерииДополнительный_5 = ДвД5;
				
				Если ЕстьОшибкиПоДокументу Тогда			
					ЕстьРасхождения = Истина;
					НоваяСтрока.ЕстьРасхождения = Истина;			
				КонецЕсли;
			
			КонецЕсли;
			
		КонецЕсли;
			
	КонецЦикла;
	
	Элементы.ДекорацияЕстьРасхождения.Видимость = ЕстьРасхождения;
	Элементы.ПроверкаАналитик_РезультатОтчетДвижений.Видимость = ОтчетДвиженияДокумента;
	Элементы.ПроверкаАналитик_РезультатГруппаДвижения.Видимость = ПроверкаАналитикДвижения;
		
КонецПроцедуры

#КонецОбласти