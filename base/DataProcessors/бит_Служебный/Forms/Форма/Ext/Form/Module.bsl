Процедура КомандаТестировать(Команда)
	
	ТекущаяДата = ТекущаяДатаНаСервере();
	
	Протокол = "";
	
	ТекстСообщения = НСтр("ru = '<html><body><h1>Начало выполнения %1</h1><i>';
						  |en = '<html><body><h1>Start of execution %1</h1><i>'");
	ТекстСообщения = СтрШаблон(ТекстСообщения, ТекущаяДата);
	ДобавитьСообщение(ПротоколЗаписиОбъектов, ТекстСообщения);
	
	ВызватьМетодОбъекта();
	
	ТекстСообщения = НСтр("ru = '</i><h2>Выполнение завершено %1</h2></body></html>';
						  |en = '</i><h2>Completion complete %1</h2></body></html>'");
	ТекстСообщения = СтрШаблон(ТекстСообщения, ТекущаяДата);
	ДобавитьСообщение(ПротоколЗаписиОбъектов, ТекстСообщения);
	
КонецПроцедуры

&НаСервере
Процедура ВызватьМетодОбъекта()

	СтрПар = Новый Структура;
	СтрПар.Вставить("ПроверитьСПрефиксом", Объект.ПроверитьСПрефиксомБит);
	СтрПар.Вставить("Префикс", Объект.Префикс);
	СтрПар.Вставить("Справочники", Объект.ПроверитьСправочники);
	СтрПар.Вставить("Документы", Объект.ПроверитьДокументы);
	СтрПар.Вставить("ПланыВидовХарактеристик", Объект.ПроверитьПланыВидовХарактеристик);
	СтрПар.Вставить("ПланыОбмена", Объект.ПроверитьПланыОбмена);
	СтрПар.Вставить("ПланыСчетов", Объект.ПроверитьПланыСчетов);
	СтрПар.Вставить("ПланыВидовРасчета", Объект.ПроверитьПланыВидовРасчета);
	СтрПар.Вставить("Процессы", Объект.ПроверитьПроцессы);
	
	ОбОбъект = РеквизитФормыВЗначение("Объект");
	
	РезСтр = ОбОбъект.ПереборМетаданных(СтрПар);
	
	Счетчик = -1;
	Для Счетчик = Счетчик + 1 По РезСтр.МассивРезультатовПроверки.Количество() - 1 Цикл
		
		ТекстСообщения = НСтр("ru = 'ОШИБКА. В объекте метаданных: <font = ""15""><b>%4</font></br>%5</b> <a href=""%1"">%2</a></br>По причине: %3</br>-------------------------------</br>';
						      |en = 'ОШИБКА. В объекте метаданных: <font = ""15""><b>%4</font></br>%5</b> <a href=""%1"">%2</a></br>По причине: %3</br>-------------------------------</br>'");
		ТекстСообщения = СтрШаблон(ТекстСообщения
		, РезСтр.МассивРезультатовПроверки[Счетчик].Элемент
		, РезСтр.МассивРезультатовПроверки[Счетчик].Название
		, РезСтр.МассивРезультатовПроверки[Счетчик].Ошибка
		, РезСтр.МассивРезультатовПроверки[Счетчик].МетаОбъект
		, РезСтр.МассивРезультатовПроверки[Счетчик].Текст);
		ДобавитьСообщение(ПротоколЗаписиОбъектов, ТекстСообщения);
		
	КонецЦикла;	
	
КонецПроцедуры // ВызватьМетодОбъекта()

