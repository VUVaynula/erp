	ФайлНаДиске = Новый Файл(ПутьКФайлу);
	
	Возврат ФайлНаДиске.Существует();

КонецФункции // ЭтотФайлСуществует()
 
&НаСервере
Процедура ПроверкаРегистраторовСформировать(СравнитьСФайлом)
	
	ПроверкаРегистраторов_ЕстьОшибки  = Ложь;
	
	КореньДерева = ПроверкаРегистраторов_Результат.ПолучитьЭлементы();
	КореньДерева.Очистить();
		
	ЗаполнитьДеревоПроверкаРегистраторов(СравнитьСФайлом);
	
	УстановитьИнформациюОбОшибках(Элементы.ПроверкаРегистраторов_ИнфоОбОшибках, СравнитьСФайлом, ПроверкаРегистраторов_ЕстьОшибки);
			
КонецПроцедуры // ПроверкаРегистраторовСформировать()

// Работа с файлами

&НаСервере
Функция ПолучитьПутьКФайлуРегистраторов()

	ПутьКФайлу = ПутьКПапке + "\" + ФайлРегистраторов;
	
	Возврат ПутьКФайлу;

КонецФункции // ПолучитьПутьКФайлуРегистраторов()

&НаСервереБезКонтекста
Функция ПолучитьИмяФайлаРегистраторов(БфТип)

	МетаВерсия = Метаданные.Версия;
	НомерВерсии = Лев(МетаВерсия, 3);
	лФайлРегистратора = "Registrars" + СтрЗаменить(Метаданные.Имя, "_БИТ_ФИНАНС", "") 
		+ СтрЗаменить(НомерВерсии, ".", "_") + ?(БфТип = 0, "", "_Типовые") + ".txt";
	
	Возврат лФайлРегистратора;

КонецФункции // ПолучитьИмяФайлаРегистраторов()

&НаСервере
Функция ПрочитатьРегистраторыИзФайла(СравнитьСФайлом)

	фТаблица = Новый ТаблицаЗначений;
	ОпТипСтрока = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(100));
	фТаблица.Колонки.Добавить("ИмяДокумента", ОпТипСтрока);
	фТаблица.Колонки.Добавить("ИмяРегистра" , ОпТипСтрока);
	фТаблица.Колонки.Добавить("ТипРегистра" , ОпТипСтрока);
	
	Если СравнитьСФайлом Тогда
		
		// Прочитать из файла  таблицу значений
		ПутьКФайлу = ПолучитьПутьКФайлуРегистраторов();
		Если ЭтотФайлСуществует(ПутьКФайлу) Тогда
			
			ФайлРег = Новый ЧтениеТекста(ПутьКФайлу, КодировкаТекста.ANSI, , Истина);	

			фСтр = ФайлРег.ПрочитатьСтроку();
			Пока фСтр <> Неопределено Цикл // строки читаются до символа перевода строки
                
                фСтр = СтрЗаменить(фСтр, "Довальц", "Давальц");
                фСтр = СтрЗаменить(фСтр, "Донны", "Данны");
                
                МассивСтр = РазобратьСтрокуСРазделителями(фСтр, ".");
				СтрТз = фТаблица.Добавить();
                
                ЕстьОшибка = Ложь;
                Попытка
                    Если МассивСтр.Количество()<3 Тогда
                        ТекстСообщения = НСтр("ru = 'Ошибка в строке:'; en = 'Line error:'") + Символы.НПП + фСтр;
						ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, ЕстьОшибка);
                    КонецЕсли;                
                Исключение
                     ТекстСообщения = НСтр("ru = 'Ошибка в строке:'; en = 'Line error:'") + Символы.НПП + фСтр;
					 ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, ЕстьОшибка);
                КонецПопытки;
                
                Если ЕстьОшибка Тогда
                    СтрТз.ИмяДокумента = фСтр;
                Иначе
                    СтрТз.ИмяДокумента = МассивСтр[0];// СтрЗаменить(МассивСтр[0], "Довальц", "Давальц");
				    СтрТз.ИмяРегистра  = МассивСтр[1];
				    СтрТз.ТипРегистра  = МассивСтр[2];               
                КонецЕсли;				
                
				// Следующая строка
			    фСтр = ФайлРег.ПрочитатьСтроку();                
                
			КонецЦикла;
		
		КонецЕсли;
	
	КонецЕсли;

	Возврат фТаблица;

КонецФункции // ПрочитатьРегистраторыИзФайла()

&НаСервере
Процедура ЗаполнитьДеревоПроверкаРегистраторов(СравнитьСФайлом)
	
	ТаблицаРегистраторовИзФайла = ПрочитатьРегистраторыИзФайла(СравнитьСФайлом);
    	
#Область ЗаполнениеТаблицыДокументовИзКонфигурации

	ОпТипСтрока = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(100));
	ТаблицаДвиженийБит = Новый ТаблицаЗначений;
	ТаблицаДвиженийБит.Колонки.Добавить("ИмяДокумента", ОпТипСтрока);
	ТаблицаДвиженийБит.Колонки.Добавить("ИмяРегистра" , ОпТипСтрока);
	ТаблицаДвиженийБит.Колонки.Добавить("ТипРегистра" , ОпТипСтрока);

	Для каждого МетаДок Из Метаданные.Документы Цикл
		
		ИмяДокумента = МетаДок.Имя;
        Если Лев(ИмяДокумента, 4) = "бит_" Тогда
            Продолжить;		
		КонецЕсли;		     
		
		Для каждого ДвижениеДок Из МетаДок.Движения Цикл
			
			// Формирование таблицы регистраторов для сортировки
            Если (БфТип = 0 И Лев(ДвижениеДок.Имя, 4) = "бит_") 
                ИЛИ (БфТип = 1 И Лев(ДвижениеДок.Имя, 4) <> "бит_") Тогда
				
				НоваяСтрока = ТаблицаДвиженийБит.Добавить();
				
				НоваяСтрока.ИмяДокумента = ИмяДокумента;
				НоваяСтрока.ИмяРегистра  = ДвижениеДок.Имя;
				
				ПолноеИмя = ДвижениеДок.ПолноеИмя();
				НоваяСтрока.ТипРегистра = Лев(ПолноеИмя, Найти(ПолноеИмя, ".") - 1);
							
			КонецЕсли;			
						
		КонецЦикла;
		
	КонецЦикла;
	
#КонецОбласти
	
#Область Запрос	
	
	Запрос = Новый Запрос;
	МенеджерВремТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МенеджерВремТаблиц;
	Запрос.УстановитьПараметр("ТабКонф", ТаблицаДвиженийБит);
	Запрос.УстановитьПараметр("ТабФайл", ТаблицаРегистраторовИзФайла);
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ТабКонф.ИмяДокумента КАК ИмяДокумента,
	|	ТабКонф.ИмяРегистра  КАК ИмяРегистра,
	|	ТабКонф.ТипРегистра  КАК ТипРегистра
	|ПОМЕСТИТЬ ВремТабКонф  
	|ИЗ
	|	&ТабКонф КАК ТабКонф
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////     
	|ВЫБРАТЬ
	|	ТабФайл.ИмяДокумента,
	|	ТабФайл.ИмяРегистра,
	|	ТабФайл.ТипРегистра
	|ПОМЕСТИТЬ ВремТабФайл
	|ИЗ 
	|	&ТабФайл КАК ТабФайл
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТабКонф.ИмяДокумента,
	|	ТабКонф.ИмяРегистра,
	|	ТабКонф.ТипРегистра,
	|	ИСТИНА 				 КАК ЕстьВКонфе,
	|	ЛОЖЬ 				 КАК ЕстьВФайле
	|ПОМЕСТИТЬ ВремТаб  
	|ИЗ
	|	ВремТабКонф КАК ТабКонф
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	ТабФайл.ИмяДокумента,
	|	ТабФайл.ИмяРегистра,
	|	ТабФайл.ТипРегистра,
	|	ЛОЖЬ,
	|	ИСТИНА
	|ИЗ 
	|	ВремТабФайл КАК ТабФайл
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВремТаб.ИмяДокумента КАК ИмяДокумента,
	|	ВремТаб.ИмяРегистра  КАК ИмяРегистра,
	|	ВремТаб.ТипРегистра  КАК ТипРегистра,
	|	ВремТаб.ЕстьВКонфе   КАК ЕстьВКонфе,
	|	ВремТаб.ЕстьВФайле   КАК ЕстьВФайле
	|ИЗ
	|	ВремТаб КАК ВремТаб
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИмяДокумента,
	|	ТипРегистра,
	|	ИмяРегистра
	|ИТОГИ
	|	МАКСИМУМ(ТипРегистра),
	|	МАКСИМУМ(ЕстьВКонфе),
	|	МАКСИМУМ(ЕстьВФайле)
	|ПО
	|	ИмяДокумента,
	|	ИмяРегистра
	|";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
#КонецОбласти 
    
	ВыборкаДок = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	Пока ВыборкаДок.Следующий() Цикл
        
        ВеткаДерева = Неопределено;
        
        Если Не ТолькоОшибки Тогда
    		// Ветка по документу
    		КореньДерева = ПроверкаРегистраторов_Результат.ПолучитьЭлементы();
    		НовыйУД = КореньДерева.Добавить();
            НовыйУД.Документ   = ВыборкаДок.ИмяДокумента;
    		НовыйУД.ЕстьВКонфе = ВыборкаДок.ЕстьВКонфе;
    		НовыйУД.ЕстьВФайле = ВыборкаДок.ЕстьВФайле;
    		ВеткаДерева = НовыйУД.ПолучитьЭлементы();
        КонецЕсли;
        
		ВыборкаРег = ВыборкаДок.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
		Пока ВыборкаРег.Следующий() Цикл
            
            Если Не ТолькоОшибки Тогда
    			// Вывод регистраторов
    			НоваяСД = ВеткаДерева.Добавить();
    			ЗаполнитьЗначенияСвойств(НоваяСД, ВыборкаРег);
    		КонецЕсли;	
            
            Если СравнитьСФайлом И ВыборкаРег.ЕстьВКонфе <> ВыборкаРег.ЕстьВФайле Тогда
                Если ТолькоОшибки Тогда
                    Если ВеткаДерева = Неопределено Тогда
                        // Ветка по документу
                		КореньДерева = ПроверкаРегистраторов_Результат.ПолучитьЭлементы();
                		НовыйУД = КореньДерева.Добавить();
                        НовыйУД.Документ   = ВыборкаДок.ИмяДокумента;
                		НовыйУД.ЕстьВКонфе = ВыборкаДок.ЕстьВКонфе;
                		НовыйУД.ЕстьВФайле = ВыборкаДок.ЕстьВФайле;
                		ВеткаДерева = НовыйУД.ПолучитьЭлементы();
                    КонецЕсли;
                    // Вывод регистраторов
                    НоваяСД = ВеткаДерева.Добавить();
                    ЗаполнитьЗначенияСвойств(НоваяСД, ВыборкаРег);
                КонецЕсли;
                ПроверкаРегистраторов_ЕстьОшибки = Истина;
                НоваяСД.ЕстьОшибки = Истина;
                НовыйУД.ЕстьОшибки = Истина;  				
            КонецЕсли;            
            
		КонецЦикла;		
	
	КонецЦикла; 

КонецПроцедуры // ЗаполнитьДеревоПроверкаРегистраторов()

&НаСервере
Функция РазобратьСтрокуСРазделителями(ИсходнаяСтрока,Разделитель)
	
	РезМассив = Новый Массив;
	
	Стр = ИсходнаяСтрока;
	КоличествоРазделителей = СтрЧислоВхождений(Стр,Разделитель);
	Для й = 1 По КоличествоРазделителей+1 Цикл
		
		ПозицияРазделителя = Найти(Стр,Разделитель);
		Если ПозицияРазделителя >0 Тогда
			ТекущееИмя = Лев(Стр,ПозицияРазделителя-1);
			Стр = Сред(Стр,ПозицияРазделителя+1);
		Иначе
			ТекущееИмя = СокрЛП(Стр);
		КонецЕсли; 
		РезМассив.Добавить(ТекущееИмя);
		
	КонецЦикла;
	
	Возврат РезМассив;
	
КонецФункции // РазобратьСтрокуСРазделителями()

