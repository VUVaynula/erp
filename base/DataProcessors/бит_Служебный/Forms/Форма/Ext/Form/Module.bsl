#Область СравнениеРегистраторов
	
&НаСервере
Процедура СравнитьРегистраторыНаСервере()
	
	ИменаРегистров = Новый Массив;
	МетаданныеРегистры = Новый Массив;
	Для каждого ЭлементРегистратор Из РегистраторыДляСравнения Цикл
		ОбъектСистемы = ЭлементРегистратор.Значение;	
		ВидОбъекта = ОбъектСистемы.Родитель.ИмяПредопределенныхДанных;
		ИмяОбъекта = ОбъектСистемы.ИмяОбъекта;
		ЭлементМетаданных = Метаданные[ВидОбъекта][ИмяОбъекта];
		ИменаРегистров.Добавить(ОбъектСистемы.ИмяОбъекта);
		МетаданныеРегистры.Добавить(ЭлементМетаданных);
	КонецЦикла;
	
	Если ИменаРегистров.Количество() < 2 Тогда
		ТекстСообщения = НСтр("ru='Заполните два регистра.';en='Fill in two registers.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Элементы.РезультатСравненияРегистраторовЕстьВПервом.Заголовок  = ИменаРегистров[0];
	Элементы.РезультатСравненияРегистраторовЕстьВоВтором.Заголовок = ИменаРегистров[1];
	
	Для каждого ЭлементДокумент Из Метаданные.Документы Цикл
		ЕстьВПервом = ЭлементДокумент.Движения.Содержит(МетаданныеРегистры[0]);
		ЕстьВоВтором = ЭлементДокумент.Движения.Содержит(МетаданныеРегистры[1]);
		Если ЕстьВПервом Или ЕстьВоВтором Тогда		
			НоваяСтрока = РезультатСравненияРегистраторов.Добавить();
			НоваяСтрока.Регистратор = ЭлементДокумент.Синоним;
			// Есть в регистрах.
			НоваяСтрока.ЕстьВПервом = ЕстьВПервом;
			НоваяСтрока.ЕстьВоВтором = ЕстьВоВтором;
			НоваяСтрока.ЕстьВОбоих = ЕстьВПервом И ЕстьВоВтором;		
		КонецЕсли;			
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ПроверкаРегистраторов

&НаКлиентеНаСервереБезКонтекста
