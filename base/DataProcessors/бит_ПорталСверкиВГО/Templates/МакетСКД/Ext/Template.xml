ИЗ
	РегистрСведений.бит_СобственныеКонтрагенты КАК СобственныеКонтрагенты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	СобственныеКонтрагенты1.Организация КАК Организация1,
	СобственныеКонтрагенты1.Контрагент  КАК Контрагент1,
	СобственныеКонтрагенты2.Организация КАК Организация2,
	СобственныеКонтрагенты2.Контрагент  КАК Контрагент2
ПОМЕСТИТЬ ВсеПары
ИЗ
	СобственныеКонтрагенты КАК СобственныеКонтрагенты1
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СобственныеКонтрагенты КАК СобственныеКонтрагенты2
		ПО СобственныеКонтрагенты1.Контрагент &lt;&gt; СобственныеКонтрагенты2.Контрагент
		   И (СобственныеКонтрагенты1.Организация В(&amp;Организация) ИЛИ ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка) В(&amp;Организация))
		   И (СобственныеКонтрагенты2.Контрагент В(&amp;Контрагент) ИЛИ ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка) В(&amp;Контрагент))
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВсеПары.Организация1,
	ВсеПары.Контрагент1,
	ВсеПары.Организация2,
	ВсеПары.Контрагент2,
	&amp;АктыСверкиВГО  		 		 КАК ТипДокумента,
	1 								 КАК Порядок,
	СписокДокументов.Ссылка 		 КАК Ссылка1,
	NULL 							 КАК Ссылка2,
	NULL 			КАК СуммаАбсолютногоРасхождения,
	NULL 			КАК СуммаАбсолютногоРасхожденияВзм,
	Ложь 			КАК ЕстьЗакрытие1,
	Ложь 			КАК ЕстьЗакрытие2
ПОМЕСТИТЬ Документы
ИЗ
	ВсеПары КАК ВсеПары
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_вго_АктСверкиВГО КАК СписокДокументов
		ПО ВсеПары.Организация1 = СписокДокументов.Организация
			И ВсеПары.Контрагент2 = СписокДокументов.Контрагент
			И (СписокДокументов.Проведен = ИСТИНА ИЛИ &amp;ВыводитьНепроведенные)
            И СписокДокументов.ДатаНачала &gt;= &amp;ДатаНачала
			И СписокДокументов.ДатаНачала &lt;= &amp;ДатаОкончания
			И (СписокДокументов.РегистрБухгалтерии В(&amp;РегистрБухгалтерии) ИЛИ ЗНАЧЕНИЕ(Справочник.бит_ОбъектыСистемы.ПустаяСсылка) В(&amp;РегистрБухгалтерии))
			И (СписокДокументов.Сценарий = &amp;Сценарий ИЛИ &amp;ПустойСценарий = &amp;Сценарий)
ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВсеПары.Организация1,
	ВсеПары.Контрагент1,
	ВсеПары.Организация2,
	ВсеПары.Контрагент2,
	&amp;АктыСверкиВГО,
	1,
	NULL,
	СписокДокументов.Ссылка,
	NULL,
	NULL,
	Ложь,
	Ложь
ИЗ
	ВсеПары КАК ВсеПары
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_вго_АктСверкиВГО КАК СписокДокументов
		ПО ВсеПары.Организация2 = СписокДокументов.Организация
			И ВсеПары.Контрагент1 = СписокДокументов.Контрагент
			И (СписокДокументов.Проведен = ИСТИНА ИЛИ &amp;ВыводитьНепроведенные)
			И СписокДокументов.ДатаНачала &gt;= &amp;ДатаНачала
			И СписокДокументов.ДатаНачала &lt;= &amp;ДатаОкончания
			И (СписокДокументов.РегистрБухгалтерии В(&amp;РегистрБухгалтерии) ИЛИ ЗНАЧЕНИЕ(Справочник.бит_ОбъектыСистемы.ПустаяСсылка) В(&amp;РегистрБухгалтерии))
			И (СписокДокументов.Сценарий = &amp;Сценарий ИЛИ &amp;ПустойСценарий = &amp;Сценарий)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВсеПары.Организация1,
	ВсеПары.Контрагент1,
	ВсеПары.Организация2,
	ВсеПары.Контрагент2,
	&amp;ПротоколыРасхождений,
	2,
	СписокДокументов.Ссылка,
	NULL,
	NULL,
	NULL,
	Ложь,
	Ложь
ИЗ
	ВсеПары КАК ВсеПары
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_вго_ПротоколРасхождений КАК СписокДокументов
		ПО ВсеПары.Организация1 = СписокДокументов.Организация
			И ВсеПары.Контрагент2 = СписокДокументов.Контрагент
			И (СписокДокументов.Проведен = ИСТИНА ИЛИ &amp;ВыводитьНепроведенные)
			И СписокДокументов.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
			И (СписокДокументов.РегистрБухгалтерии В(&amp;РегистрБухгалтерии) ИЛИ ЗНАЧЕНИЕ(Справочник.бит_ОбъектыСистемы.ПустаяСсылка) В(&amp;РегистрБухгалтерии))
			И (СписокДокументов.Сценарий = &amp;Сценарий ИЛИ &amp;ПустойСценарий = &amp;Сценарий)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВсеПары.Организация1,
	ВсеПары.Контрагент1,
	ВсеПары.Организация2,
	ВсеПары.Контрагент2,
	&amp;ПротоколыРасхождений,
	2,
	NULL,
	СписокДокументов.Ссылка,
	NULL,
	NULL,
	Ложь,
	Ложь
ИЗ
	ВсеПары КАК ВсеПары
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_вго_ПротоколРасхождений КАК СписокДокументов
		ПО ВсеПары.Организация2 = СписокДокументов.Организация
			И ВсеПары.Контрагент1 = СписокДокументов.Контрагент
			И (СписокДокументов.Проведен = ИСТИНА ИЛИ &amp;ВыводитьНепроведенные)
			И СписокДокументов.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
			И (СписокДокументов.РегистрБухгалтерии В(&amp;РегистрБухгалтерии) ИЛИ ЗНАЧЕНИЕ(Справочник.бит_ОбъектыСистемы.ПустаяСсылка) В(&amp;РегистрБухгалтерии))
			И (СписокДокументов.Сценарий = &amp;Сценарий ИЛИ &amp;ПустойСценарий = &amp;Сценарий)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВсеПары.Организация1,
	ВсеПары.Контрагент1,
	ВсеПары.Организация2,
	ВсеПары.Контрагент2,
	&amp;ПодтверждениеСверкиВГО,
	3,
	СписокДокументов.Ссылка,
	NULL,
	ВЫБОР 
		КОГДА СписокДокументов.Проведен
			ТОГДА СписокДокументов.СуммаАбсолютногоРасхождения
		ИНАЧЕ 0
	КОНЕЦ,
	ВЫБОР 
		КОГДА СписокДокументов.Проведен
			ТОГДА СписокДокументов.СуммаАбсолютногоРасхожденияВзм
		ИНАЧЕ 0
	КОНЕЦ,
	СписокДокументов.Проведен,
	Ложь	
ИЗ
	ВсеПары КАК ВсеПары
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_вго_ПодтверждениеСверкиВГО КАК СписокДокументов
		ПО ВсеПары.Организация1 = СписокДокументов.Организация1
			И ВсеПары.Организация2 = СписокДокументов.Организация2
			И ВсеПары.Контрагент1 = СписокДокументов.Контрагент1
			И ВсеПары.Контрагент2 = СписокДокументов.Контрагент2
			И (СписокДокументов.Проведен = ИСТИНА ИЛИ &amp;ВыводитьНепроведенные)
			И СписокДокументов.ДатаНачала &gt;= &amp;ДатаНачала
			И СписокДокументов.ДатаНачала &lt;= &amp;ДатаОкончания
			И (СписокДокументов.РегистрБухгалтерии В(&amp;РегистрБухгалтерии) ИЛИ ЗНАЧЕНИЕ(Справочник.бит_ОбъектыСистемы.ПустаяСсылка) В(&amp;РегистрБухгалтерии))
			И (СписокДокументов.Сценарий = &amp;Сценарий ИЛИ &amp;ПустойСценарий = &amp;Сценарий)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВсеПары.Организация1,
	ВсеПары.Контрагент1,
	ВсеПары.Организация2,
	ВсеПары.Контрагент2,
	&amp;ПодтверждениеСверкиВГО,
	3,
	NULL,
	СписокДокументов.Ссылка,
	ВЫБОР 
		КОГДА СписокДокументов.Проведен
			ТОГДА СписокДокументов.СуммаАбсолютногоРасхождения
		ИНАЧЕ 0
	КОНЕЦ,
	ВЫБОР 
		КОГДА СписокДокументов.Проведен
			ТОГДА СписокДокументов.СуммаАбсолютногоРасхожденияВзм
		ИНАЧЕ 0
	КОНЕЦ,
	Ложь,
	СписокДокументов.Проведен
ИЗ
	ВсеПары КАК ВсеПары
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_вго_ПодтверждениеСверкиВГО КАК СписокДокументов
		ПО ВсеПары.Организация1 = СписокДокументов.Организация2
			И ВсеПары.Организация2 = СписокДокументов.Организация1
			И ВсеПары.Контрагент1 = СписокДокументов.Контрагент2
			И ВсеПары.Контрагент2 = СписокДокументов.Контрагент1
			И (СписокДокументов.Проведен = ИСТИНА ИЛИ &amp;ВыводитьНепроведенные)
			И СписокДокументов.ДатаНачала &gt;= &amp;ДатаНачала
			И СписокДокументов.ДатаНачала &lt;= &amp;ДатаОкончания
			И (СписокДокументов.РегистрБухгалтерии В(&amp;РегистрБухгалтерии) ИЛИ ЗНАЧЕНИЕ(Справочник.бит_ОбъектыСистемы.ПустаяСсылка) В(&amp;РегистрБухгалтерии))
			И (СписокДокументов.Сценарий = &amp;Сценарий ИЛИ &amp;ПустойСценарий = &amp;Сценарий)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Документы.ТипДокумента,
	Документы.Порядок,
	Документы.Организация1 КАК Организация1,
	Документы.Контрагент1,
	Документы.Организация2 КАК Организация2,
	Документы.Контрагент2,
	Документы.Ссылка1,
	Документы.Ссылка2,
	ЕСТЬNULL(Документы.СуммаАбсолютногоРасхождения, 0) КАК СуммаАбсолютногоРасхождения,
	ЕСТЬNULL(Документы.СуммаАбсолютногоРасхожденияВзм, 0) КАК СуммаАбсолютногоРасхожденияВзм,
	ЕстьЗакрытие1,	
	ЕстьЗакрытие2
ИЗ
	Документы КАК Документы
ГДЕ
	(НЕ Документы.Ссылка1 ЕСТЬ NULL) ИЛИ (НЕ Документы.Ссылка2 ЕСТЬ NULL)
	
;

