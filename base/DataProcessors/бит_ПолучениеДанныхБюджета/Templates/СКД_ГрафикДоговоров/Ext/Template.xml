	бит_ГрафикиДоговоровОбороты.ДоговорКонтрагента КАК ДоговорКонтрагента,
	бит_ГрафикиДоговоровОбороты.Аналитика_1 КАК Аналитика_1,
	бит_ГрафикиДоговоровОбороты.Аналитика_2 КАК Аналитика_2,
	бит_ГрафикиДоговоровОбороты.Аналитика_3 КАК Аналитика_3,
	бит_ГрафикиДоговоровОбороты.Аналитика_4 КАК Аналитика_4,
	бит_ГрафикиДоговоровОбороты.Аналитика_5 КАК Аналитика_5,
	бит_ГрафикиДоговоровОбороты.Аналитика_6 КАК Аналитика_6,
	бит_ГрафикиДоговоровОбороты.Аналитика_7 КАК Аналитика_7,
	бит_ГрафикиДоговоровОбороты.Аналитика_8,
	бит_ГрафикиДоговоровОбороты.Аналитика_9,
	бит_ГрафикиДоговоровОбороты.Аналитика_10,
	бит_ГрафикиДоговоровОбороты.Аналитика_11,
	бит_ГрафикиДоговоровОбороты.Аналитика_12,
	СУММА(ВЫБОР
			КОГДА &amp;РежимВыбораСуммы = ИСТИНА
				ТОГДА бит_ГрафикиДоговоровОбороты.СуммаБезНДССценарийОборот
			ИНАЧЕ бит_ГрафикиДоговоровОбороты.СуммаСценарийОборот
		КОНЕЦ) КАК СуммаСценарий
{ВЫБРАТЬ
	Период,
	Сценарий.*,
	ЦФО.*,
	СтатьяОборотов.*,
	ДокументРегистратор.*,
	ТипСтатьи.*,
	ДоговорКонтрагента.*,
	Аналитика_1.*,
	Аналитика_2.*,
	Аналитика_3.*,
	Аналитика_4.*,
	Аналитика_5.*,
	Аналитика_6.*,
	Аналитика_7.*,
	Аналитика_8.*,
	Аналитика_9.*,
	Аналитика_10.*,
	Аналитика_11.*,
	Аналитика_12.*,
	СуммаСценарий}
ИЗ
	РегистрНакопления.бит_ГрафикиДоговоров.Обороты(&amp;НачалоПериода {(&amp;НачалоПериода)}, &amp;КонецПериода {(&amp;КонецПериода)}, Месяц {(&amp;Периодичность)}, {(Сценарий), (ЦФО), (СтатьяОборотов), (ДоговорКонтрагента), (Аналитика_1), (Аналитика_2), (Аналитика_3), (Аналитика_4), (Аналитика_5), (Аналитика_6), (Аналитика_7)}) КАК бит_ГрафикиДоговоровОбороты
ГДЕ
	ВЫБОР
			КОГДА &amp;Бюджет = ЗНАЧЕНИЕ(Справочник.бит_Бюджеты.ПустаяСсылка)
					ИЛИ &amp;Бюджет = НЕОПРЕДЕЛЕНО
					ИЛИ &amp;Бюджет ЕСТЬ NULL 
				ТОГДА ИСТИНА
			ИНАЧЕ бит_ГрафикиДоговоровОбороты.СтатьяОборотов В
					(ВЫБРАТЬ
						СтатьиБюджета.СтатьяОборотов
					ИЗ
						СтатьиБюджета КАК СтатьиБюджета)
		КОНЕЦ

СГРУППИРОВАТЬ ПО
	бит_ГрафикиДоговоровОбороты.Период,
