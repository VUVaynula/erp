	бит_ГрафикиДоговоровОбороты.Аналитика_4,
	бит_ГрафикиДоговоровОбороты.Аналитика_5,
	бит_ГрафикиДоговоровОбороты.Аналитика_6,
	бит_ГрафикиДоговоровОбороты.Аналитика_7,
	бит_ГрафикиДоговоровОбороты.Аналитика_8,
	бит_ГрафикиДоговоровОбороты.Аналитика_9,
	бит_ГрафикиДоговоровОбороты.Аналитика_10,
	бит_ГрафикиДоговоровОбороты.Аналитика_11,
	бит_ГрафикиДоговоровОбороты.Аналитика_12
;

