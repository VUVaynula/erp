
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметры, "АвтоТест", Ложь) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Параметры.РежимЗаполнения) Тогда
		ТекстСообщения = НСтр("ru='Непосредственное открытие этой формы не предусмотрено.';
							  |en='The immediate opening of this form is not provided.'");
		ВызватьИсключение ТекстСообщения;
	КонецЕсли;
	
	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;	
	
	// Установка списка выбора для вида сравнения таблицы отборов.
	ВидыСравнения = бит_МеханизмПолученияДанных.СформироватьСписокВыбораДляОтборовВОтчете("Массив");
	Элементы.ОтборВОтчетеВидСравнения.СписокВыбора.ЗагрузитьЗначения(ВидыСравнения);
	
	// Список типов для быстрого выбора составного.
	ТипыИсточников = Метаданные.Обработки.бит_ПолучениеДанныхБюджета.Реквизиты.ИсточникДанных.Тип.Типы();
	ТипыИсточниковДанных = бит_ОбщегоНазначения.ПодготовитьСписокВыбораТипа(ТипыИсточников);
	
	ОписаниеПроизвольногоТипа = бит_ОбщегоНазначения.ОписаниеПроизвольногоТипа();
	
	// Устанавливаем режим копирования.
	Параметры.Свойство("РежимЗаполнения", Объект.РежимЗаполнения);	
	Режимы = Обработки.бит_ПолучениеДанныхБюджета.РежимыПолученияДанных(Объект.РежимЗаполнения);
	ЭтоПланированиеДДС = Режимы.ЭтоПланированиеДДС;
	
	// Инициализация компоновщика.
	Если Режимы.ЭтоКопированиеБюджета ИЛИ Режимы.ЭтоПланированиеДДС Тогда
		АдресСКД = Обработки.бит_ПолучениеДанныхБюджета.ИнициализироватьКомпоновщик("СКД_Копирование", 
			Компоновщик, УникальныйИдентификатор);
	ИначеЕсли Режимы.ЭтоГрафикДоговоров Тогда	
		АдресСКД = Обработки.бит_ПолучениеДанныхБюджета.ИнициализироватьКомпоновщик("СКД_ГрафикДоговоров", 
			Компоновщик, УникальныйИдентификатор);
	КонецЕсли; 
	
	// Восстановление настройки по-умолчанию.
	УстановитьЗначенияПоУмолчанию();
	
	Если ЗначениеЗаполнено(Параметры.ДокументЗаполнения) Тогда
		
		Объект.ДокументЗаполнения = Параметры.ДокументЗаполнения;
		
		Если Параметры.ДанныеДокументаЗаполнения = Неопределено Тогда
			Если Режимы.ЭтоПроизвольныеПараметры Тогда
				ДанныеДок = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.ДокументЗаполнения, "Дата, Параметр");
				ДатаЗаполнения = ДанныеДок.Дата;
				ЗаполнитьЗначенияСвойств(Объект, Параметры.ПараметрыЗаполнения, 
					"ВалютаДокумента, КурсДокумента, КратностьДокумента, Сценарий, ЕдиницаИзмеренияСуммДокумента");
				НастроитьКолонкиПроизовльногоПараметра(ДанныеДок.Параметр);
			Иначе
				ДанныеДок = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.ДокументЗаполнения, 
				"Дата, ВалютаДокумента, КурсДокумента, КратностьДокумента, Сценарий, ЕдиницаИзмеренияСумм");
				ЗаполнитьЗначенияСвойств(Объект, ДанныеДок);
				ДатаЗаполнения = ДанныеДок.Дата;
			КонецЕсли;
		Иначе
			ДанныеДокументаЗаполнения = Параметры.ДанныеДокументаЗаполнения;
			ДатаЗаполнения            = ДанныеДокументаЗаполнения.Дата;
			Если Режимы.ЭтоПроизвольныеПараметры Тогда
				ЗаполнитьЗначенияСвойств(Объект, Параметры.ПараметрыЗаполнения, 
					"ВалютаДокумента, КурсДокумента, КратностьДокумента, Сценарий, ЕдиницаИзмеренияСуммДокумента");
				НастроитьКолонкиПроизовльногоПараметра(ДанныеДокументаЗаполнения.Параметр);
			Иначе
				ЗаполнитьЗначенияСвойств(Объект, ДанныеДокументаЗаполнения);
			КонецЕсли;
		КонецЕсли;
		
		ДанныеСценария = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Сценарий, "бит_Периодичность, Валюта");
		Объект.ПериодичностьСдвигаДат  = ДанныеСценария.бит_Периодичность;
		Объект.ВалютаОбработки         = ДанныеСценария.Валюта;
		
		ИзменениеВалюты();
		
	ИначеЕсли Режимы.ЭтоПланированиеДДС Тогда
		
		ПараметрыЗаполнения = Параметры.ПараметрыЗаполнения;		
		ПараметрыЗаполнения.Свойство("ВалютаДокумента", 			  Объект.ВалютаДокумента);
		ПараметрыЗаполнения.Свойство("КурсДокумента", 				  Объект.КурсДокумента);
		ПараметрыЗаполнения.Свойство("КратностьДокумента", 			  Объект.КратностьДокумента);
		ПараметрыЗаполнения.Свойство("ВалютаОбработки", 			  Объект.ВалютаОбработки);
		ПараметрыЗаполнения.Свойство("КурсОбработки", 				  Объект.КурсОбработки);
		ПараметрыЗаполнения.Свойство("КратностьОбработки", 			  Объект.КратностьОбработки);
		ПараметрыЗаполнения.Свойство("ПериодичностьСдвигаДат", 		  Объект.ПериодичностьСдвигаДат);
		ПараметрыЗаполнения.Свойство("Период", 			  			  Объект.Период);
		ПараметрыЗаполнения.Свойство("ЕдиницаИзмеренияСуммДокумента", Объект.ЕдиницаИзмеренияСуммДокумента);
		
		// Установим отбора компоновщика.
		СтруктураОтбора = Неопределено;
		Параметры.Свойство("СтруктураОтбора", СтруктураОтбора);
		
		Если СтруктураОтбора <> Неопределено Тогда
			ПараметрыСКД = Компоновщик.Настройки.ПараметрыДанных;
			Для Каждого ЭлементОтбора Из СтруктураОтбора.Параметры Цикл
				ЗначениеПараметра = ПараметрыСКД.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных(ЭлементОтбора.Ключ));
				Если ЗначениеПараметра <> Неопределено Тогда
					ЗначениеПараметра.Значение = ЭлементОтбора.Значение;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		ИзменениеВалюты();
		
	ИначеЕсли Параметры.Свойство("ПараметрыЗаполнения")	Тогда
		ЗаполнитьЗначенияСвойств(Объект, Параметры.ПараметрыЗаполнения);
	Иначе
		Объект.ВалютаДокумента = Константы.бит_ВалютаУправленческогоУчета.Получить();
		СтрКурса                  = бит_КурсыВалют.ПолучитьКурсВалюты(Объект.ВалютаДокумента, ТекущаяДатаСеанса());
		Объект.КурсДокумента      = СтрКурса.Курс;
		Объект.КратностьДокумента = СтрКурса.Кратность;
		Объект.ЕдиницаИзмеренияСуммДокумента = Перечисления.бит_ЕдиницыИзмеренияСумм.Единицы;
	КонецЕсли;
	
	ЭтоФормаВвода = ТипЗнч(Объект.ДокументЗаполнения) = Тип("ДокументСсылка.бит_ФормаВводаБюджета");
	Элементы.ИспользоватьЗначенияПоУмолчанию.Видимость = ЭтоФормаВвода;
	
	Объект.ЕдиницаИзмеренияСуммОбработки = Перечисления.бит_ЕдиницыИзмеренияСумм.Единицы;
	Если Не ЗначениеЗаполнено(Объект.ПериодичностьСдвигаДат) Тогда
		Объект.ПериодичностьСдвигаДат = Перечисления.бит_ПериодичностьПланирования.Месяц;
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(Объект.Период) Тогда
		Если ЗначениеЗаполнено(ДатаЗаполнения) Тогда
			Объект.Период.Вариант = ВариантСтандартногоПериода.ПроизвольныйПериод;
			Объект.Период.ДатаНачала    = НачалоМесяца(ДатаЗаполнения);
			Объект.Период.ДатаОкончания = КонецМесяца(ДатаЗаполнения);
		Иначе	
			Объект.Период.Вариант = ВариантСтандартногоПериода.ЭтотГод;
		КонецЕсли; 
	КонецЕсли; 
	
	ЗакрыватьПриВыборе = Ложь;
	ЗакрыватьПриЗакрытииВладельца = Истина;
	
	Объект.РежимСообщений = "Все";
	
	Если НЕ Режимы.ЭтоПроизвольныеПараметры Тогда
		// Отображение дополнительных измерений в табличных полях.
		ИзмеренияДоп = бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Дополнительные", "Синоним");	
		НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
		бит_МеханизмДопИзмерений.ПоказатьДополнительныеИзмеренияВТабличномПоле(ЭтотОбъект, "ОборотыПоБюджетам",
			ИзмеренияДоп, НастройкиИзмерений);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.ВалютаОбработки) Тогда
		Объект.ВалютаОбработки = Константы.ВалютаРегламентированногоУчета.Получить();
		Объект.КурсОбработки 	  = 1;
		Объект.КратностьОбработки = 1;	
	КонецЕсли;
	
	УстановитьВидимость();
	
	// Установка заголовка формы.
	УстановитьЗаголовокФормы(Заголовок, Режимы, ТекущаяНастройка);
		
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзменениеПериода" И УникальныйИдентификатор = Параметр Тогда
	
		ПриИзмененииПериода();
	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	УстановитьВидимость();
	
КонецПроцедуры

#КонецОбласти

