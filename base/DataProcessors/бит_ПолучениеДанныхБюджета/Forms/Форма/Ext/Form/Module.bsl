#Область ОбновлениеТаблицыДанных

// Функция запрашивает у пользователя подтверждение на очистку данных.
// 
// Параметры:
//  вхТекст - Строка.
// 
// Возвращаемое значение:
//  Булево - очищать.
// 
&НаКлиенте
Функция ПодтверждениеОчисткиДанных(вхТекст = "")
	
	Очищать = Истина;
	
	Если Объект.ОборотыПоБюджетам.Количество() > 0  Тогда
		Очищать = Ложь;
		Если ПустаяСтрока(вхТекст) Тогда
			ТекстВопроса = НСтр("ru='Данные будут очищены. Продолжить?';en='Data will be cleared. Continue?'");
		Иначе	
			ТекстВопроса = вхТекст;
		КонецЕсли; 
		Оповещение = Новый ОписаниеОповещения("КомандаОбновитьВопросЗавершение", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 15, КодВозвратаДиалога.Нет);
	КонецЕсли; 
	
	Возврат Очищать;
	
КонецФункции

// Процедура обработчик оповещения "КомандаОбновитьВопросЗавершение".
// 
// Параметры:
// Ответ 			    - КодВозвратаДиалога.
// ДополнительныеДанные - Структура.
// 
&НаКлиенте 
Процедура КомандаОбновитьВопросЗавершение(Ответ, ДополнительныеДанные) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда
	     // Выполнение по запросу от пользователя.
		 НачатьОтложенноеОбновлениеДанных();
	КонецЕсли; 
	
КонецПроцедуры

// Процедура выполняет преобразование полученных данных 
// (сдвиг периода, отклонение суммы и количества, распределение по профилю) 
// согласно указанных в обработке настроек.
// 
&НаСервере
Процедура ВыполнитьПреобразованиеДанных()

	ОбрОбъект = РеквизитФормыВЗначение("Объект");
	ОбрОбъект.ВыполнитьПреобразованиеДанных();
	ЗначениеВДанныеФормы(ОбрОбъект, Объект);
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьОтложенноеОбновлениеДанных(ДопДействие = Неопределено)
	
	Отказ = НЕ ПроверитьЗаполнение();
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ИзмененыНастройки = Ложь;	
	Если НЕ ЭтоПланированиеДДС Тогда	
		СкрытьНастройки();
		ОбработатьИзменениеНастроек(ЭтотОбъект);	
	КонецЕсли;
		
	Объект.ОборотыПоБюджетам.Очистить();
	Объект.ТаблицаРезультат.Очистить();
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ДопДействие", ДопДействие);
	
	ДлительнаяОперация    = НачатьОтложенноеОбновлениеДанныхНаСервере();
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ОтложенноеОбновлениеДанныхЗавершение", ЭтотОбъект, ДопПараметры);
	ПараметрыОжидания     = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция НачатьОтложенноеОбновлениеДанныхНаСервере()
			
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
		
	Режимы = Обработки.бит_ПолучениеДанныхБюджета.РежимыПолученияДанных(Объект.РежимЗаполнения);	
	Если НЕ Режимы.ЭтоПолучениеБюджета И НЕ Режимы.ЭтоПроизвольныеПараметры Тогда
				
		СхемаКомпоновки 	= ПолучитьИзВременногоХранилища(АдресСКД);	
		НастройкиКомпоновки = Компоновщик.ПолучитьНастройки();
		
		бит_ОтчетыБФКлиентСервер.УстановитьПараметр(НастройкиКомпоновки, "НачалоПериода", Объект.Период.ДатаНачала);
		бит_ОтчетыБФКлиентСервер.УстановитьПараметр(НастройкиКомпоновки, "КонецПериода",  Объект.Период.ДатаОкончания);
		Если Режимы.ЭтоГрафикДоговоров Тогда
			бит_ОтчетыБФКлиентСервер.УстановитьПараметр(НастройкиКомпоновки, "РежимВыбораСуммы", Объект.РежимВыбораСуммы);
		КонецЕсли;
	
		ВыполняемыйМетод = "Обработки.бит_ПолучениеДанныхБюджета.ПолучитьДанныеСКД";
		Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ВыполняемыйМетод, 
			СхемаКомпоновки, НастройкиКомпоновки, Объект.ЗаполнятьКомментарийКСтрокамБюджета);
		
	Иначе	
						
		ДанныеОбъекта = Новый Структура("ИсточникДанных, Период, НастройкаПулаПодключений");
		ЗаполнитьЗначенияСвойств(ДанныеОбъекта, Объект);
		
		ДанныеФормы = Новый Структура;
		ДанныеФормы.Вставить("ОтборВОтчете", 	 РеквизитФормыВЗначение("ОтборВОтчете"));
		ДанныеФормы.Вставить("ТаблицаПараметры", РеквизитФормыВЗначение("ТаблицаПараметры"));
	
		ВыполняемыйМетод    = "Обработки.бит_ПолучениеДанныхБюджета.ПолучитьДанные";
		Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ВыполняемыйМетод, 
			ДанныеОбъекта, ДанныеФормы);		
		
	КонецЕсли;
		
КонецФункции
			
&НаКлиенте
Процедура ОтложенноеОбновлениеДанныхЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка при выполнении, по причине: %1'"); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрШаблон(ТекстСообщения, Результат.КраткоеПредставлениеОшибки));
	Иначе	
		ОбновлениеДанныхЗавершениеНаСервере(Результат.АдресРезультата);
	КонецЕсли;
	
	Если ДополнительныеПараметры.ДопДействие <> Неопределено Тогда
		ОповеститьОВыбореДанных(ДополнительныеПараметры.ДопДействие);
	КонецЕсли;	
	
КонецПроцедуры 

&НаСервере
Процедура ОбновлениеДанныхЗавершениеНаСервере(АдресРезультата)
	
	ТаблицаРезультат = ПолучитьИзВременногоХранилища(АдресРезультата);		
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	Если Не ЗначениеЗаполнено(ТаблицаРезультат) Тогда		
		ТекстСообщения = НСтр("ru='Нет данных, удовлетворяющих отбору';en='No data satisfying the selection'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		
		Возврат;		
	КонецЕсли;
	
	Режимы = Обработки.бит_ПолучениеДанныхБюджета.РежимыПолученияДанных(Объект.РежимЗаполнения);
	Если Режимы.ЭтоПолучениеБюджета ИЛИ Режимы.ЭтоПроизвольныеПараметры Тогда
		Если Режимы.ЭтоПроизвольныеПараметры Тогда
			КолонкиТаблицыИсточника = ТаблицаРезультат.Колонки;
			Если КолонкиТаблицыИсточника.Найти("СуммаСценарий") = Неопределено
				И КолонкиТаблицыИсточника.Найти("Сумма") <> Неопределено Тогда
				КолонкиТаблицыИсточника.Сумма.Имя = "СуммаСценарий";
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
	Объект.ТаблицаРезультат.Загрузить(ТаблицаРезультат);
	
	Если Режимы.ЭтоПроизвольныеПараметры Тогда
		СоответствиеОграничений = Новый Соответствие;
		Для каждого КолонкаТаблицы Из ТаблицаРезультат.Колонки Цикл
			ИмяКолонки        = КолонкаТаблицы.Имя;
			ЭлементУправления = Элементы.Найти("ОборотыПоБюджетам" + ИмяКолонки);
			Если ЭлементУправления = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			СоответствиеОграничений.Вставить(ИмяКолонки, ЭлементУправления.ОграничениеТипа);
		КонецЦикла;
		Для каждого СтрокаРезультата Из Объект.ТаблицаРезультат Цикл
			Для каждого ЭлементОграничения Из СоответствиеОграничений Цикл
				СтрокаРезультата[ЭлементОграничения.Ключ] = ЭлементОграничения.Значение.ПривестиЗначение(СтрокаРезультата[ЭлементОграничения.Ключ]);
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	ВыполнитьПреобразованиеДанных();

КонецПроцедуры

#КонецОбласти

#Область ПереносОбъектовИзОбработки

// Функция формирует структуру результата.
// 
// Параметры:
//  Режим - Строка.
//  
// Возвращаемое значение:
//  Струкутура.
// 
&НаСервере
Функция СформироватьСтруктуруРезультата(Режим, ИдентификаторВладельца)

	РезСтруктура = Новый Структура;
	РезСтруктура.Вставить("Режим", 							 Режим);
	РезСтруктура.Вставить("ИспользоватьЗначенияПоУмолчанию", Объект.ИспользоватьЗначенияПоУмолчанию);
	РезСтруктура.Вставить("Валюта", 					     Объект.ВалютаОбработки);
	РезСтруктура.Вставить("Курс", 							 Объект.КурсОбработки);
	РезСтруктура.Вставить("Кратность", 						 Объект.КратностьОбработки);
	
	Если ЭтоПланированиеДДС Тогда
		ТаблицаБюджета = Объект.ОборотыПоБюджетам.Выгрузить();
	Иначе	
		Отбор          = Новый Структура("Выполнять", Истина);
		ТаблицаБюджета = Объект.ОборотыПоБюджетам.Выгрузить(Отбор);
	КонецЕсли;
	
	РезСтруктура.Вставить("КоличествоСтрок", ТаблицаБюджета.Количество());
	
	АдресОборотовПоБюджетамВХранилище = ПоместитьВоВременноеХранилище(ТаблицаБюджета, ИдентификаторВладельца);
	РезСтруктура.Вставить("АдресОборотовПоБюджетам", АдресОборотовПоБюджетамВХранилище);
	
	Возврат РезСтруктура;
	
КонецФункции

// Процедура опововещает форму-владельца о выборе данных.
// 
// Параметры:
//  Режим - Строка.
// 
&НаКлиенте
Процедура ОповеститьОВыбореДанных(Режим)

	РезСтруктура = СформироватьСтруктуруРезультата(Режим, ВладелецФормы.УникальныйИдентификатор);
	
	Если РезСтруктура.КоличествоСтрок > 0 Тогда
		Оповестить("ПолучениеДанныхБюджета", РезСтруктура, ВладелецФормы.УникальныйИдентификатор);
	Иначе
		ТекстСообщения = НСтр("ru='Не выбраны строки для переноса в документ.';
							  |en='Line to be transfered to the document are not selected.'");
		ПоказатьПредупреждение(, ТекстСообщения,, НСтр("ru='Перенос в документ';en='Transfer to paper'"));
	КонецЕсли; 

КонецПроцедуры

#КонецОбласти

#КонецОбласти
