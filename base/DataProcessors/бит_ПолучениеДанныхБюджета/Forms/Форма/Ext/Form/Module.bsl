// Функция формирует заголовок суммовой колонки с учетом единицы измерения сумм и валюты.
// 
// Параметры:
//   НазваниеКолонки - Строка.
//   ЕдиницаИзмерения - ПеречислениеСсылка.бит_ЕдиницыИзмеренияСумм.
//   Валюта - СправочникСсылка.Валюты.
// 
// Возвращаемое значение:
//  СтрЗаголовок - Строка.
// 
&НаСервере
Функция ЗаголовокКолонкиСумм(НазваниеКолонки, ЕдиницаИзмерения, Валюта)
	
	ШаблонЗаголовка = "%1 ( %2 %3 )";
	Если ЕдиницаИзмерения = Перечисления.бит_ЕдиницыИзмеренияСумм.Тысячи Тогда
		СтрЕдиница = НСтр("ru='тыс.';en='thousand'");
	ИначеЕсли ЕдиницаИзмерения = Перечисления.бит_ЕдиницыИзмеренияСумм.Миллионы Тогда
		СтрЕдиница = НСтр("ru='млн.';en='mln.'");
	Иначе	
		СтрЕдиница = "";
	КонецЕсли; 
	СтрЗаголовок = СтрШаблон(ШаблонЗаголовка, НазваниеКолонки, СтрЕдиница, Валюта);
	Возврат СтрЗаголовок;
	
КонецФункции

// Процедура управляет видимостью/доступностью элементов формы.
// 
&НаСервере
Процедура УстановитьВидимость()
	
	Элементы.ГруппаОтбор.Видимость                         = Режимы.ЭтоПолучениеБюджета ИЛИ Режимы.ЭтоПроизвольныеПараметры;
	Элементы.ГруппаПараметры.Видимость                     = Режимы.ЭтоПолучениеБюджета ИЛИ Режимы.ЭтоПроизвольныеПараметры;
	Элементы.ИсточникДанных.Видимость                      = Режимы.ЭтоПолучениеБюджета ИЛИ Режимы.ЭтоПроизвольныеПараметры;
	Элементы.НастройкаПулаПодключений.Видимость            = Режимы.ЭтоПолучениеБюджета ИЛИ Режимы.ЭтоПроизвольныеПараметры;
	Элементы.ГруппаНастройкиОтборКомпоновщика.Видимость    = НЕ Режимы.ЭтоПолучениеБюджета И НЕ Режимы.ЭтоПроизвольныеПараметры;
	Элементы.ЗаполнятьКомментарийКСтрокамБюджета.Видимость = Режимы.ЭтоКопированиеБюджета;
	
	Если Режимы.ЭтоПланированиеДДС Тогда
		Элементы.РазделыОбработки.ТекущаяСтраница = Элементы.СтраницаНастройки;
	КонецЕсли;	
	Элементы.РежимСообщений.Видимость				   = НЕ Режимы.ЭтоПланированиеДДС;
	Элементы.ВидОтклонения.Видимость				   = НЕ Режимы.ЭтоПланированиеДДС;
	Элементы.ЗначениеОтклонения.Видимость			   = НЕ Режимы.ЭтоПланированиеДДС;
	Элементы.ВидОтклоненияКоличества.Видимость		   = НЕ (Режимы.ЭтоПланированиеДДС ИЛИ Режимы.ЭтоПроизвольныеПараметры);
	Элементы.ЗначениеОтклоненияКоличества.Видимость	   = НЕ (Режимы.ЭтоПланированиеДДС ИЛИ Режимы.ЭтоПроизвольныеПараметры);
	Элементы.ПериодичностьСдвигаДат.Видимость		   = НЕ (Режимы.ЭтоПланированиеДДС ИЛИ Режимы.ЭтоПроизвольныеПараметры);
	Элементы.СдвигДат.Видимость						   = НЕ (Режимы.ЭтоПланированиеДДС ИЛИ Режимы.ЭтоПроизвольныеПараметры);
	Элементы.Профиль.Видимость						   = НЕ (Режимы.ЭтоПланированиеДДС ИЛИ Режимы.ЭтоПроизвольныеПараметры);
	Элементы.ИспользоватьЗначенияПоУмолчанию.Видимость = НЕ (Режимы.ЭтоПланированиеДДС ИЛИ Режимы.ЭтоПроизвольныеПараметры);
	Элементы.ГруппаДанные.Видимость					   = НЕ Режимы.ЭтоПланированиеДДС;
	Элементы.ЗакрытьНастройки.Видимость  			   = НЕ Режимы.ЭтоПланированиеДДС;
	Элементы.ФормаГруппаОбновитьПеренести.Видимость	   = Режимы.ЭтоПланированиеДДС;
	Элементы.ПрименитьНастройки.Видимость	   		   = НЕ Режимы.ЭтоПланированиеДДС;
	Элементы.РежимВыбораСуммы.Видимость				   = Режимы.ЭтоГрафикДоговоров;
	
	Элементы.ЗначениеОтклонения.Доступность           = ЗначениеЗаполнено(Объект.ВидОтклонения);
	Элементы.ЗначениеОтклоненияКоличества.Доступность = ЗначениеЗаполнено(Объект.ВидОтклоненияКоличества);
	
	Элементы.ОборотыПоБюджетамСуммаСценарийДляЗаполнения.Заголовок = ЗаголовокКолонкиСумм(
		НСтр("ru='Сумма';en='Amount'"), Объект.ЕдиницаИзмеренияСуммОбработки, Объект.ВалютаОбработки);
																							  
	Элементы.ОборотыПоБюджетамСуммаСценарийВВалютеДокумента.Заголовок = ЗаголовокКолонкиСумм(
		НСтр("ru='Сумма документа';en='Document total amount'"), Объект.ЕдиницаИзмеренияСуммДокумента,
		Объект.ВалютаДокумента);	
																								 
	ЭтоРаспределение = ЗначениеЗаполнено(Объект.Профиль);
	Элементы.ОборотыПоБюджетамПроцентРаспределения.Видимость = ЭтоРаспределение;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗаголовокФормы(Заголовок, Режимы, ТекущаяНастройка)
	
	Если Режимы.ЭтоКопированиеБюджета Тогда
		СтрЗаголовок = НСтр("ru='Копирование данных бюджета';en='Budget Data Copying'");
	ИначеЕсли Режимы.ЭтоГрафикДоговоров Тогда	
		СтрЗаголовок = НСтр("ru='Копирование данных графиков договоров';en='Copy of Contract Schedule Data'");
	ИначеЕсли Режимы.ЭтоПроизвольныеПараметры Тогда
		СтрЗаголовок = НСтр("ru='Заполнение значений произвольного параметра';en='Заполнение значений произвольного параметра'");
	Иначе	
		СтрЗаголовок = НСтр("ru='Получение данных бюджета';en='Budget Data Reception'");
	КонецЕсли; 

	Если ЗначениеЗаполнено(ТекущаяНастройка) Тогда
		СтрЗаголовок = СтрЗаголовок + "(%1)";
		СтрЗаголовок = СтрШаблон(СтрЗаголовок, ТекущаяНастройка);
	КонецЕсли; 
		
	Заголовок = СтрЗаголовок;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьКолонкиПроизовльногоПараметра(ПроизвольныйПараметр)
	
	ИзбыточныеЭлементы = Новый Массив;
	ИзбыточныеЭлементы.Добавить(Элементы.ОборотыПоБюджетамПериод);
	ИзбыточныеЭлементы.Добавить(Элементы.ОборотыПоБюджетамПериодДляЗаполнения);
	ИзбыточныеЭлементы.Добавить(Элементы.ОборотыПоБюджетамСценарий);
	ИзбыточныеЭлементы.Добавить(Элементы.ОборотыПоБюджетамЦФО);
	ИзбыточныеЭлементы.Добавить(Элементы.ОборотыПоБюджетамСтатьяОборотов);
	ИзбыточныеЭлементы.Добавить(Элементы.ОборотыПоБюджетамАналитика_5);
	ИзбыточныеЭлементы.Добавить(Элементы.ОборотыПоБюджетамАналитика_6);
	ИзбыточныеЭлементы.Добавить(Элементы.ОборотыПоБюджетамАналитика_7);
	Если бит_ОбщегоНазначенияПовтИсп.ЭтоСемействоБП() Тогда
		ИзбыточныеЭлементы.Добавить(Элементы["ОборотыПоБюджетамКонтрагент"]);
		ИзбыточныеЭлементы.Добавить(Элементы["ОборотыПоБюджетамДоговорКонтрагента"]);
		ИзбыточныеЭлементы.Добавить(Элементы["ОборотыПоБюджетамПроект"]);
		ИзбыточныеЭлементы.Добавить(Элементы["ОборотыПоБюджетамНоменклатурнаяГруппа"]);
		ИзбыточныеЭлементы.Добавить(Элементы["ОборотыПоБюджетамБанковскийСчет"]);
	ИначеЕсли бит_ОбщегоНазначенияПовтИсп.ЭтоСемействоERP() Тогда
		ИзбыточныеЭлементы.Добавить(Элементы["ОборотыПоБюджетамАналитика_8"]);
		ИзбыточныеЭлементы.Добавить(Элементы["ОборотыПоБюджетамАналитика_9"]);
		ИзбыточныеЭлементы.Добавить(Элементы["ОборотыПоБюджетамАналитика_10"]);
		ИзбыточныеЭлементы.Добавить(Элементы["ОборотыПоБюджетамАналитика_11"]);
		ИзбыточныеЭлементы.Добавить(Элементы["ОборотыПоБюджетамАналитика_12"]);
	КонецЕсли;
	ИзбыточныеЭлементы.Добавить(Элементы.ОборотыПоБюджетамКоличество);
	ИзбыточныеЭлементы.Добавить(Элементы.ОборотыПоБюджетамКоличествоДляЗаполнения);
	
	ИзбыточныеЭлементы.Добавить(Элементы.ОборотыПоБюджетамПеренестиИОбновитьРесурсы);
	
	Для каждого ЭлементМассива Из ИзбыточныеЭлементы Цикл
		ЭлементМассива.Видимость = Ложь;
	КонецЦикла;
	
	ЭлементыКолонокАналитики = Новый Массив;
	ЭлементыКолонокАналитики.Добавить(Элементы.ОборотыПоБюджетамАналитика_1);
	ЭлементыКолонокАналитики.Добавить(Элементы.ОборотыПоБюджетамАналитика_2);
	ЭлементыКолонокАналитики.Добавить(Элементы.ОборотыПоБюджетамАналитика_3);
	ЭлементыКолонокАналитики.Добавить(Элементы.ОборотыПоБюджетамАналитика_4);
	
	ВсегоАналитикДокумента = ЭлементыКолонокАналитики.Количество();
	ВыборкаАналитик        = Документы.бит_УстановкаЗначенийПроизвольныхПараметров.АтрибутыПроизвольногоПараметра(ПроизвольныйПараметр, ВсегоАналитикДокумента);
	КоличествоАналитик     = ВыборкаАналитик.Количество();
	Пока ВыборкаАналитик.Следующий() Цикл
		
		ЭлементКолонкаАналитики = ЭлементыКолонокАналитики.Получить(ВыборкаАналитик.НомерСтроки - 1);
		
		НаименованиеЭлементаАналитики = ЭлементКолонкаАналитики.Имя;
		ЗаголовокЭлемента = СтрЗаменить(НаименованиеЭлементаАналитики, "ОборотыПоБюджетам", "");
		ЗаголовокЭлемента = СтрШаблон("%1 (%2)", ЗаголовокЭлемента, ВыборкаАналитик.НаименованиеАналитики);
		
		ЭлементКолонкаАналитики.Видимость       = Истина;
		ЭлементКолонкаАналитики.Заголовок       = ЗаголовокЭлемента;
		ЭлементКолонкаАналитики.ВыбиратьТип     = Ложь;
		ЭлементКолонкаАналитики.ОграничениеТипа = ВыборкаАналитик.ТипЗначенияАналитики;
	КонецЦикла;
	
	Если КоличествоАналитик < ВсегоАналитикДокумента Тогда
		Для Сч = (КоличествоАналитик + 1) По ВсегоАналитикДокумента Цикл
			ЭлементКолонкаАналитики = ЭлементыКолонокАналитики.Получить(Сч - 1);
			ЭлементКолонкаАналитики.Видимость = Ложь;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСНастройками

&НаКлиентеНаСервереБезКонтекста
Процедура ОбработатьИзменениеНастроек(Форма)

	Форма.Элементы.ДекорацияИзмененыНастройки.Видимость = Форма.ИзмененыНастройки;
	Форма.Элементы.ОборотыПоБюджетам.Доступность 		= НЕ Форма.ИзмененыНастройки;
				
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНастройки()

	Элементы.РазделыОбработки.ТекущаяСтраница	  = Элементы.СтраницаНастройки;
	Элементы.ПрименитьНастройки.КнопкаПоУмолчанию = Истина;	

КонецПроцедуры

&НаКлиенте
Процедура СкрытьНастройки()

	Элементы.РазделыОбработки.ТекущаяСтраница = Элементы.СтраницаОбработка;
	Элементы.ОбновитьДанные.КнопкаПоУмолчанию = Истина;

	Если ИзмененыНастройки Тогда
		ОбработатьИзменениеНастроек(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

