&НаСервере
Процедура УстановитьСостояниеДокумента(ТекущаяСтрока)

	ДанныеСтроки = Объект.Документы.НайтиПоИдентификатору(ТекущаяСтрока);
	
	// Определение индекса картинки выполняется как в запросе:
	//
	// ВЫБОР
	//	КОГДА ISNULL(Документы.РучнаяКорректировка, ЛОЖЬ) = ИСТИНА
	//		ТОГДА ВЫБОР
	//				КОГДА Документы.ПометкаУдаления = ИСТИНА
	//					ТОГДА 10
	//				КОГДА ISNULL(Документы.Проведен, ЛОЖЬ) = ЛОЖЬ
	//					ТОГДА 9
	//				ИНАЧЕ 8
	//			КОНЕЦ
	//	ИНАЧЕ ВЫБОР
	//			КОГДА Документы.ПометкаУдаления = ИСТИНА
	//				ТОГДА 2
	//			КОГДА ISNULL(Документы.Проведен, ЛОЖЬ) = ИСТИНА
	//				ТОГДА 1
	//			ИНАЧЕ 0
	//		КОНЕЦ
	// КОНЕЦ КАК СостояниеДокумента.
	
	ИменаСвойств = Новый Массив; 
	ИменаСвойств.Добавить("ПометкаУдаления");
	
	МетаДокумент = ДанныеСтроки.Документ.Метаданные();
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("РучнаяКорректировка", МетаДокумент) Тогда
		ИменаСвойств.Добавить("РучнаяКорректировка");
	КонецЕсли;
	
	Если МетаДокумент.Проведение = Метаданные.СвойстваОбъектов.Проведение.Разрешить Тогда
		ИменаСвойств.Добавить("Проведен");
	КонецЕсли;
	
	ЗначенияСвойств = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеСтроки.Документ, ИменаСвойств);
	
	РеквизитыДокумента = Новый Структура; 
	РеквизитыДокумента.Вставить("ПометкаУдаления", Ложь);
	РеквизитыДокумента.Вставить("РучнаяКорректировка", Ложь);
	РеквизитыДокумента.Вставить("Проведен", Ложь);
	
	ЗаполнитьЗначенияСвойств(РеквизитыДокумента, ЗначенияСвойств);

	Если РеквизитыДокумента.РучнаяКорректировка Тогда
		Если РеквизитыДокумента.ПометкаУдаления Тогда
			СостояниеДокумента = 10;
		ИначеЕсли РеквизитыДокумента.Проведен Тогда 
			СостояниеДокумента = 9;	
		Иначе	
			СостояниеДокумента = 8;
		КонецЕсли;
	Иначе	
		Если РеквизитыДокумента.ПометкаУдаления Тогда
			СостояниеДокумента = 2;
		ИначеЕсли РеквизитыДокумента.Проведен Тогда 
			СостояниеДокумента = 1;	
		Иначе	
			СостояниеДокумента = 0;
		КонецЕсли;
	КонецЕсли;
	ДанныеСтроки.СостояниеДокумента = СостояниеДокумента; 
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьПоСпискуДокументов()
			
	ДокументыДляОбработки.ЗагрузитьЗначения(Параметры.ДокументыДляОбработки);
	
	ДобавленныеМетаданные = Новый Соответствие;
	
	Индекс = ДокументыДляОбработки.Количество() - 1;
	Пока Индекс >= 0 Цикл
		ЭлементСписка		 = ДокументыДляОбработки.Получить(Индекс);
		ДокументДляОбработки = ЭлементСписка.Значение;
		Если НЕ ЗначениеЗаполнено(ДокументДляОбработки) Тогда
			ДокументыДляОбработки.Удалить(ЭлементСписка);
		Иначе	
			МетаданныеДокумента = ДокументДляОбработки.Метаданные();
			Если ДобавленныеМетаданные.Получить(МетаданныеДокумента) = Неопределено Тогда
				ДобавленныеМетаданные.Вставить(МетаданныеДокумента, Истина);
				СписокТиповОбъектов.Добавить(МетаданныеДокумента.Имя, МетаданныеДокумента.Представление(), Истина);			
			КонецЕсли;
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
				
	Если ЗначениеЗаполнено(Параметры.ИсточникиТрансляции)
		И ТипЗнч(Параметры.ИсточникиТрансляции) = Тип("Массив") Тогда			
		Для каждого Элемент Из Параметры.ИсточникиТрансляции Цикл
			ИсточникиТрансляции.Добавить(Элемент,, Истина);	
		КонецЦикла;
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Параметры.ПриемникиТрансляции)
		И ТипЗнч(Параметры.ПриемникиТрансляции) = Тип("Массив") Тогда			
		Для каждого Элемент Из Параметры.ПриемникиТрансляции Цикл
			ПриемникиТрансляции.Добавить(Элемент,, Истина);	
		КонецЦикла;
	КонецЕсли; 

КонецПроцедуры

