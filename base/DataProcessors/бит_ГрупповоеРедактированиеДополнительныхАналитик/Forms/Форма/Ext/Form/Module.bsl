&НаКлиенте
Процедура ДтКт(Команда)
	
	ТекущиеДанные = Элементы.Документы.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Если СтребуетсяСтандартнаяФормаДтКт(ТекущиеДанные.Документ) Тогда
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ДокументДвижений", ТекущиеДанные.Документ);
		ОткрытьФорму("Обработка.КорректировкаДвижений.Форма", ПараметрыФормы, ЭтотОбъект, ТекущиеДанные.Документ);
	Иначе	
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ДокументСсылка"	   , ТекущиеДанные.Документ);
		ПараметрыФормы.Вставить("ОткрытиеИзФормыСписка", Истина);
		ОткрытьФорму("Обработка.бит_РезультатПроведения.Форма", ПараметрыФормы, ЭтотОбъект, ТекущиеДанные.Документ);
	КонецЕсли;
				
КонецПроцедуры

