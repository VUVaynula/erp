		ТекстСообщения = НСтр("ru='Обновите таблицу документов.';en='Update the spreadsheet documents.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения); 
	КонецЕсли;
	
КонецПроцедуры // ВосстановитьНастройкиОкончание()

#КонецОбласти  

