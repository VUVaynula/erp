#Область ОбновлениеСпискаДокументов
	
&НаКлиенте
Процедура НачатьОтложенноеОбновлениеСпискаДокументов()

	// Проверка наличия выбранных типов документов.
	ЕстьВыбранныеТипы = Ложь;
	Для каждого ЭлементСписка Из СписокТиповОбъектов Цикл
		Если ЭлементСписка.Пометка Тогда
		 	ЕстьВыбранныеТипы = Истина;
			Прервать;		
		КонецЕсли;
	КонецЦикла;	
	
	Если НЕ ЕстьВыбранныеТипы Тогда
		Оповещение = Новый ОписаниеОповещения("ОбновитьТаблицуДокументовНетВидовДокументов", ЭтотОбъект);  
		ПоказатьПредупреждение(Оповещение, НСтр("ru='Заполните типы документов.';en='Fill out the types of documents.'"));
		Возврат;
	КонецЕсли;	
	
	// Интерфейсное решение для сохранения текущей строки списка. 
	ТекущиеДанные		   = Элементы.Документы.ТекущиеДанные;
	НастрокиАктивнойСтроки = Новый Структура("Ссылка, Искать", Неопределено, Ложь);

	Если ТекущиеДанные <> Неопределено Тогда
		НастрокиАктивнойСтроки.Ссылка = ТекущиеДанные.Документ;
		НастрокиАктивнойСтроки.Искать = Истина;
	КонецЕсли;
	
	ДлительнаяОперация	  = НачатьОтложенноеОбновлениеСпискаДокументовНаСервере();
	ПараметрыОжидания     = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ОтложенноеОбновлениеСпискаДокументовЗавершение", 
								ЭтотОбъект, НастрокиАктивнойСтроки);
								
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция НачатьОтложенноеОбновлениеСпискаДокументовНаСервере()

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ВыполняемыйМетод    = "Обработки.бит_ГрупповоеРедактированиеДополнительныхАналитик.СписокВыбранныхДокументов";
	ПараметрыОбновления = ПараметрыОбновленияСпискаДокументов();
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ВыполняемыйМетод, 
				ПараметрыОбновления.ДанныеФормы, ПараметрыОбновления.ДанныеОбъекта);

КонецФункции

&НаСервере
Функция ПараметрыОбновленияСпискаДокументов()
	
	СхемаКомпоновкиДанных = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновкиДанных);
	СхемаКомпоновкиДанных = ОбщегоНазначения.ЗначениеВСтрокуXML(СхемаКомпоновкиДанных);
	Настройки			  = ОбщегоНазначения.ЗначениеВСтрокуXML(Объект.Компоновщик.ПолучитьНастройки());
	
	ДанныеФормы = Новый Структура;
	ДанныеФормы.Вставить("СхемаКомпоновки", Новый ХранилищеЗначения(СхемаКомпоновкиДанных, Новый СжатиеДанных(9)));
	
	ДанныеОбъекта = Новый Структура;
	ДанныеОбъекта.Вставить("Период", Объект.Период);
	ДанныеОбъекта.Вставить("Настройки", Новый ХранилищеЗначения(Настройки, Новый СжатиеДанных(9)));
	
	ПараметрыОбновления = Новый Структура;
	ПараметрыОбновления.Вставить("ДанныеФормы",   ДанныеФормы);
	ПараметрыОбновления.Вставить("ДанныеОбъекта", ДанныеОбъекта);
	
	Возврат ПараметрыОбновления;
	
КонецФункции

// Обработчик завершения длительной операции НачатьОтложенноеОбновлениеСпискаДокументов.
//  См. Синтакс-помощник: Новый ОписаниеОповещения().
//
&НаКлиенте
Процедура ОтложенноеОбновлениеСпискаДокументовЗавершение(Результат, Дополнительно) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка при выполнении, по причине: %1'"); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрШаблон(ТекстСообщения, Результат.КраткоеПредставлениеОшибки));
	Иначе	
		ОтложенноеОбновлениеСпискаДокументовЗавершениеНаСервере(Результат.АдресРезультата, Дополнительно);
		
		Если Объект.Документы.Количество() = 0 Тогда
			ТекстСообщения = НСтр("ru='Нет данных, удовлетворяющих отбору.';en='No data satisfying the selection.'");
			ПоказатьПредупреждение(, ТекстСообщения);
		КонецЕсли; 

		// Активизируем страницу со списком.
		Если Элементы.ПанельОсновная.ТекущаяСтраница <> Элементы.СтраницаОбработкаДокументов 
		   И Объект.Документы.Количество() <> 0 Тогда
			Элементы.ПанельОсновная.ТекущаяСтраница = Элементы.СтраницаОбработкаДокументов;
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ОтложенноеОбновлениеСпискаДокументовЗавершениеНаСервере(АдресРезультата, Дополнительно)

	РезультатОбновления = ПолучитьИзВременногоХранилища(АдресРезультата);
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	Если ТипЗнч(РезультатОбновления) = Тип("ТаблицаЗначений") Тогда
		Объект.Документы.Загрузить(РезультатОбновления);
	КонецЕсли;
	
	Ссылка = Дополнительно.Ссылка;
	Искать = Дополнительно.Искать;
	
	// Установка текущей строки.
	КурсорУстановлен = Ложь;
	Если Искать И Объект.Документы.Количество() > 1 Тогда
		НайденныеСтроки = Объект.Документы.НайтиСтроки(Новый Структура("Документ", Ссылка));
		Если НайденныеСтроки.Количество() > 0 Тогда
			Элементы.Документы.ТекущаяСтрока = НайденныеСтроки[0].ПолучитьИдентификатор();
			КурсорУстановлен = Истина;
		КонецЕсли;	
	КонецЕсли;
	
	Если НЕ КурсорУстановлен Тогда
		Объект.Аналитики.Очистить();
		Объект.АналитикиТолькоЧтение.Очистить();
		АналитикиМодифицированы = Ложь;
	Иначе
		ОбновитьТаблицыАналитик(Ссылка);
	КонецЕсли;
	
	СписокВыбранных.Очистить();
	АналитикиНеИспользуются = Ложь;

КонецПроцедуры

// Обработчик завершения диалога предупреждение.
//  См. Синтакс-помощник: ПоказатьПредупреждение().
//
&НаКлиенте
Процедура ОбновитьТаблицуДокументовНетВидовДокументов(Результат) Экспорт
	
	Объект.Аналитики.Очистить();
	Объект.АналитикиТолькоЧтение.Очистить();
	АналитикиМодифицированы = Ложь;
	
	ТекстСообщения = НСтр("ru='Начните отсюда.';en='Start here.'");
	ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "СписокТиповОбъектов");

КонецПроцедуры

#КонецОбласти // ОбновлениеСпискаДокументов

#Область НастройкаСхемыКомпоновки

// Процедура меняет СКД по выбранным типам документов.
// 
// Параметры:
//  СКД - Схема компоновки данных.
// 
&НаСервере
Процедура ИзменитьСКДПоВыбраннымТипамДокументов(СКД)
	
	// Поля, используемые для отборов, которые требуется удалить, 
	// если таких нет в метаданных.
	РеквизитыШапки = Новый Структура; 
	РеквизитыШапки.Вставить("ВидОперации", Ложь);
	РеквизитыШапки.Вставить("СтатьяДвиженияДенежныхСредств", Ложь);
	РеквизитыШапки.Вставить("Контрагент", Ложь);
	РеквизитыШапки.Вставить("НазначениеПлатежа", Ложь);
	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		РеквизитыШапки.Вставить("Ответственный", Ложь);
		РеквизитыШапки.Вставить("ДоговорКонтрагента", Ложь);
	КонецЕсли;

	// Изменим текст запроса:
	ПодготовитьТекстЗапросаПоВыбраннымТипамДокументов(СКД.НаборыДанных.Документы.Запрос, РеквизитыШапки);	
	
	Если СписокТиповОбъектов.Количество() <> 0 Тогда
		Индекс = СКД.НастройкиПоУмолчанию.Отбор.Элементы.Количество() - 1;
		Пока Индекс >= 0  Цикл
			ЭлементОтбора = СКД.НастройкиПоУмолчанию.Отбор.Элементы.Получить(Индекс);
			Ключ = Строка(СКД.НастройкиПоУмолчанию.Отбор.Элементы.Получить(Индекс).ЛевоеЗначение);
			Если СтрНачинаетсяС(Ключ, "Документ.") Тогда
				Ключ = СтрЗаменить(Ключ, "Документ.","");
				Пометка = Ложь;
				Если РеквизитыШапки.Свойство(Ключ, Пометка) И Пометка = Ложь Тогда
					СКД.НастройкиПоУмолчанию.Отбор.Элементы.Удалить(Индекс);				
				КонецЕсли; 
			КонецЕсли; 
			Индекс = Индекс - 1;
		КонецЦикла;  
	КонецЕсли;
	
КонецПроцедуры

&НаСервере 
Процедура ПодготовитьТекстЗапросаПоВыбраннымТипамДокументов(ТекстЗапроса, РеквизитыШапки)

	Если СписокТиповОбъектов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 
	
	// Описание полей, где: 
	// Значение, Представление, Пометка - это "Имя", "Синоним", "Выбор реквизитов".
	ФиксированныеПоля = Новый СписокЗначений;
	ФиксированныеПоля.Добавить("Ссылка","Документ", Истина);
	ФиксированныеПоля.Добавить("Номер", "Номер");
	ФиксированныеПоля.Добавить("Проведен", "Проведен");
	ФиксированныеПоля.Добавить("ПометкаУдаления", "ПометкаУдаления");
	ФиксированныеПоля.Добавить("Организация", "Организация", Истина);
	ФиксированныеПоля.Добавить("ВидОперации", "ВидОперации");
	ФиксированныеПоля.Добавить("Дата", "Дата");
	ФиксированныеПоля.Добавить("СтатьяДвиженияДенежныхСредств", "СтатьяДвиженияДенежныхСредств", Истина);
	ФиксированныеПоля.Добавить("Контрагент", "Контрагент", Истина);
	ФиксированныеПоля.Добавить("СуммаДокумента", "СуммаДокумента");
	ФиксированныеПоля.Добавить("НазначениеПлатежа", "НазначениеПлатежа");
	ФиксированныеПоля.Добавить("СостояниеДокумента", "СостояниеДокумента");
	ФиксированныеПоля.Добавить("РучнаяКорректировка", "РучнаяКорректировка", Ложь);

	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		ФиксированныеПоля.Добавить("Ответственный", "Ответственный", Истина);
		ФиксированныеПоля.Добавить("ДоговорКонтрагента",  "ДоговорКонтрагента", Истина);
	КонецЕсли; 
	
	СтрокаНеограниченнойДлинны = ОбщегоНазначения.ОписаниеТипаСтрока(0); 
	СхемаЗапроса = Новый СхемаЗапроса;
	
	Запрос = СхемаЗапроса.ПакетЗапросов.Добавить(Тип("ЗапросВыбораСхемыЗапроса"));
	Запрос.ВыбиратьРазрешенные = Истина;
	Запрос.ТаблицаДляПомещения = "ТабДокументы";
	
	// Схема не поддерживает описание расширения языка запросов для СКД.
	ОтборыСКД = Новый Массив();
	ШаблонМаркераСКД		 = "&ОтборСКД%1"; // Маркер для подстановки выражения отборов СКД.
	ШаблонВыраженияОтбораСКД = "%1%2 КАК %3"; // Пример выражения: "Ссылка.* КАК Документ"
	
	Для Каждого Элемент Из СписокТиповОбъектов Цикл
		Индекс = СписокТиповОбъектов.Индекс(Элемент);
				
		Если Индекс = 0 Тогда
			Оператор = Запрос.Операторы[0];
		Иначе	
			Оператор = Запрос.Операторы.Добавить();
			Оператор.ТипОбъединения = ТипОбъединенияСхемыЗапроса.ОбъединитьВсе;
		КонецЕсли; 

		Источник = Оператор.Источники.Добавить("Документ." + Элемент.Значение);

		Оператор.Отбор.Добавить("ИСТИНА");
		Оператор.Отбор.Добавить(СтрШаблон(ШаблонМаркераСКД, Индекс));
		
		Таблица  = Источник.Источник;
		ПоляОтбораСКД = Новый Массив(); 
		Для Каждого ФиксированноеПоле Из ФиксированныеПоля Цикл
			ИндексКолонки = ФиксированныеПоля.Индекс(ФиксированноеПоле);
			ДоступноеПоле = Таблица.ДоступныеПоля.Найти(ФиксированноеПоле.Значение);
			
			Если ДоступноеПоле <> Неопределено Тогда
				Если ДоступноеПоле.ТипЗначения = СтрокаНеограниченнойДлинны Тогда
					// Обрежем поля неограниченной длины.
					Выражение = СтрШаблон("ВЫРАЗИТЬ(%1 КАК Строка (210))", ДоступноеПоле.Имя);
					Оператор.ВыбираемыеПоля.Добавить(Выражение, ИндексКолонки);
				Иначе
					Оператор.ВыбираемыеПоля.Добавить(ДоступноеПоле, ИндексКолонки);
					// Заполним выражения отборов для СКД.
					ПолеСКД = СтрШаблон(ШаблонВыраженияОтбораСКД, ФиксированноеПоле.Значение, 
								?(ФиксированноеПоле.Пометка,".*" , ""), ФиксированноеПоле.Представление);
					ПоляОтбораСКД.Добавить(ПолеСКД);
				КонецЕсли;
			Иначе	
				Оператор.ВыбираемыеПоля.Добавить("NULL", ИндексКолонки);
			КонецЕсли; 
			
			// Выявляем хотя бы одну таблицу с доступным реквизитом шапки.
			Ключ = ФиксированноеПоле.Значение;
			Если РеквизитыШапки.Свойство(Ключ) Тогда
				Если ДоступноеПоле = Неопределено Тогда
					РеквизитыШапки[Ключ] = Макс(Ложь, РеквизитыШапки[Ключ]);
				Иначе	
					РеквизитыШапки[Ключ] = Макс(Истина, РеквизитыШапки[Ключ]);
				КонецЕсли; 
			КонецЕсли; 

			Если Индекс = 0 Тогда
				Запрос.Колонки[ИндексКолонки].Псевдоним = ФиксированноеПоле.Представление;
			КонецЕсли;	
		КонецЦикла;
		
		ОтборыСКД.Добавить(ПоляОтбораСКД);
	КонецЦикла; 
	
	// Заменим "эталонный запрос".
	ИсходнаяСхема = Новый СхемаЗапроса;
	ИсходнаяСхема.УстановитьТекстЗапроса(ТекстЗапроса);
	ИсходнаяСхема.ПакетЗапросов[0].УстановитьТекстЗапроса(СхемаЗапроса.ПолучитьТекстЗапроса());
	ТекстЗапроса = ИсходнаяСхема.ПолучитьТекстЗапроса();

	// Подставляем отборы СКД.
	Индекс = ОтборыСКД.ВГраница();
	Пока Индекс > -1 Цикл
		Элемент = ОтборыСКД.Получить(Индекс);
		ТекстОтбора = Символы.ПС
					+ "{ ГДЕ (Дата >= &ДатаНачала), (Дата <= &ДатаОкончания)," + Символы.ПС
					+ СтрСоединить(Элемент,", ") + Символы.ПС
					+ "}";
					
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И " + СтрШаблон(ШаблонМаркераСКД, Индекс), ТекстОтбора);	
		
		Индекс = Индекс -1;
	КонецЦикла; 
	
КонецПроцедуры
 
// Процедура меняет СКД по выбранным типам документов.
// 
// Параметры:
//  СКД - Схема компоновки данных.
// 
&НаСервере
Процедура ИзменитьСКДПоСтатьямДДС(СКД)

	Если ИспользоватьСтатьиДДС Тогда
		Возврат;
	КонецЕсли;
		
	НаборДанныхДокументы = СКД.НаборыДанных.Документы;
	ПоляНабораДанных     = НаборДанныхДокументы.Поля;
	
	НаборДанныхДокументы.Запрос = СтрЗаменить(НаборДанныхДокументы.Запрос, "НЕОПРЕДЕЛЕНО КАК СтатьяДвиженияДенежныхСредств,", "");
	НаборДанныхДокументы.Запрос = СтрЗаменить(НаборДанныхДокументы.Запрос, "(НЕОПРЕДЕЛЕНО) КАК СтатьяДвиженияДенежныхСредств,", "");
	НаборДанныхДокументы.Запрос = СтрЗаменить(НаборДанныхДокументы.Запрос, "Документы.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,", "");
	НаборДанныхДокументы.Запрос = СтрЗаменить(НаборДанныхДокументы.Запрос, "Документы.СтатьяДвиженияДенежныхСредств,", "");
	НаборДанныхДокументы.Запрос = СтрЗаменить(НаборДанныхДокументы.Запрос, "СтатьяДвиженияДенежныхСредств,", "");
	
	ПолеСтатьяДДС = ПоляНабораДанных.Найти("СтатьяДвиженияДенежныхСредств");
	Если ПолеСтатьяДДС <> Неопределено Тогда
		ПоляНабораДанных.Удалить(ПолеСтатьяДДС);		
	КонецЕсли;
	
	ПолеКД_СтатьяДДС = Новый ПолеКомпоновкиДанных("СтатьяДвиженияДенежныхСредств");
	Для каждого ЭлВыбор Из СКД.НастройкиПоУмолчанию.Выбор.Элементы Цикл
		Если ЭлВыбор.Поле = ПолеКД_СтатьяДДС Тогда
			СКД.НастройкиПоУмолчанию.Выбор.Элементы.Удалить(ЭлВыбор);
			Прервать;			
		КонецЕсли;		
	КонецЦикла;
	
	Для каждого ЭлОтбор Из СКД.НастройкиПоУмолчанию.Отбор.Элементы Цикл
		Если ЭлОтбор.ЛевоеЗначение = ПолеКД_СтатьяДДС Тогда
			СКД.НастройкиПоУмолчанию.Отбор.Элементы.Удалить(ЭлОтбор);
			Прервать;			
		КонецЕсли;		
	КонецЦикла; 			
		
КонецПроцедуры // ИзменитьСКД_ПоСтатьямДДС()

// Процедура инициализирует схему компоновки данных.
// 
&НаСервере
Процедура ИнициализироватьСКД(СохрПользовательскиеНастройки = Неопределено)

	Если СохрПользовательскиеНастройки = Неопределено Тогда
		СохрПользовательскиеНастройки = Объект.Компоновщик.ПользовательскиеНастройки;	
	КонецЕсли;
	
	СхемаКомпоновкиДанных = Обработки.бит_ГрупповоеРедактированиеДополнительныхАналитик.ПолучитьМакет("СхемаКомпоновкиДанных");
	ИзменитьСКДПоСтатьямДДС(СхемаКомпоновкиДанных);
	ИзменитьСКДПоВидамАналитик(СхемаКомпоновкиДанных);
	ИзменитьСКДПоВыбраннымТипамДокументов(СхемаКомпоновкиДанных);
	
	АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных, Новый УникальныйИдентификатор);
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных);
	
	Попытка
		Объект.Компоновщик.Инициализировать(ИсточникНастроек);	
	Исключение 
		ТекстСообщения = НСтр("ru='Невозможно применить настройки. По причине: %1';
							  |en='It is impossible to apply the settings. Due to: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		 
	КонецПопытки;
	
	Объект.Компоновщик.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);
	Объект.Компоновщик.ЗагрузитьПользовательскиеНастройки(СохрПользовательскиеНастройки);
	Объект.Компоновщик.Восстановить();

	Если ЗначениеЗаполнено(ДокументыДляОбработки) Тогда
		бит_ОтчетыБФКлиентСервер.ДобавитьОтбор(Объект.Компоновщик.ФиксированныеНастройки, 
			"Документ", ДокументыДляОбработки, ВидСравненияКомпоновкиДанных.ВСписке);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти // НастройкаСхемыКомпоновки

#Область ЗаписьИзменений

// Процедура выполняет управляет процедурами сохранения изменений на клиенте.
// 
// Параметры:
// 	РежимВыполнения  - Строка.
//  ОбъектыДляЗаписи - Массив (По умолчанию = Неопределено).
// 
&НаКлиенте
Процедура ЗаписатьИзменения(РежимВыполнения)
	
	ОбъектыДляЗаписи = СписокВыбранных.ВыгрузитьЗначения();	
	Если НЕ ЗначениеЗаполнено(СписокВыбранных) Тогда
		ИзменитьПризнакМодифицированностиАналитик(ЭтотОбъект, Ложь);
		ТекстСообщения = НСтр("ru = 'Выберите документы для обработки.'; en = 'Select the documents to process.'");
		ПоказатьПредупреждение(, ТекстСообщения);
		Возврат;	
	КонецЕсли;
	
	Дополнительно = Новый Структура; 
	Дополнительно.Вставить("РежимВыполнения", РежимВыполнения);
	Дополнительно.Вставить("ОбъектыДляЗаписи",ОбъектыДляЗаписи);
	
	Оповещение = Новый ОписаниеОповещения("ЗаписатьИзмененияПродолжение", ЭтотОбъект, Дополнительно); 			

	ТекстВопроса = НСтр("ru='Сохранить изменения для выделенных документов?';
						    |en='Save changes to the selected document?'");
	
	Если АналитикиМодифицированы И РежимПредупреждений Тогда
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет); 							
	Иначе
		ВыполнитьОбработкуОповещения(Оповещение, КодВозвратаДиалога.Да);	
	КонецЕсли;	
		
КонецПроцедуры

// Обработчик завершения диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте 
Процедура ЗаписатьИзмененияПродолжение(Ответ, ДополнительныеДанные) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		ЗаписатьИзмененияОкончание(ДополнительныеДанные.РежимВыполнения, ДополнительныеДанные.ОбъектыДляЗаписи);	
	Иначе
		ИзменитьПризнакМодифицированностиАналитик(ЭтотОбъект, Ложь);
	КонецЕсли; 
	
	ОжиданиеАктивизацииСтроки();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИзмененияОкончание(РежимВыполнения, ОбъектыДляЗаписи)
	
	Если НЕ ЗначениеЗаполнено(СписокВыбранных) Тогда
		Возврат;
	КонецЕсли;
	
	АналитикиЗаписаны = Ложь;
	
	НачатьОтложеннуюОбработкуДокументов(РежимВыполнения);
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьОтложеннуюОбработкуДокументов(РежимВыполнения, УточнениеПараметров = Неопределено)

	Если НЕ ЗначениеЗаполнено(СписокВыбранных) Тогда
		Возврат;
	КонецЕсли;
	
	КоличествоОбщее = СписокВыбранных.Количество();
	ПараметрыЗаписи = ПараметрыЗаписиИзменений(РежимВыполнения, СписокВыбранных, КоличествоОбщее);
	
	Если ТипЗнч(УточнениеПараметров) = Тип("Структура") Тогда
		ПараметрыЗаписи.ИсточникДопАналитик    = УточнениеПараметров.ИсточникДопАналитик;
		ПараметрыЗаписи.ВыполнитьПроведениеБит = УточнениеПараметров.ВыполнитьПроведениеБит;
	КонецЕсли;
	
	ЕстьДействиеДляВыполнения = ПараметрыЗаписи.ВыполнитьПроведение 
								ИЛИ ПараметрыЗаписи.ВыполнитьТрансляцию
								ИЛИ ПараметрыЗаписи.ВыполнитьПроведениеБит
								ИЛИ ПараметрыЗаписи.ОтменитьТрансляцию
								ИЛИ ПараметрыЗаписи.РассчитатьПартииМПЗ;
								
	Если НЕ АналитикиМодифицированы И НЕ ЕстьДействиеДляВыполнения Тогда
		Возврат;
	КонецЕсли;	
	
	КлючеваяОперация = "Обработка.бит_ГрупповоеРедактированиеДополнительныхАналитик.Форма.НачатьОтложеннуюОбработкуДокументов";
					 
	ОценкаПроизводительностиКлиент.ЗамерВремени(КлючеваяОперация);
	
	ДлительнаяОперация    = НачатьОтложеннуюОбработкуДокументовНаСервере(ПараметрыЗаписи);
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ОтложеннаяОбработкаДокументовЗавершение", ЭтотОбъект);
	ПараметрыОжидания     = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);

КонецПроцедуры

&НаСервере
Функция НачатьОтложеннуюОбработкуДокументовНаСервере(ПараметрыЗаписи)
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ВыполняемыйМетод    = "Обработки.бит_ГрупповоеРедактированиеДополнительныхАналитик.ЗаписатьИзмененияОбъектов";
	ПараметрыОбработки  = ПараметрыОбработкиСпискаДокументов();
	
	// Разобьем даные на пакеты пропорционально количеству потоков.
	ОбъектыДляЗаписи = ПараметрыОбработки.ДанныеОбъекта.ОбъектыДляЗаписи;
	РазмерСпика		 = ОбъектыДляЗаписи.Количество();
	
	КоличествоПотоков = Константы.КоличествоПотоковДлительныхОпераций.Получить();
	КоличествоПотоков = Макс(1, КоличествоПотоков);
	Если КоличествоПотоков = 1 Тогда
		РазмерыПакетов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(РазмерСпика);
	Иначе	
		Коэффициенты = Новый Массив;
		Для Индекс = 1 По КоличествоПотоков Цикл
			Коэффициенты.Добавить(1);	
		КонецЦикла;
		РазмерыПакетов = ОбщегоНазначенияКлиентСервер.РаспределитьСуммуПропорциональноКоэффициентам(
							РазмерСпика, Коэффициенты, 0);
	КонецЕсли;
	
	// Удалим пакеты нулевой длины.
	Индекс = РазмерыПакетов.ВГраница();
	Пока Индекс >= 0 Цикл
		Если РазмерыПакетов.Получить(Индекс) = 0 Тогда
			РазмерыПакетов.Удалить(Индекс);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;

	Счетчик 			   = 1;
	ИндексПакета 		   = 0;
	НаборПараметровФункции = Новый Соответствие;
	
	Для каждого СтрокаТаблицы Из ОбъектыДляЗаписи Цикл
		Если Счетчик = 1 Тогда
			РазмерПорции = РазмерыПакетов[ИндексПакета];
			ПорцияДанных = ОбъектыДляЗаписи.СкопироватьКолонки();
			ИндексПакета = ИндексПакета + 1;
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(ПорцияДанных.Добавить(), СтрокаТаблицы);
				
		Если Счетчик = РазмерПорции Тогда
			Счетчик = 0;
			
			ТекущиеДанныеОбъекта = ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыОбработки.ДанныеОбъекта);
			ТекущиеДанныеОбъекта.ОбъектыДляЗаписи = ПорцияДанных;
			
			ТекущиеПараметрыФункции = Новый Массив;
			ТекущиеПараметрыФункции.Добавить(ПараметрыОбработки.ДанныеФормы);
			ТекущиеПараметрыФункции.Добавить(ТекущиеДанныеОбъекта);
			ТекущиеПараметрыФункции.Добавить(ПараметрыЗаписи);
			ТекущиеПараметрыФункции.Добавить(АналитикиМодифицированы);
			НаборПараметровФункции.Вставить(Новый УникальныйИдентификатор, ТекущиеПараметрыФункции);
		КонецЕсли;
		Счетчик	= Счетчик + 1;
	КонецЦикла;
	
	Возврат ДлительныеОперации.ВыполнитьФункциюВНесколькоПотоков(ВыполняемыйМетод, ПараметрыВыполнения, НаборПараметровФункции);
		
КонецФункции

&НаСервере
Функция ПараметрыОбработкиСпискаДокументов()

	ДанныеФормы = Новый Структура("ПриемникиТрансляции, ИсточникиТрансляции, ИспользоватьРучнуюКорректировкуФакта,"
					"ПереключательЗПА, ПереключательРФД, ТекущийОбъектСсылка, РежимСообщений, РежимЗаписиАналитик,"
					"ПротоколТрансляции, ВестиПротоколТрансляции");

	ЗаполнитьЗначенияСвойств(ДанныеФормы, ЭтотОбъект);
		
	ДанныеОбъекта = Новый Структура("ОбъектыДляЗаписи, Аналитики");
	ДанныеОбъекта.ОбъектыДляЗаписи = Объект.Документы.Выгрузить(Новый Структура("Выбрать", Истина));
	ДанныеОбъекта.Аналитики		   = Объект.Аналитики.Выгрузить();
	
	ПараметрыОбработки = Новый Структура;
	ПараметрыОбработки.Вставить("ДанныеФормы", ДанныеФормы);
	ПараметрыОбработки.Вставить("ДанныеОбъекта", ДанныеОбъекта);
	
	Возврат ПараметрыОбработки;
	
КонецФункции

&НаКлиенте
Процедура ОтложеннаяОбработкаДокументовЗавершение(Результат, Дополнительно) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка при выполнении, по причине: %1'"); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрШаблон(ТекстСообщения, Результат.КраткоеПредставлениеОшибки));
	Иначе	
		РезультатОбработки = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		 
		Для каждого Сообщение Из Результат.Сообщения Цикл
			Сообщение.Сообщить();	
		КонецЦикла;
		
		АналитикиЗаписаны = Ложь;
		ПротоколТрансляции.Очистить();
		
		Если ТипЗнч(РезультатОбработки) = Тип("Соответствие") Тогда
			Для каждого КлючЗначение Из РезультатОбработки Цикл
				ОбработатьРезультатОтложеннойОбработкиДокументов(КлючЗначение.Значение, АналитикиЗаписаны);			
			КонецЦикла;	
		КонецЕсли;
		
		Если АналитикиМодифицированы И АналитикиЗаписаны Тогда		
			ИзменитьПризнакМодифицированностиАналитик(ЭтотОбъект, Ложь);
			Оповестить("ОбъектИзмененВГрупповомРедактированииДополнительныхАналитик", , ЭтотОбъект.ВладелецФормы);
		КонецЕсли;
		
		НачатьОтложенноеОбновлениеСпискаДокументов();
	КонецЕсли; 

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРезультатОтложеннойОбработкиДокументов(Результат, АналитикиЗаписаны)
	
	Если Результат.Статус = "Ошибка" Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка при выполнении, по причине: %1'"); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрШаблон(ТекстСообщения, Результат.КраткоеПредставлениеОшибки));
	Иначе	
		РезультатОбработки = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		
		Для каждого Сообщение Из Результат.Сообщения Цикл
			Сообщение.Сообщить();	
		КонецЦикла;
		
		Если ТипЗнч(РезультатОбработки) = Тип("Структура") Тогда
			
			ДанныеОбработаны = РезультатОбработки.АналитикиЗаписаны;
			НовыйПротокол	 = РезультатОбработки.ПротоколТрансляции;
			Сообщения 		 = РезультатОбработки.Сообщения;
			
			Если ДанныеОбработаны Тогда
				АналитикиЗаписаны = Истина;			
			КонецЕсли;
			
			ТекстПротокола = НовыйПротокол.ПолучитьТекст();
			Если ЗначениеЗаполнено(ТекстПротокола) Тогда
				ПротоколТрансляции.ДобавитьСтроку(ТекстПротокола);			
			КонецЕсли;
			
			Для каждого Сообщение Из Сообщения Цикл
				Сообщение.Сообщить();	
			КонецЦикла;
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

