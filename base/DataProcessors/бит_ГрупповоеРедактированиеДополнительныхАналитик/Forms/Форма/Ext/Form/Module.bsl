	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДокументыДата");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДокументыНомер");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДокументыОрганизация");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДокументыКонтрагент");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДокументыДоговорКонтрагента");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДокументыСтатьяДвиженияДенежныхСредств");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДокументыВидОперации");

	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Объект.Документы.Выбрать", ВидСравненияКомпоновкиДанных.Равно, Истина);
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.бит_ЦветГиперссылки);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Шрифт", ШрифтыСтиля.бит_ОсновнойЭлементСписка);
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Аналитики");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Объект.Аналитики.Изменено", ВидСравненияКомпоновкиДанных.Равно, Истина);
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Шрифт", ШрифтыСтиля.бит_ОсновнойЭлементСписка);
	
КонецПроцедуры
 
&НаКлиенте
Процедура ПоказатьНастройки()
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("РежимСообщений", 	   РежимСообщений);
	ПараметрыФормы.Вставить("РежимПредупреждений", РежимПредупреждений);
	ПараметрыФормы.Вставить("РежимЗаписи", 		   РежимЗаписи);
	ПараметрыФормы.Вставить("ИсточникиТрансляции", ИсточникиТрансляции);
	ПараметрыФормы.Вставить("ПриемникиТрансляции", ПриемникиТрансляции);

	ПараметрыФормы.Вставить("ВестиПротоколТрансляции", 			  ВестиПротоколТрансляции);
	ПараметрыФормы.Вставить("ОтображатьПунктРассчитатьПартииМПЗ", ОтображатьПунктРассчитатьПартииМПЗ);
	
	Оповещение = Новый ОписаниеОповещения("ПоказатьНастройкиОкончание", ЭтотОбъект); 
	ОткрытьФорму("Обработка.бит_ГрупповоеРедактированиеДополнительныхАналитик.Форма.ФормаНастройки", ПараметрыФормы, 
		ЭтотОбъект,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

// Обработчик завершения открытия формы.
//  См. Синтакс-помощник: ОткрытьФорму().
// 
&НаКлиенте 
Процедура ПоказатьНастройкиОкончание(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Результат);
		ЗаполнитьЗначенияСвойств(Объект, Результат);
	КонецЕсли;  
	
	ИзменитьЗаголовокКнопкиЗаписи();
	УстановитьВидимостьДоступностьЭлементовПодсистемыТрансляции();
    	
КонецПроцедуры

// Процедура открывает форму подбора типов документов //внутри модальный вызов.
// 
// Параметры:
//  Очищать - Булево
// 
&НаКлиенте
Процедура ИзменитьСписокТиповДокументов(Очищать)
	
	ДополнительныеПараметры = Новый Структура("Очищать", Очищать);
	Оповещение 				= Новый ОписаниеОповещения("ИзменитьСписокТиповДокументовОкончание", 
										ЭтотОбъект, ДополнительныеПараметры); 
	СохраненныеНастройки = Новый Структура;
	СохраненныеНастройки.Вставить("СписокТиповОбъектов",СписокТиповОбъектов);
	СохраненныеНастройки.Вставить("НастройкиОтбора",	НастройкиПодбораТиповДокументов);
	
	ПараметрыФормы = Новый Структура; 
	ПараметрыФормы.Вставить("АдресВХранилище", ПоместитьВоВременноеХранилище(СохраненныеНастройки, УникальныйИдентификатор));
	
	ОткрытьФорму("Обработка.бит_ГрупповоеРедактированиеДополнительныхАналитик.Форма.ПодборОбъектов",
		ПараметрыФормы,,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры // ИзменитьСписокТиповДокументов()

// Процедура окончание процедуры "ИзменитьСписокТиповДокументов".
// 
&НаКлиенте 
Процедура ИзменитьСписокТиповДокументовОкончание(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) <> Тип("Строка") И НЕ ЭтоАдресВременногоХранилища(Результат) Тогда
		Возврат;	
	КонецЕсли;   	 
	
	Если ДополнительныеПараметры.Очищать = Истина Тогда
		СписокТиповОбъектов.Очистить();	
	КонецЕсли;
	
	СохраненныеНастройки = ПолучитьИзВременногоХранилища(Результат);
	
	Для каждого ЭлементСписка Из СохраненныеНастройки.СписокТиповОбъектов Цикл
		Если СписокТиповОбъектов.НайтиПоЗначению(ЭлементСписка.Значение) = Неопределено Тогда
		 	СписокТиповОбъектов.Добавить(ЭлементСписка.Значение, ЭлементСписка.Представление, ЭлементСписка.Пометка);		
		КонецЕсли;                                                                           			
	КонецЦикла;
	СписокТиповОбъектов.СортироватьПоПредставлению();
	
	НастройкиПодбораТиповДокументов = СохраненныеНастройки.НастройкиПодбораТиповДокументов; 

	// Инициализация СКД
	ИнициализироватьСКД();
	УправлениеЭлементамиФормы(ЭтотОбъект);
	
КонецПроцедуры // ИзменитьСписокТиповДокументовОкончание()

// Процедура-обработчик ожидания активизации строки.
// 
&НаКлиенте
Процедура ОжиданиеАктивизацииСтроки()
	
	ТекущиеДанные = Элементы.Документы.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ТекущийОбъектСсылка = ТекущиеДанные.Документ;
	
	ОбновитьТаблицыАналитик(ТекущийОбъектСсылка);
	УстановитьТекущуюСтраницуПанелиДополнительныхАналитик(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииСпискаВыбранных()
	                             	
	Если НЕ ЗначениеЗаполнено(СписокВыбранных) Тогда
		АналитикиНеИспользуются   = Ложь;
		ПереключательЗПА		  = 0;
		Объект.Аналитики.Очистить();
		ИзменитьПризнакМодифицированностиАналитик(ЭтотОбъект, Ложь);
	КонецЕсли;
	
	УстановитьТекущуюСтраницуПанелиДополнительныхАналитик(ЭтотОбъект);
	
КонецПроцедуры
 
&НаСервереБезКонтекста
Процедура ЗарегистрироватьОшибку(ТекстОшибки)

	ТекстСообщения = НСтр("ru='Обработка.Групповая трансляция и редактирование дополнительных аналитик';
						  |en='Obrabotka.Gruppovaya translation and editing additional analyst'");
	ЗаписьЖурналаРегистрации(ТекстСообщения, УровеньЖурналаРегистрации.Ошибка,,, ТекстОшибки);

КонецПроцедуры // Зарегистрировать()
 
&НаКлиенте
Процедура ЗаполнитьДополнительныеАналитики(ИмяКоманды)
        
	Если НЕ ЗначениеЗаполнено(Объект.Документы) И НЕ ЗначениеЗаполнено(СписокВыбранных) Тогда
		Возврат;	
	КонецЕсли;
			
	Дополнительно = Новый Структура;
	Дополнительно.Вставить("ИмяКоманды",  ИмяКоманды);
	Дополнительно.Вставить("ДляСписка",	  Истина);
	Оповещение = Новый ОписаниеОповещения("ЗаполнитьДополнительныеАналитикиЗавершение", ЭтотОбъект, Дополнительно);

	Если РежимПредупреждений Тогда
		
		ТекстСообщения = НСтр("ru='Для выделенных документов аналитик будут полученны из шапки. Новые значения будут записаны';
							  |en='For the selected document analytics will be recorded'"); 
		Если РежимЗаписи = "ПроведениеДокумента" Тогда
			ТекстСообщения = ТекстСообщения + " " + НСтр("ru='и выполнено проведение.';en='and performed conduct.'"); 
		ИначеЕсли РежимЗаписи = "Трансляция" Тогда
			ТекстСообщения = ТекстСообщения + " " + НСтр("ru='и выполнена трансляция.';en='Broadcast and executed.'");
		ИначеЕсли РежимЗаписи = "ПроводитьПоРегистрамБИТ" Тогда
			ТекстСообщения = ТекстСообщения + " " + НСтр("ru='и выполнено проведение по регистрам БИТ.';
														 |en='and performed on the holding register bit.'");
		КонецЕсли;

		ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет); 
	Иначе
		ВыполнитьОбработкуОповещения(Оповещение, КодВозвратаДиалога.Да);
	КонецЕсли;	

КонецПроцедуры

// Обработчик завершения диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте 
Процедура ЗаполнитьДополнительныеАналитикиЗавершение(Ответ, ДополнительныеДанные) Экспорт
	
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;	
	КонецЕсли; 
	
	АналитикиМодифицированы = Истина;
	
	УточнениеПараметров = Новый Структура("ИсточникДопАналитик, ВыполнитьПроведениеБит", 0, Истина);
	Если ДополнительныеДанные.ИмяКоманды = "ЗаполнитьПоУмолчанию" Тогда
		УточнениеПараметров.ИсточникДопАналитик = 1;
	ИначеЕсли ДополнительныеДанные.ИмяКоманды = "ОбновитьПоУмолчанию" Тогда	
		УточнениеПараметров.ИсточникДопАналитик = 2;
	КонецЕсли;
	НачатьОтложеннуюОбработкуДокументов(РежимЗаписи, УточнениеПараметров);
	
КонецПроцедуры

// Процедура меняет заголовок кнопки записи в соответствием со значением режима записи.
// 
&НаКлиенте
Процедура ИзменитьЗаголовокКнопкиЗаписи()

	НовыйЗаголовок = НСтр("ru='Записать аналитики';en='Save Dimensions'"); 
	
	Если РежимЗаписи = "ПроведениеДокумента" Тогда
		НовыйЗаголовок = НСтр("ru='Провести документ';en='Post the document'");			
	ИначеЕсли РежимЗаписи = "Трансляция" Тогда
		НовыйЗаголовок = НСтр("ru='Выполнить трансляцию';en='Execute Conversion'");				
	ИначеЕсли РежимЗаписи = "ПроводитьПоРегистрамБИТ" Тогда
		НовыйЗаголовок = НСтр("ru='Провести по регистрам БИТ';en='Post in BIT Registers'");				
	КонецЕсли;
	
	Элементы.ЗаписатьАналитики.Заголовок = НовыйЗаголовок;
	
КонецПроцедуры // ИзменитьЗаголовокКнопкиЗаписи()

// Процедура заполняет список выбранных.
// 
&НаКлиенте
Процедура ЗаполнитьСписокВыбранных()
	
	СписокВыбранных.Очистить();
	
	Для каждого СтрокаТаблицы Из Объект.Документы Цикл
		Если СтрокаТаблицы.Выбрать Тогда
			СписокВыбранных.Добавить(СтрокаТаблицы.Документ, СтрокаТаблицы.ПолучитьИдентификатор());
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ИзменитьПризнакМодифицированностиАналитик(Форма, ПризнакМодифицированности)
	
	Элементы = Форма.Элементы;
	Объект	 = Форма.Объект;
	
	Если Форма.АналитикиМодифицированы = ПризнакМодифицированности Тогда
		Возврат;	
	КонецЕсли;	
	
	Форма.АналитикиМодифицированы = ПризнакМодифицированности; 
	
	Если НЕ Форма.АналитикиМодифицированы Тогда
		Форма.ПереключательЗПА = 0;
		Форма.ПереключательРФД = 0;
	КонецЕсли;	
	
	Если НЕ ПризнакМодифицированности Тогда
		// Признаки в таблице только сбрасываются. Взводятся другим способом.
		Для каждого СтрокаТаблицы Из Объект.Аналитики Цикл
			СтрокаТаблицы.Изменено = Ложь;	
		КонецЦикла;
	КонецЕсли;
	Элементы.ЗаписатьАналитики.КнопкаПоУмолчанию = Форма.АналитикиМодифицированы;
		
КонецПроцедуры

// Процедура устанавливает элементам формы признаки видимость, доступность, только просмотр...
// 
&НаСервере
Процедура УстановитьВидимостьДоступностьЭлементовПодсистемыТрансляции()
    
	Элементы.СтраницаПротоколТрансляции.Видимость 		= ВестиПротоколТрансляции;	
	Элементы.ДокументыВыборРассчитатьПартииМПЗ.Видимость = ОтображатьПунктРассчитатьПартииМПЗ;

КонецПроцедуры // УстановитьВидимостьДоступностьЭлементовПодсистемыТрансляции()
   
// Функция определяет работает ли документ с дополнительными аналитиками.
// 
// Параметры:
//  ТекущийДокумент - Документ Ссылка.
//  
// Возвращаемое значение:
//   Булево.
// 
&НаСервереБезКонтекста
Функция ЭтотДокументРаботаетСАналитиками(ТекущийДокумент)
	
	Возврат Обработки.бит_ГрупповоеРедактированиеДополнительныхАналитик.ЭтотДокументРаботаетСАналитиками(ТекущийДокумент);
				
КонецФункции

// Функция определяет наличие выбранного документа, работающего с дополнительными аналитиками.
// 
// Параметры:
//  Нет
//  
// Возвращаемое значение:
//   Булево
// 
&НаСервере
Функция АналитикиНеИспользуются()

	Результат = Ложь;
	
	Для каждого ВыбранныйЭлемент Из СписокВыбранных Цикл
		Если НЕ ЭтотДокументРаботаетСАналитиками(ВыбранныйЭлемент.Значение) Тогда
			Результат = Истина;
			Прервать;
		КонецЕсли;	
	КонецЦикла;

	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеЭлементамиФормы(Форма)

	Элементы = Форма.Элементы;
	
	Элементы.КомпоновщикПользовательскиеНастройки.ТолькоПросмотр = (Форма.СписокТиповОбъектов.Количество() = 0);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста 
Процедура УстановитьТекущуюСтраницуПанелиДополнительныхАналитик(Форма)
	
	Элементы 				= Форма.Элементы;
	СписокВыбранных 		= Форма.СписокВыбранных;
	АналитикиНеИспользуются = Форма.АналитикиНеИспользуются;

	Если СписокВыбранных.Количество() = 0 Тогда
		ТекущаяСтраницаРедактирование = Элементы.СтраницаОжидание;
		ПоказатьШапку				  = Ложь;
	ИначеЕсли АналитикиНеИспользуются Тогда	
		ТекущаяСтраницаРедактирование = Элементы.СтраницаНеИспользуется;
		ПоказатьШапку				  = Ложь;
	Иначе
		ТекущаяСтраницаРедактирование = Элементы.СтраницаНесколькоДокументов;
		ПоказатьШапку 				  = Истина;
	КонецЕсли;
	
	Элементы.СтраницыРедактирование.ТекущаяСтраница		  = ТекущаяСтраницаРедактирование;
	Элементы.ГруппаДополнительныеАналитикиШапка.Видимость =  ПоказатьШапку;

КонецПроцедуры

&НаСервере
Процедура ОбновитьТаблицыАналитик(ТекущийДокумент)

	ЕстьДокументОплатыБит 		    = Ложь;
	ЕстьТекущийДокументСАналитиками = Ложь;
	
	Объект.АналитикиТолькоЧтение.Очистить();
	
	Если ТекущийДокумент = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Если НЕ ЭтотДокументРаботаетСАналитиками(ТекущийДокумент) Тогда
		Возврат;
	КонецЕсли;
				
	ЕстьТекущийДокументСАналитиками = Истина;
     	 	        	
	// Аналитики шапки	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Объект", ТекущийДокумент);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДополнительныеАналитики.Аналитика КАК Аналитика,
	|	ДополнительныеАналитики.ЗначениеАналитики КАК ЗначениеАналитики,
	|	ДополнительныеАналитики.Аналитика.Код КАК ИмяАналитики
	|ИЗ
	|	РегистрСведений.бит_ДополнительныеАналитики КАК ДополнительныеАналитики
	|ГДЕ
	|	ДополнительныеАналитики.Объект = &Объект"; 
	Результат = Запрос.Выполнить();
	
	Выборка   = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
	 
		НоваяСтрока = Объект.АналитикиТолькоЧтение.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.ИмяАналитики = СокрЛП(Выборка.ИмяАналитики);

		Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
			Если Выборка.Аналитика = ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ПлатежнаяПозиция 
				И ЗначениеЗаполнено(Выборка.ЗначениеАналитики) Тогда
			    ЕстьДокументОплатыБит = Истина;		
			КонецЕсли;
		КонецЕсли; 
	КонецЦикла;
	
КонецПроцедуры

// Функция получает имя аналитики.
// 
// Параметры:
//  ТекущаяАналитика - ПланВидовХарактеристикСсылка.бит_ВидыДополнительныхАналитик.
//  
// Возвращаемое значение:
//   Строка.
// 
&НаСервере
Функция ПолучитьИмяАналитики(ТекущаяАналитика)

	Если ЗначениеЗаполнено(ТекущаяАналитика) Тогда
	 	ИмяАналитики = СокрЛП(ТекущаяАналитика.Код);
	Иначе	
	    ИмяАналитики = "";
	КонецЕсли;	

	Возврат ИмяАналитики;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПараметрыЗаписиИзменений(РежимВыполнения, ОбъектыДляЗаписи, КоличествоОбщее)
		
	ПараметрыЗаписи = Новый Структура;
	
	ПараметрыЗаписи.Вставить("ОбъектыДляЗаписи" , 		ОбъектыДляЗаписи);
	ПараметрыЗаписи.Вставить("ВыполнитьЗаписьАналитик", РежимВыполнения = "ЗаписьАналитик");
	ПараметрыЗаписи.Вставить("ВыполнитьПроведение", 	РежимВыполнения = "ПроведениеДокумента");
	ПараметрыЗаписи.Вставить("ОтменитьТрансляцию", 		РежимВыполнения = "ОтменитьТрансляцию");
	ПараметрыЗаписи.Вставить("ВыполнитьТрансляцию", 	РежимВыполнения = "Трансляция");
	ПараметрыЗаписи.Вставить("ВыполнитьПроведениеБит", 	РежимВыполнения = "ПроводитьПоРегистрамБИТ");
	ПараметрыЗаписи.Вставить("РассчитатьПартииМПЗ", 	РежимВыполнения = "РасчетПартийМПЗ");
	ПараметрыЗаписи.Вставить("КоличествоОбщее",			КоличествоОбщее);
	// 0 - Таблица на форме.
	// 1 - Результат "Заполнить из настроек".
	// 2 - Результат "Обновить из настроек".
	ПараметрыЗаписи.Вставить("ИсточникДопАналитик", 0);
	
	Возврат ПараметрыЗаписи;
	
КонецФункции

&НаСервереБезКонтекста
Функция НоваяТаблицаДополнительныеАналитики()

	Возврат Обработки.бит_ГрупповоеРедактированиеДополнительныхАналитик.НоваяТаблицаДополнительныеАналитики();
	
КонецФункции

// Процедура заполняет дополнительные аналитики по платежной позиции.
// 
// Параметры:
//  ОбъектСсылка - ДокументСсылка.*
//  ДокументБит  - ДокументСсылка.бит_ПлатежнаяПозиция 
// 					или ДокументСсылка.бит_РасходнаяПозиция 
// 					или ДокументСсылка.бит_ПланируемоеПоступлениеДенежныхСредств.
// 
&НаСервере
Процедура ЗаполнениеДополнительныхАналитикПоДокументуБит(ОбъектСсылка, Знач ДокументБит)
	
	Если НЕ ЗначениеЗаполнено(ОбъектСсылка) Тогда
		Возврат;
	КонецЕсли;
	
	Объект.Аналитики.Очистить();
	
	Если ЭтотДокументРаботаетСАналитиками(ОбъектСсылка) Тогда
		
		ДополнительныеАналитики = НоваяТаблицаДополнительныеАналитики();
		бит_МеханизмДопИзмерений.ЗаполнитьДополнительныеАналитикиПоДокументуБит(
			ДополнительныеАналитики, ОбъектСсылка, ДокументБит);
				
		Для каждого Запись Из ДополнительныеАналитики Цикл
			СтрокаТаблицы = Объект.Аналитики.Добавить();	
			СтрокаТаблицы.Аналитика    		= Запись.Аналитика;
			СтрокаТаблицы.ИмяАналитики 		= СокрЛП(Запись.Аналитика.Код);
			СтрокаТаблицы.ЗначениеАналитики = Запись.ЗначениеАналитики;
			СтрокаТаблицы.Изменено 			= Истина;
		КонецЦикла;
	КонецЕсли;		
	
	ИзменитьПризнакМодифицированностиАналитик(ЭтотОбъект, Истина);
	ПереключательЗПА = 1;
	
КонецПроцедуры

#Область ПроцедурыИФункцииПоРаботеСНастройками

&НаСервере
Процедура ПрименитьНастройки(СохраненныеНастройки)
	
	Перем ЗначениеНастроек;
	
	ПользовательскиеНастройки = Новый ПользовательскиеНастройкиКомпоновкиДанных;
	
	Если ЗначениеЗаполнено(СохраненныеНастройки) Тогда
		ЗначениеНастроек = СохраненныеНастройки.ХранилищеНастроек.Получить();
	КонецЕсли;

	НовыеНастройки = НовыеСохраненныеНастройки();
	Если ТипЗнч(ЗначениеНастроек) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(НовыеНастройки, ЗначениеНастроек);
		
		// Применение настроек старой версии.
		Значения = Неопределено;
		Если ЗначениеНастроек.Свойство("МассивИсточники", Значения) И ТипЗнч(Значения) = Тип("Массив") Тогда
			НовыеНастройки.ИсточникиТрансляции.ЗагрузитьЗначения(Значения);
		КонецЕсли;
		Если ЗначениеНастроек.Свойство("МассивПриемники", Значения) И ТипЗнч(Значения) = Тип("Массив") Тогда
			НовыеНастройки.ПриемникиТрансляции.ЗагрузитьЗначения(Значения);	
		КонецЕсли;
	КонецЕсли;
		
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, НовыеНастройки);
	ЗаполнитьЗначенияСвойств(Объект, НовыеНастройки);
	ПользовательскиеНастройки = НовыеНастройки.ПользовательскиеНастройки;
	
	ИнициализироватьСКД(ПользовательскиеНастройки);	
	
	УправлениеЭлементамиФормы(ЭтотОбъект);
	УстановитьВидимостьДоступностьЭлементовПодсистемыТрансляции();
                             
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция НовыеСохраненныеНастройки()

	Настройки = Новый Структура;
	Настройки.Вставить("РежимСообщений", 					 "Все");
	Настройки.Вставить("РежимПредупреждений", 				 Ложь);
	Настройки.Вставить("РежимЗаписи", 						 "ПроведениеДокумента");
	Настройки.Вставить("РежимЗаписиАналитик", 				 "НеПерезаписывать");
	Настройки.Вставить("ВестиПротоколТрансляции", 			 Истина);
	Настройки.Вставить("ОтображатьПунктРассчитатьПартииМПЗ", Истина);
	Настройки.Вставить("ИсточникиТрансляции", 			  	 Новый СписокЗначений);
	Настройки.Вставить("ПриемникиТрансляции", 			  	 Новый СписокЗначений);
	Настройки.Вставить("СписокТиповОбъектов", 			  	 Новый СписокЗначений);
	Настройки.Вставить("Период", 						  	 Новый СтандартныйПериод);
	Настройки.Вставить("ПользовательскиеНастройки", 	  	 Новый ПользовательскиеНастройкиКомпоновкиДанных);
	Настройки.Вставить("НастройкиПодбораТиповДокументов", 	 Неопределено);
	
	Возврат Настройки;
	
КонецФункции

&НаСервере
Процедура УстановитьЗначенияПоУмолчанию()

	Перем НастройкаПоУмолчанию;
	
	Если НЕ ЗначениеЗаполнено(ДокументыДляОбработки) Тогда
		НастройкаПоУмолчанию = бит_ОтчетыСервер.НайтиНастройкуПоУмолчаниюДляОбъекта(НастраиваемыйОбъект());
	Иначе
		НовыеНастройки = НовыеСохраненныеНастройки();
		
		НовыеНастройки.СписокТиповОбъектов = СписокТиповОбъектов;
		НовыеНастройки.ИсточникиТрансляции = ИсточникиТрансляции;
		НовыеНастройки.ПриемникиТрансляции = ПриемникиТрансляции;
		
		ХранилищеНастроек	 = Новый ХранилищеЗначения(НовыеНастройки, Новый СжатиеДанных(9));
		НастройкаПоУмолчанию = Новый Структура("ХранилищеНастроек", ХранилищеНастроек);
	КонецЕсли;
	
	ПрименитьНастройки(НастройкаПоУмолчанию);
      
КонецПроцедуры
     
&НаКлиенте
Процедура СохранитьНастройки(Команда)

	ПараметрыФормы = Новый Структура;
	
	НовыеНастройки = НовыеСохраненныеНастройки();
	ЗаполнитьЗначенияСвойств(НовыеНастройки, ЭтотОбъект);
	ЗаполнитьЗначенияСвойств(НовыеНастройки, Объект);
	НовыеНастройки.ПользовательскиеНастройки = Объект.Компоновщик.ПользовательскиеНастройки;
	
	ПараметрыФормы.Вставить("СтруктураНастройки" , НовыеНастройки);
	ПараметрыФормы.Вставить("ТипНастройки"		 , ПредопределенноеЗначение("Перечисление.бит_ТипыСохраненныхНастроек.Обработки"));
	ПараметрыФормы.Вставить("НастраиваемыйОбъект", "Обработка.бит_ГрупповоеРедактированиеДополнительныхАналитик");
	
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаСохранения",ПараметрыФормы,ЭтотОбъект,,,,,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
		
КонецПроцедуры

&НаКлиенте
Процедура ВосстановитьНастройки(Команда)

	ПараметрыФормы     = Новый Структура;
	ПараметрыФормы.Вставить("ТипНастройки"		 , ПредопределенноеЗначение("Перечисление.бит_ТипыСохраненныхНастроек.Обработки"));
	ПараметрыФормы.Вставить("НастраиваемыйОбъект", "Обработка.бит_ГрупповоеРедактированиеДополнительныхАналитик");
	
	Оповещение = Новый ОписаниеОповещения("ВосстановитьНастройкиОкончание", ЭтотОбъект); 
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаЗагрузки",ПараметрыФормы,ЭтотОбъект,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
КонецПроцедуры // ВосстановитьНастройки()

// Процедура окончание процедуры "ВосстановитьНастройки".
// 
&НаКлиенте 
Процедура ВосстановитьНастройкиОкончание(РезультатВыбора, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(РезультатВыбора) Тогда
