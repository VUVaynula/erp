&НаКлиенте
Процедура ВыборТрансляциюОтменить(Команда)
	
	Если ЗначениеЗаполнено(ПриемникиТрансляции) Тогда
		
		ТекстСообщения = НСтр("ru='По выбранным документам будут отменены движения в регистрах: %1. Продолжить?';
							  |en='According to the selected documents will be canceled movement registers: %1. Resume?'");
		
		СтрРегистры    = ПриемникиТрансляции.ВыгрузитьЗначения();
		ТекстСообщения = СтрШаблон(ТекстСообщения, СтрСоединить(СтрРегистры, Символы.ПС));
		
		Оповещение = Новый ОписаниеОповещения("ВопросОтменитьТрансляциюЗавершение", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, ТекстСообщения, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);
		
	Иначе	
		
		Оповещение = Новый ОписаниеОповещения("ВопросОтменитьТрансляциюПоОшибкеЗавершение", ЭтотОбъект); 
		СписокДействий = Новый СписокЗначений(); 
		СписокДействий.Добавить(КодВозвратаДиалога.Да, НСтр("ru='Показать настройки';en='Show Settings'"));
		СписокДействий.Добавить(КодВозвратаДиалога.Нет, НСтр("ru='Прервать';en='Interrupt'"));		
		ТекстСообщения = НСтр("ru='Не указаны приемники для отмены трансляции движений.';
							  |en='Do not tell the receiver to cancel the translation movements.'");
		ТекстЗаголовка = НСтр("ru='Отмена трансляции';en='Cancel broadcast'");
		ПоказатьВопрос(Оповещение,ТекстСообщения, СписокДействий,, КодВозвратаДиалога.Да, ТекстЗаголовка);
		
	КонецЕсли; 
	
КонецПроцедуры // ВыборТрансляциюОтменить()

