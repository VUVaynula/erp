		<query>// ВНИМАНИЕ!!! ПЕРВЫЙ ЗАПРОС ПАКЕТА - ШАБЛОН.
// ИЗМЕНЯЕТСЯ В ХОДЕ ВЫПОЛНЕНИЯ ПРОГРАММНО.
ВЫБРАТЬ
	ПроизвольныйДокумент.Ссылка КАК Документ,
	ПроизвольныйДокумент.Номер КАК Номер,
	ПроизвольныйДокумент.Проведен КАК Проведен,
	ПроизвольныйДокумент.ПометкаУдаления КАК ПометкаУдаления,
	НЕОПРЕДЕЛЕНО КАК Организация,
	НЕОПРЕДЕЛЕНО КАК Ответственный,
	НЕОПРЕДЕЛЕНО КАК ВидОперации,
	ПроизвольныйДокумент.Дата КАК Дата,
	НЕОПРЕДЕЛЕНО КАК СтатьяДвиженияДенежныхСредств,
	НЕОПРЕДЕЛЕНО КАК Контрагент,
	НЕОПРЕДЕЛЕНО КАК ДоговорКонтрагента,
	ЛОЖЬ КАК РучнаяКорректировка,
	0 КАК СуммаДокумента,
	"" КАК НазначениеПлатежа
ПОМЕСТИТЬ ТабДокументы
ИЗ
	Документ.бит_БюджетнаяОперация КАК ПроизвольныйДокумент
{ГДЕ
	ПроизвольныйДокумент.Ссылка.* КАК Документ,
	ПроизвольныйДокумент.Проведен КАК Проведен,
	ПроизвольныйДокумент.Ответственный КАК Ответственный,
	(НЕОПРЕДЕЛЕНО) КАК Организация,
	(НЕОПРЕДЕЛЕНО) КАК Контрагент,
	(НЕОПРЕДЕЛЕНО) КАК ДоговорКонтрагента,
	(НЕОПРЕДЕЛЕНО) КАК СтатьяДвиженияДенежныхСредств,
	(НЕОПРЕДЕЛЕНО) КАК НазначениеПлатежа,
	(ЛОЖЬ) КАК РучнаяКорректировка}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Документы.Документ,
	Документы.Номер,
	Документы.Проведен,
	Документы.ПометкаУдаления,
	Документы.Организация,
	Документы.ВидОперации,
	Документы.Контрагент,
	Документы.СтатьяДвиженияДенежныхСредств,
	Документы.СуммаДокумента,
	Документы.НазначениеПлатежа,
	Документы.Дата,
	ВЫБОР
		КОГДА ISNULL(Документы.РучнаяКорректировка, ЛОЖЬ) = ИСТИНА
			ТОГДА ВЫБОР
					КОГДА Документы.ПометкаУдаления = ИСТИНА
						ТОГДА 10
					КОГДА ISNULL(Документы.Проведен, ЛОЖЬ) = ЛОЖЬ
						ТОГДА 9
					ИНАЧЕ 8
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА Документы.ПометкаУдаления = ИСТИНА
					ТОГДА 2
				КОГДА ISNULL(Документы.Проведен, ЛОЖЬ) = ИСТИНА
					ТОГДА 1
				ИНАЧЕ 0
			КОНЕЦ
	КОНЕЦ КАК СостояниеДокумента,
	//ВыборДополнительныхАналитик.Результат
	//РучнаяКорректировкаФакта.Результат
	//ДополнительныеПараметрыОбъектов.Результат
	ТИПЗНАЧЕНИЯ(Документы.Документ) КАК ИмяОбъекта
ИЗ
	ТабДокументы КАК Документы
	//ВыборДополнительныхАналитик.Соединение
	//РучнаяКорректировкаФакта.Соединение
	//ДополнительныеПараметрыОбъектов.Соединение
УПОРЯДОЧИТЬ ПО
	Документы.Дата
</query>
