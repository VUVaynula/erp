
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УчетнаяЗапись = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_УчетнаяЗаписьДляВизирования");
	
	РегламентноеЗадание = НайтиРегламентноеЗадание("бит_ВизированиеЧерезПочту");
	Если РегламентноеЗадание <> Неопределено Тогда
		ВизированиеЧерезПочтуИспользование = РегламентноеЗадание.Использование;
		ВизированиеЧерезПочтуРасписание   = РегламентноеЗадание.Расписание;
		УстановитьДоступностьПредставлениеРасписания();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаСервере
Процедура УчетнаяЗаписьПриИзмененииНаСервере()
	
	Константы.бит_УчетнаяЗаписьДляВизирования.Установить(УчетнаяЗапись);
	ОбновитьПовторноИспользуемыеЗначения();
	
КонецПроцедуры

&НаКлиенте
Процедура УчетнаяЗаписьПриИзменении(Элемент)
	
	УчетнаяЗаписьПриИзмененииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ВизированиеЧерезПочтуИспользованиеПриИзменении(Элемент)
	
	ЗаписатьРегламентноеЗадание();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВизированиеЧерезПочтуНастроитьРасписание(Команда)
	
	Диалог = Новый ДиалогРасписанияРегламентногоЗадания(ВизированиеЧерезПочтуРасписание);
	Диалог.Показать(Новый ОписаниеОповещения("ВизированиеЧерезПочтуНастроитьРасписаниеЗавершение", ЭтотОбъект));
	
КонецПроцедуры

// Процедура обработчик оповещения "ВизированиеЧерезПочтуНастроитьРасписание".
// 
// Параметры:
//  Расписание - РасписаниеРегламентногоЗадания.
//  ПараметрыВыполнения - Структура.
// 
&НаКлиенте
Процедура ВизированиеЧерезПочтуНастроитьРасписаниеЗавершение(Расписание, ПараметрыВыполнения) Экспорт
	
	Если Расписание = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВизированиеЧерезПочтуРасписание   = Расписание;
	ВизированиеЧерезПочтуИспользование = Истина;
	ЗаписатьРегламентноеЗадание();
		
КонецПроцедуры

&НаСервере
Процедура ОповеститьОНовыхВизахПоПочтеНаСервере()
	
	Обработки.бит_ВизированиеСИспользованиемЭлектроннойПочты.ОповеститьОНовыхВизахПоПочте();
	
КонецПроцедуры

&НаКлиенте
Процедура ОповеститьОНовыхВизахПоПочте(Команда)
	
	ОповеститьОНовыхВизахПоПочтеНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьОтветыСогласованийПоПочтеНаСервере()
	
	Обработки.бит_ВизированиеСИспользованиемЭлектроннойПочты.ПрочитатьОтветыСогласованийПоПочте();
	
КонецПроцедуры

&НаКлиенте
Процедура ПрочитатьОтветыСогласованийПоПочте(Команда)
	
	ПрочитатьОтветыСогласованийПоПочтеНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура НоваяУчетнаяЗапись(Команда)
	
	ОткрытьФорму("Справочник.УчетныеЗаписиЭлектроннойПочты.ФормаОбъекта");
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаписатьРегламентноеЗадание()
	
	РегламентноеЗадание = НайтиРегламентноеЗадание("бит_ВизированиеЧерезПочту");
	Если РегламентноеЗадание <> Неопределено Тогда
		ПараметрыЗадания = Новый Структура;
		ПараметрыЗадания.Вставить("Использование", ВизированиеЧерезПочтуИспользование);
		ПараметрыЗадания.Вставить("Расписание", ВизированиеЧерезПочтуРасписание);
		
		РегламентныеЗаданияСервер.ИзменитьЗадание(РегламентноеЗадание, ПараметрыЗадания);
		УстановитьДоступностьПредставлениеРасписания();
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НайтиРегламентноеЗадание(ИмяПредопределенного)
	
	Отбор = Новый Структура;
	Отбор.Вставить("Метаданные", ИмяПредопределенного);
	Отбор.Вставить("Предопределенное", Истина);
	
	РезультатПоиска = РегламентныеЗаданияСервер.НайтиЗадания(Отбор);
	Возврат ?(РезультатПоиска.Количество() = 0, Неопределено, РезультатПоиска[0]);
	
КонецФункции

&НаСервере
Процедура УстановитьДоступностьПредставлениеРасписания()
	
	Элементы.ВизированиеЧерезПочтуНастроитьРасписание.Доступность = ВизированиеЧерезПочтуИспользование;
	Если ВизированиеЧерезПочтуИспользование Тогда
		РасписаниеПредставление = Строка(ВизированиеЧерезПочтуРасписание);
		Представление = ВРег(Лев(РасписаниеПредставление, 1)) + Сред(РасписаниеПредставление, 2);
	Иначе
		Представление = "";
	КонецЕсли;
	Элементы.ВизированиеЧерезПочтуНастроитьРасписание.Заголовок = Представление;
	
КонецПроцедуры

#КонецОбласти