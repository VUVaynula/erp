#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ПрограммныйИнтерфейс

// Процедура выполняет чтение ответов по согласованию и устанавливает соответствующие визы.
//
Процедура ПрочитатьОтветыСогласованийПоПочте() Экспорт
	
	Если НЕ бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_ИспользоватьЭлектроннуюПочтуДляВизирования") Тогда
		Возврат;
	КонецЕсли;
	
	УчетнаяЗапись = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_УчетнаяЗаписьДляВизирования");
	Если НЕ ЗначениеЗаполнено(УчетнаяЗапись) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыЗагрузки = Новый Структура;
	ПараметрыЗагрузки.Вставить("УчетнаяЗапись", УчетнаяЗапись);
	ПараметрыЗагрузки.Вставить("ПолучениеЗаголовков", Ложь);
	ПараметрыЗагрузки.Вставить("ПриводитьСообщенияКТипу", Ложь);
		
	НаборСообщений = РаботаСПочтовымиСообщениями.ЗагрузитьПочтовыеСообщения(
		ПараметрыЗагрузки.УчетнаяЗапись, ПараметрыЗагрузки);
		
	ТипСтрока150   = Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(150, ДопустимаяДлина.Переменная));
	ТипСтрока36    = Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(36, ДопустимаяДлина.Фиксированная));
	ТаблицаОтветов = Новый ТаблицаЗначений;
	ТаблицаОтветов.Колонки.Добавить("ИдентификаторСообщения", ТипСтрока150);
	ТаблицаОтветов.Колонки.Добавить("Отправитель", ТипСтрока150);
	ТаблицаОтветов.Колонки.Добавить("ИдВизы",      ТипСтрока36);
	ТаблицаОтветов.Колонки.Добавить("Решение",     Новый ОписаниеТипов("СправочникСсылка.бит_ВидыРешенийСогласования"));
	ТаблицаОтветов.Колонки.Добавить("Комментарий", Новый ОписаниеТипов("Строка"));
	ТаблицаОтветов.Колонки.Добавить("ТемаПисьма", Новый ОписаниеТипов("Строка"));
	ТаблицаОтветов.Колонки.Добавить("ДатаОтправления", Новый ОписаниеТипов("Дата", , ,
													   Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)));
													   
	ОбработанныеСообщения = Новый Массив;
	Для каждого Сообщение Из НаборСообщений Цикл
		Тема = Сообщение.Тема;
		УказательВизы    = СтрНайти(Тема, "$V[");
		УказательРешения = СтрНайти(Тема, "$D[");
		Если УказательВизы = 0 ИЛИ УказательРешения = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаОтвета = ТаблицаОтветов.Добавить();
		СтрокаОтвета.ИдентификаторСообщения = Сообщение.ИдентификаторСообщения;
		СтрокаОтвета.Отправитель            = Сообщение.Отправитель.Адрес;
		СтрокаОтвета.ИдВизы                 = Сред(Тема, УказательВизы + 3, 36);
		СтрокаОтвета.ДатаОтправления        = Сообщение.ДатаОтправления;
		СтрокаОтвета.ТемаПисьма             = Тема;
		
		ИдРешения = Сред(Тема, УказательРешения + 3, 36);
		Решение   = Справочники.бит_ВидыРешенийСогласования.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдРешения));
		СтрокаОтвета.Решение                = Решение;
		
		ТекстПисьма  = "";
		ПростойТекст = "";
		ТекстХТМЛ    = "";
		Для каждого ЭлементТекста Из Сообщение.Тексты Цикл
			Если ЭлементТекста.ТипТекста = ТипТекстаПочтовогоСообщения.ПростойТекст Тогда
				ПростойТекст = ЭлементТекста.Текст;
				Прервать;
			ИначеЕсли ЭлементТекста.ТипТекста = ТипТекстаПочтовогоСообщения.HTML Тогда
				ТекстХТМЛ = ЭлементТекста.Текст;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ ПустаяСтрока(ПростойТекст) Тогда
			ТекстПисьма = ПростойТекст;
		ИначеЕсли НЕ ПустаяСтрока(ТекстХТМЛ) Тогда
			Построитель = Новый ПостроительDOM;
			ЧтениеHTML  = Новый ЧтениеHTML;
			ЧтениеHTML.УстановитьСтроку(ТекстХТМЛ);
			ДокументHTML = Построитель.Прочитать(ЧтениеHTML);
			ТекстПисьма  = ДокументHTML.Тело.ТекстовоеСодержимое;
		КонецЕсли;
		
		УказательКомментария = СтрНайти(ТекстПисьма, "Комментарий:");
		Если УказательКомментария > 0 Тогда
			Комментарий = СокрЛП(Сред(ТекстПисьма, УказательКомментария + 12));
			СтрокаОтвета.Комментарий = Комментарий;
		КонецЕсли;
		
		ОбработанныеСообщения.Добавить(Сообщение);
	КонецЦикла;
	
	Если ТаблицаОтветов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаОтветов.ИдентификаторСообщения КАК ИдентификаторСообщения,
	|	ТаблицаОтветов.Отправитель КАК Отправитель,
	|	ТаблицаОтветов.ИдВизы КАК ИдВизы,
	|	ТаблицаОтветов.Решение КАК Решение,
	|	ТаблицаОтветов.Комментарий КАК Комментарий,
	|	ТаблицаОтветов.ТемаПисьма КАК ТемаПисьма,
	|	ТаблицаОтветов.ДатаОтправления КАК ДатаОтправления
	|ПОМЕСТИТЬ ТаблицаОтветов
	|ИЗ
	|	&ТаблицаОтветов КАК ТаблицаОтветов";
	Запрос.УстановитьПараметр("ТаблицаОтветов", ТаблицаОтветов);
	Запрос.Выполнить();
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаОтветов.ИдентификаторСообщения КАК ИдентификаторСообщения,
	|	МАКСИМУМ(КонтактнаяИнформацияПользователя.Ссылка) КАК Пользователь
	|ПОМЕСТИТЬ Отправители
	|ИЗ
	|	ТаблицаОтветов КАК ТаблицаОтветов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК КонтактнаяИнформацияПользователя
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
	|			ПО КонтактнаяИнформацияПользователя.Ссылка = Пользователи.Ссылка
	|				И (НЕ Пользователи.ПометкаУдаления)
	|				И (НЕ Пользователи.Недействителен)
	|		ПО (КонтактнаяИнформацияПользователя.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПользователя))
	|			И ТаблицаОтветов.Отправитель = КонтактнаяИнформацияПользователя.АдресЭП
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаОтветов.ИдентификаторСообщения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаОтветов.ИдентификаторСообщения КАК ИдентификаторСообщения,
	|	МАКСИМУМ(бит_УстановленныеВизы.АктивнаяВиза
	|			ИЛИ ТаблицаОтветов.Решение = ЗНАЧЕНИЕ(Справочник.бит_ВидыРешенийСогласования.ПустаяСсылка)) КАК ОжидаетРешения,
	|	МАКСИМУМ(бит_УстановленныеВизы.Объект) КАК ОбъектВизирования,
	|	МАКСИМУМ(бит_УстановленныеВизы.Виза) КАК Виза,
	|	МАКСИМУМ(бит_УстановленныеВизы.Пользователь) КАК ПользовательРешения,
	|	МАКСИМУМ(бит_УстановленныеВизы.ДатаУстановки) КАК ДатаУстановкиРешения,
	|	МАКСИМУМ(бит_УстановленныеВизы.Решение) КАК ПринятоеРешение
	|ПОМЕСТИТЬ ОбъектыВизирования
	|ИЗ
	|	ТаблицаОтветов КАК ТаблицаОтветов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы
	|		ПО ТаблицаОтветов.ИдВизы = бит_УстановленныеВизы.ИД
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаОтветов.ИдентификаторСообщения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаОтветов.ИдентификаторСообщения КАК ИдентификаторСообщения,
	|	ТаблицаОтветов.ИдВизы КАК ИдВизы,
	|	ТаблицаОтветов.Решение КАК Решение,
	|	ТаблицаОтветов.Комментарий КАК Комментарий,
	|	ТаблицаОтветов.ТемаПисьма КАК ТемаПисьма,
	|	ТаблицаОтветов.ДатаОтправления КАК ДатаОтправления,
	|	ТаблицаОтветов.Отправитель КАК Отправитель,
	|	Отправители.Пользователь КАК Пользователь,
	|	ОбъектыВизирования.ОбъектВизирования КАК ОбъектВизирования,
	|	ОбъектыВизирования.Виза КАК Виза,
	|	ЕСТЬNULL(ОбъектыВизирования.ОжидаетРешения, ЛОЖЬ) КАК ОжидаетРешения,
	|	ОбъектыВизирования.ПользовательРешения КАК ПользовательРешения,
	|	ОбъектыВизирования.ДатаУстановкиРешения КАК ДатаУстановкиРешения,
	|	ОбъектыВизирования.ПринятоеРешение КАК ПринятоеРешение
	|ИЗ
	|	ТаблицаОтветов КАК ТаблицаОтветов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Отправители КАК Отправители
	|		ПО ТаблицаОтветов.ИдентификаторСообщения = Отправители.ИдентификаторСообщения
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОбъектыВизирования КАК ОбъектыВизирования
	|		ПО ТаблицаОтветов.ИдентификаторСообщения = ОбъектыВизирования.ИдентификаторСообщения";
	
	ОтветныеПисьма = Новый Массив;
	
	ВыборкаРешений = Запрос.Выполнить().Выбрать();
	Пока ВыборкаРешений.Следующий() Цикл
		
		ТекстОшибки        = "";
		РешениеУстановлено = УстановитьРешениеВизированияПоПочте(ВыборкаРешений, ТекстОшибки);
		
		ПараметрыПисьма      = НовыеПараметрыПисьма();
		ПараметрыПисьма.Кому = ВыборкаРешений.Отправитель;
		
		Если РешениеУстановлено Тогда
			ПараметрыПисьма.Тело = НСтр("ru = 'Данное письмо отправлено автоматически, не отвечайте на него.'");
			Если ЗначениеЗаполнено(ВыборкаРешений.Решение) Тогда
				ТемаПисьма = НСтр("ru = 'Установка решения %1 для %2 успешно завершена: %3.'");
				ТемаПисьма = СтрШаблон(ТемаПисьма, ВыборкаРешений.Виза, ВыборкаРешений.ОбъектВизирования,
								ВыборкаРешений.Решение);
				ПараметрыПисьма.Тема = ТемаПисьма;
			
				ПараметрыПринятияРешения = НовыеПараметрыПринятияРешения();
				ПараметрыПринятияРешения.ПочтовыйАдрес     = ПараметрыЗагрузки.УчетнаяЗапись.АдресЭлектроннойПочты;
				ПараметрыПринятияРешения.ОбъектВизирования = ВыборкаРешений.ОбъектВизирования;
				ПараметрыПринятияРешения.ИДВизы            = ВыборкаРешений.ИдВизы;
				КомандаОтвета = КомандаПринятияРешения(ПараметрыПринятияРешения);
				ПараметрыПисьма.Тело = ПараметрыПисьма.Тело + Символы.ПС + Символы.ПС + КомандаОтвета;
			Иначе
				ТемаПисьма = НСтр("ru = 'Решение %1 для %2 очищено.'");
				ТемаПисьма = СтрШаблон(ТемаПисьма, ВыборкаРешений.Виза, ВыборкаРешений.ОбъектВизирования);
				ПараметрыПисьма.Тема = ТемаПисьма;
			КонецЕсли;
		Иначе
			УказательВизы = СтрНайти(ВыборкаРешений.ТемаПисьма, "$V");
			ИсходнаяТема  = Лев(ВыборкаРешений.ТемаПисьма, УказательВизы - 2);
			ТемаПисьма    = НСтр("ru = 'Не удалось установить решение'") + " " + ИсходнаяТема;
			ПараметрыПисьма.Тема = ТемаПисьма;
			ПараметрыПисьма.Тело = ТекстОшибки + Символы.ПС + НСтр("ru = 'Данное письмо отправлено автоматически, не отвечайте на него.'");
		КонецЕсли;
		
		ПодготовитьПисьмоПредварительно(ПараметрыПисьма);
		
		Письмо = РаботаСПочтовымиСообщениями.ПодготовитьПисьмо(ПараметрыЗагрузки.УчетнаяЗапись, ПараметрыПисьма);
		ОтветныеПисьма.Добавить(Письмо);
	КонецЦикла;
	
	Если ОтветныеПисьма.Количество() > 0 Тогда
		РаботаСПочтовымиСообщениями.ОтправитьПисьма(ПараметрыЗагрузки.УчетнаяЗапись, ОтветныеПисьма);
	КонецЕсли;
	
	УдалитьПочтовыеСообщения(ПараметрыЗагрузки.УчетнаяЗапись, ОбработанныеСообщения);
	
КонецПроцедуры

// Процедура выполняет отправку запросов согласования о новых визах.
//
Процедура ОповеститьОНовыхВизахПоПочте() Экспорт
	
	Если НЕ бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_ИспользоватьЭлектроннуюПочтуДляВизирования") Тогда
		Возврат;
	КонецЕсли;
	
	УчетнаяЗапись = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_УчетнаяЗаписьДляВизирования");
	Если НЕ ЗначениеЗаполнено(УчетнаяЗапись) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыДоставки = Новый Структура;
	ПараметрыДоставки.Вставить("УчетнаяЗапись", УчетнаяЗапись);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	бит_УстановленныеВизы.Объект КАК Объект,
	|	бит_УстановленныеВизы.Виза КАК Виза
	|ИЗ
	|	РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы
	|ГДЕ
	|	бит_УстановленныеВизы.АктивнаяВиза
	|	И НЕ бит_УстановленныеВизы.ОповещеноПочта";
	ВизыДляОповещений = Запрос.Выполнить().Выгрузить();
	
	Если ВизыДляОповещений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПолучателиОповещений = бит_ОповещенияСервер.ПолучателиОповещений(Перечисления.бит_фн_СпособыТранспортаОповещений.ЭлектроннаяПочта1С);
	Если ПолучателиОповещений.Количество() Тогда
		ОтветственныеЗаВизы = бит_ВизированиеСервер.ОтветственныеЗаУстановкуВиз(ВизыДляОповещений, ПолучателиОповещений);
		ОтправитьОповещенияОВизахПоПочте(ОтветственныеЗаВизы, ПараметрыДоставки);
	КонецЕсли;
	
	бит_ВизированиеСервер.УстановитьОтметкуОповещения(ВизыДляОповещений
													, Перечисления.бит_фн_СпособыТранспортаОповещений.ЭлектроннаяПочта1С);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ОписаниеВложения() Экспорт
	
	ОписаниеВложения = Новый Структура;
	ОписаниеВложения.Вставить("Представление");
	ОписаниеВложения.Вставить("АдресВоВременномХранилище");
	ОписаниеВложения.Вставить("Кодировка");
	ОписаниеВложения.Вставить("Идентификатор");
	
	Возврат ОписаниеВложения;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция УстановитьРешениеВизированияПоПочте(ВыборкаРешений, ТекстОшибки)
	
	Если НЕ ЗначениеЗаполнено(ВыборкаРешений.Пользователь) Тогда
		ТекстОшибки = НСтр("ru='Не удалось установить исполнителя по почтовому адресу ""%1"".';
						|en='Unable to match user for e-mail adress ""%1""'");
		ТекстОшибки = СтрШаблон(ТекстОшибки, ВыборкаРешений.Отправитель);
		ЗафиксироватьОшибкуСогласованияСервисаПочтовогоВизирования(ТекстОшибки);
		Возврат Ложь;
	КонецЕсли;
	
	Если НЕ ВыборкаРешений.ОжидаетРешения И ЗначениеЗаполнено(ВыборкаРешений.ПринятоеРешение) Тогда
		ТекстОшибки = НСтр("ru='Для визы ""%1"" уже принято решение ""%2"".
							|Решение установлено пользователем ""%3"" - %4'");
		ТекстОшибки = СтрШаблон(ТекстОшибки, ВыборкаРешений.Виза, ВыборкаРешений.ПринятоеРешение,
						ВыборкаРешений.ПользовательРешения, ВыборкаРешений.ДатаУстановкиРешения);
		ЗафиксироватьОшибкуСогласованияСервисаПочтовогоВизирования(ТекстОшибки);
		Возврат Ложь;
	КонецЕсли;
		
	Если НЕ ВыборкаРешений.ОжидаетРешения Тогда
		ТекстОшибки = НСтр("ru='Виза %1 больше не доступна для согласования.
						|Возможные причины:
						|• Документ распроведен;
						|• Было очищено или изменено решение по предыдущей визе;
						|• Список виз был обновлен;
						|• Изменены условия доступности визы;
						|• Есть копия базы с включенными регламентными заданиями, обращающаяся к тому же почтовому серверу;
						|• Прочее'");
		ТекстОшибки = СтрШаблон(ТекстОшибки, ВыборкаРешений.Виза);
		ЗафиксироватьОшибкуСогласованияСервисаПочтовогоВизирования(ТекстОшибки);
		Возврат Ложь;
	КонецЕсли;
		
	Если ПустаяСтрока(ВыборкаРешений.Комментарий) Тогда
		ПараметрыПроверки = РегистрыСведений.бит_УстановленныеВизы.НовыеПараметрыНуженКомментарий();
		ПараметрыПроверки.Объект          = ВыборкаРешений.ОбъектВизирования;
		ПараметрыПроверки.РешениеКонечное = ВыборкаРешений.Решение;
		ПараметрыПроверки.Комментарий     = ВыборкаРешений.Комментарий;
		ПараметрыПроверки.Виза            = ВыборкаРешений.Виза;
		Если РегистрыСведений.бит_УстановленныеВизы.НуженКомментарий(ПараметрыПроверки) Тогда
			ТекстОшибки = НСтр("ru='Для решения ""%1"" обязательно указать комментарий. %2';
							|en='It need to enter cooment for desition ""%1"". %2'");
			ТекстОшибки = СтрШаблон(ТекстОшибки, ВыборкаРешений.Решение, ВыборкаРешений.ТемаПисьма);
			ЗафиксироватьОшибкуСогласованияСервисаПочтовогоВизирования(ТекстОшибки);
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
		
	ПараметрыРешения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыПринятияРешения();
	ПараметрыРешения.ОбъектВизирования          = ВыборкаРешений.ОбъектВизирования;
	ПараметрыРешения.ИДВизы                     = ВыборкаРешений.ИДВизы;
	ПараметрыРешения.ТекущийПользователь        = ВыборкаРешений.Пользователь;
	ПараметрыРешения.Решение                    = ВыборкаРешений.Решение;
	ПараметрыРешения.Комментарий                = ВыборкаРешений.Комментарий;
	ПараметрыРешения.ДатаУстановкиРешения       = ВыборкаРешений.ДатаОтправления;	
    ПараметрыРешения.ПроводитьПослеУтверждения  = бит_ВизированиеСервер.ПриниматьКУчетуПослеУтверждения(ВыборкаРешений.ОбъектВизирования);

	Если НЕ Обработки.бит_КонсольОперативногоВизирования.УстановитьРешениеПоВизе(ПараметрыРешения) Тогда
		ТекстОшибки = НСтр("ru='Не удалось установить решение по визе %1 пользователем %2.
						|Возможные причины:
						|• Нет прав на установку визы;
						|• Идентичная почта указана у разных пользователей программы;
						|• Изменены условия доступности визы;
						|• Есть копия базы с включенными регламентными заданиями, обращающаяся к тому же почтовому серверу;
						|• Прочее'");
		ТекстОшибки = СтрШаблон(ТекстОшибки, ВыборкаРешений.Виза, ВыборкаРешений.Пользователь);
		ЗафиксироватьОшибкуСогласованияСервисаПочтовогоВизирования(ТекстОшибки);
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура ЗафиксироватьОшибкуСогласованияСервисаПочтовогоВизирования(Знач ТекстОшибки)
	
	ИмяСобытия = НСтр("ru='Сервис почтового визирования.';
						|en='Mail visas service'", ОбщегоНазначения.КодОсновногоЯзыка());
	
	ШаблонОшибки = НСтр("ru='Согласование не выполнено. %1';
						|en='Visas didn`t confirm. %1'");
	ТекстОшибки  = СтрШаблон(ШаблонОшибки, ТекстОшибки);
	
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, ТекстОшибки);
	
КонецПроцедуры

Процедура УдалитьПочтовыеСообщения(УчетнаяЗапись, НаборСообщенийДляУдаления)
	
	Если НаборСообщенийДляУдаления.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьОтключениеБезопасногоРежима(Истина);
	Профиль = ИнтернетПочтовыйПрофиль(УчетнаяЗапись);
	УстановитьОтключениеБезопасногоРежима(Ложь);
	
	Протокол = ПротоколИнтернетПочты.POP3;
	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(УчетнаяЗапись, "ПротоколВходящейПочты") = "IMAP" Тогда
		Протокол = ПротоколИнтернетПочты.IMAP;
	КонецЕсли;
	
	УстановитьОтключениеБезопасногоРежима(Истина);
	Соединение = Новый ИнтернетПочта;
	Соединение.Подключиться(Профиль, Протокол);
	Попытка
		Соединение.УдалитьСообщения(НаборСообщенийДляУдаления);
		Соединение.ОчиститьУдаленныеСообщения();
	Исключение
		ИмяСобытия = НСтр("ru='Сервис почтового визирования.';
						  |en='Mail visas service'", ОбщегоНазначения.КодОсновногоЯзыка());
		ТекстСообщения = НСтр("ru='Не удалось удалить обработанные письма. %1';
							  |en='Can`t delete emails. %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
        ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
	КонецПопытки;
	Соединение.Отключиться();
	УстановитьОтключениеБезопасногоРежима(Ложь);
	
КонецПроцедуры

Процедура ОтправитьОповещенияОВизахПоПочте(ОтветственныеЗаВизы, ПараметрыДоставки)
	
	Если ОтветственныеЗаВизы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОтветственныеЗаВизы.ОбъектВизирования КАК ОбъектВизирования,
	|	ОтветственныеЗаВизы.Ответственный КАК Ответственный,
	|	ОтветственныеЗаВизы.Виза КАК Виза
	|ПОМЕСТИТЬ ОтветственныеЗаВизы
	|ИЗ
	|	&ОтветственныеЗаВизы КАК ОтветственныеЗаВизы";
	Запрос.УстановитьПараметр("ОтветственныеЗаВизы", ОтветственныеЗаВизы);
	Запрос.Выполнить();
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОтветственныеЗаВизы.ОбъектВизирования КАК ОбъектВизирования,
	|	ОтветственныеЗаВизы.Ответственный КАК Ответственный,
	|	ОтветственныеЗаВизы.Виза КАК Виза,
	|	КонтактнаяИнформация.АдресЭП КАК АдресЭП
	|ИЗ
	|	ОтветственныеЗаВизы КАК ОтветственныеЗаВизы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК КонтактнаяИнформация
	|		ПО ОтветственныеЗаВизы.Ответственный = КонтактнаяИнформация.Ссылка
	|			И (КонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПользователя))
	|			И (КонтактнаяИнформация.АдресЭП <> """")
	|ИТОГИ
	|	МАКСИМУМ(АдресЭП)
	|ПО
	|	Ответственный";
	ВыборкаОтветственных = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ШаблонЗаголовка       = НСтр("ru = 'Согласование ""%1"" по ""%2"".'");
	ШаблонОписанияПоля    = "<b>%1:</b> %2";
	
	ЭПОтправителя      = ПараметрыДоставки.УчетнаяЗапись.АдресЭлектроннойПочты;
	
	Письма             = Новый Массив;
	ОписаниеЭУ = Обработки.бит_КонсольОперативногоВизирования.ИдентификаторЭлементаУправленияКартинки();
	
	Пока ВыборкаОтветственных.Следующий() Цикл
		
		Пользователь   = ВыборкаОтветственных.Ответственный;
		МатрицаДоступа = Обработки.бит_КонсольОперативногоВизирования.МатрицаДоступа(Пользователь);
		
		ВыборкаОповещений = ВыборкаОтветственных.Выбрать();
		Пока ВыборкаОповещений.Следующий() Цикл
			ОбъектВизирования = ВыборкаОповещений.ОбъектВизирования;
			
			АдресВХранилище = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор);
			ПараметрыПолучения = Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
			ПараметрыПолучения.МатрицаДоступа		            = МатрицаДоступа;
			ПараметрыПолучения.ВыводитьВТаблицуЗначений         = Истина;
			ПараметрыПолучения.Ответственный                    = Пользователь;
			ПараметрыПолучения.ВозвращатьПорядокИЗаголовкиПолей = Истина;
			ПараметрыПолучения.Отбор.ОбъектВизирования          = ОбъектВизирования;
			ПараметрыПолучения.Отбор.Виза                       = ВыборкаОповещений.Виза;
			ПараметрыПолучения.ВариантОтбораВиз                 = 3;
			
			НастройкиПоУмолчанию = Обработки.бит_КонсольОперативногоВизирования.НастройкаПоУмолчанию(Пользователь);
			Если ЗначениеЗаполнено(НастройкиПоУмолчанию) Тогда
				НастройкиКомпоновщика = НастройкиПоУмолчанию.ХранилищеНастроек.Получить().НастройкиКомпоновщика;
				ПараметрыПолучения.НастройкиКомпоновщика         = НастройкиКомпоновщика;
				ПараметрыПолучения.ПолучатьНастройкиКомпоновщика = Истина;
			КонецЕсли;
			
			Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
			
			Результат = ПолучитьИзВременногоХранилища(АдресВХранилище);
			ТаблицаДокументов      = Результат.РезультатТаблицаЗначений;
			ПорядокИЗаголовкиПолей = Результат.ПорядокИЗаголовкиПолей;
			
			ИДСтрокиВизирования = Неопределено;
			
			КолонкиТаблицыДокументов = ТаблицаДокументов.Колонки;
			Для каждого СтрокаТаблицыВывода Из ТаблицаДокументов Цикл
				ЭлементУправления = СтрокаТаблицыВывода.ЭлементУправления; 
				Если НЕ ЗначениеЗаполнено(ЭлементУправления) Тогда
					Продолжить;
				КонецЕсли;
				Если СтрНайти(ЭлементУправления, ОписаниеЭУ) = 0 Тогда
					Продолжить;
				КонецЕсли;
				
				ТелоСообщения  = "";
				ИДСтрокиВизирования = СтрЗаменить(ЭлементУправления, ОписаниеЭУ, "");
				
				// Вывод полей согласуемого объекта.
				Для каждого ПолеВывода Из ПорядокИЗаголовкиПолей Цикл
					ИмяПоляВывода = ПолеВывода.Имя ;
					Если КолонкиТаблицыДокументов.Найти(ИмяПоляВывода) = Неопределено Тогда
						Продолжить;
					КонецЕсли;
					ЗначениеПоля = СтрокаТаблицыВывода[ИмяПоляВывода];
					Если ТипЗнч(ЗначениеПоля) = Тип("Массив") Тогда
						ЗначениеПоля = СтрСоединить(ЗначениеПоля, ";");
					КонецЕсли;
					Если НЕ ЗначениеЗаполнено(ЗначениеПоля) Тогда
						Продолжить;
					КонецЕсли;
					ТелоСообщения = ТелоСообщения + СтрШаблон(ШаблонОписанияПоля, ПолеВывода.Заголовок, ЗначениеПоля);
					ТелоСообщения = ТелоСообщения + Символы.ПС;
				КонецЦикла;
				ТелоСообщения = ТелоСообщения + Символы.ПС;
				
				// Вывод команд согласования.
				ТелоСообщения = ТелоСообщения + НСтр("ru = 'Для согласования нажмите соответствующую ссылку.'");
				ТелоСообщения = ТелоСообщения + Символы.ПС;
				
				МетаданныеОбъекта = ОбъектВизирования.Метаданные();
				ОбъектСистемы     = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(МетаданныеОбъекта.ПолноеИмя());
				
				ПараметрыОпределенияСР = бит_ВизированиеСервер.НовыеПараметрыОпределенияСпискаРешений();
				ПараметрыОпределенияСР.ОбъектСистемы = ОбъектСистемы;
				Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Организация", МетаданныеОбъекта) Тогда
					Организация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектВизирования, "Организация");
					ПараметрыОпределенияСР.Вставить("Организация", Организация);
				КонецЕсли;
				ДоступныеРешения = бит_ВизированиеСервер.ДоступныеРешения(ПараметрыОпределенияСР);
				
				ТелоРешения = "";
				ПараметрыПринятияРешения = НовыеПараметрыПринятияРешения();
				ПараметрыПринятияРешения.ПочтовыйАдрес     = ЭПОтправителя;
				ПараметрыПринятияРешения.ОбъектВизирования = ОбъектВизирования;
				ПараметрыПринятияРешения.ИДВизы            = ИДСтрокиВизирования;
				
				Для каждого ЭлементРешение Из ДоступныеРешения Цикл
					Решение = ЭлементРешение.Значение;
					Если НЕ ПустаяСтрока(ТелоРешения) Тогда
						ТелоРешения = ТелоРешения + " | ";
					КонецЕсли;
					ПараметрыПринятияРешения.Решение = Решение;
					КомандаОтвета = КомандаПринятияРешения(ПараметрыПринятияРешения);
					ТелоРешения = ТелоРешения + КомандаОтвета;
				КонецЦикла;
				ТелоСообщения        = ТелоСообщения + ТелоРешения;
				
				ПараметрыПисьма      = НовыеПараметрыПисьма();
				ПараметрыПисьма.Кому = ВыборкаОповещений.АдресЭП;
				
				ПараметрыПисьма.Тема = СтрШаблон(ШаблонЗаголовка, ВыборкаОповещений.Виза, ОбъектВизирования);
				ПараметрыПисьма.Тело = ТелоСообщения;
				
				// Вложения.
				РезультатВыборкиВложений = ВложенияОбъекта(ОбъектВизирования);
				Если РезультатВыборкиВложений <> Неопределено
					И НЕ РезультатВыборкиВложений.Пустой() Тогда
					ВыборкаВложений = РезультатВыборкиВложений.Выбрать();
					Пока ВыборкаВложений.Следующий() Цикл
						Попытка
							ДанныеВложения = РаботаСФайлами.ДанныеФайла(ВыборкаВложений.Файл);
						Исключение
							// Не удалось получить файл вложения. Например, физически удален файл на диске.
							Продолжить;
						КонецПопытки;
						Вложение = ОписаниеВложения();
						Вложение.Представление             = ДанныеВложения.ИмяФайла;
						Вложение.АдресВоВременномХранилище = ДанныеВложения.СсылкаНаДвоичныеДанныеФайла;
						Вложение.Кодировка                 = КодировкаВложения(ДанныеВложения.Кодировка);
						ПараметрыПисьма.Вложения.Добавить(Вложение);
					КонецЦикла;
				КонецЕсли;
				ПечатныеФормы = РегистрыСведений.бит_ВложенияВизЭлектроннойПочты.ВложенияЭлектроннойПочты(ОбъектВизирования);
				Для каждого Вложение Из ПечатныеФормы Цикл
					ПараметрыПисьма.Вложения.Добавить(Вложение);
				КонецЦикла;
				
				ПодготовитьПисьмоПредварительно(ПараметрыПисьма);
				
				Письмо = РаботаСПочтовымиСообщениями.ПодготовитьПисьмо(ПараметрыДоставки.УчетнаяЗапись, ПараметрыПисьма);
				Письма.Добавить(Письмо);
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	РаботаСПочтовымиСообщениями.ОтправитьПисьма(ПараметрыДоставки.УчетнаяЗапись, Письма);
	
КонецПроцедуры

Функция НовыеПараметрыПринятияРешения()
	
	Параметры = Новый Структура;
	Параметры.Вставить("ПочтовыйАдрес");
	Параметры.Вставить("ОбъектВизирования");
	Параметры.Вставить("ИДВизы");
	Параметры.Вставить("Решение", Справочники.бит_ВидыРешенийСогласования.ПустаяСсылка());
	
	Возврат Параметры;
	
КонецФункции

Функция КомандаПринятияРешения(ПараметрыПринятияРешения)
	
	ШаблонЗаголовкаОтвета = "%1 %2. $V[%3]$D[%4].";
	ШаблонСогласования    = "<a href=""mailto:%1?subject=%2&body=%3"">%4</a>";
	
	ПредставлениеКоманды = ?(ЗначениеЗаполнено(ПараметрыПринятияРешения.Решение),
							ПараметрыПринятияРешения.Решение, НСтр("ru = 'Очистить решение';
															  	|en = 'Clear desition'"));
	
	ЗаголовокОтвета = СтрШаблон(ШаблонЗаголовкаОтвета, ПараметрыПринятияРешения.Решение,
								"%22" + ПараметрыПринятияРешения.ОбъектВизирования + "%22",
								ПараметрыПринятияРешения.ИДВизы, ПараметрыПринятияРешения.Решение.UUID());
	КомандаОтвета   = СтрШаблон(ШаблонСогласования, ПараметрыПринятияРешения.ПочтовыйАдрес, ЗаголовокОтвета,
						НСтр("ru = '1. Не меняйте заголовок сообщения.'")+
						"%0D%0A2. " + НСтр("ru = 'Впишите комментарий для согласования.'") +
						"%0D%0A" +
						"%0D%0A" + НСтр("ru = 'Комментарий:'") +
						"%0D%0A", ПредставлениеКоманды);
	
	Возврат КомандаОтвета;
	
КонецФункции

Функция НовыеПараметрыПисьма()
	
	ПараметрыПисьма = Новый Структура;
	ПараметрыПисьма.Вставить("Тема", "");
	ПараметрыПисьма.Вставить("Тело", "");
	ПараметрыПисьма.Вставить("Кому", "");
	ПараметрыПисьма.Вставить("ТипТекста", Перечисления.ТипыТекстовЭлектронныхПисем.HTML);
	ПараметрыПисьма.Вставить("Вложения", Новый Массив);
	
	Возврат ПараметрыПисьма;
	
КонецФункции

Функция ВложенияОбъекта(ОбъектВизирования)
	
	// АПК:277-выкл вызов модуля типовой конфигурации
	ИмяСправочникаХранения = РаботаСФайламиСлужебный.ИмяСправочникаХраненияФайлов(ОбъектВизирования);
	// АПК:277-вкл
	Если НЕ ЗначениеЗаполнено(ИмяСправочникаХранения) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	СправочникХраненияФайлов.Ссылка КАК Файл
	|ИЗ
	|	&ИмяСправочника КАК СправочникХраненияФайлов
	|ГДЕ
	|	СправочникХраненияФайлов.ВладелецФайла = &ВладелецФайла
	|	И НЕ СправочникХраненияФайлов.ПометкаУдаления
	|	И &ЭтоГруппа = ЛОЖЬ
	|	И &Служебный = ЛОЖЬ";
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ИмяСправочника", "Справочник." + ИмяСправочникаХранения);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Служебный",
		// АПК:277-выкл вызов модуля типовой конфигурации
		?(РаботаСФайламиСлужебный.ЕстьРеквизитСлужебный(ИмяСправочникаХранения),
		// АПК:277-вкл
		"СправочникХраненияФайлов.Служебный", "ЛОЖЬ"));
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ЭтоГруппа", 
		?(Метаданные.Справочники[ИмяСправочникаХранения].Иерархический,
		"СправочникХраненияФайлов.ЭтоГруппа", "ЛОЖЬ"));
		
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ВладелецФайла", ОбъектВизирования);
	
	Возврат Запрос.Выполнить();
	
КонецФункции

Функция КодировкаВложения(КодировкаИсточника)
	
	Если КодировкаИсточника <> "utf-8_WithoutBOM" Тогда
		Возврат КодировкаИсточника;
	КонецЕсли;
	
	Возврат бит_ОбщегоНазначения.КодировкаФайловВложенийБезСигнатуры();
	
КонецФункции

Процедура ПодготовитьПисьмоПредварительно(ПараметрыПисьма)
	
	ТелоСообщения = ПараметрыПисьма.Тело;
	
	Если ПараметрыПисьма.ТипТекста = Перечисления.ТипыТекстовЭлектронныхПисем.HTML Тогда
		ШаблонТела =
		"<html>
		|<body>
		|<div style=""font-family:Arial;font-size:10pt;"">
		|%1
		|</div>
		|</body>
		|</html>";
		ТелоСообщения = СтрЗаменить(ТелоСообщения, Символы.ПС, Символы.ПС + "<br>");
		ТелоСообщения = СтрШаблон(ШаблонТела, ТелоСообщения);
	КонецЕсли;
	
	ПараметрыПисьма.Тело = ТелоСообщения;
	
КонецПроцедуры

// Создает профиль переданной учетной записи для подключения к почтовому серверу.
//
// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиЭлектроннойПочты - учетная запись.
//
// Возвращаемое значение:
//  ИнтернетПочтовыйПрофиль - профиль учетной записи;
//  Неопределено - не удалось получить учетную запись по ссылке.
//
Функция ИнтернетПочтовыйПрофиль(УчетнаяЗапись, ДляПолучения = Ложь)
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	УчетныеЗаписиЭлектроннойПочты.СерверВходящейПочты КАК АдресСервераIMAP,
	|	УчетныеЗаписиЭлектроннойПочты.ПортСервераВходящейПочты КАК ПортIMAP,
	|	УчетныеЗаписиЭлектроннойПочты.ИспользоватьЗащищенноеСоединениеДляВходящейПочты КАК ИспользоватьSSLIMAP,
	|	УчетныеЗаписиЭлектроннойПочты.Пользователь КАК ПользовательIMAP,
	|	УчетныеЗаписиЭлектроннойПочты.СерверВходящейПочты КАК АдресСервераPOP3,
	|	УчетныеЗаписиЭлектроннойПочты.ПортСервераВходящейПочты КАК ПортPOP3,
	|	УчетныеЗаписиЭлектроннойПочты.ИспользоватьЗащищенноеСоединениеДляВходящейПочты КАК ИспользоватьSSLPOP3,
	|	УчетныеЗаписиЭлектроннойПочты.Пользователь КАК Пользователь,
	|	УчетныеЗаписиЭлектроннойПочты.СерверИсходящейПочты КАК АдресСервераSMTP,
	|	УчетныеЗаписиЭлектроннойПочты.ПортСервераИсходящейПочты КАК ПортSMTP,
	|	УчетныеЗаписиЭлектроннойПочты.ИспользоватьЗащищенноеСоединениеДляИсходящейПочты КАК ИспользоватьSSLSMTP,
	|	УчетныеЗаписиЭлектроннойПочты.ТребуетсяВходНаСерверПередОтправкой КАК POP3ПередSMTP,
	|	УчетныеЗаписиЭлектроннойПочты.Пользователь КАК ПользовательSMTP,
	|	УчетныеЗаписиЭлектроннойПочты.ВремяОжидания КАК Таймаут,
	|	УчетныеЗаписиЭлектроннойПочты.ПротоколВходящейПочты КАК Протокол,
	|	УчетныеЗаписиЭлектроннойПочты.ПриОтправкеПисемТребуетсяАвторизация КАК ПриОтправкеПисемТребуетсяАвторизация
	|ИЗ
	|	Справочник.УчетныеЗаписиЭлектроннойПочты КАК УчетныеЗаписиЭлектроннойПочты
	|ГДЕ
	|	УчетныеЗаписиЭлектроннойПочты.Ссылка = &Ссылка";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", УчетнаяЗапись);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Результат = Неопределено;
	Если Выборка.Следующий() Тогда
		СписокСвойствIMAP = "ИспользоватьSSLIMAP,АдресСервераIMAP,ПортIMAP,ПользовательIMAP";
		СписокСвойствPOP3 = "АдресСервераPOP3,ПортPOP3,ИспользоватьSSLPOP3,Пользователь";
		СписокСвойствSMTP = "АдресСервераSMTP,ПортSMTP,ИспользоватьSSLSMTP";
		
		УстановитьПривилегированныйРежим(Истина);
		Пароли = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(УчетнаяЗапись, "Пароль,ПарольSMTP");
		УстановитьПривилегированныйРежим(Ложь);
		
		Результат = Новый ИнтернетПочтовыйПрофиль;
		Если ДляПолучения Тогда
			Если Выборка.Протокол = "IMAP" Тогда
				ТребуемыеСвойства = СписокСвойствIMAP;
				Результат.ПарольIMAP = Пароли.Пароль;
			Иначе
				ТребуемыеСвойства = СписокСвойствPOP3;
				Результат.Пароль = Пароли.Пароль;
			КонецЕсли;
		Иначе
			ТребуемыеСвойства = СписокСвойствSMTP;
			Если Выборка.ПриОтправкеПисемТребуетсяАвторизация И Не Выборка.POP3ПередSMTP Тогда
				ТребуемыеСвойства = ТребуемыеСвойства + ",ПользовательSMTP";
			КонецЕсли;
			Результат.ПарольSMTP = Пароли.ПарольSMTP;
			Если Выборка.Протокол <> "IMAP" И Выборка.POP3ПередSMTP Тогда
				ТребуемыеСвойства = ТребуемыеСвойства + ",POP3ПередSMTP," + СписокСвойствPOP3;
				Результат.Пароль = Пароли.Пароль;
			КонецЕсли;
			Если Выборка.Протокол = "IMAP" Тогда
				ТребуемыеСвойства = ТребуемыеСвойства + "," + СписокСвойствIMAP;
				Результат.ПарольIMAP =Пароли.Пароль;
			КонецЕсли;
		КонецЕсли;
		ТребуемыеСвойства = ТребуемыеСвойства + ",Таймаут";
		ЗаполнитьЗначенияСвойств(Результат, Выборка, ТребуемыеСвойства);
		Если Результат.ПользовательSMTP = "" Тогда
			Результат.ПарольSMTP = "";
		КонецЕсли;
	КонецЕсли;
	
	Если Результат.ПарольIMAP = "" Тогда
		Результат.ПарольIMAP = Результат.ПарольSMTP;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

