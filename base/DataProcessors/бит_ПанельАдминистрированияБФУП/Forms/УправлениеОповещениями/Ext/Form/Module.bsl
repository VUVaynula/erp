
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Пользователи.ЭтоПолноправныйПользователь() Тогда
		РегламентноеЗадание = НайтиРегламентноеЗадание("бит_ОбработкаСобытийОповещений");
		Если РегламентноеЗадание <> Неопределено Тогда
			ОбработкаСобытийОповещенийИспользование = РегламентноеЗадание.Использование;
			ОбработкаСобытийОповещенийРасписание    = РегламентноеЗадание.Расписание;
		КонецЕсли;
		
		РегламентноеЗадание = НайтиРегламентноеЗадание("бит_ОтправкаОповещений");
		Если РегламентноеЗадание <> Неопределено Тогда
			ОтправкаОповещенийИспользование = РегламентноеЗадание.Использование;
			ОтправкаОповещенийРасписание    = РегламентноеЗадание.Расписание;
		КонецЕсли;
		
		РегламентноеЗадание = НайтиРегламентноеЗадание("бит_УдалениеОбработанныхЗаписейРегистрацииОповещений");
		Если РегламентноеЗадание <> Неопределено Тогда
			УдалениеОбработанныхЗаписейРегистрацииОповещенийИспользование = РегламентноеЗадание.Использование;
			УдалениеОбработанныхЗаписейРегистрацииОповещенийРасписание    = РегламентноеЗадание.Расписание;
		КонецЕсли;
		
		РегламентноеЗадание = НайтиРегламентноеЗадание("бит_УдалениеОповещений");
		Если РегламентноеЗадание <> Неопределено Тогда
			УдалениеОповещенийИспользование = РегламентноеЗадание.Использование;
			УдалениеОповещенийРасписание    = РегламентноеЗадание.Расписание;
		КонецЕсли;
		
		РегламентноеЗадание = НайтиРегламентноеЗадание("бит_РегистрацияОповещенийОВизировании");
		Если РегламентноеЗадание <> Неопределено Тогда
			РегистрацияОповещенийОВизированииИспользование = РегламентноеЗадание.Использование;
			РегистрацияОповещенийОВизированииРасписание    = РегламентноеЗадание.Расписание;
		КонецЕсли;
		
		РегламентноеЗадание = НайтиРегламентноеЗадание("бит_РегистрацияНапоминанийПоДоговорам");
		Если РегламентноеЗадание <> Неопределено Тогда
			РегистрацияНапоминанийПоДоговорамИспользование = РегламентноеЗадание.Использование;
			РегистрацияНапоминанийПоДоговорамРасписание    = РегламентноеЗадание.Расписание;
		КонецЕсли;
		
		РегламентноеЗадание = НайтиРегламентноеЗадание("бит_РегистрацияНапоминанийОбОплате");
		Если РегламентноеЗадание <> Неопределено Тогда
			РегистрацияНапоминанийОбОплатеИспользование = РегламентноеЗадание.Использование;
			РегистрацияНапоминанийОбОплатеРасписание    = РегламентноеЗадание.Расписание;
		КонецЕсли;
		
	Иначе
		Элементы.ГруппаРегламентныеЗадания.Видимость = Ложь;
	КонецЕсли;

	// Обновление состояния элементов.
	УстановитьДоступность();
	
КонецПроцедуры

#КонецОбласти

