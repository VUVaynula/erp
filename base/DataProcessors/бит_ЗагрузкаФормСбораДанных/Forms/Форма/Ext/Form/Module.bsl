
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	
	Если НЕ бит_ЛицензированиеБФСерверПереопределяемый.СборкаДоступна("УХ") Тогда	
		Отказ = Истина;	
	КонецЕсли; 
	
	КоллекцияПсевдоМета = Новый Структура;
	Объект.РежимСообщений = "Все";
	Объект.РежимЗаписи = "Запись";
	
	ЗаполнитьКэшЗначений();
	
	УстановитьЗначенияПоУмолчанию();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
    УстановитьЗаголовокФормы();	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПутьНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
		
	# Если ВебКлиент Тогда 
		ТекстСообщения = НСтр("ru='Работа с файлами Microsoft Excel в режиме Веб-клиента недоступна.';
						  	  |en='Working with Microsoft Excel files in mobile client mode is not available.'");
		ВызватьИсключение ТекстСообщения;
	# КонецЕсли
	
	ОповещениеПФ = Новый ОписаниеОповещения("ПутьВыборЗавершение", ЭтотОбъект);
	
	Если Объект.РежимВыбора = 1 Тогда		
		ПараметрыЗагрузки = ФайловаяСистемаКлиент.ПараметрыЗагрузкиФайла();
		ПараметрыЗагрузки.Диалог.Заголовок = НСтр("ru='Выбор файла';en='File selection'");
	    ПараметрыЗагрузки.Диалог.Фильтр = НСтр("ru='Все файлы Microsoft Excel (*.xls, *.xlsx)|*.xls; *.xlsx';
											   |en='All Microsoft Excel Files (*.xls, *.xlsx)|*.xls; *.xlsx'");
		ФайловаяСистемаКлиент.ЗагрузитьФайлы(ОповещениеПФ, ПараметрыЗагрузки, Объект.Путь);
	Иначе	
		
		ФайловаяСистемаКлиент.ВыбратьКаталог(ОповещениеПФ,, Объект.Путь);
	КонецЕсли;
	 	
КонецПроцедуры

// Процедура обработчик оповещения "ПутьВыборЗавершение".
// 
// Параметры:
// ВыбранныеПути - Массив.
// ДополнительныеДанные - Структура.
// 
&НаКлиенте 
Процедура ПутьВыборЗавершение(ВыбранныеПути, ДополнительныеДанные) Экспорт

	Если НЕ ЗначениеЗаполнено(ВыбранныеПути) Тогда
		Возврат;
	КонецЕсли;
	
	ВыбранныеФайлы.Очистить();
	
	Если ТипЗнч(ВыбранныеПути) = Тип("Строка") Тогда
			
		Объект.Путь = ВыбранныеПути;
		
	ИначеЕсли ТипЗнч(ВыбранныеПути) = Тип("Массив") Тогда

		Объект.Путь = ВыбранныеПути[0].Имя;

		Для каждого ТекПуть Из ВыбранныеПути Цикл			 
			ВыбранныеФайлы.Добавить(ТекПуть.Имя);			 
		КонецЦикла; 

	КонецЕсли; 
	
	УправлениеДоступностьюЭлементов(Ложь);
	ПодключитьОбработчикОжидания("ОжиданиеВыбораПути", 0.1, Истина);
		
КонецПроцедуры	// ПутьВыборЗавершение

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДереводанные

&НаКлиенте
Процедура ДеревоДанныеПредставлениеОткрытие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекущаяСтрока = Элементы.ДеревоДанные.ТекущиеДанные;
	
	Если НЕ ПустаяСтрока(ТекущаяСтрока.ИмяФайла) Тогда
	
		ФайловаяСистемаКлиент.ОткрытьФайл(ТекущаяСтрока.ИмяФайла);
	
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоДанныеВидПроформыНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоДанныеВыполнятьПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.ДеревоДанные.ТекущиеДанные;
	
	Если ТекущаяСтрока <> Неопределено Тогда
		
		КодДействия = ?(ТекущаяСтрока.Выполнять, 1, 0); 
		
		ИзменитьФлажки(ТекущаяСтрока,КодДействия);
		
		// Если устанавливаем флаг для листа, то нужно установить флаг и для файла.
		СтрокаРодитель = ТекущаяСтрока.ПолучитьРодителя();
		
		Если СтрокаРодитель <> Неопределено И ТекущаяСтрока.Выполнять Тогда		
			СтрокаРодитель.Выполнять = Истина;		
		КонецЕсли; 
		
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

