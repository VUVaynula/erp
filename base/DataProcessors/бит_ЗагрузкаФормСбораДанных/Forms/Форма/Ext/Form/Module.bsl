	Оповещение = Новый ОписаниеОповещения("НастройкиЗавершение", ЭтотОбъект);
	ОткрытьФорму("Обработка.бит_ЗагрузкаФормСбораДанных.Форма.ФормаНастройки",
				 ПараметрыФормы, ЭтотОбъект,,,, Оповещение, РежимОкна);
	
