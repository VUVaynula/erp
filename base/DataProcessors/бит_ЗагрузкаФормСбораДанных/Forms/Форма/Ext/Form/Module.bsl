// Процедура обработчик оповещения "НастройкиЗавершение".
// 
// Параметры:
// Рез - Структура.
// ДополнительныеДанные - Структура.
// 
&НаКлиенте 
Процедура НастройкиЗавершение(Результат, ДополнительныеДанные) Экспорт

	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		
		Объект.РежимСообщений 	   = Результат.РежимСообщений;
		Объект.РежимЗаписи 		   = Результат.РежимЗаписи;
		Объект.РазрешитьПерезапись = Результат.РазрешитьПерезапись;
		
	КонецЕсли; 
	
КонецПроцедуры	// НастройкиЗавершение

&НаКлиенте
