КонецПроцедуры

&НаКлиенте
Процедура КомандаНастройки(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("РежимСообщений"	 , Объект.РежимСообщений);
	ПараметрыФормы.Вставить("РежимЗаписи"		 , Объект.РежимЗаписи);
	ПараметрыФормы.Вставить("РазрешитьПерезапись", Объект.РазрешитьПерезапись);
	
