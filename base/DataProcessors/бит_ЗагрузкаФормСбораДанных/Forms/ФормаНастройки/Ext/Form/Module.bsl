
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РежимСообщений 		= Параметры.РежимСообщений;
	РежимЗаписи 		= Параметры.РежимЗаписи;
	РазрешитьПерезапись = Параметры.РазрешитьПерезапись;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Команда"			  , "ОК");
	СтруктураПараметров.Вставить("РежимСообщений"	  , РежимСообщений);
	СтруктураПараметров.Вставить("РежимЗаписи"   	  , РежимЗаписи);
	СтруктураПараметров.Вставить("РазрешитьПерезапись", РазрешитьПерезапись);
	
	Закрыть(СтруктураПараметров);
	
КонецПроцедуры

#КонецОбласти
