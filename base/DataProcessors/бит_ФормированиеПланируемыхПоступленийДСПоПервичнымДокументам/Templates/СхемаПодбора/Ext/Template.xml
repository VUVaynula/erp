			<dataSource>ИсточникДанных1</dataSource>
			<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Реквизиты.Ссылка КАК Документ,
	Реквизиты.Номер КАК Номер,
	Реквизиты.Дата КАК Дата,
	Реквизиты.Организация КАК Организация,
	Реквизиты.Партнер КАК Партнер,
	Реквизиты.Контрагент КАК Контрагент,
	Реквизиты.Валюта КАК Валюта,
	Реквизиты.СуммаДокумента КАК СуммаДокумента,
	ВЫБОР
		КОГДА Реквизиты.ПометкаУдаления = ИСТИНА
			ТОГДА 2
		КОГДА Реквизиты.Проведен = ИСТИНА
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК СостояниеДокумента,
	ТИПЗНАЧЕНИЯ(Реквизиты.Ссылка) КАК ВидДокумента,
	Реквизиты.ПометкаУдаления КАК ПометкаУдаления,
	Реквизиты.Проведен КАК Проведен,
	ЕСТЬNULL(ДополнительныеАналитикиЦФО.ЗначениеАналитики, НЕОПРЕДЕЛЕНО) КАК ЦФО,
	ЕСТЬNULL(ДополнительныеАналитикиСтатья.ЗначениеАналитики, НЕОПРЕДЕЛЕНО) КАК СтатьяОборотов,
	Реквизиты.Договор КАК Договор
ИЗ
	Документ.РеализацияУслугПрочихАктивов КАК Реквизиты
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_ДополнительныеАналитики КАК ДополнительныеАналитикиЦФО
		ПО Реквизиты.Ссылка = ДополнительныеАналитикиЦФО.Объект
			И (ДополнительныеАналитикиЦФО.Аналитика = ЗНАЧЕНИЕ(ПланВидовХарактеристик.бит_ВидыДополнительныхАналитик.ЦФО))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_ДополнительныеАналитики КАК ДополнительныеАналитикиСтатья
		ПО Реквизиты.Ссылка = ДополнительныеАналитикиСтатья.Объект
			И (ДополнительныеАналитикиСтатья.Аналитика = ЗНАЧЕНИЕ(ПланВидовХарактеристик.бит_ВидыДополнительныхАналитик.СтатьяОборотов))
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПозицияПоступления КАК Позиции
		ПО Реквизиты.Ссылка = Позиции.ДокументОснование И НЕ Позиции.ПометкаУдаления 
ГДЕ
	Позиции.Ссылка ЕСТЬ NULL
	И Реквизиты.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
	И НЕ Реквизиты.ПометкаУдаления</query>
