
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ВидыСравнения = бит_МеханизмПолученияДанных.СформироватьСписокВыбораДляОтборовВОтчете("Массив");
	Элементы.ОтборВОтчетеВидСравнения.СписокВыбора.ЗагрузитьЗначения(ВидыСравнения);
	
	ИсточникДанныхТипы = Новый Массив;
	ИсточникДанныхТипы.Добавить(Тип("СправочникСсылка.бит_СпособыКомпоновкиИсточниковДанных"));
	ИсточникДанныхТипы.Добавить(Тип("СправочникСсылка.бит_ИсточникиДанных"));	
	ТипыИсточниковДанных = бит_ОбщегоНазначения.ПодготовитьСписокВыбораТипа(ИсточникДанныхТипы);
	
	ОписаниеПроизвольногоТипа = бит_ОбщегоНазначения.ОписаниеПроизвольногоТипа();
	
	// Анализ параметров формы.
	Если Параметры.ЭтоЗаполнениеИзДокументаОперации Тогда		
		Параметры.Свойство("ОбъектСистемы", Объект.ОбъектСистемы);
		Если Параметры.Свойство("ИмяОбъектаСистемы") Тогда		
			Объект.ОбъектСистемы = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(Параметры.ИмяОбъектаСистемы);   		
		КонецЕсли;			
		Если ЗначениеЗаполнено(Объект.ОбъектСистемы) Тогда		
			Элементы.ОбъектСистемы.ТолькоПросмотр = Истина;
			ОбновитьСтруктуруТаблицыДанных();		
		КонецЕсли; 	
	Иначе
		// Восстановление настроек при необходимости.
		УстановитьЗначенияПоУмолчанию();		
		Если ЗначениеЗаполнено(Объект.ОбъектСистемы) Тогда		
			ОбновитьСтруктуруТаблицыДанных();		
		КонецЕсли; 	
	КонецЕсли;        	 
																			   
	Если ЗначениеЗаполнено(Параметры.ДокументЗаполнения) Тогда
		
		Объект.ДокументЗаполнения = Параметры.ДокументЗаполнения;
		ТекстРеквизитов = "Дата";
		МетаОбъект = Объект.ДокументЗаполнения.Метаданные();
		Если бит_РаботаСМетаданными.ЕстьРеквизит("Организация", МетаОбъект) Тогда  		  
			ТекстРеквизитов = ТекстРеквизитов + ", Организация";
		КонецЕсли; 		  
		Если бит_РаботаСМетаданными.ЕстьРеквизит("Сценарий", МетаОбъект) Тогда   		  
			ТекстРеквизитов = ТекстРеквизитов + ", Сценарий";
		КонецЕсли; 
		
		ДанныеДок = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.ДокументЗаполнения, ТекстРеквизитов);
		ЗаполнитьЗначенияСвойств(Объект, ДанныеДок);
		ДатаЗаполнения = Объект.ДокументЗаполнения.Дата;		
		   
	Иначе
		Параметры.Свойство("Сценарий",    Объект.Сценарий);
		Параметры.Свойство("Организация", Объект.Организация);
		Параметры.Свойство("ДатаДок",     ДатаЗаполнения)
	КонецЕсли; 
	
	// Режим работы обработки.
	ТекРежим = ?(ЗначениеЗаполнено(Параметры.Режим), Параметры.Режим, "Групповой");
		
	Если ЗначениеЗаполнено(ДатаЗаполнения) Тогда		
		Объект.Период.Вариант 	    = ВариантСтандартногоПериода.ПроизвольныйПериод;
		Объект.Период.ДатаНачала    = НачалоМесяца(ДатаЗаполнения);
		Объект.Период.ДатаОкончания = КонецМесяца(ДатаЗаполнения);		
	ИначеЕсли Не ЗначениеЗаполнено(Объект.Период) Тогда	
		Объект.Период.Вариант = ВариантСтандартногоПериода.ЭтотГод;		
	КонецЕсли; 
	
	ЗакрыватьПриВыборе = Ложь;
	ЗакрыватьПриЗакрытииВладельца = Истина;

	УстановитьВидимостьПоРежиму(ТекРежим);
	ОбработатьИзменениеНастроек(ЭтотОбъект);
	
	УстановитьЗаголовокФормы(Заголовок);

КонецПроцедуры // ПриСозданииНаСервере()

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзменениеПериода" И УникальныйИдентификатор = Параметр Тогда
	
		ПриИзмененииПериода();
	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаНачалаПриИзменении(Элемент)
	
	ПриИзмененииПериода();
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаОкончанияПриИзменении(Элемент)
	
	ПриИзмененииПериода();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектСистемыПриИзменении(Элемент)
	
	// Безусловное выполнение.
	ОбъектСистемыИзменение(); 
	
	ИзмененыНастройки = Истина;	
	ОбработатьИзменениеНастроек(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектСистемыНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СписокВидовОбъектов = Новый СписокЗначений;
	СписокВидовОбъектов.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.РегистрБухгалтерии"));
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВидыОбъектов", 	 			  СписокВидовОбъектов);
	ПараметрыФормы.Вставить("ТекущийОбъектСистемы", 		  Объект.ОбъектСистемы);
	ОткрытьФорму("ОбщаяФорма.бит_ФормаВыбораОбъектовСистемы", ПараметрыФормы,Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ИсточникДанныхНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	бит_РаботаСДиалогамиКлиент.НачалоВыбораСоставного(ЭтотОбъект,
		Элемент, Объект, "ИсточникДанных", ТипыИсточниковДанных, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ИсточникДанныхПриИзменении(Элемент)
	
	ИсточникДанныхИзменение();
	
	ИзмененыНастройки = Истина;
	ОбработатьИзменениеНастроек(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ИсточникДанныхОчистка(Элемент, СтандартнаяОбработка)
	
	Элементы.ИсточникДанных.ВыбиратьТип = Истина;
	
	ИзмененыНастройки = Истина;
	ОбработатьИзменениеНастроек(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	ИзмененыНастройки = Истина;
	ОбработатьИзменениеНастроек(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура СценарийПриИзменении(Элемент)
	
	ИзмененыНастройки = Истина;
	ОбработатьИзменениеНастроек(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаДанные

&НаКлиенте
Процедура ТаблицаДанныеВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Исключения = Новый Массив;
	Исключения.Добавить("ТаблицаДанныеВыполнять");
	Исключения.Добавить("ТаблицаДанныеПериод");
	
	Если Исключения.Найти(Поле.Имя) = Неопределено Тогда
		ИмяРеквизита = СтрЗаменить(Поле.Имя, "ТаблицаДанные_","");
		ТекСтрока = Элементы.ТаблицаДанные.ТекущиеДанные;
		ТекЗначение = ТекСтрока[ИмяРеквизита];		
		Если ЗначениеЗаполнено(ТекЗначение) Тогда		
			ПоказатьЗначение(, ТекЗначение);		
		КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСозданныеОбъекты

&НаКлиенте
Процедура СозданныеОбъектыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле <> Элементы.СозданныеОбъектыВыполнять Тогда
		ТекущиеДанные = Элементы.СозданныеОбъекты.ТекущиеДанные;
		ПоказатьЗначение(, ТекущиеДанные.СозданныйОбъект);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыОтборВОтчете
     
&НаКлиенте
Процедура ОтборВОтчетеПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТекущаяСтрока = Элементы.ОтборВОтчете.ТекущиеДанные;	
	Если ТекущаяСтрока.Значение = Неопределено Тогда		
		Элементы.ОтборВОтчетеЗначение.ВыбиратьТип = Истина;		
	Иначе		
		Элементы.ОтборВОтчетеЗначение.ВыбиратьТип = Ложь;		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборВОтчетеПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	ИзмененыНастройки = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборВОтчетеВидСравненияПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ОтборВОтчете.ТекущиеДанные;
	ОтборВОтчетеВидСравненияПриИзмененииСервер(ТекущиеДанные.ПолучитьИдентификатор());	

КонецПроцедуры

&НаКлиенте
Процедура ОтборВОтчетеЗначениеПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ОтборВОтчете.ТекущиеДанные;
	ОтборВОтчетеЗначениеПриИзмененииСервер(ТекущиеДанные.ПолучитьИдентификатор());
		
КонецПроцедуры

&НаКлиенте
Процедура ОтборВОтчетеЗначениеОчистка(Элемент, СтандартнаяОбработка)
	
	Элементы.ОтборВОтчетеЗначение.ВыбиратьТип = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаПараметры

&НаКлиенте
Процедура ТаблицаПараметрыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТекущиеДанные = Элементы.ТаблицаПараметры.ТекущиеДанные;	 	
	Если НоваяСтрока И НЕ Копирование Тогда  		
		ТекущиеДанные.ВидПараметра = ПредопределенноеЗначение("Перечисление.бит_ВидыПараметровЗапроса.Значение");   			
	КонецЕсли; 
	ПредыдущийВидПараметра = ТекущиеДанные.ВидПараметра;
	ОграничитьОписаниеТиповПараметра();
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПараметрыПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	ИзмененыНастройки = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПараметрыВидПараметраПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ТаблицаПараметры.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено Тогда
		ИД = Элементы.ТаблицаПараметры.ТекущиеДанные.ПолучитьИдентификатор();
		ИзменитьВидПараметра(ИД);
		ПредыдущийВидПараметра = ТекущиеДанные.ВидПараметра;
		ОграничитьОписаниеТиповПараметра();
	КонецЕсли; 
		
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПараметрыЗначениеПараметраНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ТаблицаПараметры.ТекущиеДанные;		
	Если ТекущиеДанные.ВидПараметра = ПредопределенноеЗначение("Перечисление.бит_ВидыПараметровЗапроса.Выражение") Тогда  		
		СтандартнаяОбработка = Ложь;			
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПараметрыЗначениеПараметраОчистка(Элемент, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ТаблицаПараметры.ТекущиеДанные;	
	Если ТекущиеДанные.ВидПараметра = ПредопределенноеЗначение("Перечисление.бит_ВидыПараметровЗапроса.Значение") Тогда		
		Элементы.ТаблицаПараметрыЗначениеПараметра.ВыбиратьТип = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

#Область РаботаСНастройками

&НаКлиенте
Процедура ПоказатьНастройки(Команда)
	
	ОткрытьНастройки();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьНастройки(Команда)
	
	СкрытьНастройки();
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьНастройки(Команда)
	
	ПараметрыФормы = ПараметрыХраненияНастроек();
	ПараметрыФормы.Вставить("СтруктураНастройки" , СохраняемыеНастройки());
	
	Если ЗначениеЗаполнено(ТекущаяНастройка) Тогда	
		ПараметрыФормы.Вставить("СохраненнаяНастройка", ТекущаяНастройка);	
	КонецЕсли; 
												
	ОповещениеЗакрытиеФормы = Новый ОписаниеОповещения("СохранитьНастройкиЗавершение", ЭтотОбъект);
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаСохранения", 
		ПараметрыФормы, ЭтотОбъект,,,, ОповещениеЗакрытиеФормы, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьНастройки(Команда)
	
	ПараметрыФормы = ПараметрыХраненияНастроек();
	
	ОповещениеЗакрытиеФормы = Новый ОписаниеОповещения("ВыбратьНастройкиЗавершение", ЭтотОбъект);
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаЗагрузки", 
		ПараметрыФормы, ЭтотОбъект,,,, ОповещениеЗакрытиеФормы, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСПериодом

&НаКлиенте
Процедура НастроитьПериод(Команда)
	
	бит_РаботаСДиалогамиКлиент.ОткрытьДиалогСтандартногоПериода(Объект, "Период",, УникальныйИдентификатор);
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСТаблицейФормыТаблицаДанные

&НаКлиенте
Процедура ОбновитьДанные(Команда)
	
	Если ТаблицаДанные.Количество() = 0 Тогда
		НачатьОтложенноеОбновлениеДанных();
	Иначе	
		Если ПодтверждениеОчисткиДанных() Тогда
        	НачатьОтложенноеОбновлениеДанных();		 	
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ДанныеУстановитьФлаги(Команда)
	
	бит_РаботаСДиалогамиКлиент.ОбработатьФлагиТаблицы(ТаблицаДанные, "Выполнять", 1, Элементы.ТаблицаДанные);
	
КонецПроцедуры

