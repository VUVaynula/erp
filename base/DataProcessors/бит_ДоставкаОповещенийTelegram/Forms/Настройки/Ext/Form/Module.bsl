
#Область ОбработчикиСобытийФормы
	
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	НастройкиДоставки = Параметры.НастройкиДоставки;
	Если ЗначениеЗаполнено(НастройкиДоставки) Тогда
		ЗаполнитьЗначенияСвойств(Объект, НастройкиДоставки);
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		НастройкиДоставки = НастройкиДоставки();
		ОповеститьОВыборе(НастройкиДоставки);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаПроверитьТокен(Команда)
	
	КомандаПроверитьТокенНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура получает структуру настройки доставки.
// 
&НаСервере
Функция НастройкиДоставки()
	
	ОбработкаОбъект   = РеквизитФормыВЗначение("Объект");
	НастройкиДоставки = бит_ОповещенияСервер.НастройкиДоставки(ОбработкаОбъект);

	Возврат НастройкиДоставки;
	
КонецФункции

&НаСервере
Процедура КомандаПроверитьТокенНаСервере()
	
	Если НЕ ЗначениеЗаполнено(Объект.Бот) Тогда		
		ТекстСообщения = НСтр("ru='Не заполнен бот.';en='Bot is empty.'");		
	Иначе		
		РезультатПроверки = Справочники.бит_БотыTelegram.ПроверитьТокен(Объект.Бот.Токен);		
		Если РезультатПроверки.Существует Тогда			
			ТекстСообщения = НСтр("ru='Проверка выполнена успешно.';en='Verification was successful.'");			
		Иначе			
			ТекстСообщения = НСтр("ru='Ошибка выполнения проверки. %1.';en='Run-time error checking. %1.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, РезультатПроверки.Сообщение);			
		КонецЕсли;		
	КонецЕсли; 
	
	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	
КонецПроцедуры

#КонецОбласти
