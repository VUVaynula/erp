#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс
		
// Выводит историю визирования.
// 
// Параметры:
//  ТабличныйДокумент - ТабличныйДокумент - Табличный документ в который будет выведена история.
//  ОбъектВизирования - ДокументСсылка - Объект визирования.
// 
Процедура ВывестиИсториюВизирования(ТабличныйДокумент, ОбъектВизирования)  Экспорт
	
	ТабличныйДокумент.Очистить();
	
	Макет = Обработки.бит_УстановкаВиз.ПолучитьМакет("ИсторияВизирования");
	
	ОблЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОблВиза      = Макет.ПолучитьОбласть("Виза");
	ОблШапкаТаблицы		   = Макет.ПолучитьОбласть("ШапкаТаблицы");
	ОблСообщениеЗаголовок1 = Макет.ПолучитьОбласть("СообщениеЗаголовокПервое");
	ОблСообщениеЗаголовок  = Макет.ПолучитьОбласть("СообщениеЗаголовок");
	ОблСообщениеТекст      = Макет.ПолучитьОбласть("СообщениеТекст");
	ОблСообщениеТекст2     = Макет.ПолучитьОбласть("СообщениеТекст2");
	ОблПоследняя           = Макет.ПолучитьОбласть("Последняя");	
	
	ЦветаВидовСтрок = Новый Структура;
	ЦветаВидовСтрок.Вставить("История"	, ЦветаСтиля.бит_ФонПодписьВерна);
	ЦветаВидовСтрок.Вставить("Сообщение", ЦветаСтиля.ИзмененноеЗначениеРеквизитаФон);
	ЦветаВидовСтрок.Вставить("Задача"	, ЦветаСтиля.ФонУправляющегоПоля);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ОбъектВизирования", ОбъектВизирования);
	Запрос.УстановитьПараметр("ТекущаяДата"		 , ТекущаяДатаСеанса());
	Запрос.Текст =
	"ВЫБРАТЬ
	|	УстановленныеВизы.Виза КАК Виза,
	|	УстановленныеВизы.Решение КАК Решение
	|ИЗ
	|	РегистрСведений.бит_УстановленныеВизы КАК УстановленныеВизы
	|ГДЕ
	|	УстановленныеВизы.Объект = &ОбъектВизирования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИсторияИзмененияСтатусов.Период КАК Период,
	|	ИсторияИзмененияСтатусов.Объект КАК Объект,
	|	ИсторияИзмененияСтатусов.ВидСтатуса КАК ВидСтатуса,
	|	ИсторияИзмененияСтатусов.Статус КАК Статус,
	|	ИсторияИзмененияСтатусов.Пользователь КАК Пользователь
	|ПОМЕСТИТЬ ВТИсторияИзмененияСтатусов
	|ИЗ
	|	РегистрСведений.бит_ИсторияИзмененияСтатусовОбъектов КАК ИсторияИзмененияСтатусов
	|ГДЕ
	|	ИсторияИзмененияСтатусов.Объект = &ОбъектВизирования
	|	И ИсторияИзмененияСтатусов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИсторияИзмененияВиз.Период КАК Период,
	|	""История"" КАК Вид,
	|	ИсторияИзмененияВиз.Объект КАК Объект,
	|	ИсторияИзмененияВиз.Виза КАК Виза,
	|	ИсторияИзмененияВиз.ИД КАК ИД,
	|	ИсторияИзмененияВиз.Пользователь КАК Пользователь,
	|	ИсторияИзмененияВиз.Комментарий КАК Комментарий,
	|	ИсторияИзмененияВиз.Решение КАК Решение,
	|	ИсторияИзмененияВиз.ДатаКрайняя КАК ДатаКрайняя,
	|	NULL КАК РезультатВыполнения,
	|	NULL КАК Состояние,
	|	ВЫБОР
	|		КОГДА ИсторияИзмененияВиз.ДатаКрайняя <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ВЫБОР
	|					КОГДА ИсторияИзмененияВиз.Период = ДАТАВРЕМЯ(1, 1, 1)
	|						ТОГДА ВЫБОР
	|								КОГДА ИсторияИзмененияВиз.ДатаКрайняя < &ТекущаяДата
	|									ТОГДА ИСТИНА
	|								ИНАЧЕ ЛОЖЬ
	|							КОНЕЦ
	|					ИНАЧЕ ВЫБОР
	|							КОГДА ИсторияИзмененияВиз.ДатаКрайняя < ИсторияИзмененияВиз.Период
	|								ТОГДА ИСТИНА
	|							ИНАЧЕ ЛОЖЬ
	|						КОНЕЦ
	|				КОНЕЦ
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Просрочено
	|ПОМЕСТИТЬ ВТИсторияИзмененияВиз
	|ИЗ
	|	РегистрСведений.бит_ИсторияИзмененияВиз КАК ИсторияИзмененияВиз
	|ГДЕ
	|	ИсторияИзмененияВиз.Объект = &ОбъектВизирования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТИсторияИзмененияВиз.Период КАК Период,
	|	NULL КАК Статус,
	|	""ИзменениеВизы"" КАК ВидИзменения,
	|	ВТИсторияИзмененияВиз.Виза КАК Виза
	|ИЗ
	|	ВТИсторияИзмененияВиз КАК ВТИсторияИзмененияВиз
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТИсторияИзмененияСтатусов.Период,
	|	ВТИсторияИзмененияСтатусов.Статус,
	|	""ИзменениеСтатуса"",
	|	NULL
	|ИЗ
	|	ВТИсторияИзмененияСтатусов КАК ВТИсторияИзмененияСтатусов
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период
	|АВТОУПОРЯДОЧИВАНИЕ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТИсторияИзмененияВиз.Период КАК Период,
	|	ВТИсторияИзмененияВиз.Вид КАК Вид,
	|	ВТИсторияИзмененияВиз.Объект КАК Объект,
	|	ВТИсторияИзмененияВиз.Виза КАК Виза,
	|	ВТИсторияИзмененияВиз.ИД КАК ИД,
	|	ВТИсторияИзмененияВиз.Пользователь КАК Пользователь,
	|	ВТИсторияИзмененияВиз.Комментарий КАК Комментарий,
	|	ВТИсторияИзмененияВиз.Решение КАК Решение,
	|	ВТИсторияИзмененияВиз.ДатаКрайняя КАК ДатаКрайняя,
	|	ВТИсторияИзмененияВиз.РезультатВыполнения КАК РезультатВыполнения,
	|	ВТИсторияИзмененияВиз.Состояние КАК Состояние,
	|	ВТИсторияИзмененияВиз.Просрочено КАК Просрочено,
	|	NULL КАК Статус,
	|	NULL КАК Ссылка,
	|	NULL КАК Номер,
	|	NULL КАК Наименование
	|ИЗ
	|	ВТИсторияИзмененияВиз КАК ВТИсторияИзмененияВиз
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СообщенияПользователей.Период,
	|	""Сообщение"",
	|	СообщенияПользователей.Объект,
	|	СообщенияПользователей.Виза,
	|	СообщенияПользователей.ИД,
	|	СообщенияПользователей.Пользователь,
	|	ВЫРАЗИТЬ(СообщенияПользователей.ТекстСообщения КАК СТРОКА(1000)),
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL,
	|	NULL
	|ИЗ
	|	РегистрСведений.бит_СообщенияПользователей КАК СообщенияПользователей
	|ГДЕ
	|	СообщенияПользователей.Объект = &ОбъектВизирования
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Задача.Дата,
	|	""Задача"",
	|	Задача.Предмет,
	|	Задача.Виза,
	|	NULL,
	|	Задача.Автор,
	|	ВЫРАЗИТЬ(Задача.Описание КАК СТРОКА(1000)),
	|	NULL,
	|	NULL,
	|	ВЫРАЗИТЬ(Задача.РезультатВыполнения КАК СТРОКА(1000)),
	|	Задача.Состояние,
	|	ВЫБОР
	|		КОГДА Задача.СрокИсполнения <> ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА ВЫБОР
	|					КОГДА Задача.ДатаОкончанияИсполнения <> ДАТАВРЕМЯ(1, 1, 1)
	|							И Задача.ДатаОкончанияИсполнения > Задача.СрокИсполнения
	|						ТОГДА ИСТИНА
	|					КОГДА Задача.ДатаОкончанияИсполнения = ДАТАВРЕМЯ(1, 1, 1)
	|							И &ТекущаяДата > Задача.СрокИсполнения
	|						ТОГДА ИСТИНА
	|					ИНАЧЕ ЛОЖЬ
	|				КОНЕЦ
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ,
	|	Задача.Состояние,
	|	Задача.Ссылка,
	|	Задача.Номер,
	|	Задача.Наименование
	|ИЗ
	|	Задача.бит_Задача КАК Задача
	|ГДЕ
	|	Задача.Предмет = &ОбъектВизирования
	|	И НЕ Задача.Виза = ЗНАЧЕНИЕ(Справочник.бит_Визы.ПустаяСсылка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период
	|ИТОГИ ПО
	|	Виза
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	МассивРезультатов = Запрос.ВыполнитьПакет();				
	
	ОблЗаголовок.Параметры.Документ = ОбъектВизирования;
	ТабличныйДокумент.Вывести(ОблЗаголовок);
	
	ТабличныйДокумент.Вывести(ОблШапкаТаблицы);
	
	// Кешируем текущие решения для вывода.
	Решения   = Новый Соответствие;
	Результат = МассивРезультатов[0];
	Выборка   = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл		
		Решения.Вставить(Выборка.Виза, Выборка.Решение);		
	КонецЦикла; 
	
	// Вывод истории и сообщений.
	Результат = МассивРезультатов[4];
	Если Результат.Пустой() Тогда		
		Возврат;		
	КонецЕсли; 
	
	// Таблица хронологии изменения статусов и виз.
	РезультатХронология = МассивРезультатов[3];
	ТабХронология = РезультатХронология.Выгрузить();
	
	ВыборкаВиза = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ТабличныйДокумент.НачатьАвтогруппировкуСтрок();
	
	Пока ВыборкаВиза.Следующий() Цикл
		
		Расшифровка = Новый Структура("Виза, ИД", ВыборкаВиза.Виза,"");
		
		Выборка = ВыборкаВиза.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		АктуальноеРешение = Решения[ВыборкаВиза.Виза];
		
		ОблВиза.Параметры.Виза = Строка(ВыборкаВиза.Виза)+?(ЗначениеЗаполнено(АктуальноеРешение), " - "+Строка(АктуальноеРешение),"");
		ОблВиза.Параметры.р    = Расшифровка;
		ТабличныйДокумент.Вывести(ОблВиза, 0);
		
		инд = 1;
		Пока Выборка.Следующий() Цикл
			
			НомерПервойСтроки = ТабличныйДокумент.ВысотаТаблицы;
			
			Расшифровка = Новый Структура("Виза, ИД", ВыборкаВиза.Виза, Выборка.ИД);			
			
			ОблМакета = ?(Выборка.Вид = "Сообщение", ОблСообщениеЗаголовок, ОблСообщениеЗаголовок1);
			ОблМакета.Параметры.Заполнить(Выборка);
			
			Если Выборка.Вид = "История" Тогда
				
				СтатусВизы = ПолучитьСтатусДляВизы(ТабХронология, Выборка);
				ОблМакета.Параметры.Статус = СтатусВизы;
				
				ОблМакета.Параметры.Решение = ?(ЗначениеЗаполнено(Выборка.Решение), Выборка.Решение,  НСтр("ru='Решение не принято';en='No decision'"));
				
				ОблМакета.Параметры.р = Расшифровка;
				ТабличныйДокумент.Вывести(ОблМакета, 1);
				
				Если ЗначениеЗаполнено(Выборка.Комментарий) Тогда
					
					ТекстКомментарий = НСтр("ru='Комментарий: %1';en='Comment: %1'");
					ОблСообщениеТекст.Параметры.Комментарий = СтрШаблон(ТекстКомментарий, Выборка.Комментарий);
					ОблСообщениеТекст.Параметры.р = Расшифровка;
					// Установка имени области для последующего поиска и позиционирования на сообщении.
					ОбластьЯчейки = ОблСообщениеТекст.Область(1,2,1,2);
					ОбластьЯчейки.Имя = Строка(Выборка.ИД);
					ТабличныйДокумент.Вывести(ОблСообщениеТекст, 1);				
					
				КонецЕсли;
				
			ИначеЕсли Выборка.Вид = "Задача" Тогда
				
				ОблСообщениеТекст2.Параметры.Заполнить(Выборка);
				
				ТекстКомментарий = НСтр("ru='Создана задача №%1 от %2';en='Task is created from №%1 from %2'");
				Комментарий = СтрШаблон(ТекстКомментарий, Выборка.Номер, Выборка.Период);
				ОблСообщениеТекст2.Параметры.Комментарий = Комментарий;
				ОблСообщениеТекст2.Параметры.р = Выборка.Ссылка;
				ТабличныйДокумент.Вывести(ОблСообщениеТекст2, 1);
				
				ТекстКомментарий = НСтр("ru='Автор: %1';en='Author: %1'");
				Комментарий = СтрШаблон(ТекстКомментарий, Выборка.Пользователь);
				ОблСообщениеТекст.Параметры.Комментарий = Комментарий;
				ТабличныйДокумент.Вывести(ОблСообщениеТекст, 2);
				
				ТекстКомментарий = НСтр("ru='Описание задачи: %1';en='Task description: 1%'");
				Комментарий = СтрШаблон(ТекстКомментарий, ?(ПустаяСтрока(Выборка.Комментарий), Выборка.Наименование, Выборка.Комментарий));
				ОблСообщениеТекст.Параметры.Комментарий = Комментарий;
				ТабличныйДокумент.Вывести(ОблСообщениеТекст, 2);
				
				ТекстКомментарий = НСтр("ru='Результат выполнения задачи: %1';en='The result of the tasks: %1'");
				Комментарий = СтрШаблон(ТекстКомментарий, Выборка.РезультатВыполнения);
				ОблСообщениеТекст.Параметры.Комментарий = Комментарий;
				ТабличныйДокумент.Вывести(ОблСообщениеТекст, 2);
				
			Иначе
				
				ОблМакета.Параметры.р = Расшифровка;
				ТабличныйДокумент.Вывести(ОблМакета, 1);
				
				Если ЗначениеЗаполнено(Выборка.Комментарий) Тогда
					
					ТекстКомментарий = НСтр("ru='Сообщение: %1';en='Message: %1'");
					Комментарий = СтрШаблон(ТекстКомментарий, Выборка.Комментарий);
					ОблСообщениеТекст.Параметры.Комментарий = Комментарий;
					ОблСообщениеТекст.Параметры.р = Расшифровка;
					// Установка имени области для последующего поиска и позиционирования на сообщении.
					ОбластьЯчейки = ОблСообщениеТекст.Область(1,2,1,2);
					ОбластьЯчейки.Имя = Строка(Выборка.ИД);
					ТабличныйДокумент.Вывести(ОблСообщениеТекст, 1);				
					
				КонецЕсли;
			КонецЕсли; 
			
			// Изменим цвет фона
			Область = ТабличныйДокумент.Область(НомерПервойСтроки+1,2,ТабличныйДокумент.ВысотаТаблицы,ТабличныйДокумент.ШиринаТаблицы);
			Область.ЦветФона = ЦветаВидовСтрок[Выборка.Вид];
			
			инд = инд +1;	
		КонецЦикла; // Выборка
		
	КонецЦикла; // ВыборкаВиза
	ТабличныйДокумент.ЗакончитьАвтогруппировкуСтрок();
	
	ТабличныйДокумент.Вывести(ОблПоследняя);
	
	ТабличныйДокумент.ПоказатьУровеньГруппировокСтрок(1);
	ТабличныйДокумент.АвтоМасштаб = Истина;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Функция получает статус объекта после установки текущей визы.
// 
// Параметры:
// 	Таб - ТаблицаЗначений - таблица содержит общую хронологию изменений статусов и виз.
// 	Выборка - ВыборкаИзРезультатаЗапроса - данные по текущей визе.
// 
// Возвращаемое значение:
// 	Статус. 
// 
Функция ПолучитьСтатусДляВизы(Таб, Выборка)
	
	Статус = Неопределено;
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("Виза"	 , Выборка.Виза);
	СтруктураОтбора.Вставить("Период", Выборка.Период);
	
	НайденныеСтроки = Таб.НайтиСтроки(СтруктураОтбора);
	
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат Статус;
	КонецЕсли;
	
	НомСтроки = Таб.Индекс(НайденныеСтроки[0]);
	
	// По хронологии событий сначала происходит изменение визы и только потом статуса
	// 	если установка визы повлекла за собой изменение статуса, то этот статус надо искать следующим по оси времени.
	НомСледСтроки = НомСтроки+1; 
	Если НомСледСтроки <= Таб.Количество()-1
		И Таб[НомСледСтроки].ВидИзменения = "ИзменениеСтатуса" Тогда
		Статус = Таб[НомСледСтроки].Статус;
	КонецЕсли;
	
	// Установка визы не изменила статус объекта, следовательно статус надо искать в "прошлом".
	Если Статус = Неопределено Тогда
		Для Ном = 0 По НомСтроки Цикл
			Инд = НомСтроки-Ном;
			
			Если Таб[Инд].ВидИзменения = "ИзменениеСтатуса" Тогда
				Статус = Таб[Инд].Статус;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Статус;
	
КонецФункции

#КонецОбласти
	
#КонецЕсли
