		<query>ВЫБРАТЬ
	бит_Дополнительный_2Остатки.Счет КАК СчетУчета,
	бит_Дополнительный_2Остатки.Субконто1 КАК Номенклатура,
	"" КАК НоменклатурнаяГруппа,
	бит_Дополнительный_2Остатки.Субконто2 КАК Склад,
	СУММА(бит_Дополнительный_2Остатки.СуммаМУОстатокДт) КАК Себестоимость,
	СУММА(бит_Дополнительный_2Остатки.КоличествоОстаток) КАК Количество,
	бит_Дополнительный_2Остатки.Субконто1.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	ВЫБОР
		КОГДА СУММА(бит_Дополнительный_2Остатки.КоличествоОстаток) &lt;&gt; 0
			ТОГДА СУММА(бит_Дополнительный_2Остатки.СуммаМУОстатокДт) / СУММА(бит_Дополнительный_2Остатки.КоличествоОстаток)
		ИНАЧЕ 0
	КОНЕЦ КАК СебестоимостьЕдиницы
ИЗ
	РегистрБухгалтерии.бит_Дополнительный_2.Остатки(&amp;НачалоПериода {(&amp;НачалоПериода)}, {(Счет)}, &amp;МассивСубконто, Организация = &amp;Организация {(Организация)}) КАК бит_Дополнительный_2Остатки
ГДЕ
	бит_Дополнительный_2Остатки.СуммаМУОстатокДт &gt; 0

СГРУППИРОВАТЬ ПО
	бит_Дополнительный_2Остатки.Счет,
	бит_Дополнительный_2Остатки.Субконто1,
	бит_Дополнительный_2Остатки.Субконто2,
	бит_Дополнительный_2Остатки.Субконто1.ЕдиницаИзмерения</query>
