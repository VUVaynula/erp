
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	ПодготовитьФорму();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СхемаОсновныеСредстваВыбор(Элемент)
	
	ОбработатьВыбор(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура СхемаНМАВыбор(Элемент)
	
	ОбработатьВыбор(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура СхемаФинансоваяАрендаВыбор(Элемент)
	
	ОбработатьВыбор(Элемент);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОборотноСальдоваяВедомость(Команда)
	
	ПараметрыПередачи = Новый Структура; 
	ПараметрыПередачи.Вставить("КлючВарианта", "ОборотноСальдоваяВедомость");
	
	Попытка
		ОткрытьФорму("Отчет.бит_ОборотноСальдоваяВедомостьМУ.Форма", ПараметрыПередачи);	
	Исключение
		ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения); 
	КонецПопытки; 

КонецПроцедуры

&НаКлиенте
Процедура ОборотноСальдоваяВедомостьПоСчету(Команда)
	
	ПараметрыПередачи = Новый Структура; 
	ПараметрыПередачи.Вставить("КлючВарианта", "ОборотноСальдоваяВедомостьПоСчету");
	
	Попытка
		ОткрытьФорму("Отчет.бит_ОборотноСальдоваяВедомостьПоСчетуМУ.Форма", ПараметрыПередачи);	
	Исключение
		ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения); 
	КонецПопытки; 

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбработатьВыбор(Элемент)
	
	Если Элемент.ТекущийЭлемент = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	ИмяЭлемента = Элемент.ТекущийЭлемент.Имя;
	НавигационнаяСсылкаБлока = Неопределено;
	Если НавигационныеСсылки.Свойство(ИмяЭлемента, НавигационнаяСсылкаБлока) 
		И ЗначениеЗаполнено(НавигационнаяСсылкаБлока) Тогда
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(НавигационнаяСсылкаБлока);
	ИначеЕсли СтрСравнить(ИмяЭлемента, "ИзменениеПараметровУчетаОСАренда") = 0 Тогда 
		// N.B. на 8.3.19 нужно поменять вызов на параметризованную навигационную ссылку.
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("ВидОперации",
			ПредопределенноеЗначение("Перечисление.бит_му_ВидыОперацийИзменениеПараметровУчетаОС.ИзменениеПараметровУчетаОСвФинансовойАренде"));
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Отбор",	СтруктураОтбора);
		ПараметрыФормы.Вставить("Заголовок",НСтр("ru = 'Изменение параметров учета ОС в финансовой аренде (МСФО)';
													|en = 'Changing the OS account settings under finance leases (IAS)'"));
		
		ОткрытьФорму("Документ.бит_му_ИзменениеПараметровУчетаОС.ФормаСписка", ПараметрыФормы, 
			ЭтотОбъект, ЭтотОбъект);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПодготовитьФорму()

	// Готовим структуру из метаданных, чтобы проверка конфигурации реагировала на изменения.
	ОбъектыПодсистемы = Новый Структура;
	
	// Справочники.
	ОбъектыПодсистемы.Вставить("СпособыОтраженияРасходовПоАмортизации", Метаданные.Справочники.бит_му_СпособыОтраженияРасходовПоАмортизации);
	
	// Документы.
	ОбъектыПодсистемы.Вставить("ДополнительныеУсловияПоДоговору",					Метаданные.Документы.бит_ДополнительныеУсловияПоДоговору);
	ОбъектыПодсистемы.Вставить("ПринятиеКУчетуОС",									Метаданные.Документы.бит_му_ПринятиеКУчетуОС);
	ОбъектыПодсистемы.Вставить("НачислениеФинансовыхПроцентовПоАрендеОС",			Метаданные.Документы.бит_му_НачислениеФинансовыхПроцентовПоАрендеОС);
	ОбъектыПодсистемы.Вставить("РеклассификацияЗадолженностиПоФинансовойАрендеОС",	Метаданные.Документы.бит_му_РеклассификацияЗадолженностиПоФинансовойАрендеОС);
	ОбъектыПодсистемы.Вставить("ЗачетАвансовПоЛизингу",								Метаданные.Документы.бит_му_ЗачетАвансовПоЛизингу);
	ОбъектыПодсистемы.Вставить("ИзменениеПараметровУчетаОС",						Метаданные.Документы.бит_му_ИзменениеПараметровУчетаОС);
	ОбъектыПодсистемы.Вставить("ПринятиеКУчетуНМА",									Метаданные.Документы.бит_му_ПринятиеКУчетуНМА);
	ОбъектыПодсистемы.Вставить("ПереоценкаНМА",										Метаданные.Документы.бит_му_ПереоценкаНМА);
	ОбъектыПодсистемы.Вставить("ИзменениеПараметровУчетаНМА",						Метаданные.Документы.бит_му_ИзменениеПараметровУчетаНМА);
	ОбъектыПодсистемы.Вставить("ОбесценениеНМА",									Метаданные.Документы.бит_му_ОбесценениеНМА);
	ОбъектыПодсистемы.Вставить("НачислениеАмортизацииНМА",							Метаданные.Документы.бит_му_НачислениеАмортизацииНМА);
	ОбъектыПодсистемы.Вставить("ВыработкаВНА",										Метаданные.Документы.бит_му_ВыработкаВНА);
	ОбъектыПодсистемы.Вставить("ВыбытиеНМА",										Метаданные.Документы.бит_му_ВыбытиеНМА);
	ОбъектыПодсистемы.Вставить("МодернизацияОС",									Метаданные.Документы.бит_му_МодернизацияОС);
	ОбъектыПодсистемы.Вставить("ПереоценкаОС",										Метаданные.Документы.бит_му_ПереоценкаОС);
	ОбъектыПодсистемы.Вставить("ОбесценениеОС",										Метаданные.Документы.бит_му_ОбесценениеОС);
	ОбъектыПодсистемы.Вставить("ПеремещениеОС",										Метаданные.Документы.бит_му_ПеремещениеОС);
	ОбъектыПодсистемы.Вставить("НачислениеАмортизацииОС",							Метаданные.Документы.бит_му_НачислениеАмортизацииОС);
	ОбъектыПодсистемы.Вставить("ПереводОСВСоставИнвестиционнойСобственности",		Метаданные.Документы.бит_му_ПереводОСВСоставИнвестиционнойСобственности);
	ОбъектыПодсистемы.Вставить("ВыбытиеОС",											Метаданные.Документы.бит_му_ВыбытиеОС);
	ОбъектыПодсистемы.Вставить("ИзменениеПараметровУчетаОСАренда",					Метаданные.Документы.бит_му_ИзменениеПараметровУчетаОС);
	
	// Регистры сведений.
	ОбъектыПодсистемы.Вставить("ГруппыВНАКлассыВНА",	Метаданные.РегистрыСведений.бит_му_ГруппыВНА_КлассыВНА);
	ОбъектыПодсистемы.Вставить("ПараметрыКлассовВНА",	Метаданные.РегистрыСведений.бит_му_ПараметрыКлассовВНА);
	
	// Формирование навигационных ссылок и проверка доступа по функциональным опциям.
	НедоступныеОбъекты = Новый Массив;
	Для Каждого ОбъектПодсистемы Из ОбъектыПодсистемы Цикл
		НавигационнаяСсылкаБлока = ""; 
		ОбъектДоступен = ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектПодсистемы.Значение);
		Если ОбъектДоступен Тогда
			Если СтрСравнить(ОбъектПодсистемы.Ключ, "ИзменениеПараметровУчетаОСАренда") = 0 Тогда
			    НавигационнаяСсылкаБлока = "";
			Иначе	
				НавигационнаяСсылкаБлока = ПолучитьНавигационнуюСсылку(ОбъектПодсистемы.Значение);
			КонецЕсли;
		Иначе
			НедоступныеОбъекты.Добавить(ОбъектПодсистемы.Ключ);	
		КонецЕсли;
		ОбъектыПодсистемы[ОбъектПодсистемы.Ключ] = НавигационнаяСсылкаБлока;
	КонецЦикла;
	
	НавигационныеСсылки = Новый ФиксированнаяСтруктура(ОбъектыПодсистемы);
	
	СхемаОсновныеСредства	= Обработки.бит_ПанельФункций_ВНА.ПолучитьМакет("СхемаОсновныеСредства");
	СхемаНМА				= Обработки.бит_ПанельФункций_ВНА.ПолучитьМакет("СхемаНМА");
	СхемаФинансоваяАренда	= Обработки.бит_ПанельФункций_ВНА.ПолучитьМакет("СхемаФинансоваяАренда");
	
	// Ссылка может быть одновременно на разных схемах.
	Для Каждого НедоступныйОбъект Из НедоступныеОбъекты Цикл
		ЭлементыСхемы = СхемаОсновныеСредства.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаНМА.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаФинансоваяАренда.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект)
	
	ЭлементСхемы = ЭлементыСхемы[НедоступныйОбъект];
	ЭлементСхемы.ЦветФона = ЦветаСтиля.бит_ЦветНедоступногоПоля;
	
КонецПроцедуры

#КонецОбласти
