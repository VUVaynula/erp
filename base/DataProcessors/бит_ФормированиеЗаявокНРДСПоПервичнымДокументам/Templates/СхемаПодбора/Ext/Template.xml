		<query>// ВНИМАНИЕ!!! ПЕРВЫЙ ЗАПРОС ПАКЕТА - ШАБЛОН.
// ИЗМЕНЯЕТСЯ В ХОДЕ ВЫПОЛНЕНИЯ ПРОГРАММНО.
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ПроизвольныйДокумент.Ссылка КАК Документ,
	ПроизвольныйДокумент.Номер КАК Номер,
	ПроизвольныйДокумент.Дата КАК Дата,
	ПроизвольныйДокумент.Проведен КАК Проведен,
	ПроизвольныйДокумент.ПометкаУдаления КАК ПометкаУдаления,
	ПроизвольныйДокумент.Организация КАК Организация,
	ПроизвольныйДокумент.Валюта КАК Валюта,
	ПроизвольныйДокумент.СуммаДокумента КАК СуммаДокумента,
	ПроизвольныйДокумент.Контрагент КАК Контрагент,
	ЛОЖЬ КАК РучнаяКорректировка
ПОМЕСТИТЬ ТабДокументы
ИЗ
	Документ.ВозвратТоваровОтКлиента КАК ПроизвольныйДокумент
{ГДЕ
	ПроизвольныйДокумент.Ссылка.* КАК Документ,
	ПроизвольныйДокумент.Проведен КАК Проведен,
	ПроизвольныйДокумент.Организация КАК Организация,
	ПроизвольныйДокумент.Контрагент КАК Контрагент}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Документы.Документ КАК Документ,
	ISNULL(Документы.Номер, "") КАК Номер,
	ISNULL(Документы.Дата, ДАТАВРЕМЯ(1, 1, 1)) КАК Дата,
	Документы.Организация КАК Организация,
	Документы.Валюта КАК Валюта,
	Документы.СуммаДокумента КАК СуммаДокумента,
	Документы.Контрагент КАК Контрагент,
	ВЫБОР
		КОГДА Документы.ПометкаУдаления = ИСТИНА
			ТОГДА 2
		КОГДА ISNULL(Документы.Проведен, ЛОЖЬ) = ИСТИНА
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ  КАК СостояниеДокумента,
	ТИПЗНАЧЕНИЯ(Документы.Документ) КАК ВидДокумента,
	Документы.ПометкаУдаления КАК ПометкаУдаления,
	ISNULL(Документы.Проведен, ЛОЖЬ) КАК Проведен
ИЗ
	ТабДокументы КАК Документы
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
		ПО Документы.Документ = ПлатежныеПозиции.ДокументОснование И НЕ ПлатежныеПозиции.ПометкаУдаления 
ГДЕ
	ПлатежныеПозиции.Ссылка ЕСТЬ NULL И ТИПЗНАЧЕНИЯ(Документы.Документ) &lt;&gt; ТИП(Документ.бит_кзн_ЗаявкаНаРасходованиеСредств)
	
ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	Документы.Документ КАК Документ,
	ISNULL(Документы.Номер, "") КАК Номер,
	ISNULL(Документы.Дата, ДАТАВРЕМЯ(1, 1, 1)) КАК Дата,
	Документы.Организация КАК Организация,
	Документы.Валюта КАК Валюта,
	ДанныеДокументовКазначейства.Сумма КАК СуммаДокумента,
	Документы.Контрагент КАК Контрагент,
	ВЫБОР
		КОГДА Документы.ПометкаУдаления = ИСТИНА
			ТОГДА 2
		КОГДА ISNULL(Документы.Проведен, ЛОЖЬ) = ИСТИНА
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ  КАК СостояниеДокумента,
	&amp;ПрогнозПлатежаПредставлениеВида КАК ВидДокумента,
	Документы.ПометкаУдаления КАК ПометкаУдаления,
	ISNULL(Документы.Проведен, ЛОЖЬ) КАК Проведен
ИЗ
	ТабДокументы КАК Документы
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ЗаявкаНаРасходованиеСредств КАК Заявки
		ПО Документы.Документ = Заявки.ДокументОснование И НЕ Заявки.ПометкаУдаления
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_ДанныеДокументовКазначейства КАК ДанныеДокументовКазначейства
		ПО (ДанныеДокументовКазначейства.Документ = Документы.Документ) 
ГДЕ
	Заявки.Ссылка ЕСТЬ NULL 
	И ТИПЗНАЧЕНИЯ(Документы.Документ) = ТИП(Документ.бит_кзн_ЗаявкаНаРасходованиеСредств) 
	И Документы.Проведен 
	
</query>
