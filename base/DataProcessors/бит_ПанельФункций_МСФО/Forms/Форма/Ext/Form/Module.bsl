&НаКлиенте
Процедура ОбработатьВыбор(Элемент)
	
	Если Элемент.ТекущийЭлемент = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	ИмяЭлемента = Элемент.ТекущийЭлемент.Имя;
	НавигационнаяСсылкаБлока = Неопределено;
	Если ОбъектыСПараметрами.Свойство(ИмяЭлемента) Тогда // N.B. на 8.3.19 нужно поменять вызов на параметризованную навигационную ссылку.
		Если Элементы.СтраницыОсновная.ТекущаяСтраница = Элементы.СтраницаОтчетность Тогда
			Если СтрСравнить(ИмяЭлемента, "ОборотноСальдоваяВедомость") = 0 Тогда
				ПараметрыПередачи = Новый Структура;
				ПараметрыПередачи.Вставить("КлючВарианта", "ОборотноСальдоваяВедомость");
				Попытка
					ОткрытьФорму("Отчет.бит_ОборотноСальдоваяВедомостьМУ.ФормаОбъекта", ПараметрыПередачи);
				Исключение
					ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				КонецПопытки;
			ИначеЕсли СтрСравнить(ИмяЭлемента, "ОборотноСальдоваяВедомостьПоСчету") = 0 Тогда
				ПараметрыПередачи = Новый Структура;
				ПараметрыПередачи.Вставить("КлючВарианта", "ОборотноСальдоваяВедомостьПоСчету");
				Попытка
					ОткрытьФорму("Отчет.бит_ОборотноСальдоваяВедомостьПоСчетуМУ.ФормаОбъекта", ПараметрыПередачи);
				Исключение
					ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				КонецПопытки;
			ИначеЕсли СтрСравнить(ИмяЭлемента, "ОборотыСчета") = 0 Тогда
				ПараметрыПередачи = Новый Структура;
				ПараметрыПередачи.Вставить("КлючВарианта", "ОборотыСчета");
				Попытка
					ОткрытьФорму("Отчет.бит_ОборотыСчетаМУ.ФормаОбъекта", ПараметрыПередачи);
				Исключение
					ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				КонецПопытки;
			ИначеЕсли СтрСравнить(ИмяЭлемента, "АнализСубконто") = 0 Тогда
				ПараметрыПередачи = Новый Структура;
				ПараметрыПередачи.Вставить("КлючВарианта", "АнализСубконто");
				Попытка
					ОткрытьФорму("Отчет.бит_АнализСубконтоМУ.ФормаОбъекта", ПараметрыПередачи);
				Исключение
					ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				КонецПопытки;
			ИначеЕсли СтрСравнить(ИмяЭлемента, "АнализСчета") = 0 Тогда
				ПараметрыПередачи = Новый Структура;
				ПараметрыПередачи.Вставить("КлючВарианта", "АнализСчета");
				Попытка
					ОткрытьФорму("Отчет.бит_АнализСчетаМУ.ФормаОбъекта", ПараметрыПередачи);
				Исключение
					ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				КонецПопытки;
			ИначеЕсли СтрСравнить(ИмяЭлемента, "КарточкаСчета") = 0 Тогда
				ПараметрыПередачи = Новый Структура;
				ПараметрыПередачи.Вставить("КлючВарианта", "КарточкаСчета");
				Попытка
					ОткрытьФорму("Отчет.бит_КарточкаСчетаМУ.ФормаОбъекта", ПараметрыПередачи);
				Исключение
					ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				КонецПопытки;
			ИначеЕсли СтрСравнить(ИмяЭлемента, "КарточкаСубконто") = 0 Тогда
				ПараметрыПередачи = Новый Структура;
				ПараметрыПередачи.Вставить("КлючВарианта", "КарточкаСубконто");
				Попытка
					ОткрытьФорму("Отчет.бит_КарточкаСубконтоМУ.ФормаОбъекта", ПараметрыПередачи);
				Исключение
					ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				КонецПопытки;
			ИначеЕсли СтрСравнить(ИмяЭлемента, "ОтчетПоПроводкам") = 0 Тогда
				ПараметрыПередачи = Новый Структура;
				ПараметрыПередачи.Вставить("КлючВарианта", "ОтчетПоПроводкам");
				Попытка
					ОткрытьФорму("Отчет.бит_ОтчетПоПроводкамМУ.ФормаОбъекта", ПараметрыПередачи);
				Исключение
					ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				КонецПопытки;
			ИначеЕсли СтрСравнить(ИмяЭлемента, "ПроверкаСоответствийВидовЗатрат") = 0 Тогда
				ПараметрыПередачи = Новый Структура;
				ПараметрыПередачи.Вставить("КлючВарианта", "ПроверкаСоответствийВидовЗатрат");
				Попытка
					ОткрытьФорму("Отчет.бит_ПроверкаСоответствийВидовЗатратМУ.ФормаОбъекта", ПараметрыПередачи);
				Исключение
					ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				КонецПопытки;
			КонецЕсли;
		Иначе	
			Если СтрСравнить(ИмяЭлемента, "МаскаКода") = 0 Тогда
				КлючЗаписи = КлючЗаписи(); 
				ПараметрыФормы = Новый Структура("Ключ", КлючЗаписи);
				ОткрытьФорму("РегистрСведений.бит_МаскиКодов.ФормаЗаписи", ПараметрыФормы, 
					ЭтотОбъект, ЭтотОбъект);
			ИначеЕсли СтрСравнить(ИмяЭлемента, "ВводНачальныхОстатковПоОС") = 0 Тогда
				Отборы = Новый Структура("ВидОперации",
				ПредопределенноеЗначение("Перечисление.бит_му_ВидыОперацийПринятиеКУчетуОС.ВводНачальныхОстатковОС")); 
				ПараметрыФормы = Новый Структура("Отбор", Отборы);
				ОткрытьФорму("Документ.бит_му_ПринятиеКУчетуОС.ФормаСписка", ПараметрыФормы, 
					ЭтотОбъект, ЭтотОбъект);
			ИначеЕсли СтрСравнить(ИмяЭлемента, "ВводНачальныхОстатковПоФинансовойАренде") = 0 Тогда
				Отборы = Новый Структура("ВидОперации",
				ПредопределенноеЗначение("Перечисление.бит_му_ВидыОперацийПринятиеКУчетуОС.ВводОстатковОСВФинансовойАренде")); 
				ПараметрыФормы = Новый Структура("Отбор", Отборы);
				ОткрытьФорму("Документ.бит_му_ПринятиеКУчетуОС.ФормаСписка", ПараметрыФормы, 
					ЭтотОбъект, ЭтотОбъект);
			ИначеЕсли СтрСравнить(ИмяЭлемента, "ВводНачальныхОстатковПоФинансовымИнструментам") = 0 Тогда
				Отборы = Новый Структура("ВидОперации",
				ПредопределенноеЗначение("Перечисление.бит_му_ВидыОперацийПризнаниеФинИнструментов.ВводНачальныхОстатковКредитыЗаймыПолученные")); 
				ПараметрыФормы = Новый Структура("Отбор", Отборы);
				ОткрытьФорму("Документ.бит_му_ПризнаниеФинИнструментов.ФормаСписка", ПараметрыФормы, 
					ЭтотОбъект, ЭтотОбъект);
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли НавигационныеСсылки.Свойство(ИмяЭлемента, НавигационнаяСсылкаБлока) 
		И ЗначениеЗаполнено(НавигационнаяСсылкаБлока) Тогда
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(НавигационнаяСсылкаБлока);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КлючЗаписи()
	
	ОбъектСистемы = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени("ПланСчетов.бит_Дополнительный_2");
	ЗначенияКлюча = Новый Структура("ОбъектСистемы, ИмяРеквизита", ОбъектСистемы, "Код");
	Результат = РегистрыСведений.бит_МаскиКодов.СоздатьКлючЗаписи(ЗначенияКлюча);

	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ПодготовитьФорму()
	
	// Объекты с параметрами.
	Исключения = Новый Структура;
	Исключения.Вставить("МаскаКода");
	Исключения.Вставить("ВводНачальныхОстатковПоОС");
	Исключения.Вставить("ВводНачальныхОстатковПоФинансовойАренде");
	Исключения.Вставить("ВводНачальныхОстатковПоФинансовымИнструментам");
	Исключения.Вставить("ОборотноСальдоваяВедомость");
	Исключения.Вставить("ОборотноСальдоваяВедомостьПоСчету");
	Исключения.Вставить("ОборотыСчета");
	Исключения.Вставить("АнализСубконто");
	Исключения.Вставить("АнализСчета");
	Исключения.Вставить("КарточкаСчета");
	Исключения.Вставить("КарточкаСубконто");
	Исключения.Вставить("ОтчетПоПроводкам");
	Исключения.Вставить("ПроверкаСоответствийВидовЗатрат");
	
	ОбъектыСПараметрами = Новый ФиксированнаяСтруктура(Исключения);
	
	// Готовим структуру из метаданных, чтобы проверка конфигурации реагировала на изменения.
	ОбъектыПодсистемы = Новый Структура;
	
	// Справочники.
	ОбъектыПодсистемы.Вставить("РыночныеСтавкиКредитыЗаймы",Метаданные.Справочники.бит_му_РыночныеСтавкиКредитыЗаймы);
	ОбъектыПодсистемы.Вставить("Запросы",					Метаданные.Справочники.бит_Запросы);
	ОбъектыПодсистемы.Вставить("ИсточникиДанных",			Метаданные.Справочники.бит_ИсточникиДанных);
	ОбъектыПодсистемы.Вставить("ВидыАктивовОбязательств",	Метаданные.Справочники.бит_му_ВидыАктивовОбязательств);
	ОбъектыПодсистемы.Вставить("НастройкиРазнесенияСальдо",	Метаданные.Справочники.бит_му_НастройкиРазнесенияСальдо);
	ОбъектыПодсистемы.Вставить("ВидыЗакрытияСчетов",		Метаданные.Справочники.бит_ВидыЗакрытияСчетов);
	ОбъектыПодсистемы.Вставить("НастройкиЗакрытия",			Метаданные.Справочники.бит_НастройкиЗакрытия);
	
	// Документы.
	ОбъектыПодсистемы.Вставить("ОперацияУправленческий",						Метаданные.Документы.бит_ОперацияУправленческий);
	ОбъектыПодсистемы.Вставить("ДополнительныеУсловияПоДоговору",				Метаданные.Документы.бит_ДополнительныеУсловияПоДоговору);
	ОбъектыПодсистемы.Вставить("ПризнаниеФинИнструментов",						Метаданные.Документы.бит_му_ПризнаниеФинИнструментов);
	ОбъектыПодсистемы.Вставить("РеклассификацияЗадолженности",					Метаданные.Документы.бит_му_РеклассификацияЗадолженности);
	ОбъектыПодсистемы.Вставить("НачислениеПроцентовПоФинИнструментам",			Метаданные.Документы.бит_му_НачислениеПроцентовПоФинИнструментам);
	ОбъектыПодсистемы.Вставить("РаспределениеПлатежейПоКредитамЗаймам",			Метаданные.Документы.бит_му_РаспределениеПлатежейПоКредитамЗаймам);
	ОбъектыПодсистемы.Вставить("ОбесценениеДебиторскойЗадолженности",			Метаданные.Документы.бит_му_ОбесценениеДебиторскойЗадолженности);
	ОбъектыПодсистемы.Вставить("КорректировкаГрафиковФинансовыхНачислений",		Метаданные.Документы.бит_му_КорректировкаГрафиковФинансовыхНачислений);
	ОбъектыПодсистемы.Вставить("ПоступлениеМПЗ",								Метаданные.Документы.бит_му_ПоступлениеМПЗ);
	ОбъектыПодсистемы.Вставить("РеализацияМПЗ",									Метаданные.Документы.бит_му_РеализацияМПЗ);
	ОбъектыПодсистемы.Вставить("НачислениеРезерваПоМПЗ",						Метаданные.Документы.бит_му_НачислениеРезерваПоМПЗ);
	ОбъектыПодсистемы.Вставить("КорректировкаСтоимостиМПЗ",						Метаданные.Документы.бит_му_КорректировкаСтоимостиМПЗ);
	ОбъектыПодсистемы.Вставить("РасчетОтложенныхНалогов",						Метаданные.Документы.бит_му_РасчетОтложенныхНалогов);
	ОбъектыПодсистемы.Вставить("РазнесениеСальдоНаОтчетнуюДату",				Метаданные.Документы.бит_му_РазнесениеСальдоНаОтчетнуюДату);
	ОбъектыПодсистемы.Вставить("ЗакрытиеСчетов",								Метаданные.Документы.бит_ЗакрытиеСчетов);
	ОбъектыПодсистемы.Вставить("ПереоценкаВалютныхДенежныхСтатей",				Метаданные.Документы.бит_ПереоценкаВалютныхДенежныхСтатей);
	ОбъектыПодсистемы.Вставить("НачислениеАмортизацииОС",						Метаданные.Документы.бит_му_НачислениеАмортизацииОС);
	ОбъектыПодсистемы.Вставить("НачислениеАмортизацииНМА",						Метаданные.Документы.бит_му_НачислениеАмортизацииНМА);
	ОбъектыПодсистемы.Вставить("НачислениеФинансовыхПроцентовПоАрендеОС",		Метаданные.Документы.бит_му_НачислениеФинансовыхПроцентовПоАрендеОС);
	ОбъектыПодсистемы.Вставить("ВводНачальныхОстатковПоОС",						Метаданные.Документы.бит_му_ПринятиеКУчетуОС);
	ОбъектыПодсистемы.Вставить("ВводНачальныхОстатковПоФинансовойАренде",		Метаданные.Документы.бит_му_ПринятиеКУчетуОС);
	ОбъектыПодсистемы.Вставить("ВводНачальныхОстатковПоФинансовымИнструментам",	Метаданные.Документы.бит_му_ПризнаниеФинИнструментов);
	
	// Регистры сведений.
	ОбъектыПодсистемы.Вставить("УчетнаяПолитика",					Метаданные.РегистрыСведений.бит_му_УчетнаяПолитика);
	ОбъектыПодсистемы.Вставить("НачалоОткрытогоПериода",			Метаданные.РегистрыСведений.бит_НачалоОткрытогоПериода);
	ОбъектыПодсистемы.Вставить("СчетаРасчетовСКонтрагентами",		Метаданные.РегистрыСведений.бит_му_СчетаРасчетовСКонтрагентами);
	ОбъектыПодсистемы.Вставить("СчетаУчетаНоменклатуры",			Метаданные.РегистрыСведений.бит_му_СчетаУчетаНоменклатуры);
	ОбъектыПодсистемы.Вставить("ВалютныеНеденежныеСтатьи",			Метаданные.РегистрыСведений.бит_ВалютныеНеденежныеСтатьи);
	ОбъектыПодсистемы.Вставить("ДополнительныеСтавки",				Метаданные.РегистрыСведений.бит_му_ДополнительныеСтавки);
	ОбъектыПодсистемы.Вставить("НазначенияНастроекРазнесенияСальдо",Метаданные.РегистрыСведений.бит_му_НазначенияНастроекРазнесенияСальдо);
	ОбъектыПодсистемы.Вставить("НазначениеАлгоритмовЗакрытия",		Метаданные.РегистрыСведений.бит_НазначениеАлгоритмовЗакрытия);
	ОбъектыПодсистемы.Вставить("МаскаКода",							Метаданные.РегистрыСведений.бит_МаскиКодов);
	
	// Обработки.
	ОбъектыПодсистемы.Вставить("НастройкиРасчетаОтложенныхНалогов", Метаданные.Обработки.бит_му_НастройкиРасчетаОтложенныхНалогов);
	
	// Регистры бухгалтерии.
	ОбъектыПодсистемы.Вставить("ЖурналПроводокМСФО", Метаданные.РегистрыБухгалтерии.бит_Дополнительный_2);
	
	// Планы счетов.
	ОбъектыПодсистемы.Вставить("ПланСчетовМСФО", Метаданные.ПланыСчетов.бит_Дополнительный_2);
	
	// Отчеты.
	ОбъектыПодсистемы.Вставить("ИнтерактивнаяОборотноСальдоваяВедомость",	Метаданные.Отчеты.бит_осв_ИнтерактивнаяОборотноСальдоваяВедомость);
	ОбъектыПодсистемы.Вставить("ПроизвольныйОтчет",							Метаданные.Отчеты.бит_ПроизвольныйОтчет);
	ОбъектыПодсистемы.Вставить("ОСВПоЗаписямТрансляции",					Метаданные.Отчеты.бит_ОСВПоЗаписямТрансляции);
	ОбъектыПодсистемы.Вставить("ОтчетПоТипамПроводок",						Метаданные.Отчеты.бит_ОтчетПоТипамПроводок);
	
	// Формирование навигационных ссылок и проверка доступа по функциональным опциям.
	НедоступныеОбъекты = Новый Массив;
	Для Каждого ОбъектПодсистемы Из ОбъектыПодсистемы Цикл
		НавигационнаяСсылкаБлока = ""; 
		ОбъектДоступен = ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектПодсистемы.Значение);
		Если ОбъектДоступен Тогда
			НавигационнаяСсылкаБлока = ПолучитьНавигационнуюСсылку(ОбъектПодсистемы.Значение);
		Иначе
			НедоступныеОбъекты.Добавить(ОбъектПодсистемы.Ключ);	
		КонецЕсли;
		ОбъектыПодсистемы[ОбъектПодсистемы.Ключ] = НавигационнаяСсылкаБлока;
	КонецЦикла;

	НавигационныеСсылки = Новый ФиксированнаяСтруктура(ОбъектыПодсистемы);
	
	СхемаОбщиеСведения 		   					= Обработки.бит_ПанельФункций_МСФО.ПолучитьМакет("СхемаОбщиеСведения");
	СхемаФинансовыеИнструменты 					= Обработки.бит_ПанельФункций_МСФО.ПолучитьМакет("СхемаФинансовыеИнструменты");
	СхемаМПЗ 				 					= Обработки.бит_ПанельФункций_МСФО.ПолучитьМакет("СхемаМПЗ");
	СхемаОтложенныеНалоги 	  					= Обработки.бит_ПанельФункций_МСФО.ПолучитьМакет("СхемаОтложенныеНалоги");
	СхемаРазнесениеСальдоАктивноПассивныхСчетов = Обработки.бит_ПанельФункций_МСФО.ПолучитьМакет("СхемаРазнесениеСальдоАктивноПассивныхСчетов");
	СхемаЗакрытиеСчетов 	 					= Обработки.бит_ПанельФункций_МСФО.ПолучитьМакет("СхемаЗакрытиеСчетов");
	СхемаРегламентныеОперации 					= Обработки.бит_ПанельФункций_МСФО.ПолучитьМакет("СхемаРегламентныеОперации");
	СхемаОтчетность 		  					= Обработки.бит_ПанельФункций_МСФО.ПолучитьМакет("СхемаОтчетность");

	// Ссылка может быть одновременно на разных схемах.
	Для Каждого НедоступныйОбъект Из НедоступныеОбъекты Цикл
		ЭлементыСхемы = СхемаОбщиеСведения.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаФинансовыеИнструменты.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаМПЗ.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаОтложенныеНалоги.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаРазнесениеСальдоАктивноПассивныхСчетов.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаЗакрытиеСчетов.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаРегламентныеОперации.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаОтчетность.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект)
	
	ЭлементСхемы = ЭлементыСхемы[НедоступныйОбъект];
	ЭлементСхемы.ЦветФона = ЦветаСтиля.бит_ЦветНедоступногоПоля;
	
КонецПроцедуры

#КонецОбласти
