
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	ПодготовитьФорму();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СхемаЗаявкиНаРасходВыбор(Элемент)
	
	Если Элемент.ТекущийЭлемент = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	ИмяЭлемента = Элемент.ТекущийЭлемент.Имя;
	Если СтрСравнить(ИмяЭлемента, "ПрогнозПлатежа") = 0 Тогда
		ПараметрыФормы = Новый Структура("ВидПлана", ПредопределенноеЗначение("Перечисление.бит_кзн_ВидыПланов.Прогноз"));
		ОткрытьФорму("Документ.бит_кзн_ЗаявкаНаРасходованиеСредств.ФормаСписка", ПараметрыФормы, ЭтотОбъект, "ПрогнозПлатежа");
	ИначеЕсли СтрСравнить(ИмяЭлемента, "ЗаявкаНаРасходованиеСредств") = 0 Тогда
		ПараметрыФормы = Новый Структура("ВидПлана", ПредопределенноеЗначение("Перечисление.бит_кзн_ВидыПланов.План"));
		ОткрытьФорму("Документ.бит_кзн_ЗаявкаНаРасходованиеСредств.ФормаСписка", ПараметрыФормы, ЭтотОбъект);
	Иначе
		ОбработатьВыбор(Элемент);
	КонецЕсли;
	
КонецПроцедуры

