КонецФункции

Функция ОбновитьДеревоСчетов(ДанныеФормы, ДанныеОбъекта) Экспорт

	КлючеваяОперация = НСтр("ru = 'Рабочее место казначея. Обновление дерева документов';
								|en = 'Financial Officer Workplace. Updating the Document tree'");
	ОписаниеЗамера = ОценкаПроизводительности.НачатьЗамерДлительнойОперации(КлючеваяОперация);
	
	ДеревоСчета 		   = ДанныеФормы.ДеревоСчета;
	КолонкиПериодов 	   = ДанныеФормы.КолонкиПериодов;
	МаксУровеньДеревоСчета = ДанныеФормы.МаксУровеньДеревоСчета;
	
	НачалоПериода = ДанныеОбъекта.НачалоПериода;
	КонецПериода  = ДанныеОбъекта.КонецПериода;
	СчетаУчета	  = ДанныеОбъекта.Счета;

	ДанныеФормы.ДеревоСчета.Строки.Очистить();
	ДанныеФормы.КолонкиПериодов.Очистить();
	ДанныеФормы.МаксУровеньДеревоСчета = 0;

	Если НЕ ЗначениеЗаполнено(НачалоПериода) 
	 ИЛИ НЕ ЗначениеЗаполнено(КонецПериода) 
	 ИЛИ (НачалоПериода > КонецПериода)Тогда
		
		ВызватьИсключение НСтр("ru='Настройка периода отображения данных выполнена не верно.';
							   |en='Setting the display data periroda made is not true.'");
	КонецЕсли;
	
	РезультатКомпоновкиРМК = РезультатКомпоновкиДанныхРМК(ДанныеОбъекта);
	Если РезультатКомпоновкиРМК.Строки.Количество() = 0 Тогда
		Возврат ДанныеФормы;	
	КонецЕсли;
	
	ПериодыКомпоновки = Новый ТаблицаЗначений(); 
	ПериодыКомпоновки.Колонки.Добавить("Период");
	
	МестоХраненияТип = Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчетаОрганизаций, СправочникСсылка.Кассы");
	
	БанковскиеСчета = Новый ТаблицаЗначений(); 
	БанковскиеСчета.Колонки.Добавить("БанковскийСчет", МестоХраненияТип);
	БанковскиеСчета.Колонки.Добавить("Сумма", ОбщегоНазначения.ОписаниеТипаЧисло(15, 2));
	
	ЗаполнитьБанковскиеСчетаИПериоды(БанковскиеСчета, ПериодыКомпоновки, РезультатКомпоновкиРМК.Строки);
	ЗаполнитьКолонкиПериодов(ДанныеФормы.КолонкиПериодов, ПериодыКомпоновки, ДанныеОбъекта);
	ДобавитьКолонкиДерева(ДанныеФормы.ДеревоСчета, ДанныеФормы.КолонкиПериодов);
	
	ДанныеСчетов = ДанныеСчетов(БанковскиеСчета, ДанныеОбъекта, ДанныеФормы.КолонкиПериодов);
			
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьНесколькоВалют") Тогда
		Если РезультатКомпоновкиРМК.Колонки.Найти("ВалютаДенежныхСредств") = Неопределено Тогда
			РезультатКомпоновкиРМК.Колонки.Добавить("ВалютаДенежныхСредств", ОбщегоНазначения.ОписаниеТипаСтрока(25));
		КонецЕсли;
	КонецЕсли;
	
	// Выведем дерево счетов 
	ОбойтиСтрокиДереваСчетов(РезультатКомпоновкиРМК, ДанныеФормы.ДеревоСчета.Строки, 
		Неопределено, ДанныеСчетов, ДанныеОбъекта, ДанныеФормы);

	ИмяШага = НСтр("ru = 'Завершение обновления'; en = 'Completing the update'");
	ОценкаПроизводительности.ЗакончитьЗамерДлительнойОперации(ОписаниеЗамера, 1, ИмяШага);
	
	Возврат ДанныеФормы;
	
КонецФункции

