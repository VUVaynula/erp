			<dataSource>ИсточникДанных1</dataSource>
			<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	ДокументыОплаты.ПлатежнаяПозиция КАК ПлатежнаяПозиция,
	ДокументыОплаты.ПлатежныйДокумент КАК ПлатежныйДокумент
ПОМЕСТИТЬ ТаблицаДокументыОплаты
ИЗ
	(ВЫБРАТЬ
		ВЫРАЗИТЬ(бит_ДополнительныеАналитики.ЗначениеАналитики КАК Документ.бит_ПлатежнаяПозиция) КАК ПлатежнаяПозиция,
		бит_ДополнительныеАналитики.Объект КАК ПлатежныйДокумент
	ИЗ
		РегистрСведений.бит_ДополнительныеАналитики КАК бит_ДополнительныеАналитики
	ГДЕ
		бит_ДополнительныеАналитики.Аналитика = ЗНАЧЕНИЕ(ПланВидовХарактеристик.бит_ВидыДополнительныхАналитик.ПлатежнаяПозиция)
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		бит_ДокументыМножественнойОплаты.ПлатежнаяПозиция,
		бит_ДокументыМножественнойОплаты.ДокументОплаты
	ИЗ
		РегистрСведений.бит_ДокументыМножественнойОплаты КАК бит_ДокументыМножественнойОплаты) КАК ДокументыОплаты

ИНДЕКСИРОВАТЬ ПО
	ПлатежнаяПозиция
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ПланируемыйРасходОб.ДокументПланирования КАК ПлатежнаяПозиция,
	ПланируемыйРасходОб.ДокументПланирования.Важность КАК Важность,
	ПланируемыйРасходОб.ВидДенежныхСредств КАК ВидДенежныхСредств,
	ПланируемыйРасходОб.Организация КАК Организация,
	ВЫБОР
		КОГДА ПланируемыйРасходОб.ДоговорКонтрагента.РасчетыВУсловныхЕдиницах
			ТОГДА Константы.ВалютаРегламентированногоУчета
		ИНАЧЕ ПланируемыйРасходОб.Валюта
	КОНЕЦ КАК ВалютаДенежныхСредств,
	ВЫБОР
		КОГДА ПланируемыйРасходОб.ВидДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.бит_ВидыДенежныхСредств.Безналичные)
			ТОГДА ПланируемыйРасходОб.БанковскийСчет
		ИНАЧЕ "Касса"
	КОНЕЦ КАК БанковскийСчет,
	ВЫБОР
		КОГДА &amp;Периодичность = 6
			ТОГДА НАЧАЛОПЕРИОДА(ПланируемыйРасходОб.Период, ДЕНЬ)
		КОГДА &amp;Периодичность = 7
			ТОГДА НАЧАЛОПЕРИОДА(ПланируемыйРасходОб.Период, НЕДЕЛЯ)
		КОГДА &amp;Периодичность = 8
			ТОГДА НАЧАЛОПЕРИОДА(ПланируемыйРасходОб.Период, ДЕКАДА)
		КОГДА &amp;Периодичность = 9
			ТОГДА НАЧАЛОПЕРИОДА(ПланируемыйРасходОб.Период, МЕСЯЦ)
		КОГДА &amp;Периодичность = 10
			ТОГДА НАЧАЛОПЕРИОДА(ПланируемыйРасходОб.Период, КВАРТАЛ)
		КОГДА &amp;Периодичность = 11
			ТОГДА НАЧАЛОПЕРИОДА(ПланируемыйРасходОб.Период, ПОЛУГОДИЕ)
		КОГДА &amp;Периодичность = 12
			ТОГДА НАЧАЛОПЕРИОДА(ПланируемыйРасходОб.Период, ГОД)
		ИНАЧЕ ПланируемыйРасходОб.Период
	КОНЕЦ КАК Период,
	ПланируемыйРасходОб.ДокументПланирования.ДокументОснование КАК ДокументПланирования,
	ЗНАЧЕНИЕ(Перечисление.бит_ВидыДанныхРабочееМестоКазначея.Расход) КАК ВидДанных,
	ТаблицаДокументыОплаты.ПлатежныйДокумент КАК ПлатежныйДокумент,
	ВЫБОР
		КОГДА ТаблицаДокументыОплаты.ПлатежныйДокумент ЕСТЬ NULL 
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ЕстьПлатежныйДокумент,
	СУММА(ЕСТЬNULL(ПланируемыйРасходОстатки.СуммаОстаток, 0)) КАК СуммаОстаток,
	ВЫБОР
		КОГДА ЕСТЬNULL(ПланируемыйРасходОстатки.СуммаОстаток, 0) &gt; 0
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК Оплачено,
	СУММА(ПланируемыйРасходОб.СуммаВзаиморасчетыПриход) КАК Сумма,
	СУММА(бит_ДДС.СуммаВзаиморасчетыОборот) КАК СуммаФакт,
	СУММА(0) КАК Отклонение,
	ПланируемыйРасходОб.ЦФО,
	ПланируемыйРасходОб.СтатьяОборотов,
	ПланируемыйРасходОб.Проект,
	ПланируемыйРасходОб.НоменклатурнаяГруппа,
	ПланируемыйРасходОб.Контрагент,
	ПланируемыйРасходОб.ДоговорКонтрагента,
	ПланируемыйРасходОб.Аналитика_1,
	ПланируемыйРасходОб.Аналитика_2,
	ПланируемыйРасходОб.Аналитика_3,
	ПланируемыйРасходОб.Аналитика_4,
	ПланируемыйРасходОб.Аналитика_5,
	ПланируемыйРасходОб.Аналитика_6,
	ПланируемыйРасходОб.Аналитика_7
{ВЫБРАТЬ
	ПлатежнаяПозиция.*,
	Сумма,
	ВидДенежныхСредств.*,
	Организация.*,
	ВалютаДенежныхСредств.*,
	БанковскийСчет.*,
	Период,
	ДокументПланирования.*,
	ВидДанных.*,
	ПлатежныйДокумент.*,
	ЕстьПлатежныйДокумент,
	СуммаОстаток,
