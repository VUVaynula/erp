
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не ЗначениеЗаполнено(Параметры.ДокументПланирования) Тогда
		ТекстСообщения = НСтр("ru = 'Непосредственное открытие этой формы не предусмотрено.';
							  |en = 'This form cannot be opened directly.'");
		ВызватьИсключение ТекстСообщения;
	КонецЕсли;
	
	ВалютаПлатежа 		 = Параметры.ВалютаПлатежа;
	ДокументПланирования = Параметры.ДокументПланирования;
	
	ТипДокументаПланирования = ТипЗнч(ДокументПланирования);
	Если ТипДокументаПланирования = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств")
	 ИЛИ ТипДокументаПланирования = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция") Тогда
		
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ПланируемыйРасходДенежныхСредств.СуммаОстаток КАК Сумма
		|ИЗ
		|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.Остатки(,
		|		&УсловиеНаДокумент) КАК ПланируемыйРасходДенежныхСредств";
		
		ЧтоЗаменить = "&УсловиеНаДокумент";
		Если ТипЗнч(ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция") Тогда
			НаЧтоЗаменить = "Позиция = &Документ";
		Иначе	
			НаЧтоЗаменить = "ДокументПланирования = &Документ";
		КонецЕсли;
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, ЧтоЗаменить,НаЧтоЗаменить);
	Иначе	
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ПланируемоеПоступлениеДенежныхСредств.СуммаОстаток КАК Сумма
		|ИЗ
		|	РегистрНакопления.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.Остатки(,
		|		&УсловиеНаДокумент) КАК ПланируемоеПоступлениеДенежныхСредств";
		
		ЧтоЗаменить = "&УсловиеНаДокумент";
		Если ТипЗнч(ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ПозицияПоступления") Тогда
			НаЧтоЗаменить = "Позиция = &Документ";
		Иначе	
			НаЧтоЗаменить = "ДокументПланирования = &Документ";
		КонецЕсли;
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, ЧтоЗаменить,НаЧтоЗаменить);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Документ", ДокументПланирования);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка 		 = РезультатЗапроса.Выбрать();
	
	ОсталосьЗаплатить = 0;
	Если Выборка.Следующий() Тогда
		ОсталосьЗаплатить = Выборка.Сумма;
	КонецЕсли;
	
	ВалютаДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументПланирования, "ВалютаДокумента");
	
	Если ВалютаПлатежа <> ВалютаДокумента Тогда
		СуммаКОплате = Параметры.СуммаПлатежа;
		Сумма 		 = ПересчитатьСуммыКОплате(СуммаКОплате, ВалютаПлатежа, ВалютаДокумента);
	Иначе
		Элементы.ГруппаСуммаОплаты.Видимость = Ложь;
		Сумма = Параметры.СуммаПлатежа;
	КонецЕсли; 
	
	НадписьОсталосьЗаплатить = НСтр("ru='Доступно: %1';en='Available: %1'"); 
	НадписьОсталосьЗаплатить = СтрШаблон(НадписьОсталосьЗаплатить, 
								РаботаСКурсамиВалют.СформироватьСуммуПрописью(ОсталосьЗаплатить, ВалютаДокумента));
	
КонецПроцедуры

&НаКлиенте
Процедура ОК(Команда)
	
	Если СуммаЗаполненаКорректно() Тогда
		Результат = Новый Структура;
		Результат.Вставить("Команда", 		  "ОК");
		Результат.Вставить("Сумма", 		  Сумма);
		Результат.Вставить("ВалютаПлатежа",   ВалютаПлатежа);
		Результат.Вставить("СуммаДокумента" , ОсталосьЗаплатить);
		
		Закрыть(Результат);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура СуммаКОплатеПриИзменении(Элемент)
	
	Сумма = ПересчитатьСуммыКОплате(СуммаКОплате, ВалютаПлатежа, ВалютаДокумента);
	
	СуммаЗаполненаКорректно();	
	
КонецПроцедуры

&НаКлиенте
Процедура СуммаПриИзменении(Элемент)

	Если СуммаЗаполненаКорректно() Тогда
		СуммаКОплате = ПересчитатьСуммыКОплате(Сумма, ВалютаДокумента, ВалютаПлатежа);
	Иначе
		Сумма = ОсталосьЗаплатить;
	КонецЕсли;
	
КонецПроцедуры

//  Процедура пересчитывает суммы к оплате. 
//
&НаСервере
Функция ПересчитатьСуммыКОплате(Сумма, ВалютаНач, ВалютаКон)

	НачальныйКурс = бит_КурсыВалют.ПолучитьКурсВалюты(ВалютаНач, ТекущаяДатаСеанса());
	КонечныйКурс  = бит_КурсыВалют.ПолучитьКурсВалюты(ВалютаКон, ТекущаяДатаСеанса());
	
	Возврат РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(Сумма, НачальныйКурс, КонечныйКурс);
	
КонецФункции // ПересчитатьСуммыКОплате()

&НаКлиенте
Функция СуммаЗаполненаКорректно()

	Отказ = Ложь;
	Если Сумма > ОсталосьЗаплатить Тогда
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Поле", "Корректность",
							НСтр("ru='Сумма';en='Amount'"),,, НадписьОсталосьЗаплатить);
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "Сумма",, Отказ); 
	КонецЕсли;
	
	Возврат НЕ Отказ;
	
КонецФункции
 