&НаКлиенте
Процедура КомандаОбновить(Команда)
	
	НачатьОтложенноеОбновлениеДереваСчетов();
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ДействиеДеревоСчетаУровень(Команда)
	
	КнопкиУровней = Элементы.ДеревоСчетаУровни.ПодчиненныеЭлементы;
	НомПодчерк = Найти(Команда.Имя,"_");
	Если НомПодчерк > 0 Тогда
		 НомУровняСтр = Сред(Команда.Имя,НомПодчерк+1);
		 Попытка
			 НомУровня = Число(НомУровняСтр);
		 Исключение
			 НомУровня = -1;
		 КонецПопытки; 
		 
		 Если НомУровня > 0 Тогда
		   бит_РаботаСДиалогамиКлиент.РазвернутьДоУровня(Элементы.ДеревоСчета,ДеревоСчета,НомУровня);
		   инд = 1;
		   Для каждого Кнопка Из КнопкиУровней Цикл
		   	   Кнопка.Пометка = Ложь;
			   Если инд = НомУровня Тогда
			   	  Кнопка.Пометка = Истина;
			   КонецЕсли; 
			   инд = инд+1;
		   КонецЦикла; 
		 КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаОткрытьНастройки(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТекущийОбъект",Объект);
	
	Оповещение = Новый ОписаниеОповещения("ОткрытьНастройкиОкончание",ЭтотОбъект);
	ОткрытьФорму("Обработка.бит_РабочееМестоКазначея.Форма.ФормаНастройки", ПараметрыФормы,
		ЭтотОбъект,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте 
Процедура ОткрытьНастройкиОкончание(РезультатВыбора, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(РезультатВыбора) = Тип("Структура") И РезультатВыбора.Команда = "ОК" Тогда
		ОбработкаИзмененияНастроек(РезультатВыбора);
		ВидимостьДанныхПоВыделеннымДокументам(ЭтотОбъект);
		УстановитьЗаголовокФормы(ЭтотОбъект);
		ИзменитьДоступностьПриИзмененииНастроек(ЭтотОбъект, Истина);
	КонецЕсли; 
	
КонецПроцедуры // ОткрытьНастройкиОкончание()

&НаКлиенте
Процедура КомандаВидимостьПанелиНастроек(Команда)
	
	ПанельНастройкиВидимость = НЕ ПанельНастройкиВидимость;
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаВОперДень(Команда)
	
	Если Объект.ОперативныйДень < Объект.НачалоПериода ИЛИ Объект.ОперативныйДень > Объект.КонецПериода Тогда
		ВызватьИсключение НСтр("ru='Дата переноса за границами периода рабочего места казначея.';
							   |en='Date of transfer outside the workplace treasurer period.'");
	КонецЕсли; 

	Если КомандаВКолонкеНеПоддерживается() Тогда
		Возврат;
	КонецЕсли; 
	
	ВыделенныеСтроки = Элементы.ДеревоСчета.ВыделенныеСтроки;
	Если КомандаВСтрокеНеПоддерживается(ВыделенныеСтроки) ИЛИ ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 
	
	ПараметрыИзменения = ПараметрыИзмененияРеквизитовДокументов(ВыделенныеСтроки, Объект.ОперативныйДень);
	
	Если ПараметрыИзменения.Количество()>0 Тогда
		 ВыполнитьГрупповоеИзменениеРеквизитов(ПараметрыИзменения);	
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаПеренестиНаДату(Команда)
	
	Если КомандаВКолонкеНеПоддерживается() Тогда
		Возврат;
	КонецЕсли; 

	ВыделенныеСтроки = Элементы.ДеревоСчета.ВыделенныеСтроки;
	Если КомандаВСтрокеНеПоддерживается(ВыделенныеСтроки) ИЛИ ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 
	
	ИмяПоля 	  = СтрЗаменить(Элементы.ДеревоСчета.ТекущийЭлемент.Имя, "ДеревоСчета","");
	ТекущийПериод = '0001-01-01';
	Для каждого Элемент Из КолонкиПериодов Цикл
		Если ИмяПоля = Элемент.Представление Тогда
			ТекущийПериод = Элемент.Значение;
		КонецЕсли; 
	КонецЦикла;
	
	Если ТекущийПериод < Объект.ОперативныйДень Тогда	
		ДатаПереноса = Объект.ОперативныйДень;
	Иначе	
		ДатаПереноса = ТекущийПериод;
	КонецЕсли; 
	
	Оповещение = Новый ОписаниеОповещения("КомандаПеренестиНаДатуЗавершение", ЭтотОбъект, ВыделенныеСтроки); 
	ТекстПодсказки = НСтр("ru='Введите новую дату платежа';en='Enter the new date of payment'"); 
	ПоказатьВводДаты(Оповещение, ДатаПереноса, ТекстПодсказки, ЧастиДаты.Дата);
	
КонецПроцедуры

// Обработчик завершения выбора диалога ввода даты.
//  См. Синтакс-помощник: ПоказатьВводДаты().
//
&НаКлиенте 
Процедура КомандаПеренестиНаДатуЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если НЕ Результат = Неопределено Тогда
		
		ДатаПереноса = ДатаСоСдвигом(Результат, Объект.Периодичность);
		
		Если ДатаПереноса < ДатаСоСдвигом(ТекущийДень, Объект.Периодичность) Тогда
			ВызватьИсключение НСтр("ru='Перенос в период ранее текущего дня не поддерживается.';
								   |en='Transferring the period before the current day are not supported.'");
		КонецЕсли;
		
		Если ДатаПереноса < ДатаСоСдвигом(Объект.НачалоПериода, Объект.Периодичность)
		 ИЛИ ДатаПереноса > ДатаСоСдвигом(Объект.КонецПериода, Объект.Периодичность, Ложь) Тогда
			ВызватьИсключение НСтр("ru='Дата переноса за границами периода рабочего места казначея.';
								   |en='Date of transfer outside the workplace treasurer period.'");
		КонецЕсли; 
		
		// Коллекция колонок всегда в рамках периода. Иначе - это ошибка при программировании.
		КолонкаПериода = КолонкиПериодов.НайтиПоЗначению(ДатаПереноса);
		КолонкаПериода.Пометка = Истина;
		
		УпралениеВидимостьюКолонкиПериода("ДеревоСчета" + КолонкаПериода.Представление, КолонкаПериода.Пометка, ЭтотОбъект);

		ПараметрыИзменения = ПараметрыИзмененияРеквизитовДокументов(ДополнительныеПараметры, ДатаПереноса);
		Если ПараметрыИзменения.Количество()>0 Тогда
			ВыполнитьГрупповоеИзменениеРеквизитов(ПараметрыИзменения);
		КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаПеренестиНаБанкСчет(Команда)
	
	Если КомандаВКолонкеНеПоддерживается() Тогда
		Возврат;
	КонецЕсли; 

	ТекстСообщения = ""; 
	Отказ 		   = Ложь;
	
	Отбор = ОтборСпискаДляПереносаНаСчет(ТекстСообщения, Отказ);
	Если Отказ Тогда
		ПоказатьПредупреждение(, ТекстСообщения,, НСтр("ru='Рабочее место казначея';en='Financial Officer Workplace'"));
	Иначе
		ВыделенныеСтроки = Элементы.ДеревоСчета.ВыделенныеСтроки;
		КомандаВСтрокеНеПоддерживается = КомандаВСтрокеНеПоддерживается(ВыделенныеСтроки) ИЛИ ВыделенныеСтроки.Количество() = 0;
		Если НЕ КомандаВСтрокеНеПоддерживается Тогда
			Оповещение = Новый ОписаниеОповещения("КомандаПеренестиНаБанкСчетЗавершение", ЭтотОбъект, ВыделенныеСтроки); 

			ПараметрыПередачи = Новый Структура();
			ПараметрыПередачи.Вставить("Отбор"			   , 	 Отбор);
			ПараметрыПередачи.Вставить("ЗакрыватьПриВыборе", 	 Истина);
			ПараметрыПередачи.Вставить("МножественныйВыбор", 	 Ложь);
			
			ИмяФормыВыбора = СтрШаблон("Справочник.%1.ФормаВыбора", 
								бит_ОбщегоНазначенияКлиентСерверПереопределяемый.ИмяСправочникаБанковскихСчетов());
			ОткрытьФорму(ИмяФормыВыбора, ПараметрыПередачи,,,,,Оповещение);
		КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры

// Обработчик завершения открытия формы.
//  См. Синтакс-помощник: ОткрытьФорму().
//
&НаКлиенте 
