&НаКлиенте
Процедура КомандаГрупповаяОплата(Команда)
	
	МассивОплата = Новый Массив;

	КоллекцияОрганизации = ДеревоСчета.ПолучитьЭлементы();
	Для каждого ТекЭлемент Из КоллекцияОрганизации Цикл
		СформироватьМассивОплаты(ТекЭлемент, МассивОплата, "ГрупповаяОплата");
	КонецЦикла;
	
	Позиции = СформироватьСтруктуруПозиций(МассивОплата);
	Если Позиции.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru='Отсутствуют платежные позиции для групповой оплаты.';
							   |en='No payment position for the group payment.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли; 
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Позиции",	   					Новый ФиксированныйМассив(Позиции));
	ПараметрыФормы.Вставить("ДатаОплаты",  					Объект.ОперативныйДень);
	ПараметрыФормы.Вставить("РежимЗаписиРасчетыЧерезБанк",  Объект.РежимЗаписиРасчетыЧерезБанк);
	ПараметрыФормы.Вставить("РежимЗаписиРасчетыЧерезКассу", Объект.РежимЗаписиРасчетыЧерезКассу);
	
	Оповещение = Новый ОписаниеОповещения("КомандаГрупповаяОплатаЗавершение", ЭтотОбъект); 
	ОткрытьФорму("Обработка.бит_ГрупповаяОплатаЗаявок.Форма", ПараметрыФормы, ЭтотОбъект, ЭтотОбъект,,, Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаГрупповаяОплатаЗавершение(Результат, Дополнительно) Экспорт

	Если НЕ ЗначениеЗаполнено(Результат) ИЛИ НЕ ЭтоАдресВременногоХранилища(Результат) Тогда
		Возврат;	
	КонецЕсли;
	
	СозданоРанее   = СписокДокументовДвиженияДС.Количество(); 			
	НовыеДокументы = КомандаГрупповаяОплатаЗавершениеНаСервере(Результат);
	
	Для каждого Элемент Из НовыеДокументы Цикл
		СписокДокументовДвиженияДС.Добавить(Элемент);		
	КонецЦикла; 	
		
	ПослеЗаписиДокументовОплаты(СозданоРанее, СписокДокументовДвиженияДС.Количество());

	НачатьОтложенноеОбновлениеДереваСчетов();
	
КонецПроцедуры

&НаСервере
Функция КомандаГрупповаяОплатаЗавершениеНаСервере(АдресВХранишище)

	Результат = ПолучитьИзВременногоХранилища(АдресВХранишище);	
	НовыеДокументы = Результат.ВыгрузитьКолонку("ДокументОплаты");
	НовыеДокументы = ОбщегоНазначенияКлиентСервер.СвернутьМассив(НовыеДокументы);
	
	Возврат НовыеДокументы;
	
КонецФункции

