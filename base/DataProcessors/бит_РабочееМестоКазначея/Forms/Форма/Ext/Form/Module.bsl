
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	
	ИзменитьДоступностьПриИзмененииНастроек(ЭтотОбъект, Ложь);
	
	КэшЗначений = Новый Структура;
	КэшЗначений.Вставить("ТекущийПользователь",	Пользователи.ТекущийПользователь());
	КэшЗначений.Вставить("НастраиваемыйОбъект",	Метаданные.Обработки.бит_РабочееМестоКазначея.ПолноеИмя());
	КэшЗначений.Вставить("ТипНастройки",		Перечисления.бит_ТипыСохраненныхНастроек.Обработки);
	КэшЗначений.Вставить("ИзмеренияДоп",		бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Дополнительные","Синоним"));
	КэшЗначений.Вставить("НастройкиИзмерений",	бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений"));
	
	// Настроим отображение полей доп. аналитик в дереве Дерево счета.
	бит_МеханизмДопИзмерений.ОтобразитьДополнительныеИзмеренияВТабличномПоле_Управляемая(
		ЭтотОбъект, "ДеревоСчета", КэшЗначений.ИзмеренияДоп, КэшЗначений.НастройкиИзмерений);
	
	// Настроим отображение полей доп. аналитик в дереве ТекДокументТаблица.
	бит_МеханизмДопИзмерений.ОтобразитьДополнительныеИзмеренияВТабличномПоле_Управляемая(
		ЭтотОбъект, "ТекДокументТаблица", КэшЗначений.ИзмеренияДоп, КэшЗначений.НастройкиИзмерений);
																							
	ИмяСкдДляМассиваСчетов 	   = "СхемаКомпоновкиДанных";
	АдресСхемыКомпоновкиДанных = ИнициализироватьКомпоновщик(Объект.Компоновщик,ИмяСкдДляМассиваСчетов,
											УникальныйИдентификатор);
	
	ЗаполнитьФормуПоУмолчанию();
	ТекущийДень = НачалоДня(ТекущаяДатаСеанса());

	// Применим настройку по-умолчанию, если таковая есть.
	ТекущаяНастройка = ПолучитьНастройкиПриСозданииНаСервере();	
	ПрименитьНастройки(ТекущаяНастройка);
	
	МаксУровеньДеревоСчета = 7;
	// АПК:1297-выкл Строковый параметр.
	НастройкиПанелей = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("НастройкиПользователя",
								"Настройки панелей РМК", НастройкиПанелейПоУмолчанию(ЭтотОбъект));
	// АПК:1297-выкл
	ЗаполнитьЗначенияСвойств(ЭтотОбъект,  НастройкиПанелей);	
	
	Элементы.ГруппаТекущийДокумент.Высота = Объект.ВысотаПанелиТекущийДокумент;
	УстановитьЗаголовокФормы(ЭтотОбъект);
		
	ИспользоватьПрогнозы = ПолучитьФункциональнуюОпцию("бит_кзн_ИспользоватьПрогнозыПлатежейИПоступлений");
	Если НЕ ИспользоватьПрогнозы Тогда
		Объект.ВыводитьПрогнозыПлатежей = Ложь;	
	КонецЕсли;

	УправлениеФормой(ЭтотОбъект);
	ВидимостьДанныхПоВыделеннымДокументам(ЭтотОбъект);
	УстановитьВидимостьДекорацияПерейтиКСформированнымДокументам(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	Если НЕ ЗавершениеРаботы Тогда
	// АПК:1297-выкл Строковый параметр.
		ОбщегоНазначенияВызовСервера.ХранилищеОбщихНастроекСохранить("НастройкиПользователя",
			"Настройки панелей РМК", НастройкиПанелейПоУмолчанию(ЭтотОбъект));
	// АПК:1297-вкл
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

