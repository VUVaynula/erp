#Область РеестрПлатежей

&НаКлиенте
Процедура СоздатьРеестрыПлатежей(СводныйРеестр)
	
	Если СводныйРеестр Тогда
		МассивОплата = Новый Массив;		
		КоллекцияОрганизации = ДеревоСчета.ПолучитьЭлементы();
		Для каждого ТекЭлемент Из КоллекцияОрганизации Цикл
			СформироватьМассивОплаты(ТекЭлемент, МассивОплата, "СформироватьСводныйРеестр");
		КонецЦикла; 
		
		Если МассивОплата.Количество() >0 Тогда
			СозданоРанее = СписокРеестры.Количество();
			СоздатьСводныйРеестр(МассивОплата);
			ПослеЗаписиДокументовОплаты(СозданоРанее, СписокРеестры.Количество());
		КонецЕсли; 
	Иначе	
		РеестрыОрганизаций = Новый Соответствие;
		КоллекцияОрганизации = ДеревоСчета.ПолучитьЭлементы();
		Для каждого ТекЭлемент Из КоллекцияОрганизации Цикл
			МассивОплата = Новый Массив;		
			СформироватьМассивОплаты(ТекЭлемент, МассивОплата, "");
			Если МассивОплата.Количество()>0 Тогда
				РеестрыОрганизаций.Вставить(ТекЭлемент.Организация,МассивОплата);
			КонецЕсли; 
		КонецЦикла; 
		
		Если РеестрыОрганизаций.Количество() > 0 Тогда
			СозданоРанее = СписокРеестры.Количество();
			
			СоздатьРеестрыПлатежейНаСервере(РеестрыОрганизаций);
			ПослеЗаписиДокументовОплаты(СозданоРанее, СписокРеестры.Количество());
		КонецЕсли; 
	КонецЕсли;	

	НачатьОтложенноеОбновлениеДереваСчетов();
	
КонецПроцедуры

 &НаСервере
Процедура СоздатьСводныйРеестр(МассивИД)

	СоздатьРеестр(Справочники.Организации.ПустаяСсылка(), МассивИД);
	 
 КонецПроцедуры // СоздатьСводныйРеестр()

 &НаСервере
Процедура СоздатьРеестр(Организация, МассивИд)
	
	ДокРеестр = Документы.бит_кзн_РеестрПлатежей.СоздатьДокумент();
	
	ДокРеестр.Организация	= Организация;
	ДокРеестр.Дата			= Объект.ОперативныйДень;
	ДокРеестр.Ответственный	= бит_УправлениеПользователямиСервер.ЗначениеПоУмолчаниюТиповой("ОсновнойОтветственный", Пользователи.ТекущийПользователь());
	ДокРеестр.УстановитьВремя(РежимАвтоВремя.ТекущееИлиПоследним);
	
	МассивЗаявокНаПеремещение = Новый Массив;
	
	Для каждого Ид Из МассивИд Цикл
		ЭлементДерева = ДеревоСчета.НайтиПоИдентификатору(Ид);
		Если НЕ ЭлементДерева = Неопределено Тогда
			
			Если (ТипЗнч(ЭлементДерева.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств")
				ИЛИ ТипЗнч(ЭлементДерева.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию"))
				И МассивЗаявокНаПеремещение.Найти(ЭлементДерева.ДокументПланирования) = Неопределено Тогда
			
				ДобавитьСтрокуРеестра(ДокРеестр, ЭлементДерева, Ложь);
				
				МассивЗаявокНаПеремещение.Добавить(ЭлементДерева.ДокументПланирования);
			ИначеЕсли ТипЗнч(ЭлементДерева.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств") Тогда 
				Продолжить;
			ИначеЕсли ЗначениеЗаполнено(ЭлементДерева.ПлатежнаяПозиция)
				И НЕ ТипЗнч(ЭлементДерева.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств")
				И НЕ ТипЗнч(ЭлементДерева.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда
			
				ДобавитьСтрокуРеестра(ДокРеестр, ЭлементДерева, Истина);
			Иначе 
				Для каждого Эл Из ЭлементДерева.ПолучитьЭлементы() Цикл
					ДобавитьСтрокуРеестра(ДокРеестр, Эл, Ложь);
				КонецЦикла; 
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла; 
	
	Если ДокРеестр.ТаблицаПлатежи.Количество()>0 Тогда	
		бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ДокРеестр,РежимЗаписиДокумента.Запись,,Объект.РежимСообщений);
		СписокРеестры.Добавить(ДокРеестр.Ссылка);
	КонецЕсли;
	
КонецПроцедуры // СоздатьРеестрПлатежей()

&НаСервере
Процедура ДобавитьСтрокуРеестра(ДокРеестр, ЭлементДерева, ОдиночнаяПозиция)

	Если ЭлементДерева.Выполнять = 0 Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = ДокРеестр.ТаблицаПлатежи.Добавить();
	НоваяСтрока.Организация 			= ЭлементДерева.Организация;
	НоваяСтрока.ЗаблокироватьСтроку 	= 0;
	НоваяСтрока.ЗаявкаПлатежнаяПозиция 	= ЭлементДерева.ДокументПланирования;
	НоваяСтрока.ОдиночнаяПозиция 		= ОдиночнаяПозиция;
	НоваяСтрока.ПлатежнаяПозиция 		= ЭлементДерева.ПлатежнаяПозиция;
	НоваяСтрока.Статус 					= ЭлементДерева.СтатусПозиции;
	НоваяСтрока.ФормаОплаты 			= ЭлементДерева.ПлатежнаяПозиция.ФормаОплаты;
	НоваяСтрока.СуммаКОплате 	= ЭлементДерева.Сумма;
	СтрОплата = Документы.бит_кзн_ПлатежнаяПозиция.ПолучитьОстаток(ЭлементДерева.ПлатежнаяПозиция);
	НоваяСтрока.СуммаОстаток 	= СтрОплата.Остаток;
	НоваяСтрока.СуммаДокумента 	= ЭлементДерева.ПлатежнаяПозиция.СуммаДокумента;	
	НоваяСтрока.СуммаПлан 		= ЭлементДерева.Сумма;
	НоваяСтрока.ВалютаПлатежа 	= ЭлементДерева.ВалютаДенежныхСредств;
	НоваяСтрока.ВалютаДокумента	= ЭлементДерева.ПлатежнаяПозиция.ВалютаДокумента;
	
КонецПроцедуры // ДобавитьСтрокуРеестраПлатежей()

 &НаСервере
Процедура СоздатьРеестрыПлатежейНаСервере(РеестрыОрганизаций)
	 	 
	 Для каждого КиЗ Из РеестрыОрганизаций Цикл	 
	 	  Организация = КиЗ.Ключ;
		  МассивИд = КиЗ.Значение;		  
		  СоздатьРеестр(КиЗ.Ключ, КиЗ.Значение);		  
	 КонецЦикла; 

КонецПроцедуры
 
#КонецОбласти // РеестрПлатежей

#Область Статистика

&НаКлиенте
Процедура ПересчитатьЗначенияВыделенныхДокументов(фВыполнять, Сумма, ПлатПозиция)

	НайденноеЗнач = ВыделенныеДокументыСписокПозиций.НайтиПоЗначению(ПлатПозиция);
	Если фВыполнять
		И НайденноеЗнач <> Неопределено Тогда	
		Возврат;
	ИначеЕсли НЕ фВыполнять
		И НайденноеЗнач = Неопределено Тогда	
		Возврат;
	КонецЕсли; 
	
	Если фВыполнять Тогда
		ВыделенныеДокументыСписок.Добавить(Сумма);
	Иначе	
		элСписка = ВыделенныеДокументыСписок.НайтиПоЗначению(Сумма);
		ВыделенныеДокументыСписок.Удалить(элСписка);
	КонецЕсли; 
	
	Если фВыполнять Тогда
		ВыделенныеДокументыКоличество = ВыделенныеДокументыКоличество + 1;
		ВыделенныеДокументыСумма = ВыделенныеДокументыСумма + Сумма;
	Иначе	
		ВыделенныеДокументыКоличество = ВыделенныеДокументыКоличество - 1;
		ВыделенныеДокументыСумма = ВыделенныеДокументыСумма - Сумма;
	КонецЕсли; 

	Если ВыделенныеДокументыСписок.Количество()>0 Тогда
		ВыделенныеДокументыСписок.СортироватьПоЗначению(НаправлениеСортировки.Убыв);
		ВыделенныеДокументыМаксимум = Число(Строка(ВыделенныеДокументыСписок[0]));
		
		ВыделенныеДокументыСписок.СортироватьПоЗначению(НаправлениеСортировки.Возр);
		ВыделенныеДокументыМинимум = Число(Строка(ВыделенныеДокументыСписок[0]));
	Иначе	
		ВыделенныеДокументыМаксимум = 0;
		ВыделенныеДокументыМинимум = 0;
	КонецЕсли; 
	
	Если ВыделенныеДокументыКоличество <> 0 Тогда
		ВыделенныеДокументыСреднее = ВыделенныеДокументыСумма/ВыделенныеДокументыКоличество;
	Иначе	
		ВыделенныеДокументыСреднее = 0;
	КонецЕсли; 
	
	Если фВыполнять Тогда
		ВыделенныеДокументыСписокПозиций.Добавить(ПлатПозиция);
	Иначе	
		элСписка = ВыделенныеДокументыСписокПозиций.НайтиПоЗначению(ПлатПозиция);
		ВыделенныеДокументыСписокПозиций.Удалить(элСписка);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОчиститьЗначенияВыделенныхДокументов(Форма)
	
	Форма.ВыделенныеДокументыСумма 			= 0;
	Форма.ВыделенныеДокументыКоличество 	= 0;
	Форма.ВыделенныеДокументыМаксимум 		= 0;
	Форма.ВыделенныеДокументыМинимум 		= 0;
	Форма.ВыделенныеДокументыСреднее 		= 0;
	Форма.ВыделенныеДокументыСписок 		= Новый СписокЗначений;
	Форма.ВыделенныеДокументыСписокПозиций 	= Новый СписокЗначений;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСтатистику()
	
	ОчиститьЗначенияВыделенныхДокументов(ЭтотОбъект);
	ДополнитьСтатистикуВыделенныхСтрок(ДеревоСчета);
	
	ВыделенныеДокументыКоличество = ВыделенныеДокументыСписокПозиций.Количество();
	
	Если ВыделенныеДокументыКоличество > 0 Тогда
		ВыделенныеДокументыСписок.СортироватьПоЗначению(НаправлениеСортировки.Убыв);
		ВыделенныеДокументыМаксимум = ВыделенныеДокументыСписок[0];
					
		ВыделенныеДокументыСписок.СортироватьПоЗначению(НаправлениеСортировки.Возр);
		ВыделенныеДокументыМинимум  = ВыделенныеДокументыСписок[0];
					
		ВыделенныеДокументыСреднее  = ВыделенныеДокументыСумма/ВыделенныеДокументыКоличество;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьСтатистикуВыделенныхСтрок(СтрокаРодитель)
	
	КоллекцияСтрок = СтрокаРодитель.ПолучитьЭлементы();
	Для каждого СтрокаДерева Из КоллекцияСтрок Цикл
		ПлатежнаяПозиция = СтрокаДерева.ПлатежнаяПозиция;
		СуммаСтроки      = СтрокаДерева.Сумма; 
		
		Если СтрокаДерева.Выполнять И ЗначениеЗаполнено(ПлатежнаяПозиция) Тогда
			НайденноеЗнач = ВыделенныеДокументыСписокПозиций.НайтиПоЗначению(ПлатежнаяПозиция);
			Если НайденноеЗнач <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ВыделенныеДокументыСписокПозиций.Добавить(ПлатежнаяПозиция);
			ВыделенныеДокументыСписок.Добавить(СуммаСтроки);
			
			ВыделенныеДокументыСумма = ВыделенныеДокументыСумма + СуммаСтроки;
		КонецЕсли;
		ДополнитьСтатистикуВыделенныхСтрок(СтрокаДерева);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти // Статистика

#Область ЗаполнениеОсновнойОбластиРМК

&НаСервере
Функция ПараметрыОбновленияДереваСчетов()

	ДанныеФормы = Обработки.бит_РабочееМестоКазначея.НовыеПараметрыИзДанныхФормы();	
	ЗаполнитьЗначенияСвойств(ДанныеФормы, ЭтотОбъект);
	
	ДанныеФормы.ДеревоСчета = РеквизитФормыВЗначение("ДеревоСчета"); 
	
	ДанныеОбъекта = Обработки.бит_РабочееМестоКазначея.НовыеПараметрыИзДанныхОбъекта();
	ЗаполнитьЗначенияСвойств(ДанныеОбъекта, Объект);
	
	ДанныеОбъекта.ПользовательскиеНастройки = Объект.Компоновщик.ПользовательскиеНастройки;
	ДанныеОбъекта.Счета		  				= Объект.Счета.Выгрузить();

	ПараметрыОбновления = Новый Структура;
	ПараметрыОбновления.Вставить("ДанныеФормы",   ДанныеФормы);
	ПараметрыОбновления.Вставить("ДанныеОбъекта", ДанныеОбъекта);
	
	Возврат ПараметрыОбновления;
	
КонецФункции

&НаСервере
Процедура ОбновитьДеревоСчетов()

	// Проверка возможности формирования.
	Отказ = НЕ ПериодЗаполненПравильно(ЭтотОбъект);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;  
	
	// Интерфейсное решение для сохранения текущей строки списка. 
	ТекущаяПозиция = Новый Структура("Измерение, ПлатежнаяПозиция, Искать", 
						Неопределено, Неопределено, Ложь);
	ТекущаяСтрока  = Элементы.ДеревоСчета.ТекущаяСтрока;
	Если НЕ ТекущаяСтрока = Неопределено Тогда
		ТекущиеДанные = ДеревоСчета.НайтиПоИдентификатору(ТекущаяСтрока);
		ЗаполнитьЗначенияСвойств(ТекущаяПозиция, ТекущиеДанные);
		ТекущаяПозиция.Искать = Истина;
	КонецЕсли; 
	
	ПараметрыОбновления = ПараметрыОбновленияДереваСчетов();
	РезультатОбновления = Обработки.бит_РабочееМестоКазначея.ОбновитьДеревоСчетов(ПараметрыОбновления.ДанныеФормы, 
								ПараметрыОбновления.ДанныеОбъекта);
	
	АдресРезультата = ПоместитьВоВременноеХранилище(РезультатОбновления, Новый УникальныйИдентификатор);
	ОбновитьДеревоСчетовЗавершениеНаСервере(АдресРезультата, ТекущаяПозиция);

КонецПроцедуры

&НаКлиенте
Процедура НачатьОтложенноеОбновлениеДереваСчетов()
	
	Отказ = НЕ ПериодЗаполненПравильно(ЭтотОбъект);
	Если Отказ Тогда
		Возврат;
	КонецЕсли; 

	// Интерфейсное решение для сохранения текущей строки списка. 
	ТекущаяСтрока = Элементы.ДеревоСчета.ТекущаяСтрока;

	ТекущаяПозиция = Новый Структура("Измерение, ПлатежнаяПозиция, Искать", 
							Неопределено, Неопределено, Ложь);
							
	Если НЕ ТекущаяСтрока = Неопределено Тогда
		ТекущиеДанные = ДеревоСчета.НайтиПоИдентификатору(ТекущаяСтрока);
		ЗаполнитьЗначенияСвойств(ТекущаяПозиция, ТекущиеДанные);
		ТекущаяПозиция.Искать = Истина;
	КонецЕсли; 

	ДлительнаяОперация    = НачатьОтложенноеОбновлениеДереваСчетовНаСервере();
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ОтложенноеОбновлениеДереваСчетовЗавершение", ЭтотОбъект, ТекущаяПозиция);
	ПараметрыОжидания     = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция НачатьОтложенноеОбновлениеДереваСчетовНаСервере()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ВыполняемыйМетод    = "Обработки.бит_РабочееМестоКазначея.ОбновитьДеревоСчетов";
	
	ПараметрыОбновления = ПараметрыОбновленияДереваСчетов();
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ВыполняемыйМетод, 
				ПараметрыОбновления.ДанныеФормы, ПараметрыОбновления.ДанныеОбъекта);
КонецФункции
			
&НаКлиенте
Процедура ОтложенноеОбновлениеДереваСчетовЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка при выполнении, по причине: %1'"); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрШаблон(ТекстСообщения, Результат.КраткоеПредставлениеОшибки));
	Иначе	
		ОбновитьДеревоСчетовЗавершениеНаСервере(Результат.АдресРезультата, ДополнительныеПараметры);
		
		ОчиститьЗначенияВыделенныхДокументов(ЭтотОбъект);
		УстановитьВидимостьДекорацияПерейтиКСформированнымДокументам(ЭтотОбъект);
		
		бит_РаботаСДиалогамиКлиент.РазвернутьДоУровня(Элементы.ДеревоСчета,ДеревоСчета,Объект.УровеньРаскрытияСчетов);
		ИзменитьДоступностьПриИзмененииНастроек(ЭтотОбъект, Ложь);
	КонецЕсли; 
	
КонецПроцедуры 

&НаСервере
Процедура ОбновитьДеревоСчетовЗавершениеНаСервере(АдресРезультата, ТекущаяПозиция)

	ОчиститьИнформационныеПоля();
	РезультатОбновления    = ПолучитьИзВременногоХранилища(АдресРезультата);
	КолонкиПериодов		   = РезультатОбновления.КолонкиПериодов;
	МаксУровеньДеревоСчета = РезультатОбновления.МаксУровеньДеревоСчета;
	
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	// Обновим реквизиты и элементы формы.
	ОбновитьРеквизитыИЭлементыФормыДереваСчетов();
	ЗначениеВРеквизитФормы(РезультатОбновления.ДеревоСчета, "ДеревоСчета");
	
	// Создадим подменю для управления уровнями дерева.
	СоздатьДействияУровней();

	// Установим оформление.
	УстановитьУсловноеОформление();

	// Поискать строку дерева по ключу: ТекПозиция.
	Если ТекущаяПозиция.Искать Тогда
		// Осторожно: Безрекурсивный обход дерева.
		Стек = Новый Массив; 
		ТекущаяСтрока = -1;
		СтрокиДерева  = ДеревоСчета.ПолучитьЭлементы();
		Для каждого СтрокаТаблицы Из СтрокиДерева Цикл
			Если ТекущаяСтрока >= 0 Тогда
				// Установить как текущую.
				Прервать; // Нашли что-то			
			КонецЕсли;
			Стек.Добавить(СтрокаТаблицы);
			
			Пока Стек.Количество() > 0 Цикл
				
				ТекущийОбъект = Стек.Получить(Стек.ВГраница());
				Стек.Удалить(Стек.ВГраница());
				
				Если ТекущийОбъект.Измерение = ТекущаяПозиция.Измерение
					И ТекущийОбъект.ПлатежнаяПозиция = ТекущаяПозиция.ПлатежнаяПозиция Тогда
					ТекущаяСтрока = ТекущийОбъект.ПолучитьИдентификатор();
					Прервать;				
				КонецЕсли;
				
				Для каждого Элемент Из ТекущийОбъект.ПолучитьЭлементы() Цикл
					Стек.Добавить(Элемент);
				КонецЦикла; 
			КонецЦикла;
		КонецЦикла; 
		Если ТекущаяСтрока >= 0 Тогда
			// Установить как текущую.
			Элементы.ДеревоСчета.ТекущаяСтрока = ТекущаяСтрока;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОбновитьРеквизитыИЭлементыФормыДереваСчетов()
	
	// Удалим колонки и реквизиты периодов
	МассивУдалить = Новый Массив;
	Для каждого Элемент Из Элементы.ДеревоСчета.ПодчиненныеЭлементы Цикл
		Если СтрНайти(Элемент.Имя,"ДеревоСчетаП_")>0 Тогда
			МассивУдалить.Добавить(Элемент);
		КонецЕсли; 
	КонецЦикла; 
	
	Для каждого Элемент Из МассивУдалить Цикл
		Элементы.Удалить(Элемент);
	КонецЦикла; 
	
	МассивРеквизитов = ПолучитьРеквизиты("ДеревоСчета");
	МассивУдалить = Новый Массив;
	
	Для каждого Реквизит Из МассивРеквизитов Цикл
		Если СтрНайти(Реквизит.Имя,"П_")>0 Тогда
			МассивУдалить.Добавить(Реквизит.Путь+"."+Реквизит.Имя);
		КонецЕсли; 
	КонецЦикла; 
	
	Если МассивУдалить.Количество()>0 Тогда
		ИзменитьРеквизиты(,МассивУдалить);
	КонецЕсли; 

	Если КолонкиПериодов.Количество() = 0 Тогда
		// Вообще нет данных - ничего не делаем
		Возврат;
	КонецЕсли;	
	
	// Добавим реквизиты и колонки дерева периодов
	// создадим колонки периодов.
	ПервыйПериод    = КолонкиПериодов[0].Значение;
	ПоследнийПериод = КолонкиПериодов[КолонкиПериодов.Количество() - 1].Значение;	
	ОписаниеЧисло   = Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(15,2));
	
	// Добавим реквизиты.
	ДобавляемыеРеквизиты = Новый Массив;
	Для каждого Элемент Из КолонкиПериодов Цикл
		
		ИмяКолонки = Элемент.Представление;
		Значение   = Элемент.Значение;
		
		Если Значение = ПоследнийПериод Тогда
			ЗаголовокКолонки = НСтр("ru = 'На конец периода';en = 'At the end of the period'");
		ИначеЕсли Значение = ПервыйПериод Тогда
			ЗаголовокКолонки = НСтр("ru = 'На начало периода';en = 'At the beginning of the period'");
		Иначе	
			ЗаголовокКолонки = Формат(Значение,"ДЛФ=D");
		КонецЕсли; 
		НовыйРеквизит = Новый РеквизитФормы(ИмяКолонки,ОписаниеЧисло,"ДеревоСчета",ЗаголовокКолонки);
		ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);		
		
	КонецЦикла; 
	
	ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	// Добавим элементы.
	Для каждого Элемент Из КолонкиПериодов Цикл
		
		Значение 	 = Элемент.Значение;
		ИмяКолонки   = Элемент.Представление;		
		ИмяЭлемента  = "ДеревоСчета" + ИмяКолонки;
		НовыйЭлемент = Элементы.Добавить(ИмяЭлемента, Тип("ПолеФормы"), Элементы.ДеревоСчета);
		
		НовыйЭлемент.Вид 			= ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.ПутьКДанным 	= "ДеревоСчета."+ИмяКолонки;
		НовыйЭлемент.ТолькоПросмотр = Истина;
		
		// Установим ширину элемента периода.
		НовыйЭлемент.Ширина = 10;
		НовыйЭлемент.ГоризонтальноеПоложениеВШапке = ГоризонтальноеПоложениеЭлемента.Центр;

	КонецЦикла; 

КонецПроцедуры
 
