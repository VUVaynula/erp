КонецПроцедуры 

&НаСервере
Функция ВыходныеИПраздничныеДни()
	
	ВыходныеИПраздничныеДни = Новый Массив; 
	
	Если НЕ Объект.ВыделятьВыходныеДни ИЛИ НЕ ЗначениеЗаполнено(КолонкиПериодов) Тогда
		Возврат ВыходныеИПраздничныеДни; 	
	КонецЕсли;
		
	НачалоПериода = КолонкиПериодов[0].Значение;
	КонецПериода  = КолонкиПериодов[КолонкиПериодов.Количество() - 1].Значение;

	Календарь = бит_НастройкиПрограммы.Календарь(Неопределено, НачалоПериода);
	
	Если НЕ ЗначениеЗаполнено(Календарь) Тогда
		Возврат ВыходныеИПраздничныеДни;
	КонецЕсли;
	
	ВидыДней = Новый Массив;
	ВидыДней.Добавить(Перечисления.ВидыДнейПроизводственногоКалендаря.Суббота);
	ВидыДней.Добавить(Перечисления.ВидыДнейПроизводственногоКалендаря.Воскресенье);
	ВидыДней.Добавить(Перечисления.ВидыДнейПроизводственногоКалендаря.Праздник);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Календарь", 	   Календарь);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",  КонецПериода);
	Запрос.УстановитьПараметр("ВидыДней",      ВидыДней);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТабКалендарь.Дата КАК Дата
	|ИЗ
	|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ТабКалендарь
	|ГДЕ
	|	ТабКалендарь.ПроизводственныйКалендарь = &Календарь
	|	И ТабКалендарь.ВидДня В(&ВидыДней)
	|	И ТабКалендарь.Дата МЕЖДУ &НачалоПериода И &КонецПериода";
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ВыходныеИПраздничныеДни.Добавить(Выборка.Дата);
	КонецЦикла; 

	Возврат ВыходныеИПраздничныеДни;
	
КонецФункции

&НаСервере
Функция НайтиСтрокуРасходПоступление(ТекущаяСтрока, ВидПеречисления)

	СтрокаРасходПоступление = Неопределено;
	
	Если НЕ ТекущаяСтрока = Неопределено Тогда
		
		Если ВРег(ТекущаяСтрока.ИмяГруппировки) = ВРег("БанковскийСчет") Тогда
			
			СтрокаРасходПоступление = НайтиСтрокуВида(ТекущаяСтрока,ВидПеречисления);
			
		ИначеЕсли ВРег(ТекущаяСтрока.ИмяГруппировки) = ВРег("ВидДанных") Тогда	
			
			СтрокаБанкСчет = ТекущаяСтрока.ПолучитьРодителя();
			СтрокаРасходПоступление = НайтиСтрокуВида(СтрокаБанкСчет,ВидПеречисления);
			
		ИначеЕсли ВРег(ТекущаяСтрока.ИмяГруппировки) = ВРег("ДокументПланирования") Тогда
			
			Если ВРег(ТекущаяСтрока.ПолучитьРодителя().ПолучитьРодителя().ИмяГруппировки) = ВРег("ВидДанных") Тогда 
			
				СтрокаВидДанных = ТекущаяСтрока.ПолучитьРодителя().ПолучитьРодителя();
			
			ИначеЕсли ВРег(ТекущаяСтрока.ПолучитьРодителя().ПолучитьРодителя().ПолучитьРодителя().ИмяГруппировки) = ВРег("ВидДанных") Тогда
				
				СтрокаВидДанных = ТекущаяСтрока.ПолучитьРодителя().ПолучитьРодителя().ПолучитьРодителя();
				
			Иначе
				
				СтрокаВидДанных = ТекущаяСтрока.ПолучитьРодителя();
				
			КонецЕсли; 
			
			Если НЕ СтрокаВидДанных = Неопределено Тогда
				
				Если СтрокаВидДанных.ВидДанных = ВидПеречисления Тогда
					
					СтрокаРасходПоступление = СтрокаВидДанных;
					
				// начало добавления 15.02.2012
				ИначеЕсли СтрокаВидДанных.ВидДанных = Перечисления.бит_ВидыДанныхРабочееМестоКазначея.Прогноз Тогда
					СтрокаРасходПоступление = СтрокаВидДанных.ПолучитьРодителя();
				// конец добавления 15.02.2012
				
				Иначе
					
					СтрокаБанкСчет = СтрокаВидДанных.ПолучитьРодителя();
					СтрокаРасходПоступление = НайтиСтрокуВида(СтрокаБанкСчет,ВидПеречисления);
					
				КонецЕсли; 
				
			КонецЕсли; 
			
		КонецЕсли;  // имя группировки
		
	КонецЕсли; // Есть текущая строка 

	Возврат СтрокаРасходПоступление;
	
КонецФункции // НайтиСтрокуРасход()

&НаСервере
Процедура СформироватьПлатежныеДокументы(ВыделенныеСтроки)
	 	
	// Хранятся заявки на перемещения для которых создались платежные документы.
	ЗаявкиНаПеремещение = Новый Массив;
	
	РезультатРаботы = Новый Массив; 
	
	Для каждого Элемент Из ВыделенныеСтроки Цикл

		ЭлементДерева = ДеревоСчета.НайтиПоИдентификатору(Элемент);
		Если ЭлементДерева = Неопределено Тогда
			Продолжить;	
		КонецЕсли;
	
		Если ЭлементДерева.ПолучитьЭлементы().Количество() > 1 Тогда
			
			ПлатежныеПозиции = Новый Массив;
			Для каждого СтрокаТаблицы Из ЭлементДерева.ПолучитьЭлементы() Цикл
				Если СтрокаТаблицы.Выполнять > 0 Тогда
					СуммаВзаиморасчетов = СтрокаТаблицы.Сумма;
					Если СтрокаТаблицы.ПлатежнаяПозиция.ВалютаДокумента <> СтрокаТаблицы.ВалютаДенежныхСредств Тогда
						СуммаВзаиморасчетов = СтрокаТаблицы.ПлатежнаяПозиция.СуммаДокумента;										
					КонецЕсли;

					АтрибутыПозиции = Новый Структура("Позиция, Сумма", 
												СтрокаТаблицы.ПлатежнаяПозиция, СуммаВзаиморасчетов);
					ПлатежныеПозиции.Добавить(АтрибутыПозиции);
				КонецЕсли; 
			КонецЦикла;
			
			Если ЭлементДерева.ВидДенежныхСредств = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
				РежимЗаписи = Объект.РежимЗаписиРасчетыЧерезБанк;
			Иначе	
				РежимЗаписи = Объект.РежимЗаписиРасчетыЧерезКассу;
			КонецЕсли;
					
			Если ТипЗнч(ЭлементДерева.Измерение) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств") Тогда
				ДанныеЗаполнения = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.НовыеПараметрыДокументаСоздатьПлатежныеДокументы(); 
				ДанныеЗаполнения.Дата		 				  = ДатаОплаты;
				ДанныеЗаполнения.РежимЗаписи 				  = РежимЗаписи;
				
				Для каждого АтрибутыПозиции Из ПлатежныеПозиции Цикл
					ЗаполнитьЗначенияСвойств(ДанныеЗаполнения.Позиции.Добавить(), АтрибутыПозиции);
				КонецЦикла;
				Результат = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.СоздатьДокументыНаОсновеВыделенных(
								ЭлементДерева.Измерение, ДанныеЗаполнения);
				ДокументОплаты = ОбщегоНазначенияКлиентСервер.СвернутьМассив(Результат.ВыгрузитьКолонку("ДокументОплаты"));			
				РезультатРаботы.Добавить(ДокументОплаты);				
			Иначе 
				
				ДанныеЗаполнения = Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.НовыеПараметрыДокументаСоздатьПлатежныеДокументы(); 
				ДанныеЗаполнения.Дата		 = ДатаОплаты;
				ДанныеЗаполнения.РежимЗаписи = РежимЗаписи;
				
				Для каждого АтрибутыПозиции Из ПлатежныеПозиции Цикл
					ЗаполнитьЗначенияСвойств(ДанныеЗаполнения.Позиции.Добавить(), АтрибутыПозиции);
				КонецЦикла;
				Результат = Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.СоздатьДокументыНаОсновеВыделенных(
								ЭлементДерева.Измерение, ДанныеЗаполнения);
				ДокументОплаты = ОбщегоНазначенияКлиентСервер.СвернутьМассив(Результат.ВыгрузитьКолонку("ДокументОплаты"));			
				РезультатРаботы.Добавить(ДокументОплаты);				
			КонецЕсли; 
				
		ИначеЕсли ТипЗнч(ЭлементДерева.Измерение) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств") Тогда  
			
			Если ЗаявкиНаПеремещение.Найти(ЭлементДерева.Измерение) = Неопределено Тогда
				Если ЭлементДерева.ВидДенежныхСредств = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
					РежимЗаписи = Объект.РежимЗаписиРасчетыЧерезБанк;
				Иначе	
					РежимЗаписи = Объект.РежимЗаписиРасчетыЧерезКассу;
				КонецЕсли;
				
				ПараметрыДокумента = бит_Казначейство.НовыеПараметрыСозданияПлатежногоДокумента();
				ПараметрыДокумента.ВызовИзРеестра	 = Ложь;
				ПараметрыДокумента.ДокументОснование = ЭлементДерева.Измерение;
				ПараметрыДокумента.СуммаКОплате      = ЭлементДерева.Сумма;
				ПараметрыДокумента.РежимЗаписи       = РежимЗаписи;

				Результат = Документы.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств.СоздатьПлатежныйДокументНаОсновании(ПараметрыДокумента);
					
				ЗаявкиНаПеремещение.Добавить(ЭлементДерева.Измерение);
				РезультатРаботы.Добавить(Результат);
			КонецЕсли; 
			
		ИначеЕсли ТипЗнч(ЭлементДерева.Измерение) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда  
			
			Если ЗаявкиНаПеремещение.Найти(ЭлементДерева.Измерение) = Неопределено Тогда
				Если ЭлементДерева.ВидДенежныхСредств = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
					РежимЗаписи = Объект.РежимЗаписиРасчетыЧерезБанк;
				Иначе	
					РежимЗаписи = Объект.РежимЗаписиРасчетыЧерезКассу;
				КонецЕсли;

				ПараметрыДокумента = бит_Казначейство.НовыеПараметрыСозданияПлатежногоДокумента();
				ПараметрыДокумента.ВызовИзРеестра	 = Истина;
				ПараметрыДокумента.ДокументОснование = ЭлементДерева.Измерение;
				ПараметрыДокумента.СуммаКОплате      = ЭлементДерева.Сумма;
				ПараметрыДокумента.РежимЗаписи       = РежимЗаписи;
				ЗначениеРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭлементДерева.Измерение,
																				"СтавкаНДС, СуммаНДС");
				ПараметрыДокумента.СтавкаНДС         = ЗначениеРеквизитов.СтавкаНДС;
				ПараметрыДокумента.СуммаНДС          = ЗначениеРеквизитов.СуммаНДС;
				
				Результат = Документы.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию.СоздатьПлатежныйДокументНаОсновании(
								ПараметрыДокумента);
				ЗаявкиНаПеремещение.Добавить(ЭлементДерева.Измерение);
				РезультатРаботы.Добавить(Результат);
			КонецЕсли; 
			
		Иначе 
						
			Если ЗначениеЗаполнено(ЭлементДерева.ПлатежнаяПозиция) Тогда
				ПлатежнаяПозиция = ЭлементДерева.ПлатежнаяПозиция;
			Иначе
				ПодчиненыеСтроки = ЭлементДерева.ПолучитьЭлементы();
				ПлатежнаяПозиция = ПодчиненыеСтроки[0].ПлатежнаяПозиция;
			КонецЕсли;
			
			Если ЭлементДерева.Измерение.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда					
				БанковскийСчетКасса = ПлатежнаяПозиция.БанковскийСчет;					
			ИначеЕсли ЭлементДерева.Измерение.ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Наличные Тогда	
				БанковскийСчетКасса = ПлатежнаяПозиция.Касса;					
			КонецЕсли;
			
			КурсыВалют = Новый Структура("ВалютаДокумента, ВалютаПлатежа", 
							ПлатежнаяПозиция.ВалютаДокумента, ЭлементДерева.ВалютаДенежныхСредств);
							
			СуммаВзаиморасчетов = ЭлементДерева.Сумма;
			
			Если ПлатежнаяПозиция.ВалютаДокумента <> ЭлементДерева.ВалютаДенежныхСредств Тогда
				СуммаВзаиморасчетов = ПлатежнаяПозиция.СуммаДокумента;										
			КонецЕсли;
			
			АтрибутыПозиции  = Новый Структура("Позиция, Сумма", ПлатежнаяПозиция, СуммаВзаиморасчетов);
			ПлатежныеПозиции = Новый Массив;
			ПлатежныеПозиции.Добавить(АтрибутыПозиции);
			
			ПараметрыФормирования = Новый Структура;
			ПараметрыФормирования.Вставить("Дата", 				  ДатаОплаты);
			ПараметрыФормирования.Вставить("БанковскийСчетКасса", БанковскийСчетКасса);
			ПараметрыФормирования.Вставить("Позиции",			  ПлатежныеПозиции);
			
			ПараметрыДокументов = Новый Массив;
			ПараметрыДокументов.Добавить(ПараметрыФормирования);
			
			Если ЭлементДерева.ВидДенежныхСредств = Перечисления.бит_ВидыДенежныхСредств.Безналичные Тогда
				РежимЗаписи = Объект.РежимЗаписиРасчетыЧерезБанк;
			Иначе	
				РежимЗаписи = Объект.РежимЗаписиРасчетыЧерезКассу;
			КонецЕсли;
			
			ПараметрыОплаты = Новый Структура;
			ПараметрыОплаты.Вставить("Позиция", ПлатежнаяПозиция);
			ПараметрыОплаты.Вставить("Сумма", СуммаВзаиморасчетов);
			
			ПараметрыДокументов = Новый Массив;
			ПараметрыДокументов.Добавить(ПараметрыОплаты);

			Если ТипЗнч(ЭлементДерева.Измерение) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств")
				ИЛИ ТипЗнч(ЭлементДерева.Измерение) = Тип("ДокументСсылка.бит_кзн_ПлатежнаяПозиция") Тогда
				
				ДанныеЗаполнения = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.НовыеПараметрыДокументаСоздатьПлатежныеДокументы(); 
				ДанныеЗаполнения.Дата		 = ДатаОплаты;
				ДанныеЗаполнения.РежимЗаписи = РежимЗаписи;

				НоваяСтрока = ДанныеЗаполнения.Позиции.Добавить();
				НоваяСтрока.Позиция = ПлатежнаяПозиция;
				НоваяСтрока.Сумма 	= СуммаВзаиморасчетов;
				
				Результат = Документы.бит_кзн_ЗаявкаНаРасходованиеСредств.СоздатьДокументыНаОсновеВыделенных(
								ЭлементДерева.Измерение, ДанныеЗаполнения);
				РезультатРаботы.Добавить(Результат.ВыгрузитьКолонку("ДокументОплаты"));				
			Иначе
				
				ДанныеЗаполнения = Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.НовыеПараметрыДокументаСоздатьПлатежныеДокументы(); 
				ДанныеЗаполнения.Дата		 = ДатаОплаты;
				ДанныеЗаполнения.РежимЗаписи = РежимЗаписи;
				
				НоваяСтрока = ДанныеЗаполнения.Позиции.Добавить();
				НоваяСтрока.Позиция = ПлатежнаяПозиция;
				НоваяСтрока.Сумма 	= СуммаВзаиморасчетов;
				
				Результат = Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств.СоздатьДокументыНаОсновеВыделенных(
								ЭлементДерева.Измерение, ДанныеЗаполнения);
				РезультатРаботы.Добавить(Результат.ВыгрузитьКолонку("ДокументОплаты"));				
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла; 

	Для каждого Элемент Из РезультатРаботы Цикл
		НовыеДокументы = Новый Массив; 
		Если ТипЗнч(Элемент) = Тип("Массив") Тогда
			НовыеДокументы = Элемент; 	
		ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Элемент, "МассивДокументов") Тогда 	
			НовыеДокументы = Элемент.МассивДокументов;
		КонецЕсли;
		Для каждого НовыйДокумент Из НовыеДокументы Цикл
			СписокДокументовДвиженияДС.Добавить(НовыйДокумент.Ссылка);
		КонецЦикла; 
	КонецЦикла; 
	
	ОбновитьДеревоСчетов();	 
	 
 КонецПроцедуры

&НаСервере
Функция ИзменитьЗаявку(ИдСтроки, СуммаНовая, Разбить)
	
	ДействиеВыполнено = Ложь;
	ОсталосьЗаплатить = 0;
	
	ТекущаяСтрока = ДеревоСчета.НайтиПоИдентификатору(ИдСтроки);
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат ДействиеВыполнено;	
	КонецЕсли; 
	
	Заявка		   = ТекущаяСтрока.Измерение;
	БанковскийСчет = ТекущаяСтрока.ПолучитьРодителя().БанковскийСчет;
	ФормаОплаты    = ТекущаяСтрока.ПолучитьРодителя().ВидДенежныхСредств;
	
	НачатьТранзакцию();
	Попытка
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Заявка", Заявка);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПланируемыйРасходДенежныхСредств.Позиция КАК Позиция,
		|	ПланируемыйРасходДенежныхСредств.СуммаОстаток КАК СуммаДокумента
		|ИЗ
		|	РегистрНакопления.бит_кзн_ПланируемыйРасходДенежныхСредств.Остатки(, ДокументПланирования = &Заявка) 
		|		КАК ПланируемыйРасходДенежныхСредств";
		РезультатЗапроса = Запрос.Выполнить();
		
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("Документ.бит_кзн_ПлатежнаяПозиция");
		ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Ссылка","Позиция");
		Блокировка.Заблокировать();
		
		ПлатежныеПозиции = РезультатЗапроса.Выгрузить();
		
		Если Разбить Тогда
			ОсталосьЗаплатить = ПлатежныеПозиции.Итог("СуммаДокумента") - СуммаНовая;
		КонецЕсли;
		
		Отказ 		 = Ложь;
		Коэффициенты = ПлатежныеПозиции.ВыгрузитьКолонку("СуммаДокумента");
		Суммы 		 = ОбщегоНазначенияКлиентСервер.РаспределитьСуммуПропорциональноКоэффициентам(СуммаНовая, 
							Коэффициенты, 2);
		ПлатежныеПозиции.ЗагрузитьКолонку(Суммы, "СуммаДокумента");	
		
		ПлатежнаяПозиция = Неопределено;
		
		Для каждого СтрокаТаблицы Из ПлатежныеПозиции Цикл
			
			ПлатежнаяПозиция = СтрокаТаблицы.Позиция;
			ДокОбъект        = ПлатежнаяПозиция.ПолучитьОбъект();
			
			ДокОбъект.СуммаДокумента = СтрокаТаблицы.СуммаДокумента;
			ЗначениеСтавки     = бит_БухгалтерскийУчет.ПолучитьСтавкуНДС(ДокОбъект.СтавкаНДС);	
			ДокОбъект.СуммаНДС = бит_БухгалтерияКлиентСервер.РассчитатьСуммуНДС(ДокОбъект.СуммаДокумента,
									Истина, Истина, ЗначениеСтавки);
									
			Если ДокОбъект.ВалютаДокумента = ДокОбъект.ВалютаВзаиморасчетов Тогда
				ДокОбъект.СуммаВзаиморасчетов = ДокОбъект.СуммаДокумента;
			Иначе
				Данные = Новый Структура;
				Данные.Вставить("Сумма", 						 ДокОбъект.СуммаДокумента);
				Данные.Вставить("КурсЧислительВзаиморасчетов",	 ДокОбъект.КурсЧислительВзаиморасчетов);
				Данные.Вставить("КурсЗнаменательВзаиморасчетов", ДокОбъект.КурсЗнаменательВзаиморасчетов);
				Данные.Вставить("СуммаВзаиморасчетов",			 ДокОбъект.СуммаВзаиморасчетов);
				
				ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
					Данные, ДокОбъект.ВалютаДокумента, Константы.ВалютаРегламентированногоУчета.Получить());
				
				ДокОбъект.СуммаВзаиморасчетов = Данные.СуммаВзаиморасчетов; 		
			КонецЕсли;
		
			ДокОбъект.ДополнительныеСвойства.Вставить("ПропуститьКонтрольПревышенияБюджета", Истина);
			ДокОбъект.ДополнительныеСвойства.Вставить("НеСинхронизировать", Истина);
			
			Успех = бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ДокОбъект,РежимЗаписиДокумента.Проведение,,"Ошибки");
			Если НЕ Успех Тогда
				ТекстСообщения = НСтр("ru='Не удалось изменить документ %1.';en='Failed to change document %1.'"); 
				ТекстСообщения = СтрШаблон(ТекстСообщения, СтрокаТаблицы.Позиция);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, СтрокаТаблицы.Позиция,,,Отказ);
				Прервать;
			КонецЕсли; 
		КонецЦикла; 
		
		Если НЕ Отказ Тогда
			Если ОсталосьЗаплатить > 0 Тогда
				Если ПлатежнаяПозиция <> Неопределено Тогда
					ДокОбъект = ПлатежнаяПозиция.Скопировать();
				Иначе
					ВызватьИсключение НСтр("ru = 'Не определен документ-позиция'"); // ++ NB  
					ДокОбъект = Документы.бит_кзн_ПлатежнаяПозиция.СоздатьДокумент();
				КонецЕсли;
				ДанныеЗаполнения = Новый Структура;
				ДанныеЗаполнения.Вставить("Дата", ТекущаяДатаСеанса());
				ДанныеЗаполнения.Вставить("ДатаПлан", ТекущаяДатаСеанса());
				ДанныеЗаполнения.Вставить("ДокументПланирования", Заявка);
				ДанныеЗаполнения.Вставить("СуммаДокумента", ОсталосьЗаплатить);
				
				Если ФормаОплаты = Перечисления.бит_ВидыДенежныхСредств.Наличные Тогда
					ДанныеЗаполнения.Вставить("Касса", БанковскийСчет);
				Иначе	
					ДанныеЗаполнения.Вставить("БанковскийСчет", БанковскийСчет);
				КонецЕсли;
				
				ДокОбъект.Заполнить(ДанныеЗаполнения);
				ДокОбъект.ДополнительныеСвойства.Вставить("НеСинхронизировать", Истина);
				
				Если ДокОбъект.ВалютаДокумента = ДокОбъект.ВалютаВзаиморасчетов Тогда
					ДокОбъект.СуммаВзаиморасчетов = ДокОбъект.СуммаДокумента;
				Иначе
					Данные = Новый Структура;
					Данные.Вставить("Сумма", 						 ДокОбъект.СуммаДокумента);
					Данные.Вставить("КурсЧислительВзаиморасчетов",	 ДокОбъект.КурсЧислительВзаиморасчетов);
					Данные.Вставить("КурсЗнаменательВзаиморасчетов", ДокОбъект.КурсЗнаменательВзаиморасчетов);
					Данные.Вставить("СуммаВзаиморасчетов",			 ДокОбъект.СуммаВзаиморасчетов);
					
					ДенежныеСредстваКлиентСервер.РассчитатьСуммуВзаиморасчетовВСтрокеРасшифровки(
						Данные, ДокОбъект.ВалютаДокумента, Константы.ВалютаРегламентированногоУчета.Получить());
					
					ДокОбъект.СуммаВзаиморасчетов = Данные.СуммаВзаиморасчетов; 		
				КонецЕсли;

				Успех = бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ДокОбъект,РежимЗаписиДокумента.Проведение,,"Ошибки");
				Если НЕ Успех Тогда
					ТекстСообщения = НСтр("ru='Не удалось записать новый документ.';en='Failed to write a new document.'"); 
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если Отказ Тогда
			ОтменитьТранзакцию();
		Иначе	
			ЗафиксироватьТранзакцию();
		КонецЕсли; 
		ДействиеВыполнено = НЕ Отказ;
		
	Исключение
		ОтменитьТранзакцию();

		ТекстСообщения = НСтр("ru = 'Не удалось заблокировать документ для изменения.'; 
							  |en = 'The document could not be blocked for editing.'"); 
		ВызватьИсключение ТекстСообщения;
	КонецПопытки; 
	
	Возврат ДействиеВыполнено;
	
КонецФункции

 &НаСервереБезКонтекста 
 Функция ЗначениеРеквизитаОбъектаСервер(Ссылка, ИмяРеквизита);
 	
 	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, ИмяРеквизита);	
 	
 КонецФункции

 &НаСервере
Функция СформироватьСтруктуруПозиций(МассивОплата)

	СтрПозиций = Новый Массив;
	МассивЗаявокНаПеремещение = Новый Массив;
	Для каждого Элемент Из МассивОплата Цикл
	 
	 	ЭлементДерева = ДеревоСчета.НайтиПоИдентификатору(Элемент);
		
		Если НЕ ЭлементДерева = Неопределено Тогда

			Если ТипЗнч(ЭлементДерева.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств")
				ИЛИ ТипЗнч(ЭлементДерева.ДокументПланирования) = Тип("ДокументСсылка.бит_кзн_ПланируемоеПоступлениеДенежныхСредств") Тогда
			
				Продолжить;
			ИначеЕсли ЗначениеЗаполнено(ЭлементДерева.ПлатежнаяПозиция) И ЭлементДерева.Выполнять > 0 Тогда 
				Разрешено = ПроверитьВозможностьГрупповойОплаты(ЭлементДерева.ПлатежнаяПозиция);
				Если Разрешено Тогда
					
					СуммаВзаиморасчетов = ЭлементДерева.Сумма;
					Если ЭлементДерева.ПлатежнаяПозиция.ВалютаДокумента <> ЭлементДерева.ВалютаДенежныхСредств Тогда
						СуммаВзаиморасчетов = ЭлементДерева.ПлатежнаяПозиция.СуммаДокумента;										
					КонецЕсли;

					Структура = Новый Структура;
					Структура.Вставить("ПлатежнаяПозиция", ЭлементДерева.ПлатежнаяПозиция);
					Структура.Вставить("СуммаКОплате"	 , СуммаВзаиморасчетов);
					СтрПозиций.Добавить(Структура);
				КонецЕсли; 
			Иначе 
				
				Для каждого Эл Из ЭлементДерева.ПолучитьЭлементы() Цикл
					Если Эл.Выполнять > 0 Тогда
						Разрешено = ПроверитьВозможностьГрупповойОплаты(Эл.ПлатежнаяПозиция);
						Если Разрешено Тогда
							СуммаВзаиморасчетов = Эл.Сумма;
							Если Эл.ПлатежнаяПозиция.ВалютаДокумента <> Эл.ВалютаДенежныхСредств Тогда
								СуммаВзаиморасчетов = Эл.ПлатежнаяПозиция.СуммаДокумента;										
							КонецЕсли;
							Структура = Новый Структура;
							Структура.Вставить("ПлатежнаяПозиция", Эл.ПлатежнаяПозиция);
							Структура.Вставить("СуммаКОплате"	 , СуммаВзаиморасчетов);
							СтрПозиций.Добавить(Структура);
						КонецЕсли; 
					КонецЕсли;
				КонецЦикла; 
			КонецЕсли; 
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтрПозиций;
	
КонецФункции // СформироватьСтруктуруПозиций()

&НаСервере
Функция ПроверитьВозможностьГрупповойОплаты(ПлатежнаяПозиция)

	ПарамВидимости = бит_Казначейство.ПодготовитьПараметрыВидимости(ПлатежнаяПозиция.ХозяйственнаяОперация);
	
	Разрешено = Ложь;
	Если ПарамВидимости.ЕстьКонтрагент Тогда
		Если ЗначениеЗаполнено(ПлатежнаяПозиция.Контрагент) Тогда
			Разрешено = Истина;
		Иначе	
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("ПОЛЕ", "Заполнение", 
								НСтр("ru = 'Получатель'; en = 'Recipient'"));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ПлатежнаяПозиция, "Контрагент");				
		КонецЕсли;
	КонецЕсли;
	
	Возврат Разрешено;
	
КонецФункции // ПроверитьВозможностьГрупповойОплаты()

&НаСервере
Функция СохраняемыеНастройки()

	МетаОбъект       = Метаданные.Обработки.бит_РабочееМестоКазначея;
	Исключения = Новый Массив;
	Исключения.Добавить("Компоновщик");
	Исключения.Добавить("КомпоновщикАнализ");	
	Исключения.Добавить("ОперативныйДень");
	
	СохраняемыеНастройки = Справочники.бит_СохраненныеНастройки.УпаковатьРеквизиты(Объект, МетаОбъект, Исключения);
	СохраняемыеНастройки.Вставить("НастройкиКомпоновщика"      ,Объект.Компоновщик.ПользовательскиеНастройки);
	СохраняемыеНастройки.Вставить("НастройкиКомпоновщикаАнализ",Объект.КомпоновщикАнализ.ПользовательскиеНастройки);
	
	Возврат СохраняемыеНастройки;
	
КонецФункции

&НаСервере
Процедура ПрименитьНастройки(ВыбНастройка)
	
	Если ЗначениеЗаполнено(ВыбНастройка) Тогда
		СтруктураНастроек = ВыбНастройка.ХранилищеНастроек.Получить();
		Если ТипЗнч(СтруктураНастроек) = Тип("Структура") Тогда
			МетаОбъект       = Метаданные.Обработки.бит_РабочееМестоКазначея;
			МассивИсключений = Новый Массив;
			МассивИсключений.Добавить("Компоновщик");
			МассивИсключений.Добавить("КомпоновщикАнализ");			
			МассивИсключений.Добавить("ОперативныйДень");
			
			Справочники.бит_СохраненныеНастройки.РаспаковатьРеквизиты(Объект,МетаОбъект,СтруктураНастроек,МассивИсключений);
			Если СтруктураНастроек.Свойство("НастройкиКомпоновщика") Тогда
				Объект.Компоновщик.ЗагрузитьПользовательскиеНастройки(СтруктураНастроек.НастройкиКомпоновщика);
			КонецЕсли; 
			
			Если СтруктураНастроек.Свойство("НастройкиКомпоновщикаАнализ") Тогда
				Объект.КомпоновщикАнализ.ЗагрузитьПользовательскиеНастройки(СтруктураНастроек.НастройкиКомпоновщикаАнализ);
			КонецЕсли; 
		КонецЕсли; // Сохранена структура.
	КонецЕсли; // Настройка заполнена.
	
	ТекущаяНастройка = ВыбНастройка;

	Объект.РежимОстатков = Константы.бит_кзн_РежимОтображенияОстатковДС.Получить();

	УстановитьЗаголовокФормы(ЭтотОбъект);
	
КонецПроцедуры // ПрименитьНастройки()

&НаСервере
Функция ПолучитьНастройкиПриСозданииНаСервере()
	
	// Получим настройку по умолчанию.
	НастройкаПоУмолчанию = бит_ОтчетыСервер.НайтиНастройкуПоУмолчаниюДляОбъекта(КэшЗначений.НастраиваемыйОбъект);
	
	Возврат НастройкаПоУмолчанию;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ДатаСоСдвигом(Дата, Периодичность, НачалоПериода = Истина)
	
	Если Периодичность = ПредопределенноеЗначение("Перечисление.бит_кзн_ПериодичностьРМК.Неделя") Тогда
		Если НачалоПериода Тогда
			НоваяДата = НачалоНедели(Дата);
		Иначе	
			НоваяДата = КонецНедели(Дата);
		КонецЕсли;
	ИначеЕсли Периодичность = ПредопределенноеЗначение("Перечисление.бит_кзн_ПериодичностьРМК.Месяц") Тогда
		Если НачалоПериода Тогда
			НоваяДата = НачалоМесяца(Дата);
		Иначе	
			НоваяДата = КонецМесяца(Дата);
		КонецЕсли;
	Иначе
		НоваяДата = Дата;
	КонецЕсли; 

	Возврат НоваяДата;
	
КонецФункции

&НаКлиенте
Процедура ПоказатьСформированныеДокументы(Результат) Экспорт

	СпискиДокументов = Новый Структура; 
	СпискиДокументов.Вставить("СписокДокументовДвижения", СписокДокументовДвиженияДС.ВыгрузитьЗначения());
	СпискиДокументов.Вставить("СписокРеестры",        	  СписокРеестры.ВыгрузитьЗначения());
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("СпискиДокументов", СпискиДокументов);
	
	ОткрытьФорму("Обработка.бит_РабочееМестоКазначея.Форма.СформированныеДокументы", ПараметрыФормы,,
		ЭтотОбъект,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);  

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписиДокументовОплаты(СозданоРанее, ВсегоСоздано)

	УстановитьВидимостьДекорацияПерейтиКСформированнымДокументам(ЭтотОбъект);	
	
	НовыхДокументов = ВсегоСоздано - СозданоРанее;
	ТекстСообщения  = НСтр("ru = 'Записано документов: %1.'; en = 'Recorded documents: %1.'"); 
	ТекстСообщения  = СтрШаблон(ТекстСообщения, Формат(НовыхДокументов, "ЧДЦ=0"));
	ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения); 
	
	Если Элементы.ДекорацияПерейтиКСформированнымДокументам.Видимость И НовыхДокументов > 0 Тогда
		ТекстСообщения = НСтр("ru = 'Записаны платежные документы.'; en = 'Payment documents recorded.'");
		Подсказка	   = НСтр("ru = 'Перейти к документам ...'; en = 'Go to documents ...'"); 
		ПоказатьОповещениеПользователя(ТекстСообщения, 
			Новый ОписаниеОповещения("ПослеЗаписиДокументовОплатыЗавершение", ЭтотОбъект), Подсказка);	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписиДокументовОплатыЗавершение(Результат) Экспорт 

	ДекорацияПерейтиКДокументамОплатыНажатие(Неопределено);

КонецПроцедуры
 
#КонецОбласти
