	ПараметрыПередачи = Новый Структура; 
	ПараметрыПередачи.Вставить("КлючВарианта", "ОборотыБюджета");
	
	Попытка
		ОткрытьФорму("Отчет.бит_ОборотыБюджета.ФормаОбъекта", ПараметрыПередачи);	
	Исключение
		ТекстСообщения = НСтр("ru = 'Неправильное имя отчета. Обратитесь в группу разработки.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения); 
	КонецПопытки; 

