#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбработатьВыбор(Элемент)
	
	Если Элемент.ТекущийЭлемент = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	ИмяЭлемента = Элемент.ТекущийЭлемент.Имя;
	НавигационнаяСсылкаБлока = Неопределено;
	Если НавигационныеСсылки.Свойство(ИмяЭлемента, НавигационнаяСсылкаБлока) 
		И ЗначениеЗаполнено(НавигационнаяСсылкаБлока) Тогда
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(НавигационнаяСсылкаБлока);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПодготовитьФорму()

	// ++ ЕРП
	Элементы.СоответствияАналитик.Видимость	= Ложь; // N.B. Перенести отчет.
	Элементы.ЦФООрганизаций.Видимость		= Ложь;
	// -- ЕРП
	
	// Готовим структуру из метаданных, чтобы проверка конфигурации реагировала на изменения.
	ОбъектыПодсистемы = Новый Структура;
	
	// Справочники.
	ОбъектыПодсистемы.Вставить("НастройкиФормВводаБюджета",				Метаданные.Справочники.бит_НастройкиФормВводаБюджета);
	ОбъектыПодсистемы.Вставить("ЭкземплярыОтчетов",						Метаданные.Справочники.бит_ЭкземплярыОтчетов);
	ОбъектыПодсистемы.Вставить("НастройкиРаспределенияБюджета",			Метаданные.Справочники.бит_НастройкиРаспределенияБюджета);
	ОбъектыПодсистемы.Вставить("НастройкиПротоколовРасхожденийБюджета",	Метаданные.Справочники.бит_НастройкиПротоколовРасхожденийБюджета);
	ОбъектыПодсистемы.Вставить("СтатьиОборотов",						Метаданные.Справочники.бит_СтатьиОборотов);
	ОбъектыПодсистемы.Вставить("ПравилаТрансляции",						Метаданные.Справочники.бит_ПравилаТрансляции);
	
	// Документы.
	ОбъектыПодсистемы.Вставить("УстановкаЗависимыхОборотов",				Метаданные.Документы.бит_УстановкаЗависимыхОборотов);
	ОбъектыПодсистемы.Вставить("УстановкаЗначенийПроизвольныхПараметров",	Метаданные.Документы.бит_УстановкаЗначенийПроизвольныхПараметров);
	ОбъектыПодсистемы.Вставить("ФормаВводаБюджета",							Метаданные.Документы.бит_ФормаВводаБюджета);
	ОбъектыПодсистемы.Вставить("БюджетнаяОперация",							Метаданные.Документы.бит_БюджетнаяОперация);
	ОбъектыПодсистемы.Вставить("РаспределениеБюджета",						Метаданные.Документы.бит_РаспределениеБюджета);
	ОбъектыПодсистемы.Вставить("УстановкаКонтрольныхЗначений",				Метаданные.Документы.бит_УстановкаКонтрольныхЗначений);
	ОбъектыПодсистемы.Вставить("ФиксацияБюджета",							Метаданные.Документы.бит_ФиксацияБюджета);
	ОбъектыПодсистемы.Вставить("КорректировкаБюджета",						Метаданные.Документы.бит_КорректировкаБюджета);
	ОбъектыПодсистемы.Вставить("КорректировкаКонтрольныхЗначений",			Метаданные.Документы.бит_КорректировкаКонтрольныхЗначений);
	ОбъектыПодсистемы.Вставить("ПолучениеФактическихДанных",				Метаданные.Документы.бит_ПолучениеФактическихДанных);
	ОбъектыПодсистемы.Вставить("ПротоколРасхожденийБюджета",				Метаданные.Документы.бит_ПротоколРасхожденийБюджета);
	ОбъектыПодсистемы.Вставить("АктуализацияБюджета",						Метаданные.Документы.бит_АктуализацияБюджета);
	ОбъектыПодсистемы.Вставить("ОперацияБюджетирование",					Метаданные.Документы.бит_ОперацияБюджетирование);
	ОбъектыПодсистемы.Вставить("ПереоценкаВалютныхДенежныхСтатей",			Метаданные.Документы.бит_ПереоценкаВалютныхДенежныхСтатей);
	
	// Регистры сведений.
	ОбъектыПодсистемы.Вставить("НазначениеДополнительныхИзмерений", Метаданные.РегистрыСведений.бит_НазначениеДополнительныхИзмерений);
	
	// Регистры бухгалтерии.
	ОбъектыПодсистемы.Вставить("РегистрБухгалтерииБюджетирование", Метаданные.РегистрыБухгалтерии.бит_Бюджетирование);
	
	// Планы счетов.
	ОбъектыПодсистемы.Вставить("Бюджетирование", Метаданные.ПланыСчетов.бит_Бюджетирование);
	
	// Формирование навигационных ссылок и проверка доступа по функциональным опциям.
	НедоступныеОбъекты = Новый Массив;
	Для Каждого ОбъектПодсистемы Из ОбъектыПодсистемы Цикл
		НавигационнаяСсылкаБлока = ""; 
		ОбъектДоступен = ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектПодсистемы.Значение);
		Если ОбъектДоступен Тогда
			НавигационнаяСсылкаБлока = ПолучитьНавигационнуюСсылку(ОбъектПодсистемы.Значение);
		Иначе
			НедоступныеОбъекты.Добавить(ОбъектПодсистемы.Ключ);	
		КонецЕсли;
		ОбъектыПодсистемы[ОбъектПодсистемы.Ключ] = НавигационнаяСсылкаБлока;
	КонецЦикла;
	
	НавигационныеСсылки = Новый ФиксированнаяСтруктура(ОбъектыПодсистемы);
	
	СхемаБюджетирование 			  = Обработки.бит_ПанельФункций_Бюджетирование.ПолучитьМакет("СхемаБюджетирование");
	СхемаБюджетированиеБалансовыйУчет = Обработки.бит_ПанельФункций_Бюджетирование.ПолучитьМакет("СхемаБюджетированиеБалансовыйУчет");
	
	// Ссылка может быть одновременно на разных схемах.
	Для Каждого НедоступныйОбъект Из НедоступныеОбъекты Цикл
		ЭлементыСхемы = СхемаБюджетирование.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаБюджетированиеБалансовыйУчет.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект)
	
	ЭлементСхемы = ЭлементыСхемы[НедоступныйОбъект];
	ЭлементСхемы.ЦветФона = ЦветаСтиля.бит_ЦветНедоступногоПоля;
	
КонецПроцедуры

#КонецОбласти
