#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

// Функция.
//
// Параметры:
//
//
// Возвращаемое значение:
//  Результат - Строка.
//
&НаСервере
Функция НеобходимаКонвертацияПодразделенийМСФО() Экспорт

	Результат = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	бит_вго_АктСверкиВГО.Ссылка КАК Документ,
		|	ТИПЗНАЧЕНИЯ(бит_вго_АктСверкиВГО.Ссылка) КАК ТипДокумента
		|ИЗ
		|	Документ.бит_вго_АктСверкиВГО КАК бит_вго_АктСверкиВГО
		|ГДЕ
		|	(ТИПЗНАЧЕНИЯ(бит_вго_АктСверкиВГО.Проводки.ПодразделениеРасчетов) = ТИП(Справочник.ПодразделенияОрганизаций)
		|				И бит_вго_АктСверкиВГО.Проводки.ПодразделениеРасчетов <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|			ИЛИ бит_вго_АктСверкиВГО.Проводки.ПодразделениеКор <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|				И ТИПЗНАЧЕНИЯ(бит_вго_АктСверкиВГО.Проводки.ПодразделениеКор) = ТИП(Справочник.ПодразделенияОрганизаций))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бит_вго_ПротоколРасхождений.Ссылка,
		|	ТИПЗНАЧЕНИЯ(бит_вго_ПротоколРасхождений.Ссылка)
		|ИЗ
		|	Документ.бит_вго_ПротоколРасхождений КАК бит_вго_ПротоколРасхождений
		|ГДЕ
		|	(ТИПЗНАЧЕНИЯ(бит_вго_ПротоколРасхождений.Проводки.ПодразделениеДт) = ТИП(Справочник.ПодразделенияОрганизаций)
		|				И бит_вго_ПротоколРасхождений.Проводки.ПодразделениеДт <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|			ИЛИ ТИПЗНАЧЕНИЯ(бит_вго_ПротоколРасхождений.Проводки.ПодразделениеКт) = ТИП(Справочник.ПодразделенияОрганизаций)
		|				И бит_вго_ПротоколРасхождений.Проводки.ПодразделениеКт <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бит_му_ВыбытиеОС.Ссылка,
		|	ТИПЗНАЧЕНИЯ(бит_му_ВыбытиеОС.Ссылка)
		|ИЗ
		|	Документ.бит_му_ВыбытиеОС КАК бит_му_ВыбытиеОС
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(бит_му_ВыбытиеОС.Подразделение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|	И бит_му_ВыбытиеОС.Подразделение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бит_му_ВыработкаВНА.Ссылка,
		|	ТИПЗНАЧЕНИЯ(бит_му_ВыработкаВНА.Ссылка)
		|ИЗ
		|	Документ.бит_му_ВыработкаВНА КАК бит_му_ВыработкаВНА
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(бит_му_ВыработкаВНА.Подразделение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|	И бит_му_ВыработкаВНА.Подразделение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бит_му_ИзменениеПараметровУчетаОС.Ссылка,
		|	ТИПЗНАЧЕНИЯ(бит_му_ИзменениеПараметровУчетаОС.Ссылка)
		|ИЗ
		|	Документ.бит_му_ИзменениеПараметровУчетаОС КАК бит_му_ИзменениеПараметровУчетаОС
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(бит_му_ИзменениеПараметровУчетаОС.Подразделение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|	И бит_му_ИзменениеПараметровУчетаОС.Подразделение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бит_му_МодернизацияОС.Ссылка,
		|	ТИПЗНАЧЕНИЯ(бит_му_МодернизацияОС.Ссылка)
		|ИЗ
		|	Документ.бит_му_МодернизацияОС КАК бит_му_МодернизацияОС
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(бит_му_МодернизацияОС.Подразделение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|	И бит_му_МодернизацияОС.Подразделение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бит_му_НачислениеАмортизацииОС.Ссылка,
		|	ТИПЗНАЧЕНИЯ(бит_му_НачислениеАмортизацииОС.Ссылка)
		|ИЗ
		|	Документ.бит_му_НачислениеАмортизацииОС КАК бит_му_НачислениеАмортизацииОС
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(бит_му_НачислениеАмортизацииОС.Подразделение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|	И бит_му_НачислениеАмортизацииОС.Подразделение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бит_му_ОбесценениеОС.Ссылка,
		|	ТИПЗНАЧЕНИЯ(бит_му_ОбесценениеОС.Ссылка)
		|ИЗ
		|	Документ.бит_му_ОбесценениеОС КАК бит_му_ОбесценениеОС
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(бит_му_ОбесценениеОС.Подразделение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|	И бит_му_ОбесценениеОС.Подразделение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бит_му_ПереводОСВСоставИнвестиционнойСобственности.Ссылка,
		|	ТИПЗНАЧЕНИЯ(бит_му_ПереводОСВСоставИнвестиционнойСобственности.Ссылка)
		|ИЗ
		|	Документ.бит_му_ПереводОСВСоставИнвестиционнойСобственности КАК бит_му_ПереводОСВСоставИнвестиционнойСобственности
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(бит_му_ПереводОСВСоставИнвестиционнойСобственности.Подразделение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|	И бит_му_ПереводОСВСоставИнвестиционнойСобственности.Подразделение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бит_му_ПеремещениеОС.Ссылка,
		|	ТИПЗНАЧЕНИЯ(бит_му_ПеремещениеОС.Ссылка)
		|ИЗ
		|	Документ.бит_му_ПеремещениеОС КАК бит_му_ПеремещениеОС
		|ГДЕ
		|	(ТИПЗНАЧЕНИЯ(бит_му_ПеремещениеОС.Подразделение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|				И бит_му_ПеремещениеОС.Подразделение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|			ИЛИ ТИПЗНАЧЕНИЯ(бит_му_ПеремещениеОС.ОсновныеСредства.Местонахождение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|				И бит_му_ПеремещениеОС.ОсновныеСредства.Местонахождение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|			ИЛИ ТИПЗНАЧЕНИЯ(бит_му_ПеремещениеОС.ОсновныеСредства.Местонахождение_старый) = ТИП(Справочник.ПодразделенияОрганизаций)
		|				И бит_му_ПеремещениеОС.ОсновныеСредства.Местонахождение_старый <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бит_му_ПереоценкаОС.Ссылка,
		|	ТИПЗНАЧЕНИЯ(бит_му_ПереоценкаОС.Ссылка)
		|ИЗ
		|	Документ.бит_му_ПереоценкаОС КАК бит_му_ПереоценкаОС
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(бит_му_ПереоценкаОС.Подразделение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|	И бит_му_ПереоценкаОС.Подразделение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	бит_му_ПринятиеКУчетуОС.Ссылка,
		|	ТИПЗНАЧЕНИЯ(бит_му_ПринятиеКУчетуОС.Ссылка)
		|ИЗ
		|	Документ.бит_му_ПринятиеКУчетуОС КАК бит_му_ПринятиеКУчетуОС
		|ГДЕ
		|	(ТИПЗНАЧЕНИЯ(бит_му_ПринятиеКУчетуОС.Подразделение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|				И бит_му_ПринятиеКУчетуОС.Подразделение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
		|			ИЛИ ТИПЗНАЧЕНИЯ(бит_му_ПринятиеКУчетуОС.ОсновныеСредства.Местонахождение) = ТИП(Справочник.ПодразделенияОрганизаций)
		|				И бит_му_ПринятиеКУчетуОС.ОсновныеСредства.Местонахождение <> ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка))";
		

	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() > 0 Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции // ПолучитьПодразделенияМСФО()

#КонецЕсли
