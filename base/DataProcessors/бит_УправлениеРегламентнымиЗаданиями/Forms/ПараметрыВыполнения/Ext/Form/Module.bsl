
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметры, "АвтоТест", Ложь) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Параметры.ИмяМетаданных) Тогда
		ТекстСообщения = НСтр("ru = 'Непосредственное открытие этой формы не предусмотрено.';
								|en = 'You can''t open this form directly.'");
    	ВызватьИсключение ТекстСообщения;
	КонецЕсли;
		
	ИмяМетаданных 	= Параметры.ИмяМетаданных;
	АдресВХранилище = Параметры.АдресВХранилище;
	Заголовок		= Параметры.Заголовок;
	
	Если НЕ ЭтоАдресВременногоХранилища(АдресВХранилище) Тогда
		АдресВХранилище = ПоместитьВоВременноеХранилище(Неопределено, Новый УникальныйИдентификатор());
	КонецЕсли;
	
	УстановитьФлагиЗаданий();	
	
	Если ЭтоСоздатьДокументыПланированияИзДопУсловий Тогда
		ПрочитатьПараметрыСоздатьДокументыПланированияИзДопУсловий();
	ИначеЕсли ЭтоРегистрацияОповещенийОВизировании Тогда
		УстановитьПараметрыВыбораОповещения();
		ПрочитатьПараметрыРегистрацияОповещенийОВизировании();
	ИначеЕсли ЭтоУстановкаРешенийПоПросроченнымВизам Тогда
		ВизируемыеОбъектыСистемы = ВизируемыеОбъектыСистемы();
		ПрочитатьПараметрыУстановкаРешенийПоПросроченнымВизам();
	ИначеЕсли ЭтоЗакрытиеДокументовПланирования Тогда
		ПрочитатьПараметрыЗакрытиеДокументовПланирования();
	КонецЕсли;
			
	УправлениеФормой();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы И Модифицированность Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	ОчиститьСообщения();
	
	Если Модифицированность Тогда
		ТекстВопроса = НСтр("ru = 'Параметры регламентного задания изменены. Сохранить изменения?';
							|en = 'Parameters of the regulation task have been change. Save changes?'");
		ОписаниеОповещения = Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект); 
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте 
Процедура ПередЗакрытиемЗавершение(Ответ, ДополнительныеДанные) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		ЗаписатьИЗакрыть();
	Иначе
		Модифицированность = Ложь;
		Закрыть();
	КонецЕсли;
                
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СоздаватьЗаявкаНаРасходованиеДСПриИзменении(Элемент)
	
	Если СоздаватьЗаявкаНаРасходованиеДС Тогда
		СоздаватьПрогнозПлатежа = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздаватьПрогнозПлатежаПриИзменении(Элемент)
	
	Если СоздаватьПрогнозПлатежа Тогда
		СоздаватьЗаявкаНаРасходованиеДС = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбъектСистемыНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	СписокВидовОбъектов = Новый СписокЗначений;
	СписокВидовОбъектов.Добавить(ПредопределенноеЗначение("Перечисление.бит_ВидыОбъектовСистемы.Документ"));
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВидыОбъектов", 		   СписокВидовОбъектов);
	ПараметрыФормы.Вставить("ТекущийОбъектСистемы",    ОбъектСистемы);
	ПараметрыФормы.Вставить("ДоступныеОбъектыСистемы", ВизируемыеОбъектыСистемы);
	ОткрытьФорму("ОбщаяФорма.бит_ФормаВыбораОбъектовСистемы", ПараметрыФормы, Элемент);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

