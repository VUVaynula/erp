Функция ЗначенияПоУмолчаниюСоздатьДокументыПланированияИзДопУсловий() Экспорт

	ЗначенияПоУмолчанию = Новый Структура;
	ЗначенияПоУмолчанию.Вставить("СоздаватьЗаявкаНаРасходованиеДС",   Истина);
	ЗначенияПоУмолчанию.Вставить("ЗаявкаДни", 						   3);
	ЗначенияПоУмолчанию.Вставить("СоздаватьПланируемоеПоступлениеДС", Истина);
	ЗначенияПоУмолчанию.Вставить("ПланируемоеПоступлениеДни", 		   3);
	ЗначенияПоУмолчанию.Вставить("СоздаватьЗаявкаНаЗатраты", 		   Истина);
	ЗначенияПоУмолчанию.Вставить("ЗаявкаНаЗатратыДни",		  		   3);
	ЗначенияПоУмолчанию.Вставить("СоздаватьПрогнозПлатежа", 		   Ложь);
	ЗначенияПоУмолчанию.Вставить("ПрогнозПлатежаДни",				   0);
	ЗначенияПоУмолчанию.Вставить("РежимЗаписи", 					   "Запись");
	ЗначенияПоУмолчанию.Вставить("ДатаНачала", 					   	   НачалоДня(ТекущаяДатаСеанса()));

	Возврат ЗначенияПоУмолчанию;
	
КонецФункции

Функция ЗначенияПоУмолчаниюУстановкаРешенийПоПросроченнымВизам() Экспорт

	ЗначенияПоУмолчанию = Новый Структура;
	ЗначенияПоУмолчанию.Вставить("Решение", 	  Неопределено);
	ЗначенияПоУмолчанию.Вставить("Статус",		  Неопределено);
	ЗначенияПоУмолчанию.Вставить("Организация",   Неопределено);
	ЗначенияПоУмолчанию.Вставить("ОбъектСистемы", Неопределено);

	Возврат ЗначенияПоУмолчанию;
	
КонецФункции

Функция ЗначенияПоУмолчаниюРегистрацияОповещенийОВизировании() Экспорт

	СогласующиеЛица = Новый ТаблицаЗначений;
	СогласующиеЛица.Колонки.Добавить("Пользователь");
	СогласующиеЛица.Колонки.Добавить("НастройкаОбработкиВизирования");

	ЗначенияПоУмолчанию = Новый Структура;
	ЗначенияПоУмолчанию.Вставить("Оповещение",					  Неопределено);
	ЗначенияПоУмолчанию.Вставить("НастройкаОбработкиВизирования", Неопределено);
	ЗначенияПоУмолчанию.Вставить("СогласующиеЛица",				  СогласующиеЛица);
	
	Возврат ЗначенияПоУмолчанию;
	
КонецФункции

Функция ЗначенияПоУмолчаниюЗакрытиеДокументовПланирования() Экспорт

	ЗначенияПоУмолчанию = Новый Структура;
	ЗначенияПоУмолчанию.Вставить("НастройкаПодбораЗакрываемыхДокументов", Неопределено);

	Возврат ЗначенияПоУмолчанию;
	
КонецФункции

