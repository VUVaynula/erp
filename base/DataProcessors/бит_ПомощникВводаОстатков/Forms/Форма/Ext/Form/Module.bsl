	фИмяРегИсточника = УстановитьИмяРегистра(Объект.РегистрИсточник);
    
    ОсновныеСчета.Очистить();
	ЗабалансовыеСчета.Очистить();
	Объект.ТаблицаДанныеТрансляции.Очистить();
		
КонецПроцедуры // РегистрИсточникПриИзмененииСервер()

