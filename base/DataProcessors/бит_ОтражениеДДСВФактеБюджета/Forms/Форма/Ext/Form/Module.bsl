	ПодготовитьФормуНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВариантПериодаПриИзменении(Элемент)
	
	ПриИзмененииПериода();
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодДатаНачалаПриИзменении(Элемент)
	
	ПриИзмененииПериода();
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодДатаОкончанияПриИзменении(Элемент)
	
	ПриИзмененииПериода();
	
КонецПроцедуры

&НаКлиенте
Процедура РежимПроверкиАналитикПриИзменении(Элемент)
	
	Если Объект.РежимПроверкиАналитик > 0 Тогда
		ПроверяемыеАналитики.Очистить();
	КонецЕсли;
	
	ПриИзмененииНастроекПроверки();
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура РежимКонтроляПриИзменении(Элемент)
	
	УправлениеФормой(ЭтотОбъект);
	ОбновитьПервичныеДокументы(Неопределено);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПервичныеДокументы

&НаКлиенте
Процедура ПервичныеДокументыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ПервичныеДокументы.ТекущиеДанные;
	
	ПоказатьЗначение(,ТекущиеДанные.Документ);
	
КонецПроцедуры

&НаКлиенте
Процедура ПервичныеДокументыПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.ПервичныеДокументы.ТекущиеДанные;      
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.Документ = ТекущийОбъектСсылка Тогда
		Возврат;
    КонецЕсли;      

	ОтключитьОбработчикОжидания("ПервичныеДокументыОжиданиеАктивизацииСтроки");
	ПодключитьОбработчикОжидания("ПервичныеДокументыОжиданиеАктивизацииСтроки", 0.1, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПроверяемыеАналитики

&НаКлиенте
Процедура ПроверяемыеАналитикиПриИзменении(Элемент)
	
	ПриИзмененииНастроекПроверки();
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыКомпоновщикНастройкиОтбор

&НаКлиенте
Процедура КомпоновщикНастройкиОтборПриИзменении(Элемент)
	
	ИзмененыНастройки = Истина;
	
КонецПроцедуры

#КонецОбласти // ОбработчикиСобытийЭлементовТаблицыФормыКомпоновщикНастройкиОтбор

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПервичныеДокументыСнятьФлажки(Команда)
	
	ОбработатьФлагиПервичныеДокументы(0);
	
КонецПроцедуры

&НаКлиенте
Процедура ПервичныеДокументыУстановитьФлажки(Команда)
	
	ОбработатьФлагиПервичныеДокументы(1);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПервичныеДокументы(Команда)
	
	Если НЕ ПериодЗаполненПравильно() Тогда
		Возврат;
	КонецЕсли;
	
	ИзмененыНастройки = Ложь;
	
	СкрытьНастройки();
	НачатьЗаполнениеСпискаДокументов();
	
КонецПроцедуры

&НаКлиенте
Процедура ПервичныеДокументыПровести(Команда)
	
	ЗаписатьИзменения("ПровестиДокументы");
	ПервичныеДокументыОжиданиеАктивизацииСтроки();

КонецПроцедуры

&НаКлиенте
Процедура ПервичныеДокументыПровестиПоБФ(Команда)
	
	ЗаписатьИзменения("ПровестиПоРегистрамБИТ");
	
КонецПроцедуры

&НаКлиенте
Процедура ГрупповоеРедактированиеАналитик(Команда)
	
	ОбъектыДляОбработки = Новый Массив;
	Для Каждого СтрокаДокумента Из Объект.ПервичныеДокументы Цикл
		Если НЕ СтрокаДокумента.Пометка Тогда
			Продолжить;
		КонецЕсли;
		ОбъектыДляОбработки.Добавить(СтрокаДокумента.Документ);
	КонецЦикла;
	
	Если ОбъектыДляОбработки.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru = 'Выберите документы для обработки.';
								|en = 'Select documents to process.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ДокументыДляОбработки = ОтраженияФактаПоДокументам(ОбъектыДляОбработки);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ДокументыДляОбработки", ДокументыДляОбработки);
	
	ОткрытьФорму("Обработка.бит_ИзменениеОтраженийФакта.Форма.Форма", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

// Обработчик завершения редактирования периода.
//  См. Синтакс-помощник: Показать().
//
&НаКлиенте
Процедура НастроитьПериод(Команда)
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода();
	Диалог.Период.ДатаНачала 	= Объект.Период.ДатаНачала;
	Диалог.Период.ДатаОкончания = Объект.Период.ДатаОкончания;
	Диалог.Период.Вариант		= Объект.Период.Вариант;
		
	Оповещение = Новый ОписаниеОповещения("ВыборПериодаЗавершение", ЭтотОбъект);
	Диалог.Показать(Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборПериодаЗавершение(ПериодРезультат, ДополнительныеПараметры) Экспорт
	
	Если ПериодРезультат <> Неопределено Тогда
		
		Объект.Период.ДатаНачала    = ПериодРезультат.ДатаНачала;
		Объект.Период.ДатаОкончания = ПериодРезультат.ДатаОкончания;
		Объект.Период.Вариант 	    = ПериодРезультат.Вариант;
		
		ПриИзмененииПериода();
														
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ДтКт(Команда)
	
	ТекущиеДанные = Элементы.ПервичныеДокументы.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Документ = ТекущиеДанные.Документ;
	Если ТребуетсяСтандартнаяФормаДтКт(Документ) Тогда
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ДокументДвижений", Документ);
		ОткрытьФорму("Обработка.КорректировкаДвижений.Форма", ПараметрыФормы, ЭтотОбъект, Документ);
	Иначе	
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ДокументСсылка"	   , Документ);
		ПараметрыФормы.Вставить("ОткрытиеИзФормыСписка", Истина);
		ОткрытьФорму("Обработка.бит_РезультатПроведения.Форма", ПараметрыФормы, ЭтотОбъект, Документ);
	КонецЕсли;
				
КонецПроцедуры

&НаКлиенте
Процедура ОкноАналитик(Команда)
	
	ТекущиеДанные = Элементы.ПервичныеДокументы.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Документ = ТекущиеДанные.Документ;
	ОткрытьОтраженияФакта(Документ);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьНастройки(Команда)

	Если НЕ ПериодЗаполненПравильно() Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = ПараметрыХраненияНастроек();
	ПараметрыФормы.Вставить("СтруктураНастройки" , СохраняемыеНастройки());
	
	Оповещение = Новый ОписаниеОповещения("СохранитьНастройкиЗавершение",ЭтотОбъект);
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаСохранения", ПараметрыФормы,
		ЭтотОбъект,,,,Оповещение, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
		
КонецПроцедуры
	
// Обработчик завершения открытия формы.
//  См. Синтакс-помощник: ОткрытьФорму().
// 
&НаКлиенте
Процедура СохранитьНастройкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		УстановитьЗаголовок(Результат, ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры // СохранитьНастройки()

&НаКлиенте
Процедура ВыбратьНастройки(Команда)

	ПараметрыФормы = ПараметрыХраненияНастроек();
	Оповещение	   = Новый ОписаниеОповещения("ВыбратьНастройкиЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаЗагрузки", ПараметрыФормы, 
		ЭтотОбъект,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры

// Обработчик завершения открытия формы.
//  См. Синтакс-помощник: ОткрытьФорму().
// 
&НаКлиенте 
Процедура ВыбратьНастройкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
		
	Если ЗначениеЗаполнено(Результат) Тогда
		ПрименитьНастройки(Результат);
		НачатьЗаполнениеСпискаДокументов();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьНастройки(Команда)
	
	ОткрытьНастройки();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьНастройки(Команда)
	
	СкрытьНастройки();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПроцедурыИФункцииПоРаботеСНастройками

&НаСервере
Процедура УстановитьНастройкиПоУмолчанию()
	
	Перем НастройкаПоУмолчанию;
	
	НастройкаПоУмолчанию = бит_ОтчетыСервер.НайтиНастройкуПоУмолчаниюДляОбъекта(НастраиваемыйОбъект());
	
	ПрименитьНастройки(НастройкаПоУмолчанию);
	
КонецПроцедуры

&НаКлиенте
Функция ПараметрыХраненияНастроек()

	ПараметрыХранения = Новый Структура;
	ПараметрыХранения.Вставить("ТипНастройки",		  ПредопределенноеЗначение("Перечисление.бит_ТипыСохраненныхНастроек.Обработки"));
	ПараметрыХранения.Вставить("НастраиваемыйОбъект", НастраиваемыйОбъект());

	Возврат ПараметрыХранения;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция НастраиваемыйОбъект()

	Возврат "Обработка.бит_ОтражениеДДСВФактеБюджета";

КонецФункции

&НаСервере
Функция СохраняемыеНастройки()

	ЗаполнитьПроверяемыеАналитики();
	СохраняемыеНастройки = Обработки.бит_ОтражениеДДСВФактеБюджета.НовыеСохраняемыеНастройки();
	ЗаполнитьЗначенияСвойств(СохраняемыеНастройки, Объект);
	
	СохраняемыеНастройки.НастройкиКомпоновкиДанных = Объект.КомпоновщикНастроек.ПолучитьНастройки();
	
	Возврат СохраняемыеНастройки;
	
КонецФункции

&НаСервере
Процедура ПрименитьНастройки(НастройкаПодбораДокументов = Неопределено)
	
	ПроверяемыеАналитики.Очистить();
	
	Обработки.бит_ОтражениеДДСВФактеБюджета.ПрименитьНастройки(
		НастройкаПодбораДокументов, Объект);
		
	Если ТипЗнч(Объект.ПроверяемыеАналитики) = Тип("СписокЗначений") Тогда
		Контроль = ЗначенияОтбораДополнительныхАналитик();		
		Для каждого Элемент Из Объект.ПроверяемыеАналитики Цикл
			Если Контроль.Найти(Элемент.Значение) <> Неопределено  Тогда
				НоваяСтрока = ПроверяемыеАналитики.Добавить();
				НоваяСтрока.Аналитика = Элемент.Значение;	
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;	

	УстановитьЗаголовок(НастройкаПодбораДокументов, ЭтотОбъект);
			
	УправлениеФормой(ЭтотОбъект);
 	ОбработатьИзменениеНастроек(ЭтотОбъект);
                            
КонецПроцедуры

#КонецОбласти

#Область ЗаполнениеСпискаДокументов

&НаКлиенте
Процедура НачатьЗаполнениеСпискаДокументов()
	
	Если НЕ ПериодЗаполненПравильно() Тогда
		Возврат;
	КонецЕсли;	

	ТекущийОбъектСсылка = Неопределено;
	УтановитьОписаниеОшибки("");
	
	ИзмененыНастройки = Ложь;
	ОбработатьИзменениеНастроек(ЭтотОбъект);

	ДлительнаяОперация = ЗапуститьФоновоеЗаполнениеСпискаДокументов();
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ТекстСообщения 	   = НСтр("ru = 'Идет заполнение списка документов'"); 
	ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗаполненияСпискаДокументов", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОписаниеОповещения, ПараметрыОжидания);

КонецПроцедуры

// Обработка оповещения. Подробности см.ДлительныеОперацииКлиент.ОжидатьЗавершение.
//
&НаКлиенте
Процедура ПослеЗаполненияСпискаДокументов(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Если Результат.Статус <> "Выполнено" Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка при выполнении: %1'"); 
		ПоказатьПредупреждение(, СтрШаблон(ТекстСообщения, Результат.КраткоеПредставлениеОшибки));
	Иначе
		ПослеЗаполненияСпискаДокументовНаСервере(Результат.АдресРезультата);
	КонецЕсли; 

КонецПроцедуры

&НаСервере
Функция ЗапуститьФоновоеЗаполнениеСпискаДокументов()
		
	// Заполнение пераметов длительной операции.
	НаименованиеЗадания = НСтр("ru = 'Заполнение списка документов.'");
	ВыполняемыйМетод	= "Обработки.бит_ОтражениеДДСВФактеБюджета.ЗаполнитьПереченьДокументов";

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	
	НастройкиКомпоновки 	   = Объект.КомпоновщикНастроек.ПолучитьНастройки(); 
	АдресСхемыКомпоновкиДанных = ИнициализироватьКомпоновщик(Объект.КомпоновщикНастроек);
	СКД 					   = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновкиДанных);
	
	НастройкиКомпоновкиДанных  = Объект.КомпоновщикНастроек.ПолучитьНастройки();
	
	бит_ОтчетыБФКлиентСервер.УстановитьПараметр(НастройкиКомпоновкиДанных, "Период", Объект.Период);
	бит_ОтчетыБФКлиентСервер.УстановитьПараметр(НастройкиКомпоновкиДанных, "ВсеПозиции",
		НЕ ТолькоСОтклоненияПоСумме(ЭтотОбъект));
	
	Настройки = Обработки.бит_ОтражениеДДСВФактеБюджета.НовыеНастройкиПроверкиЗаполнения();
	ЗаполнитьПроверяемыеАналитики();
	ЗаполнитьЗначенияСвойств(Настройки, Объект);
	
	ФоновоеЗадание = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ВыполняемыйМетод, 
							СКД, НастройкиКомпоновкиДанных, Настройки);
	Возврат ФоновоеЗадание;

КонецФункции

&НаСервере
Процедура ПослеЗаполненияСпискаДокументовНаСервере(АдресРезультата)

	РезультатПоиска    = Объект.ПервичныеДокументы.НайтиСтроки(Новый Структура("Пометка", Истина));
	ОтмеченыеДокументы = Новый Массив;
	Для каждого Элемент Из РезультатПоиска Цикл
		ОтмеченыеДокументы.Добавить(Элемент.Документ);
	КонецЦикла;
	
	ТаблицаДокументов = ПолучитьИзВременногоХранилища(АдресРезультата);

	Объект.ПервичныеДокументы.Загрузить(ТаблицаДокументов);
	
	Если ЗначениеЗаполнено(ОтмеченыеДокументы) Тогда
		Для каждого СтрокаТаблицы  Из Объект.ПервичныеДокументы Цикл
			СтрокаТаблицы.Пометка = ОтмеченыеДокументы.Найти(СтрокаТаблицы.Документ) <> Неопределено;
		КонецЦикла;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТаблицаДокументов) Тогда
		УстановитьОтборПоРегистраторуВДвижениях(Неопределено);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти // ЗаполнениеСпискаДокументов

#Область ЗаписьИзменений

&НаКлиентеНаСервереБезКонтекста
Функция ПараметрыЗаписиИзменений(РежимВыполнения, ОбъектыДляЗаписи, КоличествоОбщее)
		
	ПараметрыЗаписи = Новый Структура;
	
	ПараметрыЗаписи.Вставить("ОбъектыДляЗаписи" , 		ОбъектыДляЗаписи);
	ПараметрыЗаписи.Вставить("ВыполнитьПроведение", 	РежимВыполнения = "ПровестиДокументы");
	ПараметрыЗаписи.Вставить("ВыполнитьПроведениеБит", 	РежимВыполнения = "ПровестиПоРегистрамБИТ");
	ПараметрыЗаписи.Вставить("КоличествоОбщее",			КоличествоОбщее);
	
	Возврат ПараметрыЗаписи;
	
КонецФункции

&НаКлиенте
Процедура ЗаписатьИзменения(РежимВыполнения)

	ОбъектыДляЗаписи = Новый Массив;
	Для каждого СтрокаДокумента Из Объект.ПервичныеДокументы Цикл
		Если СтрокаДокумента.Пометка Тогда
			ОбъектыДляЗаписи.Добавить(СтрокаДокумента.Документ);
		КонецЕсли;
	КонецЦикла;

	Если НЕ ЗначениеЗаполнено(ОбъектыДляЗаписи) Тогда
		ТекстСообщения = НСтр("ru = 'Выберите документы для обработки.'; en = 'Select the documents to process.'");
		ПоказатьПредупреждение(, ТекстСообщения);
		Возврат;	
	КонецЕсли;
	
	НачатьОтложеннуюОбработкуДокументов(РежимВыполнения, ОбъектыДляЗаписи);
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьОтложеннуюОбработкуДокументов(РежимВыполнения, ОбъектыДляЗаписи)

	Если НЕ ЗначениеЗаполнено(ОбъектыДляЗаписи) Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();
		
	КоличествоОбщее = ОбъектыДляЗаписи.Количество();
	ПараметрыЗаписи = ПараметрыЗаписиИзменений(РежимВыполнения, ОбъектыДляЗаписи, КоличествоОбщее);
			
	КлючеваяОперация = "Обработка.бит_ОтражениеДДСВФактеБюджета.Форма.НачатьОтложеннуюОбработкуДокументов";
					 
	ОценкаПроизводительностиКлиент.ЗамерВремени(КлючеваяОперация);
	
	ДлительнаяОперация    = НачатьОтложеннуюОбработкуДокументовНаСервере(ОбъектыДляЗаписи, ПараметрыЗаписи);
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ОтложеннаяОбработкаДокументовЗавершение", ЭтотОбъект);
	ПараметрыОжидания     = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ПараметрыОжидания.ВыводитьСообщения = Истина;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);

КонецПроцедуры

&НаСервере
Функция НачатьОтложеннуюОбработкуДокументовНаСервере(ОбъектыДляЗаписи, ПараметрыЗаписи)
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ВыполняемыйМетод    = "Обработки.бит_ОтражениеДДСВФактеБюджета.ЗаписатьИзмененияОбъектов";
	
	// Разобьем даные на пакеты пропорционально количеству потоков.
	РазмерСпика		  = ОбъектыДляЗаписи.Количество();
	КоличествоПотоков = Константы.КоличествоПотоковДлительныхОпераций.Получить();
	КоличествоПотоков = Макс(1, КоличествоПотоков);
	Если КоличествоПотоков = 1 Тогда
		РазмерыПакетов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(РазмерСпика);
	Иначе	
		Коэффициенты = Новый Массив;
		Для Индекс = 1 По КоличествоПотоков Цикл
			Коэффициенты.Добавить(1);	
		КонецЦикла;
		РазмерыПакетов = ОбщегоНазначенияКлиентСервер.РаспределитьСуммуПропорциональноКоэффициентам(
							РазмерСпика, Коэффициенты, 0);
	КонецЕсли;

	// Удалим пакеты нулевой длины.
	Индекс = РазмерыПакетов.ВГраница();
	Пока Индекс >= 0 Цикл
		Если РазмерыПакетов.Получить(Индекс) = 0 Тогда
			РазмерыПакетов.Удалить(Индекс);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	
	Счетчик 			   = 1;
	ИндексПакета 		   = 0;
	НаборПараметровФункции = Новый Соответствие;
	
	Для каждого Элемент Из ОбъектыДляЗаписи Цикл
		Если Счетчик = 1 Тогда
			РазмерПорции = РазмерыПакетов[ИндексПакета];
			ПорцияДанных = Новый Массив;
			ИндексПакета = ИндексПакета + 1;
		КонецЕсли;
		ПорцияДанных.Добавить(Элемент);

		Если Счетчик = РазмерПорции Тогда
			Счетчик = 0;
			
			ТекущиеПараметрыФункции = Новый Массив;
			ТекущиеПараметрыФункции.Добавить(ПорцияДанных);
			ТекущиеПараметрыФункции.Добавить(ПараметрыЗаписи);
			НаборПараметровФункции.Вставить(Новый УникальныйИдентификатор, ТекущиеПараметрыФункции);
		КонецЕсли;
		Счетчик	= Счетчик + 1;
	КонецЦикла;
	
	Возврат ДлительныеОперации.ВыполнитьФункциюВНесколькоПотоков(ВыполняемыйМетод, ПараметрыВыполнения, НаборПараметровФункции);
		
КонецФункции

&НаКлиенте
Процедура ОтложеннаяОбработкаДокументовЗавершение(Результат, Дополнительно) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка при выполнении, по причине: %1'"); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрШаблон(ТекстСообщения, Результат.КраткоеПредставлениеОшибки));
	Иначе	
		РезультатОбработки = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		 
		Для каждого Сообщение Из Результат.Сообщения Цикл
			Сообщение.Сообщить();	
		КонецЦикла;
		
		Если ТипЗнч(РезультатОбработки) = Тип("Соответствие") Тогда
			Для каждого КлючЗначение Из РезультатОбработки Цикл
				ОбработатьРезультатОтложеннойОбработкиДокументов(КлючЗначение.Значение);			
			КонецЦикла;	
		КонецЕсли;
		
		ТекстСообщения = НСтр("ru = 'Обработка завершена.'; en = 'Processing is completed.'");
		ПоказатьПредупреждение(, ТекстСообщения);
	КонецЕсли; 

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРезультатОтложеннойОбработкиДокументов(Результат)
	
	Если Результат.Статус = "Ошибка" Тогда
		ТекстСообщения = НСтр("ru = 'Ошибка при выполнении, по причине: %1'"); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрШаблон(ТекстСообщения, Результат.КраткоеПредставлениеОшибки));
	Иначе	
		РезультатОбработки = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		
		Для каждого Сообщение Из Результат.Сообщения Цикл
			Сообщение.Сообщить();	
		КонецЦикла;
		
		Если ТипЗнч(РезультатОбработки) = Тип("Структура") Тогда
			Сообщения = РезультатОбработки.Сообщения;
			Для каждого Сообщение Из Сообщения Цикл
				Сообщение.Сообщить();	
			КонецЦикла;
			ПропущенныеОбъекты = РезультатОбработки.ПропущенныеОбъекты;
			// Можно что-то поделать с этим списком.
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

