&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
	
	Объект 	 = Форма.Объект;
	Элементы = Форма.Элементы;
	
	Элементы.СтраницаПровекаАналитик.Видимость = ПроверятьЗаполнениеАналитик(Форма);
	
	Если Форма.ПроверяемыеАналитики.Количество() = 0 И (Объект.РежимПроверкиАналитик = 0) Тогда
		Элементы.ПервичныеДокументыЗаполнениеАналитик.Видимость = Ложь;
	Иначе
		Элементы.ПервичныеДокументыЗаполнениеАналитик.Видимость = Истина;
	КонецЕсли;
	
	Элементы.ПроверяемыеАналитики.Доступность = (Объект.РежимПроверкиАналитик = 0);
	
КонецПроцедуры

&НаСервере
Функция ЗначенияОтбораДополнительныхАналитик()
	
	ФиксировнныеНастройки = Новый СписокЗначений;
	ФиксировнныеНастройки.Добавить(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.СтатьяОборотов);
	ФиксировнныеНастройки.Добавить(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ЦФО);
	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		ФиксировнныеНастройки.Добавить(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.Проект);
		ФиксировнныеНастройки.Добавить(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.НоменклатурнаяГруппа);
		ФиксировнныеНастройки.Добавить(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.Контрагент);
		ФиксировнныеНастройки.Добавить(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ДоговорКонтрагента);
		ФиксировнныеНастройки.Добавить(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.БанковскийСчет);
		ФиксировнныеНастройки.Добавить(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ПланируемоеПоступлениеДенежныхСредств);
		ФиксировнныеНастройки.Добавить(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ПлатежнаяПозиция);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ФиксировнныеНастройки", ФиксировнныеНастройки);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДополнительныеИзмерения.Аналитика КАК Аналитика,
	|	ДополнительныеИзмерения.Синоним КАК Синоним
	|ПОМЕСТИТЬ ДополнительныеИзмерения
	|ИЗ
	|	РегистрСведений.бит_НазначениеДополнительныхИзмерений КАК ДополнительныеИзмерения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДополнительныеИзмерения.Аналитика КАК Аналитика,
	|	ДополнительныеИзмерения.Синоним КАК Синоним
	|ИЗ
	|	ДополнительныеИзмерения КАК ДополнительныеИзмерения
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДополнительныеАналитики.Ссылка,
	|	ДополнительныеАналитики.Наименование
	|ИЗ
	|	ПланВидовХарактеристик.бит_ВидыДополнительныхАналитик КАК ДополнительныеАналитики
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДополнительныеИзмерения КАК ДополнительныеИзмерения
	|		ПО (ДополнительныеИзмерения.Аналитика = ДополнительныеАналитики.Ссылка)
	|ГДЕ
	|	ДополнительныеИзмерения.Аналитика ЕСТЬ NULL
	|	И ДополнительныеАналитики.Ссылка В(&ФиксировнныеНастройки)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Синоним";
	
	ВидыДополнительныхАналитик = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ВидыДополнительныхАналитик.Добавить(Выборка.Аналитика);	
	КонецЦикла;
	
	Возврат ВидыДополнительныхАналитик;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПроверяемыеАналитики()
	
	Объект.ПроверяемыеАналитики = Новый СписокЗначений;
	Для каждого СтрокаТаблицы Из ПроверяемыеАналитики Цикл
		Объект.ПроверяемыеАналитики.Добавить(СтрокаТаблицы.Аналитика);	
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ОтраженияФактаПоДокументам(Документы)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОтражениеФактаДДС.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.бит_ОтражениеФактаДДС КАК ОтражениеФактаДДС
	|ГДЕ
	|	НЕ ОтражениеФактаДДС.ПометкаУдаления
	|	И ОтражениеФактаДДС.ДокументОснование В(&ДокументыОснования)";
	Запрос.УстановитьПараметр("ДокументыОснования", Документы);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

#КонецОбласти