			"Объект.ПервичныеДокументы.СуммаДокумента", ВидСравненияКомпоновкиДанных.НеРавно,
			Новый ПолеКомпоновкиДанных("Объект.ПервичныеДокументы.СуммаБюджет"));
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветОтрицательногоЧисла);
	
