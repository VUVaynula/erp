&НаСервере
Процедура ПодготовитьФормуНаСервере()
		
	бит_МеханизмДопИзмерений.ПоказатьДополнительныеИзмеренияВТабличномПоле(ЭтотОбъект, "РегистрОборотыПоБюджетам");

	НовыйПараметрВыбора  = Новый ПараметрВыбора("Отбор.Ссылка", ЗначенияОтбораДополнительныхАналитик());
	НовыеПараметрыВыбора = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(НовыйПараметрВыбора);
	
	Элементы.ПроверяемыеАналитикиАналитика.ПараметрыВыбора = Новый ФиксированныйМассив(НовыеПараметрыВыбора);
	
	Если НЕ Обработки.бит_ОтражениеДДСВФактеБюджета.ВедетсяСоответствиеСтатейОборотов() Тогда
		РежимыКонтроля = Элементы.РежимКонтроля.СписокВыбора;
		РежимСоответствияСтатей = 3;
		РежимыКонтроля.Удалить(РежимыКонтроля.НайтиПоЗначению(РежимСоответствияСтатей));
	КонецЕсли;
	
	// Надписи в проводках:
	ХозрасчетныйНаборЗаписей.Параметры.УстановитьЗначениеПараметра("НадписьНУ", 		  НСтр("ru = 'НУ:'"));
	ХозрасчетныйНаборЗаписей.Параметры.УстановитьЗначениеПараметра("НадписьПР",			  НСтр("ru = 'ПР:'"));
	ХозрасчетныйНаборЗаписей.Параметры.УстановитьЗначениеПараметра("НадписьВР", 		  НСтр("ru = 'ВР:'"));
	ХозрасчетныйНаборЗаписей.Параметры.УстановитьЗначениеПараметра("НадписьКоличествоДт", НСтр("ru = 'Кол.:'"));
	ХозрасчетныйНаборЗаписей.Параметры.УстановитьЗначениеПараметра("НадписьКоличествоКт", НСтр("ru = 'Кол.:'"));
	
	УстановитьНастройкиПоУмолчанию();
	УстановитьОтборПоРегистраторуВДвижениях(Неопределено);
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
Функция ПериодЗаполненПравильно()

	ЗаполненПравильно = Истина;
	
	Отказ  = Ложь;
	
	Если НЕ ЗначениеЗаполнено(Объект.Период.ДатаНачала) Тогда
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Начало периода';en = 'Period start'")); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "Период.ДатаНачала", "Объект", Отказ);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Период.ДатаОкончания) Тогда
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Конец периода';en = 'Period end'")); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "Период.ДатаОкончания", "Объект", Отказ);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Период.ДатаНачала) И ЗначениеЗаполнено(Объект.Период.ДатаОкончания) Тогда
		Если Объект.Период.ДатаОкончания < Объект.Период.ДатаНачала Тогда
			ТекстСообщения = НСтр("ru='Период указан неверно. Дата начала больше даты окончания.';
								  |en='The period is incorrect. The start date is greater than the end date.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "Период.ДатаНачала", "Объект", Отказ);
		КонецЕсли;
	КонецЕсли;
	
	Если ПроверятьЗаполнениеАналитик(ЭтотОбъект)
		И Объект.РежимПроверкиАналитик = 0
		И ПроверяемыеАналитики.Количество() = 0 Тогда
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("СПИСОК",, НСтр("ru = 'Список аналитик'"),,
																			"Проверяемые аналитики"); 
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "ПроверяемыеАналитики", "ПроверяемыеАналитики", Отказ);
	КонецЕсли;
	
	Если Отказ Тогда
		ЗаполненПравильно = Ложь;
	КонецЕсли;  
	
	Возврат ЗаполненПравильно; 

КонецФункции

