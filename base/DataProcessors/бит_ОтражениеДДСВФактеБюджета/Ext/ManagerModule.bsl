#Область СлужебныйПрограммныйИнтерфейс

#Область ЗаписьИзменений

Функция ЗаписатьИзмененияОбъектов(ОбъектыДляЗаписи, ПараметрыЗаписи) Экспорт
		
	ЗакрытыеДляРедактирования = ОбъектыЗакрытыеДляРедактирования(ОбъектыДляЗаписи);
	ПропущенныеОбъекты		  = Новый Массив;	
	
	Для каждого ОбъектСсылка Из ОбъектыДляЗаписи Цикл
		Если ЗакрытыеДляРедактирования.Найти(ОбъектСсылка) <> Неопределено Тогда
			ПропущенныеОбъекты.Добавить(ОбъектСсылка);
			ТекстСообщения = НСтр("ru = 'Документ %1 находится закрытом периоде. Редактирование запрещено.'; 
								|en = 'Document %1 is in a closed period. Editing is prohibited.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ОбъектСсылка);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ОбъектСсылка);
			Продолжить;
		КонецЕсли;
		
		Если ОбъектСсылка.ПометкаУдаления Тогда 
			ТекстСообщения = НСтр("ru = 'Документ %1 пропущен: пометка на удаление.'; 
				|en = 'Document %1 is marked for deletion.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ОбъектСсылка);
			ПропущенныеОбъекты.Добавить(ОбъектСсылка);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ОбъектСсылка);
			Продолжить;
		КонецЕсли;	
		
		НачатьТранзакцию();
		Попытка		
			Если ПараметрыЗаписи.ВыполнитьПроведение Тогда 
				УдалосьПровести = УдалосьПровестиДокумент(ОбъектСсылка);
				Если НЕ УдалосьПровести Тогда
					ПропущенныеОбъекты.Добавить(ОбъектСсылка);				
				КонецЕсли;
			ИначеЕсли ПараметрыЗаписи.ВыполнитьПроведениеБит Тогда 
				УдалосьПровести = УдалосьВыполнитьПроведениеБитСервер(ОбъектСсылка);
				Если НЕ УдалосьПровести Тогда
					ПропущенныеОбъекты.Добавить(ОбъектСсылка);
				КонецЕсли;
			КонецЕсли;
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ТекстСообщения = НСтр("ru = 'Ошибка обработки документа %1. По причине: %2'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ОбъектСсылка, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ОбъектСсылка);
		КонецПопытки;
	КонецЦикла;
		
	РезультатВыполнения = Новый Структура;
	РезультатВыполнения.Вставить("Сообщения",		   Новый Массив);
	// Не вполне понятно как работают сообщения. Возможно в пред. сборке они работали не штатно,
	// поэтому приходилось получать: ПолучитьСообщенияПользователю(Истина));
	// Теперь для совместимости использую массив.
	РезультатВыполнения.Вставить("ПропущенныеОбъекты", ПропущенныеОбъекты);
	
	Возврат РезультатВыполнения;

КонецФункции
	
#КонецОбласти // ЗаписьИзменений

Функция ИнициализироватьКомпоновщик(Компоновщик, НастройкиКомпоновкиДанных) Экспорт

	СхемаКомпоновкиДанных = Обработки.бит_ОтражениеДДСВФактеБюджета.ПолучитьМакет("ДокументыДвижений");
	
	АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных, Новый УникальныйИдентификатор);
	ИсточникНастроек		   = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных);
	
	Попытка
		Компоновщик.Инициализировать(ИсточникНастроек);	
	Исключение 
		ТекстСообщения = НСтр("ru='Невозможно применить настройки. По причине: %1';
							  |en='It is impossible to apply the settings. Due to: %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		 
	КонецПопытки;
		
	Если НастройкиКомпоновкиДанных.Выбор.Элементы.Количество() = 0 Тогда
		Компоновщик.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);
	Иначе	

		НастройкиКомпоновкиДанных.Выбор.Элементы.Очистить();
		ОсновнойВариант = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;
		Для каждого Элемент Из ОсновнойВариант.Выбор.Элементы Цикл
			бит_ОтчетыБФКлиентСервер.ДобавитьВыбранноеПоле(НастройкиКомпоновкиДанных, Элемент.Поле);	
		КонецЦикла;
		Компоновщик.ЗагрузитьНастройки(НастройкиКомпоновкиДанных);
		Компоновщик.Восстановить(СпособВосстановленияНастроекКомпоновкиДанных.Полное);
	КонецЕсли;
	
	Возврат АдресСхемыКомпоновкиДанных;

КонецФункции

Функция НовыеСохраняемыеНастройки() Экспорт 
	
	СохраняемыеНастройки = Новый Структура;
	СохраняемыеНастройки.Вставить("Период", 			       Новый СтандартныйПериод(ВариантСтандартногоПериода.ЭтотМесяц));
	СохраняемыеНастройки.Вставить("НастройкиКомпоновкиДанных", Новый НастройкиКомпоновкиДанных);
	СохраняемыеНастройки.Вставить("РежимКонтроля",             0);
	СохраняемыеНастройки.Вставить("РежимПроверкиАналитик",     0);
	
	ПроверяемыеАналитики = Новый СписокЗначений;
	ПроверяемыеАналитики.Добавить(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.СтатьяОборотов);
	ПроверяемыеАналитики.Добавить(ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ЦФО);
	
	СохраняемыеНастройки.Вставить("ПроверяемыеАналитики", ПроверяемыеАналитики);

	Возврат СохраняемыеНастройки;
	
КонецФункции

Функция ПрименитьНастройки(НастройкаПодбораДокументов, Обработка) Экспорт

	ШаблонНастроек = НовыеСохраняемыеНастройки();

	Если ЗначениеЗаполнено(НастройкаПодбораДокументов) Тогда
		
		РеквизитыНастройки 	 = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(НастройкаПодбораДокументов, "ХранилищеНастроек");
		СохраненныеНастройки = РеквизитыНастройки.ХранилищеНастроек.Получить();
		
		Если ТипЗнч(СохраненныеНастройки) = Тип("Структура") Тогда
			ЗаполнитьЗначенияСвойств(ШаблонНастроек, СохраненныеНастройки);
		КонецЕсли;  		
	КонецЕсли;
	
	АдресСКД = ИнициализироватьКомпоновщик(Обработка.КомпоновщикНастроек, 
						ШаблонНастроек.НастройкиКомпоновкиДанных);
						
	ЗаполнитьЗначенияСвойств(Обработка, ШаблонНастроек);
	
	Если ШаблонНастроек.Период.Вариант = ВариантСтандартногоПериода.ПроизвольныйПериод Тогда
		Обработка.Период = Новый СтандартныйПериод(ШаблонНастроек.Период.ДатаНачала, 
									ШаблонНастроек.Период.ДатаОкончания);
	Иначе	
		Обработка.Период = Новый СтандартныйПериод(ШаблонНастроек.Период.Вариант);
	КонецЕсли;

	Возврат АдресСКД;	

КонецФункции

Функция ЗаполнитьПереченьДокументов(СхемаКомпоновкиДанных, НастройкиКомпоновкиДанных, Настройки) Экспорт
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиКомпоновкиДанных,,,
							Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки);
	
	ТаблицаПереченьПолный = Новый ТаблицаЗначений;
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ТаблицаПереченьПолный);
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	ТаблицаПереченьПолный.Колонки.Добавить("ОписаниеОшибки", Новый ОписаниеТипов("Строка", ,
															 Новый КвалификаторыСтроки(0, ДопустимаяДлина.Переменная)));
	ПроверитьОтклонениеСуммыОтражения(ТаблицаПереченьПолный, Настройки);
	ПроверитьЗаполнениеАналитик(ТаблицаПереченьПолный, Настройки);
	ПроверитьСоответствиеСтатейОборотов(ТаблицаПереченьПолный, Настройки);
	УдалитьСтрокиБезОшибок(ТаблицаПереченьПолный, Настройки);
	
	Возврат ТаблицаПереченьПолный;
	
КонецФункции

Функция НовыеНастройкиПроверкиЗаполнения() Экспорт

	Настройки = Новый Структура;
	Настройки.Вставить("РежимКонтроля",         0);
	Настройки.Вставить("ПроверяемыеАналитики",  Неопределено);
	Настройки.Вставить("РежимПроверкиАналитик", 0);
	
	Возврат Настройки;
	
КонецФункции

Функция ВедетсяСоответствиеСтатейОборотов() Экспорт
	
	Если бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СоответствиеСтатей.СтатьяРегл КАК СтатьяРегл
	|ИЗ
	|	РегистрСведений.бит_СтатьиОборотов_СтатьиРегл КАК СоответствиеСтатей";
	Возврат НЕ Запрос.Выполнить().Пустой();
	
КонецФункции

#КонецОбласти

