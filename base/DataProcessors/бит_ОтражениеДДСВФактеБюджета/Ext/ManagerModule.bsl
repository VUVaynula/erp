Процедура УдалитьСтрокиБезОшибок(ПервичныеДокументы, Настройки)
	
	Если ПоказыватьВсеДокументы(Настройки.РежимКонтроля) Тогда
		Возврат;
	КонецЕсли;
	
	Индекс = ПервичныеДокументы.Количество() - 1;
	Пока Индекс >= 0 Цикл
		СтрокаДокумента = ПервичныеДокументы.Получить(Индекс);		
		Если ПустаяСтрока(СтрокаДокумента.ОписаниеОшибки) Тогда
			ПервичныеДокументы.Удалить(СтрокаДокумента);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;	
	
КонецПроцедуры

