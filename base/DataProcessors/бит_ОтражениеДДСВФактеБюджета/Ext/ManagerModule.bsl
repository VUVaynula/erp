Функция ОбъектыЗакрытыеДляРедактирования(ОбъектыДляОбработки)
	
	ЗакрытыеДляРедактирования = Новый Массив;
    
    Для каждого ОбъектСсылка Из ОбъектыДляОбработки Цикл
		МетаОбъект			 = ОбъектСсылка.Метаданные();
        ЗапретРедактирования = бит_ДатыЗапретаРедактирования.ВыполнитьПроверкуДатыЗапретаРедактирования(
									МетаОбъект, ОбъектСсылка);
        Если ЗапретРедактирования Тогда
            ЗакрытыеДляРедактирования.Добавить(ОбъектСсылка);
        КонецЕсли;
    КонецЦикла;

    Возврат ЗакрытыеДляРедактирования;
	
КонецФункции

Функция УдалосьВыполнитьПроведениеБитСервер(ОбъектСсылка)
	
	Отказ 		    = Ложь;
	РежимПроведения = РежимЗаписиДокумента.Запись;
	ДокументОбъект  = ОбъектСсылка.ПолучитьОбъект();
	
	бит_Казначейство.ОбработкаПроведенияПлатежногоДокумента(ДокументОбъект, Отказ, РежимПроведения, Истина);
	
	Если НЕ Отказ Тогда
		ТрансляцияВыполнена = УдалосьВыполнитьТрансляциюПроводок(ДокументОбъект);
		Если НЕ ТрансляцияВыполнена Тогда
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат НЕ Отказ;
	
КонецФункции

Функция УдалосьВыполнитьТрансляциюПроводок(ДокументОбъект)
	
	Отказ = Ложь;
	ИспользуетсяМеханизмКонтроляЗакрытогоПериода = бит_ОбщегоНазначения.ЕстьМеханизмКонтроляЗакрытогоПериода();
	Если ИспользуетсяМеханизмКонтроляЗакрытогоПериода Тогда			
		// При наличии механизма контроля закрытого периода сохраним движения для последующего анализа.
		бит_КонтрольЗакрытогоПериода.КонсервироватьДвижения(ДокументОбъект, Отказ, РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);	
	КонецЕсли;
	
	// МХО.
	бит_МеханизмХозяйственныхОперацийСервер.бит_мхо_НастраиваемыеДвиженияДокументовОбработкаПроведения(
		ДокументОбъект, Отказ, РежимПроведенияДокумента.Неоперативный);
	Для каждого НаборЗаписей Из ДокументОбъект.Движения Цикл
		Если НаборЗаписей.Записывать Тогда
			ДокументОбъект.Движения.Записать();
			Прервать;
		КонецЕсли; 
	КонецЦикла; 
	
	// Трансляция.
	бит_МеханизмТрансляции.ВыполнитьТрансляцию(ДокументОбъект,,, Истина, Перечисления.бит_РежимыТрансляции.Ручной);
	Если ИспользуетсяМеханизмКонтроляЗакрытогоПериода Тогда			
		// При наличии механизма контроля закрытого периода сформируем корректирующие проводки.
		бит_КонтрольЗакрытогоПериода.КонтрольПриОбработкеПроведения(ДокументОбъект, Отказ, РежимЗаписиДокумента.Проведение, Истина);	
	КонецЕсли;	
	
	Если ДокументОбъект.Заблокирован() Тогда	
		ДокументОбъект.Разблокировать(); 	
	КонецЕсли;
	
	Возврат НЕ Отказ;
		
КонецФункции

Функция УдалосьПровестиДокумент(ОбъектСсылка)

	УдалосьПровести = Истина;
	ДокументОбъект	= ОбъектСсылка.ПолучитьОбъект();	
	
	Попытка
		ДокументОбъект.Заблокировать();
		МожноЗаписатьДокумент = Истина;
	Исключение
		ТекстСообщения = НСтр("ru='Документ %1 заблокирован. Проведение невозможно.';
							  |en='Document %1 blocked. Carrying impossible.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбъектСсылка);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения); 
		МожноЗаписатьДокумент = Ложь;
		УдалосьПровести 	  = Ложь;
	КонецПопытки;                 
	
	Если МожноЗаписатьДокумент Тогда
		Успех = бит_ОбщегоНазначения.ЗаписатьПровестиДокумент(ДокументОбъект, 
					РежимЗаписиДокумента.Проведение);
		ДокументОбъект.Разблокировать();
		Если НЕ Успех Тогда
			УдалосьПровести = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат УдалосьПровести;
	
КонецФункции

#КонецОбласти // ЗаписьИзменений

Функция ПроверятьСуммыОтражения(РежимКонтроля)
	
	Возврат (РежимКонтроля = 0) ИЛИ (РежимКонтроля = 1) ИЛИ (РежимКонтроля = 4);
	
КонецФункции

Функция ПроверятьЗаполнениеАналитик(РежимКонтроля)
	
	Возврат (РежимКонтроля = 0) ИЛИ (РежимКонтроля = 2) ИЛИ (РежимКонтроля = 4);
	
КонецФункции

Функция ПроверятьСоответствиеСтатейОборотов(РежимКонтроля)
	
	Возврат ((РежимКонтроля = 0) ИЛИ (РежимКонтроля = 3) ИЛИ (РежимКонтроля = 4))
				И ВедетсяСоответствиеСтатейОборотов();
	
КонецФункции

Функция ПоказыватьВсеДокументы(РежимКонтроля)
	
	Возврат (РежимКонтроля = 4);
	
КонецФункции

Процедура ДобавитьОписаниеОшибки(СтрокаДокумента, ТекстОшибки)
	
	ОписаниеОшибки = СтрокаДокумента.ОписаниеОшибки;
	Если НЕ ПустаяСтрока(ОписаниеОшибки) Тогда
		ОписаниеОшибки = ОписаниеОшибки + Символы.ПС + Символы.ПС;
	КонецЕсли;
	ОписаниеОшибки = ОписаниеОшибки + ТекстОшибки;
	СтрокаДокумента.ОписаниеОшибки = ОписаниеОшибки;
	
КонецПроцедуры

Процедура ПроверитьОтклонениеСуммыОтражения(ТаблицаПереченьПолный, Настройки)
	
	Если НЕ ПроверятьСуммыОтражения(Настройки.РежимКонтроля) Тогда
		Возврат;
	КонецЕсли;
	
	ШаблонОшибки =
		НСтр("ru='Сумма документа не соответствует сумме отражения в бюджете. Сумма документа: %1, сумма бюджета: %2.'");
	Для каждого СтрокаДокумента Из ТаблицаПереченьПолный Цикл
		СуммаДокумента = СтрокаДокумента.СуммаДокумента;
		СуммаОтражения = СтрокаДокумента.СуммаБюджет;
		Если СуммаДокумента <> СуммаОтражения Тогда
			ТекстОшибки = СтрШаблон(ШаблонОшибки, СуммаДокумента, СуммаОтражения);
			ДобавитьОписаниеОшибки(СтрокаДокумента, ТекстОшибки);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ПроверитьЗаполнениеАналитик(ПервичныеДокументы, Настройки)
	
	Если НЕ ПроверятьЗаполнениеАналитик(Настройки.РежимКонтроля) ИЛИ НЕ ЗначениеЗаполнено(ПервичныеДокументы) Тогда
		Возврат;
	КонецЕсли;
		
	Если Настройки.РежимПроверкиАналитик = 0 Тогда
		ПроверитьЗаполнениеАналитикИзЗаданногоСписка(ПервичныеДокументы, Настройки);
	Иначе
		ПроверитьЗаполнениеАналитикИзНастройкиСтатьиОборотов(ПервичныеДокументы, Настройки);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьЗаполнениеАналитикИзЗаданногоСписка(ПервичныеДокументы, Настройки)
	
	ПроверяемыеАналитики = Настройки.ПроверяемыеАналитики;
	Если НЕ ЗначениеЗаполнено(ПроверяемыеАналитики) Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектыСПустойАналитикой = ОбъектыСПустойАналитикойИзЗаданногоСписка(ПервичныеДокументы, Настройки);
	Если ОбъектыСПустойАналитикой.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекстОшибки = "";
	Если ПроверяемыеАналитики.Количество() = 1 Тогда
		ШаблонОшибки = НСтр("ru='Не заполнена аналитика ""%1"".'");
		ТекстОшибки  = СтрШаблон(ШаблонОшибки, ПроверяемыеАналитики[0].Значение);
	Иначе
		ШаблонОшибки = НСтр("ru='Не заполнены одна или несколько аналитик из перечня: %1.'");
		ТекстОшибки  = СтрШаблон(ШаблонОшибки, СтрСоединить(ПроверяемыеАналитики.ВыгрузитьЗначения(), ", "));
	КонецЕсли;
				
	Для каждого СтрокаДокумента Из ПервичныеДокументы Цикл
		Если ОбъектыСПустойАналитикой.НайтиПоЗначению(СтрокаДокумента.Документ) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаДокумента.ЗаполнениеАналитик = 6;
		ДобавитьОписаниеОшибки(СтрокаДокумента, ТекстОшибки);
	КонецЦикла;
	
КонецПроцедуры

Функция ОбъектыСПустойАналитикойИзЗаданногоСписка(ПервичныеДокументы, Настройки)
	
	ОбъектыСПустойАналитикой  = Новый СписокЗначений;
	ПараметрыПроверкиАналитик = ПараметрыПроверкиАналитик(Настройки.ПроверяемыеАналитики);
	ТекстЗапроса              = ТекстЗапросаПроверкиАналитикИзЗаданногоСписка(ПараметрыПроверкиАналитик);
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ОбъектыПроверки",        ПервичныеДокументы.ВыгрузитьКолонку("Документ"));
	Запрос.УстановитьПараметр("ПустыеЗначенияАналитик", ПараметрыПроверкиАналитик.ПустыеЗначенияАналитик);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат ОбъектыСПустойАналитикой;
	КонецЕсли;
	
	ОбъектыСПустойАналитикой.ЗагрузитьЗначения(РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Объект"));
	Возврат ОбъектыСПустойАналитикой;
	
КонецФункции

Функция ПараметрыПроверкиАналитик(ПроверяемыеАналитики)
	
	ПараметрыПроверки = Новый Структура;
	ПараметрыПроверки.Вставить("ИменаИзмерений",         Новый Массив);
	ПараметрыПроверки.Вставить("ПустыеЗначенияАналитик", Новый Массив);
	
	НастройкиИзмерений       = бит_МеханизмДопИзмерений.ПолучитьНастройкиДополнительныхИзмерений("Аналитика");
	
	ПараметрыПроверки.ПустыеЗначенияАналитик.Добавить(Неопределено);
	Для каждого ЭлементСписка Из ПроверяемыеАналитики Цикл
		Аналитика     = ЭлементСписка.Значение;
		ТипыАналитики = Аналитика.ТипЗначения.Типы();
		Для каждого Тип Из ТипыАналитики Цикл
			ПараметрыПроверки.ПустыеЗначенияАналитик.Добавить(бит_ОбщегоНазначения.ПустоеЗначениеТипа(Тип));
		КонецЦикла;
		
		Если Аналитика = ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.ЦФО Тогда
			ПараметрыПроверки.ИменаИзмерений.Добавить("ЦФО");
		ИначеЕсли Аналитика = ПланыВидовХарактеристик.бит_ВидыДополнительныхАналитик.СтатьяОборотов Тогда
			ПараметрыПроверки.ИменаИзмерений.Добавить("СтатьяОборотов");
		Иначе
			НастройкаИзмерения = НастройкиИзмерений.Получить(Аналитика);
			Если НастройкаИзмерения = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ПараметрыПроверки.ИменаИзмерений.Добавить(НастройкаИзмерения.ИмяИзмерения);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПараметрыПроверки;
	
КонецФункции

Функция ТекстЗапросаПроверкиАналитикИзЗаданногоСписка(ПараметрыПроверки)
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ОборотыПоБюджетам.Регистратор КАК Объект
	|ИЗ
	|	РегистрНакопления.бит_ОборотыПоБюджетам КАК ОборотыПоБюджетам
	|ГДЕ
	|	ОборотыПоБюджетам.Регистратор В(&ОбъектыПроверки)
	|	И &УсловиеПустыхАналитик";
	
	ШаблонПоля   = "ОборотыПоБюджетам.%1 В(&ПустыеЗначенияАналитик)";
	УсловияПолей = Новый Массив;
	Для каждого ИмяПоля Из ПараметрыПроверки.ИменаИзмерений Цикл
		УсловияПолей.Добавить(СтрШаблон(ШаблонПоля, ИмяПоля));
	КонецЦикла;
	ТекстУсловияПустыхАналитик = СтрСоединить(УсловияПолей, Символы.ПС + Символы.Таб + "ИЛИ ");
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеПустыхАналитик", "(" + ТекстУсловияПустыхАналитик + ")");
	
	Возврат ТекстЗапроса;
	
КонецФункции

Процедура ПроверитьЗаполнениеАналитикИзНастройкиСтатьиОборотов(ПервичныеДокументы, Настройки)
	
	ОбъектыСПустойАналитикой = ОбъектыСПустойАналитикойИзНастройкиСтатьиОборотов(ПервичныеДокументы);
	Если ОбъектыСПустойАналитикой.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПредставлениеИзмерений = ПредставлениеИзмеренийОборотовПоБюджетам();
	
	ШаблонОшибки = НСтр("ru='Не заполнена аналитика ""%1"".'");
	
	Для каждого СтрокаДокумента Из ПервичныеДокументы Цикл
		ПустыеПоляАналитик = ОбъектыСПустойАналитикой.Получить(СтрокаДокумента.Документ);
		Если ПустыеПоляАналитик = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		СтрокаДокумента.ЗаполнениеАналитик = 6;
		
		Для каждого ПолеАналитики Из ПустыеПоляАналитик Цикл
			ТекстОшибки = СтрШаблон(ШаблонОшибки, ПредставлениеИзмерений.Получить(ПолеАналитики));
			ДобавитьОписаниеОшибки(СтрокаДокумента, ТекстОшибки);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция ОбъектыСПустойАналитикойИзНастройкиСтатьиОборотов(ПервичныеДокументы)
	
	ОбъектыСПустойАналитикой = Новый Соответствие;
	ПоляАналитик             = ИменаПолейАналитикОборотыПоБюджетам();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ОбъектыПроверки", ПервичныеДокументы.ВыгрузитьКолонку("Документ"));
	Запрос.Текст = ТекстЗапросаПроверкиАналитикИзНастройкиСтатьиОборотов(ПоляАналитик);
	
	ВыборкаОбъектов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОбъектов.Следующий() Цикл
		ОбъектПроверки     = ВыборкаОбъектов.Объект;
		ПустыеПоляАналитик = Новый Массив;
		Выборка            = ВыборкаОбъектов.Выбрать();
		Пока Выборка.Следующий() Цикл
			Для каждого ПолеАналитики Из ПоляАналитик Цикл
				Если Выборка["Обязательный_" + ПолеАналитики]
					И НЕ ЗначениеЗаполнено(Выборка[ПолеАналитики]) Тогда
					ПустыеПоляАналитик.Добавить(ПолеАналитики);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		Если ПустыеПоляАналитик.Количество() > 0 Тогда
			ПустыеПоляАналитик = бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(ПустыеПоляАналитик);
			ОбъектыСПустойАналитикой.Вставить(ОбъектПроверки, ПустыеПоляАналитик);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ОбъектыСПустойАналитикой;
	
КонецФункции

Функция ИменаПолейАналитикОборотыПоБюджетам()
	
	ПоляАналитик = Новый Массив;
	ПоляАналитик.Добавить("ЦФО");
	ПоляАналитик.Добавить("СтатьяОборотов");
	
	КоличествоСводныхАналитик = 0;
	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		ПоляАналитик.Добавить("Контрагент");
		ПоляАналитик.Добавить("ДоговорКонтрагента");
		ПоляАналитик.Добавить("Проект");
		ПоляАналитик.Добавить("НоменклатурнаяГруппа");
		ПоляАналитик.Добавить("БанковскийСчет");
		КоличествоСводныхАналитик = 7;
	Иначе
		КоличествоСводныхАналитик = 12;
	КонецЕсли;
	
	ШаблонИмениСводнойАналитики = "Аналитика_%1";
	Для Сч = 1 По КоличествоСводныхАналитик Цикл
		ИмяСводнойАналитики = СтрШаблон(ШаблонИмениСводнойАналитики, Сч);
		ПоляАналитик.Добавить(ИмяСводнойАналитики);
	КонецЦикла;
	
	Возврат ПоляАналитик;
	
КонецФункции

Функция ТекстЗапросаПроверкиАналитикИзНастройкиСтатьиОборотов(ПоляАналитик)
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОборотыПоБюджетам.Регистратор КАК Объект,
	|	&ТекстВыборкиПолейАналитик КАК ТекстВыборкиПолейАналитик
	|ИЗ
	|	РегистрНакопления.бит_ОборотыПоБюджетам КАК ОборотыПоБюджетам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_СтатьиОборотов КАК СтатьиОборотов
	|		ПО ОборотыПоБюджетам.СтатьяОборотов = СтатьиОборотов.Ссылка
	|			И (ОборотыПоБюджетам.Регистратор В (&ОбъектыПроверки))
	|ИТОГИ ПО
	|	Объект";
	
	ШаблонПоля =
	"	ОборотыПоБюджетам.%1 КАК %1,
	|	СтатьиОборотов.Обязательный_%1 КАК Обязательный_%1";
	ШаблонПредопределенногоПоля =
	"	ОборотыПоБюджетам.%1 КАК %1,
	|	ИСТИНА КАК Обязательный_%1";
	ВыборкиПолейАналитик = Новый Массив;
	Для каждого ПолеАналитики Из ПоляАналитик Цикл
		ЭтоПредопределенное = (ПолеАналитики = "ЦФО") ИЛИ (ПолеАналитики = "СтатьяОборотов");
		ТекстВыборкиПоля = СтрШаблон(?(ЭтоПредопределенное, ШаблонПредопределенногоПоля, ШаблонПоля), ПолеАналитики);
		ВыборкиПолейАналитик.Добавить(ТекстВыборкиПоля);
	КонецЦикла;
	ТекстВыборкиПолейАналитик = СтрСоединить(ВыборкиПолейАналитик, "," + Символы.ПС + Символы.Таб);	
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТекстВыборкиПолейАналитик КАК ТекстВыборкиПолейАналитик",
								ТекстВыборкиПолейАналитик);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПредставлениеИзмеренийОборотовПоБюджетам()
	
	ПредставлениеИзмерений = Новый Соответствие;
	
	НастройкиИзмерений = бит_МеханизмДопИзмерений.ПолучитьНастройкиДополнительныхИзмерений();
	Для каждого НастройкаИзмерения Из НастройкиИзмерений Цикл
		ПараметрыИзмерения = НастройкаИзмерения.Значение;
		ПредставлениеИзмерений.Вставить(ПараметрыИзмерения.ИмяИзмерения, ПараметрыИзмерения.Синоним);
	КонецЦикла;
	
	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		ПредставлениеИзмерений.Вставить("ЦФО",                  НСтр("ru='ЦФО'"));
		ПредставлениеИзмерений.Вставить("СтатьяОборотов",       НСтр("ru='Статья оборотов'"));
		ПредставлениеИзмерений.Вставить("Контрагент",           НСтр("ru='Контрагент'"));
		ПредставлениеИзмерений.Вставить("ДоговорКонтрагента",   НСтр("ru='Договор контрагента'"));
		ПредставлениеИзмерений.Вставить("Проект",               НСтр("ru='Проект'"));
		ПредставлениеИзмерений.Вставить("НоменклатурнаяГруппа", НСтр("ru='Номенклатурная группа'"));
		ПредставлениеИзмерений.Вставить("БанковскийСчет",       НСтр("ru='Банковский счет'"));
	КонецЕсли;

	Возврат ПредставлениеИзмерений;
	
КонецФункции

Процедура ПроверитьСоответствиеСтатейОборотов(ПервичныеДокументы, Настройки)
	
	Если НЕ ПроверятьСоответствиеСтатейОборотов(Настройки.РежимКонтроля) Тогда
		Возврат;
	КонецЕсли;
	
	ДокументыБезСоответствияСтатей = ДокументыБезСоответствияСтатей(ПервичныеДокументы);
	Если ДокументыБезСоответствияСтатей.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ШаблонОшибки =
		НСтр("ru='Статьи оборотов в факте бюджета не соответствуют статьям регламентированного учета.
		|	Статьи оборотов в факте бюджета: %1.
		|	Статьи регламентированного учета: %2.
		|	Статьи оборотов в соответствии: %3.'");
	РазделительСтатей = ", ";
	
	Для каждого СтрокаДокумента Из ПервичныеДокументы Цикл
		ДанныеСтатей = ДокументыБезСоответствияСтатей.Получить(СтрокаДокумента.Документ);
		Если ДанныеСтатей = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		СтрокаДокумента.ЗаполнениеАналитик = 6;
		
		ТекстОшибки = СтрШаблон(ШаблонОшибки,
						СтрСоединить(ДанныеСтатей.СтатьиОборотовФактические, РазделительСтатей),
						СтрСоединить(ДанныеСтатей.СтатьиРегламентированногоУчета, РазделительСтатей),
						СтрСоединить(ДанныеСтатей.СтатьиОборотовСоответствия, РазделительСтатей));
		ДобавитьОписаниеОшибки(СтрокаДокумента, ТекстОшибки);
	КонецЦикла;
	
КонецПроцедуры

Функция ДокументыБезСоответствияСтатей(ПервичныеДокументы)
	
	ДокументыБезСоответствияСтатей = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаПроверкиСоответствияСтатей();
	
	ОбъектыПроверки = ПервичныеДокументы.ВыгрузитьКолонку("Документ");
	Запрос.УстановитьПараметр("ОбъектыПроверки", ОбъектыПроверки);
	
	ВидыСубконтоСтатей = Новый Массив;
	ВидыСубконтоСтатей.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.СтатьиДвиженияДенежныхСредств);
	Запрос.УстановитьПараметр("ВидыСубконтоСтатей", ВидыСубконтоСтатей);
	
	ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаДокументов.Следующий() Цикл
		Документ = ВыборкаДокументов.Регистратор;
		СтатьиРегламентированногоУчета = Новый Массив;
		СтатьиОборотовСоответствия     = Новый Массив;
		СтатьиОборотовФактические      = Новый Массив;
		ВыборкаЗаписей = ВыборкаДокументов.Выбрать();
		Пока ВыборкаЗаписей.Следующий() Цикл
			СтатьиРегламентированногоУчета.Добавить(ВыборкаЗаписей.СтатьяРегл);
			СтатьиОборотовСоответствия.Добавить(ВыборкаЗаписей.СтатьяХозрасчетный);
			СтатьиОборотовФактические.Добавить(ВыборкаЗаписей.СтатьяОборотыПоБюджетам);
		КонецЦикла;
		СтатьиРегламентированногоУчета =
			бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(СтатьиРегламентированногоУчета);
		СтатьиОборотовСоответствия = бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(СтатьиОборотовСоответствия);
		СтатьиОборотовФактические  = бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(СтатьиОборотовФактические);
		
		ДанныеСтатей = Новый Структура;
		ДанныеСтатей.Вставить("СтатьиРегламентированногоУчета", СтатьиРегламентированногоУчета);
		ДанныеСтатей.Вставить("СтатьиОборотовСоответствия", СтатьиОборотовСоответствия);
		ДанныеСтатей.Вставить("СтатьиОборотовФактические", СтатьиОборотовФактические);
		
		ДокументыБезСоответствияСтатей.Вставить(Документ, ДанныеСтатей);
	КонецЦикла;
	
	Возврат ДокументыБезСоответствияСтатей;
	
КонецФункции

