&НаСервере
Процедура ЗаполнитьОтборыПоУмолчаниюДляТабличныхЧастей()

	НайденныеСтатьиОборотов = ТаблицаРеквизитов.НайтиСтроки(Новый Структура("ИмяРеквизита", "СтатьяОборотов"));
	Если НайденныеСтатьиОборотов.Количество() > 0 Тогда
		// Для реквизитов типа статья оборотов игнорировать группы.
		СтрокаОтбора = ТаблицаОтбор.Добавить();
		СтрокаОтбора.Имя 		   = НСтр("ru = 'СтатьяОборотов_ЭтоГруппа'; en = 'LineItem_ThisIsAGroup'");
		СтрокаОтбора.Представление = НСтр("ru = 'Статья оборотов.Это группа'; en = 'Line item. This is a group'");
		СтрокаОтбора.ПутьКДанным   = НСтр("ru = 'СтатьяОборотов.ЭтоГруппа'; en = 'LineItem.ThisIsAGroup'");;
		СтрокаОтбора.ВидСравнения  = ВидСравненияКомпоновкиДанных.Равно;
		СтрокаОтбора.Значение      = Ложь;
		СтрокаОтбора.ТипЗначения   = Новый ОписаниеТипов("Булево");
		СтрокаОтбора.Использование = Истина;
	КонецЕсли;
		
КонецПроцедуры

&НаСервереБезКонтекста
Функция СформироватьТекстЗапросаДляОтборов(ОбъектМетаданных, ТаблицаРеквизитов)
		
	Первый = Истина;
			
	Для каждого Рек Из ТаблицаРеквизитов Цикл
		
		Если НЕ Рек.ВыгружатьСписки Тогда
			Продолжить;	
		КонецЕсли;
		
		ИмяРеквизита = Рек.ИмяРеквизита;
		
		ТипыРеквизита = Рек.ОписаниеТипов.Типы();
		Если ТипыРеквизита.Количество() = 1 Тогда
			
			Знч = Рек.ОписаниеТипов.ПривестиЗначение(Неопределено);
			Если бит_ОбщегоНазначения.ЗначениеПринадлежитКоллекцииМетаданных("Справочники", Знч) Тогда
				ИмяТипа = "Справочник";
			ИначеЕсли бит_ОбщегоНазначения.ЗначениеПринадлежитКоллекцииМетаданных("ПланыСчетов", Знч) Тогда
				ИмяТипа = "ПланСчетов";
			ИначеЕсли бит_ОбщегоНазначения.ЗначениеПринадлежитКоллекцииМетаданных("Перечисления", Знч) Тогда
				ИмяТипа = "Перечисление";
			ИначеЕсли бит_ОбщегоНазначения.ЗначениеПринадлежитКоллекцииМетаданных("Документы", Знч) Тогда
				ИмяТипа = "Документ";
			Иначе
				Продолжить;			
			КонецЕсли;
								
			ИмяОбъекта = Знч.Метаданные().Имя;
								
			Если Первый Тогда
			
				ТекстЗапроса = 
				"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
				|	ТекТаб.Ссылка КАК %3
				|ИЗ
				|	%1.%2 КАК ТекТаб
				|{ГДЕ
				|	ТекТаб.Ссылка.* КАК %3}
				|";	
				
				Первый = Ложь;
				
			Иначе
				
				ТекстЗапроса = ТекстЗапроса + "
				|ОБЪЕДИНИТЬ ВСЕ
				|ВЫБРАТЬ ПЕРВЫЕ 1
				|	ТекТаб.Ссылка КАК %3
				|ИЗ
				|	%1.%2 КАК ТекТаб
				|{ГДЕ
				|	ТекТаб.Ссылка.* КАК %3
				|}
				|";
				
			КонецЕсли;	
			
			ТекстЗапроса = СтрШаблон(ТекстЗапроса, ИмяТипа, ИмяОбъекта, ИмяРеквизита);
							
		КонецЕсли;
		
	КонецЦикла;

	Возврат ТекстЗапроса;
	
КонецФункции // СформироватьТекстЗапросаДляОтборов()

