	КонецЕсли;
	
	СтрПар = Новый Структура("ТекстЗапроса", ТекстЗапросаОтборов);				  
	бит_ПолучениеДанныхКлиент.ОткрытьФормуПолейПостроителя(ТекущиеДанные, "ТаблицаОтбор", "ПутьКДанным", "Отбор", "", СтрПар, Элемент);
	
