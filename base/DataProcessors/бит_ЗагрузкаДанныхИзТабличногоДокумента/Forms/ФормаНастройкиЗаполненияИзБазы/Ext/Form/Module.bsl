
#Область ОбработчикиСобытийФормы	

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Объект.ПериодЗаполнения = Параметры.ПериодЗаполнения;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы	

&НаКлиенте
Процедура ОК(Команда)
	
	НастройкиЗаполнения = Новый Структура;
	НастройкиЗаполнения.Вставить("ПериодЗаполнения", Объект.ПериодЗаполнения);
    Закрыть(НастройкиЗаполнения);
    
КонецПроцедуры

#КонецОбласти
