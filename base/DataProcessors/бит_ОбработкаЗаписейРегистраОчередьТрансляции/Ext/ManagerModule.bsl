	Возврат Параметры;
	
КонецФункции

Функция ПараметрыОтложеннойОчистки()
	
	ДокументыДляОбработки = Новый ТаблицаЗначений;
	ДокументыДляОбработки.Колонки.Добавить("Статус");
	ДокументыДляОбработки.Колонки.Добавить("Организация");
	ДокументыДляОбработки.Колонки.Добавить("Объект");
	ДокументыДляОбработки.Колонки.Добавить("Источник");
	ДокументыДляОбработки.Колонки.Добавить("Приемник");
	
	Параметры = Новый Структура;
	Параметры.Вставить("ДокументыДляОбработки",   ДокументыДляОбработки);
	Параметры.Вставить("ДополнительныеПараметры", Новый Структура);
	
	Возврат Параметры;

КонецФункции

Функция НовыеСообщенияПользователю()

	ОписаниеТиповЧисло = ОбщегоНазначения.ОписаниеТипаЧисло(1);

	Результат = Новый ТаблицаЗначений;
	
	Результат.Колонки.Добавить("КлючДанных");  // Ссылка на объект.
	Результат.Колонки.Добавить("Дата");        // Дата, к которой относятся данные объекта. Используется для сортировки списка сообщений.
	Результат.Колонки.Добавить("Сообщение");   // СообщениеПользователю
	Результат.Колонки.Добавить("ТипСообщения", ОписаниеТиповЧисло); // 0 - ошибка, 1 - информация.
	
	Возврат Результат;

КонецФункции

Функция ОбъектыТрансляцииВОчереди()

	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бит_ОчередьТрансляции.Статус КАК Статус,
	|	бит_ОчередьТрансляции.Объект КАК Ссылка,
	|	бит_ОчередьТрансляции.ПоставленоВОчередь КАК ПоставленоВОчередь
	|ИЗ
	|	РегистрСведений.бит_ОчередьТрансляции КАК бит_ОчередьТрансляции
	|ГДЕ
	|	бит_ОчередьТрансляции.Статус = ЗНАЧЕНИЕ(Перечисление.бит_СтатусыВыполненияОтложеннойТрансляции.Ожидание)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПоставленоВОчередь";
		
	Возврат Запрос.Выполнить();

КонецФункции

// Функция получает записи регистра бит_ОчередьТрансляции для дальнейшей обработки. 
// Используется при программном вызове действий с записями регистра.
// 
// Параметры:
//  ВидОперации  - ПеречислениеСсылка.бит_ВидыОперацийОбработкиОчередиТрансляции.
// 
// Возвращаемое значение:
//   Результат   - РезультатЗапроса.
// 
Функция ПолучитьДанныеДляОбработки(ВидОперации)

 	Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
	АдресСКД  = ИнициализироватьКомпоновщик(Компоновщик, Новый УникальныйИдентификатор);
	УстановитьОтборыКомпоновщика(Компоновщик,ВидОперации);
	Результат = ВыполнитьЗапросПоНастройке(Компоновщик, АдресСКД);
    УдалитьИзВременногоХранилища(АдресСКД);
	
	Возврат Результат;
	
КонецФункции // ПолучитьДанныеДляОбработки()

