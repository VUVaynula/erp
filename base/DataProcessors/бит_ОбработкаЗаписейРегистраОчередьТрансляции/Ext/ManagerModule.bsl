#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

#Область ОтложеннаяТрансляция

Функция НачатьОтложеннуюТрансляцию() Экспорт

	ИдентификаторЗадания = ИдентификаторЗаданияОтложеннаяТрансляция(); 
	ВыполняемыйМетод     = "Обработки.бит_ОбработкаЗаписейРегистраОчередьТрансляции.ВыполнитьОтложеннуюТрансляцию";
	
	Результат = НовыйРезультатДлительнойОперации();
	
	Если НЕ ЗаданиеВыполнено(ИдентификаторЗадания) Тогда
		Возврат Результат;	
	КонецЕсли;               
	
	ПараметрыВыполнения  = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторЗадания);
	ПараметрыВыполнения.КлючФоновогоЗадания = Строка(ИдентификаторЗадания);
	ПараметрыВыполнения.ОжидатьЗавершение   = Неопределено;
	
	РезультатЗапроса = ОбъектыТрансляцииВОчереди(); 
	ОбъектыВОчереди  = РезультатЗапроса.Выбрать(); 
	РазмерСпика		 = ОбъектыВОчереди.Количество();
	
	Если РазмерСпика = 0 Тогда
		Результат.Статус = "Выполнено";                    	
		Возврат Результат;	
	КонецЕсли;            
	
	КоличествоПотоков = Константы.КоличествоПотоковДлительныхОпераций.Получить();
	КоличествоПотоков = Макс(1, КоличествоПотоков); 
	
	Если КоличествоПотоков = 1 Тогда
		РазмерыПакетов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(РазмерСпика);
	Иначе	
		Коэффициенты = Новый Массив;
		Для Индекс = 1 По КоличествоПотоков Цикл
			Коэффициенты.Добавить(1);	
		КонецЦикла;
		РазмерыПакетов = ОбщегоНазначенияКлиентСервер.РаспределитьСуммуПропорциональноКоэффициентам(
							РазмерСпика, Коэффициенты, 0);
	КонецЕсли;
	
	// Удалим пакеты нулевой длины.
	Индекс = РазмерыПакетов.ВГраница();
	Пока Индекс >= 0 Цикл
		Если РазмерыПакетов.Получить(Индекс) = 0 Тогда
			РазмерыПакетов.Удалить(Индекс);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;

	Счетчик 			   = 1;
	ИндексПакета 		   = 0;
	НаборПараметровФункции = Новый Соответствие;
	
	Пока ОбъектыВОчереди.Следующий() Цикл
		Если Счетчик = 1 Тогда
			РазмерПорции = РазмерыПакетов[ИндексПакета];
			ПорцияДанных = Новый Массив;
			ИндексПакета = ИндексПакета + 1;
		КонецЕсли;
		ПорцияДанных.Добавить(ОбъектыВОчереди.Ссылка);
		
		Если Счетчик = РазмерПорции Тогда
			Счетчик = 0;
			
			ПараметрыОбработки  = ПараметрыОтложеннойТрансляции();
			ПараметрыОбработки.ДокументыДляОбработки = ПорцияДанных;
						
			ТекущиеПараметрыФункции = Новый Массив;
			ТекущиеПараметрыФункции.Добавить(ПараметрыОбработки);

			НаборПараметровФункции.Вставить(Новый УникальныйИдентификатор, ТекущиеПараметрыФункции);
		КонецЕсли;
		Счетчик	= Счетчик + 1;
	КонецЦикла;
	
	Возврат ДлительныеОперации.ВыполнитьФункциюВНесколькоПотоков(ВыполняемыйМетод, ПараметрыВыполнения, НаборПараметровФункции);
		
КонецФункции

Функция ВыполнитьОтложеннуюТрансляцию(Параметры) Экспорт
		
	РезультатОбработки = Новый Структура();
	РезультатОбработки.Вставить("ОбработаноДокументов",         0);
	РезультатОбработки.Вставить("НеУдалосьОбработать",          0);
	РезультатОбработки.Вставить("ПроведениеПрервано",           Ложь);
	РезультатОбработки.Вставить("ВывестиИнформациюУведомлений", Ложь);
	РезультатОбработки.Вставить("ДополнительныеПараметры",		Параметры.ДополнительныеПараметры);
	РезультатОбработки.Вставить("СообщенияПользователю",		НовыеСообщенияПользователю());
	
	ДокументыДляОбработки = Параметры.ДокументыДляОбработки;
	Если НЕ ЗначениеЗаполнено(ДокументыДляОбработки) Тогда
		Возврат РезультатОбработки;
	КонецЕсли;
		
	ИмяСобытия = НСтр("ru='Начало выполнения отложенной трансляции.';
					  |en='Start of delayed translation.'", ОбщегоНазначения.КодОсновногоЯзыка());
	ТекстСообщения = НСтр("ru='Начало выполнения отложенной трансляции.';
						  |en='Start of delayed translation.'"); 
    ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);
	
	СообщенияПользователю				 = НовыеСообщенияПользователю();
	ЕстьМеханизмКонтроляЗакрытогоПериода = бит_ОбщегоНазначения.ЕстьМеханизмКонтроляЗакрытогоПериода();
	
	ОбработаноДокументов = 0;
	НеУдалосьОбработать  = 0;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументыДляОбработки", ДокументыДляОбработки);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	бит_ОчередьТрансляции.Статус КАК Статус,
	|	бит_ОчередьТрансляции.Организация КАК Организация,
	|	бит_ОчередьТрансляции.Объект КАК Объект,
	|	бит_ОчередьТрансляции.Источник КАК Источник,
	|	бит_ОчередьТрансляции.Приемник КАК Приемник,
	|	бит_ОчередьТрансляции.ПоставленоВОчередь КАК ПоставленоВОчередь,
	|	бит_ОчередьТрансляции.Протокол КАК Протокол,
	|	бит_ОчередьТрансляции.ДатаТрансляции КАК ДатаТрансляции
	|ИЗ
	|	РегистрСведений.бит_ОчередьТрансляции КАК бит_ОчередьТрансляции
	|ГДЕ
	|	бит_ОчередьТрансляции.Статус = ЗНАЧЕНИЕ(Перечисление.бит_СтатусыВыполненияОтложеннойТрансляции.Ожидание)
	|	И бит_ОчередьТрансляции.Объект В(&ДокументыДляОбработки)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПоставленоВОчередь
	|ИТОГИ ПО
	|	Объект
	|АВТОУПОРЯДОЧИВАНИЕ";
				   
	Результат		= Запрос.Выполнить();
	ВыборкаДокумент = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаДокумент.Следующий() Цикл
		
		Отказ = Ложь;		
		// Прочитаем набор регистра-очереди.
		СтруктураОтбор = Новый Структура;
		СтруктураОтбор.Вставить("Объект",ВыборкаДокумент.Объект);
		НаборОчередь = бит_ОбщегоНазначения.ПрочитатьНаборЗаписейРегистраСведений(СтруктураОтбор,"бит_ОчередьТрансляции");
		
		// Заполним перечень источников и приемников.
		Источники 	 = Новый Массив;
		Приемники 	 = Новый Массив;
		ВсеИсточники = Ложь;
		ВсеПриемники = Ложь;
		
		Выборка = ВыборкаДокумент.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);		
		
		Пока Выборка.Следующий() Цикл
			Если ЗначениеЗаполнено(Выборка.Источник) Тогда
			   Источники.Добавить(Выборка.Источник);
			Иначе	
			   ВсеИсточники = Истина;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Выборка.Приемник) Тогда
			   Приемники.Добавить(Выборка.Приемник);
			Иначе	
			   ВсеПриемники = Истина;
			КонецЕсли; 
		КонецЦикла;
		
		Если ВсеИсточники Тогда
			Источники = Неопределено;			
		КонецЕсли; 
		
		Если ВсеПриемники Тогда
			Приемники = Неопределено;
		КонецЕсли; 
		
		ДокументОбъект = ВыборкаДокумент.Объект.ПолучитьОбъект();
	
		Если ЕстьМеханизмКонтроляЗакрытогоПериода Тогда
			бит_КонтрольЗакрытогоПериода.КонсервироватьДвижения(ДокументОбъект, Отказ, 
				РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
		КонецЕсли; 
		
		// Выполним трансляцию движений.
		РезультатОбработкиДокумента = бит_МеханизмТрансляции.ВыполнитьТрансляцию(ДокументОбъект, Источники, Приемники, 
										Истина, Перечисления.бит_РежимыТрансляции.Отложенный);
										
		ДатаТрансляции = ТекущаяДатаСеанса();
		
		Если ЕстьМеханизмКонтроляЗакрытогоПериода Тогда
			бит_КонтрольЗакрытогоПериода.КонтрольПриОбработкеПроведения(ДокументОбъект, Отказ,
				РежимЗаписиДокумента.Проведение, Истина);			
		КонецЕсли; 				
		
		Индекс = НаборОчередь.Количество() - 1;
		Пока Индекс >= 0 Цикл			
			
			ЗаписьОчередь = НаборОчередь[Индекс];
						
			Если ЗаписьОчередь.Статус = Перечисления.бит_СтатусыВыполненияОтложеннойТрансляции.Ошибка 
			 ИЛИ ЗаписьОчередь.Статус = Перечисления.бит_СтатусыВыполненияОтложеннойТрансляции.Выполнено Тогда
				
				НаборОчередь.Удалить(ЗаписьОчередь);
				
			Иначе
				Если РезультатОбработкиДокумента.ЕстьОшибки Тогда
					ЗаписьОчередь.Статус   = Перечисления.бит_СтатусыВыполненияОтложеннойТрансляции.Ошибка;
				Иначе	
					ЗаписьОчередь.Статус   = Перечисления.бит_СтатусыВыполненияОтложеннойТрансляции.Выполнено;
				КонецЕсли; 
				ЗаписьОчередь.Протокол = РезультатОбработкиДокумента.Протокол;
				ЗаписьОчередь.ДатаТрансляции = ДатаТрансляции;
			КонецЕсли; 
			
			Индекс = Индекс - 1;
		КонецЦикла;
		
		ОбработаноДокументов = ОбработаноДокументов + 1;
		
		Если РезультатОбработкиДокумента.ЕстьОшибки Тогда
			НеУдалосьОбработать = НеУдалосьОбработать + 1;
		КонецЕсли;
		
		НоваяЗапись = СообщенияПользователю.Добавить();
		
		НоваяЗапись.КлючДанных 	 = ВыборкаДокумент.Объект;
		НоваяЗапись.Дата 	  	 = ДатаТрансляции;
		НоваяЗапись.Сообщение 	 = РезультатОбработкиДокумента.Протокол;
		НоваяЗапись.ТипСообщения = ?(РезультатОбработкиДокумента.ЕстьОшибки, 0, 1);
		
		НаборОчередь.Записать();
	КонецЦикла; // По документам.

	ИмяСобытия = НСтр("ru='Завершено выполнение отложенной трансляции.';
					  |en='Delayed translation completed.'", ОбщегоНазначения.КодОсновногоЯзыка());
	ТекстСообщения = НСтр("ru='Завершено выполнение отложенной трансляции.';
						  |en='Delayed translation completed.'"); 
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);

	РезультатОбработки.ОбработаноДокументов  = ОбработаноДокументов;
	РезультатОбработки.НеУдалосьОбработать   = НеУдалосьОбработать;
	РезультатОбработки.СообщенияПользователю = СообщенияПользователю;
	
	Возврат РезультатОбработки;
	
КонецФункции

#КонецОбласти

#Область ОтложеннаяОчисткаОчереди

Функция НачатьОтложеннуюОчисткуОчереди() Экспорт

	ИдентификаторЗадания  = ИдентификаторЗаданияОтложеннаяОчистка();
    ВыполняемыйМетод    = "Обработки.бит_ОбработкаЗаписейРегистраОчередьТрансляции.ВыполнитьОтложеннуюОчисткуОчереди";
	
	Результат = НовыйРезультатДлительнойОперации();
	
	Если НЕ ЗаданиеВыполнено(ИдентификаторЗадания) Тогда
		Возврат Результат;	
	КонецЕсли;   
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторЗадания);
	ПараметрыВыполнения.КлючФоновогоЗадания = Строка(ИдентификаторЗадания);
	ПараметрыВыполнения.ОжидатьЗавершение   = Неопределено;
	
	ПараметрОтбора	 = Перечисления.бит_ВидыОперацийОбработкиОчередиТрансляции.УдалитьОбработанныеЗаписи;
	РезультатЗапроса = ПолучитьДанныеДляОбработки(ПараметрОтбора);
	ОбъектыВОчереди  = РезультатЗапроса.Выбрать();
	РазмерСпика		 = ОбъектыВОчереди.Количество();
	
	Если РазмерСпика = 0 Тогда
		Результат.Статус = "Выполнено";                    	
		Возврат Результат;	
	КонецЕсли;
	
	КоличествоПотоков = Константы.КоличествоПотоковДлительныхОпераций.Получить();
	КоличествоПотоков = Макс(1, КоличествоПотоков);
	Если КоличествоПотоков = 1 Тогда
		РазмерыПакетов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(РазмерСпика);
	Иначе	
		Коэффициенты = Новый Массив;
		Для Индекс = 1 По КоличествоПотоков Цикл
			Коэффициенты.Добавить(1);	
		КонецЦикла;
		РазмерыПакетов = ОбщегоНазначенияКлиентСервер.РаспределитьСуммуПропорциональноКоэффициентам(
							РазмерСпика, Коэффициенты, 0);
	КонецЕсли;
	
	// Удалим пакеты нулевой длины.
	Индекс = РазмерыПакетов.ВГраница();
	Пока Индекс >= 0 Цикл
		Если РазмерыПакетов.Получить(Индекс) = 0 Тогда
			РазмерыПакетов.Удалить(Индекс);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;

	Счетчик 			   = 1;
	ИндексПакета 		   = 0;
	НаборПараметровФункции = Новый Соответствие;
	Пока ОбъектыВОчереди.Следующий() Цикл
		Если Счетчик = 1 Тогда
			РазмерПорции = РазмерыПакетов[ИндексПакета];
			ИндексПакета = ИндексПакета + 1;
			
			ДокументыДляОбработки = ПараметрыОтложеннойОчистки().ДокументыДляОбработки;
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(ДокументыДляОбработки.Добавить(), ОбъектыВОчереди);
		
		Если Счетчик = РазмерПорции Тогда
			Счетчик = 0;
			
			ПараметрыОбработки  = ПараметрыОтложеннойОчистки();
			ПараметрыОбработки.ДокументыДляОбработки = ДокументыДляОбработки;
						
			ТекущиеПараметрыФункции = Новый Массив;
			ТекущиеПараметрыФункции.Добавить(ПараметрыОбработки);

			НаборПараметровФункции.Вставить(Новый УникальныйИдентификатор, ТекущиеПараметрыФункции);
		КонецЕсли;
		Счетчик	= Счетчик + 1;
	КонецЦикла;
	
	Возврат ДлительныеОперации.ВыполнитьФункциюВНесколькоПотоков(ВыполняемыйМетод, ПараметрыВыполнения, НаборПараметровФункции);	

КонецФункции

Функция ВыполнитьОтложеннуюОчисткуОчереди(Параметры) Экспорт

	РезультатОбработки = Новый Структура();
	РезультатОбработки.Вставить("ОбработаноДокументов",         0);
	РезультатОбработки.Вставить("НеУдалосьОбработать",          0);
	РезультатОбработки.Вставить("ВывестиИнформациюУведомлений", Ложь);
	РезультатОбработки.Вставить("ДополнительныеПараметры",		Параметры.ДополнительныеПараметры);
	РезультатОбработки.Вставить("СообщенияПользователю",		НовыеСообщенияПользователю());
	
	ДокументыДляОбработки = Параметры.ДокументыДляОбработки;
	Если НЕ ЗначениеЗаполнено(ДокументыДляОбработки) Тогда
		Возврат РезультатОбработки;
	КонецЕсли;
	
	ИмяСобытия = НСтр("ru='Начало удаления обработанных записей очереди трансляции.';
					  |en='Start of removing the processed records of translation queue.'",
					  ОбщегоНазначения.КодОсновногоЯзыка());
	ТекстСообщения = НСтр("ru='Начало удаления обработанных записей очереди трансляции.';
						  |en='Start of removing the processed records of translation queue.'"); 
    ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);

	ОбработаноДокументов = 0;
	НеУдалосьОбработать  = 0;

	Для каждого СтрокаТаблицы Из ДокументыДляОбработки Цикл
		
		МенеджерЗаписи = РегистрыСведений.бит_ОчередьТрансляции.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, СтрокаТаблицы);	
		МенеджерЗаписи.Удалить();
		
		ОбработаноДокументов = ОбработаноДокументов + 1;
	КонецЦикла;
	
	ИмяСобытия = НСтр("ru='Завершено удаление обработанных записей очереди трансляции.';
					  |en='Removing processed records of translation queue completed.'",
					  ОбщегоНазначения.КодОсновногоЯзыка());
	ТекстСообщения = НСтр("ru='Завершено удаление обработанных записей очереди трансляции.';
						  |en='Removing processed records of translation queue completed.'"); 
	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);

	РезультатОбработки.ОбработаноДокументов  = ОбработаноДокументов;
	РезультатОбработки.НеУдалосьОбработать   = НеУдалосьОбработать;

	Возврат РезультатОбработки;
	
КонецФункции

#КонецОбласти

// Функция инициализирует компоновщик для получения записей 
// регистра сведений бит_ОчередьТрансляции для последующей обработки.
// 
// Параметры:
//  Компоновщик              - КомпоновщикНастроекСхемыКомпоновкиДанных.
//  УникальныйИдентификатор  - УникальныйИдентификатор.
// 
// Возвращаемое значение:
//   АдресСхемыКомпоновкиДанных   - Строка.
// 
Функция ИнициализироватьКомпоновщик(Компоновщик,УникальныйИдентификатор) Экспорт

	СхемаКомпоновкиДанных = Обработки.бит_ОбработкаЗаписейРегистраОчередьТрансляции.ПолучитьМакет("СхемаКомпоновкиДанных");
	АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных, УникальныйИдентификатор);
	
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных);
	
    Компоновщик.Инициализировать(ИсточникНастроек);
	Компоновщик.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);

	Возврат АдресСхемыКомпоновкиДанных;
	
КонецФункции // ИнициализироватьКомпоновщик()

// Функция выполняет запрос по настройке компновщика.
// 
// Параметры:
//  Компоновщик  - КомпоновщикНастроекКомпоновкиДанных.
//  АдресСхемыКомпоновкиДанных  - Строка.
// 
// Возвращаемое значение:
//   Результат   - РезультатЗапроса.
// 
Функция ВыполнитьЗапросПоНастройке(Компоновщик,АдресСхемыКомпоновкиДанных)  Экспорт

	 СхемаКомпоновкиДанных = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновкиДанных);

	// Выполняем компановку макета МакетСКД
	// (настройки берутся из схемы компановки данных и из пользовательских настроек).
	КомпоновщикМакетаКомпоновкиДанных = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетСКД = КомпоновщикМакетаКомпоновкиДанных.Выполнить(СхемаКомпоновкиДанных, Компоновщик.ПолучитьНастройки());
	
	// Получаем запрос макета компановки данных
	Запрос = Новый Запрос(МакетСКД.НаборыДанных.ОчередьТрансляции.Запрос);
	
	// Устанавливаем параметры запроса
	ОписаниеПараметровЗапроса = Запрос.НайтиПараметры();
	Для каждого ОписаниеПараметраЗапроса Из ОписаниеПараметровЗапроса Цикл
		Запрос.УстановитьПараметр(ОписаниеПараметраЗапроса.Имя, МакетСКД.ЗначенияПараметров[ОписаниеПараметраЗапроса.Имя].Значение);
	КонецЦикла;

	Результат = Запрос.Выполнить();

	Возврат Результат;
	
КонецФункции // ВыполнитьЗапросПоНастройке()

// Процедура устанавливает отбор компоновщика по статусу в зависимости от вида операции.
// 
// Параметры:                                                  
//  Компоновщик  - КомпоновщикНастроекКомпоновкиДанных.
//  ВидОперации  - ПеречислениеСсылка.бит_ВидыОперацийОбработкиОчередиТрансляции.
// 
Процедура УстановитьОтборыКомпоновщика(Компоновщик,ВидОперации) Экспорт

    Для каждого ЭлементОтбора Из Компоновщик.Настройки.Отбор.Элементы Цикл
	
		Если Строка(ЭлементОтбора.ЛевоеЗначение) = "Статус" Тогда
			
			// Установим отбор по статусу в зависимости от вида операции.
			ЭлементОтбора.Использование = Истина;
			Если ВидОперации = Перечисления.бит_ВидыОперацийОбработкиОчередиТрансляции.УдалитьОбработанныеЗаписи Тогда
				
				ЭлементОтбора.ПравоеЗначение   = Перечисления.бит_СтатусыВыполненияОтложеннойТрансляции.Выполнено;
				ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ;
				
			ИначеЕсли ВидОперации = Перечисления.бит_ВидыОперацийОбработкиОчередиТрансляции.ИзменитьСтатус Тогда
				
				ЭлементОтбора.ПравоеЗначение   = Перечисления.бит_СтатусыВыполненияОтложеннойТрансляции.Ошибка;
				ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ;				
				
			КонецЕсли; 
			
			// Синхронизируем элемент пользовательских настроек с настройкой отбора.
			ЭлементПН = бит_ОбщегоНазначения.НайтиЭлементПользовательскойНастройки(ЭлементОтбора.ИдентификаторПользовательскойНастройки
			                                                                                   ,Компоновщик);
			Если ЭлементПН <> Неопределено Тогда
				
				ЭлементПН.ПравоеЗначение   = ЭлементОтбора.ПравоеЗначение;
				ЭлементПН.Использование    = ЭлементОтбора.Использование;
				ЭлементПН.РежимОтображения = ЭлементОтбора.РежимОтображения;
				
			КонецЕсли; 
			 
		КонецЕсли; // Отбор по статусу
	
	КонецЦикла; // По элементам отбора
	

КонецПроцедуры // УстановитьОтборыКомпоновщика()

// Процедура выполняет изменение статусов оповещений в регистре бит_ОчередьТрансляции.
// 
// Параметры:
//  РезультатЗапроса  - РезультатЗапроса.
//  НовыйСтатус       - ПеречислениеСсылка.бит_ВидыОперацийОбработкиОчередиТрансляции.
//  РежимСообщения    - Строка.
// 
Процедура ИзменитьСтатусОповещений(РезультатЗапроса, НовыйСтатус, РежимСообщений = "Нет") Экспорт
	
	РежимыВывода = бит_ОбщегоНазначения.ОпределитьРежимыВывода(РежимСообщений);	
	
	Если РезультатЗапроса = Неопределено Тогда		
		РезультатЗапроса = ПолучитьДанныеДляОбработки(Перечисления.бит_ВидыОперацийОбработкиОчередиТрансляции.ИзменитьСтатус);		
	КонецЕсли; 	
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Ном = 1;
	КоличествоЗаписей = Выборка.Количество();
	Пока Выборка.Следующий() Цикл
	
		МенеджерЗаписи = РегистрыСведений.бит_ОчередьТрансляции.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи,Выборка);
		
		Попытка			
			МенеджерЗаписи.Удалить();
			ЗаполнитьЗначенияСвойств(МенеджерЗаписи,Выборка);
			МенеджерЗаписи.Статус = НовыйСтатус;
			МенеджерЗаписи.Записать();			
		Исключение			
			Если РежимыВывода.ВыводитьОшибки Тогда			
				ТекстСообщения = НСтр("ru='Не удалось изменить статус оповещния для объекта ""%1"".';
									  |en='Failed to change alert status for object ""%1"".'");
				ТекстСообщения = СтрШаблон(ТекстСообщения, МенеджерЗаписи.Объект);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);				
			КонецЕсли; 			
		КонецПопытки; 
		
		Ном = Ном+1;
		Если Ном%10 = 0 Тогда			
			 ТекстСостояния = НСтр("ru='Изменение статусов оповещений %1 из %2';
			 					   |en='Change of notification status %1 from %2'");
			 ТекстСостояния = СтрШаблон(ТекстСостояния, Строка(Ном), Строка(КоличествоЗаписей));
			 ОбщегоНазначения.СообщитьПользователю(ТекстСостояния);			 
		КонецЕсли; 
		 
	КонецЦикла; // По выборке
	
	Если РежимыВывода.ВыводитьИнформацию Тогда		
		ТекстСообщения = НСтр("ru='Изменение статусов оповещений завершено.';
							  |en='Change of notification status completed.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		
	КонецЕсли;
	
КонецПроцедуры

// Процедура удаляет обработанные записи регистра бит_ОчередьТрансляции.
// 
// Параметры:
//  РезультатЗапроса  - РезультатЗапроса.
//  РежимСообщений    - Строка.
// 
Процедура УдалитьОбработанныеЗаписи(РезультатЗапроса = Неопределено,РежимСообщений = "Нет") Экспорт
	
	РежимыВывода = бит_ОбщегоНазначения.ОпределитьРежимыВывода(РежимСообщений);		
	
	Если РезультатЗапроса = Неопределено Тогда		
		РезультатЗапроса = ПолучитьДанныеДляОбработки(Перечисления.бит_ВидыОперацийОбработкиОчередиТрансляции.УдалитьОбработанныеЗаписи);		
	КонецЕсли; 
	
	Если РезультатЗапроса.Пустой() Тогда		
		ТекстСообщения = НСтр("ru='Нет данных для обработки.';en='No data was provided.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;		
	КонецЕсли; 
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Ном = 1;
	КоличествоЗаписей = Выборка.Количество();	
	Пока Выборка.Следующий() Цикл
		
		МенеджерЗаписи = РегистрыСведений.бит_ОчередьТрансляции.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи,Выборка);
		
		Попытка			
			МенеджерЗаписи.Удалить();			
		Исключение			
			Если РежимыВывода.ВыводитьОшибки Тогда			
				ТекстСообщения = НСтр("ru = 'Не удалось удалить запись очереди трансляции  для объекта ""%1"" зарегистрированную ""%2"".';
		      						  |en = 'Failed to delete translation queue entry for object ""%1"" registered ""%2"".'");
				ТекстСообщения = ТекстСообщения + ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
				ТекстСообщения = СтрШаблон(ТекстСообщения, Строка(МенеджерЗаписи.Объект), Строка(МенеджерЗаписи.ПоставленоВОчередь));
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);				
			КонецЕсли;			
		КонецПопытки; 
		
		Ном = Ном+1;
		Если Ном%10 = 0 Тогда			
			ТекстСостояния = НСтр("ru='Удаление обработанных записей %1 из %2';en='Removing processed records %1 from %2'");
			ТекстСостояния = СтрШаблон(ТекстСостояния, Строка(Ном), Строка(КоличествоЗаписей));
			ОбщегоНазначения.СообщитьПользователю(ТекстСостояния);			 
		КонецЕсли;		
		
	КонецЦикла; 
	
	Если РежимыВывода.ВыводитьИнформацию Тогда		
		ТекстСообщения = НСтр("ru='Удаление обработанных записей завершено.';en='Removing processed records completed'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		
	КонецЕсли;	
	
КонецПроцедуры // УдалитьОбработанныеЗаписи()

#КонецОбласти

