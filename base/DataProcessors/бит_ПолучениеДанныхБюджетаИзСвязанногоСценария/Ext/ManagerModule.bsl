// Функция - Конструктор параметра функции ЗаполнитьОборотыПоБюджетам.
// 
// Возвращаемое значение:
//  Структура - параметры получения оборотов по бюджетам.
//
Функция НовыеПараметрыЗаполненияОборотовПоБюджетам() Экспорт
	
	ПараметрыПолучения = Новый Структура;
	ПараметрыПолучения.Вставить("НастройкиКомпоновщикаЗависимостей",       Неопределено);
	ПараметрыПолучения.Вставить("НастройкиКомпоновщикаОборотовПоБюджетам", Неопределено);
	ПараметрыПолучения.Вставить("ДокументЗаполнения",            Неопределено);
	ПараметрыПолучения.Вставить("ПериодЗаполнения",              Неопределено);
	ПараметрыПолучения.Вставить("Сценарий",                      Справочники.СценарииПланирования.ПустаяСсылка());
	ПараметрыПолучения.Вставить("СценарийЗависимый",             Справочники.СценарииПланирования.ПустаяСсылка());
	ПараметрыПолучения.Вставить("КурсДокумента",                 1);
	ПараметрыПолучения.Вставить("КратностьДокумента",            1);
	ПараметрыПолучения.Вставить("ВалютаДокумента",               Справочники.Валюты.ПустаяСсылка());
	ПараметрыПолучения.Вставить("КурсОбработки",                 1);
	ПараметрыПолучения.Вставить("КратностьОбработки",            1);
	ПараметрыПолучения.Вставить("ВалютаОбработки",               Справочники.Валюты.ПустаяСсылка());
	ПараметрыПолучения.Вставить("ЕдиницаИзмеренияСумм",          Перечисления.бит_ЕдиницыИзмеренияСумм.ПустаяСсылка());
	ПараметрыПолучения.Вставить("РазмерностьЕдиницы",            1);
	ПараметрыПолучения.Вставить("Профиль",                Справочники.бит_ПрофилиРаспределенияПоПериодам.ПустаяСсылка());
	ПараметрыПолучения.Вставить("ПериодичностьСдвигаДат", Перечисления.бит_ПериодичностьПланирования.ПустаяСсылка());
	ПараметрыПолучения.Вставить("СдвигДат",                      0);
	ПараметрыПолучения.Вставить("ВидОтклонения",          Перечисления.бит_ВидыОтклоненийКонтрольныхЗначений.ПустаяСсылка());
	ПараметрыПолучения.Вставить("ВидОтклоненияКоличества",Перечисления.бит_ВидыОтклоненийКонтрольныхЗначений.ПустаяСсылка());
	ПараметрыПолучения.Вставить("ЗначениеОтклонения",            0);
	ПараметрыПолучения.Вставить("ЗначениеОтклоненияКоличества",  0);
	
	Возврат ПараметрыПолучения;
	
КонецФункции

// Процедура получает при помощи СКД обороты по бюджетам.
//
// Параметры:
//  ПараметрыПолучения	 - Структура - см. НовыеПараметрыЗаполненияТаблицыВизирования().
//  АдресВХранилище		 - Строка	 - Адрес временного хранилища результатов заполнения таблицы.
//
Процедура ЗаполнитьОборотыПоБюджетам(ПараметрыПолучения, АдресВХранилище = "") Экспорт
	
	ТаблицаРезультат  = ЗависимыеОборотыПоБюджетам(ПараметрыПолучения);
	ОборотыПоБюджетам = ПреобразованныеОборотыПоБюджетам(ТаблицаРезультат, ПараметрыПолучения);
	
	// Возвращаем результаты.
	СтруктураРезультатаЗаполнения = Новый Структура;
	СтруктураРезультатаЗаполнения.Вставить("ТаблицаРезультат",  ТаблицаРезультат);
	СтруктураРезультатаЗаполнения.Вставить("ОборотыПоБюджетам", ОборотыПоБюджетам);
	
	ПоместитьВоВременноеХранилище(СтруктураРезультатаЗаполнения, АдресВХранилище);
		
КонецПроцедуры

// Функция получает настройку обработки по-умолчанию.
//
// Параметры:
//  Ответственный - СправочникСсылка.Пользователи (необязательный). Пользователь,
//		для которого собирается информация о доступных визах. Если значение не заполнено,
//		определяется доступность для текущего пользователя.
// Возвращаемое значение:
//  ВыбраннаяНастройка  - СправочникСсылка.бит_СохраненныеНастройки.
//
Функция НастройкаПоУмолчанию(Ответственный = Неопределено) Экспорт
	
	Если Ответственный = Неопределено Тогда
		Ответственный = Пользователи.ТекущийПользователь();
	КонецЕсли;
		
	// Получим настройку по - умолчанию.
	НастройкаПоУмолчанию = бит_ОтчетыСервер.НайтиНастройкуПоУмолчаниюДляОбъекта(НаименованиеОбъектаСохраняемыхНастроек(),
							,, Ответственный);
	
	Если ЗначениеЗаполнено(НастройкаПоУмолчанию) Тогда
		Возврат НастройкаПоУмолчанию;
	КонецЕсли;
	
	// Если настройки по умолчанию нет, попробуем определить последнюю использованную пользователем настройку.
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ОбъектСистемы", Метаданные.Обработки.бит_ПолучениеДанныхБюджетаИзСвязанногоСценария);
	СтруктураПараметров.Вставить("КлючЗначения", "ПоследниеЗначения");
	
	ПоследниеЗначения = РегистрыСведений.бит_СохраненныеЗначения.ПолучитьЗнч(Ответственный, СтруктураПараметров);
	Если ТипЗнч(ПоследниеЗначения) = Тип("Структура") И ПоследниеЗначения.Свойство("Настройка") Тогда
		Возврат ПоследниеЗначения.Настройка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция НаименованиеОбъектаСохраняемыхНастроек() Экспорт
	
	Возврат Метаданные.Обработки.бит_ПолучениеДанныхБюджетаИзСвязанногоСценария.ПолноеИмя();
	
КонецФункции

// Процедура инициализирует компоновщик.
// 
Функция ИнициализироватьКомпоновщик(ИмяМакетаКомпоновки, Компоновщик, УникальныйИдентификатор) Экспорт
	
	АдресКомпоновки = "";
	
	НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	// Создаем СКД по запросу.
	СКД = Обработки.бит_ПолучениеДанныхБюджетаИзСвязанногоСценария.ПолучитьМакет(ИмяМакетаКомпоновки);
	бит_МеханизмДопИзмерений.СформироватьЗаголовкиПолейДополнительныхИзмеренийВСКД(СКД,
		"НаборДанных1", НастройкиИзмерений);

	АдресКомпоновки = ПоместитьВоВременноеХранилище(СКД, УникальныйИдентификатор);
	
	// Инициализируем компоновщик.
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресКомпоновки);
	Попытка
		Компоновщик.Инициализировать(ИсточникНастроек);
	Исключение
		ТекстСообщения = НСтр("ru = 'Не удалось инициализировать компоновщик. Описание ошибки: %1.';
							  |en = 'The linker could not be initialized. Error description: %1.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;
	Компоновщик.ЗагрузитьНастройки(СКД.НастройкиПоУмолчанию);
	
	Возврат АдресКомпоновки;
	
КонецФункции

// Выполняет преобразование полученных данных (сдвиг периода, отклонение суммы и количества, распределение по профилю)
//согласно указанным в обработке настроек.
//
// Параметры:
//	ТаблицаРезультат - ТаблицаЗначений, Неопределено
//	ПараметрыПреобразования - Структура.
//
// Возвращаемое значение:
//	ТаблицаЗначений.
//
Функция ПреобразованныеОборотыПоБюджетам(ТаблицаРезультат, ПараметрыПреобразования) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ТаблицаРезультат) Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	ОборотыПоБюджетам = ПодготовитьСтруктуруТаблицыОборотов(ТаблицаРезультат);
	
	Для каждого СтрокаТаблицы Из ТаблицаРезультат Цикл
		НоваяСтрока = ОборотыПоБюджетам.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		
		// Получим период для заполнения исходя от сдвига дат.
		НоваяСтрока.ПериодДляЗаполнения = бит_ОбщегоНазначенияКлиентСервер.ПолучитьПериодПоСдвигу(НоваяСтрока.Период,
											ПараметрыПреобразования.СдвигДат, ПараметрыПреобразования.ПериодичностьСдвигаДат);

		РассчетПоказателейСтроки(НоваяСтрока, ПараметрыПреобразования);
	КонецЦикла;
	
	РаспределитьПоПериодам(ОборотыПоБюджетам, ПараметрыПреобразования);
	
	Возврат ОборотыПоБюджетам;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ЗаполнениеОботовПоБюджетам

Функция ЗависимыеОборотыПоБюджетам(ПараметрыОбработки)
	
	Зависимости = ЗависимостиСценариев(ПараметрыОбработки);
	Если Зависимости.Количество() = 0 Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	ОборотыИсточника = ОборотыИсточника(ПараметрыОбработки, Зависимости);
	Если ОборотыИсточника.Количество() = 0 Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	ЗависимыеОбороты = ЗависимыеОбороты(ПараметрыОбработки, ОборотыИсточника);
	Если ЗависимыеОбороты.Количество() = 0 Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	Возврат ОборотыПоБюджетам(ПараметрыОбработки, ЗависимыеОбороты);
		
КонецФункции

Функция ЗависимостиСценариев(ПараметрыОбработки)
	
	Зависимости = Новый ТаблицаЗначений;
	
	Настройки = ПараметрыОбработки.НастройкиКомпоновщикаЗависимостей;
	Для каждого КлючИЗначение Из ПараметрыОбработки Цикл
		ПараметрНастройки = Настройки.ПараметрыДанных.Элементы.Найти(КлючИЗначение.Ключ);
		Если ПараметрНастройки <> Неопределено Тогда
			ПараметрНастройки.Использование = Истина;
			ПараметрНастройки.Значение      = КлючИЗначение.Значение;
		КонецЕсли;
	КонецЦикла;
	
	СхемаКомпоновки = Обработки.бит_ПолучениеДанныхБюджетаИзСвязанногоСценария.ПолучитьМакет("Зависимости");
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;	
	МакетКомпоновки   = КомпоновщикМакета.Выполнить(СхемаКомпоновки, Настройки,,,
														Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки);
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(Зависимости); 	
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	Возврат Зависимости;
	
КонецФункции

