	|		ПО (ОборотыПоБюджетам.ЦФО = Зависимости.ЦФО
	|				ИЛИ Зависимости.ЦФО = ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка))
	|			И (ОборотыПоБюджетам.СтатьяОборотов = Зависимости.СтатьяОборотов
	|				ИЛИ Зависимости.СтатьяОборотов = ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.ПустаяСсылка))
	|			И (ОборотыПоБюджетам.Аналитика_1 = Зависимости.Аналитика_1
	|				ИЛИ Зависимости.Аналитика_1 = НЕОПРЕДЕЛЕНО)
	|			И (ОборотыПоБюджетам.Аналитика_2 = Зависимости.Аналитика_2
	|				ИЛИ Зависимости.Аналитика_2 = НЕОПРЕДЕЛЕНО)
	|			И (ОборотыПоБюджетам.Аналитика_3 = Зависимости.Аналитика_3
	|				ИЛИ Зависимости.Аналитика_3 = НЕОПРЕДЕЛЕНО)
	|			И (ОборотыПоБюджетам.Аналитика_4 = Зависимости.Аналитика_4
	|				ИЛИ Зависимости.Аналитика_4 = НЕОПРЕДЕЛЕНО)
	|			И (ОборотыПоБюджетам.Аналитика_5 = Зависимости.Аналитика_5
	|				ИЛИ Зависимости.Аналитика_5 = НЕОПРЕДЕЛЕНО)
	|			И (ОборотыПоБюджетам.Аналитика_6 = Зависимости.Аналитика_6
	|				ИЛИ Зависимости.Аналитика_6 = НЕОПРЕДЕЛЕНО)
	|			И (ОборотыПоБюджетам.Аналитика_7 = Зависимости.Аналитика_7
	|				ИЛИ Зависимости.Аналитика_7 = НЕОПРЕДЕЛЕНО)
	|			И (ОборотыПоБюджетам.Аналитика_8 = Зависимости.Аналитика_8
	|				ИЛИ Зависимости.Аналитика_8 = НЕОПРЕДЕЛЕНО)
	|			И (ОборотыПоБюджетам.Аналитика_9 = Зависимости.Аналитика_9
	|				ИЛИ Зависимости.Аналитика_9 = НЕОПРЕДЕЛЕНО)
	|			И (ОборотыПоБюджетам.Аналитика_10 = Зависимости.Аналитика_10
	|				ИЛИ Зависимости.Аналитика_10 = НЕОПРЕДЕЛЕНО)
	|			И (ОборотыПоБюджетам.Аналитика_11 = Зависимости.Аналитика_11
	|				ИЛИ Зависимости.Аналитика_11 = НЕОПРЕДЕЛЕНО)
	|			И (ОборотыПоБюджетам.Аналитика_12 = Зависимости.Аналитика_12
	|				ИЛИ Зависимости.Аналитика_12 = НЕОПРЕДЕЛЕНО)";
	Запрос.УстановитьПараметр("НачалоПериода", ПараметрыОбработки.ПериодЗаполнения.ДатаНачала);
	Запрос.УстановитьПараметр("ОкончаниеПериода", ПараметрыОбработки.ПериодЗаполнения.ДатаОкончания);
	Запрос.УстановитьПараметр("Сценарий", ПараметрыОбработки.Сценарий);
	
	ОборотыИсточника = Запрос.Выполнить().Выгрузить();
	НомерСтроки = 1;
	Для каждого СтрокаИсточника Из ОборотыИсточника Цикл
		СтрокаИсточника.НомерСтроки = НомерСтроки;
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	Возврат ОборотыИсточника;
	
КонецФункции

Функция ЗависимыеОбороты(ПараметрыОбработки, ОборотыИсточника)
	
	ИмяКолонкиКомментария = "КомментарийРасчета";
	Если ОборотыИсточника.Колонки.Найти(ИмяКолонкиКомментария) = Неопределено Тогда
		ОборотыИсточника.Колонки.Добавить(ИмяКолонкиКомментария, Новый ОписаниеТипов("Строка", ,
																 Новый КвалификаторыСтроки(0, ДопустимаяДлина.Переменная)));
	КонецЕсли;
	
	ПараметыЗаполнения = бит_Бюджетирование.НовыеПараметыЗаполненияЗависимыхОборотов();
	ПараметыЗаполнения.ТаблицаИсточник   = ОборотыИсточника;
	ПараметыЗаполнения.ТаблицаПриемник   = ОборотыИсточника.СкопироватьКолонки();
	ПараметыЗаполнения.Сценарий          = ПараметрыОбработки.Сценарий;
	ПараметыЗаполнения.СценарийЗависимый = ПараметрыОбработки.СценарийЗависимый;
	ПараметыЗаполнения.ВестиПротокол     = Истина;
	
	Возврат бит_Бюджетирование.ЗависимыеОборотыПоИсточнику(ПараметыЗаполнения);
	
КонецФункции

Функция ОборотыПоБюджетам(ПараметрыОбработки, ЗависимыеОбороты)
	
	ОборотыПоБюджетам = Новый ТаблицаЗначений;
	
	Настройки = ПараметрыОбработки.НастройкиКомпоновщикаОборотовПоБюджетам;
	Для каждого КлючИЗначение Из ПараметрыОбработки Цикл
		ПараметрНастройки = Настройки.ПараметрыДанных.Элементы.Найти(КлючИЗначение.Ключ);
		Если ПараметрНастройки <> Неопределено Тогда
			ПараметрНастройки.Использование = Истина;
			ПараметрНастройки.Значение      = КлючИЗначение.Значение;
		КонецЕсли;
	КонецЦикла;
	
	ВнешниеНаборыДанных = Новый Структура;
	ЗависимыеОбороты.Колонки.Сумма.Имя = "СуммаСценарий";
	ВнешниеНаборыДанных.Вставить("ЗависимыеОбороты", ЗависимыеОбороты);
	
	СхемаКомпоновки = Обработки.бит_ПолучениеДанныхБюджетаИзСвязанногоСценария.ПолучитьМакет("ОборотыПоБюджетам");
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;	
	МакетКомпоновки   = КомпоновщикМакета.Выполнить(СхемаКомпоновки, Настройки,,,
														Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных,, Истина);
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ОборотыПоБюджетам); 	
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	Возврат ОборотыПоБюджетам;
	
КонецФункции

#КонецОбласти

#Область ПреобразованиеОборотовПоБюджетам

Функция ПодготовитьСтруктуруТаблицыОборотов(ТаблицаРезультат)
	
	ТипБулево = Новый ОписаниеТипов("Булево");
	ТипДата   = Новый ОписаниеТипов("Дата",,, Новый КвалификаторыДаты(ЧастиДаты.Дата));
	ТипКоличество = Новый ОписаниеТипов("Число",
					Новый КвалификаторыЧисла(15, 3, ДопустимыйЗнак.Любой));
	ТипСумма      = Новый ОписаниеТипов("Число",
					Новый КвалификаторыЧисла(15, 2, ДопустимыйЗнак.Любой));
	ТипРаспределения = Новый ОписаниеТипов("Число",
					   Новый КвалификаторыЧисла(14, 8, ДопустимыйЗнак.Неотрицательный));
	
	ОборотыПоБюджетам = ТаблицаРезультат.СкопироватьКолонки();
	ОборотыПоБюджетам.Колонки.Добавить("Выполнять",                     ТипБулево);
	ОборотыПоБюджетам.Колонки.Добавить("ПериодДляЗаполнения",           ТипДата);
	ОборотыПоБюджетам.Колонки.Добавить("КоличествоДляЗаполнения",       ТипКоличество);
	ОборотыПоБюджетам.Колонки.Добавить("СуммаСценарийДляЗаполнения",    ТипСумма);
	ОборотыПоБюджетам.Колонки.Добавить("СуммаСценарийВВалютеДокумента", ТипСумма);
	ОборотыПоБюджетам.Колонки.Добавить("ПроцентРаспределения",          ТипРаспределения);
	
	Возврат ОборотыПоБюджетам;
	
КонецФункции

Процедура РассчетПоказателейСтроки(СтрокаОборота, ПараметрыОбработки)
	
	РассчитатьСуммуДляЗаполненияВСтроке(СтрокаОборота, ПараметрыОбработки.ВидОтклонения,
										ПараметрыОбработки.ЗначениеОтклонения);
	РассчитатьКоличествоДляЗаполненияВСтроке(СтрокаОборота, ПараметрыОбработки.ВидОтклоненияКоличества,
										ПараметрыОбработки.ЗначениеОтклоненияКоличества);
	РассчитатьСуммуВВалютеДокументаВСтроке(СтрокаОборота, ПараметрыОбработки);
	
КонецПроцедуры
				
Процедура РассчитатьСуммуДляЗаполненияВСтроке(ТекущаяСтрока, ВидОтклонения, ЗначениеОтклонения)
	
	Если НЕ ТекущаяСтрока.СтатьяОборотовУчет_Сумма Тогда
		СуммаДляЗаполнения = 0;
	ИначеЕсли ВидОтклонения = Перечисления.бит_ВидыОтклоненийКонтрольныхЗначений.Процент Тогда
		СуммаДляЗаполнения = ТекущаяСтрока.СуммаСценарий + ТекущаяСтрока.СуммаСценарий * ЗначениеОтклонения / 100;
	ИначеЕсли ВидОтклонения = Перечисления.бит_ВидыОтклоненийКонтрольныхЗначений.Абсолютное Тогда
		СуммаДляЗаполнения = ТекущаяСтрока.СуммаСценарий + ЗначениеОтклонения;
	Иначе
		СуммаДляЗаполнения = ТекущаяСтрока.СуммаСценарий;
	КонецЕсли;
	
	ТекущаяСтрока.СуммаСценарийДляЗаполнения = СуммаДляЗаполнения;
	
КонецПроцедуры				

Процедура РассчитатьКоличествоДляЗаполненияВСтроке(ТекущаяСтрока, ВидОтклоненияКоличества, ЗначениеОтклоненияКоличества)
	
	Если НЕ ТекущаяСтрока.СтатьяОборотовУчет_Количество Тогда
		КоличествоДляЗаполнения = 0;
	ИначеЕсли ВидОтклоненияКоличества = Перечисления.бит_ВидыОтклоненийКонтрольныхЗначений.Процент Тогда
		КоличествоДляЗаполнения = ТекущаяСтрока.Количество + ТекущаяСтрока.Количество * ЗначениеОтклоненияКоличества / 100;
	ИначеЕсли ВидОтклоненияКоличества = Перечисления.бит_ВидыОтклоненийКонтрольныхЗначений.Абсолютное Тогда
		КоличествоДляЗаполнения = ТекущаяСтрока.Количество + ЗначениеОтклоненияКоличества;
	Иначе
		КоличествоДляЗаполнения = ТекущаяСтрока.Количество;
	КонецЕсли;
	
	ТекущаяСтрока.КоличествоДляЗаполнения = КоличествоДляЗаполнения;
	
КонецПроцедуры

Процедура РассчитатьСуммуВВалютеДокументаВСтроке(ТекущаяСтрока, ПараметрыОбработки)
	
	// Расчитаем сумму в указанных единицах измерения сумм документа.
	СуммаВЕдиницеДокумента = бит_ОбщегоНазначения.ПересчитатьИзРазмерностиВРазмерность(ТекущаяСтрока.СуммаСценарийДляЗаполнения,
																						1, ПараметрыОбработки.РазмерностьЕдиницы);
		
	// Рассчитаем сумму в валюте документа.
	СуммаВВалютеДокумента = бит_КурсыВалютКлиентСервер.ПересчитатьИзВалютыВВалюту(СуммаВЕдиницеДокумента,
		ПараметрыОбработки.ВалютаОбработки, ПараметрыОбработки.ВалютаДокумента, ПараметрыОбработки.КурсОбработки,
		ПараметрыОбработки.КурсДокумента, ПараметрыОбработки.КратностьОбработки, ПараметрыОбработки.КратностьДокумента);
	
	ТекущаяСтрока.СуммаСценарийВВалютеДокумента = СуммаВВалютеДокумента;
	
КонецПроцедуры

Процедура РаспределитьПоПериодам(ОборотыПоБюджетам, ПараметрыОбработки)
	
	ПрофильРаспределения = ПараметрыОбработки.Профиль;
	
	РаспределенияПоПериодам = РаспределенияПоПериодам(ПрофильРаспределения);
	Если НЕ ЗначениеЗаполнено(РаспределенияПоПериодам) Тогда
		Возврат;
	КонецЕсли;
	
	КопияОборотыПоБюджетам  = ОборотыПоБюджетам.Скопировать();
	ОборотыПоБюджетам.Очистить();
	
	ПоляРаспределения = Новый Массив;
	ПоляРаспределения.Добавить("КоличествоДляЗаполнения");
	ПоляРаспределения.Добавить("СуммаСценарийДляЗаполнения");
	ПоляРаспределения.Добавить("СуммаСценарийВВалютеДокумента");
	
	Для каждого СтрокаОборотов Из КопияОборотыПоБюджетам Цикл
		ИтогиРаспределения = Новый Структура;
		Для каждого Поле Из ПоляРаспределения Цикл
			ИтогиРаспределения.Вставить(Поле, 0);
		КонецЦикла;
		
		Для каждого СтрокаРаспределения Из РаспределенияПоПериодам Цикл
			НоваяСтрокаОборотов = ОборотыПоБюджетам.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаОборотов, СтрокаОборотов);
			
			НоваяСтрокаОборотов.ПериодДляЗаполнения  = бит_ОбщегоНазначенияКлиентСервер.ПолучитьПериодПоСдвигу(
														НоваяСтрокаОборотов.ПериодДляЗаполнения, СтрокаРаспределения.НомерПериода,
														ПараметрыОбработки.ПериодичностьСдвигаДат);
			НоваяСтрокаОборотов.ПроцентРаспределения = СтрокаРаспределения.Процент;
			
			Для каждого Поле Из ПоляРаспределения Цикл
				НоваяСтрокаОборотов[Поле] = НоваяСтрокаОборотов[Поле] * СтрокаРаспределения.Коэффициент;
				ИтогиРаспределения[Поле]  = ИтогиРаспределения[Поле] + НоваяСтрокаОборотов[Поле];
			КонецЦикла; 
		КонецЦикла;
		
		Для каждого Поле Из ПоляРаспределения Цикл
			Дельта = СтрокаОборотов[Поле] - ИтогиРаспределения[Поле];
			Если Дельта <> 0 Тогда
				НоваяСтрокаОборотов[Поле] = НоваяСтрокаОборотов[Поле] + Дельта;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция РаспределенияПоПериодам(ПрофильРаспределения)
	
	Если НЕ ЗначениеЗаполнено(ПрофильРаспределения) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	РаспределенияПоПериодам = ПрофильРаспределения.Профиль.Выгрузить();
	РаспределенияПоПериодам.Колонки.Добавить("Коэффициент", Новый ОписаниеТипов("Число"));
	
	Для каждого СтрокаРаспределения Из РаспределенияПоПериодам Цикл
		СтрокаРаспределения.Коэффициент = СтрокаРаспределения.Процент / 100;
	КонецЦикла;
	
	Возврат РаспределенияПоПериодам;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли