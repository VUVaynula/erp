Процедура ДополнитьПараметрыЗаполнения(ПараметрыЗаполнения, СоставАналитик)

	Для каждого Аналитика Из СоставАналитик Цикл
		ПараметрыЗаполнения[Аналитика.Ключ] = ПараметрыЗаполнения[Аналитика.Значение];
	КонецЦикла; 
	
	Если НЕ ЗначениеЗаполнено(ПараметрыЗаполнения.Организация) Тогда
		ПараметрыЗаполнения.Организация = ПараметрыЗаполнения.ОрганизацияЦФО;
	КонецЕсли;
	
КонецПроцедуры

Функция ПодготовитьПараметрыЗаполненияДокумента(ВидПлана, СоставАналитик, СтрокаДокумент)
	
	ПараметрыЗаполненияДокумента = НовыеПараметрыЗаполненияДокумента();
	ЗаполнитьЗначенияСвойств(ПараметрыЗаполненияДокумента, СтрокаДокумент);
	ДополнитьПараметрыЗаполнения(ПараметрыЗаполненияДокумента, СоставАналитик);
	ПараметрыЗаполненияДокумента.ВидПлана = ВидПлана;
	
	Возврат ПараметрыЗаполненияДокумента;

КонецФункции

