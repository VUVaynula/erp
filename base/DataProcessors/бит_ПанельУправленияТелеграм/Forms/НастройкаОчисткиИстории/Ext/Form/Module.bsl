
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СрокХраненияИсторииТелеграм = Константы.бит_СрокХраненияИсторииТелеграм.Получить();
	
	Задание = РегламентноеЗадание();
	Элементы.КомандаРасписание.Заголовок = Задание.Расписание;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаСервере
Процедура СрокХраненияИсторииТелеграмПриИзмененииНаСервере()
	
	Если СрокХраненияИсторииТелеграм > 0 Тогда
		Константы.бит_СрокХраненияИсторииТелеграм.Установить(СрокХраненияИсторииТелеграм);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СрокХраненияИсторииТелеграмПриИзменении(Элемент)
	
	СрокХраненияИсторииТелеграмПриИзмененииНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОткрытьРасписание(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("УстановитьРасписание", ЭтотОбъект);
	Диалог = Новый ДиалогРасписанияРегламентногоЗадания(ПолучитьРасписание());
	Диалог.Показать(ОписаниеОповещения);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция ПолучитьРасписание()

	УстановитьПривилегированныйРежим(Истина);
	
	Задание = РегламентноеЗадание();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Задание.Расписание;
	
КонецФункции

// Процедура окончание выбора расписания задания. 
//
// Параметры:
//  РезультатВыбора         - Структура.
//  ДополнительныеПараметры - Структура.
//
&НаКлиенте 
Процедура УстановитьРасписание(РасписаниеЗадания, ДополнительныеПараметры) Экспорт
	
	Если РасписаниеЗадания = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.КомандаРасписание.Заголовок = РасписаниеЗадания;
	УстановитьРасписаниеНаСервере(РасписаниеЗадания);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьРасписаниеНаСервере(РасписаниеЗадания)

	УстановитьПривилегированныйРежим(Истина);
	
	НашеЗадание = РегламентноеЗадание();
	Параметры   = Новый Структура();
	Параметры.Вставить("Расписание", РасписаниеЗадания);
	РегламентныеЗаданияСервер.ИзменитьЗадание(НашеЗадание.УникальныйИдентификатор, Параметры);
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция РегламентноеЗадание()

	УстановитьПривилегированныйРежим(Истина);
	
	Отбор = Новый Структура();
	Отбор.Вставить("Метаданные", "бит_УдалениеИсторииТелеграм");
	Задания = РегламентныеЗаданияСервер.НайтиЗадания(Отбор);
	Задание = Задания[0];
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Задание;
	
КонецФункции

#КонецОбласти