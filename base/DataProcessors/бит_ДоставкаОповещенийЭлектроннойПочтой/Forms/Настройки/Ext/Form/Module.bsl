
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	НастройкиДоставки = Параметры.НастройкиДоставки;
	Если ЗначениеЗаполнено(НастройкиДоставки) Тогда
		ЗаполнитьЗначенияСвойств(Объект, НастройкиДоставки);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.КодировкаСообщения) Тогда
		Объект.КодировкаСообщения = "windows-1251";
	КонецЕсли;
	
	Элементы.SMTPАутентификация.СписокВыбора.Добавить("БезАутентификации");
    Элементы.SMTPАутентификация.СписокВыбора.Добавить("Default");	
	Элементы.SMTPАутентификация.СписокВыбора.Добавить("Plain");
	Элементы.SMTPАутентификация.СписокВыбора.Добавить("Login");
	Элементы.SMTPАутентификация.СписокВыбора.Добавить("CramMD5");
	
	Элементы.POPАутентификация.СписокВыбора.Добавить("Обычная");
	Элементы.POPАутентификация.СписокВыбора.Добавить("APOP");
	Элементы.POPАутентификация.СписокВыбора.Добавить("CramMD5");
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)
	
	Если ПроверитьЗаполнение() Тогда
		
		НастройкиДоставки = НастройкиДоставки();
		ОповеститьОВыборе(НастройкиДоставки);
		
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура получате структуру настройки доставки.
// 
&НаСервере
Функция НастройкиДоставки()
	
	ОбработкаОбъект   = РеквизитФормыВЗначение("Объект");
	НастройкиДоставки = бит_ОповещенияСервер.НастройкиДоставки(ОбработкаОбъект);

	Возврат НастройкиДоставки;
	
КонецФункции

#КонецОбласти
