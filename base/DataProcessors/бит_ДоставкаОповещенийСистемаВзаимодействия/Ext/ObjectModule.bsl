#Область СлужебныйПрограммныйИнтерфейс

// Функция определяет, что обработка является обработкой доставки оповещений.
// 
// Возвращаемое значение:
//   Булево
// 
Функция ЭтоОбработкаДоставкиОповещений() Экспорт
	
	Возврат Истина;
	
КонецФункции

Функция НастройкиПоУмолчанию() Экспорт

	РезСтруктура = Новый Структура;

	Возврат РезСтруктура;
	
КонецФункции // НастройкиПоУмолчанию()

Функция ОтправитьСообщение(СообщениеСтруктура, НастройкиДоставки, СтруктураПараметров, ПротоколОтправки = "") Экспорт
	
	Результат = Ложь;
	Отказ 	  = Ложь;
	СтруктураСообщенияКорректна(СообщениеСтруктура, Отказ, ПротоколОтправки);
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если НЕ Отказ 
		И ТипЗнч(СтруктураПараметров.АдресПолучателя) = Тип("СправочникСсылка.Пользователи")
		И ЗначениеЗаполнено(СтруктураПараметров.АдресПолучателя) Тогда	
		
		ПользовательСВ = Обсуждения.ПользовательСистемыВзаимодействия(СтруктураПараметров.АдресПолучателя);
		ИдентификаторПользователяСВ = ПользовательСВ.Идентификатор;
		
		КлючОбсуждения = XMLСтрока(СообщениеСтруктура.Оповещение) + Строка(ИдентификаторПользователяСВ);
		Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(КлючОбсуждения);
		Если Обсуждение = Неопределено Тогда
			Обсуждение = СистемаВзаимодействия.СоздатьОбсуждение();
			Обсуждение.Ключ = КлючОбсуждения;
			Обсуждение.Участники.Добавить(ИдентификаторПользователяСВ);
		ИначеЕсли НЕ Обсуждение.Участники.Содержит(ИдентификаторПользователяСВ) Тогда	
			Обсуждение.Участники.Добавить(ИдентификаторПользователяСВ);
		КонецЕсли;
		Если ЗначениеЗаполнено(СообщениеСтруктура.Оповещение) Тогда
			Обсуждение.Заголовок = Строка(СообщениеСтруктура.Оповещение);			
		Иначе	
			Обсуждение.Заголовок = СообщениеСтруктура.Заголовок;			
		КонецЕсли;  
		Обсуждение.Записать();
		
		СообщениеСВ = СистемаВзаимодействия.СоздатьСообщение(Обсуждение.Идентификатор);
		Если ЗначениеЗаполнено(СообщениеСтруктура.Оповещение)
			И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СообщениеСтруктура.Оповещение, "ВидСобытия") = Перечисления.бит_фн_ВидыСобытийОповещений.ДокументыДляВизирования Тогда
			
			// Это РМВ.
			СсылкиВТекстеСообщения = СообщениеСтруктура.СсылкиВТекстеСообщения.Получить();
			Если СтрСравнить(СообщениеСтруктура.ТипТекстаСообщения, "HTML") = 0 Тогда
				Текст = "";
				Если ЗначениеЗаполнено(СсылкиВТекстеСообщения) Тогда
					СтрокиСообщения = Новый Массив();
					Для Каждого СсылкаВТексте Из СсылкиВТекстеСообщения Цикл
						СтрокиСообщения.Добавить(СсылкаВТексте.Значение);	
					КонецЦикла;
					Текст = СтрСоединить(СтрокиСообщения, Символы.ПС);
				КонецЕсли;
			Иначе
				Текст = СообщениеСтруктура.Текст;
			КонецЕсли;
			СообщениеСВ.Текст = Текст;
			СообщениеСВ.Данные = "ОткрытьНавигационнуюСсылку";
			Представление = НСтр("ru = 'Рабочее место визирования'; en = 'Approval Workplace'");
			СообщениеСВ.Действия.Добавить("e1cib/app/Обработка.бит_КонсольОперативногоВизирования", Представление);
		Иначе
			СсылкиВТекстеСообщения = СообщениеСтруктура.СсылкиВТекстеСообщения.Получить();
			Если ЗначениеЗаполнено(СсылкиВТекстеСообщения) Тогда
				Для Каждого СсылкаВТексте Из СсылкиВТекстеСообщения Цикл
					СообщениеСВ.Действия.Добавить(СсылкаВТексте.Ключ, СсылкаВТексте.Значение);
				КонецЦикла;
			КонецЕсли;
			Если СтрСравнить(СообщениеСтруктура.ТипТекстаСообщения, "HTML") = 0 Тогда
				СообщениеСВ.Текст = СообщениеСтруктура.Заголовок;
			Иначе
				СообщениеСВ.Текст = СообщениеСтруктура.Текст;
			КонецЕсли;
			СообщениеСВ.Данные = "ОткрытьНавигационнуюСсылку";
		КонецЕсли;
		СообщениеСВ.Записать();
		
		Результат = Истина;
		
	КонецЕсли; 
	
	Если Результат Тогда			
		ТекстСообщения = НСтр("ru='Сообщение отправлено в систему взаимодействия.';
								|en='Message sent to the Interaction system.'");
	Иначе			
		ТекстСообщения = НСтр("ru='Ошибка отправки сообщения в систему взаимодействия.';
								|en='Error while sending message Interaction system.'");
	КонецЕсли; 
	ПротоколОтправки = ТекстСообщения;
	
	Возврат Результат;
	
КонецФункции

