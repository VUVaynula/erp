	<Attributes>
		<Attribute name="СписокДокументов" id="1">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Список документов</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>List of Documents</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>СписокДокументов.ОтветНаЗапросСсылка</Field>
				<Field>СписокДокументов.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ЗапросНалоговогоМониторинга.Организация КАК Организация,
	ЗапросНалоговогоМониторинга.ТипЗапроса КАК ТипЗапроса,
	ЗапросНалоговогоМониторинга.Содержание КАК Содержание,
	ЗапросНалоговогоМониторинга.Номер КАК Номер,
	ЗапросНалоговогоМониторинга.Дата КАК Дата,
	ЗапросНалоговогоМониторинга.ЗапрашиваемыеДанные КАК ЗапрашиваемыеДанные,
	ЗапросНалоговогоМониторинга.ДатаНачалаПериода КАК ДатаНачалаПериода,
	ЗапросНалоговогоМониторинга.ДатаКонцаПериода КАК ДатаКонцаПериода,
	ЗапросНалоговогоМониторинга.СрокВыполненияЗапроса КАК СрокВыполненияЗапроса,
	ВЫБОР
		КОГДА НаличиеПрисоединенныхФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА 0
		КОГДА НаличиеПрисоединенныхФайлов.ЕстьФайлы
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЕстьФайлы,
	ЗапросНалоговогоМониторинга.Ссылка КАК Ссылка,
	ВЫБОР
		КОГДА ОтветНаЗапросНалоговогоМониторинга.Ссылка ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ЕстьОтвет,
	ВЫБОР
		КОГДА СтатусыОбъектов_Статус.Статус = ЗНАЧЕНИЕ(Справочник.бит_СтатусыОбъектов.Отклонен)
			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_СтатусыЗапросаНалоговогоМониторинга.ОтветОтклонен)
		КОГДА СтатусыОбъектов_Статус.Статус = ЗНАЧЕНИЕ(Справочник.бит_СтатусыОбъектов.Утвержден)
			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_СтатусыЗапросаНалоговогоМониторинга.Исполнен)
		КОГДА ЗапросНалоговогоМониторинга.СрокВыполненияЗапроса &lt; &amp;ТекущаяДата
			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_СтатусыЗапросаНалоговогоМониторинга.Просрочен)
		КОГДА НЕ ОтветНаЗапросНалоговогоМониторинга.Ссылка ЕСТЬ NULL
			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_СтатусыЗапросаНалоговогоМониторинга.ОтветПолучен)
		КОГДА ЗапросНалоговогоМониторинга.Проведен
			ТОГДА ЗНАЧЕНИЕ(Перечисление.бит_СтатусыЗапросаНалоговогоМониторинга.Отправлен)
		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.бит_СтатусыЗапросаНалоговогоМониторинга.Черновик)
	КОНЕЦ КАК СтатусЗапроса,
	ОтветНаЗапросНалоговогоМониторинга.Ссылка КАК ОтветНаЗапросСсылка
ИЗ
	Документ.бит_ЗапросНалоговогоМониторинга КАК ЗапросНалоговогоМониторинга
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеПрисоединенныхФайлов
		ПО ЗапросНалоговогоМониторинга.Ссылка = НаличиеПрисоединенныхФайлов.ОбъектСФайлами
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_ОтветНаЗапросНалоговогоМониторинга КАК ОтветНаЗапросНалоговогоМониторинга
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_СтатусыОбъектов КАК СтатусыОбъектов_Статус
			ПО ОтветНаЗапросНалоговогоМониторинга.Ссылка = СтатусыОбъектов_Статус.Объект
				И (СтатусыОбъектов_Статус.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))
		ПО ЗапросНалоговогоМониторинга.Ссылка = ОтветНаЗапросНалоговогоМониторинга.ЗапросОснование</QueryText>
				<MainTable>Document.бит_ЗапросНалоговогоМониторинга</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:item xsi:type="dcsset:FilterItemComparison">
							<dcsset:use>false</dcsset:use>
							<dcsset:left xsi:type="dcscor:Field">СтатусЗапроса</dcsset:left>
							<dcsset:comparisonType>Equal</dcsset:comparisonType>
							<dcsset:userSettingID>6d209639-f0ec-472c-88af-7a2bc94295a5</dcsset:userSettingID>
						</dcsset:item>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
					<dcsset:itemsViewMode>Normal</dcsset:itemsViewMode>
					<dcsset:itemsUserSettingID>911b6018-f537-43e8-a417-da56b22f9aec</dcsset:itemsUserSettingID>
				</ListSettings>
			</Settings>
