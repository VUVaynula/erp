		<query>ВЫБРАТЬ
	ВЫБОР
		КОГДА &amp;ВидНастройки = ЗНАЧЕНИЕ(Перечисление.бит_рлс_ВидыНастроекПрав.Доступ)
			ТОГДА &amp;Все
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка)
	КОНЕЦ КАК ЦФО
ПОМЕСТИТЬ ЦфоПоУмолчанию

ОБЪЕДИНИТЬ ВСЕ
ВЫБРАТЬ
	ЗНАЧЕНИЕ(Справочник.Подразделения.ПустаяСсылка)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВЫБОР
		КОГДА &amp;ВидНастройки = ЗНАЧЕНИЕ(Перечисление.бит_рлс_ВидыНастроекПрав.Доступ)
			ТОГДА &amp;Все
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.ПустаяСсылка)
	КОНЕЦ КАК СтатьяОборотов
ПОМЕСТИТЬ СтатьиПоУмолчанию

ОБЪЕДИНИТЬ ВСЕ
ВЫБРАТЬ
	ЗНАЧЕНИЕ(Справочник.бит_СтатьиОборотов.ПустаяСсылка)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЦфоПоУмолчанию.ЦФО КАК ЦФО,
	СтатьиПоУмолчанию.СтатьяОборотов КАК СтатьяОборотов	
ПОМЕСТИТЬ ПарыЦФОСтатьи
ИЗ
	ЦфоПоУмолчанию КАК ЦфоПоУмолчанию,
	СтатьиПоУмолчанию КАК СтатьиПоУмолчанию
{ГДЕ
	ЦфоПоУмолчанию.ЦФО.*,
	СтатьиПоУмолчанию.СтатьяОборотов.*}

ОБЪЕДИНИТЬ ВСЕ
ВЫБРАТЬ
	Подразделения.Ссылка,
	СтатьиПоУмолчанию.СтатьяОборотов
ИЗ
	Справочник.Подразделения КАК Подразделения,
	СтатьиПоУмолчанию КАК СтатьиПоУмолчанию
{ГДЕ
	Подразделения.Ссылка.* КАК ЦФО,
	СтатьиПоУмолчанию.СтатьяОборотов.*}

ОБЪЕДИНИТЬ ВСЕ
ВЫБРАТЬ
	ЦфоПоУмолчанию.ЦФО,
	бит_СтатьиОборотов.Ссылка
ИЗ
	ЦфоПоУмолчанию КАК ЦфоПоУмолчанию,
	Справочник.бит_СтатьиОборотов КАК бит_СтатьиОборотов
{ГДЕ
	ЦфоПоУмолчанию.ЦФО.*,
	бит_СтатьиОборотов.Ссылка.* КАК СтатьяОборотов}
	
ОБЪЕДИНИТЬ ВСЕ
ВЫБРАТЬ
	Подразделения.Ссылка,
	бит_СтатьиОборотов.Ссылка
ИЗ
	Справочник.Подразделения КАК Подразделения,
	Справочник.бит_СтатьиОборотов КАК бит_СтатьиОборотов
{ГДЕ
	Подразделения.Ссылка.* КАК ЦФО,
	бит_СтатьиОборотов.Ссылка.* КАК СтатьяОборотов}
	
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ПарыЦФОСтатьи.ЦФО 					КАК ЦФО,
	ПарыЦФОСтатьи.СтатьяОборотов 		КАК СтатьяОборотов,
	ЕСТЬNULL(ПраваДоступа.Чтение, ЛОЖЬ) КАК Чтение,
	ЕСТЬNULL(ПраваДоступа.Запись, ЛОЖЬ) КАК Запись
ИЗ
	ПарыЦФОСтатьи КАК ПарыЦФОСтатьи
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_рлс_ПраваДоступа КАК ПраваДоступа
		ПО ПарыЦФОСтатьи.ЦФО = ПраваДоступа.Разделитель_1
			И ПарыЦФОСтатьи.СтатьяОборотов = ПраваДоступа.Разделитель_2
			И (ПраваДоступа.ВидНастройки = &amp;ВидНастройки)
			И (ПраваДоступа.ВидОбластиДоступа = &amp;ВидОбластиДоступа)
			И (ПраваДоступа.Пользователь = &amp;Пользователь)
{ГДЕ
	(ЕСТЬNULL(ПраваДоступа.Чтение, ЛОЖЬ)) КАК Чтение,
	(ЕСТЬNULL(ПраваДоступа.Запись, ЛОЖЬ)) КАК Запись}
</query>
