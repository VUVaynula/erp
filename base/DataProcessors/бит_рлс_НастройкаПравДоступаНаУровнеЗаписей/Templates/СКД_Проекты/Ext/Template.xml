		<field xsi:type="DataSetFieldField">
			<dataPath>Проект</dataPath>
			<field>Проект</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Проект</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Project</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ВЫБОР
		КОГДА &amp;ВидНастройки = ЗНАЧЕНИЕ(Перечисление.бит_рлс_ВидыНастроекПрав.Доступ)
			ТОГДА &amp;Все
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
	КОНЕЦ КАК Проект,
	ЛОЖЬ КАК Чтение,
	ЛОЖЬ КАК Запись
ПОМЕСТИТЬ ВремТабл

ОБЪЕДИНИТЬ ВСЕ
ВЫБРАТЬ
	ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка),
	ЛОЖЬ,
	ЛОЖЬ

ОБЪЕДИНИТЬ ВСЕ
ВЫБРАТЬ
	ЕСТЬNULL(бит_рлс_ПраваДоступа.Разделитель_4, ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)),
	бит_рлс_ПраваДоступа.Чтение,
	бит_рлс_ПраваДоступа.Запись
ИЗ
	РегистрСведений.бит_рлс_ПраваДоступа КАК бит_рлс_ПраваДоступа
ГДЕ
	бит_рлс_ПраваДоступа.Пользователь = &amp;Пользователь
	И ЕСТЬNULL(бит_рлс_ПраваДоступа.Разделитель_4, ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)) В (&amp;СписокПоУмолчанию)
	И бит_рлс_ПраваДоступа.ВидНастройки = &amp;ВидНастройки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВремТабл.Проект,
	МАКСИМУМ(ВремТабл.Чтение) КАК Чтение,
	МАКСИМУМ(ВремТабл.Запись) КАК Запись
ПОМЕСТИТЬ НастройкиПоУмолчанию
ИЗ
	ВремТабл КАК ВремТабл

СГРУППИРОВАТЬ ПО
	ВремТабл.Проект
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Справочник.Ссылка КАК Проект,
	ПраваДоступа.Чтение КАК Чтение,
	ПраваДоступа.Запись КАК Запись
ПОМЕСТИТЬ НастройкиПоПроектам
ИЗ
	Справочник.Проекты КАК Справочник
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_рлс_ПраваДоступа КАК ПраваДоступа
		ПО Справочник.Ссылка = ПраваДоступа.Разделитель_4
			И (ПраваДоступа.ВидНастройки = &amp;ВидНастройки)
			И (ПраваДоступа.Пользователь = &amp;Пользователь)
			И (ПраваДоступа.ВидОбластиДоступа = &amp;ВидОбластиДоступа)
{ГДЕ
	Справочник.Ссылка.* КАК Проект,
	ПраваДоступа.Чтение,
	ПраваДоступа.Запись}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	НастройкиПоУмолчанию.Проект КАК Проект,
	НастройкиПоУмолчанию.Чтение КАК Чтение,
	НастройкиПоУмолчанию.Запись КАК Запись
{ВЫБРАТЬ
	Проект.*,
	Чтение,
	Запись}
ИЗ
	НастройкиПоУмолчанию КАК НастройкиПоУмолчанию

ОБЪЕДИНИТЬ ВСЕ
ВЫБРАТЬ
	НастройкиПоПроектам.Проект,
	НастройкиПоПроектам.Чтение,
	НастройкиПоПроектам.Запись
ИЗ
	НастройкиПоПроектам КАК НастройкиПоПроектам</query>
