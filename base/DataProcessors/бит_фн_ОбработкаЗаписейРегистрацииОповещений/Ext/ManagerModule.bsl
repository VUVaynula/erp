#Область СлужебныйПрограммныйИнтерфейс

// Функция инициализирует компоновщик для получения записей 
// регистра сведений бит_фн_РегистрацияСобытийОповещений для последующей обработки.
// 
// Параметры:
//  Компоновщик              - КомпоновщикНастроекСхемыКомпоновкиДанных.
//  УникальныйИдентификатор  - УникальныйИдентификатор.
// 
// Возвращаемое значение:
//   АдресСхемыКомпоновкиДанных   - Строка.
// 
Функция ИнициализироватьКомпоновщик(Компоновщик,УникальныйИдентификатор) Экспорт

	// ++ ЕРП
	СхемаКомпоновкиДанных = Обработки.бит_фн_ОбработкаЗаписейРегистрацииОповещений.ПолучитьМакет("СхемаКомпоновкиДанныхERP");
	// -- ЕРП
	АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных, УникальныйИдентификатор);
	
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных);
	
    Компоновщик.Инициализировать(ИсточникНастроек);
	Компоновщик.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);

	Возврат АдресСхемыКомпоновкиДанных;
	
КонецФункции // ИнициализироватьКомпоновщик()

// Функция выполняет запрос по настройке компновщика.
// 
// Параметры:
//  Компоновщик  - КомпоновщикНастроекКомпоновкиДанных.
//  АдресСхемыКомпоновкиДанных  - Строка.
//  ВидОперации  - ПеречислениеСсылка.бит_фн_ВидыОперацийОбработкиЗаписейРегистраОповещений.
// 
// Возвращаемое значение:
//   Результат   - РезультатЗапроса.
// 
Функция ВыполнитьЗапросПоНастройке(Компоновщик,АдресСхемыКомпоновкиДанных,ВидОперации)  Экспорт

	 СхемаКомпоновкиДанных = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновкиДанных);

	// Выполняем компановку макета МакетСКД
	// (настройки берутся из схемы компановки данных и из пользовательских настроек).
	КомпоновщикМакетаКомпоновкиДанных = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетСКД = КомпоновщикМакетаКомпоновкиДанных.Выполнить(СхемаКомпоновкиДанных, Компоновщик.ПолучитьНастройки());
	
	// Получаем запрос макета компановки данных.
	Запрос = Новый Запрос(МакетСКД.НаборыДанных.РегистрацияОповещений.Запрос);
	
	// Для целей оптимизации необходима группировка по НастройкамДоставки.
	Если ВидОперации = Перечисления.бит_фн_ВидыОперацийОбработкиРегистрацииОповещений.СоздатьОповещения Тогда
		Запрос.Текст = Запрос.Текст +"
									|ИТОГИ ПО
									|	ВидСобытия,
									|	Оповещение,
									|	Пользователь";
	КонецЕсли;			
	
	// Устанавливаем параметры запроса.
	ОписаниеПараметровЗапроса = Запрос.НайтиПараметры();
	Для каждого ОписаниеПараметраЗапроса Из ОписаниеПараметровЗапроса Цикл
		Запрос.УстановитьПараметр(ОписаниеПараметраЗапроса.Имя, МакетСКД.ЗначенияПараметров[ОписаниеПараметраЗапроса.Имя].Значение);
	КонецЦикла;

	Результат = Запрос.Выполнить();

	Возврат Результат;
	
КонецФункции // ВыполнитьЗапросПоНастройке()

// Процедура устанавливает отбор компоновщика по статусу в зависимости от вида операции.
// 
// Параметры:                                                  
//  Компоновщик  - КомпоновщикНастроекКомпоновкиДанных.
//  ВидОперации  - ПеречислениеСсылка.бит_фн_ВидыОперацийОбработкиЗаписейРегистраОповещений.
// 
Процедура УстановитьОтборыКомпоновщика(Компоновщик,ВидОперации) Экспорт

    Для каждого ЭлементОтбора Из Компоновщик.Настройки.Отбор.Элементы Цикл
	
		Если Строка(ЭлементОтбора.ЛевоеЗначение) = "СтатусРегистрации" Тогда
			
			// Установим отбор по статусу в зависимости от вида операции.
			ЭлементОтбора.Использование = Истина;
			Если ВидОперации = Перечисления.бит_фн_ВидыОперацийОбработкиРегистрацииОповещений.СоздатьОповещения Тогда
				
				ЭлементОтбора.ПравоеЗначение   = Перечисления.бит_фн_СтатусыРегистрацииОповещений.Зарегистрировано;
				ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
				
			ИначеЕсли ВидОперации = Перечисления.бит_фн_ВидыОперацийОбработкиРегистрацииОповещений.УдалитьОбработанныеЗаписи Тогда
				
				ЭлементОтбора.ПравоеЗначение   = Перечисления.бит_фн_СтатусыРегистрацииОповещений.Обработано;
				ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ;				
				
			КонецЕсли; 
			
			// Синхронизируем элемент пользовательских настроек с настройкой отбора.
			ЭлементПН = бит_ОбщегоНазначения.НайтиЭлементПользовательскойНастройки(ЭлементОтбора.ИдентификаторПользовательскойНастройки
			                                                                                   ,Компоновщик);
			Если ЭлементПН <> Неопределено Тогда
				
				ЭлементПН.ПравоеЗначение = ЭлементОтбора.ПравоеЗначение;
				ЭлементПН.Использование  = ЭлементОтбора.Использование;
				ЭлементПН.РежимОтображения = ЭлементОтбора.РежимОтображения;
				
			КонецЕсли; 
			 
		КонецЕсли; // Отбор по статусу
	
	КонецЦикла; // По элементам отбора
	

КонецПроцедуры // УстановитьОтборыКомпоновщика()

// Конструктор параметров обработки событий оповещений.
//
// Возвращаемое значение:
//	Структура.
//
Функция НовыеПараметрыОбработкиСобытийОповещений() Экспорт
	
	ПараметрыОбработки = Новый Структура;
	
	ПараметрыОбработки.Вставить("ЗаписыватьОповещения", Истина);
	ПараметрыОбработки.Вставить("РежимСообщений",       "Нет");
	ПараметрыОбработки.Вставить("Результат",            Неопределено);
	ПараметрыОбработки.Вставить("СоздаватьОбсуждения",  Ложь);
	
	Возврат ПараметрыОбработки;
	
КонецФункции

// Процедура обрабатываеть события оповещений и формирует сообщения.
//
// Параметры:
//  ПараметрыОбработки - Структура - См. НовыеПараметрыОбработкиСобытийОповещений().
//
Процедура ОбработатьСобытияОповещений(ПараметрыОбработки) Экспорт
	
	ЗаписыватьОповещения = ПараметрыОбработки.ЗаписыватьОповещения;
	РежимСообщений       = ПараметрыОбработки.РежимСообщений;
	Результат            = ПараметрыОбработки.Результат;
	СоздаватьОбсуждения  = ПараметрыОбработки.СоздаватьОбсуждения;
	
	РежимыВывода = бит_ОбщегоНазначения.ОпределитьРежимыВывода(РежимСообщений);			
	
	КэшАдресов = Новый ТаблицаЗначений;
	КэшАдресов.Колонки.Добавить("Получатель", Новый ОписаниеТипов("СправочникСсылка.Пользователи"));
	КэшАдресов.Колонки.Добавить("ВидКонтактнойИнформации");
	КэшАдресов.Колонки.Добавить("Адрес");
	
	КэшАдресов.Индексы.Добавить("Получатель,ВидКонтактнойИнформации");
		
	Если Результат = Неопределено Тогда
		 Результат = ПолучитьДанныеДляОбработки(Перечисления.бит_фн_ВидыОперацийОбработкиРегистрацииОповещений.СоздатьОповещения);
	КонецЕсли; 
	
	Если Результат.Пустой() Тогда
		 ТекстСообщения = НСтр("ru='Нет данных для обработки.';en='No data was provided.'");
		 ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		 Возврат;
	КонецЕсли; 
	
	ТаблицаОповещений = Результат.Выгрузить();
	ТаблицаОповещений.Свернуть("Оповещение");
	МассивОповещений  = ТаблицаОповещений.ВыгрузитьКолонку("Оповещение");
	
	СоотвТаблиц = Справочники.бит_фн_Оповещения.СформироватьТаблицыПолучателей(МассивОповещений);
	
	ВыборкаВидСобытия = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаВидСобытия.Следующий() Цикл
		
		ВыборкаОповещения = ВыборкаВидСобытия.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаОповещения.Следующий() Цикл
			
			ТаблицаПолучатели = СоотвТаблиц[ВыборкаОповещения.Оповещение];
			
			КоличествоОбсуждений = 0;
			Если ТаблицаПолучатели <> Неопределено Тогда
				КоличествоОбсуждений = ТаблицаПолучатели.НайтиСтроки(Новый Структура("СоздаватьОбсуждение", Истина)).Количество();
			КонецЕсли;
			Если КоличествоОбсуждений = 0
				И НЕ ЗаписыватьОповещения Тогда
				// Нет необходимости формировать оповещения получателям.
				Возврат;
			КонецЕсли;
			
			ВыборкаПользователь = ВыборкаОповещения.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаПользователь.Следующий() Цикл
				
				Выборка = ВыборкаПользователь.Выбрать();
				Ошибки  = Новый Массив(); 

				Если ВыборкаВидСобытия.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ДокументыДляВизирования 
					ИЛИ ВыборкаВидСобытия.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.НапоминанияПоГрафикуНачислений 
					ИЛИ ВыборкаВидСобытия.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.НапоминанияПоГрафикуПлатежей 
                    ИЛИ ВыборкаВидСобытия.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ОкончаниеСрокаДействияДоговора
                    ИЛИ ВыборкаВидСобытия.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.НапоминанияОбОплате Тогда
					
					// Для данного вида события несколько записей регистрации формируем в одно сообщение.
					СтруктураКонтекст = Новый Структура;
					СтруктураКонтекст.Вставить("ВидСобытия",		ВыборкаВидСобытия.ВидСобытия);
					СтруктураКонтекст.Вставить("Получатель",		Справочники.Пользователи.ПустаяСсылка());
					СтруктураКонтекст.Вставить("ВыборкаДокументов", Выборка);
					СтруктураКонтекст.Вставить("Оповещение",		ВыборкаПользователь.Оповещение);
					СтруктураКонтекст.Вставить("Пользователь",		ВыборкаПользователь.Пользователь);
										
					ОповещенияПолучателям = СформироватьОповещенияПолучателям(ТаблицаПолучатели, СтруктураКонтекст, КэшАдресов, РежимыВывода, Ошибки);
					Если СоздаватьОбсуждения Тогда
						бит_ОповещенияСервер.СоздатьОбсуждения(ОповещенияПолучателям);
					КонецЕсли; 
					Если ЗаписыватьОповещения Тогда
						Для каждого ПараметрыОповещения Из ОповещенияПолучателям Цикл
							ЗаписатьОповещение(ПараметрыОповещения, РежимыВывода.ВыводитьОшибки);
						КонецЦикла; 
					КонецЕсли; 
					
					Выборка.Сбросить();
					
					Если ВыборкаВидСобытия.ВидСобытия <> Перечисления.бит_фн_ВидыСобытийОповещений.ДокументыДляВизирования  Тогда
						
						НайденнаяСтрока = ТаблицаПолучатели.Найти("ТекущийОбъект.Контрагент", "Получатель");
						Если НайденнаяСтрока <> Неопределено Тогда
							ПараметрыОбработки = НовыеПараметрыОбработкиОповещений();
							ПараметрыОбработки.Выборка = Выборка; 
							ПараметрыОбработки.ЗаписыватьОповещения = ЗаписыватьОповещения; 
							ПараметрыОбработки.КэшАдресов = КэшАдресов; 
							ПараметрыОбработки.Ошибки = Ошибки; 
							ПараметрыОбработки.РежимыВывода = РежимыВывода; 
							ПараметрыОбработки.СоздаватьОбсуждения = СоздаватьОбсуждения; 
							ОбработатьОповещения(НайденнаяСтрока, ТаблицаПолучатели, ПараметрыОбработки);
						КонецЕсли;
						
						НайденнаяСтрока = ТаблицаПолучатели.Найти("ТекущийОбъект.Ответственный", "Получатель");
						Если НайденнаяСтрока <> Неопределено Тогда
							ПараметрыОбработки = НовыеПараметрыОбработкиОповещений();
							ПараметрыОбработки.Выборка = Выборка; 
							ПараметрыОбработки.ЗаписыватьОповещения = ЗаписыватьОповещения; 
							ПараметрыОбработки.КэшАдресов = КэшАдресов; 
							ПараметрыОбработки.Ошибки = Ошибки; 
							ПараметрыОбработки.РежимыВывода = РежимыВывода; 
							ПараметрыОбработки.СоздаватьОбсуждения = СоздаватьОбсуждения; 
							ОбработатьОповещения(НайденнаяСтрока, ТаблицаПолучатели, ПараметрыОбработки);
						КонецЕсли;
						
						НайденнаяСтрока = ТаблицаПолучатели.Найти("ТекущийОбъект.Руководитель", "Получатель");
						Если НайденнаяСтрока <> Неопределено Тогда
							ПараметрыОбработки = НовыеПараметрыОбработкиОповещений();
							ПараметрыОбработки.Выборка = Выборка; 
							ПараметрыОбработки.ЗаписыватьОповещения = ЗаписыватьОповещения; 
							ПараметрыОбработки.КэшАдресов = КэшАдресов; 
							ПараметрыОбработки.Ошибки = Ошибки; 
							ПараметрыОбработки.РежимыВывода = РежимыВывода; 
							ПараметрыОбработки.СоздаватьОбсуждения = СоздаватьОбсуждения; 
							ОбработатьОповещения(НайденнаяСтрока, ТаблицаПолучатели, ПараметрыОбработки);
								КонецЕсли;
						
						НайденнаяСтрока = ТаблицаПолучатели.Найти("ТекущийОбъект.РуководительКонтрагента", "Получатель");
						Если НайденнаяСтрока <> Неопределено Тогда
							ПараметрыОбработки = НовыеПараметрыОбработкиОповещений();
							ПараметрыОбработки.Выборка = Выборка; 
							ПараметрыОбработки.ЗаписыватьОповещения = ЗаписыватьОповещения; 
							ПараметрыОбработки.КэшАдресов = КэшАдресов; 
							ПараметрыОбработки.Ошибки = Ошибки; 
							ПараметрыОбработки.РежимыВывода = РежимыВывода; 
							ПараметрыОбработки.СоздаватьОбсуждения = СоздаватьОбсуждения; 
							ОбработатьОповещения(НайденнаяСтрока, ТаблицаПолучатели, ПараметрыОбработки);
						КонецЕсли;
					КонецЕсли;

					// Отметим событие оповещения как обработанное.
					Если ЗаписыватьОповещения Тогда
						Пока Выборка.Следующий() Цикл
							ОтметитьОбработанныеОповещения(Выборка, РежимыВывода, Ошибки);
						КонецЦикла;
					КонецЕсли; 
										
				Иначе
					// Каждой записи регистрации оповещения будет соответствовать одно сообщение.
					Пока Выборка.Следующий() Цикл
						
						СтруктураКонтекст = Контекст(Выборка);
						ОповещенияПолучателям = СформироватьОповещенияПолучателям(ТаблицаПолучатели, СтруктураКонтекст, КэшАдресов, РежимыВывода, Ошибки);
						Если СоздаватьОбсуждения Тогда
							бит_ОповещенияСервер.СоздатьОбсуждения(ОповещенияПолучателям);
						КонецЕсли; 
						Если ЗаписыватьОповещения Тогда
							Для каждого ПараметрыОповещения Из ОповещенияПолучателям Цикл
								ЗаписатьОповещение(ПараметрыОповещения, РежимыВывода.ВыводитьОшибки);
							КонецЦикла; 
							// Отметим событие оповещения как обработанное.
							ОтметитьОбработанныеОповещения(Выборка, РежимыВывода, Ошибки);
						КонецЕсли; 
					КонецЦикла;
				КонецЕсли; // Определена таблица получателей
			КонецЦикла; // Пользователи
		КонецЦикла; // Оповещения
	КонецЦикла; // Обход видов событий
	
КонецПроцедуры

// Процедура удаляет обработанные записи регистра бит_фн_РегистрацияСобытийОповещений.
// 
// Параметры:
//  РезультатЗапроса  - РезультатЗапроса.
//  РежимСообщений    - Строка.
// 
Процедура УдалитьОбработанныеЗаписи(РезультатЗапроса = Неопределено,РежимСообщений = "Нет") Экспорт
	
	РежимыВывода = бит_ОбщегоНазначения.ОпределитьРежимыВывода(РежимСообщений);		
	
	Если РезультатЗапроса = Неопределено Тогда		
		РезультатЗапроса = ПолучитьДанныеДляОбработки(Перечисления.бит_фн_ВидыОперацийОбработкиРегистрацииОповещений.УдалитьОбработанныеЗаписи);
	КонецЕсли; 
	
	Если РезультатЗапроса.Пустой() Тогда		
		ТекстСообщения = НСтр("ru='Нет данных для обработки.';en='No data was provided.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли; 
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Ном = 1;
	КоличествоЗаписей = Выборка.Количество();	
	Пока Выборка.Следующий() Цикл
		
		МенеджерЗаписи = РегистрыСведений.бит_фн_РегистрацияСобытийОповещений.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи,Выборка);
		
		Попытка			
			МенеджерЗаписи.Удалить();			
		Исключение			
			Если РежимыВывода.ВыводитьОшибки Тогда			
				ТекстСообщения = НСтр("ru='Не удалось удалить запись о регистрации события ""%1"" для объекта ""%2"" за период ""%3"". %4';
						  	  		  |en='Failed to delete the record for the registration of the event ""%1"" for the object ""%2"" for the period ""%3"". %4'");
				ТекстСообщения = СтрШаблон(ТекстСообщения, Строка(МенеджерЗаписи.ВидСобытия), Строка(МенеджерЗаписи.Объект),
					Строка(МенеджерЗаписи.Период), ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);				
			КонецЕсли;			
		КонецПопытки; 
		
		Ном = Ном+1;
	КонецЦикла; 
	
	Если РежимыВывода.ВыводитьИнформацию Тогда		
		ТекстСообщения = НСтр("ru='Удаление обработанных записей завершено.';
							  |en='Removing processed records completed'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		
	КонецЕсли; 	
	
КонецПроцедуры // УдалитьОбработанныеЗаписи()

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НовыеПараметрыОбработкиОповещений()

	КэшАдресов = Новый ТаблицаЗначений;
	КэшАдресов.Колонки.Добавить("Получатель", Новый ОписаниеТипов("СправочникСсылка.Пользователи"));
	КэшАдресов.Колонки.Добавить("ВидКонтактнойИнформации");
	КэшАдресов.Колонки.Добавить("Адрес");
	КэшАдресов.Индексы.Добавить("Получатель,ВидКонтактнойИнформации");
	
	ПараметрыКопирования = Новый Структура;
	ПараметрыКопирования.Вставить("Выборка",				Неопределено);
	ПараметрыКопирования.Вставить("ЗаписыватьОповещения",	Истина);
	ПараметрыКопирования.Вставить("КэшАдресов", 			КэшАдресов);
	ПараметрыКопирования.Вставить("Ошибки", 				Новый Массив());
	ПараметрыКопирования.Вставить("РежимыВывода", 			бит_ОбщегоНазначенияКлиентСервер.ОпределитьРежимыВывода("Все"));
	ПараметрыКопирования.Вставить("СоздаватьОбсуждения", 	Ложь);
	
	Возврат ПараметрыКопирования;
	
КонецФункции

Процедура ОбработатьОповещения(НайденнаяСтрока, ТаблицаПолучатели, ПараметрыОбработки)
	
	Выборка = ПараметрыОбработки.Выборка; 
	ЗаписыватьОповещения = ПараметрыОбработки.ЗаписыватьОповещения; 
	КэшАдресов = ПараметрыОбработки.КэшАдресов; 
	Ошибки = ПараметрыОбработки.Ошибки; 
	РежимыВывода = ПараметрыОбработки.РежимыВывода; 
	СоздаватьОбсуждения = ПараметрыОбработки.СоздаватьОбсуждения; 
	
	ДопТаблицаПолучатели = ТаблицаПолучатели.СкопироватьКолонки();
	НоваяСтрока = ДопТаблицаПолучатели.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, НайденнаяСтрока);
	
	// Каждой записи регистрации оповещения будет соответствовать одно сообщение.
	Пока Выборка.Следующий() Цикл
		СтруктураКонтекст = Контекст(Выборка);
		ОповещенияПолучателям = СформироватьОповещенияПолучателям(ДопТаблицаПолучатели, СтруктураКонтекст, КэшАдресов, РежимыВывода, Ошибки);
		Если СоздаватьОбсуждения Тогда
			бит_ОповещенияСервер.СоздатьОбсуждения(ОповещенияПолучателям);
		КонецЕсли;
		Если ЗаписыватьОповещения Тогда
			Для каждого ПараметрыОповещения Из ОповещенияПолучателям Цикл
				ЗаписатьОповещение(ПараметрыОповещения, РежимыВывода.ВыводитьОшибки);
			КонецЦикла; 
		КонецЕсли; 
	КонецЦикла;
	Выборка.Сбросить();

КонецПроцедуры

// Функция получает записи регистра бит_фн_Оповещения для дальнейшей обработки. 
// Используется при программном вызове действий с записями регистра.
// 
// Параметры:
//  ВидОперации  - ПеречислениеСсылка.бит_фн_ВидыОперацийОбработкиЗаписейРегистраОповещений.
// 
// Возвращаемое значение:
//   Результат   - РезультатЗапроса.
// 
Функция ПолучитьДанныеДляОбработки(ВидОперации)

 	Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
	АдресСКД  = ИнициализироватьКомпоновщик(Компоновщик,Новый УникальныйИдентификатор);
	УстановитьОтборыКомпоновщика(Компоновщик,ВидОперации);
	Результат = ВыполнитьЗапросПоНастройке(Компоновщик,АдресСКД,ВидОперации);
    УдалитьИзВременногоХранилища(АдресСКД);
	
	Возврат Результат;
	
КонецФункции // ПолучитьДанныеДляОбработки()

Процедура ПодготовитьВыборкуЗаписейДляОтправки(ВыборкаДокументов, ПользовательскоеУсловие)
	
	МассивТиповОбъекта = Новый Массив;
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_ДополнительныеУсловияПоДоговору"));
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_ФормаВводаБюджета"));
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_БюджетнаяОперация"));
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_КорректировкаБюджета"));
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_КорректировкаКонтрольныхЗначений"));
	
	// ++ ЕРП
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_АктуализацияБюджета"));
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_ПротоколРасхожденийБюджета"));
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств"));
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию"));
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств"));
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_пз_ЗаявкаНаЗатраты"));
	МассивТиповОбъекта.Добавить(Тип("ДокументСсылка.бит_пз_СводнаяЗаявкаНаЗатраты"));
	МассивТиповОбъекта.Добавить(Тип("СправочникСсылка.ДоговорыКонтрагентов"));
	МассивТиповОбъекта.Добавить(Тип("СправочникСсылка.ДоговорыКредитовИДепозитов"));
	Если бит_ОбщегоНазначенияКлиентСерверПереопределяемый.ЕстьДоговорыАренды() Тогда
		МассивТиповОбъекта.Добавить(Тип("СправочникСсылка.ДоговорыАренды"));
	КонецЕсли;
	МассивТиповОбъекта.Добавить(Тип("СправочникСсылка.ДоговорыМеждуОрганизациями"));
	МассивТиповОбъекта.Добавить(Тип("СправочникСсылка.СоглашенияСКлиентами"));
	МассивТиповОбъекта.Добавить(Тип("СправочникСсылка.СоглашенияСПоставщиками"));
	// -- ЕРП
	
	// Подготовим таблицу значений.
	ТаблицаДокументов = Новый ТаблицаЗначений;
	ТаблицаДокументов.Колонки.Добавить("Период",       Новый ОписаниеТипов("Дата"));
	ТаблицаДокументов.Колонки.Добавить("ВидСобытия",   Новый ОписаниеТипов("ПеречислениеСсылка.бит_фн_ВидыСобытийОповещений"));	
	ТаблицаДокументов.Колонки.Добавить("Оповещение",   Новый ОписаниеТипов("СправочникСсылка.бит_фн_Оповещения"));
	ТаблицаДокументов.Колонки.Добавить("Объект",       Новый ОписаниеТипов(МассивТиповОбъекта));
	ТаблицаДокументов.Колонки.Добавить("Статус",       Новый ОписаниеТипов("СправочникСсылка.бит_СтатусыОбъектов"));
	ТаблицаДокументов.Колонки.Добавить("Виза",         Новый ОписаниеТипов("СправочникСсылка.бит_Визы"));
	ТаблицаДокументов.Колонки.Добавить("Решение",      Новый ОписаниеТипов("СправочникСсылка.бит_ВидыРешенийСогласования"));
	ТаблицаДокументов.Колонки.Добавить("Комментарий",  Новый ОписаниеТипов("Строка"));	
	ТаблицаДокументов.Колонки.Добавить("Пользователь", Новый ОписаниеТипов("СправочникСсылка.Пользователи"));
	ТаблицаДокументов.Колонки.Добавить("Получатель",   Новый ОписаниеТипов("СправочникСсылка.Пользователи"));
	
	// Заполняем ТЗ по пользовательскому условию.
	Пока ВыборкаДокументов.Следующий() Цикл
		флУсловиеВыполнено = бит_УправлениеПроцессами.ПроверитьПользовательскоеУсловие(ПользовательскоеУсловие
																			,Контекст(ВыборкаДокументов));
		Если флУсловиеВыполнено Тогда
			НоваяСтрока = ТаблицаДокументов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДокументов);			
		КонецЕсли; 																	  
	КонецЦикла;
	
	// Преобразуем ТЗ в выборку из запроса для формирования сообщений по шаблону.
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТаблицаДокументов", ТаблицаДокументов);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаДокументов.Период КАК Период,
	|	ТаблицаДокументов.ВидСобытия КАК ВидСобытия,
	|	ТаблицаДокументов.Оповещение КАК Оповещение,
	|	ТаблицаДокументов.Объект КАК Объект,
	|	ТаблицаДокументов.Статус КАК Статус,
	|	ТаблицаДокументов.Виза КАК Виза,
	|	ТаблицаДокументов.Решение КАК Решение,
	|	ТаблицаДокументов.Комментарий КАК Комментарий,
	|	ТаблицаДокументов.Пользователь КАК Пользователь,
	|	ТаблицаДокументов.Получатель КАК Получатель
	|ПОМЕСТИТЬ ТабВрем
	|ИЗ
	|	&ТаблицаДокументов КАК ТаблицаДокументов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТабВрем.Период КАК Период,
	|	ТабВрем.ВидСобытия КАК ВидСобытия,
	|	ТабВрем.Оповещение КАК Оповещение,
	|	ТабВрем.Объект КАК Объект,
	|	ТабВрем.Статус КАК Статус,
	|	ТабВрем.Виза КАК Виза,
	|	ТабВрем.Решение КАК Решение,
	|	ТабВрем.Комментарий КАК Комментарий,
	|	ТабВрем.Пользователь КАК Пользователь,
	|	ТабВрем.Получатель КАК Получатель
	|ИЗ
	|	ТабВрем КАК ТабВрем";
	
	ВыборкаДокументов = Запрос.Выполнить().Выбрать();
		
КонецПроцедуры

// Процедура формирует сообщения указанным получателям.
// 
// Параметры:
// 	ТаблицаПолучатели - таблица значений.
// 	СтруктураКонтекст - структура.
// 	КэшАдресов - таблицазначений.
// 	РежимыВывода - структура.
// 
Функция СформироватьОповещенияПолучателям(ТаблицаПолучатели, СтруктураКонтекст, КэшАдресов, РежимыВывода, Ошибки)
	
	ОповещенияПолучателям = Новый Массив();
	Если ТаблицаПолучатели = Неопределено Тогда
		Возврат ОповещенияПолучателям; 
	КонецЕсли;
	
	Кроме = Новый Соответствие;
	
	// РЛС.
	ВыборкаДокументовРЛС = Неопределено;
	Если СтруктураКонтекст.Свойство("ВыборкаДокументов")
		И УправлениеДоступом.ОграничиватьДоступНаУровнеЗаписей() Тогда
		
		ОбъектыВыборки = Новый ТаблицаЗначений();
		ОбъектыВыборки.Колонки.Добавить("Период",			ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
		ОбъектыВыборки.Колонки.Добавить("СтатусРегистрации",Новый ОписаниеТипов("ПеречислениеСсылка.бит_фн_СтатусыРегистрацииОповещений"));
		ОбъектыВыборки.Колонки.Добавить("ВидСобытия",		Новый ОписаниеТипов("ПеречислениеСсылка.бит_фн_ВидыСобытийОповещений"));
		ОбъектыВыборки.Колонки.Добавить("Оповещение",		Новый ОписаниеТипов("СправочникСсылка.бит_фн_Оповещения"));
		ОбъектыВыборки.Колонки.Добавить("Объект",			ОбщегоНазначения.ОписаниеТипаВсеСсылки());
		ОбъектыВыборки.Колонки.Добавить("ИД",				Новый ОписаниеТипов("УникальныйИдентификатор"));
		ОбъектыВыборки.Колонки.Добавить("Статус",			Новый ОписаниеТипов("СправочникСсылка.бит_СтатусыОбъектов"));
		ОбъектыВыборки.Колонки.Добавить("Виза",				Новый ОписаниеТипов("СправочникСсылка.бит_Визы"));
		ОбъектыВыборки.Колонки.Добавить("Решение",			Новый ОписаниеТипов("СправочникСсылка.бит_ВидыРешенийСогласования"));
		ОбъектыВыборки.Колонки.Добавить("Пользователь",		Новый ОписаниеТипов("СправочникСсылка.Пользователи"));
		ОбъектыВыборки.Колонки.Добавить("Комментарий",		ОбщегоНазначения.ОписаниеТипаСтрока(100));
		
		ЗапросРЛС = Новый Запрос();
		ЗапросРЛС.Текст =
		"ВЫБРАТЬ
		|	Таблица.Период КАК Период,
		|	Таблица.СтатусРегистрации КАК СтатусРегистрации,
		|	Таблица.ВидСобытия КАК ВидСобытия,
		|	Таблица.Оповещение КАК Оповещение,
		|	Таблица.Объект КАК Объект,
		|	Таблица.ИД КАК ИД,
		|	Таблица.Статус КАК Статус,
		|	Таблица.Виза КАК Виза,
		|	Таблица.Решение КАК Решение,
		|	Таблица.Пользователь КАК Пользователь,
		|	Таблица.Комментарий КАК Комментарий
		|ПОМЕСТИТЬ ВТаблица
		|ИЗ
		|	&Таблица КАК Таблица
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТаблица.Период КАК Период,
		|	ВТаблица.СтатусРегистрации КАК СтатусРегистрации,
		|	ВТаблица.ВидСобытия КАК ВидСобытия,
		|	ВТаблица.Оповещение КАК Оповещение,
		|	ВТаблица.Объект КАК Объект,
		|	ВТаблица.ИД КАК ИД,
		|	ВТаблица.Статус КАК Статус,
		|	ВТаблица.Виза КАК Виза,
		|	ВТаблица.Решение КАК Решение,
		|	ВТаблица.Пользователь КАК Пользователь,
		|	ВТаблица.Комментарий КАК Комментарий
		|ИЗ
		|	ВТаблица КАК ВТаблица";
	КонецЕсли;
	
	// ++ ЕРП
	Если СтруктураКонтекст.Свойство("ТекущийОбъект")
		И ТипЗнч(СтруктураКонтекст.ТекущийОбъект) = Тип("ДокументСсылка.бит_кзн_ЗаявкаНаРасходованиеСредств")
		И (СтруктураКонтекст.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ДоступнаВиза
		ИЛИ СтруктураКонтекст.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ЗаписанДокумент
		ИЛИ СтруктураКонтекст.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ПринятоРешение
		ИЛИ СтруктураКонтекст.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ПроведенДокумент
		ИЛИ СтруктураКонтекст.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.УстановленСтатус) Тогда
		
		Запрос = Новый Запрос();
		Запрос.УстановитьПараметр("ДокументПланирования", СтруктураКонтекст.ТекущийОбъект);
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Таблица.Ссылка КАК Ссылка,
		|	Таблица.СтатьяОборотов КАК СтатьяОборотов,
		|	Таблица.ЦФО КАК ЦФО,
		|	Таблица.СуммаДокумента КАК СуммаДокумента,
		|	Таблица.ВалютаДокумента КАК ВалютаДокумента
		|ИЗ
		|	Документ.бит_кзн_ПлатежнаяПозиция КАК Таблица
		|ГДЕ
		|	Таблица.ДокументПланирования = &ДокументПланирования";

		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Количество() > 0 Тогда
			СтруктураКонтекст.ВыборкаПлатежныхПозиций = Выборка;
		КонецЕсли;
	КонецЕсли;
	// -- ЕРП
	
	Для Каждого СтрокаПолучатели Из ТаблицаПолучатели Цикл
		
		// Для определенных видов событий необходимо преобразовать выборку по пользовательскому условию.
		Если ЗначениеЗаполнено(СтрокаПолучатели.ПользовательскоеУсловие) Тогда
			Если СтруктураКонтекст.Свойство("ВыборкаДокументов") Тогда
				ПодготовитьВыборкуЗаписейДляОтправки(СтруктураКонтекст.ВыборкаДокументов, СтрокаПолучатели.ПользовательскоеУсловие);
				Если СтруктураКонтекст.ВыборкаДокументов.Количество() = 0 Тогда
					Продолжить;
				КонецЕсли;
			Иначе
				флУсловиеВыполнено = бит_УправлениеПроцессами.ПроверитьПользовательскоеУсловие(СтрокаПолучатели.ПользовательскоеУсловие
																					,СтруктураКонтекст);
				Если НЕ флУсловиеВыполнено Тогда
					Продолжить;				
				КонецЕсли; 																	  
			КонецЕсли; 
		КонецЕсли;
		
		ЭтоКроме = ?(СтрокаПолучатели.УсловиеВхождения = "Кроме",Истина,Ложь);
		
		// Получаем текущего пользователя различными способами.
		ТекущийПолучатель = Неопределено;
		Если ТипЗнч(СтрокаПолучатели.Получатель) = Тип("СправочникСсылка.Пользователи") 
			ИЛИ ТипЗнч(СтрокаПолучатели.Получатель) = Тип("СправочникСсылка.Контрагенты")
			ИЛИ ТипЗнч(СтрокаПолучатели.Получатель) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			 
			 Если СтруктураКонтекст.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ДоступнаВиза 
				 И СтрокаПолучатели.Получатель <> СтруктураКонтекст.Пользователь Тогда
				 Продолжить;
			 КонецЕсли;
			 
			 ТекущийПолучатель = СтрокаПолучатели.Получатель;
				 
		ИначеЕсли ТипЗнч(СтрокаПолучатели.Получатель) = Тип("Строка") Тогда
			Если СтруктураКонтекст.Свойство("ТекущийОбъект") Тогда
				Если СтрокаПолучатели.Получатель = "ТекущийОбъект.Ответственный" Тогда
					Если ТипЗнч(СтруктураКонтекст.ТекущийОбъект) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
						СтрокаКод = "СтруктураКонтекст.ТекущийОбъект.бит_Ответственный";
					Иначе
						СтрокаКод = "СтруктураКонтекст." + СтрокаПолучатели.Получатель;
					КонецЕсли;
					ТекущийПолучатель = ВычислитьПолучателя(СтруктураКонтекст, СтрокаКод);
				ИначеЕсли СтрокаПолучатели.Получатель = "ТекущийОбъект.Руководитель" Тогда
					Если ТипЗнч(СтруктураКонтекст.ТекущийОбъект) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
						СтрокаКод = "СтруктураКонтекст.ТекущийОбъект.бит_КураторДоговора";
					Иначе
						СтрокаКод = "СтруктураКонтекст.ТекущийОбъект.КураторДоговора";
					КонецЕсли;
					ТекущийПолучатель = ВычислитьПолучателя(СтруктураКонтекст, СтрокаКод);
				ИначеЕсли СтрокаПолучатели.Получатель = "ТекущийОбъект.РуководительКонтрагента" Тогда
					Если ТипЗнч(СтруктураКонтекст.ТекущийОбъект) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
						СтрокаКод = "СтруктураКонтекст.ТекущийОбъект.бит_КураторДоговораСоСтороныКонтрагента";
					Иначе
						СтрокаКод = "СтруктураКонтекст.ТекущийОбъект.КураторДоговораСоСтороныКонтрагента";
					КонецЕсли;
					ТекущийПолучатель = ВычислитьПолучателя(СтруктураКонтекст, СтрокаКод);
				Иначе
					Если бит_ОбщегоНазначения.ЭтоСемействоБП() 
					И ТипЗнч(СтруктураКонтекст.ТекущийОбъект) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
						СтрокаКод = "СтруктураКонтекст.ТекущийОбъект.Владелец";
					Иначе
							СтрокаКод = "СтруктураКонтекст." + СтрокаПолучатели.Получатель;
					КонецЕсли;	
				
					Если СтруктураКонтекст.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ИзмененоСостояниеЗадачи 
						И СтрокаПолучатели.Получатель = "ТекущийОбъект.Исполнитель" 
						И ЗначениеЗаполнено(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураКонтекст.ТекущийОбъект, "РольИсполнителя")) Тогда
						ТекущийПолучатель = ВычислитьПолучателяИзмененоСостояниеЗадачи(СтруктураКонтекст.ТекущийОбъект);
					Иначе
						ТекущийПолучатель = ВычислитьПолучателя(СтруктураКонтекст, СтрокаКод);
					КонецЕсли;					
				КонецЕсли;					
			Иначе
				СтрокаКод = "СтруктураКонтекст."+СтрокаПолучатели.Получатель;
				ТекущийПолучатель = ВычислитьПолучателя(СтруктураКонтекст,СтрокаКод);
				Если НЕ ЗначениеЗаполнено(ТекущийПолучатель) Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ТипЗнч(СтрокаПолучатели.Получатель) = Тип("СправочникСсылка.бит_ПользовательскиеФункции") Тогда	 

			 ТекущийПолучатель = бит_ОбщегоНазначения.ВыполнитьПользовательскуюФункцию(СтрокаПолучатели.Получатель,СтруктураКонтекст);
			 Если СтруктураКонтекст.ВидСобытия = Перечисления.бит_фн_ВидыСобытийОповещений.ДоступнаВиза 
				 И ТипЗнч(ТекущийПолучатель) = Тип("СправочникСсылка.Пользователи") 
				 И ТекущийПолучатель <> СтруктураКонтекст.Пользователь Тогда
				 Продолжить;
			 КонецЕсли;
			 
		КонецЕсли; 
		
		ТекущийПолучатель = ПреобразоватьВМассив(ТекущийПолучатель);
		
		// Поиск организации для проверки РЛС.
		ОрганизацииОбъектов = Новый Соответствие();
		Если УправлениеДоступом.ОграничиватьДоступНаУровнеЗаписей() Тогда
			Если СтруктураКонтекст.Свойство("ТекущийОбъект")
				И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтруктураКонтекст.ТекущийОбъект, "Организация") Тогда
				
				Организация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураКонтекст.ТекущийОбъект, "Организация");
				ОрганизацииОбъектов.Вставить(СтруктураКонтекст.ТекущийОбъект, Организация);
			ИначеЕсли СтруктураКонтекст.Свойство("ВыборкаДокументов") Тогда	
				СсылкиВыборки = Новый Массив();
				СтруктураКонтекст.ВыборкаДокументов.Сбросить();
				Выборка = СтруктураКонтекст.ВыборкаДокументов;
				Пока Выборка.Следующий() Цикл
					Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Выборка.Объект, "Организация") Тогда
						СсылкиВыборки.Добавить(Выборка.Объект)
					Иначе
						ОрганизацииОбъектов.Вставить(Выборка.Объект, Неопределено);
					КонецЕсли;
				КонецЦикла;
				РеквизитыОбъектов = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(СсылкиВыборки, "Организация");
				Для Каждого ЭлементКоллекции Из РеквизитыОбъектов Цикл
					ОрганизацииОбъектов.Вставить(ЭлементКоллекции.Ключ,  ЭлементКоллекции.Значение.Организация);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		
		// Проверим пользователя, на вхождение в перечень исключаемых
		// добавим в результирующий массив получателей.
		Для Каждого Элемент Из ТекущийПолучатель Цикл
			
			ДобавитьПользователя = ПроверитьВозможностьДобавленияПолучателя(Кроме,ЭтоКроме,Элемент);
			Если ДобавитьПользователя Тогда
				
				// Проверка на РЛС, по организации.
				Если ТипЗнч(Элемент) = Тип("СправочникСсылка.Пользователи")
					И НЕ Пользователи.ЭтоПолноправныйПользователь(Элемент,, Ложь)
					И УправлениеДоступом.ОграничиватьДоступНаУровнеЗаписей()
					И ОрганизацииОбъектов.Количество() > 0 Тогда
					
					Если СтруктураКонтекст.Свойство("ТекущийОбъект") Тогда
						
						Организация = ОрганизацииОбъектов[СтруктураКонтекст.ТекущийОбъект];
						Если ЗначениеЗаполнено(Организация) Тогда
							ДоступныеОрганизации = УправлениеДоступомБП.ОрганизацииДанныеКоторыхДоступныПользователю(
								ОбщегоНазначения.ИмяТаблицыПоСсылке(СтруктураКонтекст.ТекущийОбъект), Ложь, Элемент);
							Если ДоступныеОрганизации.Найти(Организация) = Неопределено Тогда
								Продолжить;
							КонецЕсли;
						КонецЕсли;
					ИначеЕсли СтруктураКонтекст.Свойство("ВыборкаДокументов") Тогда
						
						СтруктураКонтекст.ВыборкаДокументов.Сбросить();
						Выборка = СтруктураКонтекст.ВыборкаДокументов;
						Пока Выборка.Следующий() Цикл
							Организация = ОрганизацииОбъектов[Выборка.Объект];
							Если ЗначениеЗаполнено(Организация) Тогда
								ДоступныеОрганизации = УправлениеДоступомБП.ОрганизацииДанныеКоторыхДоступныПользователю(
									ОбщегоНазначения.ИмяТаблицыПоСсылке(Выборка.Объект), Ложь, Элемент);
								
								Если ДоступныеОрганизации.Найти(Организация) <> Неопределено Тогда
									НоваяСтрока	= ОбъектыВыборки.Добавить();
									ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
								КонецЕсли
							Иначе
								НоваяСтрока	= ОбъектыВыборки.Добавить();
								ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
							КонецЕсли;
						КонецЦикла;
						
						Если ОбъектыВыборки.Количество() = 0 Тогда
							Продолжить
						КонецЕсли;
						ЗапросРЛС.УстановитьПараметр("Таблица", ОбъектыВыборки);
						ВыборкаДокументовРЛС = ЗапросРЛС.Выполнить().Выбрать();
						ОбъектыВыборки.Очистить();
					КонецЕсли;
				КонецЕсли;
				
				СтруктураКонтекст.Получатель = Элемент;
				
				Если СтруктураКонтекст.Свойство("ВыборкаДокументов") Тогда
					СтруктураКонтекст.ВыборкаДокументов.Сбросить();
				КонецЕсли;
				
				ПараметрыОповещения = ЗаполнитьОповещение(СтрокаПолучатели.ШаблонСообщения, СтрокаПолучатели.НастройкаДоставки,
					СтруктураКонтекст, СтрокаПолучатели.СоздаватьОбсуждение, ВыборкаДокументовРЛС, РежимыВывода.ВыводитьОшибки);
				
				ТочкиДоставки = ПодготовитьТочкиДоставки(СтрокаПолучатели.ВидКонтактнойИнформации, 
					СтрокаПолучатели.ШаблонСообщения, СтрокаПолучатели.НастройкаДоставки, СтруктураКонтекст,КэшАдресов,
					РежимыВывода.ВыводитьОшибки,Ошибки); 
				
					Для Каждого ТочкаДоставки Из ТочкиДоставки Цикл
						СпособТранспорта = бит_ОповещенияКлиентСервер.ОпределитьСпособТранспорта(ТочкаДоставки.АдресПолучателя);
						ТекущиеПараметрыОповещения = Новый Структура;
						ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ТекущиеПараметрыОповещения, ПараметрыОповещения);
						ТекущиеПараметрыОповещения.АдресПолучателя	= ТочкаДоставки.АдресПолучателя;
						ТекущиеПараметрыОповещения.СпособТранспорта	= СпособТранспорта;
						ТекущиеПараметрыОповещения.Бейджи			= ТочкаДоставки.КоличествоБейджей;
						ТекущиеПараметрыОповещения.ИД				= Строка(Новый УникальныйИдентификатор);
						ОповещенияПолучателям.Добавить(ТекущиеПараметрыОповещения);
					КонецЦикла; 					
			КонецЕсли; 
		КонецЦикла;
		
	КонецЦикла; // По строкам таблицы получателей.
	
	Возврат ОповещенияПолучателям;
	
КонецФункции
 
// Процедура отмечает обработанные записи регистра.
// 
// Параметры:
// 	Выборка - ВыборкаИзРезультатаЗапроса.
// 	РежимыВывода - структура.
// 
Процедура ОтметитьОбработанныеОповещения(Выборка, РежимыВывода, Ошибки)
	
	МенеджерЗаписи = РегистрыСведений.бит_фн_РегистрацияСобытийОповещений.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи,Выборка);
	Попытка
		
		МенеджерЗаписи.Удалить();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи,Выборка);			
		Если Ошибки.Количество() = 0 Тогда
			МенеджерЗаписи.СтатусРегистрации = Перечисления.бит_фн_СтатусыРегистрацииОповещений.Обработано;
		Иначе	
			МенеджерЗаписи.СтатусРегистрации = Перечисления.бит_фн_СтатусыРегистрацииОповещений.ОшибкаОтправки;
			МенеджерЗаписи.ПротоколОбработки = СтрСоединить(Ошибки,";");
			МенеджерЗаписи.ДатаОбработки     = ТекущаяДатаСеанса();
		КонецЕсли; 
		МенеджерЗаписи.Записать();

	Исключение
		
		Если РежимыВывода.ВыводитьОшибки Тогда			
			ТекстСообщения = НСтр("ru='Не удалось изменить статус записи о регистрации.';
								  |en='Unable to change the status of the record of the registration.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);			
		КонецЕсли; 
		
	КонецПопытки;
	
КонецПроцедуры

// Функция проверяет возможность формирования сообщения данному получателю.
// 
// Параметры:
//  Кроме             - Соответствие - Хранит перечень исключаемых получателей.
//  ЭтоКроме          - Булево.
//  ТекущийПолучатель - СправочникСсылка.Пользователи.
// 
// Возвращаемое значение:
//   Результат   - Добавлять получателя или нет.
// 
Функция ПроверитьВозможностьДобавленияПолучателя(Кроме,ЭтоКроме,ТекущийПолучатель)

	Результат = Ложь;
	Если ЭтоКроме Тогда
		Если Кроме[ТекущийПолучатель] = Неопределено Тогда
			Кроме.Вставить(ТекущийПолучатель,Истина);
		КонецЕсли; 
	Иначе
		Если Кроме[ТекущийПолучатель] = Неопределено Тогда
			Результат = Истина;
		КонецЕсли; 
	КонецЕсли; 

	Возврат Результат;
	
КонецФункции // ПроверитьВозможностьДобавления()

Функция ВычислитьПолучателяИзмененоСостояниеЗадачи(ОбъектЗадача)
	
	СтруктураПараметров = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ОбъектЗадача, "РольИсполнителя,ОбъектАдресации_1,ОбъектАдресации_2,ОбъектАдресации_3");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	бит_ИсполнителиЗадач.Исполнитель КАК Исполнитель
	|ИЗ
	|	РегистрСведений.бит_ИсполнителиЗадач КАК бит_ИсполнителиЗадач
	|ГДЕ
	|	бит_ИсполнителиЗадач.РольИсполнителя = &РольИсполнителя
	|	И бит_ИсполнителиЗадач.ОбъектАдресации_1 = &ОбъектАдресации_1
	|	И бит_ИсполнителиЗадач.ОбъектАдресации_2 = &ОбъектАдресации_2
	|	И бит_ИсполнителиЗадач.ОбъектАдресации_3 = &ОбъектАдресации_3";
	
	Запрос.УстановитьПараметр("ОбъектАдресации_1", СтруктураПараметров.ОбъектАдресации_1);
	Запрос.УстановитьПараметр("ОбъектАдресации_2", СтруктураПараметров.ОбъектАдресации_2);
	Запрос.УстановитьПараметр("ОбъектАдресации_3", СтруктураПараметров.ОбъектАдресации_3);
	Запрос.УстановитьПараметр("РольИсполнителя",   СтруктураПараметров.РольИсполнителя);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	ПользователиМассив = Новый Массив;
	Пока Выборка.Следующий() Цикл
		ПользователиМассив.Добавить(Выборка.Исполнитель);
	КонецЦикла;
	
	Возврат ПользователиМассив;
	
КонецФункции

// Функция вычисляет получателя по переданному выражению.
// 
// Параметры:
//  СтруктураКонтекст  - Структура.
//  СтрокаКод          - Строка.
// 
// Возвращаемое значение:
//   ТекущийПользователь   - СправочникСсылка.Пользователи.
// 
Функция ВычислитьПолучателя(СтруктураКонтекст,СтрокаКод)
	
	Попытка
		// АПК:488-выкл проектное решение.
		ТекущийПолучатель = Вычислить(СтрокаКод);
		// АПК:488-вкл
	Исключение
		ТекущийПолучатель = Неопределено;
	КонецПопытки;

	Возврат ТекущийПолучатель;
	
КонецФункции // ВычислитьПолучателя()

// Функция формирует структуру в контексте которой происходит выполнение кода при формировании сообщений.
// 
// Параметры:
//  Выборка  - ВыборкаИзРезультатаЗапроса.
// 
// Возвращаемое значение:
//   Контекст   - Структура.
// 
Функция Контекст(Выборка)
	
	Контекст = Новый Структура;
	Контекст.Вставить("Период",			Выборка.Период);
	Контекст.Вставить("ВидСобытия",		Выборка.ВидСобытия);	
	Контекст.Вставить("Оповещение",		Выборка.Оповещение);
	Контекст.Вставить("ТекущийОбъект",	Выборка.Объект);
	Контекст.Вставить("Статус",			Выборка.Статус);
	Контекст.Вставить("Виза",			Выборка.Виза);
	Контекст.Вставить("Решение",		Выборка.Решение);
	Контекст.Вставить("Комментарий",	Выборка.Комментарий);	
	Контекст.Вставить("Пользователь",	Выборка.Пользователь);
	Контекст.Вставить("Получатель",		Справочники.Пользователи.ПустаяСсылка());
	// ++ ЕРП
	Контекст.Вставить("СуммаЗаявки",				Выборка.СуммаЗаявки);
	Контекст.Вставить("ВыборкаПлатежныхПозиций",	Неопределено);
	// -- ЕРП
	
	Возврат Контекст;
	
КонецФункции // СформироватьСтруктуруКонтекст()
 
Функция ЗаполнитьОповещение(ШаблонСообщения, НастройкаДоставки, Знач СтруктураКонтекст, СоздаватьОбсуждение, ВыборкаДокументовРЛС, ВыводитьСообщения)
	
	Если ВыборкаДокументовРЛС <> Неопределено Тогда
		СтруктураКонтекст.ВыборкаДокументов = ВыборкаДокументовРЛС;
	КонецЕсли;
	
	ПараметрыОповещения = НовыеПараметрыОповещения();
	ПараметрыОповещения.Статус            = Перечисления.бит_фн_СтатусыОтправкиОповещений.ГотовоКОтправке;
	ПараметрыОповещения.Пользователь      = СтруктураКонтекст.Получатель;
	ПараметрыОповещения.НастройкаДоставки = НастройкаДоставки;
	ПараметрыОповещения.ИД                = Строка(Новый УникальныйИдентификатор);
	ПараметрыОповещения.ДатаРегистрации   = ТекущаяДатаСеанса();
	
	// Обработаем старый формат сообщенияю.
	СтруктураСообщения = бит_ОповещенияСервер.СформироватьСообщениеПоШаблону(ШаблонСообщения,СтруктураКонтекст);
	
	// Обработаем новый формат сообщения.
	СтруктураСообщения.Заголовок= бит_СтрокиСервер.ОбработатьТекстШаблона(СтруктураСообщения.Заголовок, СтруктураКонтекст);
	ПараметрыШаблона = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ШаблонСообщения, "ТипТекстаСообщения, РучноеРедактирование");
	Если СтрСравнить(ПараметрыШаблона.ТипТекстаСообщения, "HTML") = 0 И НЕ ПараметрыШаблона.РучноеРедактирование Тогда
		СтруктураСообщения.Текст = СтрЗаменить(СтруктураСообщения.Текст, """", "'");
		СтруктураСообщения.Текст = СтрЗаменить(СтруктураСообщения.Текст, "&quot;", """");
	КонецЕсли;
	СтруктураСообщения.Текст	= бит_СтрокиСервер.ОбработатьТекстШаблона(СтруктураСообщения.Текст, СтруктураКонтекст);
	СтруктураСообщения.Подпись	= бит_СтрокиСервер.ОбработатьТекстШаблона(СтруктураСообщения.Подпись, СтруктураКонтекст);
	
	ПараметрыОповещения.Сообщение_Заголовок = СтруктураСообщения.Заголовок;
	ПараметрыОповещения.Сообщение_Текст     = СтруктураСообщения.Текст;
	ПараметрыОповещения.Сообщение_Подпись   = СтруктураСообщения.Подпись;

	СсылкиВТексте = Новый Соответствие();
	Если СтруктураКонтекст.Свойство("ТекущийОбъект") Тогда
		НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(СтруктураКонтекст.ТекущийОбъект);
		СсылкиВТексте.Вставить(НавигационнаяСсылка, Строка(СтруктураКонтекст.ТекущийОбъект));
	ИначеЕсли СтруктураКонтекст.Свойство("ВыборкаДокументов") Тогда
		СтруктураКонтекст.ВыборкаДокументов.Сбросить();
		Выборка = СтруктураКонтекст.ВыборкаДокументов;
		Пока Выборка.Следующий() Цикл
			НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(Выборка.Объект);
			СсылкиВТексте.Вставить(НавигационнаяСсылка, Строка(Выборка.Объект));
		КонецЦикла;
	КонецЕсли;
	ПараметрыОповещения.СсылкиВТекстеСообщения = Новый ХранилищеЗначения(СсылкиВТексте);
	ПараметрыОповещения.Оповещение = СтруктураКонтекст.Оповещение;
	
	ПараметрыОповещения.ТипТекстаСообщения = ПараметрыШаблона.ТипТекстаСообщения;

	ПараметрыОповещения.СоздаватьОбсуждение    = СоздаватьОбсуждение;
	ПараметрыОповещения.ДополнительныеСвойства = СтруктураКонтекст;
	
	Возврат ПараметрыОповещения;
	
КонецФункции

Функция ЗаписатьОповещение(Параметры, ВыводитьСообщения)

	МенеджерЗаписи = РегистрыСведений.бит_фн_Оповещения.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Параметры);
	Попытка
		МенеджерЗаписи.Записать();
	Исключение
		Если ВыводитьСообщения Тогда
			ТекстСообщения = НСтр("ru = 'Не удалось записать оповещение с Идентификатором ""%1"".
                                        |По причине: %2';
								  |en = 'Failed to record alert with ID ""%1"".
                                   		|Because of: %2'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, МенеджерЗаписи.ИД, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		КонецЕсли; 
	КонецПопытки;
	
КонецФункции

