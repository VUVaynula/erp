Функция РезультаСформированияДокументов(ДанныеОбработки) Экспорт
    
    РеквизитыДокумента  = Метаданные.Документы.бит_ФормаВводаБюджета.Реквизиты;
    
    ТекущийПользователь 		  = Пользователи.ТекущийПользователь();	
	ДанныеДляЗаполненияДокументов = ДанныеОбработки.ДанныеДляЗаполненияДокументов;
	НастройкаИмениФайла 		  = ДанныеОбработки.НастройкаИмениФайла;
	
	ИменаКолонок = Новый Массив;
	Для каждого Колонка Из ДанныеДляЗаполненияДокументов.Колонки Цикл
		ИмяКолонки = Колонка.Имя;
		Если Лев(ИмяКолонки, 4) = "Док_" ИЛИ РеквизитыДокумента.Найти(ИмяКолонки) = Неопределено Тогда
			Продолжить;            
		КонецЕсли;	
		ИменаКолонок.Добавить(ИмяКолонки);
	КонецЦикла;
	
	Для каждого СтрокаТаблицы Из ДанныеДляЗаполненияДокументов Цикл
        
        Если НЕ СтрокаТаблицы.Выбрать ИЛИ ЗначениеЗаполнено(СтрокаТаблицы.Док_ФормаВводаБюджета) Тогда
            Продолжить;       
        КонецЕсли;
        
        // Создание документа.
        ДокументОбъект = Документы.бит_ФормаВводаБюджета.СоздатьДокумент();
        
        ДанныеЗаполнения = Новый Структура;
		
		ДанныеЗаполнения.Вставить("ДатаНачалаПланирования",    ДанныеОбработки.ПериодПланирования.ДатаНачала);
        ДанныеЗаполнения.Вставить("ДатаОкончанияПланирования", ДанныеОбработки.ПериодПланирования.ДатаОкончания);
        
        Для каждого ИмяКолонки Из ИменаКолонок Цикл            
			Значение = Неопределено;
			ДанныеОбработки.Свойство(ИмяКолонки, Значение);
			Если НЕ ЗначениеЗаполнено(СтрокаТаблицы[ИмяКолонки]) И ЗначениеЗаполнено(Значение) Тогда
                 // Если в тч реквизит не заполнен, то берем из шапки.
            	 ДанныеЗаполнения.Вставить(ИмяКолонки, ДанныеОбработки[ИмяКолонки]);           
            Иначе
                 ДанныеЗаполнения.Вставить(ИмяКолонки, СтрокаТаблицы[ИмяКолонки]);
            КонецЕсли;         	
        КонецЦикла;
        
        Если НЕ ЗначениеЗаполнено(ДанныеЗаполнения.Ответственный) Тогда
            ДанныеЗаполнения.Вставить("Ответственный", ТекущийПользователь);
        КонецЕсли;
        
        // Заполнение документа через экспортную процедуру модуля документа.
        ДокументОбъект.ЗаполнитьДокумент(ДанныеЗаполнения);
        ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);

		СтрокаТаблицы.Док_ФормаВводаБюджета = ДокументОбъект.Ссылка;
		НастройкиФормы = Справочники.бит_НастройкиФормВводаБюджета.ПодготовитьНастройки(СтрокаТаблицы.НастройкаФормы);// ++ NB посмотреть 
		СтрокаТаблицы.Док_КоличествоРазворачивать = НастройкиФормы.КоличествоРазворачивать; 
		СтрокаТаблицы.Док_ИдКартинки              = 0;
		СтрокаТаблицы.Док_ИмяФайла                = ИмяФайлаПоНастройкам(ДокументОбъект, НастройкаИмениФайла);			 
    КонецЦикла;
	
	Возврат ДанныеДляЗаполненияДокументов;

КонецФункции

Функция ИмяФайлаПоНастройкам(ТекДокумент, НастройкаИмениФайла) Экспорт

    ИмяФайла = "";
    
    МассивСтрок = Новый Массив;
    Для каждого ЭлСп Из НастройкаИмениФайла Цикл
        Если ЭлСп.Значение = "ПроизвольныйТекст" Тогда
            МассивСтрок.Добавить(ЭлСп.Представление);
        ИначеЕсли ЭлСп.Значение = "НомерДокумента" Тогда
            МассивСтрок.Добавить(СокрЛП(ТекДокумент.Номер));       
        Иначе 
            МетаРек = Метаданные.Документы.бит_ФормаВводаБюджета.Реквизиты.Найти(ЭлСп.Значение);
            Если МетаРек <> Неопределено Тогда
                ЗначениеРеквизита = ТекДокумент[ЭлСп.Значение];
                Если ЗначениеЗаполнено(ЗначениеРеквизита) Тогда
                    МассивСтрок.Добавить(ЗначениеРеквизита.Наименование);       
                КонецЕсли;
            КонецЕсли;
        КонецЕсли;
    КонецЦикла; 
    ИмяФайла = СтрСоединить(МассивСтрок, " - ");
                
    // Удаление недопустимых символов.
    ИмяФайла = СтрЗаменить(ИмяФайла, "\" , "");
    ИмяФайла = СтрЗаменить(ИмяФайла, "/" , "");
    ИмяФайла = СтрЗаменить(ИмяФайла, ":" , "");
    ИмяФайла = СтрЗаменить(ИмяФайла, "*" , "");
    ИмяФайла = СтрЗаменить(ИмяФайла, "?" , "");
    ИмяФайла = СтрЗаменить(ИмяФайла, """", "");
    ИмяФайла = СтрЗаменить(ИмяФайла, "<" , "");
    ИмяФайла = СтрЗаменить(ИмяФайла, ">" , "");
    ИмяФайла = СтрЗаменить(ИмяФайла, "|" , "");
       
    Возврат ИмяФайла;
	
КонецФункции

Функция НовыеДанныеОбработки() Экспорт

	ДанныеОбработки = Новый Структура;
	ДанныеОбработки.Вставить("Сценарий");
	ДанныеОбработки.Вставить("ВалютаДокумента");
	ДанныеОбработки.Вставить("КурсДокумента",	   1);
	ДанныеОбработки.Вставить("КратностьДокумента", 1);
	ДанныеОбработки.Вставить("РежимЗависимыхОборотов");
	ДанныеОбработки.Вставить("РежимФормированияДвижений");
	ДанныеОбработки.Вставить("ЕдиницаИзмеренияСумм");
	
	ДанныеОбработки.Вставить("ПериодПланирования", 			  Новый СтандартныйПериод);
	ДанныеОбработки.Вставить("ДанныеДляЗаполненияДокументов", Новый ТаблицаЗначений);
	ДанныеОбработки.Вставить("НастройкаИмениФайла", 		  Новый СписокЗначений);
	
	Возврат ДанныеОбработки; 
	
КонецФункции

