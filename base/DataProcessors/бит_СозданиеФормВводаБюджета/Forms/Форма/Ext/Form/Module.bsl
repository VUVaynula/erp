&НаСервере
Процедура ОбработатьИзменениеФормыВводаБюджета(Идентификатор)
     
    ТекущиеДанные = Объект.ФормыВводаБюджета.НайтиПоИдентификатору(Идентификатор);
	
	РеквизитыТаблицы    = Метаданные.Обработки.бит_СозданиеФормВводаБюджета.ТабличныеЧасти.ФормыВводаБюджета.Реквизиты;
	МетаданныеДокумента = Метаданные.Документы.бит_ФормаВводаБюджета.Реквизиты;
	
	ИменаРеквизитов = Новый Массив;
	Для каждого РеквизитТаблицы Из РеквизитыТаблицы Цикл
		ИмяРеквизита = РеквизитТаблицы.Имя;
		Если Лев(ИмяРеквизита, 4) = "Док_" ИЛИ МетаданныеДокумента.Найти(ИмяРеквизита) = Неопределено Тогда
			Продолжить;            
		КонецЕсли;
		
		ТекущиеДанные[ИмяРеквизита] = ТекущиеДанные.Док_ФормаВводаБюджета[ИмяРеквизита];  
		ИменаРеквизитов.Добавить(ИмяРеквизита);
	КонецЦикла;
	
	РеквизитыДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТекущиеДанные.Док_ФормаВводаБюджета, 
							СтрСоединить(ИменаРеквизитов, ","));
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, РеквизитыДокумента);
	
	Если ЗначениеЗаполнено(ТекущиеДанные.НастройкаФормы) Тогда
		
		ИзмеренияНастройки = Справочники.бит_НастройкиФормВводаБюджета.ПодготовитьНастройки(ТекущиеДанные.НастройкаФормы);
		Для каждого КлючЗначение Из ИзмеренияНастройки.Измерения Цикл
			
			ТекОписание = КлючЗначение.Значение;
			Если ТекОписание.СпособЗаполнения <> Перечисления.бит_СпособыЗаполненияИзмеренийВФормахВвода.Разворачивать 
				И ЗначениеЗаполнено(ТекОписание.ЗначениеПоУмолчанию) Тогда
				
				ТекущиеДанные[ТекОписание.Имя] = ТекОписание.ЗначениеПоУмолчанию;
			КонецЕсли; 
		КонецЦикла; // СтрНастройкиФормы.
		НастройкиФормы = Справочники.бит_НастройкиФормВводаБюджета.ПодготовитьНастройки(ТекущиеДанные.НастройкаФормы);
		ТекущиеДанные.Док_КоличествоРазворачивать = НастройкиФормы.КоличествоРазворачивать;
	КонецЕсли; // НастройкаФормы.
	
	ТекущиеДанные.Док_ИмяФайла   = ПолучитьИмяФайла(ТекущиеДанные.Док_ФормаВводаБюджета, НастройкаИмени);
	ТекущиеДанные.Док_ИдКартинки = 0;
                   
КонецПроцедуры

&НаСервере
Процедура ПодготовитьФормуНаСервере()

    НастройкиИзмерений = Новый Структура;
    НастройкиИзмерений.Вставить("ИзмеренияДоп"      , бит_Бюджетирование.ПолучитьИзмеренияБюджетирования("Дополнительные","Синоним"));
	НастройкиИзмерений.Вставить("НастройкиИзмерений", бит_Бюджетирование.НастройкиИзмеренийБюджетирования()); 
	
	НастройкаПоУмолчанию = бит_ОтчетыСервер.НайтиНастройкуПоУмолчаниюДляОбъекта(НастраиваемыйОбъект());
	ПрименитьНастройки(НастройкаПоУмолчанию);

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПересчитатьКурсВалюты(Сценарий, ВалютаДокумента, КурсДокумента, КратностьДокумента, ДатаНачалаПланирования)
    
    Если НЕ ЗначениеЗаполнено(Сценарий) И НЕ ЗначениеЗаполнено(ВалютаДокумента) Тогда
        Возврат;   
    КонецЕсли;
	
	Если ЗначениеЗаполнено(Сценарий)
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сценарий, "ИспользоватьКурсыСценария") Тогда
		ДатаКурса = ДатаНачалаПланирования;
	Иначе
		ДатаКурса = ТекущаяДатаСеанса();
	КонецЕсли;
	
    СтрКурса = бит_Бюджетирование.ПолучитьКурсПоСценарию(Сценарий, ВалютаДокумента, ДатаКурса);
	КурсДокумента      = СтрКурса.Курс;
	КратностьДокумента = СтрКурса.Кратность;
    
КонецПроцедуры

