&НаСервере
Функция НовыеСохраняемыеНастройки()

	СохраняемыеНастройки = Новый Структура;
	СохраняемыеНастройки.Вставить("ПериодПланирования", 	   Новый СтандартныйПериод(ВариантСтандартногоПериода.СледующийГод));
	СохраняемыеНастройки.Вставить("ВалютаДокумента",		   Константы.ВалютаРегламентированногоУчета.Получить());
	СохраняемыеНастройки.Вставить("КурсДокумента", 			   1);
	СохраняемыеНастройки.Вставить("КратностьДокумента", 	   1);
	СохраняемыеНастройки.Вставить("Сценарий");
	СохраняемыеНастройки.Вставить("РежимЗависимыхОборотов",    Перечисления.бит_РежимыЗависимыхОборотов.Автоматический);
	СохраняемыеНастройки.Вставить("РежимФормированияДвижений", Перечисления.бит_РежимыФормированияДвиженийФормыВвода.Все);
	СохраняемыеНастройки.Вставить("ЕдиницаИзмеренияСумм", 	   Перечисления.бит_ЕдиницыИзмеренияСумм.Единицы);
	СохраняемыеНастройки.Вставить("ПутьКПапке", 			   "");
	
	СохраняемыеНастройки.Вставить("СохранятьДанныеОСозданныхДокументах", Истина);
	СохраняемыеНастройки.Вставить("СохранятьТаблицуЗагрузки", 			 Истина);
	СохраняемыеНастройки.Вставить("НастройкаИмени", 			 		 НовыеНастройкиИмениФайла());
	СохраняемыеНастройки.Вставить("Расширение", 			 		 	 ".xlsx");
	
	СохраняемыеНастройки.Вставить("ТаблицаФВБ", Новый ХранилищеЗначения(Новый ТаблицаЗначений));
	СохраняемыеНастройки.Вставить("ТаблицаЗД",  Новый ХранилищеЗначения(Новый ТаблицаЗначений));
	
	Возврат СохраняемыеНастройки;
	
КонецФункции

&НаСервере
Функция СохраняемыеНастройки()

    СохраняемыеНастройки = НовыеСохраняемыеНастройки();
	ЗаполнитьЗначенияСвойств(СохраняемыеНастройки, Объект);
	ЗаполнитьЗначенияСвойств(СохраняемыеНастройки, ЭтотОбъект);
    
    // Табличная часть "ФормыВводаБюджета".
	ИменаКолонок = Новый Массив;
    Для каждого РеквизитТаблицы Из Метаданные.Обработки.бит_СозданиеФормВводаБюджета.ТабличныеЧасти.ФормыВводаБюджета.Реквизиты Цикл
        Если СохранятьДанныеОСозданныхДокументах ИЛИ Лев(РеквизитТаблицы.Имя, 4) <> "Док_" Тогда
			ИменаКолонок.Добавить(РеквизитТаблицы.Имя);
        КонецЕсли;        
	КонецЦикла;   
	
    ТаблицаФВБ = Объект.ФормыВводаБюджета.Выгрузить(, СтрСоединить(ИменаКолонок, ","));
    СохраняемыеНастройки.ТаблицаФВБ = Новый ХранилищеЗначения(ТаблицаФВБ, Новый СжатиеДанных(9));
	
	// Табличная часть "ЗагруженныеДанные".
    Если СохранятьТаблицуЗагрузки Тогда 
        ИменаКолонок = Новый Массив;
        Для каждого РеквизитТаблицы Из Метаданные.Обработки.бит_СозданиеФормВводаБюджета.ТабличныеЧасти.ЗагруженныеДанные.Реквизиты Цикл
            ИменаКолонок.Добавить(РеквизитТаблицы.Имя);                  
		КонецЦикла;
		
        ТаблицаЗД = Объект.ЗагруженныеДанные.Выгрузить(, СтрСоединить(ИменаКолонок, ","));
        СохраняемыеНастройки.ТаблицаЗД = Новый ХранилищеЗначения(ТаблицаЗД, Новый СжатиеДанных(9));
    КонецЕсли;
       		
	Возврат СохраняемыеНастройки;
	
КонецФункции

&НаСервере
Процедура ПрименитьНастройки(НастройкаОбработки)

	ШаблонНастроек = НовыеСохраняемыеНастройки();
	Если ЗначениеЗаполнено(НастройкаОбработки) Тогда
		
		РеквизитыНастройки 	 = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(НастройкаОбработки, "ХранилищеНастроек");
		СохраненныеНастройки = РеквизитыНастройки.ХранилищеНастроек.Получить();
		Если ТипЗнч(СохраненныеНастройки) = Тип("Структура") Тогда
			ЗаполнитьЗначенияСвойств(ШаблонНастроек, СохраненныеНастройки);
		КонецЕсли; 
	КонецЕсли;	
	
	ЗаполнитьЗначенияСвойств(Объект, ШаблонНастроек);
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ШаблонНастроек);
	
	Если НЕ ЗначениеЗаполнено(НастройкаИмени) Тогда
        НастройкаИмени = НовыеНастройкиИмениФайла();
    КонецЕсли;

	Объект.ФормыВводаБюджета.Загрузить(ШаблонНастроек.ТаблицаФВБ.Получить());
	Объект.ЗагруженныеДанные.Загрузить(ШаблонНастроек.ТаблицаЗД.Получить());
	
	бит_ОбщегоНазначения.УдалитьБитыеСсылкиИзТабличнойЧасти(Объект.ФормыВводаБюджета, "Док_ФормаВводаБюджета");
	бит_ОбщегоНазначения.УдалитьБитыеСсылкиИзТабличнойЧасти(Объект.ЗагруженныеДанные, "Док_ФормаВводаБюджета");		
	
	УстановитьЗаголовок(НастройкаОбработки, ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Функция НовыеНастройкиИмениФайла()

    НовыеНастройки = Новый СписокЗначений;

	НовыеНастройки.Добавить("ПроизвольныйТекст", НСтр("ru = 'ФВБ';en='FIB'"), Истина);
    НовыеНастройки.Добавить("НомерДокумента", 	 НСтр("ru='Номер документа';en='Document No.'"));
    НовыеНастройки.Добавить("НастройкаФормы", 	 НСтр("ru='Настройка формы';en='Form Setup'"));
    НовыеНастройки.Добавить("ЦФО", 				 НСтр("ru='ЦФО';en='FRC'"));
    НовыеНастройки.Добавить("Сценарий", 		 НСтр("ru='Сценарий';en='Scenario'"));
	
	Возврат НовыеНастройки;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗаголовок(Настройка, Форма)

	Заголовок = НСтр("ru = 'Пакетное создание форм ввода бюджета %1'; en = 'Batch Creation of Budget Input Forms %1'");
	
	Если ЗначениеЗаполнено(Настройка) Тогда
		Заголовок = СтрШаблон(Заголовок, "(" + Строка(Настройка) + ")");
	Иначе	
		Заголовок = СтрШаблон(Заголовок, "");
	КонецЕсли;

	Форма.Заголовок = Заголовок;

КонецПроцедуры

&НаСервере
Процедура ФормыВводаБюджетаНастройкаФормыПриИзмененииНаСервере(Ид)
     
    ТекущиеДанные = Объект.ФормыВводаБюджета.НайтиПоИдентификатору(Ид);
    
    Если ЗначениеЗаполнено(ТекущиеДанные.НастройкаФормы) Тогда
            
        СтрНастройкиФормы = Справочники.бит_НастройкиФормВводаБюджета.ПодготовитьНастройки(ТекущиеДанные.НастройкаФормы);
        Для каждого КиЗ Из СтрНастройкиФормы.Измерения Цикл
            
            ТекОписание = КиЗ.Значение;
            Если ТекОписание.СпособЗаполнения <> Перечисления.бит_СпособыЗаполненияИзмеренийВФормахВвода.Разворачивать 
                И ЗначениеЗаполнено(ТекОписание.ЗначениеПоУмолчанию) Тогда
                
                ТекущиеДанные[ТекОписание.Имя] = ТекОписание.ЗначениеПоУмолчанию;
            КонецЕсли; 
        КонецЦикла; // СтрНастройкиФормы.
    КонецЕсли; // НастройкаФормы.  
                   
КонецПроцедуры

&НаСервере
Процедура УдалитьФормыВводаБюджетаНаСервере()

	ОтборПоДокументам = Новый Массив;
    Для каждого СтрокаТаблицы Из Объект.ФормыВводаБюджета Цикл
        Если НЕ СтрокаТаблицы.Выбрать ИЛИ НЕ ЗначениеЗаполнено(СтрокаТаблицы.Док_ФормаВводаБюджета) Тогда
            Продолжить;       
        КонецЕсли;
        ОтборПоДокументам.Добавить(СтрокаТаблицы.Док_ФормаВводаБюджета);
    КонецЦикла;
    
    Если НЕ ЗначениеЗаполнено(ОтборПоДокументам) Тогда
        Возврат;   
    КонецЕсли;
    
    // Удаление задач.
    Запрос = Новый Запрос;
    Запрос.УстановитьПараметр("ОтборПоДокументам", ОтборПоДокументам);
    Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Задачи.Ссылка КАК Ссылка,
	|	Задачи.Предмет КАК Предмет
	|ИЗ
	|	Задача.бит_Задача КАК Задачи
	|ГДЕ
	|	Задачи.Предмет В(&ОтборПоДокументам)
	|	И НЕ Задачи.ПометкаУдаления";
	
	Результат 		= Запрос.Выполнить();    
    ЗадачиКУдалению = Результат.Выгрузить();
	    
    // Удаление документов.
    Для каждого СтрокаТаблицы Из Объект.ФормыВводаБюджета Цикл
		
		Если НЕ СтрокаТаблицы.Выбрать ИЛИ НЕ ЗначениеЗаполнено(СтрокаТаблицы.Док_ФормаВводаБюджета) Тогда
            Продолжить;       
        КонецЕсли;
		
		НачатьТранзакцию();
		Попытка
			// Пометка объектов на удаление.
			ПометитьНаУдалениеДокумент(СтрокаТаблицы);
			ПометитьНаУдалениеЗадачу(СтрокаТаблицы, ЗадачиКУдалению);
			// Обновление строки в обработке.
			СтрокаТаблицы.Док_ФормаВводаБюджета    = Документы.бит_ФормаВводаБюджета.ПустаяСсылка();
			СтрокаТаблицы.Док_ИмяФайла   		   = "";
			СтрокаТаблицы.Док_ИдКартинки 		   = 2;
			СтрокаТаблицы.Док_ВыгруженШаблонВExcel = Ложь;
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ТекстСообщения = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			ШаблонПоля 	   = "ФормыВводаБюджета[%1].Док_ФормаВводаБюджета";
			Поле 	  	   = СтрШаблон(ШаблонПоля, Формат(СтрокаТаблицы.НомерСтроки - 1, "ЧГ="));			
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,, Поле, "Объект");
		КонецПопытки;        
    КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ПометитьНаУдалениеДокумент(СтрокаТаблицы)

	Попытка
		ТекОбъект = СтрокаТаблицы.Док_ФормаВводаБюджета.ПолучитьОбъект();
		ТекОбъект.Заблокировать();
		ТекОбъект.УстановитьПометкуУдаления(Истина);
	Исключение
		Пояснение  	   		= ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ПредставлениеСписка = НСтр("ru = 'Создание документов'; en = 'Creating Documents'");
		
		ТекстСообщения = НСтр("ru = 'В строке ""%1"" списка ""%2"" не удалось пометить на удаление документ ""%3"". По причине: %4.'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, СтрокаТаблицы.НомерСтроки, ПредставлениеСписка, 
							СтрокаТаблицы.Док_ФормаВводаБюджета, Пояснение);
		ВызватьИсключение ТекстСообщения;
	КонецПопытки;        

КонецПроцедуры

&НаСервере
Процедура ПометитьНаУдалениеЗадачу(СтрокаТаблицы, ЗадачиКУдалению)

		Попытка
			Фильтр			 = Новый Структура("Предмет", СтрокаТаблицы.Док_ФормаВводаБюджета);
			РезультатаПоиска = ЗадачиКУдалению.НайтиСтроки(Фильтр);
			Если ЗначениеЗаполнено(РезультатаПоиска) Тогда
				Для каждого Элемент Из РезультатаПоиска Цикл
					Задача = Элемент.Ссылка;	
					ЗадачаОбъект = Задача.ПолучитьОбъект();
					ЗадачаОбъект.Заблокировать();
					ЗадачаОбъект.УстановитьПометкуУдаления(Истина);	
				КонецЦикла;			
			КонецЕсли;
		Исключение
			Пояснение  	   		= ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			ПредставлениеСписка = НСтр("ru = 'Создание документов'; en = 'Creating Documents'");
			
			ТекстСообщения = НСтр("ru = 'В строке ""%1"" списка ""%2"" не удалось пометить на удаление задачу, связаную с докуменом ""%3"". По причине: %4.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, СтрокаТаблицы.НомерСтроки, ПредставлениеСписка, 
								СтрокаТаблицы.Док_ФормаВводаБюджета, Пояснение);
			ВызватьИсключение ТекстСообщения;
		КонецПопытки;        

КонецПроцедуры

&НаСервере
Процедура СоздатьЗадачиОтветственнымНаСервере()
    
    МаксКоличествоОбъектов = бит_УправлениеПроцессами.МаксимальноеКоличествоОбъектовАдресации();
    ТекущийПользователь    = Пользователи.ТекущийПользователь();
    
    Для каждого СтрФвб Из Объект.ФормыВводаБюджета Цикл
        
        Если НЕ СтрФвб.Выбрать ИЛИ НЕ ЗначениеЗаполнено(СтрФвб.Док_ФормаВводаБюджета) Тогда
            Продолжить;       
        КонецЕсли;
        
        СтруктураЗадачи = Задачи.бит_Задача.СтруктураЗадачи();
	
    	СтруктураЗадачи.Предмет         = СтрФвб.Док_ФормаВводаБюджета;
    	СтруктураЗадачи.Наименование    = НСтр("ru='Заполнить бюджет';en='Fill budget'");
        СтруктураЗадачи.СпособАдресации = 0;
    	СтруктураЗадачи.Исполнитель     = ?(ЗначениеЗаполнено(СтрФвб.Ответственный), СтрФвб.Ответственный, ТекущийПользователь);
        СтруктураЗадачи.Важность        = Перечисления.бит_ВидыВажностиЗадач.Средняя;
               
        ОбЗадача = Задачи.бит_Задача.ЗаполнитьОбъектЗадачи(СтруктураЗадачи, МаксКоличествоОбъектов);
	    ЗадачаЗаписана = бит_ОбщегоНазначения.ЗаписатьЗадачу(ОбЗадача);      
                
        Если ЗадачаЗаписана Тогда            
            ТекстСообщения = НСтр("ru='Для документа ""%1"" записана задача ""%2"".';
								  |en='For a document ""%1"" is recorded task ""%2"".'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, СтрФвб.Док_ФормаВводаБюджета, ОбЗадача.Наименование); 			
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
        КонецЕсли;          
                
    КонецЦикла;
    
КонецПроцедуры

#КонецОбласти
