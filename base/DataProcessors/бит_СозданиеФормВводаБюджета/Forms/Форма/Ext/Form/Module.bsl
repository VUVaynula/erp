	Иначе
		Оповещение = Новый ОписаниеОповещения("ПроверитьКаталогНачатьСозданиеКаталога", ЭтотОбъект, Дополнительно); 
		НачатьСозданиеКаталога(Оповещение, Объект.ПутьКПапке); 
	КонецЕсли; 

КонецПроцедуры

