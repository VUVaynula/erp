&НаКлиенте
Процедура ВыгрузитьШаблоныВExcelЗавершение(ПутьКПапке, Дополнительно) Экспорт 
		
	Для каждого СтрокаТаблицы Из Объект.ФормыВводаБюджета Цикл
		
		Если НЕ СтрокаТаблицы.Выбрать Тогда
			Продолжить;       
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Док_ФормаВводаБюджета) ИЛИ НЕ ЗначениеЗаполнено(СтрокаТаблицы.Док_ИмяФайла) Тогда
			// Отмена выгрузки, если в строке нет документа или файл уже выгружен.
			Продолжить;       
		КонецЕсли;
		
		ТабДокДанные = ПолучитьТабДокДанные(СтрокаТаблицы.Док_ФормаВводаБюджета);
		
		ПутьКФайлу = ПутьКПапке + "\" + СтрокаТаблицы.Док_ИмяФайла;
		
		Попытка        
			
			бит_ОбменДаннымиКлиент.ФВБ_ВыгрузитьШаблонЭксель(ТабДокДанные, СтрокаТаблицы.Док_ФормаВводаБюджета, 
				ВременныеДанныеФормы, СтрокаТаблицы.Док_КоличествоРазворачивать, ПутьКФайлу, Расширение);
			// Отметка о выгрузке.
			СтрокаТаблицы.Док_ВыгруженШаблонВExcel = Истина;
			СтрокаТаблицы.Док_ИмяФайла = СтрЗаменить(ПутьКФайлу, ПутьКПапке + "\", ""); 
			
		Исключение
			
			ТекстСообщения = НСтр("ru='Не удалось записать файл %1.';
								  |en='Could not write the file %1.'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, СтрокаТаблицы.Док_ИмяФайла);
			ВызватьИсключение ТекстСообщения;
		КонецПопытки;    	
	КонецЦикла;

КонецПроцедуры

