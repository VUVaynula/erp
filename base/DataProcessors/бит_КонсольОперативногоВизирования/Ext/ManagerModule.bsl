Процедура ОбработатьПредставлениеПереопределяемыхОбъектов(ТекстЗапроса, ОписаниеТиповВиз)
	
	Если НЕ бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
		Возврат;
	КонецЕсли;
	
	ШаблонТипаДокумента = "ДокументСсылка.%1";
	ТипЗаявкаНаРасходование   = Тип(СтрШаблон(ШаблонТипаДокумента,
								бит_ОбщегоНазначенияПереопределяемый.ИмяЗаявкиНаРасходованиеСредств()));
	ТипПланируемоеПоступление = Тип(СтрШаблон(ШаблонТипаДокумента,
								бит_ОбщегоНазначенияПереопределяемый.ИмяПланируемогоПоступленияДенежныхСредств()));
	Если НЕ ОписаниеТиповВиз.СодержитТип(ТипЗаявкаНаРасходование)
		И НЕ ОписаниеТиповВиз.СодержитТип(ТипПланируемоеПоступление) Тогда
		Возврат;
	КонецЕсли;
	
	ПодстрокаПоиска = "ОтборныеВизы.ТипОбъектаВизирования КАК ТипОбъектаВизирования";
	ПодстрокаЗамены =
	"ВЫБОР
	|	КОГДА ОтборныеВизы.ОбъектВизирования ССЫЛКА Документ.бит_кзн_ЗаявкаНаРасходованиеСредств
	|		И ДанныеДокументов.ВидПлана = ЗНАЧЕНИЕ(Перечисление.бит_кзн_ВидыПланов.Прогноз) ТОГДА
	|		""%1""
	|	КОГДА ОтборныеВизы.ОбъектВизирования ССЫЛКА Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств
	|		И ДанныеДокументов.ВидПлана = ЗНАЧЕНИЕ(Перечисление.бит_кзн_ВидыПланов.Прогноз) ТОГДА
	|		""%2""
	|   ИНАЧЕ
	|		ОтборныеВизы.ТипОбъектаВизирования
	|КОНЕЦ КАК ТипОбъектаВизирования";
	ПодстрокаЗамены = СтрШаблон(ПодстрокаЗамены, НСтр("ru='Прогноз платежа';en='Prediction payment'"),
						НСтр("ru='Прогноз поступления ДС';en='Prediction DS incoming'"));
	ТекстЗапроса    = СтрЗаменить(ТекстЗапроса, ПодстрокаПоиска, ПодстрокаЗамены);
	
КонецПроцедуры

