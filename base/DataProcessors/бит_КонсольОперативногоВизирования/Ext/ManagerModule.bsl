Функция ОписаниеТаблицыПолейСоединенияСтрок(ОписаниеТиповОбъектов)
	
	ТаблицаИсточник = Новый ТаблицаЗначений;
	ТипОрганизация  = Новый ОписаниеТипов("СправочникСсылка.Организации");
	ТипДатаNULL     = Новый ОписаниеТипов("Дата, NULL", , ,Новый КвалификаторыДаты(ЧастиДаты.Дата));
	
	ТаблицаИсточник.Колонки.Добавить("ОбъектВизирования", ОписаниеТиповОбъектов);
	ТаблицаИсточник.Колонки.Добавить("ДатаПлан",          ТипДатаNULL, "");
	ТаблицаИсточник.Колонки.Добавить("ДатаПланКрайняя",   ТипДатаNULL, "");
	ТаблицаИсточник.Колонки.Добавить("СтатьяОборотов",    Новый ОписаниеТипов("СправочникСсылка.бит_СтатьиОборотов, NULL"));
	
	НастройкиИзмерений = бит_ОбщиеПеременныеСервер.ЗначениеПеременной("бит_НастройкиДополнительныхИзмерений");
	Для каждого ЭлементНастройки Из НастройкиИзмерений Цикл
		Если ЭлементНастройки.Значение.ТипЗначения = ТипОрганизация Тогда
			Продолжить; // Организация выводится из реквизита шапки
		КонецЕсли;
		ТаблицаИсточник.Колонки.Добавить(ЭлементНастройки.Ключ,
											Новый ОписаниеТипов(ЭлементНастройки.Значение.ТипЗначения, "NULL"),
											ЭлементНастройки.Значение.Синоним);
	КонецЦикла;
	
	Если бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
		ТаблицаИсточник.Колонки.Добавить("ОбъектРасчетов", Новый ОписаниеТипов("СправочникСсылка.ОбъектыРасчетов"));
		ТаблицаИсточник.Колонки.Добавить("Договор",
			Новый ОписаниеТипов("СправочникСсылка.ДоговорыМеждуОрганизациями, СправочникСсылка.ДоговорыКонтрагентов"));
	КонецЕсли;
	
	Возврат ТаблицаИсточник;
	
КонецФункции

Процедура НастроитьГруппировкиОтчета(Настройки, ВариантГруппировки)
	
	СтруктураНастройки = Настройки.Структура;
	СтруктураНастройки.Очистить();
	
	РасположениеИтогов = Настройки.ПараметрыВывода.Элементы.Найти("РасположениеИтогов");
	РасположениеИтогов.Использование = Ложь;
	
	СтрокаГруппировки = Неопределено;
	Если ВариантГруппировки = 0 Тогда
		// Группировка по сроку выполнения.
		СтрокаГруппировки    = СтруктураНастройки.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
		
		ПоляГруппировки      = СтрокаГруппировки.ПоляГруппировки.Элементы;
		НовоеПолеГруппировки = ПоляГруппировки.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
		НовоеПолеГруппировки.Поле          = Новый ПолеКомпоновкиДанных("СрокВыполнения");
		НовоеПолеГруппировки.Использование = Истина;
		НовоеПолеГруппировки = ПоляГруппировки.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
		НовоеПолеГруппировки.Поле          = Новый ПолеКомпоновкиДанных("ПорядокСортировкиСрока");
		НовоеПолеГруппировки.Использование = Истина;
		
		ВыбранныеПоля   = СтрокаГруппировки.Выбор.Элементы;
		НовоеПолеВыбора = ВыбранныеПоля.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
		НовоеПолеВыбора.Поле          = Новый ПолеКомпоновкиДанных("СрокВыполнения");
		НовоеПолеВыбора.Использование = Истина;
		
		ПоляПорядка      = СтрокаГруппировки.Порядок.Элементы;
		НовоеПолеПорядка = ПоляПорядка.Добавить(Тип("АвтоЭлементПорядкаКомпоновкиДанных"));
		НовоеПолеПорядка.Использование = Истина;
		
		СтрокаГруппировки.Использование = Истина;
	ИначеЕсли ВариантГруппировки = 1 Тогда
		// Группировка по видам документов.
		СтрокаГруппировки    = СтруктураНастройки.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
		
		ПоляГруппировки      = СтрокаГруппировки.ПоляГруппировки.Элементы;
		НовоеПолеГруппировки = ПоляГруппировки.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
		НовоеПолеГруппировки.Поле          = Новый ПолеКомпоновкиДанных("ВидДокумента");
		НовоеПолеГруппировки.Использование = Истина;
		
		ВыбранныеПоля   = СтрокаГруппировки.Выбор.Элементы;
		НовоеПолеВыбора = ВыбранныеПоля.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
		НовоеПолеВыбора.Поле          = Новый ПолеКомпоновкиДанных("ВидДокумента");
		НовоеПолеВыбора.Использование = Истина;
		
		ПоляПорядка      = СтрокаГруппировки.Порядок.Элементы;
		НовоеПолеПорядка = ПоляПорядка.Добавить(Тип("АвтоЭлементПорядкаКомпоновкиДанных"));
		НовоеПолеПорядка.Использование = Истина;
		
		СтрокаГруппировки.Использование = Истина;
	Иначе
		// Без группировок.
		РасположениеИтогов.Значение      = РасположениеИтоговКомпоновкиДанных.Нет;
		РасположениеИтогов.Использование = Истина;
	КонецЕсли;
	
	Если СтрокаГруппировки = Неопределено Тогда 
		СтрокаДетальныхЗаписей = СтруктураНастройки.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	Иначе
		СтрокаДетальныхЗаписей = СтрокаГруппировки.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	КонецЕсли;
	ВыбранныеПоля   = СтрокаДетальныхЗаписей.Выбор.Элементы;
	НовоеПолеВыбора = ВыбранныеПоля.Добавить(Тип("АвтоВыбранноеПолеКомпоновкиДанных"));
	НовоеПолеВыбора.Использование = Истина;
	СтрокаДетальныхЗаписей.Использование = Истина;
	
	ПоляПорядка      = СтрокаДетальныхЗаписей.Порядок.Элементы;
	НовоеПолеПорядка = ПоляПорядка.Добавить(Тип("АвтоЭлементПорядкаКомпоновкиДанных"));
	НовоеПолеПорядка.Использование = Истина;
	
КонецПроцедуры

Функция ПозицияВыбранногоПоля(КоллекцияЭлементовСтруктуры, ПолеКомпоновки)
	
	СчетчикПолей = 1;
	Для каждого ВыбранноеПоле Из КоллекцияЭлементовСтруктуры.Выбор.Элементы Цикл
		Если ТипЗнч(ВыбранноеПоле) = Тип("АвтоВыбранноеПолеКомпоновкиДанных")
			ИЛИ НЕ ВыбранноеПоле.Использование Тогда
			Продолжить;
		КонецЕсли;
		Если ВыбранноеПоле.Поле = ПолеКомпоновки Тогда
			Возврат СчетчикПолей;
		КонецЕсли;
		СчетчикПолей = СчетчикПолей + 1;
	КонецЦикла;
	
	Для каждого НастройкиГруппировки Из КоллекцияЭлементовСтруктуры.Структура Цикл
		НомерПозиции = ПозицияВыбранногоПоля(НастройкиГруппировки, ПолеКомпоновки);
		Если НомерПозиции <> 0 Тогда
			Возврат НомерПозиции;
		КонецЕсли;
	КонецЦикла;
	
	Возврат 0;
	
КонецФункции

// Возвращает ссылку на элемент справочника "Объекты системы", соответствующий переданному типу
//
// Параметры:
//  ТипОбъекта - Тип.
// 
// Возвращаемое значение:
//  СправочникСсылка.бит_ОбъектыСистемы.
//
Функция ОбъектСистемыДокумент(СоответствиеОбъектовСистемы, ТипОбъекта)
	
	Если НЕ ЗначениеЗаполнено(ТипОбъекта)
		ИЛИ ТипЗнч(ТипОбъекта) <> Тип("Тип") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если СоответствиеОбъектовСистемы = Неопределено Тогда
		СоответствиеОбъектовСистемы = Новый Соответствие;
	КонецЕсли;
	
	ОбъектСистемы = СоответствиеОбъектовСистемы.Получить(ТипОбъекта);
	Если ОбъектСистемы = Неопределено Тогда
		ОбъектСистемы =  бит_УправлениеОбъектамиСистемы.НайтиОбъектДоступаПоТипу(ТипОбъекта,
							Перечисления.бит_ВидыОбъектовСистемы.Документ);
		СоответствиеОбъектовСистемы.Вставить(ТипОбъекта, ОбъектСистемы);
	КонецЕсли;
	
	Возврат ОбъектСистемы;
	
КонецФункции

Функция ВыполняетсяПользовательскоеУсловие(ОбъектВизирования, ПользовательскоеУсловие, Ответственный)
	
	ПараметрыУсловия = Новый Структура;
	ПараметрыУсловия.Вставить("ТекущийОбъект",       ОбъектВизирования);
	ПараметрыУсловия.Вставить("ТекущийПользователь", Ответственный);
	Возврат бит_УправлениеПроцессами.ПроверитьПользовательскоеУсловие(ПользовательскоеУсловие,
							ПараметрыУсловия,,,"Ошибки");
	
КонецФункции

Процедура УстановитьОграниченияИспользованияПоляСКД(СКД, ИмяНабора, ИмяПоля, Ограничение = Истина)
	
	ПолеАналитикиСКД = СКД.НаборыДанных[ИмяНабора].Поля.Найти(ИмяПоля);
	Если ПолеАналитикиСКД = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПолеАналитикиСКД.ОграничениеИспользования.Группировка = Ограничение;
	ПолеАналитикиСКД.ОграничениеИспользования.Поле        = Ограничение;
	ПолеАналитикиСКД.ОграничениеИспользования.Порядок     = Ограничение;
	ПолеАналитикиСКД.ОграничениеИспользования.Условие     = Ограничение;	
	
КонецПроцедуры

Функция СуммаИВалютаДокумента(ДокументВизирования, ДатаПересчета)
	
	СуммаИВалюта = Новый Структура;
	СуммаИВалюта.Вставить("СуммаДокумента",  0);
	СуммаИВалюта.Вставить("ВалютаДокумента", Справочники.Валюты.ПустаяСсылка());
	
	Если ЭтоСсылкаНаРеестр(ДокументВизирования) Тогда
		ВалютаРегл = бит_ОбщегоНазначенияПовтИсп.ЗначениеПеременной("ВалютаРегламентированногоУчета");
		
		Запрос  = Новый Запрос;
		Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
			ТекстЗапроса =
			"ВЫБРАТЬ
			|	РеестрПлатежей.ВалютаДокумента КАК ВалютаДокумента,
			|	РеестрПлатежей.Сумма КАК Сумма
			|ПОМЕСТИТЬ ТабличнаяЧастьРеестра
			|ИЗ
			|	Документ.бит_РеестрПлатежей.Заявки КАК РеестрПлатежей
			|ГДЕ
			|	РеестрПлатежей.Ссылка = &Ссылка";
		Иначе
			ТекстЗапроса =
			"ВЫБРАТЬ
			|	РеестрПлатежей.ВалютаДокумента КАК ВалютаДокумента,
			|	РеестрПлатежей.СуммаДокумента КАК Сумма
			|ПОМЕСТИТЬ ТабличнаяЧастьРеестра
			|ИЗ
			|	Документ.бит_кзн_РеестрПлатежей.ТаблицаПлатежи КАК РеестрПлатежей
			|ГДЕ
			|	РеестрПлатежей.Ссылка = &Ссылка";
		КонецЕсли;
		
		ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
		ТекстЗапроса = ТекстЗапроса +
		"ВЫБРАТЬ
		|	СУММА(ВЫБОР
		|			КОГДА ТабличнаяЧастьРеестра.ВалютаДокумента = &ВалютаРегл
		|				ТОГДА ТабличнаяЧастьРеестра.Сумма
		|			ИНАЧЕ ТабличнаяЧастьРеестра.Сумма * КурсыВалютСрезПоследних.Курс / КурсыВалютСрезПоследних.Кратность
		|		КОНЕЦ) КАК Сумма
		|ИЗ
		|	ТабличнаяЧастьРеестра КАК ТабличнаяЧастьРеестра
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&ДатаПересчета, ) КАК КурсыВалютСрезПоследних
		|		ПО ТабличнаяЧастьРеестра.ВалютаДокумента = КурсыВалютСрезПоследних.Валюта";
		Запрос.Текст = ТекстЗапроса;
		Запрос.УстановитьПараметр("Ссылка",        ДокументВизирования);
		Запрос.УстановитьПараметр("ДатаПересчета", ДатаПересчета);
		Запрос.УстановитьПараметр("ВалютаРегл",    ВалютаРегл);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Сумма) Тогда
			СуммаИВалюта.ВалютаДокумента = ВалютаРегл;
			СуммаИВалюта.СуммаДокумента  = Выборка.Сумма;
		КонецЕсли;
	КонецЕсли;
	
	Возврат СуммаИВалюта;
	
КонецФункции

Процедура УстановитьПараметрыДанных(Настройки, ПараметрыПолучения)
	
	ПараметрРежимАрхива = Настройки.ПараметрыДанных.Элементы.Найти("РежимАрхива");
	Если ПараметрРежимАрхива <> Неопределено Тогда
		ПараметрРежимАрхива.Использование = Истина;
		ПараметрРежимАрхива.Значение      = ПараметрыПолучения.РежимАрхива;
	КонецЕсли;
	
	ПараметрТекущаяДата = Настройки.ПараметрыДанных.Элементы.Найти("ТекущаяДата");
	Если ПараметрТекущаяДата <> Неопределено Тогда
		ПараметрТекущаяДата.Использование = Истина;
		ПараметрТекущаяДата.Значение      = ТекущаяДатаСеанса();
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьПараметрыВывода(Настройки, ПараметрыПолучения)
	
	ПараметрАвтопозицияРесурсов = Настройки.ПараметрыВывода.Элементы.Найти("АвтопозицияРесурсов");
	Если ПараметрАвтопозицияРесурсов <> Неопределено Тогда
		АвтопозицияРесурсов = ПараметрыПолучения.АвтопозицияРесурсов;
		Если АвтопозицияРесурсов = Истина Тогда
			ПараметрАвтопозицияРесурсов.Использование = Ложь;
		Иначе
			ПараметрАвтопозицияРесурсов.Использование = Истина;
			ПараметрАвтопозицияРесурсов.Значение      = АвтоПозицияРесурсовКомпоновкиДанных.НеИспользовать;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

Функция ПорядокИЗаголовкиПолейСхемы(ПараметрыПолучения, Схема, Настройки, ИсключаемыеПоля)
	
	ПорядокИЗаголовкиПолей = Новый Массив;
	
	Если НЕ ПараметрыПолучения.ВозвращатьПорядокИЗаголовкиПолей Тогда
		Возврат ПорядокИЗаголовкиПолей;
	КонецЕсли;
	
	ДобавитьОпределениеПолей(ПорядокИЗаголовкиПолей, Настройки.Выбор.Элементы, Схема, ИсключаемыеПоля);
	Если Настройки.Структура.Количество() = 1 Тогда
		ДобавитьОпределениеПолей(ПорядокИЗаголовкиПолей, Настройки.Структура[0].ПоляГруппировки.Элементы,
									Схема, ИсключаемыеПоля);
	КонецЕсли;
		
	Возврат ПорядокИЗаголовкиПолей;
	
КонецФункции

Процедура ДобавитьОпределениеПолей(ПорядокИЗаголовкиПолей, КоллекцияЭлементовИсточник, Схема, ИсключаемыеПоля)
	
	Для каждого ЭлементКоллекцииПолей Из КоллекцияЭлементовИсточник Цикл
		Если НЕ ЭлементКоллекцииПолей.Использование Тогда
			Продолжить;
		КонецЕсли;
		ВыбранноеПоле = ЭлементКоллекцииПолей.Поле;
		Если ИсключаемыеПоля.НайтиПоЗначению(ВыбранноеПоле) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ПолеСтрокой   = Строка(ВыбранноеПоле);
		
		СтруктураПоля = Новый Структура("Имя, Заголовок");
		СтруктураПоля.Имя        = СтрЗаменить(ПолеСтрокой, ".", "");
		СтруктураПоля.Заголовок  = ПолеСтрокой;
		НайденоОпределение = Ложь;
		Для каждого НаборДанных Из Схема.НаборыДанных Цикл
			Для каждого ПолеНабора Из НаборДанных.Поля Цикл
				Если ПолеСтрокой = ПолеНабора.Поле Тогда
					СтруктураПоля.Заголовок = ПолеНабора.Заголовок;
					НайденоОпределение      = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если НайденоОпределение Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
		ПорядокИЗаголовкиПолей.Добавить(СтруктураПоля);
		ИсключаемыеПоля.Добавить(ВыбранноеПоле);
	КонецЦикла;
	
КонецПроцедуры

Процедура УстановитьВнешниеОтборы(ПараметрыПолучения, Настройки)
	
	Отборы = ПараметрыПолучения.Отбор.ВнешниеОтборы;
	Если Отборы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ОтборыНастройки = Настройки.Отбор.Элементы;
	
	ПризнакСтандартногоВарианта = "/StandardPeriodVariant:";
	
	Для каждого ЭлементОтбора Из Отборы Цикл
		ЗначениеОтбора = ЭлементОтбора.Значение;
		
		ЗначениеФильтра = ЗначениеОтбора.ПравоеЗначение;
		Если ТипЗнч(ЗначениеФильтра) = Тип("Строка")
			И СтрНачинаетсяС(ЗначениеФильтра, ПризнакСтандартногоВарианта) Тогда
			
			ОписаниеВарианта = СтрЗаменить(ЗначениеФильтра, ПризнакСтандартногоВарианта, "");
			ОписаниеВарианта = ЗначениеИзСтрокиВнутр(ОписаниеВарианта);
			ФильтрПериод     = Новый СтандартныйПериод(ОписаниеВарианта);
			
			НовыйЭлементОтбора = ОтборыНастройки.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			НовыйЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(ЗначениеОтбора.ЛевоеЗначение);
			НовыйЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.БольшеИлиРавно;
			НовыйЭлементОтбора.ПравоеЗначение = ФильтрПериод.ДатаНачала;
			НовыйЭлементОтбора.Использование  = Истина;
			
			НовыйЭлементОтбора = ОтборыНастройки.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			НовыйЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(ЗначениеОтбора.ЛевоеЗначение);
			НовыйЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.МеньшеИлиРавно;
			НовыйЭлементОтбора.ПравоеЗначение = ФильтрПериод.ДатаОкончания;
			НовыйЭлементОтбора.Использование  = Истина;
		Иначе
			НовыйЭлементОтбора = ОтборыНастройки.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			НовыйЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(ЗначениеОтбора.ЛевоеЗначение);
			НовыйЭлементОтбора.ВидСравнения   = ЗначениеОтбора.ВидСравнения;
			НовыйЭлементОтбора.ПравоеЗначение = ЗначениеОтбора.ПравоеЗначение;
			НовыйЭлементОтбора.Использование  = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция КартинкаБиблиотеки(Назначение)
	
	Если Назначение = "ФлагВыбораЛожь" Тогда
		Возврат БиблиотекаКартинок.бит_ЗвездаПустая;
	ИначеЕсли Назначение = "ФлагВыбораИстина" Тогда
		Возврат БиблиотекаКартинок.бит_ЗвездаСтрелочка;
	ИначеЕсли Назначение = "Согласовано" Тогда
		Возврат БиблиотекаКартинок.бит_ГалочкаКруглая;
	ИначеЕсли Назначение = "Отклонено" Тогда
		Возврат БиблиотекаКартинок.УдалитьНепосредственно;
	КонецЕсли;
	
КонецФункции

Функция ПараметрыИзвлеченияКартинки(ИсходныйТекст)
	
	// #Картинка#НаименованиеИзображения#[Произвольный текст после извлечения]
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Текст");
	СтруктураПараметров.Вставить("Картинка");
	
	Если ТекстСодержитИдентификаторКартинки(ИсходныйТекст) Тогда
		НачалоОписанияКартинки = СтрНайти(ИсходныйТекст, "#",,, 2);
		ОкончаниеОписанияКартинки = СтрНайти(ИсходныйТекст, "#",,, 3);
	КонецЕсли;
	
	НаименованиеКартинки = Сред(ИсходныйТекст, НачалоОписанияКартинки + 1, ОкончаниеОписанияКартинки - НачалоОписанияКартинки - 1);
	СтруктураПараметров.Текст    = СтрЗаменить(ИсходныйТекст, ИдентификаторПодстановкиКартинки() + НаименованиеКартинки + "#", "");
	СтруктураПараметров.Картинка = БиблиотекаКартинок[НаименованиеКартинки];
		
	Возврат СтруктураПараметров;
	
КонецФункции

Функция ИдентификаторПодстановкиКартинки()
	
	Возврат "#Картинка#";
	
КонецФункции

Функция ТекстСодержитИдентификаторКартинки(ИсходныйТекст)
	
	ПодстановкаКартинки = ИдентификаторПодстановкиКартинки();
	Если СтрНайти(ИсходныйТекст, ПодстановкаКартинки) > 0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

Функция ПредрасчетныеРеквизиты()
	
	ПредрасчетныеРеквизиты = Новый Массив;
	ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "Дата");
	ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "Комментарий", 250);
	ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "Контрагент");
	ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "НазначениеПлатежаУпр");
	ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "Номер");
	ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "Ответственный");
	ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "СверхБюджета");
	ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "Сценарий");
	
	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "ДатаРасхода");
		ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "Исполнитель");
		ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "Проект");
		ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "ДокументОснование",, "ОснованиеПланирования");
	Иначе
		ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "Инициатор");
		ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, "ВидПлана",, "ОснованиеПланирования");
	КонецЕсли;
	
	Возврат ПредрасчетныеРеквизиты;
	
КонецФункции

Процедура ДобавитьПредрасчетныйРеквизит(ПредрасчетныеРеквизиты, ИмяРеквизита, ОграничениеДлины = 0, ИмяПоляРезультат = "")
	
	СтруктураРеквизита = Новый Структура;
	СтруктураРеквизита.Вставить("Имя", ИмяРеквизита);
	СтруктураРеквизита.Вставить("ОграничениеДлины", ОграничениеДлины);
	СтруктураРеквизита.Вставить("ИмяПоляРезультат", ?(ПустаяСтрока(ИмяПоляРезультат), ИмяРеквизита, ИмяПоляРезультат));
	
	ПредрасчетныеРеквизиты.Добавить(СтруктураРеквизита);
	
КонецПроцедуры

Функция ЭтоСсылкаНаРеестр(ДокументСсылка)
	
	НаименованиеРеестра = бит_ОбщегоНазначения.ИмяРеестраПлатежей();
	ТипРеестра   = Тип("ДокументСсылка." + НаименованиеРеестра);
	ТипДокумента = ТипЗнч(ДокументСсылка);
	
	Возврат ТипДокумента = ТипРеестра;
	
КонецФункции

Процедура УстановитьРешениеПоСтроке(СтрокаДанных, ПараметрыОтметкиРешения, СообщенияПользователю)
	
	Если НЕ СтрокаДанных.Обрабатывать Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектВизирования = СтрокаДанных.ОбъектВизирования;
	
	Если НЕ СогласованиеПоВизеДоступно(ОбъектВизирования,
										СтрокаДанных.ИД,
										ПараметрыОтметкиРешения.ТекущийПользователь) Тогда 
		ТекстСообщения = НСтр("ru='Визы были изменены другим пользователем, согласование невозможно.';
							  |en='Visas have been changed by another user, can`t set desition.'");
		СообщенияПользователю.Добавить(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ПараметрыОтметкиРешения.ПроводитьПослеУтверждения = бит_ВизированиеСервер.ПриниматьКУчетуПослеУтверждения(ОбъектВизирования);
	ПараметрыОтметкиРешения.ОбъектВизирования         = ОбъектВизирования;
	ПараметрыОтметкиРешения.ИДВизы                    = СтрокаДанных.ИД;

	Если УстановитьРешениеПоВизе(ПараметрыОтметкиРешения, СообщенияПользователю) Тогда
		СтрокаДанных.Обрабатывать    = Ложь;
		СтрокаДанных.ПринятоеРешение = ПараметрыОтметкиРешения.Решение;	
	КонецЕсли;
	
КонецПроцедуры

Функция СогласованиеПоВизеДоступно(ОбъектВизирования, ИДВизы, Пользователь)
	
	НаборВиз = РегистрыСведений.бит_УстановленныеВизы.СоздатьНаборЗаписей();
	НаборВиз.Отбор.Объект.Установить(ОбъектВизирования);
	НаборВиз.Прочитать();
	ТаблицаВизы = НаборВиз.Выгрузить();
	ТаблицаВизы.Колонки.Добавить("ДоступностьВизы", Новый ОписаниеТипов("Булево"));
	
	ВизыПользователя  = бит_ВизированиеСервер.ВизыПользователя(Пользователь, ОбъектВизирования);
	ЕстьПараНаВсеВизы = (ВизыПользователя.НайтиПоЗначению(Справочники.бит_ГруппыВиз.ВсеВизы) <> Неопределено);
	
	Для каждого СтрокаВизы Из ТаблицаВизы Цикл
		СтрокаВизы.ДоступностьВизы = ЕстьПараНаВсеВизы
										ИЛИ (ВизыПользователя.НайтиПоЗначению(СтрокаВизы.Виза) <> Неопределено);
	КонецЦикла;
		
	Алгоритм = Справочники.бит_АлгоритмыПроцессов.ПустаяСсылка();
	Для каждого СтрокаВизы Из ТаблицаВизы Цикл
		Если ЗначениеЗаполнено(СтрокаВизы.Алгоритм) Тогда
			Алгоритм = СтрокаВизы.Алгоритм;
			Прервать;
		КонецЕсли; 
	КонецЦикла;
	
	ВыполнятьПоэтапно = бит_УправлениеПроцессами.ВыполнятьАлгоритмПоэтапно(Алгоритм);	
	
	ТаблицаТочек      = бит_УправлениеПроцессами.ОписаниеТочекАлгоритма(Алгоритм, ТаблицаВизы);
	
	// Определяем, какие точки алгоритма доступны.
	ДопПараметрыПроверкиУсловий = бит_ВизированиеСервер.НовыеПараметрыПроверкиУсловия();
	ДопПараметрыПроверкиУсловий.ТекущийОбъект = ОбъектВизирования;
	ДопПараметрыПроверкиУсловий.Визы          = ТаблицаВизы;
	ДопПараметрыПроверкиУсловий.Алгоритм      = Алгоритм;

	бит_УправлениеПроцессами.ОпределитьДоступностьТочек(ТаблицаТочек, ВыполнятьПоэтапно, ДопПараметрыПроверкиУсловий);
	
	СтрокаВизы = ТаблицаТочек.Найти(ИДВизы, "ИД");
	Если СтрокаВизы = Неопределено Тогда
		Возврат Ложь;
	Иначе
		Возврат СтрокаВизы.Доступность;
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#КонецЕсли