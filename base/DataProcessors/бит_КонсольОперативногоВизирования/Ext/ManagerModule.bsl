	ПараметрыРешения.Вставить("ТекущийПользователь");
	
	ПараметрыРешения.ПроводитьПослеУтверждения = Ложь;
	ПараметрыРешения.ТекущийПользователь       = Пользователи.ТекущийПользователь();
	
