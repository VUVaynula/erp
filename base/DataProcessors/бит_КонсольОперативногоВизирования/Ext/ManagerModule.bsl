Функция ТекстЗапросаПравДоступа()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТаблицаДоступа.Виза КАК Виза,
	|	ТаблицаДоступа.ПолныйДоступ КАК ПолныйДоступ,
	|	ТаблицаДоступа.УсловиеДоступа КАК УсловиеДоступа
	|ПОМЕСТИТЬ ТаблицаДоступа
	|ИЗ
	|	&ТаблицаДоступа КАК ТаблицаДоступа
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Виза";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаНачальнаяВыборкаАктивныхВиз(ПараметрыПолучения)
	
	Если ПараметрыПолучения.РежимПолученияРеквизитов Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	бит_УстановленныеВизы.Объект КАК Объект,
		|	бит_УстановленныеВизы.Виза КАК Виза,
		|	бит_УстановленныеВизы.ИД КАК ИД,
		|	бит_УстановленныеВизы.ДатаУстановки КАК ДатаКрайняя,
		|	бит_УстановленныеВизы.Решение КАК ПринятоеРешение
		|ПОМЕСТИТЬ АктивныеВизы
		|ИЗ
		|	РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы
		|ГДЕ
		|	&УсловиеПоОбъекту
		|	И &УсловиеПоТипуОбъекта
		|	И &УсловиеПоВизам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ //РАЗРЕШЕННЫЕ
		|	АктивныеВизы.Объект КАК ОбъектВизирования,
		|	АктивныеВизы.Виза КАК Виза,
		|	АктивныеВизы.ИД КАК ИД,
		|	АктивныеВизы.ДатаКрайняя КАК ДатаКрайняя,
		|	АктивныеВизы.ПринятоеРешение КАК ПринятоеРешение,
		|	ИСТИНА КАК ПолныйДоступ,
		|	ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеУсловия.ПустаяСсылка) КАК УсловиеДоступа,
		|	ТИПЗНАЧЕНИЯ(АктивныеВизы.Объект) КАК ТипОбъектаВизирования
		|ПОМЕСТИТЬ НачальнаяВыборкаАктивныхВиз
		|ИЗ
		|	АктивныеВизы КАК АктивныеВизы
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ОбъектВизирования";
	ИначеЕсли ПараметрыПолучения.РежимАрхива Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	бит_УстановленныеВизы.Объект КАК Объект,
		|	бит_УстановленныеВизы.Виза КАК Виза,
		|	бит_УстановленныеВизы.ИД КАК ИД,
		|	бит_УстановленныеВизы.ДатаУстановки КАК ДатаКрайняя,
		|	бит_УстановленныеВизы.Решение КАК ПринятоеРешение
		|ПОМЕСТИТЬ АктивныеВизы
		|ИЗ
		|	РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы
		|ГДЕ
		|	НЕ бит_УстановленныеВизы.АктивнаяВиза
		|	И бит_УстановленныеВизы.Пользователь = &Ответственный
		|	И &УсловиеПоОбъекту
		|	И &УсловиеПоТипуОбъекта
		|	И &УсловиеПоВизам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ //РАЗРЕШЕННЫЕ
		|	АктивныеВизы.Объект КАК ОбъектВизирования,
		|	АктивныеВизы.Виза КАК Виза,
		|	АктивныеВизы.ИД КАК ИД,
		|	АктивныеВизы.ДатаКрайняя КАК ДатаКрайняя,
		|	АктивныеВизы.ПринятоеРешение КАК ПринятоеРешение,
		|	ИСТИНА КАК ПолныйДоступ,
		|	ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеУсловия.ПустаяСсылка) КАК УсловиеДоступа,
		|	ТИПЗНАЧЕНИЯ(АктивныеВизы.Объект) КАК ТипОбъектаВизирования
		|ПОМЕСТИТЬ НачальнаяВыборкаАктивныхВиз
		|ИЗ
		|	АктивныеВизы КАК АктивныеВизы
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ОбъектВизирования";
	ИначеЕсли ПараметрыПолучения.РежимПроверкиОповещений Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	бит_УстановленныеВизы.Объект КАК Объект,
		|	бит_УстановленныеВизы.Виза КАК Виза,
		|	бит_УстановленныеВизы.ИД КАК ИД,
		|	бит_УстановленныеВизы.ДатаКрайняя КАК ДатаКрайняя
		|ПОМЕСТИТЬ АктивныеВизы
		|ИЗ
		|	РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы
		|ГДЕ
		|	бит_УстановленныеВизы.АктивнаяВиза
		|	И &УсловиеПоОбъекту
		|	И &УсловиеПоТипуОбъекта
		|	И &УсловиеПоВизам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	РегистрацияСобытийОповещений.Объект КАК Объект
		|ПОМЕСТИТЬ Оповещения
		|ИЗ
		|	РегистрСведений.бит_фн_РегистрацияСобытийОповещений КАК РегистрацияСобытийОповещений
		|ГДЕ
		|	РегистрацияСобытийОповещений.Оповещение.НеРегистрироватьПовторно
		|	И РегистрацияСобытийОповещений.Оповещение.ВидСобытия = ЗНАЧЕНИЕ(Перечисление.бит_фн_ВидыСобытийОповещений.ДокументыДляВизирования)
		|	И РегистрацияСобытийОповещений.Пользователь = &Ответственный
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Объект
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ //РАЗРЕШЕННЫЕ
		|	АктивныеВизы.Объект КАК ОбъектВизирования,
		|	АктивныеВизы.Виза КАК Виза,
		|	АктивныеВизы.ИД КАК ИД,
		|	АктивныеВизы.ДатаКрайняя КАК ДатаКрайняя,
		|	ЗНАЧЕНИЕ(Справочник.бит_ВидыРешенийСогласования.ПустаяСсылка) КАК ПринятоеРешение,
		|	ТаблицаДоступа.ПолныйДоступ КАК ПолныйДоступ,
		|	ТаблицаДоступа.УсловиеДоступа КАК УсловиеДоступа,
		|	ТИПЗНАЧЕНИЯ(АктивныеВизы.Объект) КАК ТипОбъектаВизирования
		|ПОМЕСТИТЬ НачальнаяВыборкаАктивныхВиз
		|ИЗ
		|	АктивныеВизы КАК АктивныеВизы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаДоступа КАК ТаблицаДоступа
		|		ПО АктивныеВизы.Виза = ТаблицаДоступа.Виза
		|		ЛЕВОЕ СОЕДИНЕНИЕ Оповещения КАК Оповещения
		|		ПО АктивныеВизы.Объект = Оповещения.Объект
		|ГДЕ
		|	Оповещения.Объект ЕСТЬ NULL
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ОбъектВизирования";
	Иначе
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	бит_УстановленныеВизы.Объект КАК Объект,
		|	бит_УстановленныеВизы.Виза КАК Виза,
		|	бит_УстановленныеВизы.ИД КАК ИД,
		|	бит_УстановленныеВизы.ДатаКрайняя КАК ДатаКрайняя
		|ПОМЕСТИТЬ АктивныеВизы
		|ИЗ
		|	РегистрСведений.бит_УстановленныеВизы КАК бит_УстановленныеВизы
		|ГДЕ
		|	бит_УстановленныеВизы.АктивнаяВиза
		|	И &УсловиеПоОбъекту
		|	И &УсловиеПоТипуОбъекта
		|	И &УсловиеПоВизам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ //РАЗРЕШЕННЫЕ
		|	АктивныеВизы.Объект КАК ОбъектВизирования,
		|	АктивныеВизы.Виза КАК Виза,
		|	АктивныеВизы.ИД КАК ИД,
		|	АктивныеВизы.ДатаКрайняя КАК ДатаКрайняя,
		|	ЗНАЧЕНИЕ(Справочник.бит_ВидыРешенийСогласования.ПустаяСсылка) КАК ПринятоеРешение,
		|	ТаблицаДоступа.ПолныйДоступ КАК ПолныйДоступ,
		|	ТаблицаДоступа.УсловиеДоступа КАК УсловиеДоступа,
		|	ТИПЗНАЧЕНИЯ(АктивныеВизы.Объект) КАК ТипОбъектаВизирования
		|ПОМЕСТИТЬ НачальнаяВыборкаАктивныхВиз
		|ИЗ
		|	АктивныеВизы КАК АктивныеВизы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаДоступа КАК ТаблицаДоступа
		|		ПО АктивныеВизы.Виза = ТаблицаДоступа.Виза
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ОбъектВизирования";
	КонецЕсли;
	
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	ТекстЗапроса = ТекстЗапроса +
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НачальнаяВыборкаАктивныхВиз.ТипОбъектаВизирования КАК ТипОбъектаВизирования
	|ИЗ
	|	НачальнаяВыборкаАктивныхВиз КАК НачальнаяВыборкаАктивныхВиз";
	
	ОтборОбъектВизирования = ПараметрыПолучения.Отбор.ОбъектВизирования;
	ТекстЗапроса           = СтрЗаменить(ТекстЗапроса, "&УсловиеПоОбъекту",
								ТекстФильтраОбъектВизирования(ОтборОбъектВизирования));
								
	ТипыОбъектовВизирования = ПараметрыПолучения.Отбор.ТипОбъекта;
	ТекстЗапроса            = СтрЗаменить(ТекстЗапроса, "&УсловиеПоТипуОбъекта",
								ТекстФильтраТипыОбъектов(ТипыОбъектовВизирования));
	
	ВариантОтбораВиз = ПараметрыПолучения.ВариантОтбораВиз;
	ТекстЗапроса     = СтрЗаменить(ТекстЗапроса, "&УсловиеПоВизам",
						ТекстФильтраВизы(ВариантОтбораВиз));
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаВыбратьВизы(ОписаниеТиповВиз)
	
	МассивПредрасчетныхРеквизитов = ПредрасчетныеРеквизиты();
	ДобавитьПредрасчетныйРеквизит(МассивПредрасчетныхРеквизитов, "Организация");
	
	ТипыВиз   = ОписаниеТиповВиз.Типы();
	ПервыйТип = Истина;	
	
	ТекстЗапроса = "УНИЧТОЖИТЬ АктивныеВизы";
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
	Для каждого ТипВизы Из ТипыВиз Цикл
		
		МетаданныеОбъектаВизирования = ПустоеЗначениеТипа(ТипВизы).Метаданные();
		ПолноеИмяМетаданного         = МетаданныеОбъектаВизирования.ПолноеИмя();
		
		Если ПервыйТип Тогда
			ШаблонВыборки =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	АктивныеВизы.ОбъектВизирования КАК ОбъектВизирования,
			|	АктивныеВизы.Виза КАК Виза,
			|	АктивныеВизы.ИД КАК ИД,
			|	АктивныеВизы.ДатаКрайняя КАК ДатаКрайняя,
			|	АктивныеВизы.ПринятоеРешение КАК ПринятоеРешение,
			|	АктивныеВизы.ПолныйДоступ КАК ПолныйДоступ,
			|	АктивныеВизы.УсловиеДоступа КАК УсловиеДоступа,
			|	АктивныеВизы.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
			|	&МассивПредрасчетныхРеквизитов КАК МассивПредрасчетныхРеквизитов
			|ПОМЕСТИТЬ ОтборныеВизы
			|ИЗ
			|	НачальнаяВыборкаАктивныхВиз КАК АктивныеВизы
			|ГДЕ
			|	АктивныеВизы.ОбъектВизирования ССЫЛКА Документ.бит_ФормаВводаБюджета
			|	И ВЫРАЗИТЬ(АктивныеВизы.ОбъектВизирования КАК Документ.бит_ФормаВводаБюджета).Ссылка ЕСТЬ НЕ NULL";
		Иначе
			ШаблонВыборки = "
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	АктивныеВизы.ОбъектВизирования КАК ОбъектВизирования,
			|	АктивныеВизы.Виза КАК Виза,
			|	АктивныеВизы.ИД КАК ИД,
			|	АктивныеВизы.ДатаКрайняя КАК ДатаКрайняя,
			|	АктивныеВизы.ПринятоеРешение КАК ПринятоеРешение,
			|	АктивныеВизы.ПолныйДоступ КАК ПолныйДоступ,
			|	АктивныеВизы.УсловиеДоступа КАК УсловиеДоступа,
			|	АктивныеВизы.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
			|	&МассивПредрасчетныхРеквизитов КАК МассивПредрасчетныхРеквизитов
			|ИЗ
			|	НачальнаяВыборкаАктивныхВиз КАК АктивныеВизы
			|ГДЕ
			|	АктивныеВизы.ОбъектВизирования ССЫЛКА Документ.бит_ФормаВводаБюджета
			|	И ВЫРАЗИТЬ(АктивныеВизы.ОбъектВизирования КАК Документ.бит_ФормаВводаБюджета).Ссылка ЕСТЬ НЕ NULL";
		КонецЕсли;
		
		ТекстПолученияРеквизитов      = "";
		Для каждого Реквизит Из МассивПредрасчетныхРеквизитов Цикл
			Если НЕ ПустаяСтрока(ТекстПолученияРеквизитов) Тогда
				ТекстПолученияРеквизитов = ТекстПолученияРеквизитов + ",
				|	";
			КонецЕсли;
			
			ИмяРеквизита     = Реквизит.Имя;
			ИмяПоляРезультат = Реквизит.ИмяПоляРезультат;
			Если НЕ ОбщегоНазначения.ЕстьРеквизитОбъекта(ИмяРеквизита, МетаданныеОбъектаВизирования)
				И НЕ ОбщегоНазначения.ЭтоСтандартныйРеквизит(МетаданныеОбъектаВизирования.СтандартныеРеквизиты,
																ИмяРеквизита) Тогда
				ТекстЗапросаРеквизита = "NULL КАК %1";
				ТекстЗапросаРеквизита = СтрШаблон(ТекстЗапросаРеквизита, ИмяПоляРезультат);
			ИначеЕсли Реквизит.ОграничениеДлины > 0 Тогда
				ТекстЗапросаРеквизита = "ВЫРАЗИТЬ(ВЫРАЗИТЬ(АктивныеВизы.ОбъектВизирования КАК %1).%2 КАК СТРОКА(%3)) КАК %4";
				ТекстЗапросаРеквизита = СтрШаблон(ТекстЗапросаРеквизита, ПолноеИмяМетаданного, ИмяРеквизита,
													Реквизит.ОграничениеДлины, ИмяПоляРезультат);
			Иначе
				ТекстЗапросаРеквизита = "ВЫРАЗИТЬ(АктивныеВизы.ОбъектВизирования КАК %1).%2 КАК %3";
				ТекстЗапросаРеквизита = СтрШаблон(ТекстЗапросаРеквизита, ПолноеИмяМетаданного, ИмяРеквизита,
													ИмяПоляРезультат);
			КонецЕсли;
			
			ТекстПолученияРеквизитов = ТекстПолученияРеквизитов + ТекстЗапросаРеквизита;
		КонецЦикла;
		ШаблонВыборки = СтрЗаменить(ШаблонВыборки, "&МассивПредрасчетныхРеквизитов КАК МассивПредрасчетныхРеквизитов",
							ТекстПолученияРеквизитов);
		ШаблонВыборки = СтрЗаменить(ШаблонВыборки, "Документ.бит_ФормаВводаБюджета", ПолноеИмяМетаданного);
		ТекстЗапроса  = ТекстЗапроса + ШаблонВыборки;
		
		ПервыйТип     = Ложь;
	КонецЦикла;
	
	ТекстЗапроса = ТекстЗапроса + "
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ОбъектВизирования";
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	ТекстЗапроса = ТекстЗапроса + "УНИЧТОЖИТЬ НачальнаяВыборкаАктивныхВиз";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстФильтраОбъектВизирования(ОтборОбъектВизирования)
	
	Если НЕ ЗначениеЗаполнено(ОтборОбъектВизирования) Тогда
		ТекстФильтра = "ИСТИНА";
	ИначеЕсли ТипЗнч(ОтборОбъектВизирования) = Тип("СписокЗначений") Тогда
		ТекстФильтра = "бит_УстановленныеВизы.Объект В (&ОтборОбъектВизирования)";
	Иначе
		ТекстФильтра = "бит_УстановленныеВизы.Объект = &ОтборОбъектВизирования";
	КонецЕсли;
	
	Возврат ТекстФильтра;
	
КонецФункции

Функция ТекстФильтраТипыОбъектов(ТипыОбъектовВизирования)
	
	Если ТипыОбъектовВизирования.Количество() = 0 Тогда
		ТекстФильтра = "ИСТИНА";
	Иначе
		ТекстФильтра = "ТИПЗНАЧЕНИЯ(бит_УстановленныеВизы.Объект) В (&ТипыОбъектовВизирования)";
	КонецЕсли;
	
	Возврат ТекстФильтра;
	
КонецФункции

Функция ТекстФильтраВизы(ВариантОтбораВиз)
	
	ТекстФильтра = "ИСТИНА";
	
	Если ВариантОтбораВиз = 1 ИЛИ ВариантОтбораВиз = 2 Тогда
		ТекстФильтра = "бит_УстановленныеВизы.Виза.Вид = ЗНАЧЕНИЕ(Перечисление.бит_ВидыВиз.%1)";
		ТекстФильтра = СтрШаблон(ТекстФильтра, ?(ВариантОтбораВиз = 1, "Согласующая", "Утверждающая"));
	ИначеЕсли ВариантОтбораВиз = 3 Тогда
		ТекстФильтра = "бит_УстановленныеВизы.Виза В ИЕРАРХИИ (&ФильтрВизы)";
	КонецЕсли;
	
	Возврат ТекстФильтра;
	
КонецФункции

Функция ТекстЗапросаСмешанныеПоляШапкиТЧ(ОписаниеТиповВиз)
	
	ТекстЗапросаСмешанныхПолей = "";
	НужноОбъединение           = Ложь;
	ВключеныПлатежныеПозиции   = Ложь;
	ТипыВиз                    = ОписаниеТиповВиз.Типы();
	
	Для каждого ТипВизы Из ТипыВиз Цикл
		
		МетаданныеОбъектаВизирования = ПустоеЗначениеТипа(ТипВизы).Метаданные();
		Если Не ПравоДоступа("Чтение", МетаданныеОбъектаВизирования) Тогда
			Продолжить;
		КонецЕсли;
		
		ПолноеИмяМетаданного = МетаданныеОбъектаВизирования.ПолноеИмя();
		
		Если МетаданныеОбъектаВизирования.ТабличныеЧасти.Найти("Распределение") <> Неопределено
			И МетаданныеОбъектаВизирования.ТабличныеЧасти.Распределение.Реквизиты.Найти("СтатьяОборотов") <> Неопределено
			И МетаданныеОбъектаВизирования.ТабличныеЧасти.Распределение.Реквизиты.Найти("ЦФО") <> Неопределено Тогда
			
			Если НужноОбъединение Тогда
				ТекстЗапросаСмешанныхПолей = ТекстЗапросаСмешанныхПолей + ОбъединитьВсе();
			КонецЕсли;
			
			ТекстЗапросаСмешанныхПолей = ТекстЗапросаСмешанныхПолей +
			"ВЫБРАТЬ
			|	ТЧВизы.Ссылка КАК ОбъектВизирования,
			|	ТЧВизы.СтатьяОборотов КАК СтатьяОборотовСмешанная,
			|	ТЧВизы.ЦФО КАК ЦФОСмешанная,
			|	ОтборныеВизы.Виза КАК ВизаСмешанная 
			|ИЗ
			|	ОтборныеВизы КАК ОтборныеВизы
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ " + ПолноеИмяМетаданного + ".Распределение КАК ТЧВизы
			|		ПО ОтборныеВизы.ОбъектВизирования = ТЧВизы.Ссылка";
			
		ИначеЕсли ПолноеИмяМетаданного = "Документ.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию"
			ИЛИ ПолноеИмяМетаданного = "Документ.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств"
			ИЛИ ПолноеИмяМетаданного = "Документ.бит_кзн_ЗаявкаНаРасходованиеСредств" Тогда
			
			Если ВключеныПлатежныеПозиции Тогда
				Продолжить;
			КонецЕсли;
			
			Если НужноОбъединение Тогда
				ТекстЗапросаСмешанныхПолей = ТекстЗапросаСмешанныхПолей + ОбъединитьВсе();
			КонецЕсли;
			
			ТекстЗапросаСмешанныхПолей = ТекстЗапросаСмешанныхПолей +
			"ВЫБРАТЬ
			|	ОтборныеВизы.ОбъектВизирования КАК ОбъектВизирования,
			|	ПлатежнаяПозиция.СтатьяОборотов КАК СтатьяОборотовСмешанная,
			|	ПлатежнаяПозиция.ЦФО КАК ЦФОСмешанная,
			|	ОтборныеВизы.Виза КАК ВизаСмешанная 
			|ИЗ
			|	ОтборныеВизы КАК ОтборныеВизы
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПозиция
			|		ПО ОтборныеВизы.ОбъектВизирования = ПлатежнаяПозиция.ДокументПланирования
			|			И (НЕ ПлатежнаяПозиция.ПометкаУдаления)";
			
			ВключеныПлатежныеПозиции = Истина;
			
		ИначеЕсли ПолноеИмяМетаданного = "Документ.бит_мто_ЗаявкаНаЗакупку"
			ИЛИ ПолноеИмяМетаданного = "Документ.бит_мто_ЗаявкаНаПотребность" Тогда
			
			Если НужноОбъединение Тогда
				ТекстЗапросаСмешанныхПолей = ТекстЗапросаСмешанныхПолей + ОбъединитьВсе();
			КонецЕсли;
			
			ТекстЗапросаСмешанныхПолей = ТекстЗапросаСмешанныхПолей +
			"ВЫБРАТЬ
			|	ТЧТовары.Ссылка КАК ОбъектВизирования,
			|	ТЧТовары.СтатьяОборотов КАК СтатьяОборотовСмешанная,
			|	ТЧТовары.ЦФО КАК ЦФОСмешанная,
			|	ОтборныеВизы.Виза КАК ВизаСмешанная 
			|ИЗ
			|	ОтборныеВизы КАК ОтборныеВизы
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ " + ПолноеИмяМетаданного + ".Товары КАК ТЧТовары
			|		ПО ОтборныеВизы.ОбъектВизирования = ТЧТовары.Ссылка
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ТЧУслуги.Ссылка КАК ОбъектВизирования,
			|	ТЧУслуги.СтатьяОборотов КАК СтатьяОборотовСмешанная,
			|	ТЧУслуги.ЦФО КАК ЦФОСмешанная,
			|	ОтборныеВизы.Виза КАК ВизаСмешанная 
			|ИЗ
			|	ОтборныеВизы КАК ОтборныеВизы
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ " + ПолноеИмяМетаданного + ".Услуги КАК ТЧУслуги
			|		ПО ОтборныеВизы.ОбъектВизирования = ТЧУслуги.Ссылка
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ТЧОборудование.Ссылка КАК ОбъектВизирования,
			|	ТЧОборудование.СтатьяОборотов КАК СтатьяОборотовСмешанная,
			|	ТЧОборудование.ЦФО КАК ЦФОСмешанная,
			|	ОтборныеВизы.Виза КАК ВизаСмешанная 
			|ИЗ
			|	ОтборныеВизы КАК ОтборныеВизы
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ " + ПолноеИмяМетаданного + ".Оборудование КАК ТЧОборудование
			|		ПО ОтборныеВизы.ОбъектВизирования = ТЧОборудование.Ссылка";
			
		Иначе
			
			Если НужноОбъединение Тогда
				ТекстЗапросаСмешанныхПолей = ТекстЗапросаСмешанныхПолей + ОбъединитьВсе();
			КонецЕсли;
			
			ЕстьСтатья = МетаданныеОбъектаВизирования.Реквизиты.Найти("СтатьяОборотов") <> Неопределено;
			ЕстьЦФО    = МетаданныеОбъектаВизирования.Реквизиты.Найти("ЦФО") <> Неопределено;
			
			ТекстШаблонаЗапросаСмешанныхПолей =
			"ВЫБРАТЬ
			|	&ОбъектВизирования КАК ОбъектВизирования,
			|	&СтатьяОборотов КАК СтатьяОборотовСмешанная,
			|	&ЦФО КАК ЦФОСмешанная,
			|	ОтборныеВизы.Виза КАК ВизаСмешанная
			|ИЗ
			|	ОтборныеВизы КАК ОтборныеВизы
			|ГДЕ
			|	ОтборныеВизы.ОбъектВизирования ССЫЛКА &ВидОбъекта";
			
			ТекстПриведенияТипа = "ВЫРАЗИТЬ(ОтборныеВизы.ОбъектВизирования КАК %1)";
			ТекстПриведенияТипа = СтрШаблон(ТекстПриведенияТипа, ПолноеИмяМетаданного);
			
			ТекстШаблонаЗапросаСмешанныхПолей = СтрЗаменить(ТекстШаблонаЗапросаСмешанныхПолей, "&ОбъектВизирования", ТекстПриведенияТипа);
															
			ТекстПодстановки = "НЕОПРЕДЕЛЕНО";
			Если ЕстьСтатья Тогда
				ТекстПодстановки = ТекстПриведенияТипа + ".СтатьяОборотов";
			КонецЕсли;
			ТекстШаблонаЗапросаСмешанныхПолей = СтрЗаменить(ТекстШаблонаЗапросаСмешанныхПолей, "&СтатьяОборотов", ТекстПодстановки);
			
			ТекстПодстановки = "НЕОПРЕДЕЛЕНО";
			Если ЕстьЦФО Тогда
				ТекстПодстановки = ТекстПриведенияТипа + ".ЦФО";
			КонецЕсли;
			ТекстШаблонаЗапросаСмешанныхПолей = СтрЗаменить(ТекстШаблонаЗапросаСмешанныхПолей, "&ЦФО", ТекстПодстановки);
			
			ТекстШаблонаЗапросаСмешанныхПолей = СтрЗаменить(ТекстШаблонаЗапросаСмешанныхПолей, "&ВидОбъекта", ПолноеИмяМетаданного);
			
			ТекстЗапросаСмешанныхПолей = ТекстЗапросаСмешанныхПолей + ТекстШаблонаЗапросаСмешанныхПолей;
			
		КонецЕсли;
		
		НужноОбъединение = Истина;
		
	КонецЦикла;
	
	Если ПустаяСтрока(ТекстЗапросаСмешанныхПолей) Тогда
		ТекстЗапросаСмешанныхПолей =
		"ВЫБРАТЬ
		|	НЕОПРЕДЕЛЕНО КАК ОбъектВизирования,
		|	НЕОПРЕДЕЛЕНО КАК СтатьяОборотовСмешанная,
		|	НЕОПРЕДЕЛЕНО КАК ЦФОСмешанная,
		|	НЕОПРЕДЕЛЕНО КАК ВизаСмешанная";
	КонецЕсли;
	
	ТекстЗапросаСмешанныхПолей = "ВЫБРАТЬ РАЗРЕШЕННЫЕ" + Сред(ТекстЗапросаСмешанныхПолей, 8);
	
	Возврат ТекстЗапросаСмешанныхПолей;
	
КонецФункции

Функция ОбъединитьВсе()
	
	Возврат "
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|";
	
КонецФункции

Функция НаложитьОтборыРолевойАдресации(Запрос, ПараметрыПолучения)
	
	Если ПараметрыПолучения.РежимАрхива ИЛИ ПараметрыПолучения.РежимПолученияРеквизитов Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ОтборныеВизы.ОбъектВизирования КАК ОбъектВизирования,
	|	ОтборныеВизы.Виза КАК Виза
	|ПОМЕСТИТЬ ОграниченныеВизы
	|ИЗ
	|	ОтборныеВизы КАК ОтборныеВизы
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтборныеВизы.ОбъектВизирования,
	|	ОтборныеВизы.Виза
	|
	|ИМЕЮЩИЕ
	|	МАКСИМУМ(ОтборныеВизы.ПолныйДоступ) = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОтборныеВизы.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
	|	ОтборныеВизы.УсловиеДоступа КАК УсловиеДоступа,
	|	ОтборныеВизы.ОбъектВизирования КАК ОбъектВизирования,
	|	ОтборныеВизы.Виза КАК Виза
	|ПОМЕСТИТЬ УсловияРолевыхОграничений
	|ИЗ
	|	ОтборныеВизы КАК ОтборныеВизы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОграниченныеВизы КАК ОграниченныеВизы
	|		ПО ОтборныеВизы.ОбъектВизирования = ОграниченныеВизы.ОбъектВизирования
	|			И ОтборныеВизы.Виза = ОграниченныеВизы.Виза
	|			И (ОтборныеВизы.УсловиеДоступа.ВидПользовательскогоУсловия = ЗНАЧЕНИЕ(Перечисление.бит_ВидыПользовательскихУсловий.РолеваяАдресация))
	|			И (&УсловиеОсобыеОбъектыПроверки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ОграниченныеВизы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИсполнителиЗадач.РольИсполнителя КАК РольИсполнителя,
	|	ИсполнителиЗадач.ОбъектАдресации_1 КАК ОбъектАдресации_1,
	|	ИсполнителиЗадач.ОбъектАдресации_2 КАК ОбъектАдресации_2,
	|	ИсполнителиЗадач.ОбъектАдресации_3 КАК ОбъектАдресации_3,
	|	АВТОНОМЕРЗАПИСИ() КАК КлючЗаписи
	|ПОМЕСТИТЬ ИсполнителиЗадач
	|ИЗ
	|	РегистрСведений.бит_ИсполнителиЗадач КАК ИсполнителиЗадач
	|ГДЕ
	|	ИсполнителиЗадач.Исполнитель = &Ответственный
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УсловияРолевыхОграничений.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
	|	УсловияРолевыхОграничений.УсловиеДоступа КАК УсловиеДоступа,
	|	РолеваяАдресацияУсловий.РольИсполнителя КАК РольИсполнителя,
	|	УсловияРолевыхОграничений.ОбъектВизирования КАК ОбъектВизирования,
	|	ИсполнителиЗадач.ОбъектАдресации_1 КАК ОбъектАдресации_1,
	|	ИсполнителиЗадач.ОбъектАдресации_2 КАК ОбъектАдресации_2,
	|	ИсполнителиЗадач.ОбъектАдресации_3 КАК ОбъектАдресации_3,
	|	ИсполнителиЗадач.КлючЗаписи КАК КлючЗаписиАдресации
	|ПОМЕСТИТЬ МатрицаОбъектовАдресации
	|ИЗ
	|	УсловияРолевыхОграничений КАК УсловияРолевыхОграничений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_ПользовательскиеУсловия.РолеваяАдресация КАК РолеваяАдресацияУсловий
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИсполнителиЗадач КАК ИсполнителиЗадач
	|			ПО РолеваяАдресацияУсловий.РольИсполнителя = ИсполнителиЗадач.РольИсполнителя
	|		ПО УсловияРолевыхОграничений.УсловиеДоступа = РолеваяАдресацияУсловий.Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	РольИсполнителя
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ИсполнителиЗадач
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МатрицаОбъектовАдресации.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
	|	МатрицаОбъектовАдресации.УсловиеДоступа КАК УсловиеДоступа,
	|	МатрицаОбъектовАдресации.РольИсполнителя КАК РольИсполнителя,
	|	МАКСИМУМ(АдресацииРоли.Ссылка ЕСТЬ NULL) КАК БезАдресации,
	|	МАКСИМУМ(МатрицаОбъектовАдресации.ОбъектАдресации_1) КАК ОбъектАдресации_1,
	|	МАКСИМУМ(МатрицаОбъектовАдресации.ОбъектАдресации_2) КАК ОбъектАдресации_2,
	|	МАКСИМУМ(МатрицаОбъектовАдресации.ОбъектАдресации_3) КАК ОбъектАдресации_3,
	|	МАКСИМУМ(АдресацииРоли.Имя) КАК ПолеРеквизитаАдресации,
	|	АдресацииРоли.Вид КАК ВидОбъектаАдресации,
	|	АдресацииРоли.Вид.Код КАК ИмяВидаАдресации,
	|	АдресацииРоли.Вид.СпособПроверкиПринадлежности КАК СпособПроверкиАдресации
	|ИЗ
	|	МатрицаОбъектовАдресации КАК МатрицаОбъектовАдресации
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_РолиИсполнителей.ОбъектыАдресации КАК АдресацииРоли
	|		ПО МатрицаОбъектовАдресации.РольИсполнителя = АдресацииРоли.Ссылка
	|			И (АдресацииРоли.Имя = ""ОбъектАдресации_1""
	|				ИЛИ АдресацииРоли.Имя = ""ОбъектАдресации_2""
	|				ИЛИ АдресацииРоли.Имя = ""ОбъектАдресации_3"")
	|
	|СГРУППИРОВАТЬ ПО
	|	МатрицаОбъектовАдресации.ТипОбъектаВизирования,
	|	МатрицаОбъектовАдресации.УсловиеДоступа,
	|	МатрицаОбъектовАдресации.РольИсполнителя,
	|	АдресацииРоли.Вид,
	|	АдресацииРоли.Вид.Код,
	|	АдресацииРоли.Вид.СпособПроверкиПринадлежности
	|ИТОГИ ПО
	|	ТипОбъектаВизирования,
	|	УсловиеДоступа,
	|	РольИсполнителя";
	
	Если бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
		ТекстУсловиеОсобыеОбъектыПроверки = "ОтборныеВизы.ТипОбъектаВизирования <> ТИП(Документ.бит_кзн_ЗаявкаНаРасходованиеСредств)
											|	И ОтборныеВизы.ТипОбъектаВизирования <> ТИП(Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств)
											|	И ОтборныеВизы.ТипОбъектаВизирования <> ТИП(Документ.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств)";
	Иначе
		ТекстУсловиеОсобыеОбъектыПроверки = "ИСТИНА";
	КонецЕсли;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловиеОсобыеОбъектыПроверки", ТекстУсловиеОсобыеОбъектыПроверки);
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ответственный", ПараметрыПолучения.Ответственный);
	
	ВыборкаТипов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	КоличествоРезультатовПроверок = 0;
	Пока ВыборкаТипов.Следующий() Цикл
		
		ПустаяСсылкаНаОбъект          = ПустоеЗначениеТипа(ВыборкаТипов.ТипОбъектаВизирования);
		МетаданныеОбъектаВизирования  = ПустаяСсылкаНаОбъект.Метаданные();
		ПолноеИмяМетаданного          = МетаданныеОбъектаВизирования.ПолноеИмя();
		ВыборкаУсловий                = ВыборкаТипов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаУсловий.Следующий() Цикл
			ВыборкаРолей = ВыборкаУсловий.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			КоличествоУсловийДоступа = 0;
			Пока ВыборкаРолей.Следующий() Цикл
				
				КоличествоРезультатовПроверок = КоличествоРезультатовПроверок + 1;
				КоличествоУсловийДоступа      = КоличествоУсловийДоступа + 1;
				
				ПодзапросПроверкаАдресации = Новый Запрос;
				ПодзапросПроверкаАдресации.МенеджерВременныхТаблиц = Запрос.МенеджерВременныхТаблиц;
				ТекстЗапросаПроверкиАдресации =
				"ВЫБРАТЬ
				|	МатрицаОбъектовАдресации.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
				|	МатрицаОбъектовАдресации.УсловиеДоступа КАК УсловиеДоступа,
				|	&ПолеОбъектВизирования КАК ОбъектВизирования,
				|	МатрицаОбъектовАдресации.РольИсполнителя КАК РольИсполнителя,
				|	МатрицаОбъектовАдресации.ОбъектАдресации_1 КАК ОбъектАдресации_1,
				|	МатрицаОбъектовАдресации.ОбъектАдресации_2 КАК ОбъектАдресации_2,
				|	МатрицаОбъектовАдресации.ОбъектАдресации_3 КАК ОбъектАдресации_3,
				|	МатрицаОбъектовАдресации.КлючЗаписиАдресации КАК КлючЗаписиАдресации
				|ПОМЕСТИТЬ ОбъектыПроверки
				|ИЗ
				|	МатрицаОбъектовАдресации КАК МатрицаОбъектовАдресации
				|ГДЕ
				|	МатрицаОбъектовАдресации.ТипОбъектаВизирования = &ТипОбъектаВизирования
				|	И МатрицаОбъектовАдресации.РольИсполнителя     = &РольИсполнителя
				|	И МатрицаОбъектовАдресации.УсловиеДоступа      = &УсловиеДоступа";
				ТекстЗапросаПроверкиАдресации = СтрЗаменить(ТекстЗапросаПроверкиАдресации
															, "&ПолеОбъектВизирования"
															, "ВЫРАЗИТЬ(МатрицаОбъектовАдресации.ОбъектВизирования КАК "
															+ ПолноеИмяМетаданного + ")");
				ПодзапросПроверкаАдресации.УстановитьПараметр("ТипОбъектаВизирования", ВыборкаРолей.ТипОбъектаВизирования);
				ПодзапросПроверкаАдресации.УстановитьПараметр("РольИсполнителя"      , ВыборкаРолей.РольИсполнителя);
				ПодзапросПроверкаАдресации.УстановитьПараметр("УсловиеДоступа"       , ВыборкаРолей.УсловиеДоступа);
				ТекстЗапросаПроверкиАдресации = ТекстЗапросаПроверкиАдресации + ОбщегоНазначения.РазделительПакетаЗапросов();
				
				// Роль исполнителя может содержать до 3х измерений адресации,
				//  для доступа должно выполняться сопоставление объектов визирования по всем измерениям.
				ВыборкаВидовАдресации = ВыборкаРолей.Выбрать();
				
				КоличествоВидовАдресации = 0;
				Пока ВыборкаВидовАдресации.Следующий() Цикл
					
					КоличествоВидовАдресации = КоличествоВидовАдресации + 1;
					
					ИмяПоляПроверки = ВыборкаВидовАдресации.ИмяВидаАдресации;
					СпособПроверки  = ВыборкаВидовАдресации.СпособПроверкиАдресации;
					
					ПроверятьШапку    = ?(СпособПроверки = Перечисления.бит_СпособыПроверкиПринадлежностиОбъектаАдресации.Шапка
											ИЛИ СпособПроверки = Перечисления.бит_СпособыПроверкиПринадлежностиОбъектаАдресации.ШапкаТабличныеЧасти
											, Истина, Ложь);
					ПроверятьТабЧасть = ?(СпособПроверки = Перечисления.бит_СпособыПроверкиПринадлежностиОбъектаАдресации.ТабличныеЧасти
											ИЛИ СпособПроверки = Перечисления.бит_СпособыПроверкиПринадлежностиОбъектаАдресации.ШапкаТабличныеЧасти
											, Истина, Ложь);
					// В рамках проверки поля адресации значение может присутствовать в шапке или строке одной из табличных частей,
					//  в соответствии со способом проверки.
					
					КоличествоОбластейПоиска = 0;
					ТекстПроверкиРеквизита   = "";
					Если ПроверятьШапку Тогда
						Если бит_РаботаСМетаданными.ЕстьРеквизит(ИмяПоляПроверки, МетаданныеОбъектаВизирования) Тогда
							КоличествоОбластейПоиска = КоличествоОбластейПоиска + 1;
							ТекстПроверкиРеквизита   = ТекстПроверкиРеквизита +
							"ВЫБРАТЬ
							|	ОбъектыПроверки.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
							|	ОбъектыПроверки.УсловиеДоступа КАК УсловиеДоступа,
							|	ОбъектыПроверки.ОбъектВизирования КАК ОбъектВизирования,
							|	ОбъектыПроверки.РольИсполнителя КАК РольИсполнителя,
							|	ОбъектыПроверки.КлючЗаписиАдресации КАК КлючЗаписиАдресации
							|ПОМЕСТИТЬ БлокПроверкиВидаАдресации
							|ИЗ
							|	ОбъектыПроверки КАК ОбъектыПроверки
							|ГДЕ
							|	&ПолеПроверкиРеквизита = &ПолеРеквизитаАдресации";
							ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита
																, "&ПолеПроверкиРеквизита"
																, "ОбъектыПроверки.ОбъектВизирования." + ИмяПоляПроверки);
							ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита
																, "&ПолеРеквизитаАдресации"
																, "ОбъектыПроверки." + ВыборкаВидовАдресации.ПолеРеквизитаАдресации);
						Иначе
							Если УправлениеСвойствами.ИспользоватьДопРеквизиты(ПустаяСсылкаНаОбъект) Тогда
								КоличествоОбластейПоиска = КоличествоОбластейПоиска + 1;
								ТекстПроверкиРеквизита   = ТекстПроверкиРеквизита +
								"ВЫБРАТЬ
								|	ОбъектыПроверки.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
								|	ОбъектыПроверки.УсловиеДоступа КАК УсловиеДоступа,
								|	ОбъектыПроверки.ОбъектВизирования КАК ОбъектВизирования,
								|	ОбъектыПроверки.РольИсполнителя КАК РольИсполнителя,
								|	ОбъектыПроверки.КлючЗаписиАдресации КАК КлючЗаписиАдресации
								|ПОМЕСТИТЬ БлокПроверкиВидаАдресации
								|ИЗ
								|	&ДополнительныеРеквизиты КАК ТЧДополнительныеРеквизиты
								|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
								|		ПО ТЧДополнительныеРеквизиты.Свойство = ДополнительныеРеквизитыИСведения.Ссылка
								|			И (ДополнительныеРеквизитыИСведения.Имя = ""&ИмяРеквизита"")
								|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОбъектыПроверки КАК ОбъектыПроверки
								|		ПО ТЧДополнительныеРеквизиты.Ссылка = ОбъектыПроверки.ОбъектВизирования
								|ГДЕ
								|	ТЧДополнительныеРеквизиты.Значение = &ПолеРеквизитаАдресации";
	                            ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита
																	, "&ДополнительныеРеквизиты"
																	, ПолноеИмяМетаданного + ".ДополнительныеРеквизиты");
								ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита
																	, "&ИмяРеквизита"
																	, ИмяПоляПроверки);
								ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита
																	, "&ПолеРеквизитаАдресации"
																	, "ОбъектыПроверки." + ВыборкаВидовАдресации.ПолеРеквизитаАдресации);
							КонецЕсли;
							Если УправлениеСвойствами.ИспользоватьДопСведения(ПустаяСсылкаНаОбъект) Тогда
								КоличествоОбластейПоиска = КоличествоОбластейПоиска + 1;
								Если КоличествоОбластейПоиска > 1 Тогда
									ТекстПроверкиРеквизита = ТекстПроверкиРеквизита +
									"
									|
									|ОБЪЕДИНИТЬ
									|
									|";
								КонецЕсли;
								ТекстПроверкиРеквизита   = ТекстПроверкиРеквизита +
								"ВЫБРАТЬ
								|	ОбъектыПроверки.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
								|	ОбъектыПроверки.УсловиеДоступа КАК УсловиеДоступа,
								|	ОбъектыПроверки.ОбъектВизирования КАК ОбъектВизирования,
								|	ОбъектыПроверки.РольИсполнителя КАК РольИсполнителя,
								|	ОбъектыПроверки.КлючЗаписиАдресации КАК КлючЗаписиАдресации";
								Если КоличествоОбластейПоиска = 1 Тогда
									ТекстПроверкиРеквизита = ТекстПроверкиРеквизита +
									"
									|ПОМЕСТИТЬ БлокПроверкиВидаАдресации";
								КонецЕсли;
								ТекстПроверкиРеквизита = ТекстПроверкиРеквизита +
								"
								|ИЗ
								|	РегистрСведений.ДополнительныеСведения КАК ТаблицаСвойств
								|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
								|		ПО ТаблицаСвойств.Свойство = ДополнительныеРеквизитыИСведения.Ссылка
								|			И (ДополнительныеРеквизитыИСведения.Имя = ""&ИмяРеквизита"")
								|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОбъектыПроверки КАК ОбъектыПроверки
								|		ПО ТаблицаСвойств.Объект = ОбъектыПроверки.ОбъектВизирования
								|ГДЕ
								|	ТаблицаСвойств.Значение = &ПолеРеквизитаАдресации";
	                            ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита
																	, "&ИмяРеквизита"
																	, ИмяПоляПроверки);
								ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита
																	, "&ПолеРеквизитаАдресации"
																	, "ОбъектыПроверки." + ВыборкаВидовАдресации.ПолеРеквизитаАдресации);
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
					
					Если ПроверятьТабЧасть Тогда
						Для каждого ТабЧастьОбъекта Из МетаданныеОбъектаВизирования.ТабличныеЧасти Цикл
							Если бит_РаботаСМетаданными.ЕстьРеквизитТабЧасти(ИмяПоляПроверки
																			, МетаданныеОбъектаВизирования
																			, ТабЧастьОбъекта.Имя) Тогда
								КоличествоОбластейПоиска = КоличествоОбластейПоиска + 1;
								Если КоличествоОбластейПоиска > 1 Тогда
									ТекстПроверкиРеквизита = ТекстПроверкиРеквизита +
									"
									|
									|ОБЪЕДИНИТЬ
									|
									|";
								КонецЕсли;
								
								ТекстПроверкиРеквизита = ТекстПроверкиРеквизита +
								"ВЫБРАТЬ
								|	ОбъектыПроверки.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
								|	ОбъектыПроверки.УсловиеДоступа КАК УсловиеДоступа,
								|	ОбъектыПроверки.ОбъектВизирования КАК ОбъектВизирования,
								|	ОбъектыПроверки.РольИсполнителя КАК РольИсполнителя,
								|	ОбъектыПроверки.КлючЗаписиАдресации КАК КлючЗаписиАдресации";
								Если КоличествоОбластейПоиска = 1 Тогда
									ТекстПроверкиРеквизита = ТекстПроверкиРеквизита +
									"
									|ПОМЕСТИТЬ БлокПроверкиВидаАдресации";
								КонецЕсли;
								ТекстПроверкиРеквизита = ТекстПроверкиРеквизита +
								"
								|ИЗ
								|	ОбъектыПроверки КАК ОбъектыПроверки
								|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПутьКТабличнойЧасти КАК ТабличнаяЧастьОбъекта
								|		ПО ОбъектыПроверки.ОбъектВизирования = ТабличнаяЧастьОбъекта.Ссылка
								|			И (&ПолеПроверкиРеквизита = &ПолеРеквизитаАдресации)";
								ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита
																	, "ПутьКТабличнойЧасти"
																	, ПолноеИмяМетаданного + "." + ТабЧастьОбъекта.Имя);
								ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита
																	, "&ПолеПроверкиРеквизита"
																	, "ТабличнаяЧастьОбъекта." + ИмяПоляПроверки);
								ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита
																	, "&ПолеРеквизитаАдресации"
																	, "ОбъектыПроверки." + ВыборкаВидовАдресации.ПолеРеквизитаАдресации);
							КонецЕсли;
						КонецЦикла;
					КонецЕсли;
					
					Если ВыборкаВидовАдресации.БезАдресации Тогда
						// Справочник бит_РолиИсполнителей не содержит ролей адресации.
						ТекстПроверкиРеквизита =
						"ВЫБРАТЬ
						|	ОбъектыПроверки.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
						|	ОбъектыПроверки.УсловиеДоступа КАК УсловиеДоступа,
						|	ОбъектыПроверки.ОбъектВизирования КАК ОбъектВизирования,
						|	ОбъектыПроверки.РольИсполнителя КАК РольИсполнителя,
						|	ОбъектыПроверки.КлючЗаписиАдресации КАК КлючЗаписиАдресации
						|ПОМЕСТИТЬ БлокПроверкиВидаАдресации
						|ИЗ
						|	ОбъектыПроверки КАК ОбъектыПроверки";
					ИначеЕсли ПустаяСтрока(ТекстПроверкиРеквизита) Тогда
						// Ни реквизиты шапки, ни реквизиты ТЧ не содержат атрибутов адресации.
						ТекстПроверкиРеквизита =
						"ВЫБРАТЬ
						|	ОбъектыПроверки.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
						|	ОбъектыПроверки.УсловиеДоступа КАК УсловиеДоступа,
						|	ОбъектыПроверки.ОбъектВизирования КАК ОбъектВизирования,
						|	ОбъектыПроверки.РольИсполнителя КАК РольИсполнителя,
						|	ОбъектыПроверки.КлючЗаписиАдресации КАК КлючЗаписиАдресации
						|ПОМЕСТИТЬ БлокПроверкиВидаАдресации
						|ИЗ
						|	ОбъектыПроверки КАК ОбъектыПроверки
						|ГДЕ
						|	ЛОЖЬ";
					КонецЕсли;
					
					ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита
														, "БлокПроверкиВидаАдресации"
														, "БлокПроверкиВидаАдресации" + КоличествоВидовАдресации);
					Если КоличествоОбластейПоиска = 1 Тогда
						ТекстПроверкиРеквизита = СтрЗаменить(ТекстПроверкиРеквизита, "ВЫБРАТЬ", "ВЫБРАТЬ РАЗЛИЧНЫЕ");
					КонецЕсли;
					
					ТекстЗапросаПроверкиАдресации = ТекстЗапросаПроверкиАдресации + ТекстПроверкиРеквизита;
					ТекстЗапросаПроверкиАдресации = ТекстЗапросаПроверкиАдресации + ОбщегоНазначения.РазделительПакетаЗапросов();
					
				КонецЦикла;
				
				ТекстЗапросаПроверкиАдресации = ТекстЗапросаПроверкиАдресации +
				"ВЫБРАТЬ
				|	ОбъектыПроверки.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
				|	ОбъектыПроверки.УсловиеДоступа КАК УсловиеДоступа,
				|	ОбъектыПроверки.ОбъектВизирования КАК ОбъектВизирования,
				|	ОбъектыПроверки.РольИсполнителя КАК РольИсполнителя
				|ПОМЕСТИТЬ РезультатПроверки" + Формат(КоличествоРезультатовПроверок, "ЧГ=") + "
				|ИЗ
				|	ОбъектыПроверки КАК ОбъектыПроверки";
				Для Сч = 1 По КоличествоВидовАдресации Цикл
					ПодстрокаФильтрации = "
					|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ БлокПроверкиВидаАдресации КАК БлокПроверкиВидаАдресации
					|	ПО ОбъектыПроверки.ТипОбъектаВизирования = БлокПроверкиВидаАдресации.ТипОбъектаВизирования
					|		И ОбъектыПроверки.УсловиеДоступа = БлокПроверкиВидаАдресации.УсловиеДоступа
					|		И ОбъектыПроверки.ОбъектВизирования = БлокПроверкиВидаАдресации.ОбъектВизирования
					|		И ОбъектыПроверки.РольИсполнителя = БлокПроверкиВидаАдресации.РольИсполнителя
					|		И ОбъектыПроверки.КлючЗаписиАдресации = БлокПроверкиВидаАдресации.КлючЗаписиАдресации";
					ПодстрокаФильтрации = СтрЗаменить(ПодстрокаФильтрации
														, "БлокПроверкиВидаАдресации"
														, "БлокПроверкиВидаАдресации" + Формат(Сч, "ЧГ="));
					ТекстЗапросаПроверкиАдресации = ТекстЗапросаПроверкиАдресации + ПодстрокаФильтрации;
				КонецЦикла;
				ТекстЗапросаПроверкиАдресации = ТекстЗапросаПроверкиАдресации + ОбщегоНазначения.РазделительПакетаЗапросов();
				ТекстЗапросаПроверкиАдресации = ТекстЗапросаПроверкиАдресации + "УНИЧТОЖИТЬ ОбъектыПроверки";
				Для Сч = 1 По КоличествоВидовАдресации Цикл
					ТекстЗапросаПроверкиАдресации = ТекстЗапросаПроверкиАдресации + ОбщегоНазначения.РазделительПакетаЗапросов();
					ТекстЗапросаПроверкиАдресации = ТекстЗапросаПроверкиАдресации + "УНИЧТОЖИТЬ БлокПроверкиВидаАдресации" + Формат(Сч, "ЧГ=");
				КонецЦикла;
				
				ПодзапросПроверкаАдресации.Текст = ТекстЗапросаПроверкиАдресации;
				ПодзапросПроверкаАдресации.Выполнить();
				
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Если КоличествоРезультатовПроверок = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТекстРезультатаПроверки = "";
	ТекстСтрокаДеструктора  = "";
	Для НомерРезультата = 1 По КоличествоРезультатовПроверок Цикл
		НомерРезультатаСтрокой = Формат(НомерРезультата, "ЧГ=");
		
		Если НомерРезультата > 1 Тогда
			ТекстРезультатаПроверки = ТекстРезультатаПроверки +
			"
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|";
		КонецЕсли;
			
		ТекстРезультатаПроверки = ТекстРезультатаПроверки +
		"ВЫБРАТЬ
		|	РезультатПроверки.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
		|	РезультатПроверки.УсловиеДоступа КАК УсловиеДоступа,
		|	РезультатПроверки.ОбъектВизирования КАК ОбъектВизирования,
		|	РезультатПроверки.РольИсполнителя КАК РольИсполнителя";
		Если НомерРезультата = 1 Тогда
			ТекстРезультатаПроверки = ТекстРезультатаПроверки +
			"
			|ПОМЕСТИТЬ РезультатПроверки";
		КонецЕсли;
		ТекстРезультатаПроверки = ТекстРезультатаПроверки +
		"
		|ИЗ
		|	РезультатПроверки" + НомерРезультатаСтрокой + " КАК РезультатПроверки";
		
		ТекстСтрокаДеструктора =  ОбщегоНазначения.РазделительПакетаЗапросов() +
		"УНИЧТОЖИТЬ РезультатПроверки" + НомерРезультатаСтрокой;
	КонецЦикла;
	
	ТекстРезультатаПроверки = ТекстРезультатаПроверки + ОбщегоНазначения.РазделительПакетаЗапросов();
	ТекстРезультатаПроверки = ТекстРезультатаПроверки +
	"ВЫБРАТЬ
	|	УсловияРолевыхОграничений.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
	|	УсловияРолевыхОграничений.УсловиеДоступа КАК УсловиеДоступа,
	|	УсловияРолевыхОграничений.ОбъектВизирования КАК ОбъектВизирования,
	|	УсловияРолевыхОграничений.Виза КАК Виза,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА РезультатПроверки.ОбъектВизирования ЕСТЬ NULL
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ) КАК ДоступРолевойАдресации
	|ПОМЕСТИТЬ РезультатПроверкиРолевойАдресации
	|ИЗ
	|	УсловияРолевыхОграничений КАК УсловияРолевыхОграничений
	|		ЛЕВОЕ СОЕДИНЕНИЕ РезультатПроверки КАК РезультатПроверки
	|		ПО УсловияРолевыхОграничений.ТипОбъектаВизирования = РезультатПроверки.ТипОбъектаВизирования
	|			И УсловияРолевыхОграничений.УсловиеДоступа = РезультатПроверки.УсловиеДоступа
	|			И УсловияРолевыхОграничений.ОбъектВизирования = РезультатПроверки.ОбъектВизирования
	|
	|СГРУППИРОВАТЬ ПО
	|	УсловияРолевыхОграничений.ТипОбъектаВизирования,
	|	УсловияРолевыхОграничений.УсловиеДоступа,
	|	УсловияРолевыхОграничений.ОбъектВизирования,
	|	УсловияРолевыхОграничений.Виза
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ОбъектВизирования";
	ТекстРезультатаПроверки = ТекстРезультатаПроверки + ТекстСтрокаДеструктора;
	ТекстРезультатаПроверки = ТекстРезультатаПроверки + ОбщегоНазначения.РазделительПакетаЗапросов();
	ТекстРезультатаПроверки = ТекстРезультатаПроверки + "УНИЧТОЖИТЬ УсловияРолевыхОграничений";
	
	Запрос.Текст = ТекстРезультатаПроверки;
	Запрос.Выполнить();
	
	Возврат Истина;
	
КонецФункции

// Предназначена для получения пустого значения заданного типа:
//	примитивного, или ссылочного. Используется
//
// Параметры:
//	ЗаданныйТип - Тип - Тип, пустое значение которого нужно получить.
//
Функция ПустоеЗначениеТипа(ЗаданныйТип) Экспорт

	Если ЗаданныйТип = Тип("Число") Тогда
		Возврат 0;

	ИначеЕсли ЗаданныйТип = Тип("Строка") Тогда
		Возврат "";

	ИначеЕсли ЗаданныйТип = Тип("Дата") Тогда
		Возврат '00010101000000';

	ИначеЕсли ЗаданныйТип = Тип("Булево") Тогда
		Возврат Ложь;

	Иначе
		Возврат Новый (ЗаданныйТип);

	КонецЕсли;

КонецФункции

Функция ТекстЗапросаДетальныеЗаписиВиз(ПараметрыПолучения, ОписаниеТиповВиз, ЕстьФильтрыРолевойАдресации)
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОтборныеВизы.ОбъектВизирования КАК ОбъектВизирования
	|ПОМЕСТИТЬ РазличныеОбъектыВизирования
	|ИЗ
	|	ОтборныеВизы КАК ОтборныеВизы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НЕОПРЕДЕЛЕНО КАК ОбъектВизирования,
	|	0 КАК СуммаДокумента,
	|	ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка) КАК ВалютаДокумента,
	|	НЕОПРЕДЕЛЕНО КАК ДоговорКонтрагента,
	|	НЕОПРЕДЕЛЕНО КАК ВидПлана
	|ПОМЕСТИТЬ ДанныеДокументов";
	
	ТипыВиз = ОписаниеТиповВиз.Типы();
	Для каждого ТипВизы Из ТипыВиз Цикл
		МетаданныеВизы = ПустоеЗначениеТипа(ТипВизы).Метаданные();
		
		ТекстЗапросаПоОбъекту = ТекстЗапросаРеквизитовПоДокументуВизирования(МетаданныеВизы);
		Если ТекстЗапросаПоОбъекту = Неопределено Тогда
			Продолжить;
		КонецЕсли;
			
		ТекстЗапроса = ТекстЗапроса + ТекстЗапросаПоОбъекту;
	КонецЦикла;
	
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
	Если ЕстьФильтрыРолевойАдресации Тогда
		ТекстЗапроса = ТекстЗапроса +
		"ВЫБРАТЬ
		|	ОтборныеВизы.ОбъектВизирования КАК ОбъектВизирования,
		|	ОтборныеВизы.Виза КАК Виза,
		|	ОтборныеВизы.ИД КАК ИД,
		|	ОтборныеВизы.ДатаКрайняя КАК ДатаКрайняя,
		|	ОтборныеВизы.ПринятоеРешение КАК ПринятоеРешение,
		|	ОтборныеВизы.ПолныйДоступ КАК ПолныйДоступ,
		|	ОтборныеВизы.УсловиеДоступа КАК УсловиеДоступа,
		|	ОтборныеВизы.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
		|	ЕСТЬNULL(СтатусыОбъектов.Статус, ЗНАЧЕНИЕ(Справочник.бит_СтатусыОбъектов.ПустаяСсылка)) КАК Статус,
		|	ЕСТЬNULL(НаличиеФайлов.ЕстьФайлы, ЛОЖЬ) КАК ЕстьФайлы,
		|	ОтборныеВизы.Организация КАК Организация,
		|	ДанныеДокументов.СуммаДокумента КАК СуммаДокумента,
		|	ДанныеДокументов.ВалютаДокумента КАК ВалютаДокумента,
		|	ДанныеДокументов.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	ВЫБОР
		|		КОГДА ДанныеДокументов.ВалютаДокумента ЕСТЬ NULL
		|			И &УсловиеОбъектРеестрПлатежей ТОГДА
		|			ИСТИНА
		|		ИНАЧЕ
		|			ЛОЖЬ
		|	КОНЕЦ КАК ПересчитатьСумму,
		|	ВЫБОР
		|		КОГДА РезультатПроверкиРолевойАдресации.ОбъектВизирования ЕСТЬ NULL
		|			ТОГДА 0 //Не ролевое пользовательское условие
		|		КОГДА РезультатПроверкиРолевойАдресации.ДоступРолевойАдресации = ЛОЖЬ
		|			ТОГДА 1 //Не доступа по ролям
		|		КОГДА РезультатПроверкиРолевойАдресации.ДоступРолевойАдресации = ИСТИНА
		|			ТОГДА 2 //Доступен по роли
		|	КОНЕЦ КАК ДоступРолевойАдресации,
		|	&МассивПредрасчетныхРеквизитов КАК МассивПредрасчетныхРеквизитов
		|ИЗ
		|	ОтборныеВизы КАК ОтборныеВизы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_СтатусыОбъектов КАК СтатусыОбъектов
		|		ПО ОтборныеВизы.ОбъектВизирования = СтатусыОбъектов.Объект
		|			И (СтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		|		ПО ОтборныеВизы.ОбъектВизирования = НаличиеФайлов.ОбъектСФайлами
		|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеДокументов КАК ДанныеДокументов
		|		ПО ОтборныеВизы.ОбъектВизирования = ДанныеДокументов.ОбъектВизирования
		|		ЛЕВОЕ СОЕДИНЕНИЕ РезультатПроверкиРолевойАдресации КАК РезультатПроверкиРолевойАдресации
		|		ПО ОтборныеВизы.ОбъектВизирования = РезультатПроверкиРолевойАдресации.ОбъектВизирования
		|			И ОтборныеВизы.УсловиеДоступа = РезультатПроверкиРолевойАдресации.УсловиеДоступа
		|			И ОтборныеВизы.Виза = РезультатПроверкиРолевойАдресации.Виза
		|ИТОГИ
		|	МАКСИМУМ(ПолныйДоступ),
		|	МАКСИМУМ(ДоступРолевойАдресации)
		|ПО
		|	ОтборныеВизы.ОбъектВизирования,
		|	ОтборныеВизы.Виза,
		|	ОтборныеВизы.УсловиеДоступа";
	Иначе
		ТекстЗапроса = ТекстЗапроса +
		"ВЫБРАТЬ
		|	ОтборныеВизы.ОбъектВизирования КАК ОбъектВизирования,
		|	ОтборныеВизы.Виза КАК Виза,
		|	ОтборныеВизы.ИД КАК ИД,
		|	ОтборныеВизы.ДатаКрайняя КАК ДатаКрайняя,
		|	ОтборныеВизы.ПринятоеРешение КАК ПринятоеРешение,
		|	ОтборныеВизы.ПолныйДоступ КАК ПолныйДоступ,
		|	ОтборныеВизы.УсловиеДоступа КАК УсловиеДоступа,
		|	ОтборныеВизы.ТипОбъектаВизирования КАК ТипОбъектаВизирования,
		|	ЕСТЬNULL(СтатусыОбъектов.Статус, ЗНАЧЕНИЕ(Справочник.бит_СтатусыОбъектов.ПустаяСсылка)) КАК Статус,
		|	ЕСТЬNULL(НаличиеФайлов.ЕстьФайлы, ЛОЖЬ) КАК ЕстьФайлы,
		|	ОтборныеВизы.Организация КАК Организация,
		|	ДанныеДокументов.СуммаДокумента КАК СуммаДокумента,
		|	ДанныеДокументов.ВалютаДокумента КАК ВалютаДокумента,
		|	ДанныеДокументов.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	ВЫБОР
		|		КОГДА ДанныеДокументов.ВалютаДокумента ЕСТЬ NULL
		|			И &УсловиеОбъектРеестрПлатежей ТОГДА
		|			ИСТИНА
		|		ИНАЧЕ
		|			ЛОЖЬ
		|	КОНЕЦ КАК ПересчитатьСумму,
		|	0 КАК ДоступРолевойАдресации,
		|	&МассивПредрасчетныхРеквизитов КАК МассивПредрасчетныхРеквизитов
		|ИЗ
		|	ОтборныеВизы КАК ОтборныеВизы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_СтатусыОбъектов КАК СтатусыОбъектов
		|		ПО ОтборныеВизы.ОбъектВизирования = СтатусыОбъектов.Объект
		|			И (СтатусыОбъектов.ВидСтатуса = ЗНАЧЕНИЕ(Перечисление.бит_ВидыСтатусовОбъектов.Статус))
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		|		ПО ОтборныеВизы.ОбъектВизирования = НаличиеФайлов.ОбъектСФайлами
		|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеДокументов КАК ДанныеДокументов
		|		ПО ОтборныеВизы.ОбъектВизирования = ДанныеДокументов.ОбъектВизирования
		|ИТОГИ
		|	МАКСИМУМ(ПолныйДоступ),
		|	МАКСИМУМ(ДоступРолевойАдресации)
		|ПО
		|	ОбъектВизирования,
		|	Виза,
		|	УсловиеДоступа";
	КонецЕсли;
	
	НаименованиеРеестра = бит_ОбщегоНазначения.ИмяРеестраПлатежей();
	ТекстЗапроса        = СтрЗаменить(ТекстЗапроса, "&УсловиеОбъектРеестрПлатежей",
						"ОтборныеВизы.ОбъектВизирования ССЫЛКА Документ." + НаименованиеРеестра);
	
	МассивПредрасчетныхРеквизитов = ПредрасчетныеРеквизиты();
	ТекстПолученияРеквизитов      = "";
	Для каждого Реквизит Из МассивПредрасчетныхРеквизитов Цикл
		Если НЕ ПустаяСтрока(ТекстПолученияРеквизитов) Тогда
			ТекстПолученияРеквизитов = ТекстПолученияРеквизитов + ",
			|	";
		КонецЕсли;
		
		ИмяРеквизита = Реквизит.ИмяПоляРезультат;
		ТекстПолученияРеквизитов = ТекстПолученияРеквизитов + "ОтборныеВизы." + ИмяРеквизита + " КАК " + ИмяРеквизита;
	КонецЦикла;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&МассивПредрасчетныхРеквизитов КАК МассивПредрасчетныхРеквизитов",
					ТекстПолученияРеквизитов);
					
	ОбработатьПредставлениеПереопределяемыхОбъектов(ТекстЗапроса, ОписаниеТиповВиз);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаПолейСоединения(ОписаниеТиповВиз)
	
	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ОтборныеВизы.ОбъектВизирования КАК ОбъектВизирования,
		|	ОтборныеВизы.ОбъектВизирования КАК ИсточникПолейСоединения
		|ПОМЕСТИТЬ ОбъектыИсточникиПолейСоединения
		|ИЗ
		|	ОтборныеВизы КАК ОтборныеВизы";
	ИначеЕсли бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ОтборныеВизы.ОбъектВизирования КАК ОбъектВизирования,
		|	ОтборныеВизы.ОбъектВизирования КАК ИсточникПолейСоединения
		|ПОМЕСТИТЬ ОбъектыИсточникиПолейСоединения
		|ИЗ
		|	ОтборныеВизы КАК ОтборныеВизы
		|ГДЕ
		|	НЕ ОтборныеВизы.ОбъектВизирования ССЫЛКА Документ.бит_кзн_ЗаявкаНаРасходованиеСредств
		|	И НЕ ОтборныеВизы.ОбъектВизирования ССЫЛКА Документ.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств
		|	И НЕ ОтборныеВизы.ОбъектВизирования ССЫЛКА Документ.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ОтборныеВизы.ОбъектВизирования,
		|	ПлатежнаяПозиция.Ссылка
		|ИЗ
		|	ОтборныеВизы КАК ОтборныеВизы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежнаяПозиция
		|		ПО ОтборныеВизы.ОбъектВизирования = ПлатежнаяПозиция.ДокументПланирования
		|			И (НЕ ПлатежнаяПозиция.ПометкаУдаления)";
	КонецЕсли;
	
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
	МассивПолейАналитики = ПоляАналитики();
	
	ТипыВиз   = ОписаниеТиповВиз.Типы();
	ПервыйТип = Истина;	
	
	Для каждого ТипВизы Из ТипыВиз Цикл
		
		МетаданныеОбъектаВизирования = ПустоеЗначениеТипа(ТипВизы).Метаданные();
		ПолноеИмяМетаданного         = МетаданныеОбъектаВизирования.ПолноеИмя();
		
		Если бит_ОбщегоНазначения.ЭтоСемействоERP()
			И (ПолноеИмяМетаданного = "Документ.бит_кзн_ЗаявкаНаРасходованиеСредств"
				ИЛИ ПолноеИмяМетаданного = "Документ.бит_кзн_ЗаявкаНаПеремещениеДенежныхСредств"
				ИЛИ ПолноеИмяМетаданного = "Документ.бит_кзн_ЗаявкаНаПереводСредствВДругуюОрганизацию") Тогда
			ИмяИсточника        = "бит_кзн_ПлатежнаяПозиция";
			МетаданныеИсточника = Метаданные.Документы[ИмяИсточника];
			ПолноеИмяИсточника  = "Документ." + ИмяИсточника;
		Иначе
			МетаданныеИсточника = МетаданныеОбъектаВизирования;
			ПолноеИмяИсточника  = ПолноеИмяМетаданного;
		КонецЕсли;
		
		Если ПервыйТип Тогда
			ШаблонВыборки =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ОбъектыИсточникиПолейСоединения.ОбъектВизирования КАК ОбъектВизирования,
			|	ОбъектыИсточникиПолейСоединения.ИсточникПолейСоединения КАК ИсточникПолейСоединения,
			|	&ОтборныеВизыАналитики КАК ОтборныеВизыАналитики
			|ИЗ
			|	ОбъектыИсточникиПолейСоединения КАК ОбъектыИсточникиПолейСоединения
			|ГДЕ
			|	ОбъектыИсточникиПолейСоединения.ОбъектВизирования ССЫЛКА Документ.бит_ФормаВводаБюджета";
		Иначе
			ШаблонВыборки = "
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ОбъектыИсточникиПолейСоединения.ОбъектВизирования КАК ОбъектВизирования,
			|	ОбъектыИсточникиПолейСоединения.ИсточникПолейСоединения КАК ИсточникПолейСоединения,
			|	&ОтборныеВизыАналитики КАК ОтборныеВизыАналитики
			|ИЗ
			|	ОбъектыИсточникиПолейСоединения КАК ОбъектыИсточникиПолейСоединения
			|ГДЕ
			|	ОбъектыИсточникиПолейСоединения.ОбъектВизирования ССЫЛКА Документ.бит_ФормаВводаБюджета";
		КонецЕсли;
		
		ТекстПолученияАналитик      = "";
		Для каждого Аналитика Из МассивПолейАналитики Цикл
			Если НЕ ПустаяСтрока(ТекстПолученияАналитик) Тогда
				ТекстПолученияАналитик = ТекстПолученияАналитик + ",
				|	";
			КонецЕсли;
			
			ИмяАналитики     = Аналитика.Имя;
			СинонимАналитики = Аналитика.Синоним;
			Если НЕ ОбщегоНазначения.ЕстьРеквизитОбъекта(ИмяАналитики, МетаданныеИсточника)
				И НЕ ОбщегоНазначения.ЭтоСтандартныйРеквизит(МетаданныеИсточника.СтандартныеРеквизиты,
																ИмяАналитики) Тогда
				ТекстЗапросаАналитики = "NULL КАК %1";
				ТекстЗапросаАналитики = СтрШаблон(ТекстЗапросаАналитики, СинонимАналитики);
			Иначе
				ТекстЗапросаАналитики = "ВЫРАЗИТЬ(ОбъектыИсточникиПолейСоединения.ИсточникПолейСоединения КАК %1).%2 КАК %3";
				ТекстЗапросаАналитики = СтрШаблон(ТекстЗапросаАналитики, ПолноеИмяИсточника, ИмяАналитики,
													СинонимАналитики);
			КонецЕсли;
			
			ТекстПолученияАналитик = ТекстПолученияАналитик + ТекстЗапросаАналитики;
		КонецЦикла;
		ШаблонВыборки = СтрЗаменить(ШаблонВыборки, "&ОтборныеВизыАналитики КАК ОтборныеВизыАналитики",
							ТекстПолученияАналитик);
		ШаблонВыборки = СтрЗаменить(ШаблонВыборки, "Документ.бит_ФормаВводаБюджета", ПолноеИмяМетаданного);
		ТекстЗапроса  = ТекстЗапроса + ШаблонВыборки;
		
		ПервыйТип     = Ложь;
	КонецЦикла;
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПоляАналитики()
	
	ПоляАналитики = Новый Массив;
	
	Для Сч = 1 По 7 Цикл
		ИмяПоляАналитики = "Аналитика_" + Сч;
		ДобавитьПолеАналитики(ПоляАналитики, ИмяПоляАналитики);
	КонецЦикла;
	
	Если бит_ОбщегоНазначенияПовтИсп.ЭтоСемействоБП() Тогда
		ДобавитьПолеАналитики(ПоляАналитики, "СтатьяОборотов",       "Аналитика_8");
		ДобавитьПолеАналитики(ПоляАналитики, "ЦФО",                  "Аналитика_9");
		ДобавитьПолеАналитики(ПоляАналитики, "Контрагент",           "Аналитика_10");
		ДобавитьПолеАналитики(ПоляАналитики, "ДоговорКонтрагента",   "Аналитика_11");
		ДобавитьПолеАналитики(ПоляАналитики, "Сценарий",             "Аналитика_12");
		ДобавитьПолеАналитики(ПоляАналитики, "НоменклатурнаяГруппа", "Аналитика_13");
		ДобавитьПолеАналитики(ПоляАналитики, "Проект",               "Аналитика_14");
	ИначеЕсли бит_ОбщегоНазначенияПовтИсп.ЭтоСемействоERP() Тогда
		Для Сч = 8 По 12 Цикл
			ИмяПоляАналитики = "Аналитика_" + Сч;
			ДобавитьПолеАналитики(ПоляАналитики, ИмяПоляАналитики);
		КонецЦикла;
		
		ДобавитьПолеАналитики(ПоляАналитики, "ДатаПлан");
		ДобавитьПолеАналитики(ПоляАналитики, "ДатаПланКрайняя");
		ДобавитьПолеАналитики(ПоляАналитики, "ОбъектРасчетов");
		ДобавитьПолеАналитики(ПоляАналитики, "Договор");
	КонецЕсли;
	
	ДобавитьПолеАналитики(ПоляАналитики, "СтатьяОборотов");
	
	Возврат ПоляАналитики;
	
КонецФункции

Процедура ДобавитьПолеАналитики(ПоляАналитики, ИмяАналитики, СинонимАналитики = Неопределено)
	
	Если СинонимАналитики = Неопределено Тогда
		СинонимАналитики = ИмяАналитики;
	КонецЕсли;
	
	СтруктураАналитики = Новый Структура;
	СтруктураАналитики.Вставить("Имя",     ИмяАналитики);
	СтруктураАналитики.Вставить("Синоним", СинонимАналитики);
	
	ПоляАналитики.Добавить(СтруктураАналитики);
	
КонецПроцедуры

Функция ТекстЗапросаРеквизитовПоДокументуВизирования(МетаданныеВизы)
	
	Если Не ПравоДоступа("Чтение", МетаданныеВизы) Тогда
		Возврат "";
	КонецЕсли;
	
	ПолноеИмяМетаданных = МетаданныеВизы.ПолноеИмя();
	
	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		Если ПолноеИмяМетаданных = "Документ.бит_РеестрПлатежей" Тогда
			Возврат ТекстЗапросаРеквизитов_бит_РеестрПлатежей();
		КонецЕсли;
	ИначеЕсли бит_ОбщегоНазначения.ЭтоСемействоERP() Тогда
		Если ПолноеИмяМетаданных = "Документ.бит_кзн_ЗаявкаНаРасходованиеСредств" Тогда
			Возврат ТекстЗапросаРеквизитов_бит_кзн_ЗаявкаНаРасходованиеСредств();
		ИначеЕсли ПолноеИмяМетаданных = "Документ.бит_кзн_РеестрПлатежей" Тогда
			Возврат ТекстЗапросаРеквизитов_бит_кзн_РеестрПлатежей();
		ИначеЕсли ПолноеИмяМетаданных = "Документ.бит_кзн_ПланируемоеПоступлениеДенежныхСредств" Тогда
			Возврат ТекстЗапросаРеквизитов_бит_кзн_ПланируемоеПоступлениеДенежныхСредств();
		КонецЕсли;
	КонецЕсли;
	
	// Варианты возможных реквизитов значений документов отображаются в порядке убывания приоритета их поиска.
	ВариантыРеквизитовСуммы = Новый Массив;
	ВариантыРеквизитовСуммы.Добавить("СуммаДокумента");
	ВариантыРеквизитовСуммы.Добавить("Сумма");
	ВариантыРеквизитовСуммы.Добавить("СуммаВзаиморасчеты");
	ВариантыРеквизитовВалюты = Новый Массив;
	ВариантыРеквизитовВалюты.Добавить("ВалютаДокумента");
	ВариантыРеквизитовВалюты.Добавить("Валюта");
	ВариантыРеквизитовВалюты.Добавить("ВалютаВзаиморасчетов");
	ВариантыРеквизитовДоговора = Новый Массив;
	ВариантыРеквизитовДоговора.Добавить("ДоговорКонтрагента");
	ВариантыРеквизитовДоговора.Добавить("Договор");
	
	ПолеСуммы    = ПутьВыборкиРеквизитаДокументаВизирования(МетаданныеВизы, ВариантыРеквизитовСуммы, "0");
	ПолеВалюты   = ПутьВыборкиРеквизитаДокументаВизирования(МетаданныеВизы, ВариантыРеквизитовВалюты,
						"ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)");
	ПолеДоговора = ПутьВыборкиРеквизитаДокументаВизирования(МетаданныеВизы, ВариантыРеквизитовДоговора, "НЕОПРЕДЕЛЕНО");
	
	ТекстЗапросаПоОбъекту = "
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	МетаОбъектВизирования.Ссылка КАК ОбъектВизирования,
	|	&СуммаДокумента КАК СуммаДокумента,
	|	&ВалютаДокумента КАК ВалютаДокумента,
	|	&ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	НЕОПРЕДЕЛЕНО КАК ВидПлана
	|ИЗ
	|	РазличныеОбъектыВизирования КАК РазличныеОбъектыВизирования
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ИсточникОбъектВизирования КАК МетаОбъектВизирования
	|		ПО РазличныеОбъектыВизирования.ОбъектВизирования = МетаОбъектВизирования.Ссылка";
	
	ТекстЗапросаПоОбъекту = СтрЗаменить(ТекстЗапросаПоОбъекту, "ИсточникОбъектВизирования", МетаданныеВизы.ПолноеИмя());
	ТекстЗапросаПоОбъекту = СтрЗаменить(ТекстЗапросаПоОбъекту, "&СуммаДокумента", ПолеСуммы);
	ТекстЗапросаПоОбъекту = СтрЗаменить(ТекстЗапросаПоОбъекту, "&ВалютаДокумента", ПолеВалюты);
	ТекстЗапросаПоОбъекту = СтрЗаменить(ТекстЗапросаПоОбъекту, "&ДоговорКонтрагента", ПолеДоговора);
	
	Возврат ТекстЗапросаПоОбъекту;
	
КонецФункции

Функция ПутьВыборкиРеквизитаДокументаВизирования(МетаданныеВизы, ВариантыИменРеквизита, ЗначениеПоУмолчанию)
	
	РеквизитыВизируемогоДокумента = МетаданныеВизы.Реквизиты;
	ШаблонПоляПоРеквизиту         = "МетаОбъектВизирования.%1";
	
	Для каждого ВариантРеквизита Из ВариантыИменРеквизита Цикл
		Если РеквизитыВизируемогоДокумента.Найти(ВариантРеквизита) <> Неопределено Тогда
			Возврат СтрШаблон(ШаблонПоляПоРеквизиту, ВариантРеквизита);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЗначениеПоУмолчанию;
	
КонецФункции

Функция ТекстЗапросаРеквизитов_бит_РеестрПлатежей()
	
	// По реестру выводим суммы только в том случае, если все заявки ТЧ указаны в одной валюте.
	
	ТекстЗапросаПоОбъекту = "
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТЧРеестра.Ссылка КАК ОбъектВизирования,
	|	СУММА(ТЧРеестра.Сумма) КАК СуммаДокумента,
	|	МАКСИМУМ(ТЧРеестра.ВалютаДокумента) КАК ВалютаДокумента,
	|	НЕОПРЕДЕЛЕНО КАК ДоговорКонтрагента,
	|	НЕОПРЕДЕЛЕНО КАК ВидПлана
	|ИЗ
	|	РазличныеОбъектыВизирования КАК РазличныеОбъектыВизирования
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_РеестрПлатежей.Заявки КАК ТЧРеестра
	|		ПО РазличныеОбъектыВизирования.ОбъектВизирования = ТЧРеестра.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЧРеестра.Ссылка
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТЧРеестра.ВалютаДокумента) = 1";
	
	Возврат ТекстЗапросаПоОбъекту;
	
КонецФункции

Функция ТекстЗапросаРеквизитов_бит_кзн_ЗаявкаНаРасходованиеСредств()
	
	ТекстЗапросаПоОбъекту = "
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаявкаНаРасходованиеСредств.Ссылка КАК ОбъектВизирования,
	|	СУММА(ПлатежныеПозиции.СуммаДокумента) КАК СуммаДокумента,
	|	МАКСИМУМ(ПлатежныеПозиции.ВалютаДокумента) КАК ВалютаДокумента,
	|	МАКСИМУМ(ПлатежныеПозиции.Договор) КАК ДоговорКонтрагента,
	|	ЗаявкаНаРасходованиеСредств.ВидПлана КАК ВидПлана
	|ИЗ
	|	РазличныеОбъектыВизирования КАК РазличныеОбъектыВизирования
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.бит_кзн_ПлатежнаяПозиция КАК ПлатежныеПозиции
	|		ПО (РазличныеОбъектыВизирования.ОбъектВизирования ССЫЛКА Документ.бит_кзн_ЗаявкаНаРасходованиеСредств)
	|			И РазличныеОбъектыВизирования.ОбъектВизирования = ПлатежныеПозиции.ДокументПланирования
	|			И (НЕ ПлатежныеПозиции.ПометкаУдаления)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_ЗаявкаНаРасходованиеСредств КАК ЗаявкаНаРасходованиеСредств
	|		ПО РазличныеОбъектыВизирования.ОбъектВизирования = ЗаявкаНаРасходованиеСредств.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаявкаНаРасходованиеСредств.Ссылка,
	|	ЗаявкаНаРасходованиеСредств.ВидПлана
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПлатежныеПозиции.ВалютаДокумента) < 2";
	
	Возврат ТекстЗапросаПоОбъекту;
	
КонецФункции

Функция ТекстЗапросаРеквизитов_бит_кзн_РеестрПлатежей()
	
	ТекстЗапросаПоОбъекту = "
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТЧРеестра.Ссылка КАК ОбъектВизирования,
	|	СУММА(ТЧРеестра.СуммаДокумента) КАК СуммаДокумента,
	|	МАКСИМУМ(ТЧРеестра.ВалютаПлатежа) КАК ВалютаДокумента,
	|	НЕОПРЕДЕЛЕНО КАК ДоговорКонтрагента,
	|	НЕОПРЕДЕЛЕНО КАК ВидПлана
	|ИЗ
	|	РазличныеОбъектыВизирования КАК РазличныеОбъектыВизирования
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.бит_кзн_РеестрПлатежей.ТаблицаПлатежи КАК ТЧРеестра
	|		ПО РазличныеОбъектыВизирования.ОбъектВизирования = ТЧРеестра.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЧРеестра.Ссылка
	|
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТЧРеестра.ВалютаПлатежа) = 1";
	
	Возврат ТекстЗапросаПоОбъекту;
	
КонецФункции

