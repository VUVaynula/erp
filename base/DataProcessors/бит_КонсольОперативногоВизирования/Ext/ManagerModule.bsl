// Процедура устанавливает решение в строке.
//
// Параметры:
//  ПараметрыПолучения	 - Структура - см. НовыеПараметрыУстановкиРешенияВСтроке().
//  АдресВХранилище		 - Строка	 - Адрес временного хранилища результата установки решения.
//
Процедура УстановитьРешениеВСтроке(ПараметрыПолучения, АдресВХранилище = "") Экспорт
	
	ПараметрыОтметкиРешения = НовыеПараметрыПринятияРешения();
	ПараметрыОтметкиРешения.Решение     = ПараметрыПолучения.Решение;
	ПараметрыОтметкиРешения.Комментарий = ПараметрыПолучения.Комментарий;
	ПараметрыОтметкиРешения.ДатаУстановкиРешения = ТекущаяДатаСеанса();
	ПараметрыОтметкиРешения.ТекущийПользователь  = ПараметрыПолучения.ТекущийПользователь;
	
	СообщенияПользователю = Новый Массив;
	
	СтрокаРезультата = ПараметрыПолучения.ПараметрыСтроки;
	СтрокаРезультата.Обрабатывать = Истина; // В случае выбора статуса в строке, обрабатываем всегда.
	УстановитьРешениеПоСтроке(СтрокаРезультата, ПараметрыОтметкиРешения, СообщенияПользователю);
	
	// Возвращаем результаты.
	Результат = Новый Структура;
	Результат.Вставить("ПараметрыСтроки",       СтрокаРезультата);
	Результат.Вставить("СообщенияПользователю", СообщенияПользователю);
	
	ПоместитьВоВременноеХранилище(Результат, АдресВХранилище);
	
КонецПроцедуры

// Функция - Конструктор параметра функции УстановитьРешениеВСтроке.
// 
// Возвращаемое значение:
//  Структура - параметры получения табличных документов:
//   * Решение              - СправочникСсылка.бит_ВидыРешенийСогласования
//   * Комментарий          - Строка
//   * ПараметрыСтроки      - Структура
//   * ТекущийПользователь  - СправочникСсылка.Пользователи
//
Функция НовыеПараметрыУстановкиРешенияВСтроке() Экспорт
	
	ПараметрыПолучения = Новый Структура;
	ПараметрыПолучения.Вставить("Решение",              Справочники.бит_ВидыРешенийСогласования.ПустаяСсылка());
	ПараметрыПолучения.Вставить("Комментарий",		    "");
	ПараметрыПолучения.Вставить("ПараметрыСтроки",      Новый Структура);
	ПараметрыПолучения.Вставить("ТекущийПользователь",  Справочники.Пользователи.ПустаяСсылка());
	
	Возврат ПараметрыПолучения;
	
КонецФункции

// Процедура устанавливает решение в отмеченных строках.
//
// Параметры:
//  ПараметрыПолучения	 - Структура - см. НовыеПараметрыПакетнойУстановкиРешения().
//  АдресВХранилище		 - Строка	 - Адрес временного хранилища результата установки решения.
//
Процедура ПакетнаяУстановкаРешения(ПараметрыПолучения, АдресВХранилище = "") Экспорт
	
	ПараметрыОтметкиРешения = НовыеПараметрыПринятияРешения();
	ПараметрыОтметкиРешения.Решение     = ПараметрыПолучения.Решение;
	ПараметрыОтметкиРешения.Комментарий = ПараметрыПолучения.Комментарий;
	ПараметрыОтметкиРешения.ДатаУстановкиРешения = ТекущаяДатаСеанса();
	ПараметрыОтметкиРешения.ТекущийПользователь  = ПараметрыПолучения.ТекущийПользователь;
	
	СообщенияПользователю = Новый Массив;
	
	ДанныеТабличногоДокумента = ПараметрыПолучения.ДанныеТабличногоДокумента;
	Для каждого СтрокаРезультата Из ДанныеТабличногоДокумента Цикл
		УстановитьРешениеПоСтроке(СтрокаРезультата, ПараметрыОтметкиРешения, СообщенияПользователю);
	КонецЦикла;
	
	// Возвращаем результаты.
	Результат = Новый Структура;
	Результат.Вставить("ДанныеТабличногоДокумента", ДанныеТабличногоДокумента);
	Результат.Вставить("СообщенияПользователю",     СообщенияПользователю);
	
	ПоместитьВоВременноеХранилище(Результат, АдресВХранилище);
	
КонецПроцедуры

