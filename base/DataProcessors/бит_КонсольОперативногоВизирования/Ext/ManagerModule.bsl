
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ПрограммныйИнтерфейс

// Функция проверяет наличие необработанных виз.
//
// Параметры:
//  Ответственный - СправочникСсылка.Пользователи - Пользователь, для которого собирается информация
//                                                  о необработанных визах. Если значение не заполнено,
//		                                            определяется для текущего пользователя.
// Возвращаемое значение:
//  Булево - Наличие необработанных виз.
//
Функция ЕстьНеобработанныеВизы(Ответственный = Неопределено) Экспорт
	
	АдресВХранилище = ПоместитьВоВременноеХранилище(Новый ТаблицаЗначений, Новый УникальныйИдентификатор); 
	
	ПараметрыПолучения = НовыеПараметрыЗаполненияТаблицыВизирования();
	ПараметрыПолучения.Ответственный            = Ответственный;
	ПараметрыПолучения.МатрицаДоступа           = МатрицаДоступа(Ответственный);
	ПараметрыПолучения.ВыводитьВТаблицуЗначений = Истина;
	
	ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище);	
	Результат = ПолучитьИзВременногоХранилища(АдресВХранилище);
	ТаблицаДокументов = Результат.РезультатТаблицаЗначений;
	Возврат (ТаблицаДокументов.Количество() > 0);
	
КонецФункции

// Возвращает описание нового элемента для внешнего отбора.
//
// Возвращаемое значение:
//  Структура.
//
Функция НовыйЭлементВнешнегоОтбора() Экспорт
	
	ЭлементОтбора = Новый Структура;
	ЭлементОтбора.Вставить("ЛевоеЗначение");
	ЭлементОтбора.Вставить("ВидСравнения", ВидСравненияКомпоновкиДанных.Равно);
	ЭлементОтбора.Вставить("ПравоеЗначение");
	ЭлементОтбора.Вставить("Представление");
	
	Возврат ЭлементОтбора;
	
КонецФункции

// Процедура проверяет наличие необработанных виз для пользователя.
//
// Параметры:
//  ПараметрыПолучения - Структура.
//  АдресВХранилище	   - Строка - Адрес временного хранилища результата проверки.
// 
Процедура ПроверитьНаличиеНеобработанныхВиз(ПараметрыПолучения, АдресВХранилище = "") Экспорт
	
	РезультатПроверки = ЕстьНеобработанныеВизы(ПараметрыПолучения.Ответственный);
	ПоместитьВоВременноеХранилище(РезультатПроверки, АдресВХранилище);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Функция выполняет установку решения по визе.
//
// Параметры:
//  ПараметрыПринятияРешения - Структура - см. НовыеПараметрыПринятияРешения().
//	СообщенияПользователю - Массив - Для вывода сообщений пользователю при выполнении в фоновом режиме.
//
// Возвращаемое значение:
//  Булево - Истина: решение установлено, Ложи: в противном случае.
//
Функция УстановитьРешениеПоВизе(ПараметрыПринятияРешения, СообщенияПользователю = Неопределено) Экспорт
	
	ОбъектВизирования = ПараметрыПринятияРешения.ОбъектВизирования;
	
	Если НЕ ЗначениеЗаполнено(ОбъектВизирования) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		Блокировка        = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.бит_УстановленныеВизы");
		ЭлементБлокировки.УстановитьЗначение("Объект", ОбъектВизирования);
		Блокировка.Заблокировать();
		
		ТекНаборВизы = РегистрыСведений.бит_УстановленныеВизы.СоздатьНаборЗаписей();
		ТекНаборВизы.Отбор.Объект.Установить(ОбъектВизирования);
		ТекНаборВизы.Прочитать();
		
		Алгоритм          = бит_ВизированиеСервер.ПолучитьАлгоритмПоНаборуВиз(ТекНаборВизы);
		ВыполнятьПоэтапно = бит_УправлениеПроцессами.ВыполнятьАлгоритмПоэтапно(Алгоритм);
		ПараметрыКонтекста = Новый Структура;
		ПараметрыКонтекста.Вставить("ТекущийОбъект", ОбъектВизирования);
		ПараметрыКонтекста.Вставить("Алгоритм",      Алгоритм);
		ПараметрыКонтекста.Вставить("НаборВизы",     ТекНаборВизы);
		
		ТочкиОбработок      = Новый Массив;
		
		ПринятоеРешение     = ПараметрыПринятияРешения.Решение;
		РежимОчисткиРешения = НЕ ЗначениеЗаполнено(ПринятоеРешение); 
		
		НаборМодифицирован  = Ложь;
		Для каждого ЗаписьНабора Из ТекНаборВизы Цикл
			Если ЗаписьНабора.ИД <> ПараметрыПринятияРешения.ИДВизы Тогда
				Продолжить;
			КонецЕсли;
			
			Если РежимОчисткиРешения Тогда
				// Отмена принятого решения.
				ЗаписьНабора.Решение       = Неопределено;
				ЗаписьНабора.Пользователь  = Неопределено;
				ЗаписьНабора.ДатаУстановки = Неопределено;
				ЗаписьНабора.Комментарий   = Неопределено;
			Иначе
				ЗаписьНабора.Решение       = ПринятоеРешение;
				ЗаписьНабора.Пользователь  = ПараметрыПринятияРешения.ТекущийПользователь;
				ЗаписьНабора.ДатаУстановки = ПараметрыПринятияРешения.ДатаУстановкиРешения;
				ЗаписьНабора.Комментарий   = ПараметрыПринятияРешения.Комментарий;
			КонецЕсли;
			
			ПараметрыПоследующихТочек = бит_УправлениеПроцессами.ТочкиДействияПослеТекущей(ЗаписьНабора.ТочкаАлгоритма,
																								ПараметрыКонтекста);
			Если НЕ РежимОчисткиРешения Тогда
				Для каждого ТочкаОбработки Из ПараметрыПоследующихТочек.ТочкиОбработок Цикл
					ТочкиОбработок.Добавить(ТочкаОбработки);
				КонецЦикла;
			КонецЕсли;
			
			Если ВыполнятьПоэтапно Тогда
				// Для цикличных алгоритмов необходима очистка решений на которые возвращается выполнение.
				ТочкиДействия = ПараметрыПоследующихТочек.ТочкиДействия;
				Для каждого ТочкаДействия Из ТочкиДействия Цикл
					Для каждого ЗаписьДляОчисткиРешения Из ТекНаборВизы Цикл	
						Если ЗаписьДляОчисткиРешения.ТочкаАлгоритма = ТочкаДействия
							И ЗначениеЗаполнено(ЗаписьДляОчисткиРешения.Решение) Тогда
							ЗаписьДляОчисткиРешения.Решение       = Неопределено;
							ЗаписьДляОчисткиРешения.Пользователь  = Неопределено;
							ЗаписьДляОчисткиРешения.ДатаУстановки = Неопределено;
							ЗаписьДляОчисткиРешения.Комментарий   = Неопределено;
						КонецЕсли;
					КонецЦикла;
				КонецЦикла;
			КонецЕсли;
			
			НаборМодифицирован = Истина;
			Прервать;
		КонецЦикла;
		
		бит_РаботаСКоллекциями.УдалитьПовторяющиесяЭлементыМассива(ТочкиОбработок);
		Справочники.бит_ПользовательскиеДействия.ВыполнитьТочкиОбработки(ТочкиОбработок, ПараметрыКонтекста);
		
		УспешноеВыполнение = Ложь;
		
		Если НаборМодифицирован Тогда
			
			Если СообщенияПользователю <> Неопределено Тогда
				ТекНаборВизы.ДополнительныеСвойства.Вставить("СообщенияПользователю", СообщенияПользователю);
			КонецЕсли;
			
			Если ТекНаборВизы.ПроверитьЗаполнение() Тогда
				ТекНаборВизы.ДополнительныеСвойства.Вставить("ОтключитьРегистрациюОповещений", Истина);
				ТекНаборВизы.Записать();
				ТекНаборВизы.ДополнительныеСвойства.Удалить("ОтключитьРегистрациюОповещений");
			КонецЕсли;
			
			ДокОбъект  = ОбъектВизирования.ПолучитьОбъект();
			МетаОбъект = ДокОбъект.Метаданные();
			Если РежимОчисткиРешения Тогда
				ДокОбъект.ДополнительныеСвойства.Вставить("РежимОчисткиРешения", Истина);
			КонецЕсли;
			
			бит_ВизированиеСервер.ДовыполнитьАлгоритмВизирования(ДокОбъект, ТекНаборВизы, Ложь);
			бит_ВизированиеСервер.УстановитьКрайниеДатыВизирования(ОбъектВизирования, ТекНаборВизы, Ложь);
			
			Если ТекНаборВизы.ПроверитьЗаполнение() Тогда
				
				ТекНаборВизы.Записать();
				
				МодульВизирование = бит_ВизированиеСервер.МодульВизированияПереопределяемый();
				бит_ВизированиеСервер.УстановитьСтатус(ДокОбъект);
				бит_ВизированиеСервер.ПровестиВСтатусеУтверждено(ДокОбъект, МетаОбъект, ПараметрыПринятияРешения.ПроводитьПослеУтверждения, "Ошибки");
				МодульВизирование.СоздатьДоговорВСтатусеУтвержден(ДокОбъект);
				УспешноеВыполнение = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если УспешноеВыполнение Тогда
			ЗафиксироватьТранзакцию();
		Иначе
			ОтменитьТранзакцию();
		КонецЕсли;
	Исключение
		ОтменитьТранзакцию();
		ТекстСообщения = НСтр("ru = 'Ошибка при установке решения. %1';
								|en = 'Errors during setting desition. %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		Если СообщенияПользователю = Неопределено Тогда
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Иначе
			СообщенияПользователю.Добавить(ТекстСообщения);
		КонецЕсли;
	КонецПопытки;
	
	Возврат УспешноеВыполнение;
	
КонецФункции

// Функция собирает данные текущего пользователя о доступных визах и пользовательских условиях
//
// Параметры:
//  Ответственный - СправочникСсылка.Пользователи (необязательный). Пользователь,
//		для которого собирается информация о доступных визах. Если значение не заполнено,
//		определяется доступность для текущего пользователя.
// Возвращаемое значение:
//  ТаблицаЗначений.
// 
Функция МатрицаДоступа(Ответственный = Неопределено) Экспорт
	
	Если Ответственный = Неопределено Тогда
		Ответственный = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	Если бит_ОбщегоНазначения.ПользовательНеактивен(Ответственный) Тогда
		ПустаяМатрица = Новый ТаблицаЗначений;
		ПустаяМатрица.Колонки.Добавить("Виза", Новый ОписаниеТипов("СправочникСсылка.бит_Визы"));
		ПустаяМатрица.Колонки.Добавить("ПолныйДоступ", Новый ОписаниеТипов("Булево"));
		ПустаяМатрица.Колонки.Добавить("УсловиеДоступа", Новый ОписаниеТипов("СправочникСсылка.бит_ПользовательскиеУсловия"));
		ПустаяМатрица.Колонки.Добавить("ОбъектДоступа", Новый ОписаниеТипов("СправочникСсылка.бит_ОбъектыСистемы"));
		Возврат ПустаяМатрица; 
	КонецЕсли;
	
	Запрос       = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ГруппыПользователейПользователиГруппы.Ссылка КАК ПользовательГруппа
	|ПОМЕСТИТЬ ПользователиИГруппы
	|ИЗ
	|	Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейПользователиГруппы
	|ГДЕ
	|	ГруппыПользователейПользователиГруппы.Пользователь = &Ответственный
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Справочник.ГруппыПользователей.ВсеПользователи)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&Ответственный
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПользователиИГруппы.ПользовательГруппа КАК ПользовательГруппа,
	|	бит_ПраваУстановкиВиз.Виза КАК ВизаГруппа,
	|	бит_ПраваУстановкиВиз.ПользовательскоеУсловие КАК ПользовательскоеУсловие
	|ПОМЕСТИТЬ ПраваДоступаПоГруппам
	|ИЗ
	|	ПользователиИГруппы КАК ПользователиИГруппы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.бит_ПраваУстановкиВиз КАК бит_ПраваУстановкиВиз
	|		ПО ПользователиИГруппы.ПользовательГруппа = бит_ПраваУстановкиВиз.Пользователь
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ПраваДоступаПоГруппам.ВизаГруппа КАК Справочник.бит_Визы) КАК Виза,
	|	ПраваДоступаПоГруппам.ПользовательскоеУсловие КАК ПользовательскоеУсловие
	|ПОМЕСТИТЬ МатицаДоступаКВизам
	|ИЗ
	|	ПраваДоступаПоГруппам КАК ПраваДоступаПоГруппам
	|ГДЕ
	|	ПраваДоступаПоГруппам.ВизаГруппа ССЫЛКА Справочник.бит_Визы
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	бит_ГруппыВизВизыГруппы.Виза,
	|	ПраваДоступаПоГруппам.ПользовательскоеУсловие
	|ИЗ
	|	ПраваДоступаПоГруппам КАК ПраваДоступаПоГруппам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_ГруппыВиз.ВизыГруппы КАК бит_ГруппыВизВизыГруппы
	|		ПО ПраваДоступаПоГруппам.ВизаГруппа = бит_ГруппыВизВизыГруппы.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	бит_Визы.Ссылка,
	|	ПраваДоступаПоГруппам.ПользовательскоеУсловие
	|ИЗ
	|	ПраваДоступаПоГруппам КАК ПраваДоступаПоГруппам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_Визы КАК бит_Визы
	|		ПО (ПраваДоступаПоГруппам.ВизаГруппа = ЗНАЧЕНИЕ(Справочник.бит_ГруппыВиз.ВсеВизы))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МатицаДоступаКВизам.Виза КАК Виза
	|ПОМЕСТИТЬ ВизыБезусловногоДоступа
	|ИЗ
	|	МатицаДоступаКВизам КАК МатицаДоступаКВизам
	|ГДЕ
	|	МатицаДоступаКВизам.ПользовательскоеУсловие = ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеУсловия.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВизыБезусловногоДоступа.Виза КАК Виза,
	|	ИСТИНА КАК ПолныйДоступ,
	|	ЗНАЧЕНИЕ(Справочник.бит_ПользовательскиеУсловия.ПустаяСсылка) КАК УсловиеДоступа,
	|	НЕОПРЕДЕЛЕНО КАК ОбъектДоступа
	|ИЗ
	|	ВизыБезусловногоДоступа КАК ВизыБезусловногоДоступа
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	МатицаДоступаКВизам.Виза,
	|	ЛОЖЬ,
	|	МатицаДоступаКВизам.ПользовательскоеУсловие,
	|	ОбъектыСистемыУсловия.ОбъектСистемы
	|ИЗ
	|	МатицаДоступаКВизам КАК МатицаДоступаКВизам
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВизыБезусловногоДоступа КАК ВизыБезусловногоДоступа
	|		ПО МатицаДоступаКВизам.Виза = ВизыБезусловногоДоступа.Виза
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.бит_ПользовательскиеУсловия.ОбъектыСистемы КАК ОбъектыСистемыУсловия
	|		ПО МатицаДоступаКВизам.ПользовательскоеУсловие = ОбъектыСистемыУсловия.Ссылка
	|ГДЕ
	|	ВизыБезусловногоДоступа.Виза ЕСТЬ NULL";
	Запрос.УстановитьПараметр("Ответственный", Ответственный);
	ТаблицаДоступа = Запрос.Выполнить().Выгрузить();
	
	Возврат ТаблицаДоступа;	
	
КонецФункции

// Процедура получает при помощи СКД таблицу документов для визирования.
//
// Параметры:
//  ПараметрыПолучения	 - Структура - см. НовыеПараметрыЗаполненияТаблицыВизирования().
//  АдресВХранилище		 - Строка	 - Адрес временного хранилища результатов заполнения таблицы.
//
Процедура ЗаполнитьТаблицуВизирования(ПараметрыПолучения, АдресВХранилище = "") Экспорт
	
	Ответственный = ПараметрыПолучения.Ответственный;
	Если НЕ ЗначениеЗаполнено(Ответственный) Тогда	
		Ответственный = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	Настройки	            = ПараметрыПолучения.НастройкиКомпоновщика;
	СхемаКомпоновкиДанных   = ПараметрыПолучения.СхемаКомпоновкиДанных;
	
	ДанныеТабличногоДокумента = ПараметрыПолучения.ДанныеТабличногоДокумента;
	ВыводВТабличныйДокумент   = ПараметрыПолучения.ВыводитьВТабличныйДокумент;
	ВыводВТаблицуЗначений     = ПараметрыПолучения.ВыводитьВТаблицуЗначений;
	
	ДанныеТабличногоДокумента.Очистить();
	СоответствиеОбъектовСистемы = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.Текст = ТекстЗапросаПравДоступа();
	ТаблицаДоступа = ПараметрыПолучения.МатрицаДоступа;
	Запрос.УстановитьПараметр("ТаблицаДоступа", ТаблицаДоступа);
	Запрос.УстановитьПараметр("ФильтрВизы"    , ПараметрыПолучения.Отбор.Виза);
	Запрос.Выполнить();
	
	Запрос.Текст = ТекстЗапросаНачальнаяВыборкаАктивныхВиз(ПараметрыПолучения);
	Запрос.УстановитьПараметр("ОтборОбъектВизирования", ПараметрыПолучения.Отбор.ОбъектВизирования);
	Запрос.УстановитьПараметр("ТипыОбъектовВизирования", ПараметрыПолучения.Отбор.ТипОбъекта);
	Запрос.УстановитьПараметр("Ответственный", Ответственный);
	РезультатЗапросаТипыОбъектов = Запрос.Выполнить();
	ТипыОбъектовВизирования = РезультатЗапросаТипыОбъектов.Выгрузить().ВыгрузитьКолонку("ТипОбъектаВизирования");
	Если ТипыОбъектовВизирования.Количество() = 0 Тогда
		// Визы отсутствуют, создадим шаблон полей для первого документа из типа.
		МассивТипов = Новый Массив;
		МассивТипов.Добавить(Метаданные.ОпределяемыеТипы.бит_ОбъектыВизирования.Тип.Типы()[0]);
		ОписаниеТиповОбъектов = Новый ОписаниеТипов(МассивТипов);
	Иначе
		ОписаниеТиповОбъектов = Новый ОписаниеТипов(ТипыОбъектовВизирования);
	КонецЕсли;
	Запрос.Текст = ТекстЗапросаВыбратьВизы(ОписаниеТиповОбъектов);
	Запрос.Выполнить();
	
	Запрос.Текст = ТекстЗапросаСмешанныеПоляШапкиТЧ(ОписаниеТиповОбъектов);
	ТаблицаСмешанныхПолей = Запрос.Выполнить().Выгрузить();
	
	ТаблицаВизы                 = ОписаниеТаблицыИсточникаСКД(ОписаниеТиповОбъектов);
	
	ЕстьФильтрыРолевойАдресации = НаложитьОтборыРолевойАдресации(Запрос, ПараметрыПолучения);
	
	Запрос.Текст = ТекстЗапросаДетальныеЗаписиВиз(ПараметрыПолучения, ОписаниеТиповОбъектов, ЕстьФильтрыРолевойАдресации);
	ВыборкаОбъектовВизирования = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаОбъектовВизирования.Следующий() Цикл
		ОбъектВизирования = ВыборкаОбъектовВизирования.ОбъектВизирования;
		ВыборкаВиз = ВыборкаОбъектовВизирования.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаВиз.Следующий() Цикл
			ВыборкаУсловийДоступа = ВыборкаВиз.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			ВизаДоступна = Ложь;
			Если ВыборкаВиз.ПолныйДоступ
				ИЛИ ВыборкаВиз.ДоступРолевойАдресации = 2 Тогда // Разрешен доступ по ролевой адресации пользовательского условия.
				ВизаДоступна = Истина;
				ВыборкаУсловийДоступа.Следующий();
			Иначе
				Пока ВыборкаУсловийДоступа.Следующий() Цикл
					Если ВыборкаУсловийДоступа.ДоступРолевойАдресации = 1 Тогда
						// Запрещен доступ по ролевой адресации пользовательского условия.
						Продолжить;
					КонецЕсли;
					Если ВыполняетсяПользовательскоеУсловие(ОбъектВизирования
															,ВыборкаУсловийДоступа.УсловиеДоступа
															,Ответственный) Тогда
						ВизаДоступна = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			Если ВизаДоступна Тогда
				ВыборкаДетальныхЗаписей = ВыборкаУсловийДоступа.Выбрать();
				Пока ВыборкаДетальныхЗаписей.Следующий() Цикл
					НоваяЗаписьВизы = ТаблицаВизы.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяЗаписьВизы, ВыборкаДетальныхЗаписей);
					НоваяЗаписьВизы.ОбъектСистемы = ОбъектСистемыДокумент(СоответствиеОбъектовСистемы, ВыборкаДетальныхЗаписей.ТипОбъектаВизирования);
					Если ВыборкаДетальныхЗаписей.ПересчитатьСумму Тогда
						СуммаИВалюта = СуммаИВалютаДокумента(ВыборкаДетальныхЗаписей.ОбъектВизирования, ВыборкаДетальныхЗаписей.Дата);
						ЗаполнитьЗначенияСвойств(НоваяЗаписьВизы, СуммаИВалюта);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	ТаблицаПолейСоединенияСтрок = ОписаниеТаблицыПолейСоединенияСтрок(ОписаниеТиповОбъектов);
	Запрос.Текст = ТекстЗапросаПолейСоединения(ОписаниеТиповОбъектов);
	ВыборкаПолейСоединения = Запрос.Выполнить().Выбрать();
	Пока ВыборкаПолейСоединения.Следующий() Цикл
		НоваяСтрока = ТаблицаПолейСоединенияСтрок.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаПолейСоединения);
		Для каждого Колонка Из ТаблицаПолейСоединенияСтрок.Колонки Цикл
			Если НЕ ЗначениеЗаполнено(НоваяСтрока[Колонка.Имя]) Тогда
				НоваяСтрока[Колонка.Имя] = NULL;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Если СхемаКомпоновкиДанных <> Неопределено Тогда
		Схема = СхемаКомпоновкиДанных;
	Иначе
		Схема = Обработки.бит_КонсольОперативногоВизирования.ПолучитьМакет("СхемаКомпоновкиДанных");
	КонецЕсли;
	
	// Временное сохранение расшифровки данных
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;
	
	ЭтоМобильноеПриложение = ПараметрыПолучения.ЭтоМобильноеПриложение;
	Если ЭтоМобильноеПриложение Тогда	
		ВариантНастроек = Схема.ВариантыНастроек.Найти("МобильноеПриложение");
		Настройки = ВариантНастроек.Настройки;
	ИначеЕсли ПараметрыПолучения.ЭтоОповещения Тогда	
		ВариантНастроек = Схема.ВариантыНастроек.Найти("Оповещения");
		// АПК:277-выкл вызов механизмов типовой конфигурации.
		КомпоновкаДанныхКлиентСервер.СкопироватьЭлементы(ВариантНастроек.Настройки.Отбор, Настройки.Отбор);
		// АПК:277-вкл
		Настройки = ВариантНастроек.Настройки;
	ИначеЕсли ПараметрыПолучения.ПолучатьНастройкиКомпоновщика = Ложь Тогда
		Настройки = Схема.НастройкиПоУмолчанию; 	
	КонецЕсли;
	
	УстановитьПараметрыДанных(Настройки, ПараметрыПолучения);
	УстановитьПараметрыВывода(Настройки, ПараметрыПолучения);
	
	// Настройка группировки отчета.
	Если НЕ ЭтоМобильноеПриложение
		И НЕ ПараметрыПолучения.ЭтоОповещения Тогда
		НастроитьГруппировкиОтчета(Настройки, ПараметрыПолучения.ГруппировкаОтчета);
	КонецЕсли;
	
	// Ограничение типов: если в составе типа будут содержаться документы, недоступные пользователю, то вложенные поля
	//  не будут выводиться в отчет, даже если чтение будет производиться исключительно из доступных объектов.
	
	Для каждого КолонкаАналитики Из ТаблицаПолейСоединенияСтрок.Колонки Цикл
		ИмяКолонки = КолонкаАналитики.Имя;
		Если СтрНайти(ИмяКолонки, "Аналитика_") = 0
			И НЕ (бит_ОбщегоНазначения.ЭтоСемействоERP()
				И (ИмяКолонки = "ДатаПлан"
					ИЛИ ИмяКолонки = "ДатаПланКрайняя")) Тогда
			Продолжить;
		КонецЕсли;
		
		ПолеАналитикиСКД = Схема.НаборыДанных.ТаблицаПолейСоединенияСтрок.Поля.Найти(ИмяКолонки);
		Если НЕ ПустаяСтрока(КолонкаАналитики.Заголовок) Тогда
			ПолеАналитикиСКД.Заголовок = КолонкаАналитики.Заголовок;
			Если СтрНайти(ИмяКолонки, "Аналитика_") <> 0 Тогда
				ПолеАналитикиСКД.Заголовок = ПолеАналитикиСКД.Заголовок + " (Аналитика)";
			КонецЕсли;
		КонецЕсли;
		УстановитьОграниченияИспользованияПоляСКД(Схема, "ТаблицаПолейСоединенияСтрок", ИмяКолонки, Ложь);
		ПолеАналитикиСКД.ТипЗначения = КолонкаАналитики.ТипЗначения;
	КонецЦикла;
	
	УстановитьОграниченияИспользованияПоляСКД(Схема,
											"ТаблицаВизы",
											"ИД",
											НЕ ЭтоМобильноеПриложение);
	УстановитьОграниченияИспользованияПоляСКД(Схема,
											"ТаблицаСмешанныхПолей",
											"СтатьяОборотовСмешанная",
											НЕ ЭтоМобильноеПриложение);
	УстановитьОграниченияИспользованияПоляСКД(Схема,
											"ТаблицаСмешанныхПолей",
											"ВизаСмешанная",
											НЕ ЭтоМобильноеПриложение);
	Если бит_ОбщегоНазначения.ЭтоСемействоБП() Тогда
		УстановитьОграниченияИспользованияПоляСКД(Схема,
											"ТаблицаПолейСоединенияСтрок",
											"ОбъектРасчетов");
		УстановитьОграниченияИспользованияПоляСКД(Схема,
											"ТаблицаПолейСоединенияСтрок",
											"Договор");
	Иначе
		ПолеНабора = Схема.НаборыДанных.ТаблицаПолейСоединенияСтрок.Поля.Найти("ОбъектРасчетов");
		ПолеНабора.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.ОбъектыРасчетов");
		
		ПолеНабора = Схема.НаборыДанных.ТаблицаПолейСоединенияСтрок.Поля.Найти("Договор");
		ПолеНабора.ТипЗначения =
			Новый ОписаниеТипов("СправочникСсылка.ДоговорыМеждуОрганизациями, СправочникСсылка.ДоговорыКонтрагентов");
	КонецЕсли;
	
	ПолеКрайнейДаты     = Схема.НаборыДанных.ТаблицаВизы.Поля.Найти("ДатаКрайняя");
	Если ПараметрыПолучения.РежимАрхива Тогда
		ПолеКрайнейДаты.Заголовок = НСтр("ru = 'Дата установки';
										|en = 'Set date'");
	Иначе
		ПолеКрайнейДаты.Заголовок = НСтр("ru = 'Установить не позднее';
										|en = 'Set no later than'");
	КонецЕсли;
	
	ПолеКомпоновкиЭлементУправления = Новый ПолеКомпоновкиДанных("ЭлементУправления");
	НомерКолонкиЭлементУправления = ПозицияВыбранногоПоля(Настройки, ПолеКомпоновкиЭлементУправления); 
	Если ВыводВТабличныйДокумент И НомерКолонкиЭлементУправления = 0 Тогда
		ВызватьИсключение НСтр("ru = 'В выбранных полях должно обязательно присутствовать поле ""Элемент управления"".';
						  	   |en = 'Selected fields must have ""Control"" column.'");
	КонецЕсли;
	
	ПолеКомпоновкиЕстьФайлыКартинка = Новый ПолеКомпоновкиДанных("ЕстьФайлыКартинка");
	НомерКолонкиКартинкаЕстьФайл = ПозицияВыбранногоПоля(Настройки, ПолеКомпоновкиЕстьФайлыКартинка); 
	
	СлужебныеПоля = Новый СписокЗначений;
	СлужебныеПоля.Добавить(ПолеКомпоновкиЭлементУправления);
	СлужебныеПоля.Добавить(ПолеКомпоновкиЕстьФайлыКартинка);
	СлужебныеПоля.Добавить(Новый ПолеКомпоновкиДанных("СрокВыполнения"));
	СлужебныеПоля.Добавить(Новый ПолеКомпоновкиДанных("ИД"));
	ПорядокИЗаголовкиПолей = ПорядокИЗаголовкиПолейСхемы(ПараметрыПолучения, Схема, Настройки, СлужебныеПоля);
	УстановитьВнешниеОтборы(ПараметрыПолучения, Настройки);
	
	// Внешние наборы данных.
	ВнешниеНаборыДанных = Новый Структура;
	ВнешниеНаборыДанных.Вставить("ТаблицаВизы"          , ТаблицаВизы);
	ВнешниеНаборыДанных.Вставить("ТаблицаСмешанныхПолей", ТаблицаСмешанныхПолей);
	ВнешниеНаборыДанных.Вставить("ТаблицаПолейСоединенияСтрок", ТаблицаПолейСоединенияСтрок);
	
	РезультатТабличныйДокумент = Новый ТабличныйДокумент;
	Если ВыводВТабличныйДокумент Тогда
		
		КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
		МакетКомпоновки   = КомпоновщикМакета.Выполнить(Схема, Настройки, ДанныеРасшифровки);
		
		ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
		ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных, ДанныеРасшифровки, Истина);
		
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
		ПроцессорВывода.ОтображатьПроцентВывода = Истина;
		ПроцессорВывода.УстановитьДокумент(РезультатТабличныйДокумент); 	
		ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
		
		КолСтрокТаблицы   = РезультатТабличныйДокумент.ВысотаТаблицы; // Количество строк в отчете.
		
		ПорядковыйНомер = 1;
		
		ТипыРешений = Новый Соответствие;
		// Обходим все строки отчета.
		Для НомСтр = 1 По КолСтрокТаблицы Цикл
			ТекОбласть = РезультатТабличныйДокумент.Область(НомСтр, НомерКолонкиЭлементУправления);  
			Если ЭтоУправляющаяОбласть(ТекОбласть.Текст) Тогда
				ТекОбласть.Текст    = "";
				ТекОбласть.Картинка = КартинкаБиблиотеки("ФлагВыбораЛожь");
				
				Если ТекОбласть.Расшифровка <> Неопределено Тогда
					ЗначенияПолейРасшифровки = ДанныеРасшифровки.Элементы[ТекОбласть.Расшифровка].ПолучитьПоля();
					
					НоваяСтрока = ДанныеТабличногоДокумента.Добавить();
					НоваяСтрока.Обрабатывать = Ложь;
					Для каждого ЗначениеРасшифровки Из ЗначенияПолейРасшифровки Цикл
						НоваяСтрока[ЗначениеРасшифровки.Поле] = ЗначениеРасшифровки.Значение;
					КонецЦикла;
					НоваяСтрока.НомерПП = ПорядковыйНомер;
					ПорядковыйНомер = ПорядковыйНомер + 1;
					
					ТекОбласть.Имя = ИдентификаторЭлементаУправленияКартинки() + НоваяСтрока.ИД;
					
					ПараметрыСтроки = Новый Структура;
					ПараметрыСтроки.Вставить("ПринятоеРешение", НоваяСтрока.ПринятоеРешение);
					ПараметрыСтроки.Вставить("Обрабатывать", Ложь);
					ПараметрыОформленияЭУ = ПараметрыОформленияЭлементаУправления(ПараметрыСтроки, ТипыРешений);
					ТекОбласть.Картинка   = ПараметрыОформленияЭУ.Картинка;
				КонецЕсли;
			// АПК:1297-выкл Строковые параметры.
			// АПК:1392-выкл Строковые параметры.
			ИначеЕсли ТекОбласть.Текст = "Элемент управления"
				ИЛИ ТекОбласть.Текст = "Control" Тогда
			// АПК:1392-вкл
			// АПК:1297-вкл
				ТекОбласть.Текст = ""; // Заголовок.
			КонецЕсли;
			
			Если НомерКолонкиКартинкаЕстьФайл <> 0 Тогда
				ТекОбласть = РезультатТабличныйДокумент.Область(НомСтр, НомерКолонкиКартинкаЕстьФайл);  
				Если ТекстСодержитИдентификаторКартинки(ТекОбласть.Текст) Тогда
					ПараметрыИзвлеченияКартинки = ПараметрыИзвлеченияКартинки(ТекОбласть.Текст);
					ТекОбласть.Текст    = ПараметрыИзвлеченияКартинки.Текст;
					ТекОбласть.Картинка = ПараметрыИзвлеченияКартинки.Картинка;
				// АПК:1297-выкл Строковые параметры.
				// АПК:1392-выкл Строковые параметры.
				ИначеЕсли ТекОбласть.Текст = "Есть файлы"
					ИЛИ ТекОбласть.Текст = "There are files (picture)" Тогда
				// АПК:1392-вкл
				// АПК:1297-вкл
					ТекОбласть.Текст = ""; // Заголовок.
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	РезультатТаблицаЗначений = Новый ТаблицаЗначений;
	Если ВыводВТаблицуЗначений Тогда
		
		КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;	
		МакетКомпоновки   = КомпоновщикМакета.Выполнить(Схема,
														Настройки,
														,
														,
														Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
		ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
		ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, ВнешниеНаборыДанных,, Истина);
		
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		ПроцессорВывода.УстановитьОбъект(РезультатТаблицаЗначений); 	
		ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	КонецЕсли;
	
	// Возвращаем результаты.
	СтруктураРезультатаОбновления = Новый Структура;
	СтруктураРезультатаОбновления.Вставить("СхемаКомпоновкиДанных", Схема);
	СтруктураРезультатаОбновления.Вставить("РезультатТабличныйДокумент", РезультатТабличныйДокумент);
	СтруктураРезультатаОбновления.Вставить("РезультатТаблицаЗначений", РезультатТаблицаЗначений);
	СтруктураРезультатаОбновления.Вставить("ДанныеРасшифровки", ДанныеРасшифровки);
	СтруктураРезультатаОбновления.Вставить("ДанныеТабличногоДокумента", ДанныеТабличногоДокумента);
	СтруктураРезультатаОбновления.Вставить("НомерКолонкиЭлементУправления", НомерКолонкиЭлементУправления);
	СтруктураРезультатаОбновления.Вставить("ПорядокИЗаголовкиПолей", ПорядокИЗаголовкиПолей);
	
	Если ПараметрыПолучения.ВозвращатьТаблицуВиз Тогда
		СтруктураРезультатаОбновления.Вставить("ТаблицаВизы", ТаблицаВизы);
	Иначе
		СтруктураРезультатаОбновления.Вставить("ТаблицаВизы", Новый ТаблицаЗначений);
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(СтруктураРезультатаОбновления, АдресВХранилище);
		
КонецПроцедуры

// Функция - Конструктор параметра функции ЗаполнитьТаблицуВизирования.
// 
// Возвращаемое значение:
//  Структура - параметры получения табличных документов:
//   * Ответственный - СправочникСсылка.Пользователи
//   * НастройкиКомпоновщика  - НастройкиКомпоновкиДанных  - настройки компоновщика данных для СКД
//   * СхемаКомпоновкиДанных - Строка - адрес хранения СКД
//   * ДанныеТабличногоДокумента - ТаблицаЗначений - обрабатываемые данные, связанные с выведенным табличным документом
//   * МатрицаДоступа - ТаблицаЗначений - данные по доступным видам виз с учетом ролевой адресации
//   * ВариантОтбораВиз - Число - тип установленного фильтра по видам виз
//   * ПолучатьНастройкиКомпоновщика - Булево - признак необходимости получения настроек из пользовательских настроек компоновщика
//   * ВыводитьВТабличныйДокумент - Булево - признак необходимости получения результата в виде табличного документа
//   * ВыводитьВТаблицуЗначений - Булево - признак необходимости получения результата в виде таблицы значений
//   * ЭтоМобильноеПриложение - Булево
//   * ЭтоОповещения - Булево
//   * РежимАрхива - Булево
//   * РежимПолученияРеквизитов - Булево
//   * РежимПроверкиОповещений - Булево
//   * ВозвращатьПорядокИЗаголовкиПолей - Булево - признак необходимости определения порядка и заголовков полей
//   * ВозвращатьТаблицуВиз - Булево
//   * ГруппировкаОтчета - Число - вариант группировки для результирующего табличного документа
//   * Отбор - Структура - предопределенные отборы для получения данных:
//		• ОбъектВизирования - Ссылка, СписокЗначений - список объектов визирования
//		• ТипОбъекта - СписокЗначений - список типов объектов визирования
//		• Виза - СписокЗначений - список согласуемых виз.
//
Функция НовыеПараметрыЗаполненияТаблицыВизирования() Экспорт
	
	ПараметрыПолучения = Новый Структура;
	ПараметрыПолучения.Вставить("Ответственный",				    Неопределено);
	ПараметрыПолучения.Вставить("НастройкиКомпоновщика",		    Новый НастройкиКомпоновкиДанных);
	ПараметрыПолучения.Вставить("СхемаКомпоновкиДанных",		    Неопределено);
	ПараметрыПолучения.Вставить("ДанныеТабличногоДокумента",	    Новый ТаблицаЗначений);
	ПараметрыПолучения.Вставить("МатрицаДоступа",				    Новый ТаблицаЗначений);
	ПараметрыПолучения.Вставить("ВариантОтбораВиз",				    0);
	ПараметрыПолучения.Вставить("ПолучатьНастройкиКомпоновщика",    Ложь);
	ПараметрыПолучения.Вставить("ВыводитьВТабличныйДокумент",	    Ложь);
	ПараметрыПолучения.Вставить("ВыводитьВТаблицуЗначений", 	    Ложь);
	ПараметрыПолучения.Вставить("ЭтоМобильноеПриложение",		    Ложь);
	ПараметрыПолучения.Вставить("ЭтоОповещения",				    Ложь);
	ПараметрыПолучения.Вставить("РежимАрхива",		                Ложь);
	ПараметрыПолучения.Вставить("РежимПолученияРеквизитов",			Ложь);
	ПараметрыПолучения.Вставить("РежимПроверкиОповещений",          Ложь);
	ПараметрыПолучения.Вставить("ВозвращатьПорядокИЗаголовкиПолей", Ложь);
	ПараметрыПолучения.Вставить("ВозвращатьТаблицуВиз",             Ложь);
	ПараметрыПолучения.Вставить("ГруппировкаОтчета",                0);
	ПараметрыПолучения.Вставить("АвтопозицияРесурсов",              Ложь);
	
	Отбор = Новый Структура;
	Отбор.Вставить("ОбъектВизирования", Неопределено);
	Отбор.Вставить("ТипОбъекта",        Новый СписокЗначений);
	Отбор.Вставить("Виза",              Новый СписокЗначений); // При установке отбора по визам необходимо указать параметр ВариантОтбораВиз = 3.
	Отбор.Вставить("ВнешниеОтборы",     Новый Структура); // Устанавливается при получении виз из внешнего интерфейса (например Telegram).
	ПараметрыПолучения.Вставить("Отбор", Отбор);
	
	Возврат ПараметрыПолучения;
	
КонецФункции

Функция ИдентификаторЭлементаУправленияКартинки() Экспорт
	
	Возврат "ЭлементУправленияПолеФлага_";
	
КонецФункции

Функция ЭтоУправляющаяОбласть(ИмяОбласти) Экспорт
	
	ПризнакУправляющейОбласти = ИдентификаторЭлементаУправленияКартинки();
	Если СтрНайти(ИмяОбласти, ПризнакУправляющейОбласти) > 0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

Функция ПараметрыОформленияЭлементаУправления(ПараметрыСтроки, ТипыРешений) Экспорт
	
	Полужирный = Ложь;
	Наклонный  = Ложь;
	
	РешениеПринято = ЗначениеЗаполнено(ПараметрыСтроки.ПринятоеРешение);
	Если РешениеПринято Тогда
		ТипРешения = Справочники.бит_ВидыРешенийСогласования.ТипРешенияСогласования(ПараметрыСтроки.ПринятоеРешение,
																					ТипыРешений);
		Если ТипРешения = Перечисления.бит_ТипыРешений.Отклоняющее Тогда
			Картинка  = КартинкаБиблиотеки("Отклонено");
		Иначе	
			Картинка  = КартинкаБиблиотеки("Согласовано");
		КонецЕсли;
		Наклонный = Истина;
	ИначеЕсли ПараметрыСтроки.Обрабатывать Тогда
		Картинка   = КартинкаБиблиотеки("ФлагВыбораИстина");
		Полужирный = Истина;
	Иначе
		Картинка = КартинкаБиблиотеки("ФлагВыбораЛожь");
	КонецЕсли;
	
	ПараметрыОформления = Новый Структура;
	ПараметрыОформления.Вставить("Картинка", Картинка);
	ПараметрыОформления.Вставить("Полужирный", Полужирный);
	ПараметрыОформления.Вставить("Наклонный",  Наклонный);
	
	Возврат ПараметрыОформления;
	
КонецФункции

// Функция получает настройку консоли пользователя по-умолчанию.
//
// Параметры:
//  Ответственный - СправочникСсылка.Пользователи (необязательный). Пользователь,
//		для которого собирается информация о доступных визах. Если значение не заполнено,
//		определяется доступность для текущего пользователя.
// Возвращаемое значение:
//  ВыбраннаяНастройка  - СправочникСсылка.бит_СохраненныеНастройки.
//
Функция НастройкаПоУмолчанию(Ответственный = Неопределено) Экспорт
	
	Если Ответственный = Неопределено Тогда
		Ответственный = Пользователи.ТекущийПользователь();
	КонецЕсли;
		
	// Получим настройку по - умолчанию.
	НастройкаПоУмолчанию = бит_ОтчетыСервер.НайтиНастройкуПоУмолчаниюДляОбъекта(НаименованиеОбъектаСохраняемыхНастроек(),,, Ответственный);
	
	Если ЗначениеЗаполнено(НастройкаПоУмолчанию) Тогда
		Возврат НастройкаПоУмолчанию;
	КонецЕсли;
	
	// Если настройки по умолчанию нет, попробуем определить последнюю использованную пользователем настройку.
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ОбъектСистемы", Метаданные.Обработки.бит_КонсольОперативногоВизирования);
	СтруктураПараметров.Вставить("КлючЗначения", "ПоследниеЗначения");
	
	ПоследниеЗначения = РегистрыСведений.бит_СохраненныеЗначения.ПолучитьЗнч(Ответственный, СтруктураПараметров);
	Если ТипЗнч(ПоследниеЗначения) = Тип("Структура") И ПоследниеЗначения.Свойство("Настройка") Тогда
		Возврат ПоследниеЗначения.Настройка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция НаименованиеОбъектаСохраняемыхНастроек() Экспорт
	
	Возврат Метаданные.Обработки.бит_КонсольОперативногоВизирования.ПолноеИмя();
	
КонецФункции

Функция НовыеПараметрыПринятияРешения() Экспорт
	
	ПараметрыРешения = Новый Структура;
	ПараметрыРешения.Вставить("ОбъектВизирования");
	ПараметрыРешения.Вставить("ИДВизы");
	ПараметрыРешения.Вставить("Решение");
