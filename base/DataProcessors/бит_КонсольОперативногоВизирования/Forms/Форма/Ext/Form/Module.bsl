#Область ОтображениеРеквизитовВиз

&НаКлиенте
Процедура ОбновитьРеквизитыАктивнойВизы()
	
	Если НЕ ОтображатьРеквизитыВизы Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяОбласть = Элементы.Результат.ТекущаяОбласть;
	Если ТекущаяОбласть = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИДСтроки = ИДСтрокиПоИмениОбласти(ТекущаяОбласть.Имя);
	Если ИДАктивнойСтрокиДоИзменения = ИДСтроки Тогда
		Возврат;
	ИначеЕсли НЕ ПанельАлгоритмВидимость Тогда
		ИДАктивнойСтрокиДоИзменения = ИДСтроки;
	КонецЕсли;
		
	Если ИДСтроки <> Неопределено Тогда
		ЗаполнитьЭлементыРеквизитовВизы(ИДСтроки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЭлементыРеквизитовВизы(ИдВизы)
	
	СоздатьЭлементыРеквизитовВизы();
	
	ПорядокИЗаголовкиПолей   = ПолучитьИзВременногоХранилища(АдресПорядокИЗаголовкиПолей);
	ТаблицаДанныхВизирования = ПолучитьИзВременногоХранилища(АдресТаблицаВиз);
	КолонкиДанных            = ТаблицаДанныхВизирования.Колонки;
	
	ЗначениеПоиска = ИдентификаторЭлементаУправленияКартинки() + ИдВизы;
	СтрокаДанных   = ТаблицаДанныхВизирования.Найти(ЗначениеПоиска, "ЭлементУправления");
	Если СтрокаДанных = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ШаблонРеквизитаФормы = "РеквизитВизы_%1";
	
	Для каждого ПараметрыРеквизита Из ПорядокИЗаголовкиПолей Цикл
		ИмяРеквизитаВизы  = ПараметрыРеквизита.Имя;
		Если КолонкиДанных.Найти(ИмяРеквизитаВизы) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяРеквизитаФормы = СтрШаблон(ШаблонРеквизитаФормы, ИмяРеквизитаВизы);
		ЗначениеРеквизита = СтрокаДанных[ИмяРеквизитаВизы];
		Если ТипЗнч(ЗначениеРеквизита) = Тип("Массив") Тогда
			ЗначениеРеквизита = СтрСоединить(ЗначениеРеквизита);
		КонецЕсли;
		ЭтотОбъект[ИмяРеквизитаФормы] = ЗначениеРеквизита;
	КонецЦикла;
	
	Элементы.РеквизитыВизы.Видимость = Истина;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьЭлементыРеквизитовВизы()
	
	Если НЕ ОбновитьСоставРеквизитовВиз Тогда
		Возврат;
	КонецЕсли;
	
	ШаблонРеквизитаФормы = "РеквизитВизы_%1";
	
	// Удаление старых реквизитов.
	ЭлементыДляУдаления = Новый Массив;
	УдаляемыеРеквизиты  = Новый Массив;
	Для каждого Элемент Из Элементы Цикл
		Если СтрНачинаетсяС(Элемент.Имя, "РеквизитВизы_")
			И ТипЗнч(Элемент) = Тип("ПолеФормы") Тогда
			ЭлементыДляУдаления.Добавить(Элемент);
		КонецЕсли;
	КонецЦикла;
	Для каждого Элемент Из ЭлементыДляУдаления Цикл
		УдаляемыеРеквизиты.Добавить(Элемент.ПутьКДанным);
		Элементы.Удалить(Элемент);
	КонецЦикла;
	
	ПорядокИЗаголовкиПолей   = ПолучитьИзВременногоХранилища(АдресПорядокИЗаголовкиПолей);
	ТаблицаДанныхВизирования = ПолучитьИзВременногоХранилища(АдресТаблицаВиз);
	
	ДобавляемыеРеквизиты      = Новый Массив;
	ИменаДобавленыхРеквизитов = Новый Массив;
	Для каждого ПараметрыРеквизита Из ПорядокИЗаголовкиПолей Цикл
		ИмяРеквизитаВизы  = ПараметрыРеквизита.Имя;
		КолонкаТаблицы    = ТаблицаДанныхВизирования.Колонки.Найти(ИмяРеквизитаВизы);
		Если КолонкаТаблицы = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ТипРеквизита      = Новый ОписаниеТипов(КолонкаТаблицы.ТипЗначения,,"NULL, Массив, ТаблицаЗначений");
		Если ТипРеквизита.Типы().Количество() = 0 Тогда
			ТипРеквизита = Новый ОписаниеТипов("Строка");
		КонецЕсли;
		ИмяРеквизитаФормы = СтрШаблон(ШаблонРеквизитаФормы, ИмяРеквизитаВизы);
		НовыйРеквизит     = Новый РеквизитФормы(ИмяРеквизитаФормы, ТипРеквизита,,ПараметрыРеквизита.Заголовок);
		ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);
		ИменаДобавленыхРеквизитов.Добавить(ИмяРеквизитаФормы);
	КонецЦикла;
	ИзменитьРеквизиты(ДобавляемыеРеквизиты, УдаляемыеРеквизиты);
	
	Для каждого ИмяРеквизитаФормы Из ИменаДобавленыхРеквизитов Цикл
		НовоеПоле   = Элементы.Добавить(ИмяРеквизитаФормы, Тип("ПолеФормы"), Элементы.РеквизитыВизы);
		НовоеПоле.Вид		     = ВидПоляФормы.ПолеВвода;
		НовоеПоле.ТолькоПросмотр = Истина;
		НовоеПоле.ПутьКДанным    = ИмяРеквизитаФормы;
	КонецЦикла;
	
	ОбновитьСоставРеквизитовВиз = Ложь;
	
КонецПроцедуры

#КонецОбласти

