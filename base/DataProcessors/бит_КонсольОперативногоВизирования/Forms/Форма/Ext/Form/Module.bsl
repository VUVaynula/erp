	Если ТекущаяОбласть = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяОбласти = ТекущаяОбласть.Имя;
	ГрупповаяУстановкаПризнакаОбработкиПоДиапазонуЯчеек(ИмяОбласти, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьВыделенные(Команда)
	
	ТекущаяОбласть = Элементы.Результат.ТекущаяОбласть;
	Если ТекущаяОбласть = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяОбласти = ТекущаяОбласть.Имя;
	ГрупповаяУстановкаПризнакаОбработкиПоДиапазонуЯчеек(ИмяОбласти, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДокумент(Команда)
	
	ТекущаяОбласть = Элементы.Результат.ТекущаяОбласть;
	Если ТекущаяОбласть = Неопределено Тогда
		ТекстСообщения = НСтр("ru='Не выбран ни один документ для открытия.';
							  |en='Do not select any document to open.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ИмяОбласти = ТекущаяОбласть.Имя;
	ИДСтроки = ИДСтрокиПоИмениОбласти(ИмяОбласти);
	РасшифроватьОбласть(ИДСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура СогласованиеСтроки(Команда)
	
	ТекущаяОбласть = Элементы.Результат.ТекущаяОбласть;
	Если ТекущаяОбласть = Неопределено Тогда
		ТекстСообщения = НСтр("ru='Не выбран ни один документ для согласования.';
							  |en='Do not select any document for approval.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ИмяОбласти = ТекущаяОбласть.Имя;
	ИДСтроки = ИДСтрокиПоИмениОбласти(ИмяОбласти);
	ОткрытьОкноПринятияРешения(ИДСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура ПрисоединенныеФайлы(Команда)
	
	ТекущаяОбласть = Элементы.Результат.ТекущаяОбласть;
	Если ТекущаяОбласть = Неопределено Тогда
		ТекстСообщения = НСтр("ru='Выделите область с документом, чтобы посмотреть вложения.';
							  |en='Select the document area to view attachments.'");		
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ИмяОбласти        = ТекущаяОбласть.Имя;
	ИДСтроки          = ИДСтрокиПоИмениОбласти(ИмяОбласти);
	Если ИДСтроки = Неопределено Тогда
		ТекстСообщения = НСтр("ru='Не удалось определить документ в выделенной области.';
							  |en='Cant define document in area.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ОбъектВизирования = ПараметрыСтрокиДанных(ИДСтроки, "ОбъектВизирования");
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВладелецФайла",  ОбъектВизирования);
	ПараметрыФормы.Вставить("ТолькоПросмотр", Истина);
	
	ОткрытьФорму("Обработка.РаботаСФайлами.Форма.ПрисоединенныеФайлы", ПараметрыФормы, ЭтотОбъект, УникальныйИдентификатор);
				 
КонецПроцедуры

&НаКлиенте
Процедура СоздатьЗадачу(Команда)
	
	ТекущаяОбласть = Элементы.Результат.ТекущаяОбласть;
	Если ТекущаяОбласть = Неопределено Тогда
		ТекстСообщения = НСтр("ru='Выделите область с документом, чтобы создать задачу.';
							  |en='Select the document area to create task.'");		
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ИмяОбласти        = ТекущаяОбласть.Имя;
	ИДСтроки          = ИДСтрокиПоИмениОбласти(ИмяОбласти);
	Если ИДСтроки = Неопределено Тогда
		ТекстСообщения = НСтр("ru='Не удалось определить документ в выделенной области.';
							  |en='Cant define document in area.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ОбъектВизирования = ПараметрыСтрокиДанных(ИДСтроки, "ОбъектВизирования");
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Основание", ОбъектВизирования);
	
	ОткрытьФорму("Задача.бит_Задача.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаОбработкаРасшифровки(Команда)
	
	ТекОбласть = Элементы.Результат.ТекущаяОбласть;
	Если ТекОбласть = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбработкаРасшифровки =  Новый ОбработкаРасшифровкиКомпоновкиДанных(ДанныеРасшифровки,
								Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных));
	
	МассивДоступныхДействий = Новый Массив();
	МассивДоступныхДействий.Добавить(ДействиеОбработкиРасшифровкиКомпоновкиДанных.ОткрытьЗначение);
	МассивДоступныхДействий.Добавить(ДействиеОбработкиРасшифровкиКомпоновкиДанных.Отфильтровать);
	МассивДоступныхДействий.Добавить(ДействиеОбработкиРасшифровкиКомпоновкиДанных.Упорядочить);
	
	ОбработкаРасшифровки.ПоказатьВыборДействия(Новый ОписаниеОповещения("ОбработатьРасшифровку", ЭтотОбъект),
													ТекОбласть.Расшифровка,
													МассивДоступныхДействий);
	
КонецПроцедуры
												
&НаКлиенте
Процедура ВыполнитьСохранениеНастроек(ПриЗакрытии = Ложь)
	
	УстановитьБыстрыеФильтры();
	
	ПараметрыФормы     = Новый Структура;
	СтруктураНастройки = СохраняемыеНастройкиОтчета();
	ПараметрыФормы.Вставить("СтруктураНастройки" , СтруктураНастройки);
	ПараметрыФормы.Вставить("ТипНастройки"		 , ПредопределенноеЗначение("Перечисление.бит_ТипыСохраненныхНастроек.Обработки"));
	ПараметрыФормы.Вставить("НастраиваемыйОбъект", НастраиваемыйОбъект());
	
	Если ЗначениеЗаполнено(ТекущаяНастройка) Тогда
		ПараметрыФормы.Вставить("СохраненнаяНастройка",ТекущаяНастройка);
	КонецЕсли; 
	
	ПараметрыСохранения = Новый Структура;
	ПараметрыСохранения.Вставить("ПриЗакрытии", ПриЗакрытии);
	Оповещение = Новый ОписаниеОповещения("СохранитьНастройкиЗавершение", ЭтотОбъект, ПараметрыСохранения);
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаСохранения", ПараметрыФормы, ЭтотОбъект,,,,
		Оповещение,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьНастройки(Команда)
	
	ВыполнитьСохранениеНастроек();	
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьНастройки(Команда)
	
	ПараметрыФормы     = Новый Структура;
	ПараметрыФормы.Вставить("ТипНастройки"		 , ПредопределенноеЗначение("Перечисление.бит_ТипыСохраненныхНастроек.Обработки"));
	ПараметрыФормы.Вставить("НастраиваемыйОбъект", НастраиваемыйОбъект());
	
	Оповещение = Новый ОписаниеОповещения("ВыбратьНастройкиЗавершение",ЭтотОбъект);
	ОткрытьФорму("ХранилищеНастроек.бит_ХранилищеНастроек.ФормаЗагрузки", ПараметрыФормы, ЭтотОбъект,,,,
		Оповещение,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
Процедура ОкноНастроек(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Компоновщик",                    Объект.Компоновщик);
	ПараметрыФормы.Вставить("ОбновлятьВизыПослеСогласования", ОбновлятьВизыПослеСогласования);
	ПараметрыФормы.Вставить("АвтопозицияРесурсов",            АвтопозицияРесурсов);
	ПараметрыФормы.Вставить("ВыполнятьНаКлиенте",             ВыполнятьНаКлиенте);
	
	Оповещение = Новый ОписаниеОповещения("НастройкиОтчетаЗавершение", ЭтотОбъект);
	ОткрытьФорму("Обработка.бит_КонсольОперативногоВизирования.Форма.Настройки",ПараметрыФормы,ЭтотОбъект,,
					ЭтотОбъект.Окно,,Оповещение,РежимОткрытияОкнаФормы.Независимый);
	
КонецПроцедуры
	
&НаСервере
Процедура УстановитьНастройкиПоУмолчаниюНаСервере()
	
	Схема = Обработки.бит_КонсольОперативногоВизирования.ПолучитьМакет("СхемаКомпоновкиДанных");
	
	АдресСКД = ПоместитьВоВременноеХранилище(Схема, УникальныйИдентификатор);
	Объект.Компоновщик.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСКД));
	Объект.Компоновщик.ЗагрузитьНастройки(Схема.НастройкиПоУмолчанию);
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросУстановитьНастройкиПоУмолчаниюПриЗавершении(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		УстановитьНастройкиПоУмолчаниюНаСервере();
	КонецЕсли;
	
	ОбновитьСписокВизКлиент();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкиПоУмолчанию(Команда)
	
	Оповещение = Новый ОписаниеОповещения("ВопросУстановитьНастройкиПоУмолчаниюПриЗавершении", ЭтотОбъект);
	ТекстВопроса = НСтр("ru='Установить настройки полей по-умолчанию?';en='Set default settings?'");
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаДокументыУстановитьВсе(Команда)
	
	Модифицированность = Истина;
	НастройкаТипыДокументов.ЗаполнитьПометки(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаДокументыСнятьВсе(Команда)
	
	Модифицированность = Истина;
	НастройкаТипыДокументов.ЗаполнитьПометки(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаВариантОтбораВизПриИзменении(Элемент)
	
	Модифицированность = Истина;
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаФильтрВизыПриИзменении(Элемент)
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьБыстрыеФильтры()
	
	УстановленныеФильтры = Новый СписокЗначений;
	
	ЕстьФильтры = Ложь;
	Для каждого ЭлементСписка Из НастройкаТипыДокументов Цикл
		Если ЭлементСписка.Пометка Тогда
			УстановленныеФильтры.Добавить(ЭлементСписка.Значение, ЭлементСписка.Представление);
		Иначе			
			ЕстьФильтры = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Если УстановленныеФильтры.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru='Не отмечено ни одного документа для отображения.';en='There was no single document to display.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "ТипыОбъектовВизированияЗначение");
		Возврат;
	КонецЕсли;
	
	Если НЕ ЕстьФильтры Тогда
		УстановленныеФильтры.Очистить();
	КонецЕсли;
	
	ТипыОбъектовВизирования = УстановленныеФильтры;
	
	
	ВариантОтбораВиз = НастройкаВариантОтбораВиз;
	ФильтрВизы       = НастройкаФильтрВизы;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РаботаСТабличнымПолемРезультат

&НаКлиенте
Процедура ОбновитьСписокВизКлиент()
	
	ЗапуститьЗамерДлительностиКлючевойОперации("ФормированиеСпискаДокументов");	
	
	ДлительнаяОперация = ПараметрыОбновленияТаблицыВизирования();
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ТекстСообщения = НСтр("ru='Заполнение таблицы';en='Filling table'");  
	ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПриЗавершенииОбновленияТаблицыВизирования", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОписаниеОповещения, ПараметрыОжидания);
	
КонецПроцедуры

// Процедура окончание процедуры "ОбновитьСписокВизКлиент".
//
&НаКлиенте
Процедура ПриЗавершенииОбновленияТаблицыВизирования(ПараметрыРезультата, ДополнительныеПараметры) Экспорт
	
	Если ПараметрыРезультата = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ПараметрыРезультата.Статус = "Ошибка" Тогда
		// Ничего не делать или обработать ошибку.
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрШаблон(НСтр("en='Error during execution of %1';ru='Ошибка при выполнении: %1'"), 
		ПараметрыРезультата.КраткоеПредставлениеОшибки));
	Иначе
		ПриЗавершенииОбновленияТаблицыВизированияНаСервере(ПараметрыРезультата);
	КонецЕсли;
	
	ЗафиксироватьДлительностьКлючевойОперации();
	
КонецПроцедуры

&НаСервере
Процедура ПриЗавершенииОбновленияТаблицыВизированияНаСервере(ПараметрыРезультата)
	
	СтруктураРезультатаОбновления = ПолучитьИзВременногоХранилища(ПараметрыРезультата.АдресРезультата);
	
	СхемаКомпоновкиДанных         = ПоместитьВоВременноеХранилище(СтруктураРезультатаОбновления.СхемаКомпоновкиДанных, УникальныйИдентификатор);
	Результат                     = СтруктураРезультатаОбновления.РезультатТабличныйДокумент;
	ДанныеРасшифровки             = ПоместитьВоВременноеХранилище(СтруктураРезультатаОбновления.ДанныеРасшифровки, УникальныйИдентификатор);
	НомерКолонкиЭлементУправления = СтруктураРезультатаОбновления.НомерКолонкиЭлементУправления;
	ДанныеТабличногоДокумента.Загрузить(СтруктураРезультатаОбновления.ДанныеТабличногоДокумента);
	
	Если НЕ КомпоновщикИнициализирован Тогда
		Если ЭтоАдресВременногоХранилища(СхемаКомпоновкиДанных) Тогда
			Схема = ПолучитьИзВременногоХранилища(СхемаКомпоновкиДанных);
		Иначе
			Схема = Обработки.бит_КонсольОперативногоВизирования.ПолучитьМакет("СхемаКомпоновкиДанных");
		КонецЕсли;
		
		Если ПолучатьНастройкиКомпоновщика Тогда
			Настройки = Объект.Компоновщик.Настройки;
		Иначе
			Настройки = Схема.НастройкиПоУмолчанию;
		КонецЕсли;
		
		АдресСКД = ПоместитьВоВременноеХранилище(Схема, УникальныйИдентификатор);
		Объект.Компоновщик.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСКД));
		Объект.Компоновщик.ЗагрузитьНастройки(Настройки);
		
		КомпоновщикИнициализирован    = Истина;
		ПолучатьНастройкиКомпоновщика = Истина;
	КонецЕсли;
	
	ОбновитьСтатистикуСумм();
	
	Если ОтображатьРеквизитыВизы Тогда
		АдресПорядокИЗаголовкиПолей = ПоместитьВоВременноеХранилище(СтруктураРезультатаОбновления.ПорядокИЗаголовкиПолей,
																УникальныйИдентификатор);
		АдресТаблицаВиз             = ПоместитьВоВременноеХранилище(СтруктураРезультатаОбновления.РезультатТаблицаЗначений,
																УникальныйИдентификатор);
		ОбновитьСоставРеквизитовВиз = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПараметрыОбновленияТаблицыВизирования()

	НаименованиеЗадания = НСтр("ru='Заполнение таблицы визирования.';en='Filling the sight of the table.'");
	ВыполняемыйМетод = "Обработки.бит_КонсольОперативногоВизирования.ЗаполнитьТаблицуВизирования";
	
	НастройкиПараметров = НастройкаПараметровЗаполненияТаблицыВизирования();
	
	// Заполнение параметров длительной операции.
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	
	Если ВыполнятьНаКлиенте Тогда
		ПараметрыВыполнения.ЗапуститьВФоне   = Ложь;
		ПараметрыВыполнения.ЗапуститьНеВФоне = Истина;
	КонецЕсли;
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(ВыполняемыйМетод, НастройкиПараметров, ПараметрыВыполнения);

КонецФункции

&НаСервере
Функция НастройкаПараметровЗаполненияТаблицыВизирования()
	
	ПараметрыЗаполнения	= Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыЗаполненияТаблицыВизирования();
	ПараметрыЗаполнения.Ответственный                 = Объект.Ответственный;
	ПараметрыЗаполнения.НастройкиКомпоновщика         = Объект.Компоновщик.Настройки;
	Если ЭтоАдресВременногоХранилища(СхемаКомпоновкиДанных) Тогда
		ПараметрыЗаполнения.СхемаКомпоновкиДанных     = ПолучитьИзВременногоХранилища(СхемаКомпоновкиДанных);
	КонецЕсли;
	ПараметрыЗаполнения.ДанныеТабличногоДокумента     = РеквизитФормыВЗначение("ДанныеТабличногоДокумента");
	ПараметрыЗаполнения.МатрицаДоступа   		      = ПолучитьИзВременногоХранилища(АдресТаблицыДоступа);
	ПараметрыЗаполнения.ВариантОтбораВиз              = ВариантОтбораВиз;
	ПараметрыЗаполнения.ПолучатьНастройкиКомпоновщика = ПолучатьНастройкиКомпоновщика;
	ПараметрыЗаполнения.ВыводитьВТабличныйДокумент    = Истина;
	ПараметрыЗаполнения.РежимАрхива                   = РежимАрхива;
	ПараметрыЗаполнения.Отбор.ТипОбъекта              = ТипыОбъектовВизирования;
	ПараметрыЗаполнения.Отбор.Виза				      = ФильтрВизы; 
	ПараметрыЗаполнения.ГруппировкаОтчета             = ГруппировкаОтчета;
	ПараметрыЗаполнения.АвтопозицияРесурсов           = АвтопозицияРесурсов;
	
	Если ОтображатьРеквизитыВизы Тогда
		ПараметрыЗаполнения.ВыводитьВТаблицуЗначений         = Истина;
		ПараметрыЗаполнения.ВозвращатьПорядокИЗаголовкиПолей = Истина;
	КонецЕсли;
	
	Возврат ПараметрыЗаполнения;
	
КонецФункции

&НаСервереБезКонтекста
Функция ИдентификаторЭлементаУправленияКартинки()
	
	Возврат Обработки.бит_КонсольОперативногоВизирования.ИдентификаторЭлементаУправленияКартинки();
	
КонецФункции

&НаСервере
Функция ОбластьРезультатаПоИдентификатору(Идентификатор)
	
	ИмяОбластиЭУ = ИдентификаторЭлементаУправленияКартинки() + Идентификатор;
	ОбластьЭУ    = Результат.Области.Найти(ИмяОбластиЭУ);
	Возврат ОбластьЭУ;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЭтоУправляющаяОбласть(ИмяОбласти)
	
	Возврат Обработки.бит_КонсольОперативногоВизирования.ЭтоУправляющаяОбласть(ИмяОбласти);
	
КонецФункции

&НаСервереБезКонтекста
Функция ЧастьИмениЯчейкиБезКолонки(Знач ИмяОбласти)
	
	КолСимволовИдентификатораСтроки = СтрНайти(ИмяОбласти, "C");
	Если КолСимволовИдентификатораСтроки = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	ИмяОбластиИдентификатора = Лев(ИмяОбласти, КолСимволовИдентификатораСтроки);
	Возврат ИмяОбластиИдентификатора;
	
КонецФункции

&НаСервере
Функция ИДСтрокиПоИмениОбласти(Знач ИмяОбласти)
	
	Если НомерКолонкиЭлементУправления = 0 Тогда
		// Отчет не сформирован.
		Возврат Неопределено;
	КонецЕсли;
	
	Если НЕ ЭтоУправляющаяОбласть(ИмяОбласти) Тогда
		ИмяОбластиИдентификатора = ЧастьИмениЯчейкиБезКолонки(ИмяОбласти);
		Если ПустаяСтрока(ИмяОбластиИдентификатора) Тогда
			Возврат Неопределено;
		КонецЕсли;
		ИмяОбластиИдентификатора  = ИмяОбластиИдентификатора + НомерКолонкиЭлементУправления;
		ИмяОбластиПереименованная = Результат.Область(ИмяОбластиИдентификатора).Имя;
		Если ЭтоУправляющаяОбласть(ИмяОбластиПереименованная) Тогда
			ИмяОбласти = ИмяОбластиПереименованная;
		Иначе
			РазделительМногоуровневойЯчейки = СтрНайти(ИмяОбласти, ":");
			Если РазделительМногоуровневойЯчейки > 0 Тогда
				ИмяОбластиПравойЧасти = Сред(ИмяОбласти, РазделительМногоуровневойЯчейки);
				ПраваяЧастьОбласти    = ЧастьИмениЯчейкиБезКолонки(ИмяОбластиПравойЧасти);
				Если НЕ ПустаяСтрока(ПраваяЧастьОбласти) Тогда
					ИмяОбластиИдентификатора = ИмяОбластиИдентификатора + ПраваяЧастьОбласти + НомерКолонкиЭлементУправления;
				КонецЕсли;
			КонецЕсли;
			
			ИмяОбласти = Результат.Область(ИмяОбластиИдентификатора).Имя;
			Если НЕ ЭтоУправляющаяОбласть(ИмяОбласти) Тогда
				Возврат Неопределено;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ИДСтроки = СтрЗаменить(ИмяОбласти, ИдентификаторЭлементаУправленияКартинки(), "");
	
	Возврат ИДСтроки;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПараметрыОформленияЭлементаУправления(ПараметрыСтроки, ТипыРешений = Неопределено)
	
	Если ТипыРешений = Неопределено Тогда
		ТипыРешений = Новый Соответствие;
	КонецЕсли;
	
	Возврат Обработки.бит_КонсольОперативногоВизирования.ПараметрыОформленияЭлементаУправления(ПараметрыСтроки, ТипыРешений);
	
КонецФункции

&НаКлиенте
Процедура ОбработатьИзменениеВыбораФлага(ТекущаяОбласть)
	
	ИмяТекущейОбласти = ТекущаяОбласть.Имя;
	
	Если НЕ ЭтоУправляющаяОбласть(ИмяТекущейОбласти) Тогда
		Возврат;
	КонецЕсли;
	ИДСтроки = ИДСтрокиПоИмениОбласти(ИмяТекущейОбласти);
	
	СтрокиТаблицы = ДанныеТабличногоДокумента.НайтиСтроки(Новый Структура("ИД", ИДСтроки));
	Если СтрокиТаблицы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	СтрокаДанных = СтрокиТаблицы[0];
	
	РешениеПринято = ЗначениеЗаполнено(СтрокаДанных.ПринятоеРешение);
	
	Если РешениеПринято Тогда
		СтрокаДанных.Обрабатывать = Ложь;
	Иначе
		СтрокаДанных.Обрабатывать = НЕ СтрокаДанных.Обрабатывать;
		Если СтрокаДанных.Обрабатывать И ЗначениеЗаполнено(Объект.Решение) Тогда
			СписокВозможныхРешений = ВозможныеРешенияПоОбъекту(СтрокаДанных.ОбъектВизирования);
			Если СписокВозможныхРешений.НайтиПоЗначению(Объект.Решение) = Неопределено Тогда
				// Для выбранного объекта визирования не допустимо выбранное в шапке решение.
				Объект.Решение = Неопределено;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыСтроки = Новый Структура;
	ПараметрыСтроки.Вставить("Обрабатывать", СтрокаДанных.Обрабатывать);
	ПараметрыСтроки.Вставить("ПринятоеРешение", СтрокаДанных.ПринятоеРешение);
	
	ПараметрыОформленияЭУ = ПараметрыОформленияЭлементаУправления(ПараметрыСтроки);
	
	ТекущаяОбласть.Картинка = ПараметрыОформленияЭУ.Картинка;
	
	НомТекСтроки = ТекущаяОбласть.Верх;
	КолКолонок   = Результат.ШиринаТаблицы;
	ОбластьТекущейСтроки = Результат.Область(НомТекСтроки,1,НомТекСтроки,КолКолонок);
	// АПК:1345-выкл шрифт формируется динамически на основании настроек СКД текущей ячейки
	ОбластьТекущейСтроки.Шрифт = Новый Шрифт(ТекущаяОбласть.Шрифт,,,
							ПараметрыОформленияЭУ.Полужирный, ПараметрыОформленияЭУ.Наклонный);
	// АПК:1345-вкл
							
	ОбновитьСтатистикуСумм();
	
КонецПроцедуры

&НаКлиенте
Процедура РасшифроватьОбласть(ИДСтроки, Расшифровка = Неопределено)
	
	Если ИДСтроки = Неопределено И Расшифровка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ИДСтроки <> Неопределено Тогда
		Данные   = ПараметрыСтрокиДанных(ИДСтроки, "ОбъектВизирования");
	Иначе
		// Не удалось определить идентификатор, выполним стандартную расшифровку для текущей области
		Данные = ПолучитьДанныеРасшифровки(Расшифровка);
	КонецЕсли;
	
	ПоказатьЗначение(,Данные);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьОкноПринятияРешения(ИДСтроки)
	
	ПараметрыСтроки   = ПараметрыСтрокиДанных(ИДСтроки);
	
	Дополнительно = Новый Структура;
	Дополнительно.Вставить("ПараметрыСтроки", ПараметрыСтроки);
	
	Оповещение = Новый ОписаниеОповещения("СтрокаРезультатЗавершениеВыбораРешения", ЭтотОбъект, Дополнительно); 
	
	Если НЕ ЗначениеЗаполнено(ПараметрыСтроки.ПринятоеРешение) Тогда
		ВозможныеРешения = ВозможныеРешенияПоОбъекту(ПараметрыСтроки.ОбъектВизирования);
	Иначе
		ВозможныеРешения = Новый СписокЗначений;
		ВозможныеРешения.Добавить(ПредопределенноеЗначение("Справочник.бит_ВидыРешенийСогласования.ПустаяСсылка"), 
								  НСтр("ru='Очистить решение';en='Clear solution'"));
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура; 
	ПараметрыФормы.Вставить("МенюРешений",    ВозможныеРешения);
	ПараметрыФормы.Вставить("Комментарий",    Объект.Комментарий);
	ПараметрыФормы.Вставить("Виза", 	      ПараметрыСтроки.Виза);
	ПараметрыФормы.Вставить("Решение", 	      Объект.Решение);
	ПараметрыФормы.Вставить("Объект", 	      ПараметрыСтроки.ОбъектВизирования);
	ПараметрыФормы.Вставить("ТолькоПросмотр", Ложь);
	
	ОткрытьФорму("Обработка.бит_УстановкаВиз.Форма.ВыборРешения", ПараметрыФормы, ЭтотОбъект, ЭтотОбъект,,,
					Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВозможныеРешенияПоОбъекту(ОбъектВизирования)
	
	МетаданныеОбъекта = ОбъектВизирования.Метаданные();
	ОбъектСистемы     = Справочники.бит_ОбъектыСистемы.ОбъектСистемыПоПолномуИмени(МетаданныеОбъекта.ПолноеИмя());
	
	ПараметрыОпределенияСР = бит_ВизированиеСервер.НовыеПараметрыОпределенияСпискаРешений();
	ПараметрыОпределенияСР.ОбъектСистемы = ОбъектСистемы;
	ПараметрыОпределенияСР.ТекущийОбъект = ОбъектВизирования.ПолучитьОбъект();
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Организация", МетаданныеОбъекта) Тогда
		Организация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОбъектВизирования, "Организация");
		ПараметрыОпределенияСР.Вставить("Организация", Организация);
	КонецЕсли;
	
	Возврат бит_ВизированиеСервер.ДоступныеРешения(ПараметрыОпределенияСР);
	
КонецФункции

&НаСервере
Функция ОграничениеРешенийПоУстановленнымВизам()
	
	ТабДанные = РеквизитФормыВЗначение("ДанныеТабличногоДокумента");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДанныеТабличногоДокумента.Организация КАК Организация,
	|	ДанныеТабличногоДокумента.ОбъектСистемы КАК ОбъектСистемы,
	|	ДанныеТабличногоДокумента.Обрабатывать КАК Обрабатывать
	|ПОМЕСТИТЬ ДанныеТабличногоДокумента
	|ИЗ
	|	&ДанныеТабличногоДокумента КАК ДанныеТабличногоДокумента";
	Запрос.УстановитьПараметр("ДанныеТабличногоДокумента", ТабДанные);
	Запрос.Выполнить();
	
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДанныеТабличногоДокумента.ОбъектСистемы КАК ОбъектСистемы
	|ИЗ
	|	ДанныеТабличногоДокумента КАК ДанныеТабличногоДокумента
	|ГДЕ
	|	ДанныеТабличногоДокумента.Обрабатывать";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		// Не выбрано ни одной визы, вернем весь возможный список решений.
		Возврат ДоступныеРешения;
	КонецЕсли;
	
	// Необходимо ограничить список выбора только теми возможными решениями, которые доступны для всех отмеченных виз.
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДанныеТабличногоДокумента.Организация КАК Организация,
	|	ДанныеТабличногоДокумента.ОбъектСистемы КАК ОбъектСистемы
	|ПОМЕСТИТЬ ОбрабатываемыеДокументы
	|ИЗ
	|	ДанныеТабличногоДокумента КАК ДанныеТабличногоДокумента
	|ГДЕ
	|	ДанныеТабличногоДокумента.Обрабатывать
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ДанныеТабличногоДокумента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОбрабатываемыеДокументы.ОбъектСистемы КАК ОбъектСистемы,
	|	ЕСТЬNULL(НазначениеВидовРешений.ВидРешения, ЗНАЧЕНИЕ(Справочник.бит_ВидыРешенийСогласования.ПустаяСсылка)) КАК ВидРешения,
	|	НазначениеВидовРешений.КодСортировки КАК КодСортировки
	|ПОМЕСТИТЬ МатрицаДоступныхРешений
	|ИЗ
	|	ОбрабатываемыеДокументы КАК ОбрабатываемыеДокументы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_НазначениеВидовРешенийСогласования КАК НазначениеВидовРешений
	|		ПО (ОбрабатываемыеДокументы.Организация = НазначениеВидовРешений.Организация
	|				ИЛИ НазначениеВидовРешений.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка))
	|			И (ОбрабатываемыеДокументы.ОбъектСистемы = НазначениеВидовРешений.ОбъектСистемы
	|				ИЛИ НазначениеВидовРешений.ОбъектСистемы = ЗНАЧЕНИЕ(Справочник.бит_ОбъектыСистемы.ПустаяСсылка))
	|			И (НЕ НазначениеВидовРешений.ВидРешения.Отключено)
	|			И (НЕ НазначениеВидовРешений.ВидРешения.ПометкаУдаления)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ВидРешения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ОбрабатываемыеДокументы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МатрицаДоступныхРешений.ВидРешения КАК ВидРешения,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ МатрицаДоступныхРешений.ОбъектСистемы) КАК КоличествоВизРешения
	|ПОМЕСТИТЬ СтатистикаПоДоступнымРешениям
	|ИЗ
	|	МатрицаДоступныхРешений КАК МатрицаДоступныхРешений
	|
	|СГРУППИРОВАТЬ ПО
	|	МатрицаДоступныхРешений.ВидРешения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(СтатистикаПоДоступнымРешениям.КоличествоВизРешения) КАК КоличествоВизРешения
	|ПОМЕСТИТЬ МаксКоличествоВиз
	|ИЗ
	|	СтатистикаПоДоступнымРешениям КАК СтатистикаПоДоступнымРешениям
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтатистикаПоДоступнымРешениям.ВидРешения КАК ВидРешения,
	|	СтатистикаПоДоступнымРешениям.КоличествоВизРешения КАК КоличествоВизРешения
	|ПОМЕСТИТЬ ОтборныеРешения
	|ИЗ
	|	СтатистикаПоДоступнымРешениям КАК СтатистикаПоДоступнымРешениям
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МаксКоличествоВиз КАК МаксКоличествоВиз
	|		ПО СтатистикаПоДоступнымРешениям.КоличествоВизРешения = МаксКоличествоВиз.КоличествоВизРешения
	|			И (СтатистикаПоДоступнымРешениям.ВидРешения <> ЗНАЧЕНИЕ(Справочник.бит_ВидыРешенийСогласования.ПустаяСсылка))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СтатистикаПоДоступнымРешениям
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ МаксКоличествоВиз
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОтборныеРешения.ВидРешения КАК ВидРешения,
	|	МАКСИМУМ(МатрицаДоступныхРешений.КодСортировки) КАК КодСортировки,
	|	ОтборныеРешения.ВидРешения.Представление КАК ВидРешенияПредставление
	|ИЗ
	|	ОтборныеРешения КАК ОтборныеРешения
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МатрицаДоступныхРешений КАК МатрицаДоступныхРешений
	|		ПО ОтборныеРешения.ВидРешения = МатрицаДоступныхРешений.ВидРешения
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтборныеРешения.ВидРешения
	|
	|УПОРЯДОЧИТЬ ПО
	|	КодСортировки";
	                                      
	СписокРешений = Новый СписокЗначений;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СписокРешений.Добавить(Выборка.ВидРешения, Выборка.ВидРешенияПредставление);
	КонецЦикла; 

	Возврат СписокРешений;
	
КонецФункции

&НаСервере
Процедура ПроверитьКорректностьРешенияШапки()
	
	Если НЕ ЗначениеЗаполнено(Объект.Решение) Тогда
		Возврат;
	КонецЕсли;
	
	ДоступныеВидыРешений = ОграничениеРешенийПоУстановленнымВизам();
	Если ДоступныеВидыРешений.НайтиПоЗначению(Объект.Решение) = Неопределено Тогда
		Объект.Решение = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

// Обработчик закрытия формы выбора решения.
//  См. Синтакс-помощник: ОткрытьФорму().
// 
&НаКлиенте 
Процедура СтрокаРезультатЗавершениеВыбораРешения(РезультатВыбора, ДополнительныеДанные) Экспорт
	
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗапуститьЗамерДлительностиКлючевойОперации("УстановкаРешенияВСтроке");	
	
	ДлительнаяОперация = ПараметрыОперацииУстановикиРешенияВСтроке(РезультатВыбора, ДополнительныеДанные);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ТекстСообщения = НСтр("ru='Установка решения';en='Putting solution'");  
	ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПриЗавершенииУстановкиРешенияВСтроке", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОписаниеОповещения, ПараметрыОжидания);
	
КонецПроцедуры

// Процедура окончание процедуры "СтрокаРезультатЗавершениеВыбораРешения".
//
&НаКлиенте
Процедура ПриЗавершенииУстановкиРешенияВСтроке(ПараметрыРезультата, ДополнительныеПараметры) Экспорт
	
	ПриЗавершенииУстановкиРешенияВСтрокеНаСервере(ПараметрыРезультата, ДополнительныеПараметры);
	
	Если ОбновлятьВизыПослеСогласования Тогда
		ОбновитьСписокВизКлиент();
	Иначе
		ОбновитьКартуАлгоритма(Истина);
	КонецЕсли;
	
	ЗафиксироватьДлительностьКлючевойОперации();
	
КонецПроцедуры

&НаСервере
Процедура ПриЗавершенииУстановкиРешенияВСтрокеНаСервере(ПараметрыРезультата, ДополнительныеПараметры)
	
	РезультатУстановкиРешения = ПолучитьИзВременногоХранилища(ПараметрыРезультата.АдресРезультата);
	
	Для каждого Сообщение Из РезультатУстановкиРешения.СообщенияПользователю Цикл
		ОбщегоНазначения.СообщитьПользователю(Сообщение);
	КонецЦикла;
	
	ПараметрыСтроки = РезультатУстановкиРешения.ПараметрыСтроки;
	СтрокиДанных = ДанныеТабличногоДокумента.НайтиСтроки(Новый Структура("ИД", ПараметрыСтроки.ИД));
	ЗаполнитьЗначенияСвойств(СтрокиДанных[0], ПараметрыСтроки);
	
	ПараметрыОформленияЭУ = ПараметрыОформленияЭлементаУправления(ПараметрыСтроки);
	ОбластьЭУ = ОбластьРезультатаПоИдентификатору(ПараметрыСтроки.ИД);
	ОбластьЭУ.Картинка = ПараметрыОформленияЭУ.Картинка;
							
	НомТекСтроки = ОбластьЭУ.Верх;
	КолКолонок   = Результат.ШиринаТаблицы;
	ОбластьТекущейСтроки = Результат.Область(НомТекСтроки,1,НомТекСтроки,КолКолонок);
	// АПК:1345-выкл шрифт формируется динамически на основании настроек СКД текущей ячейки.
	ОбластьТекущейСтроки.Шрифт = Новый Шрифт(ОбластьЭУ.Шрифт,,,
							ПараметрыОформленияЭУ.Полужирный, ПараметрыОформленияЭУ.Наклонный);
	// АПК:1345-вкл
	
КонецПроцедуры

&НаСервере
Функция ПараметрыОперацииУстановикиРешенияВСтроке(РезультатВыбора, ДополнительныеДанные)

	НаименованиеЗадания = НСтр("ru='Установка решения в строке РМВ.';en='Putting solution in Approval workplace line.'");
	ВыполняемыйМетод = "Обработки.бит_КонсольОперативногоВизирования.УстановитьРешениеВСтроке";
	
	НастройкиПараметров = НастройкаПараметровУстановкиРешенияВСтроке(РезультатВыбора, ДополнительныеДанные);
	
	// Заполнение параметров длительной операции.
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	
	Если ВыполнятьНаКлиенте Тогда
		ПараметрыВыполнения.ЗапуститьВФоне   = Ложь;
		ПараметрыВыполнения.ЗапуститьНеВФоне = Истина;
	КонецЕсли;
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(ВыполняемыйМетод, НастройкиПараметров, ПараметрыВыполнения);

КонецФункции

&НаСервере
Функция НастройкаПараметровУстановкиРешенияВСтроке(РезультатВыбора, ДополнительныеДанные)
	
	ПараметрыЗаполнения	= Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыУстановкиРешенияВСтроке();
	ПараметрыЗаполнения.Решение             = РезультатВыбора.Решение;
	ПараметрыЗаполнения.Комментарий         = РезультатВыбора.Комментарий;
	ПараметрыЗаполнения.ПараметрыСтроки     = ДополнительныеДанные.ПараметрыСтроки;
	ПараметрыЗаполнения.ТекущийПользователь = Пользователи.ТекущийПользователь();
	
	Возврат ПараметрыЗаполнения;
	
КонецФункции

&НаСервере
Функция ПараметрыОперацииПакетнойУстановикиРешения()

	НаименованиеЗадания = НСтр("ru='Пакетная установка решения в РМВ.';en='Group setting solution in Approval workplace.'");
	ВыполняемыйМетод = "Обработки.бит_КонсольОперативногоВизирования.ПакетнаяУстановкаРешения";
	
	НастройкиПараметров = НастройкаПараметровПакетнойУстановкиРешения();
	
	// Заполнение параметров длительной операции.
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	
	Если ВыполнятьНаКлиенте Тогда
		ПараметрыВыполнения.ЗапуститьВФоне   = Ложь;
		ПараметрыВыполнения.ЗапуститьНеВФоне = Истина;
	КонецЕсли;
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(ВыполняемыйМетод, НастройкиПараметров, ПараметрыВыполнения);

КонецФункции

&НаСервере
Функция НастройкаПараметровПакетнойУстановкиРешения()
	
	ПараметрыЗаполнения	= Обработки.бит_КонсольОперативногоВизирования.НовыеПараметрыПакетнойУстановкиРешения();
	ПараметрыЗаполнения.Решение             = Объект.Решение;
	ПараметрыЗаполнения.Комментарий         = Объект.Комментарий;
	ПараметрыЗаполнения.ДанныеТабличногоДокумента = РеквизитФормыВЗначение("ДанныеТабличногоДокумента");
	ПараметрыЗаполнения.ТекущийПользователь = Пользователи.ТекущийПользователь();
	
	Возврат ПараметрыЗаполнения;
	
КонецФункции

// Процедура окончание процедуры "УстановитьРешение".
//
&НаКлиенте
Процедура ПриЗавершенииПакетнойУстановкиРешения(ПараметрыРезультата, ДополнительныеПараметры) Экспорт
	
	ПриЗавершенииПакетнойУстановкиРешенияНаСервере(ПараметрыРезультата, ДополнительныеПараметры);
	
	Если ОбновлятьВизыПослеСогласования Тогда
		ОбновитьСписокВизКлиент();
	Иначе
		ОбновитьКартуАлгоритма(Истина);
	КонецЕсли;
	
	Объект.Комментарий = "";
	
	ЗафиксироватьДлительностьКлючевойОперации();
	
КонецПроцедуры

&НаСервере
Процедура ПриЗавершенииПакетнойУстановкиРешенияНаСервере(ПараметрыРезультата, ДополнительныеПараметры)
	
	РезультатУстановкиРешения = ПолучитьИзВременногоХранилища(ПараметрыРезультата.АдресРезультата);
	
	Для каждого Сообщение Из РезультатУстановкиРешения.СообщенияПользователю Цикл
		ОбщегоНазначения.СообщитьПользователю(Сообщение);
	КонецЦикла;
	
	ТаблицаРезультат = РезультатУстановкиРешения.ДанныеТабличногоДокумента;
	ЗначениеВРеквизитФормы(ТаблицаРезультат, "ДанныеТабличногоДокумента");
	
	// Установим отметки завершенных операций
	ТипыРешений = Новый Соответствие;
	Для каждого СтрокаРезультата Из ТаблицаРезультат Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаРезультата.ПринятоеРешение) Тогда
			Продолжить;
		КонецЕсли;
		
		ПараметрыОформленияЭУ = ПараметрыОформленияЭлементаУправления(СтрокаРезультата, ТипыРешений);
		ОбластьЭУ = ОбластьРезультатаПоИдентификатору(СтрокаРезультата.ИД);
		ОбластьЭУ.Картинка = ПараметрыОформленияЭУ.Картинка;
		
		НомТекСтроки = ОбластьЭУ.Верх;
		КолКолонок   = Результат.ШиринаТаблицы;
		ОбластьТекущейСтроки = Результат.Область(НомТекСтроки,1,НомТекСтроки,КолКолонок);
		// АПК:1345-выкл шрифт формируется динамически на основании настроек СКД текущей ячейки
		ОбластьТекущейСтроки.Шрифт = Новый Шрифт(ОбластьЭУ.Шрифт,,,
			ПараметрыОформленияЭУ.Полужирный, ПараметрыОформленияЭУ.Наклонный);
		// АПК:1345-вкл
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПараметрыСтрокиДанных(ИДСтроки, ИмяПараметра = Неопределено)
	
	ТабДанные = РеквизитФормыВЗначение("ДанныеТабличногоДокумента");
	СтрокаДанных = ТабДанные.Найти(ИДСтроки, "ИД");
	Если СтрокаДанных = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ИмяПараметра <> Неопределено Тогда
		Возврат СтрокаДанных[ИмяПараметра];
	КонецЕсли;
	
	ПараметрыСтроки = Новый Структура;
	Для каждого КолонкаТаблицыДанных Из ТабДанные.Колонки Цикл
		ИмяКолонки = КолонкаТаблицыДанных.Имя;
		ПараметрыСтроки.Вставить(ИмяКолонки, СтрокаДанных[ИмяКолонки]);
	КонецЦикла;
	
	Возврат ПараметрыСтроки;
	
КонецФункции

&НаСервере
Процедура ОбновитьСтатистикуСумм()
	
	ТаблицаДанных = РеквизитФормыВЗначение("ДанныеТабличногоДокумента");
	Запрос        = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст  =
	"ВЫБРАТЬ
	|	ТаблицаДанных.Обрабатывать КАК Обрабатывать,
	|	ТаблицаДанных.ОбъектВизирования КАК ОбъектВизирования,
	|	ТаблицаДанных.СуммаДокумента КАК СуммаДокумента
	|ПОМЕСТИТЬ ТаблицаДанных
	|ИЗ
	|	&ТаблицаДанных КАК ТаблицаДанных";
	Запрос.УстановитьПараметр("ТаблицаДанных", ТаблицаДанных);
	Запрос.Выполнить();
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаДанных.ОбъектВизирования КАК ОбъектВизирования,
	|	ТаблицаДанных.СуммаДокумента КАК СуммаДокумента
	|ПОМЕСТИТЬ ВыбранныеВизы
	|ИЗ
	|	ТаблицаДанных КАК ТаблицаДанных
	|ГДЕ
	|	ТаблицаДанных.Обрабатывать
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(ВыбранныеВизы.ОбъектВизирования) КАК Количество,
	|	СУММА(ВыбранныеВизы.СуммаДокумента) КАК Сумма,
	|	МИНИМУМ(ВыбранныеВизы.СуммаДокумента) КАК Минимум,
	|	МАКСИМУМ(ВыбранныеВизы.СуммаДокумента) КАК Максимум,
	|	СУММА(ВыбранныеВизы.СуммаДокумента) / КОЛИЧЕСТВО(ВыбранныеВизы.ОбъектВизирования) КАК Среднее
	|ИЗ
	|	ВыбранныеВизы КАК ВыбранныеВизы";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ВыделенныеДокументыСумма      = Выборка.Сумма;
		ВыделенныеДокументыМаксимум   = Выборка.Максимум;
		ВыделенныеДокументыМинимум    = Выборка.Минимум;
		ВыделенныеДокументыСреднее    = Выборка.Среднее;
		ВыделенныеДокументыКоличество = Выборка.Количество;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРасшифровку(ВыбранноеДействие, ВыбранноеЗначение, ДополнительныеПараметры) Экспорт

	Если ВыбранноеДействие = ДействиеОбработкиРасшифровкиКомпоновкиДанных.Нет Тогда
		Возврат;
	КонецЕсли;
	
	Если ВыбранноеДействие = ДействиеОбработкиРасшифровкиКомпоновкиДанных.ОткрытьЗначение Тогда
		ПоказатьЗначение(,ВыбранноеЗначение);
	ИначеЕсли ВыбранноеДействие = ДействиеОбработкиРасшифровкиКомпоновкиДанных.Отфильтровать Тогда
		НовыеЭлементыОтбора = ВыбранноеЗначение.Структура[0].Отбор.Элементы;
		
		НастройкиКомпоновщика = Объект.Компоновщик.Настройки;
		НастройкиКомпоновщика.Отбор.Элементы.Очистить();
		Для каждого ПолеОтбора Из НовыеЭлементыОтбора Цикл
			НовоеПоле = НастройкиКомпоновщика.Отбор.Элементы.Добавить(ТипЗнч(ПолеОтбора));
			ЗаполнитьЗначенияСвойств(НовоеПоле, ПолеОтбора);
		КонецЦикла;
		
		ОбновитьСписокВизКлиент();
	ИначеЕсли ВыбранноеДействие = ДействиеОбработкиРасшифровкиКомпоновкиДанных.Упорядочить Тогда
		НовыеЭлементыПорядка = ВыбранноеЗначение.Структура[0].Порядок.Элементы;
		
		НастройкиКомпоновщика = Объект.Компоновщик.Настройки;
		НастройкиКомпоновщика.Порядок.Элементы.Очистить();
		Для каждого ПолеПорядка Из НовыеЭлементыПорядка Цикл
			НовоеПоле = НастройкиКомпоновщика.Порядок.Элементы.Добавить(ТипЗнч(ПолеПорядка));
			ЗаполнитьЗначенияСвойств(НовоеПоле, ПолеПорядка);
		КонецЦикла;
		
		ОбновитьСписокВизКлиент();
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область РаботаСТаблицейФормыНаборВизы

&НаКлиенте
Процедура УстановитьОтборНаборВизыКлиент()
	
	ТекущаяОбласть = Элементы.Результат.ТекущаяОбласть;
	Если ТекущаяОбласть = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПанельНаборВизыВидимость Тогда
		Возврат;
	КонецЕсли;
	
	ИДСтроки = ИДСтрокиПоИмениОбласти(ТекущаяОбласть.Имя);
	
	СтрокиТаблицы = ДанныеТабличногоДокумента.НайтиСтроки(Новый Структура("ИД", ИДСтроки));
	Если СтрокиТаблицы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	СтрокаДанных = СтрокиТаблицы[0];
	
	ТекущийОбъект = СтрокаДанных.ОбъектВизирования;
	УстановитьОтборНаборВизы(ТекущийОбъект);
	
КонецПроцедуры

// Процедура устанавливает отбор по текущему документу для набора виз.
//
// Параметры:
//  ТекущийОбъект  - ДокументСсылка.
//
&НаСервере
Процедура УстановитьОтборНаборВизы(ТекущийОбъект)

	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(НаборВизы, "Объект", ТекущийОбъект,
			ВидСравненияКомпоновкиДанных.Равно);

КонецПроцедуры
	 
#КонецОбласти

#Область СохранениеВосстановлениеНастроек

// Процедура - обработчик оповещения о закрытии формы сохранения настроек. 
//
&НаКлиенте
Процедура СохранитьНастройкиЗавершение(РезультатСохранения, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(РезультатСохранения) Тогда
		ТекущаяНастройка = РезультатСохранения;
		УстановитьЗаголовокФормы();
		Модифицированность = Ложь;
		Если ДополнительныеПараметры.ПриЗакрытии Тогда
			Закрыть();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - обработчик оповещения о закрытии формы применения настроек. 
//
&НаКлиенте
Процедура ВыбратьНастройкиЗавершение(РезультатСохранения, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(РезультатСохранения) Тогда        
		ТекущаяНастройка = РезультатСохранения;
		Если ПрименитьНастройки(ТекущаяНастройка) Тогда
			ОбновитьСписокВизКлиент();
		КонецЕсли;
		Модифицированность = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция НовыеСохраняемыеНастройкиОтчета()
	
	СтруктураНастройки = Новый Структура;
	СтруктураНастройки.Вставить("ТипыОбъектовВизирования",  Новый СписокЗначений);
	СтруктураНастройки.Вставить("ВариантОтбораВиз",		    0);
	СтруктураНастройки.Вставить("ФильтрВизы",	            Новый СписокЗначений);
	СтруктураНастройки.Вставить("НастройкиКомпоновщика");
	СтруктураНастройки.Вставить("НастройкиСвернуты",        Ложь);
	СтруктураНастройки.Вставить("ПанельАлгоритмВидимость",  Ложь);
	СтруктураНастройки.Вставить("ПанельНаборВизыВидимость", Ложь);
	СтруктураНастройки.Вставить("ПанельНастроекВидимость",  Ложь);
	СтруктураНастройки.Вставить("ОтображатьРеквизитыВизы",  Ложь);
	СтруктураНастройки.Вставить("АвтопозицияРесурсов",      Ложь);
	СтруктураНастройки.Вставить("ВыполнятьНаКлиенте",       Ложь);
	СтруктураНастройки.Вставить("ГруппировкаОтчета",        0);
	
	Возврат СтруктураНастройки;
	
КонецФункции

&НаСервере
Функция СохраняемыеНастройкиОтчета()
	
	СтруктураНастройки = НовыеСохраняемыеНастройкиОтчета();
	
	СтруктураНастройки.ТипыОбъектовВизирования  = ТипыОбъектовВизирования;
	СтруктураНастройки.ВариантОтбораВиз         = ВариантОтбораВиз;
	СтруктураНастройки.ФильтрВизы               = ФильтрВизы;
	СтруктураНастройки.НастройкиКомпоновщика    = Объект.Компоновщик.Настройки;
	СтруктураНастройки.НастройкиСвернуты        = НастройкиСвернуты;
	СтруктураНастройки.ПанельАлгоритмВидимость  = ПанельАлгоритмВидимость;
	СтруктураНастройки.ПанельНаборВизыВидимость = ПанельНаборВизыВидимость;
	СтруктураНастройки.ПанельНастроекВидимость  = ПанельНастроекВидимость;
	СтруктураНастройки.ОтображатьРеквизитыВизы  = ОтображатьРеквизитыВизы;
	СтруктураНастройки.АвтопозицияРесурсов      = АвтопозицияРесурсов;
	СтруктураНастройки.ВыполнятьНаКлиенте       = ВыполнятьНаКлиенте;
	СтруктураНастройки.ГруппировкаОтчета        = ГруппировкаОтчета;
	
	Возврат СтруктураНастройки;
	
КонецФункции

&НаСервереБезКонтекста
Функция НастраиваемыйОбъект()
	
	Возврат Обработки.бит_КонсольОперативногоВизирования.НаименованиеОбъектаСохраняемыхНастроек();
	
КонецФункции

// Функция применяет сохраненные настройки.
//
// Параметры:
//  ВыбраннаяНастройка  - СправочникСсылка.бит_СохраненныеНастройки.
//
&НаСервере
Функция ПрименитьНастройки(ВыбраннаяНастройка)
	
	НастройкиОбновлены = Ложь;
	
	Если ЗначениеЗаполнено(ВыбраннаяНастройка) Тогда
		СохраненнаяНастройка = ВыбраннаяНастройка.ХранилищеНастроек.Получить();
		Если ТипЗнч(СохраненнаяНастройка) = Тип("Структура") Тогда
			СтруктураНастроек = НовыеСохраняемыеНастройкиОтчета();
			ЗаполнитьЗначенияСвойств(СтруктураНастроек, СохраненнаяНастройка);
			ЗаполнитьЗначенияСвойств(ЭтотОбъект, СтруктураНастроек);
			Объект.Компоновщик.ЗагрузитьНастройки(СтруктураНастроек.НастройкиКомпоновщика);
			
			ПолучатьНастройкиКомпоновщика = Истина;
			НастройкиОбновлены = Истина;
		КонецЕсли;
	КонецЕсли; 
	
	ЗаполнитьСписокОбъектовВизирования();
	УстановитьНастройкаФильтраВиз();
	УстановитьВидимость();
	УстановитьЗаголовокФормы();
	Возврат НастройкиОбновлены;
	
КонецФункции

&НаСервере
Функция ВосстановитьНастройкиПоУмолчанию()
	
	// Пока значения по умолчанию, далее будет сохранение и восстановление.
	ПанельАлгоритмВидимость  = Ложь;
	ПанельНаборВизыВидимость = Ложь;
	ВариантОтбораВиз         = 0;
	
	// Получим настройку по - умолчанию и последнюю использованную.
	НастройкаПоУмолчанию = Обработки.бит_КонсольОперативногоВизирования.НастройкаПоУмолчанию();
	
	Если ЗначениеЗаполнено(НастройкаПоУмолчанию) Тогда
		Возврат ПрименитьНастройки(НастройкаПоУмолчанию);
	Иначе
		ЗаполнитьСписокОбъектовВизирования();
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

