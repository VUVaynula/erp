&НаСервере
Процедура УстановитьВидимость()
	
	// ГруппаАлгоритм.
	Элементы.ГрафическаяСхема.Видимость = ПанельАлгоритмВидимость;
	ТекстПодсказки = ?(ПанельАлгоритмВидимость, НСтр("ru='Скрыть карту';en='Hide map'"), НСтр("en='Show map';ru='Отобразить карту'"));
	Элементы.ДекорацияКартаАлгоритма.РасширеннаяПодсказка.Заголовок = ТекстПодсказки;
	
	// ГруппаНаборВиз.
	Элементы.НаборВизы.Видимость = ПанельНаборВизыВидимость;
	ТекстПодсказки = ?(ПанельНаборВизыВидимость, НСтр("ru='Скрыть визы';en='Hide visas'"), НСтр("en='Show visas';ru='Отобразить визы'"));
	Элементы.ДекорацияНаборВизы.РасширеннаяПодсказка.Заголовок = ТекстПодсказки;
	
	Элементы.РеквизитыВизы.Видимость = ОтображатьРеквизитыВизы;
	ТекстПодсказки = ?(ОтображатьРеквизитыВизы,
						НСтр("ru='Скрыть реквизиты визы';en='Hide visas fields'"),
						НСтр("ru='Отобразить реквизиты визы';en='Show visas fields'"));
	Элементы.ДекорацияРеквизитыВизы.РасширеннаяПодсказка.Заголовок = ТекстПодсказки;
	
	Элементы.ГруппаЛокальныеНастройки.Видимость = ПанельНастроекВидимость;
	ТекстПодсказки = ?(ПанельНастроекВидимость, 
					   НСтр("ru='Скрыть настройки';en='Hide Settings'"), 
					   НСтр("ru='Отобразить настройки';en='Display Settings'"));
	Элементы.ДекорацияНастройки.РасширеннаяПодсказка.Заголовок = ТекстПодсказки;

	ТекстПодсказки = ?(РежимАрхива, 
					   НСтр("ru='Выйти из архива';en='Disable archive mode'"), 
					   НСтр("ru='Архив согласования';en='Archive mode'"));
	Элементы.ДекорацияАрхив.РасширеннаяПодсказка.Заголовок = ТекстПодсказки;
	Заголовок      = ?(РежимАрхива,
					   НСтр("ru='Рабочее место визирования (Режим архива)';en='Approval workplace (Archive mode)'"), 
					   НСтр("ru='Рабочее место визирования';en='Approval workplace'"));
	
	// Управление видимостью настроек.
	Элементы.ГруппаПанельНавигации.Видимость = НЕ НастройкиСвернуты;
	Если НастройкиСвернуты Тогда
		Элементы.ОтображениеНастроек.Заголовок = НСтр("ru='Отобразить дополнительную панель';en='Display additional panel'");
		Элементы.ОтображениеНастроек.Картинка  = БиблиотекаКартинок.СтрелкаВниз;
	Иначе
		Элементы.ОтображениеНастроек.Заголовок = НСтр("ru='Скрыть дополнительную панель';en='Hide additional panel'");
		Элементы.ОтображениеНастроек.Картинка  = БиблиотекаКартинок.СтрелкаВверх;
	КонецЕсли;
	
	Элементы.НастройкаФильтрВизы.Доступность = (НастройкаВариантОтбораВиз = 3);
	
КонецПроцедуры

