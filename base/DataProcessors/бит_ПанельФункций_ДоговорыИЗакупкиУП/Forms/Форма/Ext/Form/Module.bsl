
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	ПодготовитьФорму();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СхемаУчетДоговоровВыбор(Элемент)
	
	ОбработатьВыбор(Элемент);
	
КонецПроцедуры

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбработатьВыбор(Элемент)
	
	Если Элемент.ТекущийЭлемент = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	ИмяЭлемента = Элемент.ТекущийЭлемент.Имя;
	НавигационнаяСсылкаБлока = Неопределено;
	Если НавигационныеСсылки.Свойство(ИмяЭлемента, НавигационнаяСсылкаБлока) 
		И ЗначениеЗаполнено(НавигационнаяСсылкаБлока) Тогда
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(НавигационнаяСсылкаБлока);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьФорму()
	
	// Готовим структуру из метаданных, чтобы проверка конфигурации реагировала на изменения.
	ОбъектыПодсистемы = Новый Структура;
	
	// Справочники.
	ОбъектыПодсистемы.Вставить("ДоговорыКонтрагентов",		Метаданные.Справочники.ДоговорыКонтрагентов);
	ОбъектыПодсистемы.Вставить("ДоговорыКредитовИДепозитов",Метаданные.Справочники.ДоговорыКредитовИДепозитов);
	Если НЕ бит_ОбщегоНазначения.ЭтоУТ() Тогда
		ОбъектыПодсистемы.Вставить("ДоговорыАренды", Метаданные.Справочники.ДоговорыАренды);
	КонецЕсли;
	
	// Документы.
	ОбъектыПодсистемы.Вставить("ДополнительныеУсловияПоДоговору",		Метаданные.Документы.бит_ДополнительныеУсловияПоДоговору);
	ОбъектыПодсистемы.Вставить("ПланируемоеПоступлениеДенежныхСредств",	Метаданные.Документы.бит_кзн_ПланируемоеПоступлениеДенежныхСредств);
	ОбъектыПодсистемы.Вставить("ЗаявкаНаРасходованиеСредств",			Метаданные.Документы.бит_кзн_ЗаявкаНаРасходованиеСредств);
	ОбъектыПодсистемы.Вставить("ПоступлениеБезналичныхДенежныхСредств",	Метаданные.Документы.ПоступлениеБезналичныхДенежныхСредств);
	ОбъектыПодсистемы.Вставить("ПриходныйКассовыйОрдер",				Метаданные.Документы.ПриходныйКассовыйОрдер);
	ОбъектыПодсистемы.Вставить("СписаниеБезналичныхДенежныхСредств",	Метаданные.Документы.СписаниеБезналичныхДенежныхСредств);
	ОбъектыПодсистемы.Вставить("РасходныйКассовыйОрдер",				Метаданные.Документы.РасходныйКассовыйОрдер);
	
	// Формирование навигационных ссылок и проверка доступа по функциональным опциям.
	НедоступныеОбъекты = Новый Массив;
	Для Каждого ОбъектПодсистемы Из ОбъектыПодсистемы Цикл
		НавигационнаяСсылкаБлока = ""; 
		ОбъектДоступен = ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектПодсистемы.Значение);
		Если ОбъектДоступен Тогда
			НавигационнаяСсылкаБлока = ПолучитьНавигационнуюСсылку(ОбъектПодсистемы.Значение);
		Иначе
			НедоступныеОбъекты.Добавить(ОбъектПодсистемы.Ключ);	
		КонецЕсли;
		ОбъектыПодсистемы[ОбъектПодсистемы.Ключ] = НавигационнаяСсылкаБлока;
	КонецЦикла;
	
	НавигационныеСсылки = Новый ФиксированнаяСтруктура(ОбъектыПодсистемы);
	
	СхемаУчетДоговоров = Обработки.бит_ПанельФункций_ДоговорыИЗакупкиУП.ПолучитьМакет("СхемаУчетДоговоров");
	
	// Ссылка может быть одновременно на разных схемах.
	Для Каждого НедоступныйОбъект Из НедоступныеОбъекты Цикл
		ЭлементыСхемы = СхемаУчетДоговоров.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект)
	
	ЭлементСхемы = ЭлементыСхемы[НедоступныйОбъект];
	ЭлементСхемы.ЦветФона = ЦветаСтиля.бит_ЦветНедоступногоПоля;
	
КонецПроцедуры

#КонецОбласти