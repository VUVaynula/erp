		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	бит_Дополнительный_2Остатки.Счет КАК СчетРезерва,
	ВЫБОР
		КОГДА бит_Дополнительный_2Остатки.Субконто1 ССЫЛКА Справочник.Контрагенты
			ТОГДА бит_Дополнительный_2Остатки.Субконто1
		КОГДА бит_Дополнительный_2Остатки.Субконто2 ССЫЛКА Справочник.Контрагенты
			ТОГДА бит_Дополнительный_2Остатки.Субконто2
		КОГДА бит_Дополнительный_2Остатки.Субконто3 ССЫЛКА Справочник.Контрагенты
			ТОГДА бит_Дополнительный_2Остатки.Субконто3
		КОГДА бит_Дополнительный_2Остатки.Субконто4 ССЫЛКА Справочник.Контрагенты
			ТОГДА бит_Дополнительный_2Остатки.Субконто4
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	КОНЕЦ КАК Контрагент,
	ВЫБОР
		КОГДА бит_Дополнительный_2Остатки.Субконто1 ССЫЛКА Справочник.ДоговорыКонтрагентов
			ТОГДА бит_Дополнительный_2Остатки.Субконто1
		КОГДА бит_Дополнительный_2Остатки.Субконто2 ССЫЛКА Справочник.ДоговорыКонтрагентов
			ТОГДА бит_Дополнительный_2Остатки.Субконто2
		КОГДА бит_Дополнительный_2Остатки.Субконто3 ССЫЛКА Справочник.ДоговорыКонтрагентов
			ТОГДА бит_Дополнительный_2Остатки.Субконто3
		КОГДА бит_Дополнительный_2Остатки.Субконто4 ССЫЛКА Справочник.ДоговорыКонтрагентов
			ТОГДА бит_Дополнительный_2Остатки.Субконто4
		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
	КОНЕЦ КАК ДоговорКонтрагента,
	ВЫБОР
		КОГДА бит_Дополнительный_2Остатки.Счет.Вид = ЗНАЧЕНИЕ(ВидСчета.Активный)
			ТОГДА бит_Дополнительный_2Остатки.СуммаМУОстатокДт
		КОГДА бит_Дополнительный_2Остатки.Счет.Вид = ЗНАЧЕНИЕ(ВидСчета.Пассивный)
			ТОГДА бит_Дополнительный_2Остатки.СуммаМУОстатокКт
		ИНАЧЕ бит_Дополнительный_2Остатки.СуммаМУОстаток
	КОНЕЦ * &amp;Коэффициент КАК СуммаОбязательства,
	100 КАК Процент,
	ВЫБОР
		КОГДА бит_Дополнительный_2Остатки.Счет.Вид = ЗНАЧЕНИЕ(ВидСчета.Активный)
			ТОГДА бит_Дополнительный_2Остатки.СуммаМУОстатокДт
		КОГДА бит_Дополнительный_2Остатки.Счет.Вид = ЗНАЧЕНИЕ(ВидСчета.Пассивный)
			ТОГДА бит_Дополнительный_2Остатки.СуммаМУОстатокКт
		ИНАЧЕ бит_Дополнительный_2Остатки.СуммаМУОстаток
	КОНЕЦ * &amp;Коэффициент КАК СуммаРезерва,
	ИСТИНА КАК Использование
ИЗ
	РегистрБухгалтерии.бит_Дополнительный_2.Остатки(
			&amp;НачалоПериода {(&amp;НачалоПериода)},
			{(Счет)},
			,
			Организация = &amp;Организация
				И ВЫБОР
					КОГДА Субконто1 ССЫЛКА Справочник.Контрагенты
						ТОГДА ИСТИНА
					КОГДА Субконто2 ССЫЛКА Справочник.Контрагенты
						ТОГДА ИСТИНА
					КОГДА Субконто3 ССЫЛКА Справочник.Контрагенты
						ТОГДА ИСТИНА
					КОГДА Субконто4 ССЫЛКА Справочник.Контрагенты
						ТОГДА ИСТИНА
					ИНАЧЕ ЛОЖЬ
				КОНЕЦ
				И ВЫБОР
					КОГДА Субконто1 ССЫЛКА Справочник.ДоговорыКонтрагентов
						ТОГДА ИСТИНА
					КОГДА Субконто2 ССЫЛКА Справочник.ДоговорыКонтрагентов
						ТОГДА ИСТИНА
					КОГДА Субконто3 ССЫЛКА Справочник.ДоговорыКонтрагентов
						ТОГДА ИСТИНА
					КОГДА Субконто4 ССЫЛКА Справочник.ДоговорыКонтрагентов
						ТОГДА ИСТИНА
					ИНАЧЕ ЛОЖЬ
				КОНЕЦ {(Организация)}) КАК бит_Дополнительный_2Остатки</query>
	</dataSet>
