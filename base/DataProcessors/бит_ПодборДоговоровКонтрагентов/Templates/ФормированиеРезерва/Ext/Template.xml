		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	бит_Дополнительный_2Остатки.Счет КАК СчетУчета,
	бит_Дополнительный_2Остатки.Субконто1 КАК Контрагент,
	бит_Дополнительный_2Остатки.Субконто2 КАК ДоговорКонтрагента,
	бит_Дополнительный_2Остатки.СуммаМУОстаток * &amp;Коэффициент КАК СуммаОбязательства,
	100 КАК Процент,
	бит_Дополнительный_2Остатки.СуммаМУОстаток * &amp;Коэффициент КАК СуммаРезерва,
	ИСТИНА КАК Использование
ИЗ
	РегистрБухгалтерии.бит_Дополнительный_2.Остатки(
			&amp;НачалоПериода {(&amp;НачалоПериода)},
			{(Счет)},
			&amp;МассивСубконто,
			Организация = &amp;Организация
				И Субконто2.ДатаОкончанияДействия &lt;&gt; ДАТАВРЕМЯ(1, 1, 1)
				И ДОБАВИТЬКДАТЕ(Субконто2.ДатаОкончанияДействия, ДЕНЬ, &amp;ЧислоДней) &lt;= &amp;НачалоПериода {(Организация)}) КАК бит_Дополнительный_2Остатки
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.бит_му_СобытияФинИнструментов.СрезПоследних(&amp;НачалоПериода {(&amp;НачалоПериода)}, Организация = &amp;Организация) КАК бит_му_СобытияФинИнструментовСрезПоследних
		ПО бит_Дополнительный_2Остатки.Субконто1 = бит_му_СобытияФинИнструментовСрезПоследних.ДоговорКонтрагента
			И бит_Дополнительный_2Остатки.Организация = бит_му_СобытияФинИнструментовСрезПоследних.Организация
ГДЕ
	бит_му_СобытияФинИнструментовСрезПоследних.Событие ЕСТЬ NULL </query>
