#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если НЕ Пользователи.ЭтоПолноправныйПользователь(, Истина) Тогда
		ВызватьИсключение НСтр("ru = 'Недостаточно прав доступа.
		                             |Изменение свойств регламентного задания доступно только администратору.';
		                             |en = 'Insufficient access rights.
		                             |Only administrators can change scheduled job settings.'",
			КатегорияОшибки.НарушениеПравДоступа);
	КонецЕсли;
	
	Действие = Параметры.Действие;
	Если СтрНайти(", Добавить, Скопировать, Изменить,", ", " + Действие + ",") = 0 Тогда
		ВызватьИсключение НСтр("ru = 'Неверные параметры открытия формы ""Регламентное задание"".';
								|en = 'Cannot open the ""Scheduled job"" form. Invalid opening parameters.'",
			КатегорияОшибки.ОшибкаКонфигурации);
	КонецЕсли;
	
	Если Действие = "Добавить" Тогда
		
		ПараметризуемыеЗадания = Новый Соответствие;
		ЗависимостиЗаданий     = РегламентныеЗаданияСлужебный.РегламентныеЗаданияЗависимыеОтФункциональныхОпций();
		
		ПараметрыОтбора        = Новый Структура;
		ПараметрыОтбора.Вставить("Параметризуется", Истина);
		РезультатПоиска = ЗависимостиЗаданий.НайтиСтроки(ПараметрыОтбора);
		
		Для Каждого СтрокаТаблицы Из РезультатПоиска Цикл
			ПараметризуемыеЗадания[СтрокаТаблицы.РегламентноеЗадание] = Истина;
		КонецЦикла;
		
		Расписание = Новый РасписаниеРегламентногоЗадания;
		
		Для Каждого РегламентноеЗаданиеМетаданные Из Метаданные.РегламентныеЗадания Цикл
			Если ПараметризуемыеЗадания[РегламентноеЗаданиеМетаданные] <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			ОписанияМетаданныхРегламентныхЗаданий.Добавить(РегламентноеЗаданиеМетаданные.Имя + Символы.ПС
					+ РегламентноеЗаданиеМетаданные.Синоним + Символы.ПС
					+ РегламентноеЗаданиеМетаданные.ИмяМетода,
				?(ПустаяСтрока(РегламентноеЗаданиеМетаданные.Синоним),
				  РегламентноеЗаданиеМетаданные.Имя,
				  РегламентноеЗаданиеМетаданные.Синоним) );
		КонецЦикла;
	Иначе
		Задание = РегламентныеЗаданияСервер.ПолучитьРегламентноеЗадание(Параметры.Идентификатор);
		ЗаполнитьЗначенияСвойств(
			ЭтотОбъект,
			Задание,
			"Ключ,
			|Предопределенное,
			|Использование,
			|Наименование,
			|ИмяПользователя,
			|ИнтервалПовтораПриАварийномЗавершении,
			|КоличествоПовторовПриАварийномЗавершении");
		
		Идентификатор = Строка(Задание.УникальныйИдентификатор);
		Если Задание.Метаданные = Неопределено Тогда
			ИмяМетаданных        = НСтр("ru = '<нет метаданных>';
										|en = '<no metadata>'");
			СинонимМетаданных    = НСтр("ru = '<нет метаданных>';
										|en = '<no metadata>'");
			ИмяМетодаМетаданных  = НСтр("ru = '<нет метаданных>';
										|en = '<no metadata>'");
		Иначе
			ИмяМетаданных        = Задание.Метаданные.Имя;
			СинонимМетаданных    = Задание.Метаданные.Синоним;
			ИмяМетодаМетаданных  = Задание.Метаданные.ИмяМетода;
		КонецЕсли;
		Расписание = Задание.Расписание;
		
		Если Действие = "Скопировать" Тогда
			Предопределенное = Ложь;
		Иначе
			СообщенияПользователюИОписаниеИнформацииОбОшибке =
				РегламентныеЗаданияСлужебный.СообщенияИОписанияОшибокРегламентногоЗадания(Задание);
		КонецЕсли;
		
		Элементы.Наименование.Видимость = Не Предопределенное;
	КонецЕсли;
	
	Если Действие <> "Изменить" Тогда
		Идентификатор = НСтр("ru = '<будет создан при записи>';
							|en = '<will be generated automatically>'");
		Использование = Ложь;
		
		Наименование = ?(Действие = "Добавить", "", РегламентныеЗаданияСлужебный.ПредставлениеРегламентногоЗадания(Задание));
	КонецЕсли;
	
	// Заполнение списка выбора имени пользователя.
	МассивПользователей = ПользователиИнформационнойБазы.ПолучитьПользователей(); // Массив из ПользовательИнформационнойБазы
	Для каждого Пользователь Из МассивПользователей Цикл
		Элементы.ИмяПользователя.СписокВыбора.Добавить(Пользователь.Имя);
	КонецЦикла;
	
	// бит_Финанс изменения кода. Начало.	
	бит_ПриСозданииНаСервере(Задание);
	// бит_Финанс изменения кода. Конец.

КонецПроцедуры 

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Действие = "Добавить" Тогда
		ПодключитьОбработчикОжидания("ВыборШаблонаНовогоРегламентногоЗадания", 0.1, Истина);
	Иначе
		ОбновитьЗаголовокФормы();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Оповещение = Новый ОписаниеОповещения("ЗаписатьИЗакрытьЗавершение", ЭтотОбъект);
	ОбщегоНазначенияКлиент.ПоказатьПодтверждениеЗакрытияФормы(Оповещение, Отказ, ЗавершениеРаботы);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НаименованиеПриИзменении(Элемент)
	
	ОбновитьЗаголовокФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Записать(Команда)
	
	ЗаписатьРегламентноеЗадание();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИЗакрытьВыполнить()
	
	ЗаписатьИЗакрытьЗавершение();
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьРасписаниеВыполнить()

	Диалог = Новый ДиалогРасписанияРегламентногоЗадания(Расписание);
	Диалог.Показать(Новый ОписаниеОповещения("ОткрытьРасписаниеЗавершение", ЭтотОбъект));
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ЗаписатьИЗакрытьЗавершение(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	ЗаписатьРегламентноеЗадание();
	Модифицированность = Ложь;
	
	// бит_Финанс изменения кода. Начало.
	// Закрыть();
	// ВАЖНО!!! Форма закроется сама, при выполнении оповещения.
	Результат = Новый Структура("Расписание, Использование");
	ЗаполнитьЗначенияСвойств(Результат, ЭтотОбъект);
	ОповеститьОВыборе(Результат);
	// бит_Финанс изменения кода. Конец.
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборШаблонаНовогоРегламентногоЗадания()
	
	// Выбор шаблона регламентного задания (метаданные).
	ОписанияМетаданныхРегламентныхЗаданий.ПоказатьВыборЭлемента(
		Новый ОписаниеОповещения("ВыборШаблонаНовогоРегламентногоЗаданияЗавершение", ЭтотОбъект),
		НСтр("ru = 'Выберите шаблон регламентного задания';
			|en = 'Select a scheduled job template'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборШаблонаНовогоРегламентногоЗаданияЗавершение(ЭлементСписка, Контекст) Экспорт
	
	Если ЭлементСписка = Неопределено Тогда
		Закрыть();
		Возврат;
	КонецЕсли;
	
	ИмяМетаданных       = СтрПолучитьСтроку(ЭлементСписка.Значение, 1);
	СинонимМетаданных   = СтрПолучитьСтроку(ЭлементСписка.Значение, 2);
	ИмяМетодаМетаданных = СтрПолучитьСтроку(ЭлементСписка.Значение, 3);
	Наименование        = ЭлементСписка.Представление;
	
	ОбновитьЗаголовокФормы();
	
	// бит_Финанс изменения кода. Начало.
	бит_УстановитьФлагиЗаданий(ЭтотОбъект);
	бит_УправлениеФормой(ЭтотОбъект);
	// бит_Финанс изменения кода. Конец.

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьРасписаниеЗавершение(НовоеРасписание, Контекст) Экспорт

	Если НовоеРасписание <> Неопределено Тогда
		Расписание = НовоеРасписание;
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьРегламентноеЗадание()
	
	Если НЕ ЗначениеЗаполнено(ИмяМетаданных) Тогда
		Возврат;
	КонецЕсли;
	
	// бит_Финанс изменения кода. Начало.
	Если бит_ОбязательноЗаполнятьПользователя(ЭтотОбъект) Тогда
		Если НЕ ЗначениеЗаполнено(ИмяПользователя) Тогда
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Поле", "Заполнение",  НСтр("ru = 'Имя Пользователя'"));
			ВызватьИсключение ТекстСообщения;
		КонецЕсли;
	КонецЕсли;
	// бит_Финанс изменения кода. Конец.

	ТекущийИдентификатор = ?(Действие = "Изменить", Идентификатор, Неопределено);
	
	ЗаписатьРегламентноеЗаданиеНаСервере();
	ОбновитьЗаголовокФормы();
	
	Оповестить("Запись_РегламентныеЗадания", ТекущийИдентификатор);
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьРегламентноеЗаданиеНаСервере()
	
	ПараметрыЗадания = Новый Структура(
	"Ключ,
	|Наименование,
	|Использование,
	|ИмяПользователя,
	|ИнтервалПовтораПриАварийномЗавершении,
	|КоличествоПовторовПриАварийномЗавершении,
	|Расписание");
	ЗаполнитьЗначенияСвойств(ПараметрыЗадания, ЭтотОбъект);
	
	// бит_Финанс изменения кода. Начало.
	бит_УстановитьПараметрыЗадания(ПараметрыЗадания);
	// бит_Финанс изменения кода. Конец.

	Если Действие = "Изменить" Тогда
		РегламентныеЗаданияСервер.ИзменитьРегламентноеЗадание(Идентификатор, ПараметрыЗадания);
	Иначе
		ПараметрыЗадания.Вставить("Метаданные", Метаданные.РегламентныеЗадания[ИмяМетаданных]);
		
		Задание = РегламентныеЗаданияСервер.ДобавитьРегламентноеЗадание(ПараметрыЗадания);
		
		Идентификатор = Строка(Задание.УникальныйИдентификатор);
		Действие = "Изменить";
	КонецЕсли;
	
	Модифицированность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗаголовокФормы()
	
	Если НЕ ПустаяСтрока(Наименование) Тогда
		Представление = Наименование;
		
	ИначеЕсли НЕ ПустаяСтрока(СинонимМетаданных) Тогда
		Представление = СинонимМетаданных;
	Иначе
		Представление = ИмяМетаданных;
	КонецЕсли;
	
	Если Действие = "Изменить" Тогда
		Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = '%1 (Регламентное задание)';
																				|en = '%1 (Scheduled job)'"), Представление);
	Иначе
		Заголовок = НСтр("ru = 'Регламентное задание (создание)';
						|en = 'Scheduled job (Create)'");
	КонецЕсли;
	
КонецПроцедуры

#Область бит_БИТФИНАНС

&НаСервере
Процедура бит_ПриСозданииНаСервере(Задание)

	// Служебные реквизиты:
	ДобавляемыеРеквизиты = Новый Массив;
	ТипБулево			 = Новый ОписаниеТипов("Булево");
	ТипСтрока 			 = ОбщегоНазначения.ОписаниеТипаСтрока(0);
	
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ЭтоРегистрацияОповещенийОВизировании", 		 ТипБулево));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ЭтоСоздатьДокументыПланированияИзДопУсловий", ТипБулево));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ЭтоОтправкаОповещений", 						 ТипБулево));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ЭтоРегистрацияНапоминанийПоДоговорам", 		 ТипБулево));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ЭтоУстановкаРешенийПоПросроченнымВизам", 	 ТипБулево));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ЭтоЗакрытиеДокументовПланирования", 			 ТипБулево));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ЭтоЗаданиеСПараметрами", 			 		 ТипБулево));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("АдресХранилищаПараметров", 			 		 ТипСтрока));
	
	ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	// Команды:
	НоваяКоманда		   = Команды.Добавить("бит_ОткрытьФормуПараметров");
	НоваяКоманда.Действие  = "бит_Подключаемый_ОткрытьФормуПараметров";
	НоваяКоманда.Заголовок = НСтр("ru = 'Настройки'; en = 'Settings'");
	НоваяКоманда.Подсказка = НСтр("ru = 'Настроить параметры выполнения'; en = 'Configure Execution Parameters'");
	// Элементы:
	НоваяКнопка = Элементы.Добавить("бит_ГиперссылкаОткрытьФормуПараметров",
					Тип("КнопкаФормы"), Элементы.ГруппаВключениеИРасписание);
					
	НоваяКнопка.ИмяКоманды = НоваяКоманда.Имя;
	НоваяКнопка.Вид		   = ВидКнопкиФормы.Гиперссылка;
	НоваяКнопка.ЦветТекста = ЦветаСтиля.бит_ЦветГиперссылки;

	бит_УстановитьФлагиЗаданий(ЭтотОбъект);
	бит_УправлениеФормой(ЭтотОбъект);
	бит_ПрочитатьПараметрыЗадания(Задание);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура бит_УстановитьФлагиЗаданий(Форма)
	
	ИмяМетаданных = Форма.ИмяМетаданных;
	
	Форма.ЭтоРегистрацияОповещенийОВизировании 			= (ИмяМетаданных = "бит_РегистрацияОповещенийОВизировании");
	Форма.ЭтоСоздатьДокументыПланированияИзДопУсловий 	= (ИмяМетаданных = "бит_СоздатьДокументыПланированияИзДопУсловий");
	Форма.ЭтоОтправкаОповещений							= (ИмяМетаданных = "бит_ОтправкаОповещений");
	Форма.ЭтоРегистрацияНапоминанийПоДоговорам 			= (ИмяМетаданных = "бит_РегистрацияНапоминанийПоДоговорам");
	Форма.ЭтоУстановкаРешенийПоПросроченнымВизам 		= (ИмяМетаданных = "бит_УстановкаРешенийПоПросроченнымВизам");
	Форма.ЭтоЗакрытиеДокументовПланирования 			= (ИмяМетаданных = "бит_ЗакрытиеДокументовПланирования");
	
	Форма.ЭтоЗаданиеСПараметрами = Форма.ЭтоРегистрацияОповещенийОВизировании
				 			   ИЛИ Форма.ЭтоУстановкаРешенийПоПросроченнымВизам
				 			   ИЛИ Форма.ЭтоСоздатьДокументыПланированияИзДопУсловий
				 			   ИЛИ Форма.ЭтоЗакрытиеДокументовПланирования;
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура бит_УправлениеФормой(Форма)

	Элементы = Форма.Элементы;
				 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "бит_ГиперссылкаОткрытьФормуПараметров", 
		"Видимость",  Форма.ЭтоЗаданиеСПараметрами);
	
	Элементы.ИмяПользователя.АвтоОтметкаНезаполненного = бит_ОбязательноЗаполнятьПользователя(Форма);
	
КонецПроцедуры

&НаСервере
Процедура бит_ПрочитатьПараметрыЗадания(Задание)

	Перем ПараметрыЗадания;
		
	Если НЕ ЭтотОбъект["ЭтоЗаданиеСПараметрами"] Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Задание.Параметры) Тогда
		ПараметрыЗадания = Задание.Параметры[0];
		Если ТипЗнч(ПараметрыЗадания) <> Тип("Структура") Тогда
			ПараметрыЗадания = Неопределено;
		КонецЕсли
	КонецЕсли;	

	ЭтотОбъект["АдресХранилищаПараметров"] = ПоместитьВоВременноеХранилище(ПараметрыЗадания, Новый УникальныйИдентификатор());
	
КонецПроцедуры

&НаКлиенте
Процедура бит_Подключаемый_ОткрытьФормуПараметров(Команда)

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ИмяМетаданных",   ИмяМетаданных);
	ПараметрыФормы.Вставить("АдресВХранилище", ЭтотОбъект["АдресХранилищаПараметров"]);
	ПараметрыФормы.Вставить("Заголовок",	   Заголовок);
	
	Оповещение = Новый ОписаниеОповещения("бит_ОткрытьФормуПараметровЗавершение", ЭтотОбъект); 
	ОткрытьФорму("Обработка.бит_УправлениеРегламентнымиЗаданиями.Форма.ПараметрыВыполнения",
		ПараметрыФормы, ЭтотОбъект,,,, Оповещение);	

КонецПроцедуры

&НаКлиенте 
Процедура бит_ОткрытьФормуПараметровЗавершение(РезультатВыбора, ДополнительныеПараметры) Экспорт
		
	Если ЭтоАдресВременногоХранилища(РезультатВыбора) Тогда
		ЭтотОбъект["АдресХранилищаПараметров"] = РезультатВыбора;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция бит_ОбязательноЗаполнятьПользователя(Форма)

	Результат = Форма.ЭтоРегистрацияОповещенийОВизировании
			ИЛИ Форма.ЭтоОтправкаОповещений
			ИЛИ Форма.ЭтоРегистрацияНапоминанийПоДоговорам
			ИЛИ Форма.ЭтоУстановкаРешенийПоПросроченнымВизам;
			  
	Возврат Результат;		  

КонецФункции

&НаСервере
Процедура бит_УстановитьПараметрыЗадания(СвойстваЗадания)

	Если НЕ ЭтотОбъект["ЭтоЗаданиеСПараметрами"] Тогда
		Возврат;
	КонецЕсли;	

	ПараметрыЗадания = Неопределено;
	
	Если ЭтоАдресВременногоХранилища(ЭтотОбъект["АдресХранилищаПараметров"]) Тогда
		ПараметрыЗадания = ПолучитьИзВременногоХранилища(ЭтотОбъект["АдресХранилищаПараметров"]);
	КонецЕсли;
	
	СвойстваЗадания.Вставить("Параметры", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПараметрыЗадания));
	
КонецПроцедуры

#КонецОбласти // бит_БИТФИНАНС

#КонецОбласти
