
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Стандартные действия при создании на сервере.
	бит_РаботаСДиалогамиСервер.ФормаПриСозданииНаСервере(Отказ, СтандартнаяОбработка, ЭтотОбъект, Объект);
	ПодготовитьФорму();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СхемаПолучениеДанныхВыбор(Элемент)
	
	ОбработатьВыбор(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура СхемаОтчетностьВыбор(Элемент)
	
	ОбработатьВыбор(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура СхемаПрезентацияОтчетностиВыбор(Элемент)
	
	ОбработатьВыбор(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура СхемаОбменДаннымиMSExcelВыбор(Элемент)
	
	ОбработатьВыбор(Элемент);
	
КонецПроцедуры

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбработатьВыбор(Элемент)
	
	Если Элемент.ТекущийЭлемент = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	ИмяЭлемента = Элемент.ТекущийЭлемент.Имя;
	НавигационнаяСсылкаБлока = Неопределено;
	Если НавигационныеСсылки.Свойство(ИмяЭлемента, НавигационнаяСсылкаБлока) 
		И ЗначениеЗаполнено(НавигационнаяСсылкаБлока) Тогда
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(НавигационнаяСсылкаБлока);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПодготовитьФорму()

	// Готовим структуру из метаданных, чтобы проверка конфигурации реагировала на изменения.
	ОбъектыПодсистемы = Новый Структура;
	
	// Справочники.
	ОбъектыПодсистемы.Вставить("Запросы",								Метаданные.Справочники.бит_Запросы);
	ОбъектыПодсистемы.Вставить("ИсточникиДанных",						Метаданные.Справочники.бит_ИсточникиДанных);
	ОбъектыПодсистемы.Вставить("ВидыИнформационныхБаз",					Метаданные.Справочники.бит_мпд_ВидыИнформационныхБаз);
	ОбъектыПодсистемы.Вставить("НастройкиВнешнихПодключений",			Метаданные.Справочники.бит_мпд_НастройкиВнешнихПодключений);
	ОбъектыПодсистемы.Вставить("НастройкиПуловПодключений",				Метаданные.Справочники.бит_мпд_НастройкиПуловПодключений);
	ОбъектыПодсистемы.Вставить("СпособыКомпоновкиИсточниковДанных",		Метаданные.Справочники.бит_СпособыКомпоновкиИсточниковДанных);
	ОбъектыПодсистемы.Вставить("НастройкиПроизвольныхОтчетов",			Метаданные.Справочники.бит_НастройкиПроизвольныхОтчетов);
	ОбъектыПодсистемы.Вставить("НастройкиОтчетов",						Метаданные.Справочники.бит_НастройкиОтчетов);
	ОбъектыПодсистемы.Вставить("ЭкземплярыОтчетов",						Метаданные.Справочники.бит_ЭкземплярыОтчетов);
	ОбъектыПодсистемы.Вставить("НастройкиПрезентацийОтчетности",		Метаданные.Справочники.бит_мпд_НастройкиПрезентацийОтчетности);
	ОбъектыПодсистемы.Вставить("НастройкиЗагрузкиИзExcel",				Метаданные.Справочники.бит_НастройкиЗагрузкиИзExcel);
	
	// Документы.
	ОбъектыПодсистемы.Вставить("ПолучениеФактическихДанных",			Метаданные.Документы.бит_ПолучениеФактическихДанных);
	
	// Обработки.
	ОбъектыПодсистемы.Вставить("ЗаполнениеПравилПоискаДанных",			Метаданные.Обработки.бит_ЗаполнениеПравилПоискаДанных);
	ОбъектыПодсистемы.Вставить("ПрезентацияОтчетности",					Метаданные.Обработки.бит_ПрезентацияОтчетности);
	ОбъектыПодсистемы.Вставить("ИмпортОбъектовИзExcel",					Метаданные.Обработки.бит_ИмпортОбъектовИзExcel);
	ОбъектыПодсистемы.Вставить("ЗагрузкаДанныхИзТабличногоДокумента",	Метаданные.Обработки.бит_ЗагрузкаДанныхИзТабличногоДокумента);
	
	// Отчеты.
	ОбъектыПодсистемы.Вставить("ОтчетПоСпособамКомпоновкиИсточников",	Метаданные.Отчеты.бит_ОтчетПоСпособамКомпоновкиИсточников);
	ОбъектыПодсистемы.Вставить("ПроизвольныйОтчет",						Метаданные.Отчеты.бит_ПроизвольныйОтчет);
	ОбъектыПодсистемы.Вставить("УниверсальныйОтчетПоИсточникамДанных",	Метаданные.Отчеты.бит_УниверсальныйОтчетПоИсточникамДанных);

	// Формирование навигационных ссылок и проверка доступа по функциональным опциям.
	НедоступныеОбъекты = Новый Массив;
	Для Каждого ОбъектПодсистемы Из ОбъектыПодсистемы Цикл
		НавигационнаяСсылкаБлока = ""; 
		ОбъектДоступен = ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектПодсистемы.Значение);
		Если ОбъектДоступен Тогда
			НавигационнаяСсылкаБлока = ПолучитьНавигационнуюСсылку(ОбъектПодсистемы.Значение);
		Иначе
			НедоступныеОбъекты.Добавить(ОбъектПодсистемы.Ключ);	
		КонецЕсли;
		ОбъектыПодсистемы[ОбъектПодсистемы.Ключ] = НавигационнаяСсылкаБлока;
	КонецЦикла;
	
	НавигационныеСсылки = Новый ФиксированнаяСтруктура(ОбъектыПодсистемы);
	
	СхемаПолучениеДанных		= Обработки.бит_ПанельФункций_ПолучениеДанных.ПолучитьМакет("СхемаПолучениеДанных");
	СхемаОтчетность				= Обработки.бит_ПанельФункций_ПолучениеДанных.ПолучитьМакет("СхемаОтчетность");
	СхемаПрезентацияОтчетности	= Обработки.бит_ПанельФункций_ПолучениеДанных.ПолучитьМакет("СхемаПрезентацияОтчетности");
	СхемаОбменДаннымиMSExcel	= Обработки.бит_ПанельФункций_ПолучениеДанных.ПолучитьМакет("СхемаОбменДаннымиMSExcel");
	
	// Ссылка может быть одновременно на разных схемах.
	Для Каждого НедоступныйОбъект Из НедоступныеОбъекты Цикл
		ЭлементыСхемы = СхемаПолучениеДанных.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаОтчетность.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаПрезентацияОтчетности.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
		ЭлементыСхемы = СхемаОбменДаннымиMSExcel.ЭлементыГрафическойСхемы; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭлементыСхемы, НедоступныйОбъект) Тогда
			ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОтметитьНедоступныйЭлемент(ЭлементыСхемы, НедоступныйОбъект)
	
	ЭлементСхемы = ЭлементыСхемы[НедоступныйОбъект];
	ЭлементСхемы.ЦветФона = ЦветаСтиля.бит_ЦветНедоступногоПоля;
	
КонецПроцедуры

#КонецОбласти
