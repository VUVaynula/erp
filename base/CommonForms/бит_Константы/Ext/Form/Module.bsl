	ИспользоватьЭлектроннуюПочтуДляВизирования = Константы.бит_ИспользоватьЭлектроннуюПочтуДляВизирования.Получить();
	КодировкаФайловВложенийБезСигнатуры        = Константы.бит_КодировкаФайловВложенийБезСигнатуры.Получить();
	ИспользоватьДелопроизводство               = Константы.бит_ИспользоватьДелопроизводство.Получить();
	ИспользоватьPowerBI                        = Константы.бит_ИспользоватьPowerBI.Получить();
	
	РежимФормированияОтчетов             = Константы.бит_РежимФормированияОтчетов.Получить();
	ИнтервалПроверкиКэша                 = Константы.бит_ИнтервалПроверкиАктуальностиКэшаНастроек.Получить();
	
	ТекущаяВерсияПродукта            = Константы.бит_ТекущаяВерсияПродукта.Получить();
	
	СистемаЛицензирования10 = Константы.бит_СистемаЛицензирования10.Получить();
	Если СистемаЛицензирования10 Тогда
		СистемаЛицензирования = 1;
	Иначе	
		СистемаЛицензирования = 2;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьКонстантыМСФО()
	
	Если бит_ОбщегоНазначения.ЭтоУТ() Тогда
		Возврат;
	КонецЕсли;
	
	ВестиПартионныйУчетПоСкладам                = Константы["бит_му_ВестиПартионныйУчетПоСкладам"].Получить();
	ВестиУчетПоТипамПроводок                    = Константы["бит_ВестиУчетПоТипамПроводок"].Получить();
	ИспользоватьСторнируемыеПроводки            = Константы["бит_ИспользоватьСторнируемыеПроводки"].Получить();
	ПроводитьОперацииПослеУтверждения           = Константы["бит_му_ПроводитьОперацииПослеУтверждения"].Получить();
	
КонецПроцедуры

// Процедура управляет отображением элементов формы.
// 
// Параметры:
//  Нет.
// 
&НаСервере
Процедура УправлениеВидимостьюДоступностью()
	
	Элементы.РежимФормированияОтчетов.ТолькоПросмотр		  = бит_ОбщегоНазначения.ЭтоФайловаяИБ();
	Элементы.ЗаполнитьТипыПроводок.Доступность			      = ВестиУчетПоТипамПроводок;
	Элементы.ИспользоватьЭлектронныеПодписи.Видимость	      = Константы.ИспользоватьЭлектронныеПодписи.Получить();
	
	Элементы.ОповещенияВТелеграмОНовыхВизах.Доступность       = ИспользоватьТелеграм;
	Элементы.ОповещенияВТелеграмОНовыхВизахОтступ.Видимость   =
		ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(Метаданные.Константы.бит_ОповещенияВТелеграмОНовыхВизах);
		
	Элементы.КодировкаФайловВложенийБезСигнатурыОтступ.Видимость =
		ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(Метаданные.Константы.бит_КодировкаФайловВложенийБезСигнатуры);
		
	Элементы.ТекущаяВерсияПродукта.Доступность	= бит_ПолныеПрава.ДоступностьОбщихНастроек();
	Элементы.НастройкиОповещений.Видимость		= Константы.бит_фн_ИспользоватьМеханизмОповещений.Получить();
	
КонецПроцедуры

// Процедура определяет доступность редактирования валюты регламентированного учета.
// 
// Параметры:
//  Нет.
// 
&НаСервере
Процедура ОпределитьДоступностьРедактированияВалютыРегламентированногоУчета()

	УстановитьПривилегированныйРежим(Истина);
			
	// Запрос по регистрам "бит_ОборотыПоБюджетам", "бит_ПланируемыйРасходДенежныхСредств" 
	// и "бит_ПланируемоеПоступлениеДенежныхСредств" на предмет наличия в них записей.  
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	бит_ОборотыПоБюджетам.Период
	|ИЗ
	|	РегистрНакопления.бит_ОборотыПоБюджетам КАК бит_ОборотыПоБюджетам
	|";
	Если Метаданные.РегистрыНакопления.Найти("бит_ПланируемыйРасходДенежныхСредств") <> Неопределено Тогда
		Запрос.Текст = Запрос.Текст + "
		|ОБЪЕДИНИТЬ ВСЕ
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	бит_ПланируемыйРасходДенежныхСредств.Период
		|ИЗ
		|	РегистрНакопления.бит_ПланируемыйРасходДенежныхСредств КАК бит_ПланируемыйРасходДенежныхСредств
		|";
	КонецЕсли;
	Если Метаданные.РегистрыНакопления.Найти("бит_ПланируемоеПоступлениеДенежныхСредств") <> Неопределено Тогда
		Запрос.Текст = Запрос.Текст + "
		|ОБЪЕДИНИТЬ ВСЕ
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	бит_ПланируемоеПоступлениеДенежныхСредств.Период
		|ИЗ
		|	РегистрНакопления.бит_ПланируемоеПоступлениеДенежныхСредств КАК бит_ПланируемоеПоступлениеДенежныхСредств
		|";
	КонецЕсли;
	
	// Если результат запроса не пустой, то запрещаем изменение валюты и меняем надпись.
	Если Не Запрос.Выполнить().Пустой() Тогда
		Элементы.ВалютаУправленческогоУчета.ТолькоПросмотр = Истина;
		Элементы.НадписьПредупреждение.Заголовок = НСтр("ru = 'Изменение валюты запрещено, так как есть проведенные документы в подсистемах ""Бюджетирование"" и ""Казначейство""';
						  	  							|en = 'Изменение валюты запрещено, так как есть проведенные документы в подсистемах ""Бюджетирование"" и ""Казначейство""'");
		Элементы.НадписьПредупреждение.ЦветТекста = ЦветаСтиля.бит_ЦветТекстаКрасный;
	Иначе
		Элементы.ВалютаУправленческогоУчета.ТолькоПросмотр = бит_ОбщегоНазначения.ЭтоСемействоERP();
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписки()

	Список = бит_ЛицензированиеБФСерверПереопределяемый.ВерсииПродуктов();
	Список.Вставить(0,"", "АВТО");
	Для каждого Элемент Из Список Цикл	
		Элементы.ТекущаяВерсияПродукта.СписокВыбора.Добавить(Элемент.Значение, Элемент.Представление);	
	КонецЦикла; 

КонецПроцедуры

&НаСервере
Функция ТекущаяВерсияПродуктаПриИзмененииНаСервере()
	
	Успех = бит_ЛицензированиеБФСерверПереопределяемый.УстановитьВерсиюРешения(ТекущаяВерсияПродукта);
	
	ТекущаяВерсияПродукта = Константы.бит_ТекущаяВерсияПродукта.Получить();
	
	ОбъектПроверки = Метаданные.Константы.бит_ПолучатьИнформациюОтБотаТелеграм;
	Если ИспользоватьТелеграм
		И НЕ ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектПроверки) Тогда
		ОповещенияВТелеграмОНовыхВизах = Ложь;
		ИспользоватьТелеграм           = Ложь;
		Константы.бит_ОповещенияВТелеграмОНовыхВизах.Установить(ОповещенияВТелеграмОНовыхВизах);
		Константы.бит_ПолучатьИнформациюОтБотаТелеграм.Установить(ИспользоватьТелеграм);
	КонецЕсли;
	
	ОбъектПроверки = Метаданные.Константы.бит_ИспользоватьЭлектроннуюПочтуДляВизирования;
	Если ИспользоватьЭлектроннуюПочтуДляВизирования
		И НЕ ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектПроверки) Тогда
		ИспользоватьЭлектроннуюПочтуДляВизирования = Ложь;
		Константы.бит_ИспользоватьЭлектроннуюПочтуДляВизирования.Установить(ИспользоватьЭлектроннуюПочтуДляВизирования);
	КонецЕсли;
	
	УправлениеГруппойИспользоватьФиксациюБюджета();
	УправлениеВидимостьюДоступностью();
	Если Успех Тогда
		ПрочитатьДанныеКонстант();
	КонецЕсли;
	
	Возврат Успех;
	
КонецФункции

&НаСервере
Процедура ПеренестиНастройкиФиксацииБюджетаНаСервере()
	
	Справочники.бит_КлючиСценарийЦФО.ПеренестиНастойкиФиксации();
	
КонецПроцедуры

&НаСервере
Функция ЕстьНастройкиФиксацииБюджета()

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	бит_ГраницыФиксацииБюджета.Сценарий КАК Сценарий,
	|	бит_ГраницыФиксацииБюджета.ЦФО КАК ЦФО,
	|	бит_ГраницыФиксацииБюджета.ДатаФиксации КАК ДатаФиксации
	|ИЗ
	|	РегистрСведений.бит_ГраницыФиксацииБюджета КАК бит_ГраницыФиксацииБюджета";
	
	РезультатЗапроса = Запрос.Выполнить();

	Возврат НЕ РезультатЗапроса.Пустой();
	
КонецФункции

&НаСервере
Процедура УправлениеГруппойИспользоватьФиксациюБюджета()

	Если ПолучитьФункциональнуюОпцию("бит_СТ") Тогда
		
		ДатыЗапретаИзмененияДоступны 	 = ПравоДоступа("Изменение", Метаданные.РегистрыСведений.ДатыЗапретаИзменения);
		ЕстьНастройкиФиксации 			 = Ложь;
		
		// См. бит_ДатыЗапретаИзмененияБФ.ПриЗаполненииРазделовДатЗапретаИзменения().
		Раздел = ПланыВидовХарактеристик.РазделыДатЗапретаИзменения.ПолучитьСсылку(Новый УникальныйИдентификатор("cb9767ea-9c3f-4328-9140-64b3ffea3089"));
		
		Если ДатыЗапретаИзмененияДоступны И ИспользоватьДатыЗапретаИзменения И ЗначениеЗаполнено(Раздел) 
			И ПолучитьФункциональнуюОпцию("бит_СТ") Тогда
			ЕстьНастройкиФиксации = ЕстьНастройкиФиксацииБюджета();
		КонецЕсли;
		
		Если ДатыЗапретаИзмененияДоступны Тогда
			Элементы.НастроитьДатыЗапретаИзменения.Доступность 	 = ИспользоватьДатыЗапретаИзменения;
			Элементы.ПеренестиНастройкиФиксацииБюджета.Видимость = ЕстьНастройкиФиксации;
		Иначе	
			Элементы.ИспользоватьДатыЗапретаИзменения.Видимость  = Ложь;
			Элементы.НастроитьДатыЗапретаИзменения.Видимость 	 = Ложь;
			Элементы.ПеренестиНастройкиФиксацииБюджета.Видимость = Ложь;
		КонецЕсли;
	Иначе 
		Элементы.ИспользоватьДатыЗапретаИзменения.Видимость  = Ложь;
		Элементы.НастроитьДатыЗапретаИзменения.Видимость 	 = Ложь;
		Элементы.ПеренестиНастройкиФиксацииБюджета.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИнтерфейсПрограммы()
	
	Если ОбновитьИнтерфейс = Истина Тогда
		ОбновитьИнтерфейс = Ложь;
		ОбщегоНазначенияКлиент.ОбновитьИнтерфейсПрограммы();
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция УстановитьМонопольныйРежимСервер(Режим)
	
	Результат = Истина;
	Если МонопольныйРежим() <> Режим Тогда
		Попытка
			УстановитьМонопольныйРежим(Режим);
		Исключение
			Результат = Ложь;
			ТекстСообщения = НСтр("ru = 'Невозможно изменить версию системы лицензирования, в программе работают другие пользователи. Требуется монопольный доступ.';
								|en = 'It is impossible to change the version of the licensing system, other users work in the program. Requires exclusive access.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		КонецПопытки;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти