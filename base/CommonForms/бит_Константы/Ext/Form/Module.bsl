&НаКлиенте
Процедура ТекущаяВерсияПродуктаПриИзменении(Элемент)

	Успех = ТекущаяВерсияПродуктаПриИзмененииНаСервере();
		
	Если Успех Тогда
		бит_РаботаСДиалогамиКлиент.ОбновитьИнтерфейсПользователя();
		Если СистемаЛицензирования = 2 Тогда
			// Оповещение обработки клиента лицензирования об изменении версии продукта, для обновления состояния.
			Оповестить("сл2_ПереключенаВерсияПродукта");	
		КонецЕсли;
	Иначе
		ТекстСообщения = НСтр("ru='Выбранная версия продукта не доступна в ""БИТ.Сервере лицензий"".';
								|en='The selected version of the product is not available in ""BIT.Servere License"".'");
		ПоказатьПредупреждение(,ТекстСообщения);
	КонецЕсли; 

КонецПроцедуры

