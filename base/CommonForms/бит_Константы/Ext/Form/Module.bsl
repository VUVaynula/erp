//
&НаКлиенте
Процедура ПеренестиНастройкиФиксацииБюджетаЗавершение(Результат, Дополнительно) Экспорт

	Если Результат = КодВозвратаДиалога.Да Тогда
		ПеренестиНастройкиФиксацииБюджетаНаСервере();
		ТекстСообщения = НСтр("ru = 'Настройки перенесены'");
		Пояснение	   = НСтр("ru = 'Проверить даты запрета изменения'"); 
		ПоказатьОповещениеПользователя(ТекстСообщения, 
			"e1cib/command/РегистрСведений.ДатыЗапретаИзменения.Команда.ДатыЗапретаИзмененияДанных", Пояснение);
	КонецЕсли;

