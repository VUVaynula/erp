// Обработчик завершения выбора диалога вопрос.
//  См. Синтакс-помощник: ПоказатьВопрос().
//
&НаКлиенте
Процедура СистемаЛицензированияЗавершение(Ответ, ДополнительныеДанные) Экспорт
	
	ОчиститьСообщения();
	Если Ответ = КодВозвратаДиалога.Да Тогда
		Результат = СистемаЛицензированияПриИзмененииНаСервере();
		Если Результат Тогда
			ЗавершитьРаботуСистемы(Ложь, Истина)
		КонецЕсли;
	Иначе
		Если СистемаЛицензирования = 1 Тогда
			СистемаЛицензирования = 2;
		Иначе	
			СистемаЛицензирования = 1;
		КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция СистемаЛицензированияПриИзмененииНаСервере()
	
	Результат = УстановитьМонопольныйРежимСервер(Истина);
	Если Результат Тогда
		Если СистемаЛицензирования = 1 Тогда
			Константы.бит_СистемаЛицензирования10.Установить(Истина);
		Иначе	
			Константы.бит_СистемаЛицензирования20.Установить(Истина);
		КонецЕсли;
	Иначе
		Если СистемаЛицензирования = 1 Тогда
			СистемаЛицензирования = 2;
		Иначе	
			СистемаЛицензирования = 1;
		КонецЕсли; 
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

