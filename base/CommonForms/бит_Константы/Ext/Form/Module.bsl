	ИспользоватьРазделениеДоступаНаУровнеБазы    = Константы.бит_ИспользоватьРазделениеДоступаНаУровнеБазы.Получить();
	
	ИспользоватьМДМ                            = Константы.бит_ИспользоватьМДМ.Получить();
