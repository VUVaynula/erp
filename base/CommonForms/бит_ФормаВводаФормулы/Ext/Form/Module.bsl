
#Область ОбработчикиСобытийФормы
                     
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТекстИсходный = СокрЛП(Параметры.Текст);
	
	Элементы.ПерейтиКРедакторуФормулы.Видимость = Ложь;
	
	АдресТаблицыВХранилище = "";
	
	Если Параметры.Свойство("Ссылка") И Параметры.Свойство("Владелец") Тогда
		
		РежимЗаполненияФормулы = "ДляЭлементаДанных";
		Ссылка 				   = Параметры.Ссылка;
		СпособКомпоновки 	   = Параметры.Владелец;
		
		ЗаполнитьДеревоАргументов(Ссылка, СпособКомпоновки);
		
		// Видимость элементов.
		Элементы.ТаблицаОбластей.Видимость = Ложь;
		Элементы.РедакторФормул.Видимость  = Ложь;
		
	ИначеЕсли Параметры.Свойство("АдресТаблицыВХранилище", АдресТаблицыВХранилище) 
		И ЭтоАдресВременногоХранилища(АдресТаблицыВХранилище) Тогда
		
		РежимЗаполненияФормулы = "ДляНастройкиПроизвольныхОтчетов";
		ЗначениеВРеквизитФормы(ПолучитьИзВременногоХранилища(АдресТаблицыВХранилище), "ТаблицаОбластей");
		
		// Видимость элементов
		Элементы.КодНаименование.Видимость   		= Ложь;
		Элементы.ДеревоАргументов.Видимость 		= Ложь;
		Элементы.ПерейтиКРедакторуФормулы.Видимость = Истина;
	Иначе
		ТекстСообщения = НСтр("ru='Непосредственное открытие этой формы не предусмотрено.';
							  |en='You can''t open this form directly.'");
    	ВызватьИсключение ТекстСообщения;
	КонецЕсли;	
	
	Элементы.КодНаименование.Пометка = Ложь;
		
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЗаполнитьТекстФормулы();	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаАргументов

&НаКлиенте
Процедура ДеревоАргументовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Если Элементы.КодНаименование.Пометка Тогда
		УстанавливаемыйТекст = "[" + ТекущиеДанные.Наименование + "]";
	Иначе
		УстанавливаемыйТекст = "[" + ТекущиеДанные.Код + "]";
    КонецЕсли;
	
	УстановитьТекстЯчейки(УстанавливаемыйТекст);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаОбластей

&НаКлиенте
Процедура ТаблицаОбластейВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	УстановитьТекстЯчейки("[" + СокрЛП(ТекущиеДанные.ИмяОбласти) + "]");
	
КонецПроцедуры // ТаблицаОбластейВыбор()

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	
	Если РежимЗаполненияФормулы = "ДляЭлементаДанных" Тогда	
		// Для элементов данных.
		ПрефПарам = "[";
		ПостПарам = "]";
		
		ЗаменитьКодПредставление(Ложь);                             
		ТекстРезультат = ТекстФормулы.ПолучитьТекст();

		Результат = Новый Структура;
		Результат.Вставить("ТекстФормулы", ТекстФормулы.ПолучитьТекст());
		
		// Массив строк расчета.
		МассивСтрокРасчета = Новый Массив;
		ЗаполнитьМассивСтрокРасчета_ОбходДерева(ДеревоАргументов, МассивСтрокРасчета, ТекстРезультат, ПрефПарам, ПостПарам);
		
		Результат.Вставить("МассивСтрокРасчета", МассивСтрокРасчета);
		
	Иначе
		
		// Для областей настроек произвольных отчетов.
		Результат = Новый Структура();
		Результат.Вставить("ОткрытьРедакторФормул", Ложь);
		Результат.Вставить("РезультатФормула"	  , ТекстФормулы.ПолучитьТекст());
	
	КонецЕсли;    	

	Закрыть(Результат);	
	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиКРедакторуФормулы(Команда)
	
	Если ТекстИсходный = ТекстФормулы.ПолучитьТекст() Тогда
		
		// Для областей настроек произвольных отчетов.
		Результат = Новый Структура();
		Результат.Вставить("ОткрытьРедакторФормул", Истина);
		Результат.Вставить("РезультатФормула"	  , ТекстФормулы.ПолучитьТекст());
		Закрыть(Результат);
		
	Иначе
		
		Оповещение = Новый ОписаниеОповещения("ПерейтиКРедакторуФормулыЗавершение", ЭтотОбъект);
		ТекстВопроса = НСтр("ru='Для перехода к редактору требуется сохранить формулу. Продолжить?';
							|en='To go to the editor, you need to save the formula. Proceed?'");
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 15, КодВозвратаДиалога.Нет);
		
	КонецЕсли;

КонецПроцедуры

// Процедура обработчик оповещения "ПерейтиКРедакторуФормулыЗавершение".
// 
// Параметры:
// Ответ 				   - КодВозвратаДиалога.
// ДополнительныеПараметры - Структура.
// 
&НаКлиенте
Процедура ПерейтиКРедакторуФормулыЗавершение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		// Для областей настроек произвольных отчетов.
		Результат = Новый Структура();
		Результат.Вставить("ОткрытьРедакторФормул", Истина);
		Результат.Вставить("РезультатФормула"	  , ТекстФормулы.ПолучитьТекст());
		Закрыть(Результат);
		
	КонецЕсли;
	
КонецПроцедуры

