	ЗаменитьКодПредставление(Элементы.КодНаименование.Пометка);

КонецПроцедуры

&НаКлиенте
Процедура РедакторФормул(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВладелецИмяФормы", ИмяФормы);
	
	ВыбранныеОбласти = Новый СписокЗначений;
	Если Элементы.ТаблицаОбластей.Видимость Тогда
		Для каждого СтрокаПараметра Из ТаблицаОбластей Цикл
			ВыбранныеОбласти.Добавить("["+СтрокаПараметра.ИмяОбласти+"]");
		КонецЦикла;
	Иначе	
		// Для справочника бит_ЭлементыДанных.
		ДобавитьВыбранныеОбластиИзДереваАргументов(ВыбранныеОбласти, ДеревоАргументов);		
	КонецЕсли;	
	
	ПараметрыФормы.Вставить("ВыбранныеОбласти", ВыбранныеОбласти);	
	ОповещениеЗакрытияФормы = Новый ОписаниеОповещения("ФормыВводаФункцииЗавершение", ЭтотОбъект);
	ОткрытьФорму("ОбщаяФорма.бит_ФормаВводаФункции", ПараметрыФормы, ЭтотОбъект,,,, ОповещениеЗакрытияФормы, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

// Процедура обработчик оповещения "ФормыВводаФункцииЗавершение".
//
// Параметры:
// Ответ - Структура
// ДополнительныеДанные - Произвольный.
//
&НаКлиенте
Процедура ФормыВводаФункцииЗавершение(Результат, ДополнительныеДанные) Экспорт
	
	Если Результат <> Неопределено Тогда
		Элементы.ТекстФормулы.ВыделенныйТекст = Результат;
	КонецЕсли;
	
КонецПроцедуры

