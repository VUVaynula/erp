
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.КонтекстныйВызов Тогда
		Элементы.Организация.ТолькоПросмотр      = Истина;
		Элементы.Организация.РежимВыбораИзСписка = Ложь;
		Элементы.Организация.КнопкаВыбора        = Ложь;
	КонецЕсли;
	
	ОписатьНастройкиУчета();
	
	Если ЗначениеЗаполнено(Параметры.СтруктурноеПодразделение) Тогда
		Организация = Параметры.СтруктурноеПодразделение;
	КонецЕсли;
	
	ТекущаяДата   = ОбщегоНазначения.ТекущаяДатаПользователя();
	ДатаИзменения = ТекущаяДата;
	
	ПравоРедактированияНастроек =
		ПравоДоступа("Изменение", Метаданные.РегистрыСведений.бит_НастройкиБюджетирования)
			И ПравоДоступа("Изменение", Метаданные.РегистрыСведений.бит_НастройкиКазначейства)
			И ПравоДоступа("Изменение", Метаданные.РегистрыСведений.бит_НастройкиВизирования)
			И ПравоДоступа("Изменение", Метаданные.РегистрыСведений.бит_НастройкиДоговоровИЗатрат)
			И ПравоДоступа("Изменение", Метаданные.РегистрыСведений.бит_НастройкиЗакупок)
			И ПравоДоступа("Изменение", Метаданные.РегистрыСведений.бит_НастройкиПрограммыОбщие);
			
	Если (НЕ ЗначениеЗаполнено(Организация) И Организация <> Неопределено) ИЛИ Параметры.РежимНастройки Тогда
		УстановитьДоступностьВидимостьНастроек(Ложь);
		Если НЕ ЗначениеЗаполнено(Организация) И ПравоРедактированияНастроек Тогда
			СоздатьСсылкиДляСущестующихНастроек();		
		КонецЕсли;
	Иначе
		ПодготовитьФормуНастройкиСписка();
		ПодготовитьФормуНаСервере();
	КонецЕсли;
			
	Если ЗначениеЗаполнено(Параметры.ТекущаяЗакладка) Тогда
		НайденныеЗакладки = Список.НайтиСтроки(Новый Структура("Идентификатор", Параметры.ТекущаяЗакладка));
		Если НайденныеЗакладки.Количество() <> 0 Тогда
			Элементы.Список.ТекущаяСтрока = НайденныеЗакладки[0].ПолучитьИдентификатор();
		КонецЕсли;
	КонецЕсли;
	
	УстановитьПодсказкуВводаОрганизации(ЭтотОбъект, Истина);
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Не ЗначениеЗаполнено(Организация) И Организация <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ОрганизацияНедоступна Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПустаяСтрока(РезультатБлокировки) Тогда
		ПоказатьПредупреждение( , РезультатБлокировки);
		РезультатБлокировки = "";
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Модифицированность И ЗавершениеРаботы Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если Модифицированность Тогда
		
		Отказ = Истина;
		
		ТекстВопроса = НСтр("ru = 'Данные были изменены. Сохранить изменения?'");
		Оповещение = Новый ОписаниеОповещения("ВопросПередЗакрытиемЗавершение", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ЗаписьНастройкиБюджетирования"
		ИЛИ ИмяСобытия = "ЗаписьНастройкиКазначейства"
		ИЛИ ИмяСобытия = "ЗаписьНастройкиВизирования"
		ИЛИ ИмяСобытия = "ЗаписьНастройкиДоговоровИЗатрат"
		ИЛИ ИмяСобытия = "ЗаписьНастройкиЗакупок"
		ИЛИ ИмяСобытия = "ЗаписьНастройкиПрограммыОбщие" Тогда
		
		ИмяРаздела = СтрЗаменить(ИмяСобытия, "Запись","");
		Если Параметр.Свойство("СтруктурноеПодразделение") Тогда
			Если Параметр.СтруктурноеПодразделение <> Организация Тогда
				Возврат;
			КонецЕсли;
		КонецЕсли;
		Если Параметр.Свойство("Период") Тогда
			Если Параметр.Период < ЭтотОбъект[ИмяРаздела].Период
				Или (Параметр.Период > ЭтотОбъект[ИмяРаздела].Период
					И Параметр.Период >= ТекущаяДата) Тогда
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		ПеречитатьНастройкиНаТекущуюДату(ИмяРаздела);
		
	ИначеЕсли ИмяСобытия = "Запись_Организации" Тогда
		
		// При записи новой организации необходимо добавить ее в список доступных организаций.
		ОбработкаОповещенияЗаписьОрганизации(Параметр, Источник);
		
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	НепроверяемыеРеквизиты = Новый Массив; 
	
	Если Элементы.СтраницыНастроек.ТекущаяСтраница = Элементы.Страница_НастройкиБюджетирования Тогда
		ОтражатьФакт = НЕ НастройкиБюджетирования.НеФормироватьДвиженияПоФактуАвтоматически;
		Если ОтражатьФакт И НЕ ЗначениеЗаполнено(НастройкиБюджетирования.СценарийОтраженияФактаБДДС) Тогда
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(, , 
								НСтр("ru = 'Сценарий отражения факта по бюджету'; 
								|en = 'Scenario for reflecting actual budget data'"));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , 
					"НастройкиБюджетирования.СценарийОтраженияФактаБДДС", , Отказ);
		КонецЕсли;
	КонецЕсли;
	
	Если Организация = Неопределено Тогда
		НепроверяемыеРеквизиты.Добавить("Организация");	
	КонецЕсли;
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаИзмененияНастроекОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	ПриИзмененииОрганизации();
	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Истина;
	
	Если Организация = Неопределено Тогда
		
		МенюОрганизации = Новый СписокЗначений; 
		МенюОрганизации.Добавить(1, НСтр("ru = 'Организации'"));
		МенюОрганизации.Добавить(2, НСтр("ru = 'ЦФО'"));
		МенюОрганизации.Добавить(3, НСтр("ru = 'Группы структурных подразделений'"));
		
		ПоказатьВыборИзМеню(Новый ОписаниеОповещения("ОрганизацияНачалоВыбораЗавершение", ЭтотОбъект),
			МенюОрганизации, Элементы.Организация);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияНачалоВыбораЗавершение(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Если ВыбранныйЭлемент.Значение = 1 Тогда
		ОписаниеТипов = Новый ОписаниеТипов("СправочникСсылка.Организации");
	ИначеЕсли ВыбранныйЭлемент.Значение = 2 Тогда
		ОписаниеТипов = Новый ОписаниеТипов("СправочникСсылка.Подразделения");
	ИначеЕсли ВыбранныйЭлемент.Значение = 3 Тогда
		ОписаниеТипов = Новый ОписаниеТипов("СправочникСсылка.бит_ГруппыСтруктурныхПодразделений");	
	Иначе
		ОписаниеТипов = Новый ОписаниеТипов;
	КонецЕсли;
	
	Организация = ОписаниеТипов.ПривестиЗначение(Организация);
	Элементы.Организация.ОграничениеТипа = ОписаниеТипов;
	УстановитьПодсказкуВводаОрганизации(ЭтотОбъект);
	
	УстановитьДоступностьВидимостьНастроек(Истина);
	Элементы.СтраницыНастроек.ТекущаяСтраница = Элементы.СтраницыНастроекОжидание;
	УстановитьДоступностьСписка();
	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Организация = Неопределено;
	Элементы.Организация.ОграничениеТипа = Новый ОписаниеТипов;
	УстановитьПодсказкуВводаОрганизации(ЭтотОбъект);
	
	// Организация сбрасывается в "неопределено". Читаем настройки "для всего предприятия".
	ПриИзмененииОрганизации();
	
КонецПроцедуры

#Область Бюджетирование
	
&НаКлиенте
Процедура НеФормироватьДвиженияПоФактуАвтоматическиПриИзменении(Элемент)
	
	ОтражатьФакт = НЕ НастройкиБюджетирования.НеФормироватьДвиженияПоФактуАвтоматически;
	Если НЕ ОтражатьФакт Тогда
		НастройкиБюджетирования.НеФормироватьПроводкиБюджетированияПриАвтоматическомСбореФакта = Истина;
		НастройкиБюджетирования.ФормироватьЗависимыеОборотыПриАвтоматическомСбореФакта		  = Ложь;
		НастройкиБюджетирования.ОтражатьФактБДДСНаОснованииОперУчета						   = Ложь;
	КонецЕсли;

	УправлениеФормой(ЭтотОбъект, "НастройкиБюджетирования");
	ОтобразитьПериоды("НастройкиБюджетирования");
	
КонецПроцедуры

