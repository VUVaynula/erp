
&НаКлиенте
Процедура КомандаОК(Команда)
	
	РезСтруктура = Новый Структура;
	РезСтруктура.Вставить("Значение", РеквизитЗначение);
	
	РезДействие = "";
	Если СпособИзменения = 0 Тогда
		
		РезДействие = "Установить";
		
	ИначеЕсли СпособИзменения = 1 Тогда
		
		РезДействие = "ИзменитьНаЗначение";
		
	ИначеЕсли СпособИзменения = 2 Тогда	
		
		РезДействие = "ИзменитьНаПроцент";
		
	КонецЕсли; 
	
	РезСтруктура.Вставить("Действие", РезДействие);
	Закрыть(РезСтруктура);
	
КонецПроцедуры
