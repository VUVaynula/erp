	
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РегламентноеЗадание = РегламентноеЗадание("бит_ОповещенияТелеграм");
	Если РегламентноеЗадание <> Неопределено Тогда
		ОповещенияТелеграмИспользование = РегламентноеЗадание.Использование;
		ОповещенияТелеграмРасписание   = РегламентноеЗадание.Расписание;
	КонецЕсли;
	
	РегламентноеЗадание = РегламентноеЗадание("бит_УдалениеИсторииТелеграм");
	Если РегламентноеЗадание <> Неопределено Тогда
		УдалениеИсторииТелеграмИспользование = РегламентноеЗадание.Использование;
		УдалениеИсторииТелеграмРасписание   = РегламентноеЗадание.Расписание;
	КонецЕсли;
	
	УстановитьДоступностьПредставлениеРассписаний();
	
	БотДляОповещений 	        = бит_ТелеграмПовтИсп.ГлавныйБот();
	ЕстьАдминистраторыБота      = ПроверитьНаличиеАдминистраторовБота(БотДляОповещений);
	СрокХраненияИсторииТелеграм = Константы.бит_СрокХраненияИсторииТелеграм.Получить();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УправлениеЭлементамиФормыКлиент();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура БотДляОповещенийПриИзменении(Элемент)
	
	ЕстьАдминистраторыБота 	= ПроверитьНаличиеАдминистраторовБота(БотДляОповещений);
	УстановитьБотаДляОповещений(БотДляОповещений);
	УправлениеЭлементамиФормыКлиент();
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияАдминистраторыНеНайденыНажатие(Элемент)
	
	СтрПараметров = Новый Структура("БотТелеграм", БотДляОповещений);
	Оповещение    = Новый ОписаниеОповещения("ДействияФормыНазначениеАдминистраторовЗавершение", ЭтотОбъект);
	ОткрытьФорму("РегистрСведений.бит_ЧатыДляСлужебныхОповещенийТелеграм.ФормаЗаписи", СтрПараметров,,,,,Оповещение);
	
КонецПроцедуры

// Обработчик завершения работы с формой.
//
&НаКлиенте 
Процедура ДействияФормыНазначениеАдминистраторовЗавершение(Результат, ДополнительныеДанные) Экспорт
	
	УправлениеЭлементамиФормыКлиент();
	
КонецПроцедуры

&НаКлиенте
Процедура ОповещенияТелеграмИспользованиеПриИзменении(Элемент)
	
	ЗаписатьРегламентноеЗадание("бит_ОповещенияТелеграм");
	
КонецПроцедуры

&НаКлиенте
Процедура УдалениеИсторииТелеграмИспользованиеПриИзменении(Элемент)
	
	ЗаписатьРегламентноеЗадание("бит_УдалениеИсторииТелеграм");
	
КонецПроцедуры

&НаСервере
Процедура СрокХраненияИсторииТелеграмПриИзмененииНаСервере()
	
	Если СрокХраненияИсторииТелеграм > 0 Тогда
		Константы.бит_СрокХраненияИсторииТелеграм.Установить(СрокХраненияИсторииТелеграм);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СрокХраненияИсторииТелеграмПриИзменении(Элемент)
	
	СрокХраненияИсторииТелеграмПриИзмененииНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОповещенияТелеграмНастроитьРасписание(Команда)
	
	Диалог = Новый ДиалогРасписанияРегламентногоЗадания(ОповещенияТелеграмРасписание);
	Диалог.Показать(Новый ОписаниеОповещения("ОповещенияТелеграмНастроитьРасписаниеЗавершение", ЭтотОбъект));
	
КонецПроцедуры

// Процедура обработчик оповещения "ОповещенияТелеграмНастроитьРасписание".
// 
// Параметры:
//  Расписание - РасписаниеРегламентногоЗадания.
//  ПараметрыВыполнения - Структура.
// 
&НаКлиенте
Процедура ОповещенияТелеграмНастроитьРасписаниеЗавершение(Расписание, ПараметрыВыполнения) Экспорт
	
	Если Расписание = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОповещенияТелеграмРасписание   = Расписание;
	ОповещенияТелеграмИспользование = Истина;
	ЗаписатьРегламентноеЗадание("бит_ОповещенияТелеграм");
		
КонецПроцедуры

&НаКлиенте
Процедура УдалениеИсторииТелеграмНастроитьРасписание(Команда)
	
	Диалог = Новый ДиалогРасписанияРегламентногоЗадания(УдалениеИсторииТелеграмРасписание);
	Диалог.Показать(Новый ОписаниеОповещения("УдалениеИсторииТелеграмНастроитьРасписаниеЗавершение", ЭтотОбъект));
	
КонецПроцедуры

// Процедура обработчик оповещения "ОповещенияТелеграмНастроитьРасписание".
// 
// Параметры:
//  Расписание - РасписаниеРегламентногоЗадания.
//  ПараметрыВыполнения - Структура.
// 
&НаКлиенте
Процедура УдалениеИсторииТелеграмНастроитьРасписаниеЗавершение(Расписание, ПараметрыВыполнения) Экспорт
	
	Если Расписание = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УдалениеИсторииТелеграмРасписание   = Расписание;
	УдалениеИсторииТелеграмИспользование = Истина;
	ЗаписатьРегламентноеЗадание("бит_УдалениеИсторииТелеграм");
		
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьСообщениеЧату(Команда)
	
	СтрПараметров = Новый Структура("БотТелеграм", БотДляОповещений);
	ОткрытьФорму("ОбщаяФорма.бит_ФормаОтправкиСообщенияВТелеграм", СтрПараметров);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьТокенБота(Команда)
	
	ПроверитьТокен(БотДляОповещений);
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьОповещенияНаСервере()
	
	бит_ТелеграмСервер.ОбработатьОповещенияБоту();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьОповещения(Команда)
	
	ОбработатьОповещенияНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция РегламентноеЗадание(ИмяПредопределенного)
	
	Отбор = Новый Структура;
	Отбор.Вставить("Метаданные", ИмяПредопределенного);
	Отбор.Вставить("Предопределенное", Истина);
	
	РезультатПоиска = РегламентныеЗаданияСервер.НайтиЗадания(Отбор);
	Возврат ?(РезультатПоиска.Количество() = 0, Неопределено, РезультатПоиска[0]);
	
КонецФункции

&НаСервере
Процедура ЗаписатьРегламентноеЗадание(Знач ИмяПредопределенного)
	
	Если ИмяПредопределенного = "бит_ОповещенияТелеграм" Тогда
		ЗначениеИспользование = ОповещенияТелеграмИспользование;
		ЗначениеРасписание    = ОповещенияТелеграмРасписание;
	ИначеЕсли ИмяПредопределенного = "бит_УдалениеИсторииТелеграм" Тогда
		ЗначениеИспользование = УдалениеИсторииТелеграмИспользование;
		ЗначениеРасписание    = УдалениеИсторииТелеграмРасписание;
	Иначе
		Возврат;
	КонецЕсли;
	
	РегламентноеЗадание = РегламентноеЗадание(ИмяПредопределенного);
	Если РегламентноеЗадание <> Неопределено Тогда
		ПараметрыЗадания = Новый Структура;
		ПараметрыЗадания.Вставить("Использование", ЗначениеИспользование);
		ПараметрыЗадания.Вставить("Расписание",    ЗначениеРасписание);
		
		РегламентныеЗаданияСервер.ИзменитьЗадание(РегламентноеЗадание, ПараметрыЗадания);
		УстановитьДоступностьПредставлениеРассписаний();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьПредставлениеРассписаний()
	
	Элементы.ОповещенияТелеграмНастроитьРасписание.Доступность = ОповещенияТелеграмИспользование;
	Если ОповещенияТелеграмИспользование Тогда
		РасписаниеПредставление = Строка(ОповещенияТелеграмРасписание);
		Представление = ВРег(Лев(РасписаниеПредставление, 1)) + Сред(РасписаниеПредставление, 2);
	Иначе
		Представление = "";
	КонецЕсли;
	Элементы.ОповещенияТелеграмНастроитьРасписание.Заголовок = Представление;
	
	Элементы.УдалениеИсторииТелеграмНастроитьРасписание.Доступность = УдалениеИсторииТелеграмИспользование;
	Если УдалениеИсторииТелеграмИспользование Тогда
		РасписаниеПредставление = Строка(УдалениеИсторииТелеграмРасписание);
		Представление = ВРег(Лев(РасписаниеПредставление, 1)) + Сред(РасписаниеПредставление, 2);
	Иначе
		Представление = "";
	КонецЕсли;
	Элементы.УдалениеИсторииТелеграмНастроитьРасписание.Заголовок = Представление;
	
КонецПроцедуры

&НаКлиенте
Процедура УправлениеЭлементамиФормыКлиент()

	Элементы.ДекорацияАдминистраторыНеНайдены.Видимость = НЕ ЕстьАдминистраторыБота;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПроверитьНаличиеАдминистраторовБота(Знач БотДляОповещений)

	ЕстьАдминистраторы = бит_ТелеграмСервер.ПроверитьНаличиеАдминистраторовБота(БотДляОповещений);

	Возврат ЕстьАдминистраторы;
	
КонецФункции

// Процедура выполняет проверку токена.
//
&НаСервереБезКонтекста
Процедура ПроверитьТокен(Знач БотДляОповещений)
	
	ТестоваяПроверка = Справочники.бит_БотыTelegram.ПроверитьТокен(БотДляОповещений.Токен);
	
	Если ТестоваяПроверка.Существует Тогда		
		ТекстСообщения = НСтр("ru='Проверка выполнена успешно.';en='Verification was successful.'");
	Иначе			
		ТекстСообщения = НСтр("ru='Ошибка выполнения проверки. %1.';en='Run-time error checking. %1.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%1", ТестоваяПроверка.Сообщение);		
	КонецЕсли; 
	
	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция УстановитьБотаДляОповещений(Знач БотДляОповещений)
	
	Константы.бит_БотДляОповещенийТелеграм.Установить(БотДляОповещений);
	ОбновитьПовторноИспользуемыеЗначения();
	
КонецФункции

#КонецОбласти
