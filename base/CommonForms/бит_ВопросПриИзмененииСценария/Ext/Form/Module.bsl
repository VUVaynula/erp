
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИзменитсяВалюта = Ложь;
	СпроситьОНормах = Ложь;
	Параметры.Свойство("ИзменитсяВалюта", ИзменитсяВалюта);
	Параметры.Свойство("СпроситьОНормах", СпроситьОНормах);
	
	ИзменитсяВалюта = ?(ТипЗнч(ИзменитсяВалюта) = Тип("Булево"), ИзменитсяВалюта, Ложь);
	СпроситьОНормах = ?(ТипЗнч(СпроситьОНормах) = Тип("Булево"), СпроситьОНормах, Ложь);
	
	Элементы.ПерезаполнитьНормы.Видимость = СпроситьОНормах;
	Элементы.ПересчитатьСуммы.Видимость   = ИзменитсяВалюта;
	
	ПерезаполнитьНормы = СпроситьОНормах;
	ПересчитатьСуммы   = ИзменитсяВалюта;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)
	
	РезСтр = Новый Структура("ПерезаполнитьНормы, ПересчитатьСуммы", ПерезаполнитьНормы, ПересчитатьСуммы);
	Закрыть(РезСтр);
	
КонецПроцедуры // КомандаОК()

#КонецОбласти
