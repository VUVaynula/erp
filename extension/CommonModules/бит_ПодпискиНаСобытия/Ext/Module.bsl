Процедура СинхронизацияПодчиненногоПКОПриЗаписи(Источник, Отказ)
// {{ПервыйБИТ ЛистТребований [ЛТ11.1]  [VUVaynula@1cbit.ru] [19.02.2026 17:09:12] +        
	Если Отказ Тогда 
		Возврат;
	КонецЕсли; 
	Если Источник.ДополнительныеСвойства.Свойство("СоздатьПКО") Тогда
		ПКООбъект = Документы.ПриходныйКассовыйОрдер.СоздатьДокумент();
		ПКООбъект.Заполнить(Источник.Ссылка);
		ПКООбъект.Дата = Источник.Дата;
		ПКООбъект.ХозяйственнаяОперация = Источник.ДополнительныеСвойства.СоздатьПКО;
		// заполняем как в источнике 05-03-26
		ПКООбъект.бит_Фирма = Источник.бит_Фирма;
		
		ПКООбъект.Записать(РежимЗаписиДокумента.Запись);	
	ИначеЕсли Источник.Проведен Тогда
		ПКО = НайтиПодчиненныйПКО(Источник.Ссылка);
		Если ПКО <> Неопределено Тогда
			ЕстьИзмененияСуммы = ПКО.СуммаДокумента <> Источник.СуммаДокумента;
			НадоРаспроводить = ПКО.Проведен И Источник.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствВДругуюКассу;
			
			бит_Фирма = Источник.бит_Фирма;
			НужноМенятьФирму = ПКО.бит_Фирма <> бит_Фирма;
			
			Если ЕстьИзмененияСуммы Или НадоРаспроводить или НужноМенятьФирму Тогда
				ПКООбъект = ПКО.ПолучитьОбъект(); 
				ПКООбъект.РасшифровкаПлатежа.Очистить();
				ПКООбъект.Заполнить(Источник.Ссылка);
				ПКООбъект.Дата = Источник.Дата;
				ПКООбъект.ХозяйственнаяОперация = ПКО.ХозяйственнаяОперация;
                ПКООбъект.бит_Фирма = Источник.бит_Фирма;
				
				ПКООбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			ИначеЕсли ПКО.ПометкаУдаления Тогда
				ПКООбъект = ПКО.ПолучитьОбъект();                         
				ПКООбъект.УстановитьПометкуУдаления(Ложь);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
// }}ПервыйБИТ ЛистТребований [ЛТ11.1]  [VUVaynula@1cbit.ru] [19.02.2026 17:09:12] -	
КонецПроцедуры

