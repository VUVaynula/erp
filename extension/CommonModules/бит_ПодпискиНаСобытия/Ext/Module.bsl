Процедура СинхронизацияПодчиненногоПКО(Источник, Отказ, РежимЗаписи)
// {{ПервыйБИТ ЛистТребований [ЛТ11.1]  [VUVaynula@1cbit.ru] [31.01.2026 21:34:06] +        
	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	Если Источник.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыдачаДенежныхСредствВДругуюКассу Тогда
		Работаем = Истина;
		РаспроводитьПриИзменении = Истина;
		ХозяйственнаяОперацияПКО = Перечисления.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзДругойКассы;
	ИначеЕсли Источник.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаДенежныхСредствВДругуюОрганизацию Тогда
		Работаем = Истина;
		РаспроводитьПриИзменении = Ложь;
		ХозяйственнаяОперацияПКО = Перечисления.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзДругойОрганизации;
	Иначе
		Работаем = Ложь;
	КонецЕсли;
	
	Если Работаем Тогда
		ПКО = НайтиПодчиненныйПКО(Источник.Ссылка);
		Если ПКО = Неопределено Тогда
			Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда 
				Источник.ДополнительныеСвойства.Вставить("СоздатьПКО", ХозяйственнаяОперацияПКО);
			КонецЕсли;
		ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.Запись Тогда          
			Если Источник.ПометкаУдаления <> ПКО.ПометкаУдаления Тогда
				ПКООбъект = ПКО.ПолучитьОбъект();
				ПКООбъект.УстановитьПометкуУдаления(Источник.ПометкаУдаления);
			ИначеЕсли ПКО.Проведен И Не Источник.Проведен Тогда
				ПКООбъект = ПКО.ПолучитьОбъект();
				ПКООбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			КонецЕсли;                                                
			
		ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
			ПКООбъект = ПКО.ПолучитьОбъект();
			Если ПКО.Проведен Тогда
				ПКООбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			КонецЕсли;	
			Если Источник.ПометкаУдаления <> ПКООбъект.ПометкаУдаления Тогда
				ПКООбъект.УстановитьПометкуУдаления(Источник.ПометкаУдаления);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
// }}ПервыйБИТ ЛистТребований [ЛТ11.1]  [VUVaynula@1cbit.ru] [31.01.2026 21:34:06] -	
КонецПроцедуры

Функция НайтиПодчиненныйПКО(РКОСсылка)
	// {{ПервыйБИТ ЛистТребований [ЛТ11.1]  [VUVaynula@1cbit.ru] [31.01.2026 21:37:46] +        
	Перем ПКО;
	
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	ПриходныйКассовыйОрдер.Ссылка КАК Ссылка
	                      |ИЗ
	                      |	Документ.ПриходныйКассовыйОрдер КАК ПриходныйКассовыйОрдер
	                      |ГДЕ
	                      |	ПриходныйКассовыйОрдер.ДокументОснование = &ДокументОснование");
	Запрос.УстановитьПараметр("ДокументОснование", РКОСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПКО = Выборка.Ссылка;
	КонецЕсли;
	
	Возврат ПКО;
	// }}ПервыйБИТ ЛистТребований [ЛТ11.1]  [VUVaynula@1cbit.ru] [31.01.2026 21:37:46] -
