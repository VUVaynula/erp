Функция ОпределитьФирму(Касса, Дата)
	// {{ПервыйБИТ ЛистТребований [ЛТ11.2 ЛТ11.3 дополнение]  [VUVaynula@1cbit.ru] [26.02.2026 16:46:54] +        
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	ВЫБОР
	                      |		КОГДА бит_СоответствияАналитикСрезПоследних.ЛеваяАналитика_1 = &Касса
	                      |			ТОГДА бит_СоответствияАналитикСрезПоследних.ПраваяАналитика_1
	                      |		ИНАЧЕ бит_СоответствияАналитикСрезПоследних.ЛеваяАналитика_1
	                      |	КОНЕЦ КАК ЦФО
	                      |ИЗ
	                      |	РегистрСведений.бит_СоответствияАналитик.СрезПоследних(
	                      |			&Период,
	                      |			ВидСоответствия = &ВидСоответствия И Используется
	                      |				И (ЛеваяАналитика_1 = &Касса
	                      |					ИЛИ ПраваяАналитика_1 = &Касса)) КАК бит_СоответствияАналитикСрезПоследних");
	Запрос.УстановитьПараметр("Период", Дата);                                                                                                        
	Запрос.УстановитьПараметр("Касса", Касса);
	
	ВидСоответствияЦФО_Касса = Справочники.бит_ЗначенияПоУмолчанию.ПолучитьМассивЗначений(Справочники.бит_ЗначенияПоУмолчанию.ВидСоответствияЦФО_Касса, , Истина);
	Запрос.УстановитьПараметр("ВидСоответствия", ВидСоответствияЦФО_Касса);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЦФО = Выборка.ЦФО;
	Иначе
		ЦФО = Справочники.Подразделения.ПустаяСсылка();
	КонецЕсли;
	
	Возврат ЦФО;
	// }}ПервыйБИТ ЛистТребований [ЛТ11.2 ЛТ11.3 дополнение]  [VUVaynula@1cbit.ru] [26.02.2026 16:46:54] -
