
Функция ЦФОПользователя(Знач Пользователь = Неопределено) Экспорт
	
	Если Пользователь = Неопределено Тогда
		Пользователь = Пользователи.АвторизованныйПользователь();	
	КонецЕсли;
	ЦФО = Справочники.Подразделения.ПустаяСсылка();
	Если ЗначениеЗаполнено(Пользователь.Подразделение) Тогда 
		Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
		                      |	бит_СоответствияАналитикСрезПоследних.ПраваяАналитика_1 КАК ЦФО
		                      |ИЗ
		                      |	РегистрСведений.бит_СоответствияАналитик.СрезПоследних(
		                      |			,
		                      |			Используется
		                      |				И ВидСоответствия = ЗНАЧЕНИЕ(Справочник.бит_ВидыСоответствийАналитик.СтруктураПредприятия_ЦФО)
		                      |				И ЛеваяАналитика_1 = &ПодразделениеПользователя) КАК бит_СоответствияАналитикСрезПоследних");
		Запрос.УстановитьПараметр("ПодразделениеПользователя", Пользователь.Подразделение);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда 
			ЦФО = Выборка.ЦФО;
		КонецЕсли;
	КонецЕсли;
	Возврат ЦФО;
	
КонецФункции