	Попытка
		Пока ДетальныеЗаписи.Следующий() Цикл  
			нов = ДокОбъект.ОбъектыКалькуляции.Добавить();
			ЗаполнитьЗначенияСвойств(нов, ДетальныеЗаписи);
			
			МЗ = РегистрыСведений.бит_ДатыРасчетаПлановойКалькуляцииДляНоменклатуры.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(МЗ, ДетальныеЗаписи, "Номенклатура,Характеристика");
			МЗ.Дата = ДокОбъект.Дата;
			МЗ.Записать();
		КонецЦикла;                                         
		
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);  
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		МЗ = РегистрыСведений.бит_ОшибкиАвтоматическогоСозданияПлановыхКалькуляций.СоздатьМенеджерЗаписи();
		МЗ.Дата = ДокОбъект.Дата;
		МЗ.Номенклатура = Выборка.Номенклатура;
		МЗ.Ошибка = СтрШаблон("Не удалось провести документ (%1 строк) для %2 по причине: %3", 
									ДокОбъект.ОбъектыКалькуляции.Количество(), 
									Выборка.Номенклатура.Наименование, 
									ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		МЗ.Записать();							
	КонецПопытки;
	
КонецПроцедуры
