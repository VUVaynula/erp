&НаКлиенте
Процедура ПриИзмененииНоменклатурыКлиент(Номенклатура = Неопределено)
	// {{ПервыйБИТ ЛистТребований [ЛТ6.6]  [VUVaynula@1cbit.ru] [25.03.2026 20:07:51] +        	
	ТД = Элементы[ИмяТаблицыСверхнормативные].ТекущиеДанные;
	Если ТД = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Номенклатура <> Неопределено Тогда
		ТД.Номенклатура = Номенклатура;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТД.Номенклатура) Тогда
		// проверим соответствует ли номенклатура отбору. вдруг вставили через ввод по строке
		СписокДоступных = бит_ПолучитьСписокНоменклатурыИзСтруктурыЗаказа();
		Если СписокДоступных.НайтиПоЗначению(ТД.Номенклатура) = Неопределено Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выбранная номенклатура не входит в перечень материалов структуры заказа. Значение очищено");
			ТД.Номенклатура = ПредопределенноеЗначение("Справочник.Номенклатура.ПустаяСсылка");
		КонецЕсли;
	КонецЕсли;
	// ------
	Если ЗначениеЗаполнено(ТД.Номенклатура) Тогда
		ТД.Упаковка = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(ТД.Номенклатура, "ЕдиницаИзмерения");
	Иначе
		ТД.Упаковка = ПредопределенноеЗначение("Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка");
	КонецЕсли;
	
	Если ТД.Количество = 0 Тогда
		ТД.Количество = 1;
	КонецЕсли;
	
	// После изменения номенклатуры характеристику сбрасываем
	ТД.Характеристика = ПредопределенноеЗначение("Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка");
	// Если для этой номенклатуры в структуре только одна характеристика - подставим сразу
	СписокХарактеристик = бит_ПолучитьСписокХарактеристикИзСтруктурыЗаказа(ТД.Номенклатура);
	Если СписокХарактеристик.Количество() = 1 Тогда
		ТД.Характеристика = СписокХарактеристик[0].Значение;
	КонецЕсли; 

	// пересчет                                               
	СтатьяСверхнормативное = ПолучитьЗначениеСтатьиКалькуляции(); 
	ПересчитатьСверхнормативныеМатериалыНаСервереПоСтроке( , Элементы[ИмяТаблицыСверхнормативные].ТекущаяСтрока, СтатьяСверхнормативное);
// }}ПервыйБИТ ЛистТребований [ЛТ6.6]  [VUVaynula@1cbit.ru] [25.03.2026 20:07:51] -	
КонецПроцедуры

