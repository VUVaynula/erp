		СтрОтборов.Вставить("Характеристика", СтрокаТЧ.Характеристика);
		СтрОтборов.Вставить("СтатьяКалькуляции", СтатьяСверхнормативное);
		
		Распределено = ПолучитьРаспределеноПоСтроке(СтрОтборов);
	Иначе              
		Распределено = 0;
	КонецЕсли;
	СтрокаТЧ[ИмяРеквизитаРаспределено] = Распределено;
	
	// 3. Остаток к распределению = Количество - Распределено
	СтрокаТЧ[ИмяРеквизитаОстатокКРаспределению] = Макс(0, СтрокаТЧ.Количество - СтрокаТЧ[ИмяРеквизитаРаспределено]);
