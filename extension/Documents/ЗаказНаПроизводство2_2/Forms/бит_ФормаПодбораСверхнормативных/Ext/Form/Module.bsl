		КонецЕсли; 
		
		стрОтбора = Новый Структура;
		стрОтбора.Вставить("Номенклатура");
		стрОтбора.Вставить("Характеристика");
		Для каждого стр из тзВыбранных Цикл                                                     
			стрОтбора.Номенклатура = стр.Номенклатура;
			стрОтбора.Характеристика = стр.Характеристика;

			СтрокиПоКлючу = Таблица.НайтиСтроки(стрОтбора);
			Если СтрокиПоКлючу.Количество() Тогда
				ЗаполнитьЗначенияСвойств(СтрокиПоКлючу[0], стр);
				СтрокиПоКлючу[0].Выбрано = Истина;					
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;	
	// }}ПервыйБИТ ЛистТребований [ЛТ6.6]  [VUVaynula@1cbit.ru] [25.03.2026 19:12:25] -
