	// {{ПервыйБИТ ЛистТребований [ЛТ6.6]  [VUVaynula@1cbit.ru] [25.03.2026 19:12:25] +        
	Если Параметры.Свойство("ДанныеДляЗаполнения") Тогда
		тзВыбранных = ПолучитьИзВременногоХранилища(Параметры.ДанныеДляЗаполнения.АдресВыбранных);   
		АдресПар = Параметры.ДанныеДляЗаполнения.АдресПар;
		Если АдресПар <> Неопределено Тогда
			тзПар = ПолучитьИзВременногоХранилища(АдресПар);
